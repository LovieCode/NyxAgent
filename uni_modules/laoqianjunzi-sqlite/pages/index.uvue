	line-height: 48rpx;
	font-weight: 700;
	color: #2b241c;
}

.metric-row {
	display: flex;
	flex-direction: row;
	justify-content: space-between;
	align-items: center;
}

.metric-space {
	margin-top: 24rpx;
}

