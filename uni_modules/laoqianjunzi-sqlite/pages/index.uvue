	font-size: 26rpx;
	color: #7d674e;
}

.metric-value {
	flex: 1;
	margin-left: 24rpx;
	text-align: right;
	font-size: 28rpx;
	font-weight: 600;
	color: #2b241c;
}

.field-block {
	display: flex;
	flex-direction: column;
}

.field-space {
	margin-top: 28rpx;
}

.field-label {
	font-size: 26rpx;
