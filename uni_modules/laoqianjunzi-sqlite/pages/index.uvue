	display: flex;
	flex-direction: column;
	padding-top: 32rpx;
	padding-right: 32rpx;
	padding-bottom: 32rpx;
	padding-left: 32rpx;
	border-radius: 40rpx;
	background-color: #fffaf0;
	border-width: 2rpx;
	border-style: solid;
	border-color: #dfd1b3;
}

