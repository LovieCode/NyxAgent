}

.field-input {
	margin-top: 16rpx;
	height: 80rpx;
	padding-top: 0;
	padding-right: 24rpx;
	padding-bottom: 0;
	padding-left: 24rpx;
	border-radius: 24rpx;
	background-color: #f8f1e2;
	border-width: 2rpx;
	border-style: solid;
	border-color: #dbc8a3;
	font-size: 28rpx;
	color: #2b241c;
}

.action-grid {
	display: flex;
