/**
 * agent-core SDK 入口
 *
 * 统一导出所有 Agent 核心能力：
 * - 类型定义（types.uts）
 * - 记忆系统（memory.uts）
 * - LLM 调用客户端（llm-client.uts）
 * - 提供商管理（provider.uts）
 * - Agent 工具（tools/agent-tools.uts）
 * - 事件流（通过 types.uts 的 AgentEvent）
 *
 * 索引模块（待实际迁移）：
 * - agent.uts / database.uts / skills.uts / generation-settings.uts
 */

import { ModelConfig } from './types'

// ====== 导出类型定义 ======
export {
	StopReason,
	TextContent,
	ThinkingContent,
	ToolCall,
	ImageContent,
	ContentBlock,
	UserMessage,
	AssistantMessage,
	ToolResultMessage,
	Message,
	Usage,
	ParamDef,
	ToolDefinition,
	ChatRequest,
	ChatEvent,
	AgentEvent,
	AgentEventType,
	ToolCallInfo,
	ToolResultInfo,
	AgentEventConsumer,
	ToolResult,
	AgentTool,
	ModelConfig,
} from './types'

// ====== 导出核心模块 ======
export * from './memory'
export * from './llm-client'
export * from './provider'
export * from './tools/agent-tools'

// ====== 索引模块（实现仍在 utils/，待实际迁移） ======
export * from '@/utils/agent.uts'
export * from '@/utils/database.uts'
export * from '@/utils/skills.uts'
export * from '@/utils/generation-settings.uts'

// ====== 工厂函数 ======

/**
 * 根据模型配置创建对应的 LLM Provider 实例。
 * 当前通过 llm-client.uts 的 agentChat/chatWithLLM 间接使用，
 * 工厂函数保留作为 SDK 标准接口。
 */
export function getVersion(): string {
	return "1.0.0"
}
