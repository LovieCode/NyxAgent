/**
 * 根据模型配置创建对应的 LLM Provider 实例
 * 支持 anthropic 和 openai 两种 provider 类型
 * 工厂函数放在入口文件中以避免循环依赖
 * @param config 模型配置，provider 字段决定创建哪种 Provider
 * @returns 对应的 LLMProvider 实例
 */
export function createProvider(config : ModelConfig) : LLMProvider {
	if (config.provider == 'anthropic') {
		return new AnthropicProvider(config)
	} else if (config.provider == 'openai') {
		return new OpenAIProvider(config)
	} else {
		// 默认使用 OpenAI 兼容格式（支持 GLM、DeepSeek 等）
		return new OpenAIProvider(config)
	}
}

/**
 * 获取插件版本号
 * @returns 版本号字符串
 */
export function getVersion() : string {
	return "1.0.0"
}
