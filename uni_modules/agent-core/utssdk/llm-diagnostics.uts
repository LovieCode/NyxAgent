/**
 * LLM 调用诊断与调试日志。
 *
 * 这里集中维护：
 * - 最近一次 token usage
 * - 最近一次 LLM call 摘要
 * - 最近一次真实请求快照
 * - verbose debug 日志开关
 *
 * 请求执行逻辑不要放进来，避免和 llm-client 形成循环依赖。
 */

import { addConversationTokenUsage, getAppSetting, getConversationTokenUsageStats, setAppSetting } from '@/utils/database.uts'

const LAST_TOKEN_USAGE_KEY = 'last_token_usage'
const LAST_LLM_CALL_KEY = 'last_llm_call'
const LAST_LLM_REQUEST_SNAPSHOT_KEY = 'last_llm_request_snapshot'
const LLM_DEBUG_LOG_SETTING_KEY = 'llm_debug_log_enabled'

function pad2(value: number): string {
	if (value < 10) return '0' + value.toString()
	return value.toString()
}

function formatLLMDiagnosticTime(timestamp: number): string {
	if (timestamp <= 0) return '时间未知'
	const d = new Date(timestamp)
	const year = d.getFullYear().toString()
	const month = pad2(d.getMonth() + 1)
	const day = pad2(d.getDate())
	const hour = pad2(d.getHours())
	const minute = pad2(d.getMinutes())
	const second = pad2(d.getSeconds())
	return year + '-' + month + '-' + day + ' ' + hour + ':' + minute + ':' + second
}

export function isLLMDebugLogEnabled(): boolean {
	return getAppSetting(LLM_DEBUG_LOG_SETTING_KEY) == 'true'
}

export function logLLMDebug(message: string): void {
	if (isLLMDebugLogEnabled() == true) {
		console.log(message)
	}
}

function readPromptCacheHitTokens(usage: UTSJSONObject): number | null {
	let hitTokens = usage['prompt_cache_hit_tokens'] as number | null
	if (hitTokens == null) hitTokens = usage['cache_read_input_tokens'] as number | null
	if (hitTokens == null) hitTokens = usage['prompt_cache_read_tokens'] as number | null
	if (hitTokens == null) hitTokens = usage['cached_tokens'] as number | null
	const promptDetails = usage['prompt_tokens_details'] as UTSJSONObject | null
	if (hitTokens == null && promptDetails != null) {
		hitTokens = promptDetails['cached_tokens'] as number | null
	}
	const inputDetails = usage['input_tokens_details'] as UTSJSONObject | null
	if (hitTokens == null && inputDetails != null) {
		hitTokens = inputDetails['cached_tokens'] as number | null
		if (hitTokens == null) hitTokens = inputDetails['cache_read_tokens'] as number | null
	}
	return hitTokens
}

/** 标准化 Token 用量字段，兼容 OpenAI/Anthropic 命名。 */
function normalizeTokenUsage(usage: UTSJSONObject): UTSJSONObject {
	let promptTokens = usage['prompt_tokens'] as number | null
	let completionTokens = usage['completion_tokens'] as number | null
	let totalTokens = usage['total_tokens'] as number | null
	const promptCacheHitTokens = readPromptCacheHitTokens(usage)
	if (promptTokens == null) promptTokens = usage['input_tokens'] as number | null
	if (completionTokens == null) completionTokens = usage['output_tokens'] as number | null
	if (totalTokens == null && promptTokens != null && completionTokens != null) {
		totalTokens = promptTokens + completionTokens
	}
	const obj: UTSJSONObject = {} as UTSJSONObject
	if (promptTokens != null) obj['prompt_tokens'] = promptTokens
	if (completionTokens != null) obj['completion_tokens'] = completionTokens
	if (totalTokens != null) obj['total_tokens'] = totalTokens
	if (promptCacheHitTokens != null) {
		obj['prompt_cache_hit_tokens'] = promptCacheHitTokens
		obj['prompt_cache_hit_tokens_reported'] = true
	}
	return obj
}

/** 保存最近一次 API 调用的 Token 用量。 */
export function saveLastTokenUsage(usage: UTSJSONObject): UTSJSONObject {
	const obj = normalizeTokenUsage(usage)
	const json = JSON.stringify(obj)
	setAppSetting(LAST_TOKEN_USAGE_KEY, json)
	logLLMDebug('[LLM] Token 用量已保存: ' + json)
	return obj
}

export function clearLastTokenUsage(): void {
	setAppSetting(LAST_TOKEN_USAGE_KEY, '')
}

export function readLastTokenUsageForCall(): UTSJSONObject | null {
	try {
		const rawUsage = getAppSetting(LAST_TOKEN_USAGE_KEY)
		if (rawUsage != null && rawUsage != '') {
			return JSON.parse(rawUsage) as UTSJSONObject
		}
	} catch (_e: any) {}
	return null
}

function readLastLLMCallInfo(): UTSJSONObject | null {
	try {
		const rawCall = getAppSetting(LAST_LLM_CALL_KEY)
		if (rawCall != null && rawCall != '') {
			return JSON.parse(rawCall) as UTSJSONObject
		}
	} catch (_e: any) {}
	return null
}

function buildScopedLLMStorageKey(baseKey: string, agentId: string, conversationId: string): string {
	const aid = agentId.trim()
	const cid = conversationId.trim()
	if (aid == '' && cid == '') {
		return baseKey
	}
	return baseKey + '_' + aid + '_' + cid
}

function cloneJsonObject(obj: UTSJSONObject): UTSJSONObject {
	return JSON.parse(JSON.stringify(obj)) as UTSJSONObject
}

export function saveLastLLMRequestSnapshot(
	baseUrl: string,
	url: string,
	model: string,
	body: UTSJSONObject,
	messageCount: number,
	toolCount: number,
	streamEnabled: boolean,
	cacheKey: string,
	agentId: string,
	conversationId: string,
	workspaceRoot: string
): void {
	const now = Date.now()
	const snapshot: UTSJSONObject = {
		type: 'real_llm_request_snapshot',
		capturedAt: now,
		timeText: formatLLMDiagnosticTime(now),
		agentId: agentId,
		conversationId: conversationId,
		workspaceRoot: workspaceRoot,
		baseUrl: baseUrl,
		url: url,
		model: model,
		stream: streamEnabled,
		messageCount: messageCount,
		toolCount: toolCount,
		cacheKey: cacheKey,
		requestBody: cloneJsonObject(body),
	} as UTSJSONObject
	const json = JSON.stringify(snapshot)
	setAppSetting(LAST_LLM_REQUEST_SNAPSHOT_KEY, json)
	const scopedKey = buildScopedLLMStorageKey(LAST_LLM_REQUEST_SNAPSHOT_KEY, agentId, conversationId)
	if (scopedKey != LAST_LLM_REQUEST_SNAPSHOT_KEY) {
		setAppSetting(scopedKey, json)
	}
}

export function readLastLLMRequestSnapshot(agentId: string = '', conversationId: string = ''): UTSJSONObject | null {
	try {
		const scopedKey = buildScopedLLMStorageKey(LAST_LLM_REQUEST_SNAPSHOT_KEY, agentId, conversationId)
		const raw = getAppSetting(scopedKey)
		if (raw != null && raw != '') {
			return JSON.parse(raw) as UTSJSONObject
		}
		if (scopedKey == LAST_LLM_REQUEST_SNAPSHOT_KEY) {
			return null
		}
	} catch (_e: any) {}
	return null
}

export function appendResponseToSnapshot(agentId: string, conversationId: string, responseText: string, thinkingText: string = ''): void {
	try {
		const scopedKey = buildScopedLLMStorageKey(LAST_LLM_REQUEST_SNAPSHOT_KEY, agentId, conversationId)
		const raw = getAppSetting(scopedKey)
		if (raw == null || raw == '') { return }
		const snapshot = JSON.parse(raw) as UTSJSONObject
		snapshot['responseText'] = responseText
		snapshot['thinkingText'] = thinkingText
		const usage = readLastTokenUsageForCall()
		if (usage != null) {
			snapshot['usage'] = cloneJsonObject(usage)
		}
		if (conversationId != '') {
			snapshot['conversationTokenUsageStats'] = getConversationTokenUsageStats(conversationId)
		}
		const updated = JSON.stringify(snapshot)
		setAppSetting(scopedKey, updated)
		if (scopedKey != LAST_LLM_REQUEST_SNAPSHOT_KEY) {
			setAppSetting(LAST_LLM_REQUEST_SNAPSHOT_KEY, updated)
		}
	} catch (_e: any) {}
}

export function saveLastLLMCall(
	success: boolean,
	streamEnabled: boolean,
	model: string,
	baseUrl: string,
	statusCode: number,
	errorMessage: string,
	usage: UTSJSONObject | null,
	messageCount: number,
	toolCount: number,
	textLength: number,
	hasToolCalls: boolean,
	conversationId: string = ''
): void {
	const now = Date.now()
	const obj: UTSJSONObject = {
		success: success,
		stream: streamEnabled,
		model: model,
		baseUrl: baseUrl,
		statusCode: statusCode,
		errorMessage: errorMessage,
		messageCount: messageCount,
		toolCount: toolCount,
		textLength: textLength,
		hasToolCalls: hasToolCalls,
		timestamp: now,
		timeText: formatLLMDiagnosticTime(now),
	} as UTSJSONObject
	if (usage != null) {
		obj['usage'] = usage
		const cacheReported = usage['prompt_cache_hit_tokens_reported'] as boolean | null
		if (success == true && cacheReported == true && conversationId != '') {
			const promptTokens = usage['prompt_tokens'] as number | null
			const cacheHitTokens = usage['prompt_cache_hit_tokens'] as number | null
			try {
				addConversationTokenUsage(
					conversationId,
					promptTokens != null ? promptTokens : 0,
					cacheHitTokens != null ? cacheHitTokens : 0
				)
			} catch (_e: any) {}
		}
	}
	const json = JSON.stringify(obj)
	setAppSetting(LAST_LLM_CALL_KEY, json)
}

/** 格式化 body 用于日志输出（去掉 messages 字段节省空间） */
export function formatBodyForLog(body: UTSJSONObject): string {
	const logBody: UTSJSONObject = {}
	const msgs = body['messages'] as UTSJSONObject[] | null
	if (msgs != null) {
		logBody['messages'] = '[' + msgs.length + ' messages]'
	}
	const modelVal = body['model'] as string | null
	if (modelVal != null) logBody['model'] = modelVal
	const maxTokens = body['max_tokens'] as number | null
	if (maxTokens != null) logBody['max_tokens'] = maxTokens
	const temperature = body['temperature'] as number | null
	if (temperature != null) logBody['temperature'] = temperature
	const stream = body['stream'] as boolean | null
	if (stream != null) logBody['stream'] = stream
	const cacheKey = body['cache_key'] as string | null
	if (cacheKey != null) logBody['cache_key'] = cacheKey
	const thinking = body['thinking'] as UTSJSONObject | null
	if (thinking != null) logBody['thinking'] = thinking
	const reasoningEffort = body['reasoning_effort'] as string | null
	if (reasoningEffort != null) logBody['reasoning_effort'] = reasoningEffort
	return JSON.stringify(logBody)
}

export function readLastLLMPreviewState(conversationId: string): UTSJSONObject {
	return {
		lastTokenUsage: readLastTokenUsageForCall(),
		lastCallInfo: readLastLLMCallInfo(),
		conversationTokenUsageStats: getConversationTokenUsageStats(conversationId),
	} as UTSJSONObject
}
