/**
 * Agent 记忆系统（SDK 模块）
 * - 短缓存：最多 64 字，运行时临时拼接到最新用户消息，不落入消息历史。
 * - 重要信息库：按固定 scope/category 存储，受限查询/写入，不开放 raw SQL。
 *
 * 存储后端：laoqianjunzi-sqlite（agent_chat.db）
 */
import { xSqlite, SQLiteResult } from '@/uni_modules/laoqianjunzi-sqlite'

const DB_NAME = 'agent_chat.db'
const MEMORY_ENABLED_KEY = 'settings_memory_enabled'
const DEFAULT_PERSON_ID = 'default'
const DEFAULT_CONVERSATION_ID = 'global'
const BUFFER_LIMIT = 64
const CORE_CONTENT_LIMIT = 240
const CORE_INJECT_BUDGET = 800

export type MemoryCoreInput = {
	scope: string
	category: string
	content: string
	priority: number
	pinned: boolean
}

export type MemoryTarget = {
	personId: string
	label: string
}

export type MemoryCompactionCursor = {
	lastMessageKey: string
	lastMessageTimestamp: number
}

/** 记忆搜索筛选条件 */
export type MemorySearchFilter = {
	query: string           // 搜索关键词
	searchMode: string      // 'fuzzy' | 'exact' | 'prefix' | 'regex'
	scope: string           // 空字符串表示不过滤
	category: string        // 空字符串表示不过滤
	priorityMin: number     // 0 表示不过滤
	priorityMax: number     // 0 表示不过滤
	startTime: number       // 毫秒时间戳，0 表示不过滤（筛选 created_at >= startTime）
	endTime: number         // 毫秒时间戳，0 表示不过滤（筛选 created_at <= endTime）
	limit: number           // 返回条数
}

function getDb(): xSqlite {
	const db = new xSqlite()
	db.createDb(DB_NAME)
	return db
}

function rowsToObjects(result: SQLiteResult): UTSJSONObject[] {
	const rows = result.rows
	const columns = result.columns
	if (rows == null || columns == null || rows.length == 0) {
		return []
	}
	const list: UTSJSONObject[] = []
	for (let r = 0; r < rows.length; r++) {
		const row = rows[r]
		const obj: UTSJSONObject = {}
		for (let c = 0; c < columns.length; c++) {
			const colName = columns[c]
			const value = row[c]
			if (value != null) {
				obj[colName] = value
			}
		}
		list.push(obj)
	}
	return list
}

export function initMemoryTables(): void {
	const db = getDb()
	db.run(
		'CREATE TABLE IF NOT EXISTS memory_buffer (' +
		'id TEXT PRIMARY KEY,' +
		'agent_id TEXT NOT NULL DEFAULT \'\',' +
		'person_id TEXT NOT NULL DEFAULT \'\',' +
		'conversation_id TEXT NOT NULL DEFAULT \'\',' +
		'content TEXT NOT NULL DEFAULT \'\',' +
		'updated_at INTEGER NOT NULL DEFAULT 0)'
	)
	db.run(
		'CREATE TABLE IF NOT EXISTS agent_memory_core (' +
		'id TEXT PRIMARY KEY,' +
		'agent_id TEXT NOT NULL DEFAULT \'\',' +
		'person_id TEXT NOT NULL DEFAULT \'\',' +
		'conversation_id TEXT NOT NULL DEFAULT \'\',' +
		'category TEXT NOT NULL DEFAULT \'important\',' +
		'scope TEXT NOT NULL DEFAULT \'manual_only\',' +
		'content TEXT NOT NULL DEFAULT \'\',' +
		'priority INTEGER NOT NULL DEFAULT 3,' +
		'confidence INTEGER NOT NULL DEFAULT 80,' +
		'pinned INTEGER NOT NULL DEFAULT 0,' +
		'archived INTEGER NOT NULL DEFAULT 0,' +
		'created_at INTEGER NOT NULL DEFAULT 0,' +
		'updated_at INTEGER NOT NULL DEFAULT 0,' +
		'last_used_at INTEGER NOT NULL DEFAULT 0,' +
		'use_count INTEGER NOT NULL DEFAULT 0)'
	)
	db.run(
		'CREATE TABLE IF NOT EXISTS agent_memory_manager_logs (' +
		'id TEXT PRIMARY KEY,' +
		'agent_id TEXT NOT NULL DEFAULT \'\',' +
		'conversation_id TEXT NOT NULL DEFAULT \'\',' +
		'executed_at INTEGER NOT NULL DEFAULT 0,' +
		'dropped_count INTEGER NOT NULL DEFAULT 0,' +
		'saved_count INTEGER NOT NULL DEFAULT 0,' +
		'forgotten_count INTEGER NOT NULL DEFAULT 0,' +
		'summary TEXT NOT NULL DEFAULT \'\',' +
		'details TEXT NOT NULL DEFAULT \'\')'
	)
	db.run(
		'CREATE TABLE IF NOT EXISTS agent_memory_compaction_state (' +
		'id TEXT PRIMARY KEY,' +
		'agent_id TEXT NOT NULL DEFAULT \'\',' +
		'conversation_id TEXT NOT NULL DEFAULT \'\',' +
		'last_message_key TEXT NOT NULL DEFAULT \'\',' +
		'last_message_timestamp INTEGER NOT NULL DEFAULT 0,' +
		'updated_at INTEGER NOT NULL DEFAULT 0)'
	)
	db.close()
}

export function getMemoryEnabled(): boolean {
	const raw = uni.getStorageSync(MEMORY_ENABLED_KEY) as string | null
	if (raw == null || raw == '') {
		return true
	}
	return raw == 'true'
}

export function setMemoryEnabled(enabled: boolean): void {
	uni.setStorageSync(MEMORY_ENABLED_KEY, enabled ? 'true' : 'false')
}

export function normalizeMemoryPersonId(personId: string): string {
	const trimmed = personId.trim()
	if (trimmed == '') {
		return DEFAULT_PERSON_ID
	}
	return trimmed
}

function sanitizeTargetPart(text: string): string {
	let result = text.trim()
	result = result.replace(/:/g, '-')
	result = result.replace(/\n/g, ' ')
	result = result.replace(/\r/g, ' ')
	if (result.length > 64) {
		result = result.substring(0, 64)
	}
	return result
}

export function buildMemoryTargetPersonId(targetType: string, targetId: string): string {
	const typeText = targetType.trim()
	const idText = sanitizeTargetPart(targetId)
	if (typeText == 'user') {
		if (idText == '' || idText == DEFAULT_PERSON_ID) return DEFAULT_PERSON_ID
		return 'user:' + idText
	}
	if (typeText == 'agent') {
		if (idText == '') return DEFAULT_PERSON_ID
		return 'agent:' + idText
	}
	if (typeText == 'custom') {
		if (idText == '') return DEFAULT_PERSON_ID
		return 'custom:' + idText
	}
	return normalizeMemoryPersonId(targetId)
}

export function memoryPersonIdToLabel(personId: string): string {
	const value = normalizeMemoryPersonId(personId)
	if (value == DEFAULT_PERSON_ID) return '当前用户'
	if (value.startsWith('agent:')) return 'Agent：' + value.substring(6)
	if (value.startsWith('user:')) return '用户：' + value.substring(5)
	if (value.startsWith('custom:')) return '对象：' + value.substring(7)
	return value
}

function normalizeConversationId(conversationId: string): string {
	const trimmed = conversationId.trim()
	if (trimmed == '') {
		return DEFAULT_CONVERSATION_ID
	}
	return trimmed
}

function normalizeAgentId(agentId: string): string {
	const trimmed = agentId.trim()
	if (trimmed == '') {
		return 'default_agent'
	}
	return trimmed
}

function trimToLimit(text: string, limit: number): string {
	const trimmed = text.trim()
	if (trimmed.length <= limit) {
		return trimmed
	}
	return trimmed.substring(0, limit)
}

function makeBufferId(agentId: string, personId: string, conversationId: string): string {
	return normalizeAgentId(agentId) + '::' + normalizeMemoryPersonId(personId) + '::' + normalizeConversationId(conversationId)
}

function makeCompactionStateId(agentId: string, conversationId: string): string {
	return normalizeAgentId(agentId) + '::' + normalizeConversationId(conversationId)
}

function isValidScope(scope: string): boolean {
	return scope == 'always' || scope == 'person_only' || scope == 'conversation_only' || scope == 'manual_only' || scope == 'rule'
}

function normalizeScope(scope: string): string {
	const value = scope.trim()
	if (isValidScope(value)) {
		return value
	}
	return 'manual_only'
}

function normalizeCategory(category: string): string {
	const value = category.trim()
	if (value == 'impression' || value == 'important' || value == 'rule' || value == 'preference' || value == 'fact') {
		return value
	}
	return 'important'
}

function clampPriority(priority: number): number {
	if (priority < 1) return 1
	if (priority > 5) return 5
	return priority
}

/**
 * 重要记忆数量限制按“可见/注入范围桶”裁剪：
 * - always/rule：Agent 全局桶，所有对象共享。
 * - person_only/manual_only：按 person_id 独立，不同用户/Agent/自定义对象互不挤占。
 * - conversation_only：按 conversation_id 独立。
 */
function getScopeLimit(scope: string): number {
	if (scope == 'rule') return 5
	if (scope == 'always') return 3
	if (scope == 'person_only') return 8
	if (scope == 'conversation_only') return 5
	if (scope == 'manual_only') return 30
	return 10
}

function appendMemoryLine(lines: string[], line: string, budgetRef: number[]): void {
	if (line == '') return
	if (budgetRef[0] <= 0) return
	let finalLine = line
	if (finalLine.length > budgetRef[0]) {
		finalLine = finalLine.substring(0, budgetRef[0])
	}
	lines.push(finalLine)
	budgetRef[0] = budgetRef[0] - finalLine.length
}

function readStringField(obj: UTSJSONObject, key: string): string {
	const value = obj[key] as string | null
	if (value == null) return ''
	return value
}

function readNumberField(obj: UTSJSONObject, key: string): number {
	const value = obj[key] as number | null
	if (value == null) return 0
	return value
}

function buildLikeQuery(query: string): string {
	const trimmed = query.trim()
	if (trimmed == '') {
		return '%'
	}
	return '%' + trimmed + '%'
}

/** 构建前缀匹配 LIKE 模式 */
function buildPrefixQuery(query: string): string {
	const trimmed = query.trim()
	if (trimmed == '') {
		return '%'
	}
	return trimmed + '%'
}

/** 根据 searchMode 构建 SQL LIKE 模式，返回 [pattern, useExact] */
function buildSearchPattern(query: string, searchMode: string): string[] {
	const trimmed = query.trim()
	if (trimmed == '') {
		return ['%', 'false']
	}
	if (searchMode == 'exact') {
		return [trimmed, 'true']
	}
	if (searchMode == 'prefix') {
		return [buildPrefixQuery(trimmed), 'false']
	}
	// 'fuzzy' 和 'regex' 都用 LIKE，regex 后续在内存中二次过滤
	return [buildLikeQuery(trimmed), 'false']
}

/**
 * UTS 兼容的正则匹配检查
 * 由于 UTS 跨平台限制，动态正则表达式在不同平台表现不同。
 * 这里使用 indexOf 做基础子串匹配作为 regex 模式的降级方案，
 * 同时尝试使用字符串 match 方法进行正则匹配。
 */
function matchMemoryRegex(content: string, pattern: string): boolean {
	if (pattern == '' || content == '') return false
	// 尝试用 indexOf 做基础匹配（最兼容）
	if (content.indexOf(pattern) >= 0) return true
	// 尝试将 .* 等常见正则语法转为子串匹配
	let cleaned = pattern
	cleaned = cleaned.replace(/\.\*/g, '')
	cleaned = cleaned.replace(/\.\+/g, '')
	cleaned = cleaned.replace(/\^/g, '')
	cleaned = cleaned.replace(/\$/g, '')
	cleaned = cleaned.replace(/\\b/g, '')
	cleaned = cleaned.replace(/\\s/g, ' ')
	if (cleaned != '' && content.indexOf(cleaned) >= 0) return true
	return false
}

export function getMemoryBuffer(agentId: string, personId: string, conversationId: string): string {
	initMemoryTables()
	const db = getDb()
	const id = makeBufferId(agentId, personId, conversationId)
	const result = db.query('SELECT content FROM memory_buffer WHERE id = ? AND ? = ? LIMIT 1', [id, 1, 1])
	db.close()
	const rows = rowsToObjects(result)
	if (rows.length == 0) {
		return ''
	}
	return readStringField(rows[0], 'content')
}

export function updateMemoryBuffer(agentId: string, personId: string, conversationId: string, content: string): string {
	initMemoryTables()
	const finalContent = trimToLimit(content, BUFFER_LIMIT)
	const id = makeBufferId(agentId, personId, conversationId)
	const now = Date.now()
	const db = getDb()
	db.run(
		'INSERT OR REPLACE INTO memory_buffer (id, agent_id, person_id, conversation_id, content, updated_at) VALUES (?, ?, ?, ?, ?, ?)',
		[id, normalizeAgentId(agentId), normalizeMemoryPersonId(personId), normalizeConversationId(conversationId), finalContent, now]
	)
	db.close()
	return finalContent
}

export function clearMemoryBuffer(agentId: string, personId: string, conversationId: string): void {
	initMemoryTables()
	const db = getDb()
	db.run('DELETE FROM memory_buffer WHERE id = ? AND ? = ?', [makeBufferId(agentId, personId, conversationId), 1, 1])
	db.close()
}

function buildLimitRows(db: xSqlite, agentId: string, personId: string, conversationId: string, scope: string): UTSJSONObject[] {
	const aid = normalizeAgentId(agentId)
	const pid = normalizeMemoryPersonId(personId)
	const cid = normalizeConversationId(conversationId)
	if (scope == 'always' || scope == 'rule') {
		const result = db.query(
			'SELECT id FROM agent_memory_core WHERE archived = 0 AND agent_id = ? AND scope = ? ORDER BY pinned DESC, priority DESC, updated_at DESC',
			[aid, scope]
		)
		return rowsToObjects(result)
	} else if (scope == 'conversation_only') {
		const result = db.query(
			'SELECT id FROM agent_memory_core WHERE archived = 0 AND agent_id = ? AND conversation_id = ? AND scope = ? ORDER BY pinned DESC, priority DESC, updated_at DESC',
			[aid, cid, scope]
		)
		return rowsToObjects(result)
	}
	const result = db.query(
		'SELECT id FROM agent_memory_core WHERE archived = 0 AND agent_id = ? AND person_id = ? AND scope = ? ORDER BY pinned DESC, priority DESC, updated_at DESC',
		[aid, pid, scope]
	)
	return rowsToObjects(result)
}

function enforceCoreLimit(db: xSqlite, agentId: string, personId: string, conversationId: string, scope: string): void {
	const limit = getScopeLimit(scope)
	const rows = buildLimitRows(db, agentId, personId, conversationId, scope)
	if (rows.length <= limit) {
		return
	}
	const now = Date.now()
	for (let i = limit; i < rows.length; i++) {
		const id = readStringField(rows[i], 'id')
		if (id != '') {
			db.run('UPDATE agent_memory_core SET archived = 1, updated_at = ? WHERE id = ?', [now, id])
		}
	}
}

export function saveCoreMemory(agentId: string, personId: string, conversationId: string, input: MemoryCoreInput): string {
	initMemoryTables()
	const content = trimToLimit(input.content, CORE_CONTENT_LIMIT)
	if (content == '') {
		return ''
	}
	const scope = normalizeScope(input.scope)
	const category = normalizeCategory(input.category)
	const priority = clampPriority(input.priority)
	const pinned = input.pinned ? 1 : 0
	const aid = normalizeAgentId(agentId)
	const pid = normalizeMemoryPersonId(personId)
	const cid = normalizeConversationId(conversationId)
	const now = Date.now()
	const randomPart = Math.floor(Math.random() * 1000000)
	const id = 'mem_' + now + '_' + randomPart + '_' + content.length + '_' + priority
	const db = getDb()
	db.run(
		'INSERT OR REPLACE INTO agent_memory_core (id, agent_id, person_id, conversation_id, category, scope, content, priority, confidence, pinned, archived, created_at, updated_at, last_used_at, use_count) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, 0, ?, ?, 0, 0)',
		[id, aid, pid, cid, category, scope, content, priority, 80, pinned, now, now]
	)
	enforceCoreLimit(db, aid, pid, cid, scope)
	db.close()
	return id
}

export function archiveCoreMemory(id: string): boolean {
	if (id == '') return false
	initMemoryTables()
	const db = getDb()
	db.run('UPDATE agent_memory_core SET archived = 1, updated_at = ? WHERE id = ?', [Date.now(), id])
	db.close()
	return true
}

export function clearCoreMemoryForAgent(agentId: string, personId: string): void {
	initMemoryTables()
	const aid = normalizeAgentId(agentId)
	const pid = normalizeMemoryPersonId(personId)
	const db = getDb()
	db.run(
		'UPDATE agent_memory_core SET archived = 1, updated_at = ? WHERE agent_id = ? AND (person_id = ? OR scope = \'always\' OR scope = \'rule\')',
		[Date.now(), aid, pid]
	)
	db.close()
}

export function clearCoreMemoryForTarget(agentId: string, personId: string, conversationId: string): void {
	initMemoryTables()
	const aid = normalizeAgentId(agentId)
	const pid = normalizeMemoryPersonId(personId)
	const cid = normalizeConversationId(conversationId)
	const db = getDb()
	db.run(
		'UPDATE agent_memory_core SET archived = 1, updated_at = ? WHERE agent_id = ? AND ((person_id = ? AND (scope = \'person_only\' OR scope = \'manual_only\')) OR (conversation_id = ? AND scope = \'conversation_only\'))',
		[Date.now(), aid, pid, cid]
	)
	db.close()
}

export function listCoreMemory(agentId: string, personId: string, conversationId: string, includeManual: boolean): UTSJSONObject[] {
	initMemoryTables()
	const aid = normalizeAgentId(agentId)
	const pid = normalizeMemoryPersonId(personId)
	const cid = normalizeConversationId(conversationId)
	const db = getDb()
	if (includeManual == true) {
		const result = db.query(
			'SELECT * FROM agent_memory_core WHERE archived = 0 AND agent_id = ? AND (scope = \'always\' OR scope = \'rule\' OR person_id = ? OR conversation_id = ?) ORDER BY pinned DESC, priority DESC, updated_at DESC',
			[aid, pid, cid]
		)
		db.close()
		return rowsToObjects(result)
	}
	const result = db.query(
		'SELECT * FROM agent_memory_core WHERE archived = 0 AND agent_id = ? AND scope != \'manual_only\' AND (scope = \'always\' OR scope = \'rule\' OR person_id = ? OR conversation_id = ?) ORDER BY pinned DESC, priority DESC, updated_at DESC',
		[aid, pid, cid]
	)
	db.close()
	return rowsToObjects(result)
}

function appendScopeMemories(db: xSqlite, lines: string[], budgetRef: number[], agentId: string, personId: string, conversationId: string, scope: string): void {
	const aid = normalizeAgentId(agentId)
	const pid = normalizeMemoryPersonId(personId)
	const cid = normalizeConversationId(conversationId)
	let rows: UTSJSONObject[] = []
	if (scope == 'rule') {
		const result = db.query(
			'SELECT id, category, scope, content FROM agent_memory_core WHERE archived = 0 AND agent_id = ? AND scope = \'rule\' AND ? = ? ORDER BY pinned DESC, priority DESC, updated_at DESC LIMIT 5',
			[aid, 1, 1]
		)
		rows = rowsToObjects(result)
	} else if (scope == 'always') {
		const result = db.query(
			'SELECT id, category, scope, content FROM agent_memory_core WHERE archived = 0 AND agent_id = ? AND scope = \'always\' AND ? = ? ORDER BY pinned DESC, priority DESC, updated_at DESC LIMIT 3',
			[aid, 1, 1]
		)
		rows = rowsToObjects(result)
	} else if (scope == 'person_only') {
		const result = db.query(
			'SELECT id, category, scope, content FROM agent_memory_core WHERE archived = 0 AND agent_id = ? AND person_id = ? AND scope = \'person_only\' ORDER BY pinned DESC, priority DESC, updated_at DESC LIMIT 8',
			[aid, pid]
		)
		rows = rowsToObjects(result)
	} else {
		const result = db.query(
			'SELECT id, category, scope, content FROM agent_memory_core WHERE archived = 0 AND agent_id = ? AND conversation_id = ? AND scope = \'conversation_only\' ORDER BY pinned DESC, priority DESC, updated_at DESC LIMIT 5',
			[aid, cid]
		)
		rows = rowsToObjects(result)
	}
	const now = Date.now()
	for (let i = 0; i < rows.length; i++) {
		const content = readStringField(rows[i], 'content')
		const category = readStringField(rows[i], 'category')
		const itemScope = readStringField(rows[i], 'scope')
		const id = readStringField(rows[i], 'id')
		appendMemoryLine(lines, '- [' + itemScope + '/' + category + '] ' + content, budgetRef)
		if (id != '') {
			db.run('UPDATE agent_memory_core SET last_used_at = ?, use_count = use_count + 1 WHERE id = ?', [now, id])
		}
	}
}

export function buildImportantMemoryInjection(agentId: string, personId: string, conversationId: string): string {
	if (getMemoryEnabled() == false) {
		return ''
	}
	initMemoryTables()
	const db = getDb()
	const lines: string[] = []
	const budgetRef: number[] = [CORE_INJECT_BUDGET]
	appendScopeMemories(db, lines, budgetRef, agentId, personId, conversationId, 'rule')
	appendScopeMemories(db, lines, budgetRef, agentId, personId, conversationId, 'always')
	appendScopeMemories(db, lines, budgetRef, agentId, personId, conversationId, 'person_only')
	appendScopeMemories(db, lines, budgetRef, agentId, personId, conversationId, 'conversation_only')
	db.close()
	if (lines.length == 0) {
		return ''
	}
	return '[Agent重要信息｜非用户原文]\n' + lines.join('\n')
}

export function buildBufferInjection(agentId: string, personId: string, conversationId: string): string {
	if (getMemoryEnabled() == false) {
		return ''
	}
	const buffer = getMemoryBuffer(agentId, personId, conversationId)
	if (buffer == '') {
		return ''
	}
	return '[短记忆缓存｜非用户原文]\n' + trimToLimit(buffer, BUFFER_LIMIT)
}

export function searchCoreMemory(agentId: string, personId: string, conversationId: string, query: string, limit: number): string {
	const filter: MemorySearchFilter = {
		query: query,
		searchMode: 'fuzzy',
		scope: '',
		category: '',
		priorityMin: 0,
		priorityMax: 0,
		startTime: 0,
		endTime: 0,
		limit: limit,
	}
	const rows = searchCoreMemoryAdvanced(agentId, personId, conversationId, filter)
	if (rows.length == 0) {
		return '重要信息库：无匹配。'
	}
	const lines: string[] = ['重要信息库：']
	for (let i = 0; i < rows.length; i++) {
		lines.push((i + 1) + '. id=' + readStringField(rows[i], 'id') + ' [' + readStringField(rows[i], 'scope') + '/' + readStringField(rows[i], 'category') + '] ' + readStringField(rows[i], 'content'))
	}
	return lines.join('\n')
}

/**
 * 增强版记忆搜索——支持日期范围、scope/category/priority 筛选、多种搜索模式
 * @returns UTSJSONObject[] 结构化结果，供 UI 层使用
 */
export function searchCoreMemoryAdvanced(agentId: string, personId: string, conversationId: string, filter: MemorySearchFilter): UTSJSONObject[] {
	initMemoryTables()
	const aid = normalizeAgentId(agentId)
	const pid = normalizeMemoryPersonId(personId)
	const cid = normalizeConversationId(conversationId)

	let safeLimit = filter.limit
	if (safeLimit <= 0) safeLimit = 8
	if (safeLimit > 50) safeLimit = 50

	const searchResult = buildSearchPattern(filter.query, filter.searchMode)
	const searchPattern = searchResult[0]
	const useExact = searchResult[1] == 'true'

	const db = getDb()

	// 构建 SQL —— 基础条件
	let sql = 'SELECT * FROM agent_memory_core WHERE archived = 0 AND agent_id = ?'
	const params: any[] = []
	params.push(aid)

	// 可见范围：总是包含 always/rule + 当前 person_id/conversation_id
	sql = sql + ' AND (scope = \'always\' OR scope = \'rule\' OR person_id = ? OR conversation_id = ?)'
	params.push(pid)
	params.push(cid)

	// scope 精确筛选
	if (filter.scope != '') {
		sql = sql + ' AND scope = ?'
		params.push(filter.scope)
	}

	// category 精确筛选
	if (filter.category != '') {
		sql = sql + ' AND category = ?'
		params.push(filter.category)
	}

	// priority 范围筛选
	if (filter.priorityMin > 0) {
		sql = sql + ' AND priority >= ?'
		params.push(filter.priorityMin + '')
	}
	if (filter.priorityMax > 0) {
		sql = sql + ' AND priority <= ?'
		params.push(filter.priorityMax + '')
	}

	// 时间范围筛选（created_at 字段，毫秒时间戳）
	if (filter.startTime > 0) {
		sql = sql + ' AND created_at >= ?'
		params.push(filter.startTime + '')
	}
	if (filter.endTime > 0) {
		sql = sql + ' AND created_at <= ?'
		params.push(filter.endTime + '')
	}

	// 搜索关键词条件
	if (useExact) {
		sql = sql + ' AND content = ?'
		params.push(searchPattern)
	} else {
		sql = sql + ' AND content LIKE ?'
		params.push(searchPattern)
	}

	// 排序和限制
	sql = sql + ' ORDER BY pinned DESC, priority DESC, updated_at DESC LIMIT ' + safeLimit

	const result = db.query(sql, params)
	db.close()

	let rows = rowsToObjects(result)

	// regex 模式：SQL 用 LIKE 做初筛，内存中二次过滤
	if (filter.searchMode == 'regex' && filter.query.trim() != '') {
		const filtered: UTSJSONObject[] = []
		for (let i = 0; i < rows.length; i++) {
			const content = readStringField(rows[i], 'content')
			if (matchMemoryRegex(content, filter.query)) {
				filtered.push(rows[i])
			}
		}
		return filtered
	}

	return rows
}

export function searchConversationHistory(agentId: string, query: string, limit: number): string {
	const filter: MemorySearchFilter = {
		query: query,
		searchMode: 'fuzzy',
		scope: '',
		category: '',
		priorityMin: 0,
		priorityMax: 0,
		startTime: 0,
		endTime: 0,
		limit: limit,
	}
	const rows = searchConversationHistoryAdvanced(agentId, filter)
	if (rows.length == 0) {
		return '历史记录：无匹配。'
	}
	const lines: string[] = ['历史记录（已过滤工具调用信息）：']
	let budget = 3000
	for (let i = 0; i < rows.length; i++) {
		let content = readStringField(rows[i], 'content')
		if (content.length > 180) {
			content = content.substring(0, 180) + '...'
		}
		const line = (i + 1) + '. [' + readStringField(rows[i], 'role') + '] ' + content
		if (budget - line.length <= 0) {
			break
		}
		lines.push(line)
		budget = budget - line.length
	}
	return lines.join('\n')
}

/**
 * 增强版对话历史搜索——支持日期范围、多种搜索模式
 * @returns UTSJSONObject[] 结构化结果，供 UI 层使用
 */
export function searchConversationHistoryAdvanced(agentId: string, filter: MemorySearchFilter): UTSJSONObject[] {
	initMemoryTables()
	const aid = normalizeAgentId(agentId)

	let safeLimit = filter.limit
	if (safeLimit <= 0) safeLimit = 8
	if (safeLimit > 50) safeLimit = 50

	const searchResult = buildSearchPattern(filter.query, filter.searchMode)
	const searchPattern = searchResult[0]
	const useExact = searchResult[1] == 'true'

	const db = getDb()

	let sql = 'SELECT m.role, m.content, m.timestamp, c.title FROM messages m JOIN conversations c ON c.id = m.conversation_id WHERE c.agent_id = ? AND (m.role = \'user\' OR m.role = \'assistant\') AND m.extra NOT LIKE \'%tool_calls%\''
	const params: any[] = []
	params.push(aid)

	// 搜索关键词
	if (useExact) {
		sql = sql + ' AND m.content = ?'
		params.push(searchPattern)
	} else {
		sql = sql + ' AND m.content LIKE ?'
		params.push(searchPattern)
	}

	// 时间范围筛选（timestamp 字段，毫秒时间戳）
	if (filter.startTime > 0) {
		sql = sql + ' AND m.timestamp >= ?'
		params.push(filter.startTime + '')
	}
	if (filter.endTime > 0) {
		sql = sql + ' AND m.timestamp <= ?'
		params.push(filter.endTime + '')
	}

	sql = sql + ' ORDER BY m.timestamp DESC LIMIT ' + safeLimit

	const result = db.query(sql, params)
	db.close()

	let rows = rowsToObjects(result)

	// regex 模式：内存二次过滤
	if (filter.searchMode == 'regex' && filter.query.trim() != '') {
		const filtered: UTSJSONObject[] = []
		for (let i = 0; i < rows.length; i++) {
			const content = readStringField(rows[i], 'content')
			if (matchMemoryRegex(content, filter.query)) {
				filtered.push(rows[i])
			}
		}
		return filtered
	}

	return rows
}

export function formatCoreMemoryList(rows: UTSJSONObject[]): string {
	if (rows.length == 0) {
		return '暂无记忆。'
	}
	const lines: string[] = []
	for (let i = 0; i < rows.length; i++) {
		lines.push((i + 1) + '. id=' + readStringField(rows[i], 'id') + ' [' + readStringField(rows[i], 'scope') + '/' + readStringField(rows[i], 'category') + '] P' + readNumberField(rows[i], 'priority') + ' ' + readStringField(rows[i], 'content'))
	}
	return lines.join('\n')
}

/** 记忆管理整理日志条目 */
export type MemoryManagerLog = {
	id: string
	agentId: string
	conversationId: string
	executedAt: number
	/** 自动触发时本轮整理片段条数；手动触发时为 0 */
	messageCount: number
	savedCount: number
	forgottenCount: number
	summary: string
	details: string
}

/** 写入一条记忆管理整理日志，每个 agent 最多保留 5 条 */
export function saveMemoryManagerLog(log: MemoryManagerLog): void {
	initMemoryTables()
	const db = getDb()
	db.run(
		'INSERT INTO agent_memory_manager_logs (id, agent_id, conversation_id, executed_at, dropped_count, saved_count, forgotten_count, summary, details) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)',
		[log.id, log.agentId, log.conversationId, log.executedAt, log.messageCount, log.savedCount, log.forgottenCount, log.summary, log.details]
	)
	// 每个 agent 只保留最近 5 条，删除多余的旧记录
	db.run(
		'DELETE FROM agent_memory_manager_logs WHERE agent_id = ? AND id NOT IN (SELECT id FROM agent_memory_manager_logs WHERE agent_id = ? ORDER BY executed_at DESC LIMIT 5)',
		[log.agentId, log.agentId]
	)
	db.close()
}

/** 查询记忆管理整理日志列表（按时间倒序，最多 5 条） */
export function listMemoryManagerLogs(agentId: string, conversationId: string): UTSJSONObject[] {
	initMemoryTables()
	const aid = normalizeAgentId(agentId)
	const cid = normalizeConversationId(conversationId)
	const db = getDb()
	const result = db.query(
		'SELECT * FROM agent_memory_manager_logs WHERE agent_id = ? AND conversation_id = ? ORDER BY executed_at DESC LIMIT 5',
		[aid, cid]
	)
	db.close()
	return rowsToObjects(result)
}

export function getMemoryCompactionCursor(agentId: string, conversationId: string): MemoryCompactionCursor {
	initMemoryTables()
	const id = makeCompactionStateId(agentId, conversationId)
	const db = getDb()
	const result = db.query(
		'SELECT last_message_key, last_message_timestamp FROM agent_memory_compaction_state WHERE id = ? AND ? = ? LIMIT 1',
		[id, 1, 1]
	)
	db.close()
	const rows = rowsToObjects(result)
	if (rows.length == 0) {
		return {
			lastMessageKey: '',
			lastMessageTimestamp: 0,
		} as MemoryCompactionCursor
	}
	const row = rows[0]
	return {
		lastMessageKey: readStringField(row, 'last_message_key'),
		lastMessageTimestamp: readNumberField(row, 'last_message_timestamp'),
	} as MemoryCompactionCursor
}

export function saveMemoryCompactionCursor(agentId: string, conversationId: string, lastMessageKey: string, lastMessageTimestamp: number): void {
	initMemoryTables()
	if (lastMessageKey.trim() == '') return
	const aid = normalizeAgentId(agentId)
	const cid = normalizeConversationId(conversationId)
	const id = makeCompactionStateId(aid, cid)
	const db = getDb()
	db.run(
		'INSERT OR REPLACE INTO agent_memory_compaction_state (id, agent_id, conversation_id, last_message_key, last_message_timestamp, updated_at) VALUES (?, ?, ?, ?, ?, ?)',
		[id, aid, cid, lastMessageKey, lastMessageTimestamp, Date.now()]
	)
	db.close()
}
