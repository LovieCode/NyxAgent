/**
 * LLM Provider 类型定义
 * 参考 Pi Agent 的 @earendil-works/pi-ai 和 @earendil-works/pi-agent-core
 * 简化适配移动端 UTS 环境
 */

/** 停止原因 */
export type StopReason = "stop" | "length" | "toolUse" | "error" | "aborted"

/** 文本内容块 */
export type TextContent = {
	type : "text"
	text : string
}

/** 思考内容块 */
export type ThinkingContent = {
	type : "thinking"
	thinking : string
}

/** 工具调用内容块 */
export type ToolCall = {
	type : "toolCall"
	id : string
	name : string
	arguments : UTSJSONObject
}

/** 图片内容块 */
export type ImageContent = {
	type : "image"
	data : string
	mimeType : string
}

/** 内容块联合类型 */
export type ContentBlock = TextContent | ThinkingContent | ToolCall

/** 用户消息 */
export type UserMessage = {
	role : "user"
	content : string
	timestamp : number
}

/** 助手消息 */
export type AssistantMessage = {
	role : "assistant"
	content : ContentBlock[]
	model : string
	stopReason : StopReason
	errorMessage : string | null
	usage : Usage
	timestamp : number
}

/** 工具结果消息 */
export type ToolResultMessage = {
	role : "toolResult"
	toolCallId : string
	toolName : string
	content : string
	isError : boolean
	timestamp : number
}

/** 消息联合类型 */
export type Message = UserMessage | AssistantMessage | ToolResultMessage

/** Token 用量 */
export type Usage = {
	inputTokens : number
	outputTokens : number
}

/** 工具参数定义 */
export type ParamDef = {
	type : string
	description : string | null
	enum : string[] | null
	required : boolean | null
}

/** 工具定义（给 LLM 看） */
export type ToolDefinition = {
	name : string
	description : string
	parameters : UTSJSONObject
}

/** LLM 请求 */
export type ChatRequest = {
	model : string
	system : string
	messages : Message[]
	tools : ToolDefinition[]
	maxTokens : number
	temperature : number | null
}

/** LLM 流式事件 - 文本块 */
export type ChatEventTextDelta = {
	type : "text_delta"
	text : string
}
/** LLM 流式事件 - 思考块 */
export type ChatEventThinkingDelta = {
	type : "thinking_delta"
	thinking : string
}
/** LLM 流式事件 - 工具调用 */
export type ChatEventToolCall = {
	type : "tool_call"
	id : string
	name : string
	args : UTSJSONObject
}
/** LLM 流式事件 - 完成 */
export type ChatEventDone = {
	type : "done"
	stopReason : StopReason
	usage : Usage
}
/** LLM 流式事件 */
export type ChatEvent = ChatEventTextDelta | ChatEventThinkingDelta | ChatEventToolCall | ChatEventDone

// ====== Agent 运行时事件类型（业务层定义，4.75+） ======

/** 工具调用信息 */
export type ToolCallInfo = {
	id : string
	name : string
	arguments : string
}

/** 工具执行结果 */
export type ToolResultInfo = {
	toolCallId : string
	toolName : string
	content : string
	isError : boolean
}

/** Agent 事件类型 */
export type AgentEventType =
	| 'agent_start'
	| 'agent_end'
	| 'turn_start'
	| 'turn_end'
	| 'text_delta'
	| 'text_end'
	| 'thinking_delta'
	| 'thinking_end'
	| 'tool_call'
	| 'tool_execution_start'
	| 'tool_execution_end'
	| 'memory_organize_start'
	| 'error'

/** Agent 运行时事件（单一 type + 可选字段，UI 层消费） */
export type AgentEvent = {
	type : AgentEventType
	/** 文本增量（text_delta 时） */
	text? : string
	/** 完整文本（text_end 时） */
	fullText? : string
	/** 思考增量（thinking_delta 时） */
	thinkingText? : string
	/** 完整思考（thinking_end 时） */
	fullThinking? : string
	/** assistant 工具调用消息（tool_call 时，用于持久化上下文） */
	toolCalls? : UTSJSONObject[]
	/** 工具调用 ID */
	toolCallId? : string
	/** 工具名称 */
	toolName? : string
	/** 工具参数 */
	toolArgs? : string
	/** 工具结果 */
	toolResult? : string
	/** 工具是否出错 */
	isError? : boolean
	/** 错误信息 */
	error? : string
	/** 轻提示文本 */
	message? : string
}

/** 事件消费者回调 */
export type AgentEventConsumer = (event : AgentEvent) => void

/** 工具执行结果 */
export type ToolResult = {
	content : string
	isError : boolean
}

/** Agent 工具接口 */
export interface AgentTool {
	name : string
	description : string
	parameters : UTSJSONObject
	execute(args : UTSJSONObject) : Promise<ToolResult>
}

/** 模型配置 */
export type ModelConfig = {
	id : string
	name : string
	provider : string
	baseUrl : string
	apiKey : string
	maxTokens : number
	contextWindow : number
}
