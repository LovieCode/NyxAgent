// Agent 沙箱 + 知识工具，统一走 file-manager.uts 文件 IO

import {
	readContent,
	writeContent,
	deleteItem,
	listDir,
	createDir,
	statItem,
	exists,
	joinPath,
	getAgentDir,
	formatFileSize,
	formatTime,
} from '@/utils/file-manager.uts'
import {
	renderKnowledgeMarkdown,
	parseTodoMarkdown,
	parseNoteMarkdown,
	buildTodoMarkdown,
	buildNoteMarkdown,
} from '@/utils/markdown.uts'
import {
	searchCoreMemoryAdvanced,
	searchConversationHistoryAdvanced,
	updateMemoryBuffer,
	saveCoreMemory,
	listCoreMemory,
	archiveCoreMemory,
	formatCoreMemoryList,
	buildMemoryTargetPersonId,
	MemoryCoreInput,
	MemorySearchFilter,
} from '../memory'
import { getProviderApiConfig } from '../provider'

/** ToolResult 匹配 agent-core types */
export type ToolResult = {
	content: string
	isError: boolean
}

/** 给 LLM 的工具定义描述 */
type ToolDefinition = {
	name: string
	description: string
	parameters: UTSJSONObject
}

/** AgentTool 接口（匹配 agent-core types） */
export interface AgentTool {
	name: string
	description: string
	parameters: UTSJSONObject
	execute(args: UTSJSONObject): Promise<ToolResult>
}

/**
 * 创建绑定到指定 agent 的沙箱文件工具列表
 * @param agentId 智能体 ID
 * @returns AgentTool 数组
 */
export function createAgentTools(agentId: string, conversationId: string = '', personId: string = '', allowCoreMemoryWrite: boolean = false): AgentTool[] {
	const tools: AgentTool[] = [
		new WorkspaceFileTool(agentId) as AgentTool,
		new MemorySearchTool(agentId, conversationId, personId) as AgentTool,
		new MemoryBufferWriteTool(agentId, conversationId, personId) as AgentTool,
		new WebSearchTool() as AgentTool,
	]
	// 核心记忆增删仅限记忆管理 Agent
	if (allowCoreMemoryWrite == true) {
		tools.push(new MemoryCoreListTool(agentId, conversationId, personId) as AgentTool)
		tools.push(new MemoryCoreSaveTool(agentId, conversationId, personId) as AgentTool)
		tools.push(new MemoryCoreForgetTool() as AgentTool)
	}
	return tools
}

// ========== 工具定义 ==========

/** 拼接 agent 沙箱绝对路径，自动裁剪 LLM 可能带的 agents/<id>/ 前缀 */
function resolveAgentPath(agentId: string, relPath: string): string {
	const dir = getAgentDir(agentId)
	if (dir == '') return ''
	if (relPath == '') return dir
	// 裁剪 agents/<agentId>/ 前缀（LLM 可能沿用旧习惯传完整路径）
	const prefix = 'agents/' + agentId + '/'
	if (relPath.startsWith(prefix)) {
		relPath = relPath.substring(prefix.length)
	} else if (relPath == 'agents/' + agentId) {
		return dir
	}
	if (relPath == '') return dir
	return joinPath(dir, relPath)
}

function normalizeWorkspacePath(agentId: string, rawPath: string): string {
	let path = rawPath.trim().replace(/\\/g, '/')
	const prefix = 'agents/' + agentId + '/'
	if (path.startsWith(prefix)) {
		path = path.substring(prefix.length)
	} else if (path == 'agents/' + agentId) {
		path = ''
	}
	while (path.startsWith('/')) {
		path = path.substring(1)
	}
	while (path.endsWith('/') && path.length > 1) {
		path = path.substring(0, path.length - 1)
	}
	return path
}

function isUnsafeWorkspacePath(path: string): boolean {
	if (path.startsWith('/') || path.startsWith('file://') || path.startsWith('unifile://')) return true
	if (path.indexOf(':') >= 0) return true
	if (path == '..' || path.indexOf('../') >= 0 || path.indexOf('/..') >= 0) return true
	if (path.indexOf('..\\') >= 0 || path.indexOf('\\..') >= 0) return true
	return false
}

function isTodoPath(path: string): boolean {
	return path == 'todo.md'
}

function isNotePath(path: string): boolean {
	return path.startsWith('notes/') && path.endsWith('.md')
}

function renderKnowledgeContent(content: string): string {
	const rendered = renderKnowledgeMarkdown(content)
	let finalContent = ''
	for (let i = 0; i < rendered.length; i++) {
		const block = rendered[i]
		if (block.type == 'heading') {
			const prefix = block.level == 1 ? '# ' : block.level == 2 ? '## ' : '### '
			finalContent = finalContent + prefix + block.text + '\n'
		} else if (block.type == 'todo') {
			const box = block.checked ? '- [x]' : '- [ ]'
			finalContent = finalContent + box + ' ' + block.text + '\n'
		} else if (block.type == 'bullet') {
			finalContent = finalContent + '- ' + block.text + '\n'
		} else {
			finalContent = finalContent + block.text + '\n'
		}
	}
	return finalContent
}

function formatWorkspaceInfo(path: string, absPath: string): string {
	const info = statItem(absPath)
	const typeStr = info.isDirectory ? '目录' : '文件'
	return '路径: ' + path + '\n名称: ' + info.name + '\n类型: ' + typeStr + '\n大小: ' + formatFileSize(info.size) + '\n修改时间: ' + formatTime(info.lastModified)
}

function formatWorkspaceList(path: string, absPath: string, detail: boolean): string {
	const files = listDir(absPath)
	const lines: string[] = []
	if (path == '' || path == 'notes') {
		lines.push('路径规则：todo.md 是待办；notes/<名称>.md 是笔记；其他路径是普通文件。')
		lines.push('')
	}
	if (files.length == 0) {
		lines.push('(目录为空)')
		return lines.join('\n')
	}
	for (let i = 0; i < files.length; i++) {
		const info = files[i]
		const prefix = info.isDirectory ? '[DIR]  ' : '[FILE] '
		if (detail == true) {
			const typeStr = info.isDirectory ? '目录' : '文件'
			lines.push(prefix + info.name + ' | 类型: ' + typeStr + ' | 大小: ' + formatFileSize(info.size) + ' | 修改时间: ' + formatTime(info.lastModified))
		} else {
			if (info.isDirectory == true) {
				lines.push(prefix + info.name)
			} else {
				lines.push(prefix + info.name + ' (' + formatFileSize(info.size) + ')')
			}
		}
	}
	return lines.join('\n')
}

class WorkspaceFileTool implements AgentTool {
	name: string = 'workspace_file'
	description: string = '统一操作当前 Agent 私有工作区文件。所有 path 都相对于当前 Agent 私有目录，禁止绝对路径和 ".."。action=list/read/write/delete/info。路径语义：todo.md 是待办文件，write 时会规范为 - [ ] / - [x]；notes/<名称>.md 是笔记，write 时会规范为带标题/元信息的 Markdown；其他路径是普通文件，按原文读写。write + is_directory=true 创建目录。read 时 render=true 会把 todo/notes Markdown 转为可读文本；普通文件 render 无效果。list 空路径列根目录，path=notes 列笔记目录。delete 可删除文件或目录，谨慎使用。'
	parameters: UTSJSONObject = {
		'type': 'object',
		'properties': {
			'action': {
				'type': 'string',
				'description': '操作类型：list/read/write/delete/info'
			},
			'path': {
				'type': 'string',
				'description': '相对路径。todo.md=待办；notes/<名称>.md=笔记；其他路径=普通文件；空路径仅用于 list 根目录。不要传绝对路径或包含 ..'
			},
			'content': {
				'type': 'string',
				'description': 'write 时要写入的内容。todo.md 使用 - [ ] / - [x]；notes/*.md 可用标准 Markdown；普通文件原样写入'
			},
			'detail': {
				'type': 'boolean',
				'description': 'list 时是否显示类型、大小、修改时间，默认 false'
			},
			'is_directory': {
				'type': 'boolean',
				'description': 'write 时为 true 表示创建目录；默认 false 表示写入文件'
			},
			'render': {
				'type': 'boolean',
				'description': 'read todo.md 或 notes/*.md 时是否返回渲染后的可读文本，默认 true；false 返回原始 Markdown'
			}
		},
		'required': ['action']
	} as UTSJSONObject

	private agentId: string

	constructor(agentId: string) {
		this.agentId = agentId
	}

	execute(args: UTSJSONObject): Promise<ToolResult> {
		return new Promise<ToolResult>((resolve) => {
			const rawAction = args['action'] as string | null
			const rawPath = args['path'] as string | null
			const rawContent = args['content'] as string | null
			const rawDetail = args['detail'] as boolean | null
			const rawIsDirectory = args['is_directory'] as boolean | null
			const rawRender = args['render'] as boolean | null
			const action = rawAction != null ? rawAction.trim().toLowerCase() : ''
			const rawPathText = rawPath != null ? rawPath : ''
			if (isUnsafeWorkspacePath(rawPathText.trim().replace(/\\/g, '/')) == true) {
				resolve({ content: '非法路径：只能使用当前 Agent 工作区内的相对路径，不能使用绝对路径或 ".."', isError: true } as ToolResult)
				return
			}
			const path = normalizeWorkspacePath(this.agentId, rawPathText)
			if (action == '') {
				resolve({ content: '缺少必要参数: action，可用 list/read/write/delete/info', isError: true } as ToolResult)
				return
			}
			if (isUnsafeWorkspacePath(path) == true) {
				resolve({ content: '非法路径：只能使用当前 Agent 工作区内的相对路径，不能使用绝对路径或 ".."', isError: true } as ToolResult)
				return
			}
			const absPath = resolveAgentPath(this.agentId, path)
			if (action == 'list') {
				const listPath = path == '' ? '' : path
				const finalAbsPath = resolveAgentPath(this.agentId, listPath)
				if (listPath != '' && !exists(finalAbsPath)) {
					resolve({ content: '路径不存在: ' + listPath, isError: true } as ToolResult)
					return
				}
				if (listPath != '') {
					const info = statItem(finalAbsPath)
					if (info.isDirectory == false) {
						resolve({ content: formatWorkspaceInfo(listPath, finalAbsPath), isError: false } as ToolResult)
						return
					}
				}
				resolve({ content: formatWorkspaceList(listPath, finalAbsPath, rawDetail == true), isError: false } as ToolResult)
				return
			}
			if (path == '') {
				resolve({ content: '缺少必要参数: path', isError: true } as ToolResult)
				return
			}
			if (action == 'info') {
				if (!exists(absPath)) {
					resolve({ content: '路径不存在: ' + path, isError: true } as ToolResult)
					return
				}
				resolve({ content: formatWorkspaceInfo(path, absPath), isError: false } as ToolResult)
				return
			}
			if (action == 'read') {
				if (!exists(absPath)) {
					resolve({ content: '文件不存在或无权限访问: ' + path, isError: true } as ToolResult)
					return
				}
				const content = readContent(absPath)
				if (content == null) {
					resolve({ content: '文件读取失败: ' + path, isError: true } as ToolResult)
					return
				}
				const shouldRender = rawRender != false
				if (shouldRender == true && (isTodoPath(path) == true || isNotePath(path) == true)) {
					resolve({ content: renderKnowledgeContent(content), isError: false } as ToolResult)
					return
				}
				resolve({ content: content, isError: false } as ToolResult)
				return
			}
			if (action == 'write') {
				if (rawIsDirectory == true) {
					const result = createDir(absPath)
					resolve({
						content: result.ok ? '目录创建成功: ' + path : '目录创建失败: ' + path,
						isError: !result.ok
					} as ToolResult)
					return
				}
				if (rawContent == null) {
					resolve({ content: '缺少必要参数: content', isError: true } as ToolResult)
					return
				}
				let finalContent = rawContent != null ? rawContent : ''
				if (isTodoPath(path) == true) {
					finalContent = buildTodoMarkdown(parseTodoMarkdown(finalContent))
				} else if (isNotePath(path) == true) {
					const parsed = parseNoteMarkdown(finalContent)
					const noteTitle = parsed['title'] as string
					const noteContent = parsed['content'] as string
					finalContent = buildNoteMarkdown(noteTitle, noteContent)
				}
				const result = writeContent(absPath, finalContent)
				resolve({
					content: result.ok ? '写入成功: ' + path : '写入失败: ' + path,
					isError: !result.ok
				} as ToolResult)
				return
			}
			if (action == 'delete') {
				const result = deleteItem(absPath)
				resolve({
					content: result.ok ? '删除成功: ' + path : '删除失败: ' + path,
					isError: !result.ok
				} as ToolResult)
				return
			}
			resolve({ content: '未知 action: ' + action + '，可用 list/read/write/delete/info', isError: true } as ToolResult)
		})
	}
}

/**
 * 获取工具定义列表（用于传给 LLM 的 tools 参数）
 * @param agentId 智能体 ID
 * @returns ToolDefinition 数组
 */
export function getToolDefinitions(agentId: string, allowCoreMemoryWrite: boolean = false): ToolDefinition[] {
	const tools = createAgentTools(agentId, '', '', allowCoreMemoryWrite)
	const defs: ToolDefinition[] = []
	for (let i = 0; i < tools.length; i++) {
		defs.push({
			name: tools[i].name,
			description: tools[i].description,
			parameters: tools[i].parameters
		} as ToolDefinition)
	}
	return defs
}

/**
 * 查询记忆与历史工具
 */
class MemorySearchTool implements AgentTool {
	name: string = 'memory_search'
	description: string = '查询 Agent 可见的记忆和历史对话。只返回 user/assistant 普通文本，不包含工具调用参数、工具结果或系统隐私信息。适合在不确定用户背景、偏好、历史要求时使用。'
	parameters: UTSJSONObject = {
		'type': 'object',
		'properties': {
			'query': {
				'type': 'string',
				'description': '要查询的关键词或问题，支持 SQL LIKE 通配符 %（任意字符）和 _（单个字符），留空则返回最近记忆'
			},
			'limit': {
				'type': 'number',
				'description': '最多返回条数，1-10，默认 8'
			},
			'target_type': {
				'type': 'string',
				'description': '查询面对对象类型：user/agent/custom。默认 user'
			},
			'target_id': {
				'type': 'string',
				'description': '查询面对对象 ID 或名称。user 可留空表示当前用户；agent 填 Agent ID；custom 填对象名称'
			},
			'search_mode': {
				'type': 'string',
				'description': '搜索模式：fuzzy（模糊匹配，默认）、exact（精确匹配）、prefix（前缀匹配）、regex（正则表达式）'
			},
			'scope': {
				'type': 'string',
				'description': '按使用范围筛选：always/person_only/conversation_only/manual_only/rule。留空不过滤'
			},
			'category': {
				'type': 'string',
				'description': '按分类筛选：impression/important/rule/preference/fact。留空不过滤'
			},
			'priority_min': {
				'type': 'number',
				'description': '最小优先级 1-5。默认 0 表示不过滤'
			},
			'priority_max': {
				'type': 'number',
				'description': '最大优先级 1-5。默认 0 表示不过滤'
			},
			'start_date': {
				'type': 'string',
				'description': '开始日期，ISO 格式如 2025-06-01。只返回此日期之后创建的记忆和消息'
			},
			'end_date': {
				'type': 'string',
				'description': '结束日期，ISO 格式如 2025-06-20。只返回此日期之前创建的记忆和消息'
			}
		},
		'required': ['query']
	} as UTSJSONObject

	private agentId: string
	private conversationId: string
	private personId: string

	constructor(agentId: string, conversationId: string, personId: string) {
		this.agentId = agentId
		this.conversationId = conversationId
		this.personId = personId
	}

		execute(args: UTSJSONObject): Promise<ToolResult> {
		return new Promise<ToolResult>((resolve) => {
			const rawQuery = args['query'] as string | null
			const rawLimit = args['limit'] as number | null
			const rawTargetType = args['target_type'] as string | null
			const rawTargetId = args['target_id'] as string | null
			const rawSearchMode = args['search_mode'] as string | null
			const rawScope = args['scope'] as string | null
			const rawCategory = args['category'] as string | null
			const rawPriorityMin = args['priority_min'] as number | null
			const rawPriorityMax = args['priority_max'] as number | null
			const rawStartDate = args['start_date'] as string | null
			const rawEndDate = args['end_date'] as string | null

			const query = rawQuery != null ? rawQuery : ''
			const limit = rawLimit != null ? rawLimit : 8
			const targetPersonId = buildMemoryTargetPersonId(rawTargetType != null ? rawTargetType : 'user', rawTargetId != null ? rawTargetId : this.personId)

			const searchMode = rawSearchMode != null ? rawSearchMode : 'fuzzy'
			const startTime = this.parseDateToTimestamp(rawStartDate)
			const endTime = this.parseEndDateToTimestamp(rawEndDate)

			const filter: MemorySearchFilter = {
				query: query,
				searchMode: searchMode,
				scope: rawScope != null ? rawScope : '',
				category: rawCategory != null ? rawCategory : '',
				priorityMin: rawPriorityMin != null ? rawPriorityMin : 0,
				priorityMax: rawPriorityMax != null ? rawPriorityMax : 0,
				startTime: startTime,
				endTime: endTime,
				limit: limit,
			} as MemorySearchFilter

			const coreRows = searchCoreMemoryAdvanced(this.agentId, targetPersonId, this.conversationId, filter)
			const historyRows = searchConversationHistoryAdvanced(this.agentId, filter)
			const coreText = this.formatAdvancedCoreResult(coreRows)
			const historyText = this.formatAdvancedHistoryResult(historyRows)
			resolve({ content: coreText + '\n\n' + historyText, isError: false } as ToolResult)
		})
	}

	/** 将日期字符串解析为毫秒时间戳（当天 00:00:00） */
	private parseDateToTimestamp(dateStr: string | null): number {
		if (dateStr == null || dateStr == '') return 0
		// 尝试解析 YYYY-MM-DD 格式
		const parts = dateStr.split('-')
		if (parts.length >= 3) {
			const year = parseInt(parts[0])
			const month = parseInt(parts[1]) - 1
			const day = parseInt(parts[2])
			if (!isNaN(year) && !isNaN(month) && !isNaN(day)) {
				const d = new Date(year, month, day, 0, 0, 0, 0)
				return d.getTime()
			}
		}
		// fallback: 直接用 Date 解析
		const d = new Date(dateStr)
		const ts = d.getTime()
		return isNaN(ts) ? 0 : ts
	}

	/** 将结束日期解析为毫秒时间戳（当天 23:59:59.999） */
	private parseEndDateToTimestamp(dateStr: string | null): number {
		if (dateStr == null || dateStr == '') return 0
		const parts = dateStr.split('-')
		if (parts.length >= 3) {
			const year = parseInt(parts[0])
			const month = parseInt(parts[1]) - 1
			const day = parseInt(parts[2])
			if (!isNaN(year) && !isNaN(month) && !isNaN(day)) {
				const d = new Date(year, month, day, 23, 59, 59, 999)
				return d.getTime()
			}
		}
		const d = new Date(dateStr)
		const ts = d.getTime()
		return isNaN(ts) ? 0 : ts
	}

	/** 将高级搜索结果格式化为 LLM 可读文本 */
	private formatAdvancedCoreResult(rows: UTSJSONObject[]): string {
		if (rows.length == 0) {
			return '重要信息库：无匹配。'
		}
		const lines: string[] = ['重要信息库：']
		for (let i = 0; i < rows.length; i++) {
			const id = this.readStr(rows[i], 'id')
			const scope = this.readStr(rows[i], 'scope')
			const category = this.readStr(rows[i], 'category')
			const content = this.readStr(rows[i], 'content')
			const priority = this.readNum(rows[i], 'priority')
			const createdAt = this.readNum(rows[i], 'created_at')
			let line = (i + 1) + '. id=' + id + ' [' + scope + '/' + category + '] P' + priority + ' ' + content
			if (createdAt > 0) {
				const d = new Date(createdAt)
				line = line + ' (' + this.formatDateShort(d) + ')'
			}
			lines.push(line)
		}
		return lines.join('\n')
	}

	/** 将高级历史搜索结果格式化为 LLM 可读文本 */
	private formatAdvancedHistoryResult(rows: UTSJSONObject[]): string {
		if (rows.length == 0) {
			return '历史记录：无匹配。'
		}
		const lines: string[] = ['历史记录（已过滤工具调用信息）：']
		let budget = 3000
		for (let i = 0; i < rows.length; i++) {
			let content = this.readStr(rows[i], 'content')
			if (content.length > 180) {
				content = content.substring(0, 180) + '...'
			}
			const role = this.readStr(rows[i], 'role')
			const timestamp = this.readNum(rows[i], 'timestamp')
			let line = (i + 1) + '. [' + role + '] '
			if (timestamp > 0) {
				const d = new Date(timestamp)
				line = line + '(' + this.formatDateShort(d) + ') '
			}
			line = line + content
			if (budget - line.length <= 0) {
				break
			}
			lines.push(line)
			budget = budget - line.length
		}
		return lines.join('\n')
	}

	private readStr(obj: UTSJSONObject, key: string): string {
		const val = obj[key] as string | null
		return val != null ? val : ''
	}

	private readNum(obj: UTSJSONObject, key: string): number {
		const val = obj[key] as number | null
		return val != null ? val : 0
	}

	private formatDateShort(d: Date): string {
		const m = (d.getMonth() + 1).toString()
		const day = d.getDate().toString()
		return m + '/' + day
	}
}

/**
 * 写入 64 字短记忆缓存工具
 */
class MemoryBufferWriteTool implements AgentTool {
	name: string = 'memory_buffer_write'
	description: string = '主动写入 64 字短记忆缓存。职责范围：只标记当前正在进行的任务、临时约束、临时偏好或对话阶段状态；需要你在状态变化时主动调用更新。它不是 todo/计划工具，不能用来拆解大型任务或长期排期；大型任务规划请使用 todo。不要只写“当前时间/现在几点”等易过期时间状态；对话中提到的时间必须结合消息时间戳判断是否仍有效。不要写工具调用信息、密钥、完整日志。'
	parameters: UTSJSONObject = {
		'type': 'object',
		'properties': {
			'content': {
				'type': 'string',
				'description': '缓存内容，最多 64 字。写当前任务状态或临时记忆；不要写 todo 清单、长期计划、孤立的当前时间/现在几点、工具调用信息、密钥或完整日志。'
			}
		},
		'required': ['content']
	} as UTSJSONObject

	private agentId: string
	private conversationId: string
	private personId: string

	constructor(agentId: string, conversationId: string, personId: string) {
		this.agentId = agentId
		this.conversationId = conversationId
		this.personId = personId
	}

	execute(args: UTSJSONObject): Promise<ToolResult> {
		return new Promise<ToolResult>((resolve) => {
			const rawContent = args['content'] as string | null
			if (rawContent == null || rawContent == '') {
				resolve({ content: '缺少必要参数: content', isError: true } as ToolResult)
				return
			}
			const finalContent = updateMemoryBuffer(this.agentId, this.personId, this.conversationId, rawContent)
			resolve({ content: '短记忆缓存已更新（' + finalContent.length + '/64）：' + finalContent, isError: false } as ToolResult)
		})
	}
}

/**
 * 保存重要信息工具
 */
class MemoryCoreSaveTool implements AgentTool {
	name: string = 'memory_core_save'
	description: string = '保存 Agent 重要信息。scope 只能是 always、person_only、conversation_only、manual_only、rule；category 只能是 impression、important、rule、preference、fact。数量限制按范围桶裁剪：person_only/manual_only 按面对对象独立，conversation_only 按会话独立，always/rule 为 Agent 全局共享。面对某人的规则请用 scope=person_only + category=rule；只有全局规则才用 scope=rule。不要保存工具调用信息、密钥或流水账。'
	parameters: UTSJSONObject = {
		'type': 'object',
		'properties': {
			'content': {
				'type': 'string',
				'description': '记忆内容，建议一句话，最多约 240 字'
			},
			'scope': {
				'type': 'string',
				'description': '使用范围：always/person_only/conversation_only/manual_only/rule。person_only/manual_only 按对象独立限额；conversation_only 按会话独立限额；always/rule 为 Agent 全局共享限额'
			},
			'category': {
				'type': 'string',
				'description': '分类：impression/important/rule/preference/fact'
			},
			'priority': {
				'type': 'number',
				'description': '优先级 1-5，越高越重要，默认 3'
			},
			'pinned': {
				'type': 'boolean',
				'description': '是否置顶，默认 false'
			},
			'target_type': {
				'type': 'string',
				'description': 'person_only 面对对象类型：user/agent/custom。默认 user'
			},
			'target_id': {
				'type': 'string',
				'description': 'person_only 面对对象 ID 或名称。user 可留空表示当前用户；agent 填 Agent ID；custom 填对象名称'
			}
		},
		'required': ['content', 'scope', 'category']
	} as UTSJSONObject

	private agentId: string
	private conversationId: string
	private personId: string

	constructor(agentId: string, conversationId: string, personId: string) {
		this.agentId = agentId
		this.conversationId = conversationId
		this.personId = personId
	}

	execute(args: UTSJSONObject): Promise<ToolResult> {
		return new Promise<ToolResult>((resolve) => {
			const rawContent = args['content'] as string | null
			if (rawContent == null || rawContent == '') {
				resolve({ content: '缺少必要参数: content', isError: true } as ToolResult)
				return
			}
			const rawScope = args['scope'] as string | null
			const rawCategory = args['category'] as string | null
			const rawPriority = args['priority'] as number | null
			const rawPinned = args['pinned'] as boolean | null
			const rawTargetType = args['target_type'] as string | null
			const rawTargetId = args['target_id'] as string | null
			const scope = rawScope != null ? rawScope : 'manual_only'
			let targetPersonId = this.personId
			if (scope == 'person_only' || scope == 'manual_only') {
				targetPersonId = buildMemoryTargetPersonId(rawTargetType != null ? rawTargetType : 'user', rawTargetId != null ? rawTargetId : this.personId)
			}
			const input: MemoryCoreInput = {
				scope: scope,
				category: rawCategory != null ? rawCategory : 'important',
				content: rawContent,
				priority: rawPriority != null ? rawPriority : 3,
				pinned: rawPinned == true,
			} as MemoryCoreInput
			const id = saveCoreMemory(this.agentId, targetPersonId, this.conversationId, input)
			if (id == '') {
				resolve({ content: '记忆为空，未保存。', isError: true } as ToolResult)
				return
			}
			resolve({ content: '重要记忆已保存：' + id, isError: false } as ToolResult)
		})
	}
}

/**
 * 列出重要信息工具
 */
class MemoryCoreListTool implements AgentTool {
	name: string = 'memory_core_list'
	description: string = '列出当前 Agent 可见的重要信息库条目，供确认和整理使用。长期写入或遗忘只由记忆管理 Agent 执行。'
	parameters: UTSJSONObject = {
		'type': 'object',
		'properties': {
			'include_manual': {
				'type': 'boolean',
				'description': '是否包含 manual_only，默认 true'
			},
			'target_type': {
				'type': 'string',
				'description': '面对对象类型：user/agent/custom。默认 user'
			},
			'target_id': {
				'type': 'string',
				'description': '面对对象 ID 或名称。user 可留空表示当前用户；agent 填 Agent ID；custom 填对象名称'
			}
		},
		'required': [] as string[]
	} as UTSJSONObject

	private agentId: string
	private conversationId: string
	private personId: string

	constructor(agentId: string, conversationId: string, personId: string) {
		this.agentId = agentId
		this.conversationId = conversationId
		this.personId = personId
	}

	execute(args: UTSJSONObject): Promise<ToolResult> {
		return new Promise<ToolResult>((resolve) => {
			const rawInclude = args['include_manual'] as boolean | null
			const rawTargetType = args['target_type'] as string | null
			const rawTargetId = args['target_id'] as string | null
			const includeManual = rawInclude != null ? rawInclude : true
			const targetPersonId = buildMemoryTargetPersonId(rawTargetType != null ? rawTargetType : 'user', rawTargetId != null ? rawTargetId : this.personId)
			const rows = listCoreMemory(this.agentId, targetPersonId, this.conversationId, includeManual)
			resolve({ content: formatCoreMemoryList(rows), isError: false } as ToolResult)
		})
	}
}

/**
 * 遗忘重要信息工具
 */
class MemoryCoreForgetTool implements AgentTool {
	name: string = 'memory_core_forget'
	description: string = '按 id 归档/遗忘一条重要记忆。只能遗忘 memory_core_list 或 memory_search 返回的记忆 id。'
	parameters: UTSJSONObject = {
		'type': 'object',
		'properties': {
			'id': {
				'type': 'string',
				'description': '要遗忘的记忆 id'
			}
		},
		'required': ['id']
	} as UTSJSONObject

	execute(args: UTSJSONObject): Promise<ToolResult> {
		return new Promise<ToolResult>((resolve) => {
			const id = args['id'] as string | null
			if (id == null || id == '') {
				resolve({ content: '缺少必要参数: id', isError: true } as ToolResult)
				return
			}
			const ok = archiveCoreMemory(id)
			resolve({ content: ok ? '已遗忘记忆：' + id : '遗忘失败：' + id, isError: !ok } as ToolResult)
		})
	}
}

// ========== 网络搜索工具 ==========

class WebSearchTool implements AgentTool {
	name: string = 'web_search'
	description: string = '联网搜索最新信息。适合查询实时数据、新闻、未知知识。优先使用记忆搜索查已有信息，只在需要最新/外部知识时使用。'
	parameters: UTSJSONObject = {
		'type': 'object',
		'properties': {
			'query': {
				'type': 'string',
				'description': '搜索关键词，用中文或英文'
			},
			'limit': {
				'type': 'number',
				'description': '返回结果数量，1-10，默认 5'
			}
		},
		'required': ['query']
	} as UTSJSONObject

	execute(args: UTSJSONObject): Promise<ToolResult> {
		return new Promise<ToolResult>((resolve) => {
			const rawQuery = args['query'] as string | null
			const rawLimit = args['limit'] as number | null
			const query = rawQuery != null ? rawQuery : ''
			if (query == '') {
				resolve({ content: '请提供搜索关键词', isError: true } as ToolResult)
				return
			}
			// 检查是否启用
			const wsEnabled = uni.getStorageSync('settings_web_search_enabled') as string
			if (wsEnabled != 'true') {
				resolve({ content: '网络搜索未启用，请在插件设置中开启。', isError: false } as ToolResult)
				return
			}
			const limit = rawLimit != null ? rawLimit : 5
			const provider = uni.getStorageSync('settings_web_search_provider') as string
			if (provider == 'grok') {
				this.doAISearch(query, resolve)
				return
			}
			// 默认 SearXNG
			// 优先使用自定义实例，否则用公共实例
			const customInstance = uni.getStorageSync('settings_web_search_instance') as string
			let instances: string[]
			if (customInstance != null && customInstance != '') {
				instances = [customInstance]
			} else {
				instances = [
					'https://searx.be',
					'https://search.sapti.me',
					'https://searx.tiekoetter.com',
					'https://searx.ninja',
					'https://searx.work',
					'https://search.ononoki.org',
				]
			}
			this.doSearchInstances(instances, 0, query, limit, false, resolve)
		})
	}

	/** AI 搜索——从提供商列表读取配置，自动适配 Grok/豆包 API */
	private doAISearch(query: string, resolve: (value: ToolResult) => void): void {
		console.log('[WebSearch] AI 搜索开始: ' + query.substring(0, query.length < 60 ? query.length : 60))
		const providerId = uni.getStorageSync('settings_web_search_provider_id') as string
		if (providerId == null || providerId == '') {
			console.log('[WebSearch] ← 未选择提供商')
			resolve({ content: '未选择搜索提供商，请在插件设置中选择。', isError: true } as ToolResult)
			return
		}
		const config = getProviderApiConfig(providerId)
		if (config == null) {
			console.log('[WebSearch] ← 提供商不存在: ' + providerId)
			resolve({ content: '提供商 ' + providerId + ' 不存在，请检查设置。', isError: true } as ToolResult)
			return
		}
		const apiKey = config['api_key'] as string | null
		const apiBase = config['api_base'] as string | null
		if (apiKey == null || apiKey == '') {
			console.log('[WebSearch] ← 未配置 API Key: ' + providerId)
			resolve({ content: '提供商 ' + providerId + ' 未配置 API Key。', isError: true } as ToolResult)
			return
		}
		let baseUrl = (apiBase != null && apiBase != '') ? apiBase : 'https://api.x.ai'
		if (baseUrl.endsWith('/')) {
			baseUrl = baseUrl.substring(0, baseUrl.length - 1)
		}
		// 检测豆包 / 火山引擎 → 走 Responses API
		const isDoubao = baseUrl.indexOf('volces.com') >= 0 || baseUrl.indexOf('volcengine.com') >= 0
		let model = uni.getStorageSync('settings_web_search_model') as string
		if (model == null || model == '') {
			model = isDoubao ? 'doubao-seed-1-6-250615' : 'grok-2'
		}
		if (isDoubao) {
			this.doDoubaoSearch(baseUrl, apiKey, model, query, providerId, resolve)
		} else {
			this.doChatCompletionsSearch(baseUrl, apiKey, model, query, providerId, resolve)
		}
	}

	/** 豆包搜索——火山引擎 Responses API，注册 web_search 工具 */
	private doDoubaoSearch(
		baseUrl: string, apiKey: string, model: string,
		query: string, providerId: string, resolve: (value: ToolResult) => void
	): void {
		const url = baseUrl + '/responses'
		const body: UTSJSONObject = {
			model: model,
			input: [
				{ role: 'user', content: query } as UTSJSONObject,
			],
			tools: [
				{ type: 'web_search' } as UTSJSONObject,
			],
		} as UTSJSONObject
		console.log('[WebSearch] 豆包 → ' + model + ' | ' + url)
		uni.request({
			url: url, method: 'POST',
			header: {
				'Content-Type': 'application/json',
				'Authorization': 'Bearer ' + apiKey,
			} as UTSJSONObject,
			data: body, timeout: 30000, sslVerify: false,
			success: (res) => {
				const statusCode = res.statusCode as number
				console.log('[WebSearch] 豆包 ← ' + statusCode)
				if (statusCode != 200) {
					let errBody = ''
					try {
						const ed = res.data as UTSJSONObject | null
						if (ed != null) { errBody = JSON.stringify(ed) }
					} catch (_e: any) {}
					console.log('[WebSearch] 豆包 ← error: ' + errBody.substring(0, errBody.length < 200 ? errBody.length : 200))
					resolve({ content: '豆包返回错误 (状态码: ' + statusCode + ')。', isError: true } as ToolResult)
					return
				}
				try {
					const data = res.data as UTSJSONObject | null
					if (data == null) {
						resolve({ content: '豆包返回为空。', isError: false } as ToolResult)
						return
					}
					// Responses API 返回 output 数组
					const output = data['output'] as UTSJSONObject[] | null
					if (output == null || output.length == 0) {
						const text = data['content'] as string | null
						if (text != null && text != '') {
							console.log('[WebSearch] 豆包 ← 成功 | ' + text.length + ' 字符')
							resolve({ content: text, isError: false } as ToolResult)
						} else {
							resolve({ content: '豆包未返回搜索内容。', isError: false } as ToolResult)
						}
						return
					}
					// 提取 output 中的文本
					const lines: string[] = []
					for (let i = 0; i < output.length; i++) {
						const item = output[i]
						const itemContent = item['content'] as UTSJSONObject[] | null
						if (itemContent != null) {
							for (let j = 0; j < itemContent.length; j++) {
								const textVal = itemContent[j]['text'] as string | null
								if (textVal != null && textVal != '') {
									lines.push(textVal)
								}
							}
						}
					}
					const result = lines.join('\n')
					console.log('[WebSearch] 豆包 ← 成功 | ' + result.length + ' 字符')
					resolve({ content: result != '' ? result : '豆包未返回搜索结果。', isError: false } as ToolResult)
				} catch (_e: any) {
					console.log('[WebSearch] 豆包 ← 解析异常: ' + _e)
					resolve({ content: '豆包响应解析失败。', isError: true } as ToolResult)
				}
			},
			fail: (_err: any) => {
				console.log('[WebSearch] 豆包 ← 网络失败 | ' + url)
				resolve({ content: 'API 请求失败，请检查网络或提供商 ' + providerId + ' 配置。', isError: true } as ToolResult)
			}
		})
	}

	/** 通用 Chat Completions 搜索（Grok / OpenAI 兼容） */
	private doChatCompletionsSearch(
		baseUrl: string, apiKey: string, model: string,
		query: string, providerId: string, resolve: (value: ToolResult) => void
	): void {
		const hasApiVersion = baseUrl.indexOf('/v1') >= 0 || baseUrl.indexOf('/api/v') >= 0
		const url = hasApiVersion ? baseUrl + '/chat/completions' : baseUrl + '/v1/chat/completions'
		const systemPrompt = '你是网络搜索工具。收到搜索请求后，请搜索网页并返回结果。\n\n' +
			'要求：\n' +
			'1. 对搜索结果进行总结，提取有价值的信息，控制在 500 字以内\n' +
			'2. 用简洁、有条理的方式返回总结内容，不要返回原文\n' +
			'3. 如果搜索结果较少，直接返回总结；如果较多，优先返回最重要的信息\n' +
			'4. 每条信息后面标注来源，格式如"来源：xxx"\n' +
			'5. 标注信息发布时间，如"2025年1月30日"等\n' +
			'6. 如果是时效性问题，忽略可能过时信息，只返回最新的\n' +
			'7. 声明：以下内容来自互联网，随时间推移可能过时，仅供参考'
		console.log('[WebSearch] ChatCompletions → ' + model + ' | ' + url)
		const body: UTSJSONObject = {
			model: model,
			messages: [
				{ role: 'system', content: systemPrompt } as UTSJSONObject,
				{ role: 'user', content: '搜索：' + query } as UTSJSONObject,
			],
			stream: false,
			temperature: 0.3,
		} as UTSJSONObject
		uni.request({
			url: url, method: 'POST',
			header: {
				'Content-Type': 'application/json',
				'Authorization': 'Bearer ' + apiKey,
			} as UTSJSONObject,
			data: body, timeout: 30000, sslVerify: false,
			success: (res) => {
				const statusCode = res.statusCode as number
				console.log('[WebSearch] ChatCompletions ← ' + statusCode)
				if (statusCode != 200) {
					let errBody = ''
					try {
						const ed = res.data as UTSJSONObject | null
						if (ed != null) { errBody = JSON.stringify(ed) }
					} catch (_e: any) {}
					console.log('[WebSearch] ChatCompletions ← error: ' + errBody.substring(0, errBody.length < 200 ? errBody.length : 200))
					resolve({ content: 'API 返回错误 (状态码: ' + statusCode + ')。', isError: true } as ToolResult)
					return
				}
				try {
					const data = res.data as UTSJSONObject | null
					if (data == null) { resolve({ content: 'API 返回为空。', isError: false } as ToolResult); return }
					const choices = data['choices'] as UTSJSONObject[] | null
					if (choices == null || choices.length == 0) { resolve({ content: 'API 未返回结果。', isError: false } as ToolResult); return }
					const message = choices[0]['message'] as UTSJSONObject | null
					if (message == null) { resolve({ content: '响应格式异常。', isError: false } as ToolResult); return }
					const content = message['content'] as string | null
					if (content == null || content == '') { resolve({ content: '未返回搜索内容。', isError: false } as ToolResult); return }
					console.log('[WebSearch] ChatCompletions ← 成功 | ' + content.length + ' 字符')
					resolve({ content: content, isError: false } as ToolResult)
				} catch (_e: any) {
					console.log('[WebSearch] ChatCompletions ← 解析异常: ' + _e)
					resolve({ content: '响应解析失败，请检查提供商 ' + providerId + ' 是否兼容。', isError: true } as ToolResult)
				}
			},
			fail: (_err: any) => {
				console.log('[WebSearch] ChatCompletions ← 网络失败 | ' + url)
				resolve({ content: 'API 请求失败，请检查网络或提供商 ' + providerId + ' 配置。', isError: true } as ToolResult)
			}
		})
	}
	
	/** 逐个尝试 SearXNG 实例，成功则 resolve，全失败则返回空 */
	private doSearchInstances(
		instances: string[],
		index: number,
		query: string,
		limit: number,
		hasResolved: boolean,
		resolve: (value: ToolResult) => void
	): void {
		if (index >= instances.length) {
			if (hasResolved == false) {
				resolve({ content: '未找到相关结果，请尝试更换关键词。', isError: false } as ToolResult)
			}
			return
		}
		const baseUrl = instances[index]
		const url = baseUrl + '/search?q=' + query + '&format=json&categories=general,news'
		let resolvedHere = false
		uni.request({
			url: url,
			method: 'GET',
			timeout: 8000,
			success: (res) => {
				const data = res.data as UTSJSONObject | null
				if (data == null) {
					this.doSearchInstances(instances, index + 1, query, limit, hasResolved, resolve)
					return
				}
				const rawResults = data['results'] as UTSJSONObject[] | null
				if (rawResults == null || rawResults.length == 0) {
					this.doSearchInstances(instances, index + 1, query, limit, hasResolved, resolve)
					return
				}
				const count = rawResults.length < limit ? rawResults.length : limit
				const lines: string[] = []
				for (let i = 0; i < count; i++) {
					const r = rawResults[i]
					const t = r['title'] as string | null
					const u = r['url'] as string | null
					const c = r['content'] as string | null
					if (t == null || u == null) continue
					lines.push((i + 1) + '. ' + t)
					lines.push('   ' + u)
					if (c != null && c != '') {
						lines.push('   ' + c)
					}
				}
				if (lines.length == 0) {
					this.doSearchInstances(instances, index + 1, query, limit, true, resolve)
				} else {
					resolve({ content: lines.join('\n'), isError: false } as ToolResult)
				}
			},
			fail: () => {
				if (resolvedHere == false) {
					this.doSearchInstances(instances, index + 1, query, limit, hasResolved, resolve)
				}
			}
		})
	}
}
