/**
 * Agent Loop 核心 - ReAct 循环实现
 * 参考 Pi Agent 的 agent-loop.ts 架构，简化适配 UTS 环境
 * 实现 思考->行动->观察 的循环推理模式
 */

import { LLMProvider } from './llm-provider'
import {
	ChatRequest,
	AssistantMessage,
	UserMessage,
	ToolResultMessage,
	Message,
	ToolDefinition,
	ToolCall,
	ContentBlock,
	TextContent,
	AgentEvent,
	AgentTool,
	ToolResult,
	Usage
} from './types'

/**
 * Agent 事件回调类型
 * @param event Agent 事件
 */
export type AgentEventCallback = (event : AgentEvent) => void

/**
 * Agent Loop 配置
 */
export type AgentLoopConfig = {
	/** 系统提示词 */
	systemPrompt : string
	/** 可用工具列表 */
	tools : AgentTool[]
	/** 最大迭代次数，默认 20 */
	maxIterations : number | null
}

/**
 * Agent Loop 主类
 * 实现 ReAct (Reasoning + Acting) 循环
 * 循环流程: LLM 推理 -> 工具调用 -> 结果观察 -> 继续推理
 */
export class AgentLoop {
	/** LLM 提供者 */
	private provider : LLMProvider
	/** 循环配置 */
	private config : AgentLoopConfig
	/** 消息历史 */
	private messages : Message[]
	/** 事件回调 */
	private onEvent : AgentEventCallback
	/** 是否已中止 */
	private aborted : boolean

	/**
	 * 构造函数
	 * @param provider LLM 提供者实例
	 * @param config Agent 循环配置
	 * @param onEvent 事件回调函数
	 */
	constructor(provider : LLMProvider, config : AgentLoopConfig, onEvent : AgentEventCallback) {
		this.provider = provider
		this.config = config
		this.onEvent = onEvent
		this.messages = [] as Message[]
		this.aborted = false
	}

	/**
	 * 运行 Agent 循环
	 * 执行完整的 ReAct 循环直到 LLM 不再调用工具或达到最大迭代次数
	 * @param userMessage 用户输入消息
	 * @returns 最终的助手消息
	 */
	run(userMessage : string) : Promise<AssistantMessage> {
		return new Promise<AssistantMessage>((resolve, reject) => {
			// 发出 agent_start 事件
			this.emit({ type: 'agent_start' } as AgentEvent)

			// 构建用户消息并添加到历史
			const userMsg : UserMessage = {
				role: 'user',
				content: userMessage,
				timestamp: Date.now()
			} as UserMessage
			this.messages.push(userMsg as Message)
			this.emit({ type: 'message_start', message: userMsg as Message } as AgentEvent)

			// 获取最大迭代次数
			const maxIter = this.config.maxIterations != null ? this.config.maxIterations! : 20

			// 启动循环
			this.runLoop(maxIter, 0, resolve, reject)
		})
	}

	/**
	 * 中止当前循环
	 * 设置中止标志，循环将在下一次迭代检查时退出
	 */
	abort() : void {
		this.aborted = true
	}

	/**
	 * 获取消息历史
	 * @returns 消息数组的副本
	 */
	getMessages() : Message[] {
		return this.messages.slice()
	}

	/**
	 * 运行循环迭代
	 * 递归执行 LLM 调用和工具执行
	 * @param maxIter 最大迭代次数
	 * @param iteration 当前迭代次数
	 * @param resolve Promise 的 resolve 函数
	 * @param reject Promise 的 reject 函数
	 */
	private runLoop(
		maxIter : number,
		iteration : number,
		resolve : (msg : AssistantMessage) => void,
		reject : (err : Error) => void
	) : void {
		// 检查中止条件
		if (this.aborted) {
			const abortMsg = this.createAbortMessage()
			this.emit({ type: 'agent_end' } as AgentEvent)
			resolve(abortMsg)
			return
		}

		// 检查最大迭代次数
		if (iteration >= maxIter) {
			const maxIterMsg = this.createMaxIterMessage(maxIter)
			this.emit({ type: 'agent_end' } as AgentEvent)
			resolve(maxIterMsg)
			return
		}

		// 发出 turn_start 事件
		this.emit({ type: 'turn_start' } as AgentEvent)

		// 构建 LLM 请求
		const request = this.buildRequest()

		// 调用 LLM
		this.provider.chat(request).then((assistantMsg : AssistantMessage) => {
			// 检查中止
			if (this.aborted) {
				const abortMsg = this.createAbortMessage()
				this.emit({ type: 'agent_end' } as AgentEvent)
				resolve(abortMsg)
				return
			}

			// 将助手消息添加到历史
			this.messages.push(assistantMsg as Message)
			this.emit({ type: 'message_start', message: assistantMsg as Message } as AgentEvent)

			// 提取工具调用
			const toolCalls = this.extractToolCalls(assistantMsg)

			if (toolCalls.length == 0) {
				// 没有工具调用，循环结束
				this.emit({ type: 'turn_end' } as AgentEvent)
				this.emit({ type: 'agent_end' } as AgentEvent)
				resolve(assistantMsg)
				return
			}

			// 执行所有工具调用
			this.executeToolCalls(toolCalls).then(() => {
				this.emit({ type: 'turn_end' } as AgentEvent)
				// 继续下一次迭代
				this.runLoop(maxIter, iteration + 1, resolve, reject)
			}).catch((err : Error) => {
				reject(err)
			})
		}).catch((err : Error) => {
			reject(err)
		})
	}

	/**
	 * 构建 LLM 请求
	 * 将系统提示、消息历史和工具定义组装为 ChatRequest
	 * @returns 完整的聊天请求
	 */
	private buildRequest() : ChatRequest {
		// 构建工具定义列表
		const toolDefs = new Array<ToolDefinition>()
		for (let i = 0; i < this.config.tools.length; i++) {
			const tool = this.config.tools[i]
			toolDefs.push({
				name: tool.name,
				description: tool.description,
				parameters: tool.parameters
			} as ToolDefinition)
		}

		const config = this.provider.getConfig()

		const request : ChatRequest = {
			model: config.id,
			system: this.config.systemPrompt,
			messages: this.messages,
			tools: toolDefs,
			maxTokens: config.maxTokens,
			temperature: null
		}

		return request
	}

	/**
	 * 从助手消息中提取工具调用
	 * @param message 助手消息
	 * @returns 工具调用数组
	 */
	private extractToolCalls(message : AssistantMessage) : ToolCall[] {
		const result = new Array<ToolCall>()
		for (let i = 0; i < message.content.length; i++) {
			const block = message.content[i]
			if (block['type'] == 'toolCall') {
				result.push(block as ToolCall)
			}
		}
		return result
	}

	/**
	 * 执行所有工具调用
	 * 依次执行每个工具调用，将结果添加到消息历史
	 * @param toolCalls 工具调用数组
	 */
	private executeToolCalls(toolCalls : ToolCall[]) : Promise<void> {
		return new Promise<void>((resolve, reject) => {
			this.executeToolCallsSequential(toolCalls, 0, resolve, reject)
		})
	}

	/**
	 * 顺序执行工具调用
	 * @param toolCalls 工具调用数组
	 * @param index 当前执行的索引
	 * @param resolve Promise 的 resolve 函数
	 * @param reject Promise 的 reject 函数
	 */
	private executeToolCallsSequential(
		toolCalls : ToolCall[],
		index : number,
		resolve : () => void,
		reject : (err : Error) => void
	) : void {
		if (index >= toolCalls.length) {
			resolve()
			return
		}

		const toolCall = toolCalls[index]

		// 发出工具执行开始事件
		this.emit({
			type: 'tool_execution_start',
			toolCallId: toolCall.id,
			toolName: toolCall.name,
			args: toolCall.arguments
		} as AgentEvent)

		// 执行工具
		this.executeTool(toolCall).then((result : ToolResult) => {
			// 构建工具结果消息
			const toolResultMsg : ToolResultMessage = {
				role: 'toolResult',
				toolCallId: toolCall.id,
				toolName: toolCall.name,
				content: result.content,
				isError: result.isError,
				timestamp: Date.now()
			} as ToolResultMessage

			// 添加到消息历史
			this.messages.push(toolResultMsg as Message)
			this.emit({ type: 'message_end', message: toolResultMsg as Message } as AgentEvent)

			// 发出工具执行结束事件
			this.emit({
				type: 'tool_execution_end',
				toolCallId: toolCall.id,
				toolName: toolCall.name,
				result: result.content,
				isError: result.isError
			} as AgentEvent)

			// 继续执行下一个工具调用
			this.executeToolCallsSequential(toolCalls, index + 1, resolve, reject)
		}).catch((err : Error) => {
			// 工具执行异常，将错误作为工具结果
			const errorMsg : string = '工具执行异常: ' + err.message
			const toolResultMsg : ToolResultMessage = {
				role: 'toolResult',
				toolCallId: toolCall.id,
				toolName: toolCall.name,
				content: errorMsg,
				isError: true,
				timestamp: Date.now()
			} as ToolResultMessage

			this.messages.push(toolResultMsg as Message)
			this.emit({ type: 'message_end', message: toolResultMsg as Message } as AgentEvent)

			this.emit({
				type: 'tool_execution_end',
				toolCallId: toolCall.id,
				toolName: toolCall.name,
				result: errorMsg,
				isError: true
			} as AgentEvent)

			// 继续执行下一个工具调用（不因单个工具失败中断整个循环）
			this.executeToolCallsSequential(toolCalls, index + 1, resolve, reject)
		})
	}

	/**
	 * 执行单个工具调用
	 * 在工具注册表中查找工具并调用其 execute 方法
	 * @param toolCall 工具调用
	 * @returns 工具执行结果
	 */
	private executeTool(toolCall : ToolCall) : Promise<ToolResult> {
		const tool = this.findTool(toolCall.name)
		if (tool == null) {
			return new Promise<ToolResult>((resolve) => {
				resolve({
					content: '未知工具: ' + toolCall.name,
					isError: true
				} as ToolResult)
			})
		}
		return tool.execute(toolCall.arguments)
	}

	/**
	 * 查找工具
	 * 在配置的工具列表中按名称查找
	 * @param name 工具名称
	 * @returns 找到的工具，未找到返回 null
	 */
	private findTool(name : string) : AgentTool | null {
		for (let i = 0; i < this.config.tools.length; i++) {
			if (this.config.tools[i].name == name) {
				return this.config.tools[i]
			}
		}
		return null
	}

	/**
	 * 发出事件
	 * @param event Agent 事件
	 */
	private emit(event : AgentEvent) : void {
		try {
			this.onEvent(event)
		} catch (_) {
			// 事件回调异常不影响主流程
		}
	}

	/**
	 * 创建中止消息
	 * @returns 包含中止信息的助手消息
	 */
	private createAbortMessage() : AssistantMessage {
		const textBlock : TextContent = {
			type: 'text',
			text: 'Agent 循环已被中止'
		} as TextContent
		return {
			role: 'assistant',
			content: [textBlock as ContentBlock],
			model: this.provider.getConfig().id,
			stopReason: 'aborted',
			errorMessage: '用户中止了 Agent 循环',
			usage: { inputTokens: 0, outputTokens: 0 } as Usage,
			timestamp: Date.now()
		} as AssistantMessage
	}

	/**
	 * 创建最大迭代次数消息
	 * @param maxIter 最大迭代次数
	 * @returns 包含迭代超限信息的助手消息
	 */
	private createMaxIterMessage(maxIter : number) : AssistantMessage {
		const textBlock : TextContent = {
			type: 'text',
			text: '已达到最大迭代次数 (' + maxIter + ')，Agent 循环终止'
		} as TextContent
		return {
			role: 'assistant',
			content: [textBlock as ContentBlock],
			model: this.provider.getConfig().id,
			stopReason: 'length',
			errorMessage: '达到最大迭代次数限制',
			usage: { inputTokens: 0, outputTokens: 0 } as Usage,
			timestamp: Date.now()
		} as AssistantMessage
	}
}
