/**
 * Anthropic LLM Provider 实现
 * 适配 Anthropic Messages API (claude 系列模型)
 * API 文档: https://docs.anthropic.com/en/api/messages
 */

import { LLMProvider } from './llm-provider'
import {
	ModelConfig,
	ChatRequest,
	AssistantMessage,
	Message,
	UserMessage,
	ToolResultMessage,
	ToolDefinition,
	TextContent,
	ThinkingContent,
	ToolCall,
	ContentBlock,
	StopReason,
	Usage
} from './types'

/**
 * Anthropic Messages API 的停止原因到内部 StopReason 的映射
 * @param reason Anthropic 返回的停止原因
 * @returns 内部 StopReason
 */
function mapStopReason(reason : string) : StopReason {
	if (reason == 'end_turn') {
		return 'stop'
	} else if (reason == 'max_tokens') {
		return 'length'
	} else if (reason == 'tool_use') {
		return 'toolUse'
	} else if (reason == 'stop_sequence') {
		return 'stop'
	} else {
		return 'error'
	}
}

/**
 * Anthropic Provider
 * 实现 Anthropic Messages API 的调用逻辑
 */
export class AnthropicProvider extends LLMProvider {

	/**
	 * 构造函数
	 * @param config 模型配置，baseUrl 默认为 https://api.anthropic.com
	 */
	constructor(config : ModelConfig) {
		super(config)
	}

	/**
	 * 发送聊天请求到 Anthropic Messages API
	 * @param request 聊天请求参数
	 * @returns 助手消息响应
	 */
	override chat(request : ChatRequest) : Promise<AssistantMessage> {
		return new Promise<AssistantMessage>((resolve, reject) => {
			// 构建请求 URL
			const baseUrl = this.config.baseUrl != null && this.config.baseUrl != '' ? this.config.baseUrl : 'https://api.anthropic.com'
			const url = baseUrl + '/v1/messages'

			// 构建请求体
			const requestBody = this.buildRequestBody(request)

			// 构建请求头
			const headers : UTSJSONObject = {
				'Content-Type': 'application/json',
				'x-api-key': this.config.apiKey,
				'anthropic-version': '2023-06-01'
			}

			// 发送请求
			uni.request({
				url: url,
				method: 'POST',
				header: headers,
				data: requestBody,
				success: (res) => {
					if (res.statusCode == 200) {
						try {
							const responseData = this.ensureJSONObject(res.data as any)
							const message = this.parseResponse(responseData)
							resolve(message)
						} catch (e) {
							reject(new Error('解析 Anthropic 响应失败: ' + e))
						}
					} else {
						const responseData = this.ensureJSONObject(res.data as any)
						const errorMsg = this.extractErrorMessage(responseData, res.statusCode)
						reject(new Error('Anthropic API 错误 (' + res.statusCode + '): ' + errorMsg))
					}
				},
				fail: (err) => {
					reject(new Error('网络请求失败: ' + err.errMsg))
				}
			})
		})
	}

	/**
	 * 构建 Anthropic Messages API 请求体
	 * @param request 内部聊天请求
	 * @returns Anthropic 格式的请求体
	 */
	private buildRequestBody(request : ChatRequest) : UTSJSONObject {
		const body : UTSJSONObject = {
			'model': this.config.id,
			'max_tokens': request.maxTokens,
			'system': request.system,
			'messages': this.convertMessages(request.messages)
		}

		// 可选参数
		if (request.temperature != null) {
			body['temperature'] = request.temperature
		}

		// 工具定义
		if (request.tools.length > 0) {
			body['tools'] = this.convertTools(request.tools)
		}

		return body
	}

	/**
	 * 将内部消息格式转换为 Anthropic Messages API 格式
	 * @param messages 内部消息数组
	 * @returns Anthropic 格式的消息数组
	 */
	private convertMessages(messages : Message[]) : Array<UTSJSONObject> {
		const result = new Array<UTSJSONObject>()
		let i = 0

		while (i < messages.length) {
			const msg = messages[i]
			const role = msg['role'] as string

			if (role == 'user') {
				const userMsg = msg as UserMessage
				result.push({
					'role': 'user',
					'content': userMsg.content
				} as UTSJSONObject)
				i++
			} else if (role == 'assistant') {
				const assistantMsg = msg as AssistantMessage
				result.push({
					'role': 'assistant',
					'content': this.convertAssistantContent(assistantMsg.content)
				} as UTSJSONObject)
				i++
			} else if (role == 'toolResult') {
				// 收集所有连续的 toolResult 消息，合并为单个 user 消息
				// 避免违反 Anthropic API 消息交替要求
				const toolResults = new Array<UTSJSONObject>()
				while (i < messages.length) {
					const curMsg = messages[i]
					const curRole = curMsg['role'] as string
					if (curRole != 'toolResult') break
					const toolMsg = curMsg as ToolResultMessage
					toolResults.push({
						'type': 'tool_result',
						'tool_use_id': toolMsg.toolCallId,
						'content': toolMsg.content,
						'is_error': toolMsg.isError
					} as UTSJSONObject)
					i++
				}
				// 合并为单个 user 消息
				result.push({
					'role': 'user',
					'content': toolResults
				} as UTSJSONObject)
			} else {
				i++
			}
		}

		return result
	}

	/**
	 * 将内部助手消息内容块转换为 Anthropic 格式
	 * @param content 内部内容块数组
	 * @returns Anthropic 格式的内容块数组
	 */
	private convertAssistantContent(content : ContentBlock[]) : Array<UTSJSONObject> {
		const result = new Array<UTSJSONObject>()

		for (let i = 0; i < content.length; i++) {
			const block = content[i]
			const blockType = block['type'] as string

			if (blockType == 'text') {
				const textBlock = block as TextContent
				result.push({
					'type': 'text',
					'text': textBlock.text
				} as UTSJSONObject)
			} else if (blockType == 'thinking') {
				const thinkBlock = block as ThinkingContent
				result.push({
					'type': 'thinking',
					'thinking': thinkBlock.thinking
				} as UTSJSONObject)
			} else if (blockType == 'toolCall') {
				const toolBlock = block as ToolCall
				result.push({
					'type': 'tool_use',
					'id': toolBlock.id,
					'name': toolBlock.name,
					'input': toolBlock.arguments
				} as UTSJSONObject)
			}
		}

		return result
	}

	/**
	 * 将内部工具定义转换为 Anthropic tools 格式
	 * @param tools 内部工具定义数组
	 * @returns Anthropic 格式的工具数组
	 */
	private convertTools(tools : ToolDefinition[]) : Array<UTSJSONObject> {
		const result = new Array<UTSJSONObject>()

		for (let i = 0; i < tools.length; i++) {
			const tool = tools[i]
			result.push({
				'name': tool.name,
				'description': tool.description,
				'input_schema': tool.parameters
			} as UTSJSONObject)
		}

		return result
	}

	/**
	 * 解析 Anthropic Messages API 响应
	 * @param data API 响应数据
	 * @returns 内部助手消息
	 */
	private parseResponse(data : UTSJSONObject) : AssistantMessage {
		// 解析内容块
		const contentArray = data['content'] as Array<UTSJSONObject> | null
		if (contentArray == null) {
			const textBlock : TextContent = { type: 'text', text: '' } as TextContent
			return {
				role: 'assistant',
				content: [textBlock as ContentBlock],
				model: this.config.id,
				stopReason: 'error' as StopReason,
				errorMessage: 'API 响应缺少 content 字段',
				usage: { inputTokens: 0, outputTokens: 0 } as Usage,
				timestamp: Date.now()
			} as AssistantMessage
		}
		const contentBlocks = new Array<ContentBlock>()

		for (let i = 0; i < contentArray!.length; i++) {
			const block = contentArray[i]
			const blockType = block['type'] as string

			if (blockType == 'text') {
				const textBlock : TextContent = {
					type: 'text',
					text: block['text'] as string
				} as TextContent
				contentBlocks.push(textBlock as ContentBlock)
			} else if (blockType == 'thinking') {
				const thinkBlock : ThinkingContent = {
					type: 'thinking',
					thinking: block['thinking'] as string
				} as ThinkingContent
				contentBlocks.push(thinkBlock as ContentBlock)
			} else if (blockType == 'tool_use') {
				const toolBlock : ToolCall = {
					type: 'toolCall',
					id: block['id'] as string,
					name: block['name'] as string,
					arguments: block['input'] as UTSJSONObject
				} as ToolCall
				contentBlocks.push(toolBlock as ContentBlock)
			}
		}

		// 解析停止原因
		const stopReasonStr = data['stop_reason'] as string | null
		const stopReason : StopReason = stopReasonStr != null ? mapStopReason(stopReasonStr!) : 'error'

		// 解析用量
		const usageObj = data['usage'] as UTSJSONObject | null
		let inputTokens : number = 0
		let outputTokens : number = 0
		if (usageObj != null) {
			const it = usageObj!['input_tokens'] as number | null
			const ot = usageObj!['output_tokens'] as number | null
			inputTokens = it != null ? it! : 0
			outputTokens = ot != null ? ot! : 0
		}
		const usage : Usage = { inputTokens: inputTokens, outputTokens: outputTokens } as Usage

		// 构建助手消息
		const message : AssistantMessage = {
			role: 'assistant',
			content: contentBlocks,
			model: data['model'] as string,
			stopReason: stopReason,
			errorMessage: null,
			usage: usage,
			timestamp: Date.now()
		}

		return message
	}

	/**
	 * 确保响应数据为 UTSJSONObject
	 * uni.request 的 res.data 可能是 UTSJSONObject 或 string，需要统一处理
	 * @param data 响应数据
	 * @returns UTSJSONObject
	 */
	private ensureJSONObject(data : any) : UTSJSONObject {
		if (data == null) {
			return {} as UTSJSONObject
		}
		// 尝试直接转换，如果失败则按字符串解析
		try {
			const obj = data as UTSJSONObject
			if (obj != null) {
				return obj
			}
		} catch (_) {
			// 转换失败，尝试 JSON 解析
		}
		try {
			return JSON.parse(data as string) as UTSJSONObject
		} catch (_) {
			return {} as UTSJSONObject
		}
	}

	/**
	 * 从错误响应中提取错误信息
	 * @param data 响应数据
	 * @param statusCode HTTP 状态码
	 * @returns 错误信息字符串
	 */
	private extractErrorMessage(data : UTSJSONObject | null, statusCode : number) : string {
		if (data == null) {
			return '未知错误 (HTTP ' + statusCode + ')'
		}
		const errorObj = data['error'] as UTSJSONObject | null
		if (errorObj != null) {
			const message = errorObj!['message'] as string | null
			if (message != null) {
				return message!
			}
		}
		return '未知错误 (HTTP ' + statusCode + ')'
	}
}
