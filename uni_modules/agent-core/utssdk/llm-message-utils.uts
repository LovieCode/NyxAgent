/**
 * LLM 消息转换工具。
 *
 * 负责把 UI 消息结构转换为 OpenAI-compatible messages/tool_calls 需要的纯数据。
 */

export function getMessagePartsForLLM(msg: UTSJSONObject): UTSJSONObject[] {
	const parts = msg['message'] as UTSJSONObject[] | null
	if (parts != null) {
		return parts
	}
	return [] as UTSJSONObject[]
}

function readPartString(part: UTSJSONObject, key: string): string {
	const value = part[key] as string | null
	return value != null ? value : ''
}

export function getMessageApiText(msg: UTSJSONObject): string {
	const overrideText = msg['agent_text_override'] as string | null
	if (overrideText != null && overrideText != '') {
		return overrideText
	}
	const parts = getMessagePartsForLLM(msg)
	if (parts.length == 0) {
		const rawContent = msg['content'] as string | null
		return rawContent != null ? rawContent : ''
	}
	let text = ''
	for (let i = 0; i < parts.length; i++) {
		const part = parts[i]
		const type = part['type'] as string | null
		if (type == 'plain' || type == 'text') {
			const raw = readPartString(part, 'text')
			if (raw != '') { text += raw }
		} else if (type == 'location') {
			const raw = readPartString(part, 'text')
			if (raw != '') {
				if (text != '') { text += '\n' }
				text += raw
			}
		} else if (type == 'image') {
			const caption = readPartString(part, 'caption')
			const url = readPartString(part, 'url') != '' ? readPartString(part, 'url') : readPartString(part, 'path')
			if (text != '') { text += '\n' }
			if (caption != '') {
				text += '[图片转述] ' + caption
			} else {
				text += '[图片]' + (url != '' ? ' ' + url : '')
			}
		} else if (type == 'file') {
			const filename = readPartString(part, 'filename') != '' ? readPartString(part, 'filename') : readPartString(part, 'name')
			const path = readPartString(part, 'path')
			const fileText = readPartString(part, 'text')
			if (text != '') { text += '\n' }
			text += '[文件] ' + (filename != '' ? filename : path)
			if (fileText != '') {
				text += '\n' + fileText
			}
		} else if (type == 'record' || type == 'voice' || type == 'audio') {
			const path = readPartString(part, 'path') != '' ? readPartString(part, 'path') : readPartString(part, 'url')
			if (text != '') { text += '\n' }
			text += '[语音/音频] ' + path
		} else if (type == 'video') {
			const path = readPartString(part, 'path') != '' ? readPartString(part, 'path') : readPartString(part, 'url')
			if (text != '') { text += '\n' }
			text += '[视频] ' + path
		}
	}
	return text
}

export function getMessageReasoningText(msg: UTSJSONObject): string {
	const parts = getMessagePartsForLLM(msg)
	let text = ''
	for (let i = 0; i < parts.length; i++) {
		const part = parts[i]
		const type = part['type'] as string | null
		if (type == 'think' || type == 'thinking') {
			let raw = readPartString(part, 'think')
			if (raw == '') { raw = readPartString(part, 'thinking') }
			if (raw != '') {
				if (text != '') { text += '\n' }
				text += raw
			}
		}
	}
	return text
}

export function getFirstImagePathFromParts(msg: UTSJSONObject): string {
	const parts = getMessagePartsForLLM(msg)
	for (let i = 0; i < parts.length; i++) {
		const part = parts[i]
		const type = part['type'] as string | null
		if (type == 'image') {
			const caption = readPartString(part, 'caption')
			if (caption != '') {
				continue
			}
			const url = readPartString(part, 'url')
			if (url != '') { return url }
			const path = readPartString(part, 'path')
			if (path != '') { return path }
		}
	}
	const msgType = msg['msgType'] as string | null
	const imageUrl = msg['imageUrl'] as string | null
	if (msgType == 'image' && imageUrl != null) {
		return imageUrl
	}
	return ''
}

function sanitizeSyntheticToolName(name: string): string {
	let result = ''
	for (let i = 0; i < name.length; i++) {
		const ch = name.charAt(i)
		const rawCode = ch.charCodeAt(0)
		const code = rawCode != null ? rawCode : 0
		const isLower = code >= 97 && code <= 122
		const isUpper = code >= 65 && code <= 90
		const isDigit = code >= 48 && code <= 57
		if (isLower == true || isUpper == true || isDigit == true || ch == '_' || ch == '-') {
			result += ch
		} else {
			result += '_'
		}
	}
	if (result == '') {
		result = 'tool'
	}
	if (result.length > 48) {
		result = result.substring(0, 48)
	}
	return result
}

function buildSyntheticToolCallId(index: number, name: string): string {
	return 'call_' + index.toString() + '_' + sanitizeSyntheticToolName(name)
}

export function normalizeToolCallId(rawId: string | null, index: number, name: string): string {
	if (rawId != null && rawId != '') {
		return rawId
	}
	return buildSyntheticToolCallId(index, name)
}

function buildApiToolCallFromItem(item: UTSJSONObject, index: number): UTSJSONObject | null {
	let id = readPartString(item, 'id')
	let name = readPartString(item, 'name')
	let args = readPartString(item, 'arguments')
	if (args == '') { args = readPartString(item, 'args') }
	const fn = item['function'] as UTSJSONObject | null
	if (fn != null) {
		if (name == '') {
			const rawName = fn['name'] as string | null
			if (rawName != null) { name = rawName }
		}
		if (args == '') {
			const rawArgs = fn['arguments'] as string | null
			if (rawArgs != null) { args = rawArgs }
		}
	}
	if (name == '') {
		return null
	}
	if (args == '') { args = '{}' }
	id = normalizeToolCallId(id != '' ? id : null, index, name)
	item['id'] = id
	return {
		id: id,
		type: 'function',
		function: {
			name: name,
			arguments: args,
		} as UTSJSONObject,
	} as UTSJSONObject
}

export function collectApiToolCalls(msg: UTSJSONObject): UTSJSONObject[] {
	const result: UTSJSONObject[] = []
	const parts = getMessagePartsForLLM(msg)
	for (let i = 0; i < parts.length; i++) {
		const part = parts[i]
		const type = part['type'] as string | null
		if (type != 'tool_call' && type != 'toolCall') { continue }
		const calls = part['tool_calls'] as UTSJSONObject[] | null
		if (calls != null) {
			for (let j = 0; j < calls.length; j++) {
				const apiCall = buildApiToolCallFromItem(calls[j], j)
				if (apiCall != null) { result.push(apiCall) }
			}
		} else {
			const single = buildApiToolCallFromItem(part, 0)
			if (single != null) { result.push(single) }
		}
	}
	if (result.length > 0) {
		return result
	}
	const oldCalls = msg['tool_calls'] as UTSJSONObject[] | null
	if (oldCalls != null) {
		for (let i = 0; i < oldCalls.length; i++) {
			const apiCall = buildApiToolCallFromItem(oldCalls[i], i)
			if (apiCall != null) { result.push(apiCall) }
		}
	}
	return result
}

export function findEmbeddedToolResult(msg: UTSJSONObject, toolCallId: string): string | null {
	if (toolCallId == '') {
		return null
	}
	const parts = getMessagePartsForLLM(msg)
	for (let i = 0; i < parts.length; i++) {
		const part = parts[i]
		const type = part['type'] as string | null
		if (type != 'tool_call' && type != 'toolCall') { continue }
		const calls = part['tool_calls'] as UTSJSONObject[] | null
		if (calls != null) {
			for (let j = 0; j < calls.length; j++) {
				let itemId = calls[j]['id'] as string | null
				if (itemId == null || itemId == '') {
					const itemName = calls[j]['name'] as string | null
					itemId = normalizeToolCallId(null, j, itemName != null ? itemName : '')
					calls[j]['id'] = itemId
				}
				if (itemId == toolCallId) {
					const status = calls[j]['status'] as string | null
					const result = calls[j]['result'] as string | null
					if (status == 'completed' || status == 'error') {
						if (result != null) {
							return result
						}
						return '[' + status + ']'
					}
					if (result != null && result != '') {
						return result
					}
				}
			}
		} else {
			const itemId = part['id'] as string | null
			if (itemId != null && itemId == toolCallId) {
				const status = part['status'] as string | null
				const result = part['result'] as string | null
				if (status == 'completed' || status == 'error') {
					if (result != null) {
						return result
					}
					return '[' + status + ']'
				}
				if (result != null && result != '') {
					return result
				}
			}
		}
	}
	return null
}

export function hasAssistantToolCalls(msg: UTSJSONObject): boolean {
	return collectApiToolCalls(msg).length > 0
}
