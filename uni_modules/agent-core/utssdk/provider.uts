/**
 * 提供商管理（SDK 模块）
 *
 * 管理多个 LLM 提供商的注册信息，以及各任务类型的默认模型分配。
 * 内置 11 个提供商预设（DeepSeek/OpenAI/Anthropic/豆包/xAI/零一万物/Kimi/MiniMax/小米/千问/硅基流动）。
 */

import {
	getAllProviders as dbGetAllProviders,
	getProviderById as dbGetProviderById,
	saveProvider as dbSaveProvider,
	deleteProvider as dbDeleteProvider,
	toggleProvider as dbToggleProvider,
	activateProvider as dbActivateProvider,
	getAppSetting,
	setAppSetting,
	saveFirstRunProviderConfiguration as dbSaveFirstRunProviderConfiguration,
} from '@/utils/database.uts'

// ==================== 模型数据结构 ====================

/**
 * 单个模型信息
 *
 * ctxStr / maxTokensStr / expanded 是 UI 状态，序列化时忽略
 */
export type ModelInfo = {
	id: string
	name?: string
	context?: number
	maxTokens?: number
	/** 自定义参数 JSON 字符串，用于传递 provider-specific 的参数 */
	params?: string
	/** 是否支持多模态（识图）能力 */
	supportsVision: boolean
	/** 是否支持原生工具调用 (function calling) */
	supportsToolCall: boolean
	/** 是否支持思维链/推理 (reasoning) */
	supportsReasoning: boolean
	/** 能力字段是否由 Provider 明确提供；旧版仅有模型 ID 的记录保持未知。 */
	capabilitiesKnown?: boolean
	// === UI state (不序列化) ===
	ctxStr?: string
	maxTokensStr?: string
	expanded?: boolean
}

/** Provider 请求协议。 */
export type ProviderModelAdapter = 'openai_compatible' | 'anthropic'

/** LLM 调用配置 */
export type LLMConfig = {
	providerId: string
	apiKey: string
	baseUrl: string
	model: string
	adapter: ProviderModelAdapter
	modelRuntime: ModelRuntimeOptions
}

/** 解析后的模型运行能力。所有发请求的入口都使用同一份结果。 */
export type ModelRuntimeOptions = {
	modelId: string
	context: number
	maxTokens: number
	params: string
	supportsVision: boolean
	supportsToolCall: boolean
	supportsReasoning: boolean
	found: boolean
	capabilitiesKnown: boolean
}

/**
 * 规范化 baseUrl：去掉末尾的 /v1 或 /v1/
 */
export function normalizeBaseUrl(url: string): string {
	let result = url
	if (result.endsWith('/v1')) {
		result = result.substring(0, result.length - 3)
	} else if (result.endsWith('/v1/')) {
		result = result.substring(0, result.length - 4)
	}
	if (result.endsWith('/')) {
		result = result.substring(0, result.length - 1)
	}
	return result
}

/**
 * 剥离 deep thinking 标签及其内容：<think_xxx>...</think_xxx>
 * 豆包 / DeepSeek 等模型会在 content 中嵌入思考过程，需过滤掉全部思考内容
 */
export function stripThinkTags(text: string): string {
	// 移除 <think_UUID>...</think_UUID> 及其中间全部内容
	text = text.replace(/<think_[^>]*>[\s\S]*?<\/think_[^>]*>/g, '')
	// 清理可能残留的孤立闭标签
	text = text.replace(/<\/think_[^>]*>/g, '')
	return text
}

/**
 * 获取默认 URL（兜底）
 */
function getDefaultUrl(providerId: string): string {
	if (providerId == 'anthropic') return 'https://api.anthropic.com'
	if (providerId == 'openai') return 'https://api.openai.com'
	if (providerId == 'deepseek') return 'https://api.deepseek.com'
	if (providerId == 'zai') return 'https://api.z.ai/api/coding/paas/v4'
	if (providerId == 'kimi-coding') return 'https://api.kimi.com/coding'
	if (providerId == 'minimax-cn') return 'https://api.minimaxi.com/anthropic'
	if (providerId == 'xiaomi') return 'https://api.xiaomimimo.com/v1'
	if (providerId == 'ant-ling') return 'https://api.ant-ling.com/v1'
	if (providerId == 'siliconflow') return 'https://api.siliconflow.cn/v1'
	if (providerId == 'volcengine') return 'https://ark.cn-beijing.volces.com/api/v3'
	if (providerId == 'xai') return 'https://api.x.ai'
	return ''
}

export function getDefaultProviderApiBase(providerId: string): string {
	return getDefaultUrl(providerId)
}

function fillDefaultProviderApiBase(provider: UTSJSONObject): void {
	const id = provider['id'] as string | null
	if (id == null || id == '') { return }
	const apiBase = provider['api_base'] as string | null
	if (apiBase != null && apiBase != '') { return }
	const defaultApiBase = getDefaultUrl(id)
	if (defaultApiBase != '') {
		provider['api_base'] = defaultApiBase
	}
}

// ==================== 提供商 CRUD ====================

/**
 * 获取所有提供商
 */
export function getAllProviders(): UTSJSONObject[] {
	const providers = dbGetAllProviders()
	for (let i = 0; i < providers.length; i++) {
		fillDefaultProviderApiBase(providers[i])
	}
	return providers
}

/**
 * 根据 id 获取提供商
 */
export function getProviderById(id: string): UTSJSONObject | null {
	const provider = dbGetProviderById(id)
	if (provider != null) {
		fillDefaultProviderApiBase(provider)
	}
	return provider
}

/**
 * 将模型数组序列化为 JSON 字符串（存数据库用）
 */
export function serializeModels(models: ModelInfo[]): string {
	const list: UTSJSONObject[] = []
	for (let i = 0; i < models.length; i++) {
		const m = models[i]
		const obj: UTSJSONObject = { id: m.id } as UTSJSONObject
		if (m.name != null && m.name != '') {
			obj['name'] = m.name
		}
		if (m.context != null && m.context > 0) {
			obj['context'] = m.context
		}
		if (m.maxTokens != null && m.maxTokens > 0) {
			obj['maxTokens'] = m.maxTokens
		}
		if (m.params != null && m.params != '') {
			obj['params'] = m.params
		}
		// 新记录写入完整能力字段，旧的裸 ID 记录仍保持兼容：未知能力不强行写成 false。
		if (m.capabilitiesKnown == true) {
			obj['vision'] = m.supportsVision
			obj['toolCall'] = m.supportsToolCall
			obj['reasoning'] = m.supportsReasoning
		} else {
			if (m.supportsVision == true) { obj['vision'] = true }
			if (m.supportsToolCall == true) { obj['toolCall'] = true }
			if (m.supportsReasoning == true) { obj['reasoning'] = true }
		}
		// UI state 不存
		list.push(obj)
	}
	return JSON.stringify(list)
}

/**
 * 从 JSON 字符串解析模型列表（兼容旧格式 ["id1","id2"]）
 */
export function parseModels(modelsStr: string): ModelInfo[] {
	if (modelsStr == '' || modelsStr == '[]') {
		return []
	}
	try {
		const raw = JSON.parse(modelsStr) as any[]
		const result: ModelInfo[] = []
		for (let i = 0; i < raw.length; i++) {
			const item = raw[i]
			if (typeof item == 'string') {
				// 旧格式 ["model-id"]
				result.push({ id: item, supportsVision: false, supportsToolCall: false, supportsReasoning: false, capabilitiesKnown: false } as ModelInfo)
			} else if (typeof item == 'object' && item != null) {
				// 新格式 [{"id":"...","context":...}]
				const obj = item as UTSJSONObject
				const mid = obj['id'] as string | null
				if (mid != null && mid != '') {
					const mi: ModelInfo = { id: mid, ctxStr: '', maxTokensStr: '', expanded: false, supportsVision: false, supportsToolCall: false, supportsReasoning: false, capabilitiesKnown: false } as ModelInfo
					// name
					const nm = obj['name'] as string | null
					if (nm != null && nm != '') {
						mi.name = nm
					}
					// context
					const ctx = obj['context'] as number | null
					if (ctx != null && ctx > 0) {
						mi.context = ctx
						mi.ctxStr = ctx + ''
					}
					// maxTokens
					const mt = obj['maxTokens'] as number | null
					if (mt != null && mt > 0) {
						mi.maxTokens = mt
						mi.maxTokensStr = mt + ''
					}
					// custom params
					const pms = obj['params'] as string | null
					if (pms != null && pms != '') {
						mi.params = pms
					}
					// vision capability
					const vision = obj['vision'] as boolean | null
					mi.supportsVision = vision == true
					// tool call capability
					const toolCall = obj['toolCall'] as boolean | null
					mi.supportsToolCall = toolCall == true
					// reasoning capability
					const reasoning = obj['reasoning'] as boolean | null
					mi.supportsReasoning = reasoning == true
					// 旧对象常只保存 true 字段；三项齐全才代表 false 也是显式配置。
					mi.capabilitiesKnown = vision != null && toolCall != null && reasoning != null
					result.push(mi)
				}
			}
		}
		return result
	} catch (_e: any) {
		return []
	}
}

/**
 * 获取提供商的模型列表（返回 ModelInfo[]）
 */
export function getProviderModels(id: string): ModelInfo[] {
	const p = dbGetProviderById(id)
	if (p == null) {
		return []
	}
	const modelsStr = p['models'] as string | null
	if (modelsStr == null || modelsStr == '') {
		return []
	}
	return parseModels(modelsStr)
}

/**
 * 获取提供商的模型 ID 列表（向后兼容）
 */
export function getProviderModelIds(id: string): string[] {
	const models = getProviderModels(id)
	const ids: string[] = []
	for (let i = 0; i < models.length; i++) {
		ids.push(models[i].id)
	}
	return ids
}

function createUnknownModelRuntime(model: string): ModelRuntimeOptions {
	return {
		modelId: model,
		context: 0,
		maxTokens: 0,
		params: '',
		supportsVision: false,
		// 旧版模型只有裸 ID 时曾经默认发送工具定义；继续保持这个兼容语义。
		supportsToolCall: true,
		supportsReasoning: false,
		found: false,
		capabilitiesKnown: false,
	} as ModelRuntimeOptions
}

/** 按 provider + model 精确读取模型能力，禁止跨 Provider 同名模型串线。 */
export function resolveModelRuntime(providerId: string, model: string): ModelRuntimeOptions {
	const unknown = createUnknownModelRuntime(model)
	if (providerId == '' || model == '') { return unknown }
	const models = getProviderModels(providerId)
	for (let i = 0; i < models.length; i++) {
		const item = models[i]
		if (item.id != model) { continue }
		return {
			modelId: item.id,
			context: item.context != null ? item.context : 0,
			maxTokens: item.maxTokens != null ? item.maxTokens : 0,
			params: item.params != null ? item.params : '',
			supportsVision: item.supportsVision == true,
			// 未声明能力的旧对象仍按兼容语义允许工具调用；明确 false 才禁用。
			supportsToolCall: item.capabilitiesKnown == true ? item.supportsToolCall == true : true,
			supportsReasoning: item.supportsReasoning == true,
			found: true,
			capabilitiesKnown: item.capabilitiesKnown == true,
		} as ModelRuntimeOptions
	}
	return unknown
}

/**
 * 保存提供商（models 传 ModelInfo[]）
 */
export function saveProvider(
	id: string,
	name: string,
	apiBase: string,
	apiKey: string,
	models: ModelInfo[],
	enabled: boolean
): boolean {
	let finalApiBase = apiBase
	if (finalApiBase == '') {
		finalApiBase = getDefaultUrl(id)
	}
	return dbSaveProvider(id, name, finalApiBase, apiKey, serializeModels(models), enabled)
}

/** 首次引导一次性提交 Provider、启用态、默认聊天模型和完成标记。 */
export function saveFirstRunProviderConfiguration(id: string, name: string, apiBase: string, apiKey: string, models: ModelInfo[], defaultModel: string): boolean {
	let finalApiBase = apiBase
	if (finalApiBase == '') { finalApiBase = getDefaultUrl(id) }
	return dbSaveFirstRunProviderConfiguration(id, name, finalApiBase, apiKey, serializeModels(models), defaultModel)
}

/**
 * 删除提供商
 */
export function deleteProvider(id: string): boolean {
	return dbDeleteProvider(id)
}

/**
 * 设置提供商启用状态
 */
export function setProviderEnabled(id: string, enabled: boolean): boolean {
	return dbToggleProvider(id, enabled)
}

/**
 * 启用一个提供商（同时禁用其他）
 */
export function setActiveProvider(id: string): boolean {
	const all = dbGetAllProviders()
	let found = false
	for (let i = 0; i < all.length; i++) {
		const providerId = all[i]['id'] as string | null
		if (providerId != null && providerId == id) {
			found = true
			break
		}
	}
	if (found == false) { return false }
	return dbActivateProvider(id)
}

/**
 * 获取提供商的有效 API 配置
 */
export function getProviderApiConfig(id: string): UTSJSONObject | null {
	const p = dbGetProviderById(id)
	if (p == null) {
		return null
	}
	const enabled = p['enabled'] as number | null
	if (enabled == null || enabled != 1) {
		return null
	}
	const apiBase = p['api_base'] as string | null
	const apiKey = p['api_key'] as string | null
	const models = p['models'] as string | null
	return {
		api_base: apiBase != null ? apiBase : '',
		api_key: apiKey != null ? apiKey : '',
		models: models != null ? models : '[]',
		enabled: enabled != null ? enabled : 0,
	} as UTSJSONObject
}

// ==================== 获取模型列表 ====================

/**
 * 从提供商的 API 获取模型列表
 * 调用 GET {baseUrl}/v1/models
 */
export type ProviderModelsFetchResult = {
	ok: boolean
	ids: string[]
	errorCode: string
	errorMessage: string
	detail: string
	statusCode: number
}

export function resolveProviderModelAdapter(providerId: string, apiBase: string): ProviderModelAdapter {
	const lowerId = providerId.toLowerCase()
	const lowerBase = apiBase.toLowerCase()
	if (lowerId == 'anthropic' || lowerBase.indexOf('anthropic.com') >= 0 || lowerBase.indexOf('/anthropic') >= 0) {
		return 'anthropic'
	}
	return 'openai_compatible'
}

function buildProviderModelsFetchResult(ok: boolean, ids: string[], errorCode: string, errorMessage: string, detail: string, statusCode: number): ProviderModelsFetchResult {
	return {
		ok: ok,
		ids: ids,
		errorCode: errorCode,
		errorMessage: errorMessage,
		detail: detail,
		statusCode: statusCode,
	} as ProviderModelsFetchResult
}

function buildProviderModelsHttpMessage(statusCode: number): string {
	if (statusCode == 401 || statusCode == 403) { return 'API Key 无效或没有模型列表权限' }
	if (statusCode == 404) { return '模型列表接口不存在，请检查接口地址' }
	if (statusCode == 408 || statusCode == 504) { return '模型列表请求超时，请稍后重试' }
	if (statusCode >= 500) { return '模型服务暂时不可用，请稍后重试' }
	return '模型列表请求失败，HTTP ' + statusCode
}

export function fetchProviderModelsDetailedForProvider(apiBase: string, apiKey: string, providerId: string): Promise<ProviderModelsFetchResult> {
	return new Promise<ProviderModelsFetchResult>((resolve) => {
		let baseUrl = apiBase
		if (baseUrl == '') {
			console.log('[Provider] 获取模型列表 ← 地址为空')
			resolve(buildProviderModelsFetchResult(false, [], 'PROVIDER_MODELS_BASE_URL_EMPTY', '接口地址不能为空', 'apiBase 为空', 0))
			return
		}
		// 去掉末尾 /
		if (baseUrl.endsWith('/')) {
			baseUrl = baseUrl.substring(0, baseUrl.length - 1)
		}
		// 检测 baseUrl 是否已包含 API 版本路径
		const hasApiVersion = baseUrl.indexOf('/v1') >= 0 || baseUrl.indexOf('/api/v') >= 0
		const adapter = resolveProviderModelAdapter(providerId, baseUrl)
		const fetchUrl = hasApiVersion ? baseUrl + '/models' : baseUrl + '/v1/models'
		const hasKey = apiKey != null && apiKey != ''
		console.log('[Provider] 获取模型列表 → ' + baseUrl + ' | adapter=' + adapter + ' | hasApiKey=' + hasKey)
		const requestHeader: UTSJSONObject = {
			'Content-Type': 'application/json',
		} as UTSJSONObject
		if (adapter == 'anthropic') {
			// Anthropic 使用 x-api-key + anthropic-version，不能复用 Bearer 头。
			requestHeader['x-api-key'] = apiKey
			requestHeader['anthropic-version'] = '2023-06-01'
		} else {
			requestHeader['Authorization'] = 'Bearer ' + apiKey
		}

		uni.request({
			url: fetchUrl,
			method: 'GET',
			timeout: 15000,
			header: requestHeader,
			success: (res) => {
				const statusCode = res.statusCode as number
				if (statusCode == 200) {
					try {
						const data = res.data as UTSJSONObject
						if (data == null) {
							console.log('[Provider] 获取模型列表 ← 200 | 响应体为空')
							resolve(buildProviderModelsFetchResult(false, [], 'PROVIDER_MODELS_RESPONSE_INVALID', '模型服务返回了无法识别的响应', 'HTTP 200 响应体为空', statusCode))
							return
						}
						const modelList = data['data'] as any[] | null
						if (modelList == null) {
							console.log('[Provider] 获取模型列表 ← 200 | 缺少 data 数组')
							resolve(buildProviderModelsFetchResult(false, [], 'PROVIDER_MODELS_RESPONSE_INVALID', '模型服务返回了无法识别的响应', 'HTTP 200 响应缺少 data 数组', statusCode))
							return
						}
						if (modelList.length == 0) {
							console.log('[Provider] 获取模型列表 ← 200 | data 数组为空，完整响应: ' + JSON.stringify(data).substring(0, JSON.stringify(data).length < 300 ? JSON.stringify(data).length : 300))
							resolve(buildProviderModelsFetchResult(true, [], '', '', 'HTTP 200，data 数组为空', statusCode))
							return
						}
						const ids: string[] = []
						for (let i = 0; i < modelList.length; i++) {
							const item = modelList[i] as UTSJSONObject
							const mid = item['id'] as string | null
							if (mid != null && mid != '') {
								ids.push(mid)
							}
						}
						if (ids.length == 0) {
							resolve(buildProviderModelsFetchResult(false, [], 'PROVIDER_MODELS_RESPONSE_INVALID', '模型服务没有返回有效的模型 ID', 'HTTP 200，data 不为空但没有有效 id', statusCode))
							return
						}
						console.log('[Provider] 获取模型列表 ← 200 | ' + ids.length + ' 个模型: ' + ids.join(', '))
						resolve(buildProviderModelsFetchResult(true, ids, '', '', '', statusCode))
					} catch (e: any) {
						console.log('[Provider] 获取模型列表 ← 200 | JSON 解析失败')
						resolve(buildProviderModelsFetchResult(false, [], 'PROVIDER_MODELS_RESPONSE_INVALID', '模型服务返回了无法识别的响应', '' + e, statusCode))
					}
				} else {
					let errBody = ''
					try {
						const rawData = res.data as UTSJSONObject | null
						if (rawData != null) {
							errBody = JSON.stringify(rawData)
						}
					} catch (_e: any) {}
					const preview = errBody != '' ? errBody.substring(0, errBody.length < 300 ? errBody.length : 300) : '(无)'
					console.log('[Provider] 获取模型列表 ← ' + statusCode + ' | ' + preview)
					resolve(buildProviderModelsFetchResult(false, [], 'PROVIDER_MODELS_HTTP_ERROR', buildProviderModelsHttpMessage(statusCode), 'HTTP ' + statusCode + ' | ' + preview, statusCode))
				}
			},
			fail: (err: any) => {
				console.log('[Provider] 获取模型列表 ← 网络失败 | ' + fetchUrl)
				let detail = '' + err
				try {
					detail = JSON.stringify(err)
				} catch (_e: any) {}
				const lowerDetail = detail.toLowerCase()
				const isTimeout = lowerDetail.indexOf('timeout') >= 0 || lowerDetail.indexOf('超时') >= 0
				const errorCode = isTimeout == true ? 'PROVIDER_MODELS_TIMEOUT' : 'PROVIDER_MODELS_NETWORK_FAILED'
				const errorMessage = isTimeout == true ? '模型列表请求超时，请检查网络或接口地址' : '无法连接模型服务，请检查网络和接口地址'
				resolve(buildProviderModelsFetchResult(false, [], errorCode, errorMessage, detail, 0))
			}
		})
	})
}

/** 保留旧 API 与 JVM 签名；未提供 Provider 时按 OpenAI-compatible 处理。 */
export function fetchProviderModelsDetailed(apiBase: string, apiKey: string): Promise<ProviderModelsFetchResult> {
	return fetchProviderModelsDetailedForProvider(apiBase, apiKey, '')
}

export function fetchProviderModelsForProvider(apiBase: string, apiKey: string, providerId: string): Promise<string[]> {
	return new Promise<string[]>((resolve) => {
		fetchProviderModelsDetailedForProvider(apiBase, apiKey, providerId).then((result) => {
			resolve(result.ids)
		})
	})
}

/** 保留旧 API 与 JVM 签名，旧调用方仍只接收模型 ID。 */
export function fetchProviderModels(apiBase: string, apiKey: string): Promise<string[]> {
	return fetchProviderModelsForProvider(apiBase, apiKey, '')
}

// ==================== 默认模型分配 ====================

/** 任务类型中文名 */
const taskTypeNames: UTSJSONObject = {
	chat: '对话',
	memory_organize: '记忆整理',
	vision: '图片转述',
	stt: '语音识别',
	tts: '语音合成',
} as UTSJSONObject

/** 任务类型 key 前缀 */
const TASK_KEY_PREFIX = 'default_task_'

export const TTS_ADAPTER_OPENAI_COMPAT = 'openai_compatible'
export const TTS_ADAPTER_VOLCENGINE = 'volcengine'

const TTS_FIELD_ADAPTER = 'ttsAdapter'
const TTS_FIELD_VOICE = 'ttsVoice'
const TTS_FIELD_RESPONSE_FORMAT = 'ttsResponseFormat'
const TTS_FIELD_SPEED = 'ttsSpeed'
const TTS_FIELD_VOLUME = 'ttsVolume'
const TTS_FIELD_PITCH = 'ttsPitch'
const TTS_FIELD_EXTRA_PARAMS = 'ttsExtraParams'

function readConfigString(config: UTSJSONObject | null, key: string): string {
	if (config == null) { return '' }
	const raw = config[key] as string | null
	return raw != null ? raw : ''
}

function copyTTSFields(source: UTSJSONObject | null, target: UTSJSONObject): void {
	let adapter = readConfigString(source, TTS_FIELD_ADAPTER)
	if (adapter == '') { adapter = TTS_ADAPTER_OPENAI_COMPAT }
	target[TTS_FIELD_ADAPTER] = adapter
	target[TTS_FIELD_VOICE] = readConfigString(source, TTS_FIELD_VOICE)
	target[TTS_FIELD_RESPONSE_FORMAT] = readConfigString(source, TTS_FIELD_RESPONSE_FORMAT)
	target[TTS_FIELD_SPEED] = readConfigString(source, TTS_FIELD_SPEED)
	target[TTS_FIELD_VOLUME] = readConfigString(source, TTS_FIELD_VOLUME)
	target[TTS_FIELD_PITCH] = readConfigString(source, TTS_FIELD_PITCH)
	target[TTS_FIELD_EXTRA_PARAMS] = readConfigString(source, TTS_FIELD_EXTRA_PARAMS)
}

/**
 * 获取任务类型中文名
 */
export function getTaskTypeName(type: string): string {
	const name = taskTypeNames[type] as string | null
	return name != null ? name : type
}

/**
 * 获取某个任务的默认提供商 + 模型
 * 返回 { providerId, model }
 */
export function getDefaultTaskModel(type: string): UTSJSONObject | null {
	const key = TASK_KEY_PREFIX + type
	const val = getAppSetting(key)
	if (val == null || val == '') {
		return null
	}
	try {
		const parsed = JSON.parse(val) as UTSJSONObject
		// 校验解析结果，避免缺少 providerId / model 的脏数据
		const rawPid = parsed['providerId']
		const rawModel = parsed['model']
		if (rawPid == null || rawModel == null) {
			return null
		}
		return parsed
	} catch (_e: any) {
		return null
	}
}

/**
 * 获取 TTS 额外参数。
 */
export function getDefaultTTSSettings(): UTSJSONObject {
	const config = getDefaultTaskModel('tts')
	let adapter = readConfigString(config, TTS_FIELD_ADAPTER)
	if (adapter == '') { adapter = TTS_ADAPTER_OPENAI_COMPAT }
	return {
		adapter: adapter,
		voice: readConfigString(config, TTS_FIELD_VOICE),
		responseFormat: readConfigString(config, TTS_FIELD_RESPONSE_FORMAT),
		speed: readConfigString(config, TTS_FIELD_SPEED),
		volume: readConfigString(config, TTS_FIELD_VOLUME),
		pitch: readConfigString(config, TTS_FIELD_PITCH),
		extraParams: readConfigString(config, TTS_FIELD_EXTRA_PARAMS),
	} as UTSJSONObject
}

/**
 * 设置 TTS 额外参数，和 default_task_tts 保存在一起。
 */
export function setDefaultTTSModelSettings(providerId: string, model: string, adapter: string, voice: string, responseFormat: string, speed: string, volume: string, pitch: string, extraParams: string): boolean {
	let normalizedAdapter = adapter.trim()
	if (normalizedAdapter == '') { normalizedAdapter = TTS_ADAPTER_OPENAI_COMPAT }
	const val = JSON.stringify({
		providerId: providerId,
		model: model,
		ttsAdapter: normalizedAdapter,
		ttsVoice: voice.trim(),
		ttsResponseFormat: responseFormat.trim(),
		ttsSpeed: speed.trim(),
		ttsVolume: volume.trim(),
		ttsPitch: pitch.trim(),
		ttsExtraParams: extraParams.trim(),
	})
	return setAppSetting(TASK_KEY_PREFIX + 'tts', val)
}

export function setDefaultTTSSettings(adapter: string, voice: string, responseFormat: string, speed: string, volume: string, pitch: string, extraParams: string): boolean {
	const current = getDefaultTaskModel('tts')
	let providerId = ''
	let model = ''
	if (current != null) {
		const rawPid = current['providerId'] as string | null
		const rawModel = current['model'] as string | null
		providerId = rawPid != null ? rawPid : ''
		model = rawModel != null ? rawModel : ''
	}
	return setDefaultTTSModelSettings(providerId, model, adapter, voice, responseFormat, speed, volume, pitch, extraParams)
}

/**
 * 设置某个任务的默认提供商 + 模型。
 */
export function setDefaultTaskModel(type: string, providerId: string, model: string): boolean {
	const key = TASK_KEY_PREFIX + type
	const current = type == 'tts' ? getDefaultTaskModel('tts') : null
	const next: UTSJSONObject = {
		providerId: providerId,
		model: model,
	} as UTSJSONObject
	if (type == 'tts') {
		copyTTSFields(current, next)
	}
	if (providerId == '' || model == '') {
		if (type == 'tts') {
			return setAppSetting(key, JSON.stringify(next))
		}
		return setAppSetting(key, '')
	}
	return setAppSetting(key, JSON.stringify(next))
}

/** 保存默认对话模型。 */
export function setDefaultChatTaskModel(providerId: string, model: string): boolean {
	if (providerId == '' || model == '') { return false }
	return setAppSetting('default_task_chat', JSON.stringify({ providerId: providerId, model: model }))
}

export function getMemoryOrganizeTaskModel(): UTSJSONObject | null {
	const config = getDefaultTaskModel('memory_organize')
	if (config == null) return null
	const rawPid = config['providerId'] as string | null
	const rawModel = config['model'] as string | null
	const providerId = rawPid != null ? rawPid : ''
	const model = rawModel != null ? rawModel : ''
	if (providerId == '' || model == '') return null
	return config
}

export function getVisionTaskModel(): UTSJSONObject | null {
	const config = getDefaultTaskModel('vision')
	if (config == null) return null
	const rawPid = config['providerId'] as string | null
	const rawModel = config['model'] as string | null
	const providerId = rawPid != null ? rawPid : ''
	const model = rawModel != null ? rawModel : ''
	if (providerId == '' || model == '') return null
	return config
}

const IMAGE_CAPTION_PROMPT_KEY = 'image_caption_prompt'
const DEFAULT_IMAGE_CAPTION_PROMPT = '请用中文简洁描述这张图片，保留对后续对话有用的主体、文字、场景和细节。'

export function getImageCaptionPrompt(): string {
	const value = getAppSetting(IMAGE_CAPTION_PROMPT_KEY)
	if (value != null && value != '') {
		return value
	}
	return DEFAULT_IMAGE_CAPTION_PROMPT
}

export function setImageCaptionPrompt(prompt: string): boolean {
	return setAppSetting(IMAGE_CAPTION_PROMPT_KEY, prompt)
}


/**
 * 解析 LLM 配置（按优先级）
 * 1. 显式 providerId + model
 * 2. chat 默认模型配置
 */
export function resolveLLMConfig(providerId: string, model: string): LLMConfig | null {
	let pid = providerId
	let mdl = model

	// 支持 "providerId||modelId" 复合格式
	if (mdl != '') {
		const sep = '||'
		const idx = mdl.indexOf(sep)
		if (idx >= 0) {
			const extractedPid = mdl.substring(0, idx)
			const extractedMid = mdl.substring(idx + sep.length)
			if (pid == '') {
				pid = extractedPid
			}
			mdl = extractedMid
		}
	}

	if (pid == '') {
		const defaultConfig = getDefaultTaskModel('chat')
		if (defaultConfig != null) {
			const defaultProvider = defaultConfig['providerId'] as string | null
			const defaultModel = defaultConfig['model'] as string | null
			if (defaultProvider != null) {
				pid = defaultProvider
			}
			if (mdl == '' && defaultModel != null) {
				mdl = defaultModel
			}
		}
	}

	if (pid == '' || mdl == '') {
		return null
	}

	const provider = getProviderById(pid)
	if (provider != null) {
		const enabledRaw = provider['enabled'] as number | null
		if (enabledRaw == null || enabledRaw != 1) {
			return null
		}
		const apiKeyRaw = provider['api_key'] as string | null
		const baseUrlRaw = provider['api_base'] as string | null
		const apiKey = apiKeyRaw != null ? apiKeyRaw : ''
		let baseUrl = baseUrlRaw != null ? baseUrlRaw : ''
		if (baseUrl == '') {
			baseUrl = getDefaultUrl(pid)
		}
		if (apiKey == '') {
			return null
		}
		return {
			providerId: pid,
			apiKey: apiKey,
			baseUrl: baseUrl,
			model: mdl,
			adapter: resolveProviderModelAdapter(pid, baseUrl),
			modelRuntime: resolveModelRuntime(pid, mdl),
		} as LLMConfig
	}
	return null
}


/**
 * 获取所有任务的默认配置
 */
export function getAllDefaultTaskModels(): UTSJSONObject[] {
	const taskTypes: string[] = ['chat', 'memory_organize', 'vision', 'stt', 'tts']
	const result: UTSJSONObject[] = []
	for (let i = 0; i < taskTypes.length; i++) {
		const t = taskTypes[i]
		const config = getDefaultTaskModel(t)
		let providerId = ''
		let model = ''
		if (config != null) {
			const rawPid = config['providerId']
			const rawModel = config['model']
			providerId = rawPid != null ? (rawPid as string) : ''
			model = rawModel != null ? (rawModel as string) : ''
		}
		const item: UTSJSONObject = {
			type: t,
			typeName: getTaskTypeName(t),
			providerId: providerId,
			model: model,
		} as UTSJSONObject
		if (t == 'tts') {
			copyTTSFields(config, item)
		}
		result.push(item)
	}
	return result
}
