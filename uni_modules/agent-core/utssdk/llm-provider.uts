/**
 * LLM Provider 抽象基类
 * 定义 LLM 调用的统一接口，由具体 Provider 子类实现
 */

import { ModelConfig, ChatRequest, AssistantMessage } from './types'

/**
 * LLM Provider 基类
 * 提供统一的聊天请求接口，子类需覆盖 chat 方法
 */
export class LLMProvider {
	/** 模型配置 */
	protected config : ModelConfig

	/**
	 * 构造函数
	 * @param config 模型配置
	 */
	constructor(config : ModelConfig) {
		this.config = config
	}

	/**
	 * 发送聊天请求（非流式）
	 * 子类必须覆盖此方法实现具体的 API 调用逻辑
	 * @param request 聊天请求参数
	 * @returns 助手消息响应
	 */
	chat(request : ChatRequest) : Promise<AssistantMessage> {
		return new Promise<AssistantMessage>((_, reject) => {
			reject(new Error('chat() 必须由子类覆盖实现'))
		})
	}

	/**
	 * 获取当前模型配置
	 * @returns 模型配置
	 */
	getConfig() : ModelConfig {
		return this.config
	}
}
