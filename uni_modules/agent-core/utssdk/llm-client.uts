/**
 * LLM 调用客户端（SDK 模块）
 *
 * 直接使用 uni.request 调用 OpenAI 兼容 API，支持流式 SSE + 非流式。
 * 包含 ReAct Agent 循环（runAgentLoop）和记忆管理器。
 *
 * 依赖（逐步迁入 SDK）：
 * - event.uts ✅ → SDK types.uts
 * - memory.uts ✅ → SDK memory.uts
 * - llm-diagnostics.uts ✅ → LLM 调用诊断、快照与日志
 * - provider.uts ⏳ → 待迁移
 * - agent-tools.uts ⏳ → 待迁移
 * - agent.uts / skills.uts / generation-settings.uts → 业务层
 *
 * 配置来源优先级（从高到低）：
 * 1. 显式传入的 providerId + model
 * 2. DB 中 chat 任务的默认配置
 * 3. 旧版 storage key（向后兼容）
 */

export type ToolCallInfo = {
	id: string
	name: string
	arguments: string
}

export type PreparedAgentContext = {
	workingMessages: UTSJSONObject[]
	toolDefs: UTSJSONObject[]
	importantMemory: string
	bufferInjection: string
	lastUserIndex: number
	droppedCount: number
	droppedScore: number
	truncateThreshold: number
	truncateDropScore: number
	droppedMessages: UTSJSONObject[]
}



type ImageBase64Result = {
	data: string
	mimeType: string
}

import { resolveLLMConfig, normalizeBaseUrl, getMemoryOrganizeTaskModel, getVisionTaskModel, getImageCaptionPrompt, stripThinkTags, getAllProviders, getProviderModels } from './provider'
import { getAgentById, isAgentToolEnabled, AGENT_TOOL_MEMORY_BUFFER_WRITE } from '@/utils/agent.uts'
import { getGlobalGenerationSettings, getEffectiveGenerationSettings, getMemoryOrganizerGenerationSettings, GenerationSettings } from '@/utils/generation-settings.uts'
import { createAgentTools, AgentTool, ToolResult } from './tools/agent-tools'
import { AgentEventStream, AgentEvent } from '@/utils/event.uts'
import { buildImportantMemoryInjection, buildBufferInjection, getMemoryEnabled, saveMemoryManagerLog, MemoryManagerLog, getMemoryCompactionCursor, saveMemoryCompactionCursor } from './memory'
import { buildAgentSkillsPrompt } from '@/utils/skills.uts'
import { wrapUserContentForAgent, makeAgentContextBlock, type AgentContextBlock } from '@/utils/message-context.uts'
import { appendResponseToSnapshot as appendResponseToSnapshotDiagnostic, clearLastTokenUsage, formatBodyForLog, isLLMDebugLogEnabled, logLLMDebug, readLastLLMPreviewState, readLastLLMRequestSnapshot as readLastLLMRequestSnapshotDiagnostic, readLastTokenUsageForCall, saveLastLLMCall, saveLastLLMRequestSnapshot, saveLastTokenUsage } from './llm-diagnostics'
import { collectApiToolCalls, findEmbeddedToolResult, getFirstImagePathFromParts, getMessageApiText, getMessageReasoningText, hasAssistantToolCalls, normalizeToolCallId } from './llm-message-utils'
import { buildDroppedMessagesPreview, buildMemoryManagerMessages, buildMemoryManagerSystemPrompt, clearMemoryCompactionRunning, collectUncompactedMemoryCandidates, findLatestMessageTimestamp, getContextMessageScore, isMemoryCompactionRunning, markMemoryCompactionRunning, registerMemoryManagerLoopStarter, startMemoryOrganization } from './llm-memory-organizer'
export * from './llm-memory-organizer'

export function readLastLLMRequestSnapshot(agentId: string = '', conversationId: string = ''): UTSJSONObject | null {
	return readLastLLMRequestSnapshotDiagnostic(agentId, conversationId)
}

export function appendResponseToSnapshot(agentId: string, conversationId: string, responseText: string, thinkingText: string = ''): void {
	appendResponseToSnapshotDiagnostic(agentId, conversationId, responseText, thinkingText)
}

// ====== 内部函数 ======

function buildOpenAIToolDefs(tools: AgentTool[]): UTSJSONObject[] {
	const toolDefs: UTSJSONObject[] = []
	for (let i = 0; i < tools.length; i++) {
		toolDefs.push({
			name: tools[i].name,
			description: tools[i].description,
			parameters: tools[i].parameters,
		} as UTSJSONObject)
	}
	return toolDefs
}

function readImageAsBase64(imagePath: string): ImageBase64Result | null {
	try {
		const fm = uni.getFileSystemManager()
		const base64 = fm.readFileSync(imagePath, 'base64')
		if (base64 == null) {
			console.log('[LLM] 读取图片失败: readFileSync 返回 null | path=' + imagePath)
			return null
		}
		let raw = base64 as string
		// 移除可能有的换行符（某些平台的 base64 输出会插入 \n）
		raw = raw.split('\n').join('').split('\r').join('')
		let mimeType = 'image/jpeg'
		const lower = imagePath.toLowerCase()
		if (lower.endsWith('.png')) mimeType = 'image/png'
		else if (lower.endsWith('.gif')) mimeType = 'image/gif'
		else if (lower.endsWith('.webp')) mimeType = 'image/webp'
		else if (lower.endsWith('.bmp')) mimeType = 'image/bmp'
		console.log('[LLM] 读取图片成功: type=' + mimeType + ' size=' + raw.length + ' path=' + imagePath)
		return { data: raw, mimeType: mimeType }
	} catch (_e: any) {
		console.log('[LLM] 读取图片异常: ' + _e + ' | path=' + imagePath)
		return null
	}
}

/**
 * 判断模型是否支持多模态（vision/image 输入）
 * 基于模型名关键词匹配，覆盖主流多模态模型
 */
function isVisionModel(model: string): boolean {
	const m = model.toLowerCase()
	if (m.indexOf('vision') >= 0) return true   // gpt-4-vision, qwen-vl, etc.
	if (m.indexOf('vl') >= 0) return true        // Qwen-VL, InternVL
	if (m.indexOf('gpt-4o') >= 0) return true    // GPT-4o / GPT-4o-mini (native vision)
	if (m.indexOf('gpt-4-turbo') >= 0) return true
	if (m.indexOf('gemini-2') >= 0) return true  // Gemini 2.0+
	if (m.indexOf('gemini-1.5') >= 0) return true // Gemini 1.5
	if (m.indexOf('claude-3') >= 0) return true   // Claude 3+
	if (m.indexOf('claude-3.5') >= 0) return true
	if (m.indexOf('qvq') >= 0) return true        // Qwen QVQ
	if (m.indexOf('qwq') >= 0) return true
	return false
}

/**
 * 根据模型 ID 查找其 vision 能力标记
 * 遍历所有启用的提供商，匹配模型 ID 返回 supportsVision
 */
function getModelVisionSupport(modelId: string): boolean {
	const allProviders = getAllProviders()
	for (let i = 0; i < allProviders.length; i++) {
		const p = allProviders[i]
		if (p['enabled'] != 1) continue
		const models = getProviderModels(p['id'] as string)
		for (let j = 0; j < models.length; j++) {
			if (models[j].id == modelId) {
				return models[j].supportsVision == true
			}
		}
	}
	return false
}

/**
 * 根据模型 ID 查找其 reasoning 开关
 * 遍历所有启用的提供商，匹配模型 ID 返回 supportsReasoning
 */
function getModelReasoningEnabled(modelId: string): boolean {
	const allProviders = getAllProviders()
	for (let i = 0; i < allProviders.length; i++) {
		const p = allProviders[i]
		if (p['enabled'] != 1) continue
		const models = getProviderModels(p['id'] as string)
		for (let j = 0; j < models.length; j++) {
			if (models[j].id == modelId) {
				return models[j].supportsReasoning == true
			}
		}
	}
	return false
}


function buildImageUserMessageContent(prompt: string, imagePath: string): UTSJSONObject[] | null {
	const imageResult = readImageAsBase64(imagePath)
	if (imageResult == null) {
		return null
	}
	const dataUrl = 'data:' + imageResult.mimeType + ';base64,' + imageResult.data
	const safeText = prompt != '' ? prompt : '[图片]'
	const contentJsonStr = '[{"type":"text","text":' + JSON.stringify(safeText) + '},{"type":"image_url","image_url":{"url":' + JSON.stringify(dataUrl) + ',"detail":"auto"}}]'
	try {
		return JSON.parse(contentJsonStr) as UTSJSONObject[]
	} catch (_e: any) {
		console.log('[LLM] 图片 content JSON 构造失败: ' + _e)
		return null
	}
}

function readMessageToolCallId(msg: UTSJSONObject): string {
	const rawToolCallId = msg['tool_call_id']
	const tcId = rawToolCallId != null ? rawToolCallId : msg['toolCallId']
	if (tcId == null) {
		return ''
	}
	return tcId as string
}

function hasCompleteFollowingToolResults(messages: UTSJSONObject[], assistantIndex: number, apiToolCalls: UTSJSONObject[]): boolean {
	if (apiToolCalls.length == 0) {
		return false
	}
	const assistantMsg = messages[assistantIndex]
	let cursor = assistantIndex + 1
	for (let i = 0; i < apiToolCalls.length; i++) {
		const expectedIdRaw = apiToolCalls[i]['id'] as string | null
		const expectedId = expectedIdRaw != null ? expectedIdRaw : ''
		if (expectedId == '') {
			return false
		}
		const embeddedResult = findEmbeddedToolResult(assistantMsg, expectedId)
		if (embeddedResult != null) {
			continue
		}
		if (cursor >= messages.length) {
			return false
		}
		const nextMsg = messages[cursor]
		const nextRole = nextMsg['role'] as string | null
		if (nextRole != 'tool' && nextRole != 'toolResult') {
			return false
		}
		const actualId = readMessageToolCallId(nextMsg)
		if (actualId != expectedId) {
			return false
		}
		cursor++
	}
	return true
}

function appendPendingToolCallIds(apiToolCalls: UTSJSONObject[], pendingToolCallIds: string[], msg: UTSJSONObject): void {
	for (let i = 0; i < apiToolCalls.length; i++) {
		const rawId = apiToolCalls[i]['id'] as string | null
		const id = rawId != null ? rawId : ''
		if (id != '') {
			const embeddedResult = findEmbeddedToolResult(msg, id)
			if (embeddedResult == null) {
				pendingToolCallIds.push(id)
			}
		}
	}
}

function appendEmbeddedToolResultMessages(apiMessages: UTSJSONObject[], apiToolCalls: UTSJSONObject[], msg: UTSJSONObject): void {
	for (let i = 0; i < apiToolCalls.length; i++) {
		const rawId = apiToolCalls[i]['id'] as string | null
		const id = rawId != null ? rawId : ''
		if (id == '') {
			continue
		}
		const embeddedResult = findEmbeddedToolResult(msg, id)
		if (embeddedResult != null) {
			apiMessages.push({
				role: 'tool',
				tool_call_id: id,
				content: embeddedResult,
			} as UTSJSONObject)
		}
	}
}

function consumePendingToolCallId(pendingToolCallIds: string[], toolCallId: string): boolean {
	if (pendingToolCallIds.length == 0 || toolCallId == '') {
		return false
	}
	if (pendingToolCallIds[0] != toolCallId) {
		return false
	}
	pendingToolCallIds.splice(0, 1)
	return true
}

function buildOpenAIMessages(systemPrompt: string, messages: UTSJSONObject[], supportsVision: boolean): UTSJSONObject[] {
	const apiMessages: UTSJSONObject[] = []
	const pendingToolCallIds: string[] = []
	if (systemPrompt != '') {
		apiMessages.push({
			role: 'system',
			content: systemPrompt,
		} as UTSJSONObject)
	}
	for (let i = 0; i < messages.length; i++) {
		const msg = messages[i]
		const role = msg['role'] as string | null
		if (role == null) continue
		const apiToolCalls = collectApiToolCalls(msg)
		if (role == 'assistant' && (msg['isStreaming'] as boolean | null) == true && apiToolCalls.length == 0) continue

		if (role == 'tool' || role == 'toolResult') {
			const tcId = readMessageToolCallId(msg)
			if (tcId == '') continue
			if (consumePendingToolCallId(pendingToolCallIds, tcId) == false) {
				console.log('[LLM] 跳过孤立 toolResult，避免 OpenAI 400 | tool_call_id=' + tcId)
				continue
			}
			apiMessages.push({
				role: 'tool',
				tool_call_id: tcId,
				content: getMessageApiText(msg),
			} as UTSJSONObject)
		} else if (role == 'assistant' && apiToolCalls.length > 0) {
			if (hasCompleteFollowingToolResults(messages, i, apiToolCalls) == true) {
				const amsg: UTSJSONObject = {
					role: 'assistant',
					content: getMessageApiText(msg),
					tool_calls: apiToolCalls,
				} as UTSJSONObject
				const reasoningHistory = getMessageReasoningText(msg)
				if (reasoningHistory != '') {
					amsg['reasoning_content'] = reasoningHistory
				}
				apiMessages.push(amsg)
				appendEmbeddedToolResultMessages(apiMessages, apiToolCalls, msg)
				appendPendingToolCallIds(apiToolCalls, pendingToolCallIds, msg)
			} else {
				const textContent = getMessageApiText(msg)
				if (textContent != '') {
					apiMessages.push({
						role: 'assistant',
						content: textContent,
					} as UTSJSONObject)
				} else {
					console.log('[LLM] 跳过缺少 toolResult 的历史工具调用，避免 OpenAI 400')
				}
			}
		} else {
			const textContent = getMessageApiText(msg)
			const imagePath = getFirstImagePathFromParts(msg)
			if (role == 'user' && imagePath != '') {
				if (supportsVision == false) {
					console.log('[LLM] 当前模型不支持多模态，图片消息降级为纯文本')
					apiMessages.push({
						role: 'user',
						content: textContent != '' ? textContent : '[图片]',
					} as UTSJSONObject)
					continue
				}
				const contentJson = buildImageUserMessageContent(textContent != '' ? textContent : '[图片]', imagePath)
				if (contentJson != null) {
					apiMessages.push({
						role: 'user',
						content: contentJson,
					} as UTSJSONObject)
				} else {
					console.log('[LLM] 图片 base64 读取失败，回退纯文本 | path=' + imagePath)
					apiMessages.push({
						role: 'user',
						content: textContent,
					} as UTSJSONObject)
				}
			} else {
				const apiMsg: UTSJSONObject = {
					role: role,
					content: textContent,
				} as UTSJSONObject
				if (role == 'assistant') {
					const reasoningHistory = getMessageReasoningText(msg)
					if (reasoningHistory != '') {
						apiMsg['reasoning_content'] = reasoningHistory
					}
				}
				apiMessages.push(apiMsg)
			}
		}
	}
	return apiMessages
}

function buildUserPrefixContextBlocks(msg: UTSJSONObject): AgentContextBlock[] {
	const blocks: AgentContextBlock[] = []
	const rawBefore = msg['agent_context_before'] as string | null
	if (rawBefore != null) {
		const beforeContent = rawBefore as string
		if (beforeContent.trim() != '') {
			const rawLabel = msg['agent_context_before_label'] as string | null
			let label = '前置上下文'
			if (rawLabel != null) {
				if (rawLabel != '') {
					label = rawLabel
				}
			}
			blocks.push(makeAgentContextBlock('before', label, beforeContent))
		}
	}
	return blocks
}

function buildUserMessageForAgent(msg: UTSJSONObject, suffixBlocks: AgentContextBlock[]): UTSJSONObject {
	const baseContent = getMessageApiText(msg)
	const prefixBlocks = buildUserPrefixContextBlocks(msg)
	if (prefixBlocks.length == 0 && suffixBlocks.length == 0) {
		return msg
	}
	const raw = JSON.stringify(msg)
	const cloned = JSON.parse(raw) as UTSJSONObject
	cloned['role'] = 'user'
	cloned['agent_text_override'] = wrapUserContentForAgent(baseContent, prefixBlocks, suffixBlocks)
	cloned['content'] = cloned['agent_text_override']
	return cloned
}

function normalizeContextSkipCount(messages: UTSJSONObject[], skipCount: number): number {
	if (skipCount <= 0) return 0
	let counted = 0
	let nextIndex = messages.length
	for (let i = 0; i < messages.length; i++) {
		const msgScore = getContextMessageScore(messages[i])
		if (msgScore <= 0) continue
		counted++
		if (counted >= skipCount) {
			nextIndex = i + 1
			break
		}
	}
	while (nextIndex < messages.length) {
		const role = messages[nextIndex]['role'] as string | null
		if (role != 'tool' && role != 'toolResult') break
		if (getContextMessageScore(messages[nextIndex]) > 0) {
			counted++
		}
		nextIndex++
	}
	return counted
}

function prepareAgentContext(
	messages: UTSJSONObject[],
	systemPrompt: string,
	agentId: string,
	conversationId: string,
	allowCoreMemoryWrite: boolean = false,
	enableContextTruncation: boolean = true,
	workspaceRoot: string = ''
): PreparedAgentContext {
	const workingMessages: UTSJSONObject[] = []
	const droppedMessages: UTSJSONObject[] = []
	const agent = getAgentById(agentId)
	if (systemPrompt != '') {
		workingMessages.push({
			role: 'system',
			content: systemPrompt,
		} as UTSJSONObject)
	}
	if (allowCoreMemoryWrite == false) {
		const skillsPrompt = buildAgentSkillsPrompt(agentId)
		if (skillsPrompt != '') {
			workingMessages.push({
				role: 'system',
				content: skillsPrompt,
			} as UTSJSONObject)
		}
	}
	if (allowCoreMemoryWrite == false && isAgentToolEnabled(agent, AGENT_TOOL_MEMORY_BUFFER_WRITE, allowCoreMemoryWrite) == true) {
		workingMessages.push({
			role: 'system',
			content: '短记忆缓存使用策略：当用户提出或改变当前任务、临时要求、输出偏好、对话阶段或下一步动作时，优先调用 memory_buffer_write 写入一句 64 字以内短状态，覆盖旧缓存；它用于下一轮立刻接上上下文。没有短期状态变化、只是普通问答或闲聊收尾时不要调用。',
		} as UTSJSONObject)
	}
	const personId = 'default'
	const importantMemory = buildImportantMemoryInjection(agentId, personId, conversationId)
	if (importantMemory != '') {
		workingMessages.push({
			role: 'system',
			content: importantMemory,
		} as UTSJSONObject)
	}
	const bufferInjection = buildBufferInjection(agentId, personId, conversationId)
	let lastUserIndex = -1
	if (bufferInjection != '') {
		for (let i = 0; i < messages.length; i++) {
			const msg = messages[i]
			const role = msg['role'] as string | null
			if (role == 'user') {
				lastUserIndex = i
			}
		}
	}
	let remainingSkip = 0
	let droppedCount = 0
	let droppedScore = 0
	let truncateThreshold = 0
	let truncateDropScore = 0
	if (enableContextTruncation == true) {
		const systemCount = workingMessages.length
		// 截断权重：user 1，普通 assistant 0.3，工具调用/结果 0.1
		if (agent != null) {
			const rawThreshold = agent['truncateThreshold']
			const rawDropCount = agent['truncateDropCount']
			const threshold = rawThreshold != null ? (rawThreshold as number) : 40
			const dropScore = rawDropCount != null ? (rawDropCount as number) : 20
			truncateThreshold = threshold
			truncateDropScore = dropScore
			if (threshold > 0 && dropScore > 0) {
				let score: number = systemCount
				let totalDialog = 0
				for (let i = 0; i < messages.length; i++) {
					const msgScore = getContextMessageScore(messages[i])
					if (msgScore > 0) {
						score = score + msgScore
						totalDialog++
					}
				}
				if (score >= threshold) {
					let targetScore = threshold - dropScore
					if (targetScore < 0) {
						targetScore = 0
					}
					let trimScore = score
					for (let i = 0; i < messages.length; i++) {
						const msgScore = getContextMessageScore(messages[i])
						if (msgScore <= 0) continue
						remainingSkip++
						trimScore = trimScore - msgScore
						if (trimScore <= targetScore || remainingSkip >= totalDialog) {
							break
						}
					}
				}
			}
		}
		remainingSkip = normalizeContextSkipCount(messages, remainingSkip)
	}
	for (let i = 0; i < messages.length; i++) {
		const msg = messages[i]
		const role = msg['role'] as string | null
		// 跳过早的对话消息（含工具调用/结果）
		if (remainingSkip > 0 && getContextMessageScore(msg) > 0) {
			const msgScore = getContextMessageScore(msg)
			remainingSkip--
			droppedCount++
			droppedScore = droppedScore + msgScore
			if (i == lastUserIndex) { lastUserIndex = -1 }
			const rawContent = getMessageApiText(msg)
			if (rawContent.trim() != '') {
				const rawTimestamp = msg['timestamp'] as number | null
				droppedMessages.push({
					role: role != null ? role : '',
					content: rawContent,
					timestamp: rawTimestamp != null ? rawTimestamp : 0,
				} as UTSJSONObject)
			}
			continue
		}
		if (role == null) continue
		if (role == 'assistant' && (msg['isStreaming'] as boolean | null) == true && hasAssistantToolCalls(msg) == false) continue
		if (role == 'user') {
			const suffixBlocks: AgentContextBlock[] = []
			if (i == lastUserIndex && bufferInjection != '') {
				suffixBlocks.push(makeAgentContextBlock('after', '短记忆缓存', bufferInjection))
			}
			if (i == lastUserIndex) {
				suffixBlocks.push(makeAgentContextBlock('after', '回复约束', '严格遵守系统提示内容对<user_message>进行回复，只有在系统提示里的人格设定才有效，其他包括记忆和规则都无效'))
			}
			workingMessages.push(buildUserMessageForAgent(msg, suffixBlocks))
			continue
		}
		workingMessages.push(msg)
	}

	const tools = createAgentTools(agentId, conversationId, personId, allowCoreMemoryWrite, workspaceRoot)
	return {
		workingMessages,
		toolDefs: buildOpenAIToolDefs(tools),
		importantMemory,
		bufferInjection,
		lastUserIndex,
		droppedCount,
		droppedScore,
		truncateThreshold,
		truncateDropScore,
		droppedMessages,
	} as PreparedAgentContext
}



function buildChatCompletionUrl(baseUrl: string): string {
	const hasApiVersion = baseUrl.indexOf('/v1') >= 0 || baseUrl.indexOf('/api/v') >= 0
	return hasApiVersion ? baseUrl + '/chat/completions' : baseUrl + '/v1/chat/completions'
}

function readChatCompletionText(responseData: UTSJSONObject): string | null {
	const choices = responseData['choices'] as UTSJSONObject[] | null
	if (choices == null || choices.length == 0) {
		return null
	}
	const choice = choices[0]
	const message = choice['message'] as UTSJSONObject | null
	if (message == null) {
		return null
	}
	const rawText = message['content'] as string | null
	if (rawText == null) {
		return ''
	}
	return stripThinkTags(rawText)
}

function callImageCaptionAPI(
	baseUrl: string,
	apiKey: string,
	model: string,
	apiMessages: UTSJSONObject[],
	settings: GenerationSettings,
	done: (text: string | null) => void
): void {
	clearLastTokenUsage()
	const url = buildChatCompletionUrl(baseUrl)
	const headers: UTSJSONObject = {
		'Content-Type': 'application/json',
		'Authorization': 'Bearer ' + apiKey,
	} as UTSJSONObject
	let maxTokens = settings.maxTokens
	if (maxTokens > 1024) {
		maxTokens = 1024
	}
	const body: UTSJSONObject = {
		model: model,
		messages: apiMessages,
		max_tokens: maxTokens,
		temperature: settings.temperature,
		stream: false,
	} as UTSJSONObject

	if (isLLMDebugLogEnabled() == true) {
		console.log('[LLM] ====== IMAGE CAPTION REQUEST ======')
		console.log('[LLM] URL: ' + url)
		console.log('[LLM] Model: ' + model + ' | Messages: ' + apiMessages.length)
		console.log('[LLM] Body: ' + formatBodyForLog(body))
		console.log('[LLM] ===================================')
	}

	const bodyStr = JSON.stringify(body)
	const finalBody = JSON.parse(bodyStr)
	uni.request({
		url: url,
		method: 'POST',
		header: headers,
		data: finalBody,
		success: (res) => {
			const statusCode = res.statusCode as number
			if (statusCode != 200) {
				let errDetail = ''
				try {
					const errData = res.data as UTSJSONObject | null
					if (errData != null) {
						const errMsg = errData['error'] as UTSJSONObject | null
						if (errMsg != null) {
							const errMessage = errMsg['message'] as string | null
							errDetail = ': ' + (errMessage != null ? errMessage : '')
						}
					}
				} catch (_e: any) {}
				console.log('[LLM] 图片转述失败 Status: ' + statusCode + errDetail)
				saveLastLLMCall(false, false, model, baseUrl, statusCode, '图片转述失败' + errDetail, null, apiMessages.length, 0, 0, false)
				done(null)
				return
			}
			try {
				const responseData = res.data as UTSJSONObject
				if (responseData == null) {
					saveLastLLMCall(false, false, model, baseUrl, statusCode, '图片转述响应为空', null, apiMessages.length, 0, 0, false)
					done(null)
					return
				}
				const usage = responseData['usage'] as UTSJSONObject | null
				let normalizedUsage: UTSJSONObject | null = null
				if (usage != null) { normalizedUsage = saveLastTokenUsage(usage) }
				const text = readChatCompletionText(responseData)
				if (text == null) {
					saveLastLLMCall(false, false, model, baseUrl, statusCode, '图片转述 choices 为空', normalizedUsage, apiMessages.length, 0, 0, false)
					done(null)
					return
				}
				const preview = text != '' ? text.substring(0, text.length < 200 ? text.length : 200) : ''
				if (isLLMDebugLogEnabled() == true) {
					console.log('[LLM] ====== IMAGE CAPTION RESPONSE ======')
					console.log('[LLM] Status: 200 | ' + preview)
					console.log('[LLM] ====================================')
				}
				saveLastLLMCall(true, false, model, baseUrl, statusCode, '', normalizedUsage, apiMessages.length, 0, text.length, false)
				done(text)
			} catch (_e2: any) {
				saveLastLLMCall(false, false, model, baseUrl, statusCode, '图片转述响应解析异常: ' + _e2, null, apiMessages.length, 0, 0, false)
				done(null)
			}
		},
		fail: (_err: any) => {
			saveLastLLMCall(false, false, model, baseUrl, -1, '图片转述网络失败: ' + _err, null, apiMessages.length, 0, 0, false)
			done(null)
		},
	})
}

function callChatAPI(
	baseUrl: string,
	apiKey: string,
	model: string,
	systemPrompt: string,
	messages: UTSJSONObject[],
	tools: UTSJSONObject[],
	settings: GenerationSettings,
	reasoningEnabled: boolean,
	done: (text: string | null, toolCalls: ToolCallInfo[] | null) => void,
	agentId: string = '',
	conversationId: string = '',
	workspaceRoot: string = ''
): void {
	const apiMessages = buildOpenAIMessages(systemPrompt, messages, true)
	clearLastTokenUsage()

	// 构建请求体：检测 baseUrl 是否已包含 API 版本路径，避免重复
	const url = buildChatCompletionUrl(baseUrl)
	const headers: UTSJSONObject = {
		'Content-Type': 'application/json',
		'Authorization': 'Bearer ' + apiKey,
	}
	const body: UTSJSONObject = {
		model: model,
		messages: apiMessages,
		max_tokens: settings.maxTokens,
		temperature: settings.temperature,
		stream: false,
	}
	if (tools.length > 0) {
		// 转换为 OpenAI tools 格式
		const openaiTools: UTSJSONObject[] = []
		for (let i = 0; i < tools.length; i++) {
			const t = tools[i]
			openaiTools.push({
				type: 'function',
				function: {
					name: t['name'] as string,
					description: t['description'] as string,
					parameters: t['parameters'],
				},
			} as UTSJSONObject)
		}
		body['tools'] = openaiTools
	}

	// 思考开关：启用时根据 provider 类型映射 API 参数
	if (reasoningEnabled) {
		if (baseUrl.indexOf('deepseek') >= 0 || model.indexOf('deepseek') >= 0) {
			body['thinking'] = { type: 'enabled' } as UTSJSONObject
		} else {
			body['reasoning_effort'] = 'medium'
		}
	}
	saveLastLLMRequestSnapshot(baseUrl, url, model, body, apiMessages.length, tools.length, false, '', agentId, conversationId, workspaceRoot)

	if (isLLMDebugLogEnabled() == true) {
		console.log('[LLM] ====== REQUEST ======')
		console.log('[LLM] URL: ' + url)
		console.log('[LLM] Model: ' + model + ' | Messages: ' + apiMessages.length + ' | Tools: ' + tools.length)
		console.log('[LLM] Body: ' + formatBodyForLog(body))
		console.log('[LLM] =======================')
	}

	// 序列化再反序列化，确保 UTSJSONObject 内嵌套数组能被正确识别
	const bodyStr = JSON.stringify(body)
	const finalBody = JSON.parse(bodyStr)

	uni.request({
		url: url,
		method: 'POST',
		header: headers,
		data: finalBody,
		success: (res) => {
			const statusCode = res.statusCode as number
			if (statusCode != 200) {
				let errDetail = ''
				try {
					const errData = res.data as UTSJSONObject | null
					if (errData != null) {
						const errMsg = errData['error'] as UTSJSONObject | null
						if (errMsg != null) {
							const errMessage = errMsg['message'] as string | null
							errDetail = ': ' + (errMessage != null ? errMessage : '')
						}
					}
				} catch (_) {}
				console.log('[LLM] API 请求失败 Status: ' + statusCode + errDetail)
				if (isLLMDebugLogEnabled() == true) {
					console.log('[LLM] Request body: ' + formatBodyForLog(body))
				}
				saveLastLLMCall(false, false, model, baseUrl, statusCode, 'API 请求失败' + errDetail, null, apiMessages.length, tools.length, 0, false)
				done('API 请求失败 (状态码: ' + statusCode + errDetail + ')', null)
				return
			}
			try {
				const responseData = res.data as UTSJSONObject
				if (responseData == null) {
					saveLastLLMCall(false, false, model, baseUrl, statusCode, 'API 响应为空', null, apiMessages.length, tools.length, 0, false)
					done(null, null)
					return
				}
				// 保存 Token 用量
				const usage = responseData['usage'] as UTSJSONObject | null
				if (isLLMDebugLogEnabled() == true) {
					console.log('[LLM] 非流式响应 usage: ' + (usage != null ? JSON.stringify(usage) : 'null'))
				}
				let normalizedUsage: UTSJSONObject | null = null
				if (usage != null) { normalizedUsage = saveLastTokenUsage(usage) }
				const choices = responseData['choices'] as UTSJSONObject[] | null
				if (choices == null || choices.length == 0) {
					saveLastLLMCall(false, false, model, baseUrl, statusCode, 'choices 为空', normalizedUsage, apiMessages.length, tools.length, 0, false)
					done('', null)
					return
				}
				const choice = choices[0]
				const message = choice['message'] as UTSJSONObject | null
				if (message == null) {
					saveLastLLMCall(false, false, model, baseUrl, statusCode, 'message 为空', normalizedUsage, apiMessages.length, tools.length, 0, false)
					done('', null)
					return
				}

			const rawText = message['content'] as string | null
			const text = rawText != null ? stripThinkTags(rawText) : ''
				const rawToolCalls = message['tool_calls'] as UTSJSONObject[] | null
				let tcNames = ''
				if (rawToolCalls != null) {
					for (let i = 0; i < rawToolCalls.length; i++) {
						const funcObj = rawToolCalls[i]['function'] as UTSJSONObject | null
						if (funcObj != null && funcObj['name'] != null) {
							if (tcNames != '') { tcNames = tcNames + ',' }
							tcNames = tcNames + (funcObj['name'] as string)
						}
					}
				}
				const preview = text != '' ? text.substring(0, text.length < 200 ? text.length : 200) : ''
				const tag = tcNames != '' ? ' tools:' + tcNames : ''
				if (isLLMDebugLogEnabled() == true) {
					console.log('[LLM] ====== RESPONSE ======')
					console.log('[LLM] Status: 200' + tag + ' | ' + preview)
					console.log('[LLM] =======================')
				}
				saveLastLLMCall(true, false, model, baseUrl, statusCode, '', normalizedUsage, apiMessages.length, tools.length, text.length, rawToolCalls != null && rawToolCalls.length > 0)

				if (rawToolCalls != null && rawToolCalls.length > 0) {
					const tcList: ToolCallInfo[] = []
					for (let i = 0; i < rawToolCalls.length; i++) {
						const tc = rawToolCalls[i]
						const funcObj = tc['function'] as UTSJSONObject | null
						if (funcObj == null) continue
						const rawId = tc['id'] as string | null
						const rawName = funcObj['name'] as string | null
						const rawArgs = funcObj['arguments'] as string | null
						const safeName = rawName != null ? rawName : ''
						tcList.push({
							id: normalizeToolCallId(rawId, i, safeName),
							name: safeName,
							arguments: rawArgs != null ? rawArgs : '{}',
						} as ToolCallInfo)
					}
					done(text, tcList)
				} else {
					done(text, null)
				}
			} catch (_e: any) {
				saveLastLLMCall(false, false, model, baseUrl, statusCode, 'API 响应解析异常: ' + _e, null, apiMessages.length, tools.length, 0, false)
				done('API 响应解析异常: ' + _e, null)
			}
		},
		fail: (_err: any) => {
			// 检测是否不支持 function calling，自动降级重试
			const errMsg = JSON.stringify(_err)
			if (tools.length > 0 && (
				errMsg.indexOf('Function calling is not enabled') >= 0 ||
				(errMsg.indexOf('tool') >= 0 && errMsg.indexOf('support') >= 0) ||
				(errMsg.indexOf('function') >= 0 && errMsg.indexOf('support') >= 0)
			)) {
				console.log('[LLM] 模型不支持 function calling，去除 tools 后重试')
				uni.showToast({ position: 'bottom', title: '当前模型不支持工具调用，已自动忽略', icon: 'none' })
				callChatAPI(baseUrl, apiKey, model, systemPrompt, messages, [], settings, reasoningEnabled, done, agentId, conversationId, workspaceRoot)
				return
			}
			saveLastLLMCall(false, false, model, baseUrl, -1, '网络请求失败: ' + _err, null, apiMessages.length, tools.length, 0, false)
			done('网络请求失败: ' + _err, null)
		},
	})
}

/**
 * 处理单行 SSE data
 */
function processSSELine(
	line: string,
	fullTextRef: string[],
	sseBufferRef: string[],
	toolCallList: UTSJSONObject[],
	hasToolCallsRef: boolean[],
	onChunk: ((text: string) => void) | null,
	fullThinkingRef: string[] | null = null,
	onThinking: ((text: string) => void) | null = null,
	onToolCallDelta: ((index: number, name: string | null, args: string | null) => void) | null = null
): void {
	const trimmed = line.trim()
	if (trimmed == '' || trimmed.startsWith(':')) return
	if (!trimmed.startsWith('data: ')) return
	const data = trimmed.substring(6)
	if (data == '[DONE]') return
		try {
			const json = JSON.parse(data) as UTSJSONObject
			// 提取 usage（OpenAI 流式最后一个 chunk 中 usage 和 choices 同时存在）
			const usage = json['usage'] as UTSJSONObject | null
			if (usage != null) {
				if (isLLMDebugLogEnabled() == true) {
					console.log('[LLM] 流式 usage: ' + JSON.stringify(usage))
				}
				saveLastTokenUsage(usage)
			}
			const choices = json['choices'] as UTSJSONObject[]
			if (choices == null || choices.length == 0) {
				return
			}
		const choice = choices[0]
		const delta = choice['delta'] as UTSJSONObject
		if (delta == null) return

		// 思考内容（DeepSeek/Grok 等模型的 reasoning_content）
		const reasoning = delta['reasoning_content'] as string | null
		if (reasoning != null && reasoning != '' && fullThinkingRef != null) {
			fullThinkingRef[0] += reasoning
			if (onThinking != null) onThinking(reasoning)
		}

		// 文本内容（剥离 deep thinking 标签）
			const content = delta['content'] as string | null
			if (content != null && content != '') {
				const cleaned = stripThinkTags(content)
				fullTextRef[0] += cleaned
				if (onChunk != null) onChunk(cleaned)
			}

		// 工具调用
		const rawToolCalls = delta['tool_calls'] as UTSJSONObject[]
		if (rawToolCalls != null && rawToolCalls.length > 0) {
			hasToolCallsRef[0] = true
			for (let j = 0; j < rawToolCalls.length; j++) {
				const tc = rawToolCalls[j]
				const rawIndex = tc['index'] as number | null
				const idx = rawIndex != null ? rawIndex : 0
				while (toolCallList.length <= idx) {
					toolCallList.push({ id: '', name: '', arguments: '' } as UTSJSONObject)
				}
				const existing = toolCallList[idx]
				const id = tc['id'] as string | null
				if (id != null && id != '') existing['id'] = id
				const funcObj = tc['function'] as UTSJSONObject
				if (funcObj != null) {
					const name = funcObj['name'] as string | null
					if (name != null && name != '') existing['name'] = name
					const args = funcObj['arguments'] as string | null
					if (args != null && args != '') {
						const oldArgs = existing['arguments'] as string | null
						existing['arguments'] = (oldArgs != null ? oldArgs : '') + args
					}
				}
				// Emit incremental tool call delta for real-time UI
				if (onToolCallDelta != null) {
					const funcObjNew = tc['function'] as UTSJSONObject
					const deltaName = funcObjNew != null ? (funcObjNew['name'] as string | null) : null
					const deltaArgs = funcObjNew != null ? (funcObjNew['arguments'] as string | null) : null
					if (deltaName != null || deltaArgs != null) {
						onToolCallDelta(idx, deltaName, deltaArgs)
					}
				}
			}
		}
	} catch (_) {}
}

/**
 * ArrayBuffer → UTF-8 字符串（手动解码，支持中文）
 */
function decodeArrayBuffer(buffer: ArrayBuffer): string {
	const bytes = new Uint8Array(buffer)
	let result = ''
	let i = 0
	while (i < bytes.length) {
		const b1 = bytes[i]
		if (b1 < 0x80) {
			result += String.fromCharCode(b1)
			i += 1
		} else if (b1 >= 0xC0 && b1 < 0xE0) {
			const b2 = bytes[i + 1]
			result += String.fromCharCode(((b1 & 0x1F) << 6) | (b2 & 0x3F))
			i += 2
		} else if (b1 >= 0xE0 && b1 < 0xF0) {
			const b2 = bytes[i + 1]
			const b3 = bytes[i + 2]
			result += String.fromCharCode(((b1 & 0x0F) << 12) | ((b2 & 0x3F) << 6) | (b3 & 0x3F))
			i += 3
		} else if (b1 >= 0xF0) {
			const b2 = bytes[i + 1]
			const b3 = bytes[i + 2]
			const b4 = bytes[i + 3]
			const code = ((b1 & 0x07) << 18) | ((b2 & 0x3F) << 12) | ((b3 & 0x3F) << 6) | (b4 & 0x3F)
			const sc = code - 0x10000
			result += String.fromCharCode(0xD800 + (sc >> 10))
			result += String.fromCharCode(0xDC00 + (sc & 0x3FF))
			i += 4
		} else {
			i += 1
		}
	}
	return result
}

/**
 * 流式调用 Chat Completions API（SSE）
 * 通过 enableChunked + onChunkReceived 实现真实流式传输
 */
function callChatAPIStream(
	baseUrl: string,
	apiKey: string,
	model: string,
	systemPrompt: string,
	messages: UTSJSONObject[],
	tools: UTSJSONObject[],
	settings: GenerationSettings,
	reasoningEnabled: boolean,
	onChunk: ((text: string) => void) | null,
	done: (text: string | null, toolCalls: ToolCallInfo[] | null, thinking: string | null) => void,
	cacheKey: string = '',
	onThinking: ((text: string) => void) | null = null,
	onToolCallDelta: ((index: number, name: string | null, args: string | null) => void) | null = null,
	conversationId: string = '',
	supportsVision: boolean = true,
	agentId: string = '',
	workspaceRoot: string = ''
): RequestTask {
	const apiMessages = buildOpenAIMessages(systemPrompt, messages, supportsVision)
	clearLastTokenUsage()

	const url = buildChatCompletionUrl(baseUrl)
	const headers: UTSJSONObject = {
		'Content-Type': 'application/json',
		'Authorization': 'Bearer ' + apiKey,
	}
	const body: UTSJSONObject = {
		model: model,
		messages: apiMessages,
		max_tokens: settings.maxTokens,
		temperature: settings.temperature,
		stream: true,
	}
	if (tools.length > 0) {
		const openaiTools: UTSJSONObject[] = []
		for (let i = 0; i < tools.length; i++) {
			const t = tools[i]
			openaiTools.push({
				type: 'function',
				function: {
					name: t['name'] as string,
					description: t['description'] as string,
					parameters: t['parameters'],
				},
			} as UTSJSONObject)
		}
		body['tools'] = openaiTools
	}

	if (cacheKey != '') {
		body['cache_key'] = cacheKey
	}

	// 思考开关：启用时根据 provider 类型映射 API 参数
	if (reasoningEnabled) {
		if (baseUrl.indexOf('deepseek') >= 0 || model.indexOf('deepseek') >= 0) {
			body['thinking'] = { type: 'enabled' } as UTSJSONObject
		} else {
			body['reasoning_effort'] = 'medium'
		}
	}
	saveLastLLMRequestSnapshot(baseUrl, url, model, body, apiMessages.length, tools.length, true, cacheKey, agentId, conversationId, workspaceRoot)

	if (isLLMDebugLogEnabled() == true) {
		console.log('[LLM] ====== STREAM REQUEST ======')
		console.log('[LLM] URL: ' + url)
		console.log('[LLM] Model: ' + model + ' | Messages: ' + apiMessages.length + ' | Tools: ' + tools.length + (cacheKey != '' ? ' | Cache: ' + cacheKey : ''))
		console.log('[LLM] Body: ' + formatBodyForLog(body))
		console.log('[LLM] =============================')
	}

	// 序列化再反序列化，避免 UTSJSONObject 内嵌数组序列化问题
	const bodyStr = JSON.stringify(body)
	const finalBody = JSON.parse(bodyStr)

	// 流式状态（用单元素数组模拟引用传递，兼容 UTS 闭包限制）
	const fullTextRef: string[] = ['']
	const sseBufferRef: string[] = ['']
	const toolCallList: UTSJSONObject[] = []
	const hasToolCallsRef: boolean[] = [false]
	const fullThinkingRef: string[] = ['']
	let streamEnded = false

	const task = uni.request({
		url: url,
		method: 'POST',
		header: headers,
		data: finalBody,
		enableChunked: true,
		success: (res) => {
			streamEnded = true
			const statusCode = res.statusCode as number
		if (statusCode != 200) {
				let errDetail = ''
				try {
					// 优先从 chunked 响应体中提取错误
					if (fullTextRef[0] != '') {
						const errData = JSON.parse(fullTextRef[0]) as UTSJSONObject
						const errObj = errData['error'] as UTSJSONObject
						if (errObj != null) {
							const errMessage = errObj['message'] as string | null
							errDetail = ': ' + (errMessage != null ? errMessage : '')
						}
					}
					// 如果 chunked 没有数据，尝试从 res.data 读取
					if (errDetail == '' && res.data != null) {
						try {
							const resDataStr = JSON.stringify(res.data)
							errDetail = ': ' + (resDataStr.length > 300 ? resDataStr.substring(0, 300) : resDataStr)
						} catch (_d) {}
					}
				} catch (_) {}
				console.log('[LLM] STREAM 请求失败 Status: ' + statusCode + errDetail)
				if (isLLMDebugLogEnabled() == true) {
					console.log('[LLM] Request body: ' + formatBodyForLog(body))
				}
				saveLastLLMCall(false, true, model, baseUrl, statusCode, 'API 请求失败' + errDetail, null, apiMessages.length, tools.length, fullTextRef[0].length, false, conversationId)
				done('API 请求失败 (状态码: ' + statusCode + errDetail + ')', null, null)
				return
			}
			// 处理剩余 buffer
			if (sseBufferRef[0] != '') {
				processSSELine(sseBufferRef[0], fullTextRef, sseBufferRef, toolCallList, hasToolCallsRef, onChunk, fullThinkingRef, onThinking, onToolCallDelta)
				sseBufferRef[0] = ''
			}
			// 最终清理可能跨 chunk 残留的 think 标签
			fullTextRef[0] = stripThinkTags(fullTextRef[0])

			// 组装结果
			if (hasToolCallsRef[0] == true) {
				const tcList: ToolCallInfo[] = []
				let tcNames = ''
				for (let i = 0; i < toolCallList.length; i++) {
					const tc = toolCallList[i]
					const rawId = tc['id'] as string | null
					const rawName = tc['name'] as string | null
					const rawArgs = tc['arguments'] as string | null
					const safeName = rawName != null ? rawName : ''
					if (safeName != '') {
						if (tcNames != '') { tcNames = tcNames + ',' }
						tcNames = tcNames + safeName
					}
					tcList.push({
						id: normalizeToolCallId(rawId, i, safeName),
						name: safeName,
						arguments: rawArgs != null ? rawArgs : '{}',
					} as ToolCallInfo)
				}
				const preview = fullTextRef[0] != '' ? fullTextRef[0].substring(0, fullTextRef[0].length < 200 ? fullTextRef[0].length : 200) : ''
				if (isLLMDebugLogEnabled() == true) {
					console.log('[LLM] ====== STREAM RESPONSE ======')
					console.log('[LLM] Status: 200 tools:' + tcNames + ' | ' + preview)
					console.log('[LLM] ==============================')
				}
				saveLastLLMCall(true, true, model, baseUrl, statusCode, '', readLastTokenUsageForCall(), apiMessages.length, tools.length, fullTextRef[0].length, true, conversationId)
				done(fullTextRef[0], tcList, fullThinkingRef[0])
			} else {
				const preview = fullTextRef[0] != '' ? fullTextRef[0].substring(0, fullTextRef[0].length < 200 ? fullTextRef[0].length : 200) : ''
				if (isLLMDebugLogEnabled() == true) {
					console.log('[LLM] ====== STREAM RESPONSE ======')
					console.log('[LLM] Status: 200 | ' + preview)
					console.log('[LLM] ==============================')
				}
				saveLastLLMCall(true, true, model, baseUrl, statusCode, '', readLastTokenUsageForCall(), apiMessages.length, tools.length, fullTextRef[0].length, false, conversationId)
				done(fullTextRef[0], null, fullThinkingRef[0])
			}
		},
	fail: (_err: any) => {
			// 检测是否不支持 function calling，自动降级重试
			const errMsg = JSON.stringify(_err)
			if (tools.length > 0 && (
				errMsg.indexOf('Function calling is not enabled') >= 0 ||
				(errMsg.indexOf('tool') >= 0 && errMsg.indexOf('support') >= 0) ||
				(errMsg.indexOf('function') >= 0 && errMsg.indexOf('support') >= 0)
			)) {
				console.log('[LLM] 模型不支持 function calling，去除 tools 后重试')
				uni.showToast({ position: 'bottom', title: '当前模型不支持工具调用，已自动忽略', icon: 'none' })
				callChatAPIStream(baseUrl, apiKey, model, systemPrompt, messages, [], settings, reasoningEnabled, onChunk, done, cacheKey, onThinking, null, conversationId, supportsVision, agentId, workspaceRoot)
				return
			}
			saveLastLLMCall(false, true, model, baseUrl, -1, '网络请求失败: ' + _err, null, apiMessages.length, tools.length, fullTextRef[0].length, false, conversationId)
			done('网络请求失败: ' + _err, null, null)
		},
	})

	task.onChunkReceived((res: RequestTaskOnChunkReceivedListenerResult) => {
		if (streamEnded == true) return
		const data = res.data
		if (data == null) return
		const chunk = decodeArrayBuffer(data as ArrayBuffer)
		sseBufferRef[0] += chunk

		// 按行拆分处理
		const parts = sseBufferRef[0].split('\n')
		sseBufferRef[0] = parts[parts.length - 1]
		for (let i = 0; i < parts.length - 1; i++) {
			processSSELine(parts[i], fullTextRef, sseBufferRef, toolCallList, hasToolCallsRef, onChunk, fullThinkingRef, onThinking, onToolCallDelta)
		}
	})

	return task
}

/**
 * 执行 Agent 循环（内部实现）
 */
function runAgentLoop(
	messages: UTSJSONObject[],
	systemPrompt: string,
	providerId: string,
	model: string,
	agentId: string,
	settings: GenerationSettings,
	stream: AgentEventStream,
	conversationId: string,
	allowCoreMemoryWrite: boolean = false,
	enableMemoryManager: boolean = true,
	workspaceRoot: string = ''
): void {
	const config = resolveLLMConfig(providerId, model)
	if (config == null) {
		const hasProvider = getAllProviders().length > 0
		let errMsg: string
		if (hasProvider) {
			errMsg = '未找到模型「' + model + '」，请在智能体设置中重新选择模型'
		} else {
			errMsg = '未配置 LLM，请先在设置中添加 API 提供商'
		}
		saveLastLLMCall(false, settings.streamEnabled, model, '', 0, errMsg, null, messages.length, 0, 0, false)
		stream.error('（' + errMsg + '）')
		return
	}
	const apiKey = config.apiKey
	let baseUrl = config.baseUrl
	const mdl = config.model
	baseUrl = normalizeBaseUrl(baseUrl)

	// 上下文截断和记忆管理递归开关解耦：管理 Agent 不递归整理，但仍需要正常截断。
	const prepared = prepareAgentContext(messages, systemPrompt, agentId, conversationId, allowCoreMemoryWrite, true, workspaceRoot)
	const workingMessages = prepared.workingMessages
	const personId = 'default'
	const tools = createAgentTools(agentId, conversationId, personId, allowCoreMemoryWrite, workspaceRoot)
	const toolDefs = prepared.toolDefs

	if (enableMemoryManager == true && getMemoryEnabled() == true && prepared.droppedScore > 0 && prepared.truncateDropScore > 0 && isMemoryCompactionRunning(agentId, conversationId) == false) {
		const cursor = getMemoryCompactionCursor(agentId, conversationId)
		const compactCandidates = collectUncompactedMemoryCandidates(messages, cursor.lastMessageKey, cursor.lastMessageTimestamp)
		const compactThreshold = prepared.truncateDropScore
		if (compactCandidates.messages.length > 0 && compactCandidates.score + 0.0001 >= compactThreshold && compactCandidates.lastMessageKey != '') {
			const started = startMemoryOrganization(
				compactCandidates.messages,
				providerId,
				model,
				agentId,
				conversationId,
				findLatestMessageTimestamp(messages),
				compactCandidates.lastMessageKey,
				compactCandidates.lastMessageTimestamp,
				compactCandidates.messages.length
			)
			if (started == true) {
				stream.push({ type: 'memory_organize_start', message: '记忆整理已开始' })
			}
		}
	}

	stream.push({ type: 'agent_start' })

	// 缓存键：agentId:conversationId，仅当智能体启用缓存时注入请求体
	const agentForCache = getAgentById(agentId)
	let cacheKey = ''
	if (enableMemoryManager == true && agentForCache != null) {
		const rawCacheEnabled = agentForCache['cacheEnabled'] as boolean | null
		if (rawCacheEnabled != false) {
			cacheKey = agentId
			if (conversationId != '') {
				cacheKey = cacheKey + ':' + conversationId
			}
		}
	}

	// ReAct 循环
	let iteration = 0
	let runLoop: (() => void) | null = null
	let activeTask: RequestTask | null = null
	stream.setAbortHandler((): void => {
		const task = activeTask
		if (task != null) {
			try {
				task.abort()
			} catch (_e: any) {}
		}
		activeTask = null
	})
	const continueLoop = (): void => {
		if (stream.aborted == true) return
		runLoop?.invoke()
	}
	runLoop = (): void => {
		if (stream.aborted == true) return
		if (settings.maxIterations > 0 && iteration >= settings.maxIterations) {
			stream.push({ type: 'error', error: '（已达到最大迭代次数 ' + settings.maxIterations + '，无法完成请求）' })
			stream.end()
			return
		}
		iteration++

		stream.push({ type: 'turn_start' })

	let chunkHandler: ((text: string) => void) | null = null
		let thinkingHandler: ((text: string) => void) | null = null
		let toolCallDeltaHandler: ((index: number, name: string | null, args: string | null) => void) | null = null
		if (settings.streamEnabled == true) {
			chunkHandler = (text: string): void => {
				stream.push({ type: 'text_delta', text: text })
			}
			thinkingHandler = (text: string): void => {
				stream.push({ type: 'thinking_delta', thinkingText: text })
			}
			toolCallDeltaHandler = (index: number, name: string | null, args: string | null): void => {
				const argsStr = args != null ? args : ''
				stream.push({
					type: 'tool_call',
					toolCallId: 'tool_delta_' + index,
					toolName: name != null ? name : '',
					toolArgs: argsStr
				})
			}
		}

		const currentModelVision = getModelVisionSupport(mdl)
		const currentModelReasoning = getModelReasoningEnabled(mdl)
		activeTask = callChatAPIStream(baseUrl, apiKey, mdl, '', workingMessages, toolDefs, settings, currentModelReasoning,
			// onChunk
			chunkHandler,
			// done
			(text: string | null, toolCalls: ToolCallInfo[] | null, thinking: string | null) => {
				activeTask = null
				if (stream.aborted == true) return
				// 思考内容结束
				if (thinking != null && thinking != '') {
					stream.push({ type: 'thinking_end', fullThinking: thinking })
				}
				if (toolCalls == null || toolCalls.length == 0) {
					// 纯文本回复，结束
					stream.push({ type: 'text_end', fullText: text != null ? text : '' })
					stream.push({ type: 'turn_end' })
					stream.end()
					return
				}

				// 有工具调用
				stream.push({ type: 'text_end', fullText: text != null ? text : '' })

				// 构建包含 tool_calls 的 assistant 消息：运行时也统一写 message parts。
				const assistantParts: UTSJSONObject[] = []
				if (thinking != null && thinking != '') {
					assistantParts.push({ type: 'think', think: thinking } as UTSJSONObject)
				}
				if (text != null && text != '') {
					assistantParts.push({ type: 'plain', text: text } as UTSJSONObject)
				}
				const tcArray: UTSJSONObject[] = []
				const tcItems: UTSJSONObject[] = []
				for (let i = 0; i < toolCalls.length; i++) {
					tcArray.push({
						id: toolCalls[i].id,
						type: 'function',
						function: {
							name: toolCalls[i].name,
							arguments: toolCalls[i].arguments,
						},
					} as UTSJSONObject)
					tcItems.push({
						id: toolCalls[i].id,
						name: toolCalls[i].name,
						arguments: toolCalls[i].arguments,
						args: toolCalls[i].arguments,
						status: 'pending',
						result: '',
						isError: false,
					} as UTSJSONObject)
				}
				if (tcItems.length > 0) {
					assistantParts.push({ type: 'tool_call', tool_calls: tcItems } as UTSJSONObject)
				}
				const assistantMsg: UTSJSONObject = {
					role: 'assistant',
					content: text != null ? text : '',
					message: assistantParts,
					tool_calls: tcArray,
				} as UTSJSONObject
				workingMessages.push(assistantMsg)
				stream.push({
					type: 'tool_call',
					fullText: text != null ? text : '',
					toolCalls: tcArray
				})

				// 串行执行工具
				let execIndex = 0
				let executeNext: (() => void) | null = null
				executeNext = (): void => {
					if (stream.aborted == true) return
					if (execIndex >= toolCalls.length) {
						stream.push({ type: 'turn_end' })
						continueLoop()
						return
					}

					const tc = toolCalls[execIndex]
					execIndex++

					stream.push({
						type: 'tool_execution_start',
						toolCallId: tc.id,
						toolName: tc.name,
						toolArgs: tc.arguments
					})

					// 查找工具
					let tool: any | null = null
					for (let i = 0; i < tools.length; i++) {
						if (tools[i].name == tc.name) {
							tool = tools[i]
							break
						}
					}

					if (tool == null) {
						const errMsg = '错误：未知工具 "' + tc.name + '"'
						stream.push({
							type: 'tool_execution_end',
							toolCallId: tc.id,
							toolName: tc.name,
							toolResult: errMsg,
							isError: true
						})
						const toolErrMsg: UTSJSONObject = {
							role: 'toolResult',
							tool_call_id: tc.id,
							toolCallId: tc.id,
							toolName: tc.name,
							content: errMsg,
							isError: true,
						} as UTSJSONObject
						workingMessages.push(toolErrMsg)
						executeNext?.invoke()
						return
					}

					let argsObj: UTSJSONObject
					try {
						argsObj = JSON.parse(tc.arguments) as UTSJSONObject
					} catch (_) {
						argsObj = {} as UTSJSONObject
					}

					// 执行工具
					const p = (tool as AgentTool).execute(argsObj)
					p.then((res: ToolResult): void => {
						if (stream.aborted == true) return
						stream.push({
							type: 'tool_execution_end',
							toolCallId: tc.id,
							toolName: tc.name,
							toolResult: res.content,
							isError: res.isError
						})
						const toolResMsg: UTSJSONObject = {
							role: 'toolResult',
							tool_call_id: tc.id,
							toolCallId: tc.id,
							toolName: tc.name,
							content: res.content,
							isError: res.isError,
						} as UTSJSONObject
						workingMessages.push(toolResMsg)
						executeNext?.invoke()
					})
					p.catch((err) => {
						if (stream.aborted == true) return
						const errMsg = '工具执行异常: ' + err
						stream.push({
							type: 'tool_execution_end',
							toolCallId: tc.id,
							toolName: tc.name,
							toolResult: errMsg,
							isError: true
						})
						const toolErrMsg: UTSJSONObject = {
							role: 'toolResult',
							tool_call_id: tc.id,
							toolCallId: tc.id,
							toolName: tc.name,
							content: errMsg,
							isError: true,
						} as UTSJSONObject
						workingMessages.push(toolErrMsg)
						executeNext?.invoke()
					})
				}

				executeNext?.invoke()
			},
			cacheKey,
			thinkingHandler,
			toolCallDeltaHandler,
			conversationId,
			currentModelVision,
			allowCoreMemoryWrite == true ? '' : agentId,
			workspaceRoot
		)
	}
	continueLoop()
}

registerMemoryManagerLoopStarter((allMessages: UTSJSONObject[], providerId: string, model: string, agentId: string, conversationId: string, conversationLatestTimestamp: number, lastMessageKey: string, lastMessageTimestamp: number, compactedCount: number): boolean => {
	const managerMessages = buildMemoryManagerMessages(allMessages, conversationLatestTimestamp)
	if (managerMessages.length == 0) return false
	markMemoryCompactionRunning(agentId, conversationId)
	const settings = getMemoryOrganizerGenerationSettings()
	settings.streamEnabled = false
	const managerSystemPrompt = buildMemoryManagerSystemPrompt(agentId, conversationId, settings.maxIterations)
	let managerProviderId = providerId
	let managerModel = model
	const managerTaskModel = getMemoryOrganizeTaskModel()
	if (managerTaskModel != null) {
		const rawProvider = managerTaskModel['providerId'] as string | null
		const rawModel = managerTaskModel['model'] as string | null
		if (rawProvider != null && rawProvider != '') {
			managerProviderId = rawProvider
		}
		if (rawModel != null && rawModel != '') {
			managerModel = rawModel
		}
	}
	// 记录本次整理的操作明细
	const toolOps: UTSJSONObject[] = []
	let savedCount = 0
	let forgottenCount = 0
	let summaryText = ''
	let hasError = false
	const managerStream = new AgentEventStream()
	managerStream.on((event: AgentEvent): void => {
		if (event.type == 'tool_call' && event.toolName != null) {
			toolOps.push({
				tool: event.toolName,
				args: event.toolArgs != null ? event.toolArgs : '',
			} as UTSJSONObject)
			if (event.toolName == 'memory_core_save') {
				savedCount++
			} else if (event.toolName == 'memory_core_forget') {
				forgottenCount++
			}
		} else if (event.type == 'text_end' && event.fullText != null) {
			summaryText = event.fullText
		} else if (event.type == 'error') {
			hasError = true
		} else if (event.type == 'agent_end') {
			clearMemoryCompactionRunning(agentId, conversationId)
			if (hasError == true) {
				return
			}
			// Agent 循环结束，写入日志
			const now = Date.now()
			const logId = 'mmlog_' + now + '_' + allMessages.length
			const opsJson = toolOps.length > 0 ? JSON.stringify(toolOps) : ''
			const log: MemoryManagerLog = {
				id: logId,
				agentId: agentId,
				conversationId: conversationId,
				executedAt: now,
				messageCount: compactedCount,
				savedCount: savedCount,
				forgottenCount: forgottenCount,
				summary: summaryText,
				details: opsJson,
			} as MemoryManagerLog
			saveMemoryManagerLog(log)
			if (lastMessageKey != '') {
				saveMemoryCompactionCursor(agentId, conversationId, lastMessageKey, lastMessageTimestamp)
			}
		}
	})
	setTimeout(() => {
		runAgentLoop(managerMessages, managerSystemPrompt, managerProviderId, managerModel, agentId, settings, managerStream, conversationId, true, false, '')
	}, 0)
	return true
})

export function buildAgentContextPreview(
	messages: UTSJSONObject[],
	systemPrompt: string,
	providerId: string,
	model: string,
	agentId: string,
	maxIterations: number = 0,
	conversationId: string = '',
	workspaceRoot: string = ''
): UTSJSONObject {
	const agent = getAgentById(agentId)
	const settings = getEffectiveGenerationSettings(agent)
	if (maxIterations > 0) {
		settings.maxIterations = maxIterations
	}
	const prepared = prepareAgentContext(messages, systemPrompt, agentId, conversationId, false, true, workspaceRoot)
	const config = resolveLLMConfig(providerId, model)
	let requestModel = ''
	let normalizedBaseUrl = ''
	let resolvedProviderId = ''
	if (config != null) {
		requestModel = config.model
		normalizedBaseUrl = normalizeBaseUrl(config.baseUrl)
		resolvedProviderId = config.providerId
	}
	const apiMessages = buildOpenAIMessages('', prepared.workingMessages, true)
	let cacheKey = ''
	if (agent != null) {
		const rawCacheEnabled = agent['cacheEnabled'] as boolean | null
		if (rawCacheEnabled != false) {
			cacheKey = agentId
			if (conversationId != '') {
				cacheKey = cacheKey + ':' + conversationId
			}
		}
	}
	// 读取上次调用的真实诊断数据。
	const diagnosticsState = readLastLLMPreviewState(conversationId)
	const openaiTools: UTSJSONObject[] = []
	for (let i = 0; i < prepared.toolDefs.length; i++) {
		const t = prepared.toolDefs[i]
		openaiTools.push({
			type: 'function',
			function: {
				name: t['name'] as string,
				description: t['description'] as string,
				parameters: t['parameters'],
			},
		} as UTSJSONObject)
	}
	return {
		providerId: resolvedProviderId,
		baseUrl: normalizedBaseUrl,
		model: requestModel,
		cacheKey: cacheKey,
		importantMemory: prepared.importantMemory,
		bufferInjection: prepared.bufferInjection,
		lastUserIndex: prepared.lastUserIndex,
		totalMessages: messages.length,
		droppedCount: prepared.droppedCount,
		droppedScore: prepared.droppedScore,
		droppedPreview: buildDroppedMessagesPreview(prepared.droppedMessages),
		lastTokenUsage: diagnosticsState['lastTokenUsage'],
		lastCallInfo: diagnosticsState['lastCallInfo'],
		conversationTokenUsageStats: diagnosticsState['conversationTokenUsageStats'],
		workingMessages: prepared.workingMessages,
		openaiMessages: apiMessages,
		toolDefs: prepared.toolDefs,
		openaiTools: openaiTools,
		settings: {
			temperature: settings.temperature,
			maxTokens: settings.maxTokens,
			maxIterations: settings.maxIterations,
			streamEnabled: settings.streamEnabled,
		} as UTSJSONObject,
	} as UTSJSONObject
}

export function captionImage(imagePath: string, prompt: string = ''): Promise<string | null> {
	return new Promise<string | null>((resolve) => {
		try {
			if (imagePath == '') {
				resolve(null)
				return
			}
			const taskModel = getVisionTaskModel()
			if (taskModel == null) {
				resolve(null)
				return
			}
			const providerIdRaw = taskModel['providerId'] as string | null
			const modelRaw = taskModel['model'] as string | null
			const providerId = providerIdRaw != null ? providerIdRaw : ''
			const model = modelRaw != null ? modelRaw : ''
			if (providerId == '' || model == '') {
				resolve(null)
				return
			}
			const config = resolveLLMConfig(providerId, model)
			if (config == null) {
				resolve(null)
				return
			}
			let captionPrompt = prompt
			if (captionPrompt == '') {
				captionPrompt = getImageCaptionPrompt()
			}
			const contentJson = buildImageUserMessageContent(captionPrompt, imagePath)
			if (contentJson == null) {
				resolve(null)
				return
			}
			const messages: UTSJSONObject[] = [{
				role: 'user',
				content: contentJson,
			} as UTSJSONObject]
			const baseUrl = normalizeBaseUrl(config.baseUrl)
			const settings = getGlobalGenerationSettings()
			callImageCaptionAPI(baseUrl, config.apiKey, config.model, messages, settings, (text: string | null) => {
				if (text == null) {
					resolve(null)
					return
				}
				const cleaned = text.trim()
				resolve(cleaned != '' ? cleaned : null)
			})
		} catch (_e: any) {
			console.log('[LLM] 图片转述异常: ' + _e)
			resolve(null)
		}
	})
}

/**
 * 发送消息给 LLM 并获取回复文本
 * @param messages 消息列表
 * @param systemPrompt 可选的系统提示词
 * @param providerId 提供商 ID（传空字符串则使用默认配置）
 * @param model 模型名（传空字符串则使用默认配置）
 */
export function chatWithLLM(
	messages: UTSJSONObject[],
	systemPrompt: string = '',
	providerId: string = '',
	model: string = ''
): Promise<string | null> {
	return new Promise<string | null>((resolve) => {
		const config = resolveLLMConfig(providerId, model)
		if (config == null) {
			const hasProvider = getAllProviders().length > 0
			const errMsg = hasProvider ? '未找到模型「' + model + '」，请先设置默认模型' : '未配置 LLM，请先在设置中添加 API 提供商'
			resolve('（' + errMsg + '）')
			return
		}

		const apiKey = config.apiKey
		let baseUrl = config.baseUrl
		const mdl = config.model

		baseUrl = normalizeBaseUrl(baseUrl)
		const settings = getGlobalGenerationSettings()

		// 构建 API 请求并发送
		callChatAPI(baseUrl, apiKey, mdl, systemPrompt, messages, [], settings, false, (text, toolCalls) => {
			resolve(text != null ? text : null)
		})
	})
}

/**
 * ReAct Agent 循环（事件流模式）
 * 在 chatWithLLM 基础上增加工具调用能力：
 *   思考 → 调用工具 → 获取结果 → 继续思考 → 最终回复
 *
 * @param messages 历史消息（UTSJSONObject[] 格式）
 * @param systemPrompt 系统提示词
 * @param providerId 提供商 ID
 * @param model 模型名
 * @param agentId 智能体 ID（用于沙箱文件工具）
 * @param maxIterations 临时最大循环次数；传 0 时使用全局/智能体设置，设置值为 0 表示不限制
 * @returns AgentEventStream 事件流
 */
export function agentChat(
	messages: UTSJSONObject[],
	systemPrompt: string,
	providerId: string,
	model: string,
	agentId: string,
	maxIterations: number = 0,
	conversationId: string = '',
	workspaceRoot: string = ''
): AgentEventStream {
	const stream = new AgentEventStream()
	const agent = getAgentById(agentId)
	const settings = getEffectiveGenerationSettings(agent)
	if (maxIterations > 0) {
		settings.maxIterations = maxIterations
	}

	// 异步执行 Agent 循环
	setTimeout(() => {
		runAgentLoop(messages, systemPrompt, providerId, model, agentId, settings, stream, conversationId, false, true, workspaceRoot)
	}, 0)

	return stream
}
