/**
 * LLM 调用客户端（SDK 模块）
 *
 * 直接使用 uni.request 调用 OpenAI 兼容 API，支持流式 SSE + 非流式。
 * 包含 ReAct Agent 循环（runAgentLoop）和记忆管理器。
 *
 * 依赖（逐步迁入 SDK）：
 * - event.uts ✅ → SDK types.uts
 * - memory.uts ✅ → SDK memory.uts
 * - provider.uts ⏳ → 待迁移
 * - agent-tools.uts ⏳ → 待迁移
 * - agent.uts / skills.uts / generation-settings.uts → 业务层
 *
 * 配置来源优先级（从高到低）：
 * 1. 显式传入的 providerId + model
 * 2. DB 中 chat 任务的默认配置
 * 3. 旧版 storage key（向后兼容）
 */

export type ToolCallInfo = {
	id: string
	name: string
	arguments: string
}

export type PreparedAgentContext = {
	workingMessages: UTSJSONObject[]
	toolDefs: UTSJSONObject[]
	importantMemory: string
	bufferInjection: string
	lastUserIndex: number
	droppedCount: number
	droppedScore: number
	truncateThreshold: number
	truncateDropScore: number
	droppedMessages: UTSJSONObject[]
}

type MemoryCompactionCandidateResult = {
	messages: UTSJSONObject[]
	score: number
	lastMessageKey: string
	lastMessageTimestamp: number
}

type ImageBase64Result = {
	data: string
	mimeType: string
}

import { resolveLLMConfig, normalizeBaseUrl, getMemoryOrganizeTaskModel } from './provider'
import { getAgentById } from '@/utils/agent.uts'
import { getGlobalGenerationSettings, getEffectiveGenerationSettings, getMemoryOrganizerGenerationSettings, GenerationSettings } from '@/utils/generation-settings.uts'
import { createAgentTools, AgentTool, ToolResult } from './tools/agent-tools'
import { AgentEventStream, AgentEvent } from '@/utils/event.uts'
import { buildImportantMemoryInjection, buildBufferInjection, getMemoryEnabled, saveMemoryManagerLog, MemoryManagerLog, getMemoryCompactionCursor, saveMemoryCompactionCursor } from './memory'
import { buildAgentSkillsPrompt } from '@/utils/skills.uts'
import { wrapUserContentForAgent, makeAgentContextBlock, type AgentContextBlock } from '@/utils/message-context.uts'
import { addConversationTokenUsage, getConversationTokenUsageStats } from '@/utils/database.uts'

const LAST_TOKEN_USAGE_KEY = 'last_token_usage'
const LAST_LLM_CALL_KEY = 'last_llm_call'

function pad2(value: number): string {
	if (value < 10) return '0' + value.toString()
	return value.toString()
}

function formatMemoryMessageTime(timestamp: number): string {
	if (timestamp <= 0) return '时间未知'
	const d = new Date(timestamp)
	const year = d.getFullYear().toString()
	const month = pad2(d.getMonth() + 1)
	const day = pad2(d.getDate())
	const hour = pad2(d.getHours())
	const minute = pad2(d.getMinutes())
	const second = pad2(d.getSeconds())
	return year + '-' + month + '-' + day + ' ' + hour + ':' + minute + ':' + second
}

function sanitizeMemoryManagerContent(content: string): string {
	let text = content.trim()
	text = text.replace(/\r/g, '\n')
	while (text.indexOf('\n\n\n') >= 0) {
		text = text.replace(/\n\n\n/g, '\n\n')
	}
	return text
}

function buildDroppedMessagesTranscript(messages: UTSJSONObject[]): string {
	let text = ''
	let budget = 8000
	for (let i = 0; i < messages.length; i++) {
		const role = messages[i]['role'] as string | null
		const rawContent = messages[i]['content'] as string | null
		if (role == null || rawContent == null) continue
		const content = sanitizeMemoryManagerContent(rawContent)
		if (content == '') continue
		const rawTimestamp = messages[i]['timestamp'] as number | null
		const timestamp = rawTimestamp != null ? rawTimestamp : 0
		let line = '[' + role + ' @ ' + formatMemoryMessageTime(timestamp) + '] ' + content
		if (line.length > budget) {
			line = line.substring(0, budget)
		}
		text = text + line + '\n\n'
		budget = budget - line.length
		if (budget <= 0) {
			break
		}
	}
	return text.trim()
}

function findLatestMessageTimestamp(messages: UTSJSONObject[]): number {
	let latest = 0
	for (let i = 0; i < messages.length; i++) {
		const rawTimestamp = messages[i]['timestamp'] as number | null
		const timestamp = rawTimestamp != null ? rawTimestamp : 0
		if (timestamp > latest) {
			latest = timestamp
		}
	}
	return latest
}

function findLatestMessageTime(messages: UTSJSONObject[]): string {
	const latest = findLatestMessageTimestamp(messages)
	return formatMemoryMessageTime(latest)
}

function buildDroppedMessagesPreview(messages: UTSJSONObject[]): UTSJSONObject[] {
	const list: UTSJSONObject[] = []
	const limit = messages.length > 12 ? 12 : messages.length
	for (let i = 0; i < limit; i++) {
		const role = messages[i]['role'] as string | null
		const rawContent = messages[i]['content'] as string | null
		let content = rawContent != null ? rawContent : ''
		if (content.length > 200) {
			content = content.substring(0, 200) + '...'
		}
		list.push({
			role: role != null ? role : '',
			content: content,
		} as UTSJSONObject)
	}
	if (messages.length > limit) {
		list.push({
			role: 'summary',
			content: '还有 ' + (messages.length - limit) + ' 条被截断消息未展开',
		} as UTSJSONObject)
	}
	return list
}

function buildMemoryManagerSystemPrompt(agentId: string, conversationId: string, maxIterations: number): string {
	return '你是记忆管理 Agent，不参与普通聊天，只负责在上下文截断时整理长期记忆。\n' +
		'你拥有完整工具，可以查询历史、查看已有记忆、保存或遗忘重要记忆，也可以用 memory_buffer_write 整理 64 字以内短记忆缓存。\n' +
		'本轮最大迭代次数为 ' + maxIterations + '。必须先核查已有记忆，避免重复写入。\n' +
		'只保存长期有用、未来会复用的信息：用户稳定偏好、明确规则、关键事实、对某人/某 Agent 的重要印象。\n' +
		'不要保存工具调用信息、工具结果、API 密钥、临时流水账、一次性任务细节、用户未明确表达的猜测。\n' +
		'默认面对对象是当前用户：target_type=user，target_id 留空。对话内短期状态优先写入短记忆缓存，不要写入重要记忆。\n' +
		'时间语义规则：每条整理输入都带消息时间戳。对话里提到的“现在/当前/凌晨两点”等必须以该条消息时间为参照，再和最新消息时间比较，不能把旧消息时间误当成当前状态。短记忆缓存不要只记录“当前时间是几点/现在是某时”，应记录任务状态或临时约束。\n' +
		'如果需要保存长期记忆，优先使用 memory_core_save；如果发现明显重复或过期，可以谨慎使用 memory_core_forget。\n' +
		'保存范围建议：稳定偏好用 person_only/preference；面对某人的规则用 person_only/rule；全局规则才用 rule/rule；跨对话事实用 person_only/fact；只对当前对话有用才用 conversation_only。person_only/manual_only 的数量限制按面对对象独立，不同对象不要互相挤占。\n' +
		'当前 agentId=' + agentId + '，conversationId=' + conversationId + '。最终只回复一行整理结果。'
}

function buildMemoryManagerMessages(allMessages: UTSJSONObject[], conversationLatestTimestamp: number): UTSJSONObject[] {
	const transcript = buildDroppedMessagesTranscript(allMessages)
	const fragmentLatestTimestamp = findLatestMessageTimestamp(allMessages)
	const safeConversationLatestTimestamp = conversationLatestTimestamp > 0 ? conversationLatestTimestamp : fragmentLatestTimestamp
	const latestTime = formatMemoryMessageTime(safeConversationLatestTimestamp)
	const fragmentLatestTime = formatMemoryMessageTime(fragmentLatestTimestamp)
	const runTime = formatMemoryMessageTime(Date.now())
	const content = '以下为本轮需要整理的对话片段，请核查并整理重要信息到记忆库。\n\n' +
		'【时间轴】当前对话最新消息时间：' + latestTime + '；本轮片段最新消息时间：' + fragmentLatestTime + '；本次整理运行时间：' + runTime + '。\n' +
		'【时间说明】每条消息头部的 @ 时间是该消息发送时间。消息中出现的“现在/当前/凌晨两点”等相对时间，必须以该条消息时间为参照，再结合当前对话最新消息时间判断是否仍有效，不能直接写成短缓存状态。整理运行时间只用于判断新旧，不得作为记忆内容写入。\n\n' +
		'【待整理片段】\n' + transcript
	const messages: UTSJSONObject[] = []
	messages.push({
		role: 'user',
		content: content,
	} as UTSJSONObject)
	return messages
}

let startMemoryManagerLoop: ((allMessages: UTSJSONObject[], providerId: string, model: string, agentId: string, conversationId: string, conversationLatestTimestamp: number, lastMessageKey: string, lastMessageTimestamp: number, compactedCount: number) => boolean) | null = null
let memoryCompactionRunningKeys: string[] = []

function buildMemoryCompactionRunningKey(agentId: string, conversationId: string): string {
	return agentId + '::' + conversationId
}

function isMemoryCompactionRunning(agentId: string, conversationId: string): boolean {
	const key = buildMemoryCompactionRunningKey(agentId, conversationId)
	for (let i = 0; i < memoryCompactionRunningKeys.length; i++) {
		if (memoryCompactionRunningKeys[i] == key) return true
	}
	return false
}

function markMemoryCompactionRunning(agentId: string, conversationId: string): void {
	if (isMemoryCompactionRunning(agentId, conversationId) == true) return
	memoryCompactionRunningKeys.push(buildMemoryCompactionRunningKey(agentId, conversationId))
}

function clearMemoryCompactionRunning(agentId: string, conversationId: string): void {
	const key = buildMemoryCompactionRunningKey(agentId, conversationId)
	for (let i = memoryCompactionRunningKeys.length - 1; i >= 0; i--) {
		if (memoryCompactionRunningKeys[i] == key) {
			memoryCompactionRunningKeys.splice(i, 1)
		}
	}
}

function isMemoryTextCandidate(msg: UTSJSONObject): boolean {
	const role = msg['role'] as string | null
	if (role != 'user' && role != 'assistant') return false
	if (role == 'assistant' && msg['tool_calls'] != null) return false
	if (role == 'assistant' && (msg['isStreaming'] as boolean | null) == true) return false
	const rawContent = msg['content'] as string | null
	if (rawContent == null || rawContent.trim() == '') return false
	return true
}

function buildMemoryCandidateMessage(msg: UTSJSONObject): UTSJSONObject {
	const role = msg['role'] as string | null
	const rawContent = msg['content'] as string | null
	const rawTimestamp = msg['timestamp'] as number | null
	return {
		role: role != null ? role : '',
		content: rawContent != null ? rawContent : '',
		timestamp: rawTimestamp != null ? rawTimestamp : 0,
	} as UTSJSONObject
}

function buildMemoryMessageKey(msg: UTSJSONObject): string {
	const role = msg['role'] as string | null
	const rawContent = msg['content'] as string | null
	const rawTimestamp = msg['timestamp'] as number | null
	const content = rawContent != null ? rawContent : ''
	const timestamp = rawTimestamp != null ? rawTimestamp : 0
	let sample = content
	if (sample.length > 160) {
		sample = content.substring(0, 100) + '…' + content.substring(content.length - 60)
	}
	sample = sample.replace(/\r/g, '\n')
	sample = sample.replace(/\n/g, '\\n')
	return (role != null ? role : '') + '@' + timestamp + '#' + content.length + '#' + sample
}

function collectMemoryCandidateMessages(messages: UTSJSONObject[]): UTSJSONObject[] {
	const list: UTSJSONObject[] = []
	for (let i = 0; i < messages.length; i++) {
		const msg = messages[i]
		if (isMemoryTextCandidate(msg) == false) continue
		list.push(buildMemoryCandidateMessage(msg))
	}
	return list
}

export function organizeAgentMemory(
	messages: UTSJSONObject[],
	providerId: string,
	model: string,
	agentId: string,
	conversationId: string
): boolean {
	if (getMemoryEnabled() == false) return false
	const candidates = collectMemoryCandidateMessages(messages)
	if (candidates.length == 0) return false
	const starter = startMemoryManagerLoop
	if (starter == null) return false
	return starter.invoke(candidates, providerId, model, agentId, conversationId, findLatestMessageTimestamp(messages), '', 0, 0)
}

// ====== 内部函数 ======

function buildOpenAIToolDefs(tools: AgentTool[]): UTSJSONObject[] {
	const toolDefs: UTSJSONObject[] = []
	for (let i = 0; i < tools.length; i++) {
		toolDefs.push({
			name: tools[i].name,
			description: tools[i].description,
			parameters: tools[i].parameters,
		} as UTSJSONObject)
	}
	return toolDefs
}

function readImageAsBase64(imagePath: string): ImageBase64Result | null {
	try {
		const fm = uni.getFileSystemManager()
		const base64 = fm.readFileSync(imagePath, 'base64')
		if (base64 == null) return null
		let raw = base64 as string
		// 移除可能有的换行符（某些平台的 base64 输出会插入 \n）
		raw = raw.split('\n').join('').split('\r').join('')
		let mimeType = 'image/jpeg'
		const lower = imagePath.toLowerCase()
		if (lower.endsWith('.png')) mimeType = 'image/png'
		else if (lower.endsWith('.gif')) mimeType = 'image/gif'
		else if (lower.endsWith('.webp')) mimeType = 'image/webp'
		else if (lower.endsWith('.bmp')) mimeType = 'image/bmp'
		return { data: raw, mimeType: mimeType }
	} catch (_e: any) {
		return null
	}
}

function buildOpenAIMessages(systemPrompt: string, messages: UTSJSONObject[]): UTSJSONObject[] {
	const apiMessages: UTSJSONObject[] = []
	if (systemPrompt != '') {
		apiMessages.push({
			role: 'system',
			content: systemPrompt,
		} as UTSJSONObject)
	}
	for (let i = 0; i < messages.length; i++) {
		const msg = messages[i]
		const role = msg['role'] as string | null
		if (role == null) continue
		if (role == 'assistant' && (msg['isStreaming'] as boolean | null) == true && msg['tool_calls'] == null) continue

		if (role == 'tool' || role == 'toolResult') {
			const rawToolCallId = msg['tool_call_id']
			const tcId = rawToolCallId != null ? rawToolCallId : msg['toolCallId']
			if (tcId == null || (tcId as string) == '') continue
			const tcContent = msg['content']
			apiMessages.push({
				role: 'tool',
				tool_call_id: tcId as string,
				content: tcContent != null ? (tcContent as string) : '',
			} as UTSJSONObject)
		} else if (role == 'assistant' && msg['tool_calls'] != null) {
			const msgContent = msg['content'] as string | null
			const amsg: UTSJSONObject = {
				role: 'assistant',
				content: msgContent != null ? msgContent : '',
				tool_calls: msg['tool_calls'],
			} as UTSJSONObject
			apiMessages.push(amsg)
		} else {
			const msgContent = msg['content'] as string | null
			const textContent = msgContent != null ? msgContent : ''

			// 图片消息：构建多段 content（文字 + 图片 base64）
			const msgType = msg['msgType'] as string | null
			const imageUrl = msg['imageUrl'] as string | null
			if (role == 'user' && msgType == 'image' && imageUrl != null && imageUrl != '') {
				const imageResult = readImageAsBase64(imageUrl)
				if (imageResult != null) {
					// 用 JSON 字符串构造多段 content，避免 UTSJSONObject 数组序列化问题
					const dataUrl = 'data:' + imageResult.mimeType + ';base64,' + imageResult.data
					const contentJsonStr = '[{"type":"text","text":' + JSON.stringify(textContent) + '},{"type":"image_url","image_url":{"url":' + JSON.stringify(dataUrl) + '}}]'
					try {
						const contentJson = JSON.parse(contentJsonStr)
						apiMessages.push({
							role: 'user',
							content: contentJson,
						} as UTSJSONObject)
					} catch (_e: any) {
						// JSON 构造失败，回退纯文本
						apiMessages.push({
							role: 'user',
							content: textContent,
						} as UTSJSONObject)
					}
				} else {
					apiMessages.push({
						role: 'user',
						content: textContent,
					} as UTSJSONObject)
				}
			} else {
				apiMessages.push({
					role: role,
					content: textContent,
				} as UTSJSONObject)
			}
		}
	}
	return apiMessages
}


function buildUserPrefixContextBlocks(msg: UTSJSONObject): AgentContextBlock[] {
	const blocks: AgentContextBlock[] = []
	const rawBefore = msg['agent_context_before'] as string | null
	if (rawBefore != null) {
		const beforeContent = rawBefore as string
		if (beforeContent.trim() != '') {
			const rawLabel = msg['agent_context_before_label'] as string | null
			let label = '前置上下文'
			if (rawLabel != null) {
				if (rawLabel != '') {
					label = rawLabel
				}
			}
			blocks.push(makeAgentContextBlock('before', label, beforeContent))
		}
	}
	return blocks
}

function buildUserMessageForAgent(msg: UTSJSONObject, suffixBlocks: AgentContextBlock[]): UTSJSONObject {
	const msgContent = msg['content'] as string | null
	const baseContent = msgContent != null ? msgContent : ''
	const prefixBlocks = buildUserPrefixContextBlocks(msg)
	if (prefixBlocks.length == 0 && suffixBlocks.length == 0) {
		return msg
	}
	return {
		role: 'user',
		content: wrapUserContentForAgent(baseContent, prefixBlocks, suffixBlocks),
	} as UTSJSONObject
}

function getContextMessageScore(msg: UTSJSONObject): number {
	const role = msg['role'] as string | null
	if (role == 'user') return 1
	if (role == 'assistant') {
		if (msg['tool_calls'] == null) return 0.3
		return 0.1
	}
	if (role == 'tool' || role == 'toolResult') return 0.1
	return 0
}

function collectUncompactedMemoryCandidates(
	messages: UTSJSONObject[],
	cursorKey: string,
	cursorTimestamp: number
): MemoryCompactionCandidateResult {
	const list: UTSJSONObject[] = []
	let selectedScore = 0
	let lastKey = ''
	let lastTimestamp = 0
	let seenCursor = cursorKey == ''
	for (let i = 0; i < messages.length; i++) {
		const msg = messages[i]
		if (isMemoryTextCandidate(msg) == false) continue
		const msgScore = getContextMessageScore(msg)
		if (msgScore <= 0) continue
		const key = buildMemoryMessageKey(msg)
		const rawTimestamp = msg['timestamp'] as number | null
		const timestamp = rawTimestamp != null ? rawTimestamp : 0
		if (seenCursor == false) {
			if (key == cursorKey) {
				seenCursor = true
				continue
			}
			if (cursorTimestamp > 0 && timestamp > cursorTimestamp) {
				seenCursor = true
			} else {
				continue
			}
		}
		list.push(buildMemoryCandidateMessage(msg))
		selectedScore = selectedScore + msgScore
		lastKey = key
		lastTimestamp = timestamp
	}
	return {
		messages: list,
		score: selectedScore,
		lastMessageKey: lastKey,
		lastMessageTimestamp: lastTimestamp,
	} as MemoryCompactionCandidateResult
}

function normalizeContextSkipCount(messages: UTSJSONObject[], skipCount: number): number {
	if (skipCount <= 0) return 0
	let counted = 0
	let nextIndex = messages.length
	for (let i = 0; i < messages.length; i++) {
		const msgScore = getContextMessageScore(messages[i])
		if (msgScore <= 0) continue
		counted++
		if (counted >= skipCount) {
			nextIndex = i + 1
			break
		}
	}
	while (nextIndex < messages.length) {
		const role = messages[nextIndex]['role'] as string | null
		if (role != 'tool' && role != 'toolResult') break
		if (getContextMessageScore(messages[nextIndex]) > 0) {
			counted++
		}
		nextIndex++
	}
	return counted
}

function prepareAgentContext(
	messages: UTSJSONObject[],
	systemPrompt: string,
	agentId: string,
	conversationId: string,
	allowCoreMemoryWrite: boolean = false,
	enableContextTruncation: boolean = true
): PreparedAgentContext {
	const workingMessages: UTSJSONObject[] = []
	const droppedMessages: UTSJSONObject[] = []
	if (systemPrompt != '') {
		workingMessages.push({
			role: 'system',
			content: systemPrompt,
		} as UTSJSONObject)
	}
	if (allowCoreMemoryWrite == false) {
		const skillsPrompt = buildAgentSkillsPrompt(agentId)
		if (skillsPrompt != '') {
			workingMessages.push({
				role: 'system',
				content: skillsPrompt,
			} as UTSJSONObject)
		}
	}
	const personId = 'default'
	const importantMemory = buildImportantMemoryInjection(agentId, personId, conversationId)
	if (importantMemory != '') {
		workingMessages.push({
			role: 'system',
			content: importantMemory,
		} as UTSJSONObject)
	}
	const bufferInjection = buildBufferInjection(agentId, personId, conversationId)
	let lastUserIndex = -1
	if (bufferInjection != '') {
		for (let i = 0; i < messages.length; i++) {
			const msg = messages[i]
			const role = msg['role'] as string | null
			if (role == 'user') {
				lastUserIndex = i
			}
		}
	}
	let remainingSkip = 0
	let droppedCount = 0
	let droppedScore = 0
	let truncateThreshold = 0
	let truncateDropScore = 0
	if (enableContextTruncation == true) {
		const systemCount = workingMessages.length
		// 截断权重：user 1，普通 assistant 0.3，工具调用/结果 0.1
		const agent = getAgentById(agentId)
		if (agent != null) {
			const rawThreshold = agent['truncateThreshold']
			const rawDropCount = agent['truncateDropCount']
			const threshold = rawThreshold != null ? (rawThreshold as number) : 40
			const dropScore = rawDropCount != null ? (rawDropCount as number) : 20
			truncateThreshold = threshold
			truncateDropScore = dropScore
			if (threshold > 0 && dropScore > 0) {
				let score: number = systemCount
				let totalDialog = 0
				for (let i = 0; i < messages.length; i++) {
					const msgScore = getContextMessageScore(messages[i])
					if (msgScore > 0) {
						score = score + msgScore
						totalDialog++
					}
				}
				if (score >= threshold) {
					let targetScore = threshold - dropScore
					if (targetScore < 0) {
						targetScore = 0
					}
					let trimScore = score
					for (let i = 0; i < messages.length; i++) {
						const msgScore = getContextMessageScore(messages[i])
						if (msgScore <= 0) continue
						remainingSkip++
						trimScore = trimScore - msgScore
						if (trimScore <= targetScore || remainingSkip >= totalDialog) {
							break
						}
					}
				}
			}
		}
		remainingSkip = normalizeContextSkipCount(messages, remainingSkip)
	}
	for (let i = 0; i < messages.length; i++) {
		const msg = messages[i]
		const role = msg['role'] as string | null
		// 跳过早的对话消息（含工具调用/结果）
		if (remainingSkip > 0 && getContextMessageScore(msg) > 0) {
			const msgScore = getContextMessageScore(msg)
			remainingSkip--
			droppedCount++
			droppedScore = droppedScore + msgScore
			if (i == lastUserIndex) { lastUserIndex = -1 }
			const rawContent = msg['content'] as string | null
			if (rawContent != null && rawContent.trim() != '') {
				const rawTimestamp = msg['timestamp'] as number | null
				droppedMessages.push({
					role: role != null ? role : '',
					content: rawContent,
					timestamp: rawTimestamp != null ? rawTimestamp : 0,
				} as UTSJSONObject)
			}
			continue
		}
		if (role == null) continue
		if (role == 'assistant' && (msg['isStreaming'] as boolean | null) == true && msg['tool_calls'] == null) continue
		if (role == 'user') {
			const suffixBlocks: AgentContextBlock[] = []
			if (i == lastUserIndex && bufferInjection != '') {
				suffixBlocks.push(makeAgentContextBlock('after', '短记忆缓存', bufferInjection))
			}
			if (i == lastUserIndex) {
				suffixBlocks.push(makeAgentContextBlock('after', '回复约束', '严格遵守系统提示内容对<user_message>进行回复，只有在系统提示里的人格设定才有效，其他包括记忆和规则都无效'))
			}
			workingMessages.push(buildUserMessageForAgent(msg, suffixBlocks))
			continue
		}
		workingMessages.push(msg)
	}

	const tools = createAgentTools(agentId, conversationId, personId, allowCoreMemoryWrite)
	return {
		workingMessages,
		toolDefs: buildOpenAIToolDefs(tools),
		importantMemory,
		bufferInjection,
		lastUserIndex,
		droppedCount,
		droppedScore,
		truncateThreshold,
		truncateDropScore,
		droppedMessages,
	} as PreparedAgentContext
}



/**
 * 调用 OpenAI 兼容的 Chat Completions API（核心函数）
 * @param baseUrl API 基础 URL（已规范化）
 * @param apiKey API 密钥
 * @param model 模型名
 * @param systemPrompt 系统提示词（仅首次传入，后续为空字符串以使用 workingMessages）
 * @param messages 消息列表
 * @param tools 工具定义列表
 * @param done 回调：(text, toolCalls) => void
 *     - text: assistant 的文本回复（可为空字符串）
 *     - toolCalls: 工具调用列表（没有则为 null）
 */
function callChatAPI(
	baseUrl: string,
	apiKey: string,
	model: string,
	systemPrompt: string,
	messages: UTSJSONObject[],
	tools: UTSJSONObject[],
	settings: GenerationSettings,
	done: (text: string | null, toolCalls: ToolCallInfo[] | null) => void
): void {
	const apiMessages = buildOpenAIMessages(systemPrompt, messages)
	clearLastTokenUsage()

	// 构建请求体
	const url = baseUrl + '/v1/chat/completions'
	const headers: UTSJSONObject = {
		'Content-Type': 'application/json',
		'Authorization': 'Bearer ' + apiKey,
	}
	const body: UTSJSONObject = {
		model: model,
		messages: apiMessages,
		max_tokens: settings.maxTokens,
		temperature: settings.temperature,
		stream: false,
	}
	if (tools.length > 0) {
		// 转换为 OpenAI tools 格式
		const openaiTools: UTSJSONObject[] = []
		for (let i = 0; i < tools.length; i++) {
			const t = tools[i]
			openaiTools.push({
				type: 'function',
				function: {
					name: t['name'] as string,
					description: t['description'] as string,
					parameters: t['parameters'],
				},
			} as UTSJSONObject)
		}
		body['tools'] = openaiTools
	}

	console.log('[LLM] ====== REQUEST ======')
	console.log('[LLM] URL: ' + url)
	console.log('[LLM] Model: ' + model + ' | Messages: ' + apiMessages.length + ' | Tools: ' + tools.length)
	console.log('[LLM] Body: ' + JSON.stringify(body))
	console.log('[LLM] =======================')

	// 序列化再反序列化，确保 UTSJSONObject 内嵌套数组能被正确识别
	const bodyStr = JSON.stringify(body)
	const finalBody = JSON.parse(bodyStr)

	uni.request({
		url: url,
		method: 'POST',
		header: headers,
		data: finalBody,
		success: (res) => {
			const statusCode = res.statusCode as number
			if (statusCode != 200) {
				let errDetail = ''
				try {
					const errData = res.data as UTSJSONObject | null
					if (errData != null) {
						const errMsg = errData['error'] as UTSJSONObject | null
						if (errMsg != null) {
							const errMessage = errMsg['message'] as string | null
							errDetail = ': ' + (errMessage != null ? errMessage : '')
						}
					}
				} catch (_) {}
				console.log('[LLM] ====== RESPONSE ERROR ======')
				console.log('[LLM] Status: ' + statusCode + errDetail)
				console.log('[LLM] =============================')
				saveLastLLMCall(false, false, model, baseUrl, statusCode, 'API 请求失败' + errDetail, null, apiMessages.length, tools.length, 0, false)
				done('API 请求失败 (状态码: ' + statusCode + errDetail + ')', null)
				return
			}
			try {
				const responseData = res.data as UTSJSONObject
				if (responseData == null) {
					saveLastLLMCall(false, false, model, baseUrl, statusCode, 'API 响应为空', null, apiMessages.length, tools.length, 0, false)
					done(null, null)
					return
				}
				// 保存 Token 用量
				const usage = responseData['usage'] as UTSJSONObject | null
				console.log('[LLM] 非流式响应 usage: ' + (usage != null ? JSON.stringify(usage) : 'null'))
				let normalizedUsage: UTSJSONObject | null = null
				if (usage != null) { normalizedUsage = saveLastTokenUsage(usage) }
				const choices = responseData['choices'] as UTSJSONObject[] | null
				if (choices == null || choices.length == 0) {
					saveLastLLMCall(false, false, model, baseUrl, statusCode, 'choices 为空', normalizedUsage, apiMessages.length, tools.length, 0, false)
					done('', null)
					return
				}
				const choice = choices[0]
				const message = choice['message'] as UTSJSONObject | null
				if (message == null) {
					saveLastLLMCall(false, false, model, baseUrl, statusCode, 'message 为空', normalizedUsage, apiMessages.length, tools.length, 0, false)
					done('', null)
					return
				}

				const rawText = message['content'] as string | null
				const text = rawText != null ? rawText : ''
				const rawToolCalls = message['tool_calls'] as UTSJSONObject[] | null
				let tcNames = ''
				if (rawToolCalls != null) {
					for (let i = 0; i < rawToolCalls.length; i++) {
						const funcObj = rawToolCalls[i]['function'] as UTSJSONObject | null
						if (funcObj != null && funcObj['name'] != null) {
							if (tcNames != '') { tcNames = tcNames + ',' }
							tcNames = tcNames + (funcObj['name'] as string)
						}
					}
				}
				const preview = text != '' ? text.substring(0, text.length < 200 ? text.length : 200) : ''
				const tag = tcNames != '' ? ' tools:' + tcNames : ''
				console.log('[LLM] ====== RESPONSE ======')
				console.log('[LLM] Status: 200' + tag + ' | ' + preview)
				console.log('[LLM] =======================')
				saveLastLLMCall(true, false, model, baseUrl, statusCode, '', normalizedUsage, apiMessages.length, tools.length, text.length, rawToolCalls != null && rawToolCalls.length > 0)

				if (rawToolCalls != null && rawToolCalls.length > 0) {
					const tcList: ToolCallInfo[] = []
					for (let i = 0; i < rawToolCalls.length; i++) {
						const tc = rawToolCalls[i]
						const funcObj = tc['function'] as UTSJSONObject | null
						if (funcObj == null) continue
						const rawId = tc['id'] as string | null
						const rawName = funcObj['name'] as string | null
						const rawArgs = funcObj['arguments'] as string | null
						tcList.push({
							id: rawId != null ? rawId : '',
							name: rawName != null ? rawName : '',
							arguments: rawArgs != null ? rawArgs : '{}',
						} as ToolCallInfo)
					}
					done(text, tcList)
				} else {
					done(text, null)
				}
			} catch (_e: any) {
				saveLastLLMCall(false, false, model, baseUrl, statusCode, 'API 响应解析异常: ' + _e, null, apiMessages.length, tools.length, 0, false)
				done('API 响应解析异常: ' + _e, null)
			}
		},
		fail: (_err: any) => {
			saveLastLLMCall(false, false, model, baseUrl, -1, '网络请求失败: ' + _err, null, apiMessages.length, tools.length, 0, false)
			done('网络请求失败: ' + _err, null, null)
		},
	})
}

/**
 * 处理单行 SSE data
 */
function processSSELine(
	line: string,
	fullTextRef: string[],
	sseBufferRef: string[],
	toolCallList: UTSJSONObject[],
	hasToolCallsRef: boolean[],
	onChunk: ((text: string) => void) | null,
	fullThinkingRef: string[] | null = null,
	onThinking: ((text: string) => void) | null = null
): void {
	const trimmed = line.trim()
	if (trimmed == '' || trimmed.startsWith(':')) return
	if (!trimmed.startsWith('data: ')) return
	const data = trimmed.substring(6)
	if (data == '[DONE]') return
		try {
			const json = JSON.parse(data) as UTSJSONObject
			// 提取 usage（OpenAI 流式最后一个 chunk 中 usage 和 choices 同时存在）
			const usage = json['usage'] as UTSJSONObject | null
			if (usage != null) {
				console.log('[LLM] 流式 usage: ' + JSON.stringify(usage))
				saveLastTokenUsage(usage)
			}
			const choices = json['choices'] as UTSJSONObject[]
			if (choices == null || choices.length == 0) {
				return
			}
		const choice = choices[0]
		const delta = choice['delta'] as UTSJSONObject
		if (delta == null) return

		// 思考内容（DeepSeek/Grok 等模型的 reasoning_content）
		const reasoning = delta['reasoning_content'] as string | null
		if (reasoning != null && reasoning != '' && fullThinkingRef != null) {
			fullThinkingRef[0] += reasoning
			if (onThinking != null) onThinking(reasoning)
		}

		// 文本内容
		const content = delta['content'] as string | null
		if (content != null && content != '') {
			fullTextRef[0] += content
			if (onChunk != null) onChunk(content)
		}

		// 工具调用
		const rawToolCalls = delta['tool_calls'] as UTSJSONObject[]
		if (rawToolCalls != null && rawToolCalls.length > 0) {
			hasToolCallsRef[0] = true
			for (let j = 0; j < rawToolCalls.length; j++) {
				const tc = rawToolCalls[j]
				const rawIndex = tc['index'] as number | null
				const idx = rawIndex != null ? rawIndex : 0
				while (toolCallList.length <= idx) {
					toolCallList.push({ id: '', name: '', arguments: '' } as UTSJSONObject)
				}
				const existing = toolCallList[idx]
				const id = tc['id'] as string | null
				if (id != null && id != '') existing['id'] = id
				const funcObj = tc['function'] as UTSJSONObject
				if (funcObj != null) {
					const name = funcObj['name'] as string | null
					if (name != null && name != '') existing['name'] = name
					const args = funcObj['arguments'] as string | null
					if (args != null && args != '') {
						const oldArgs = existing['arguments'] as string | null
						existing['arguments'] = (oldArgs != null ? oldArgs : '') + args
					}
				}
			}
		}
	} catch (_) {}
}

function readPromptCacheHitTokens(usage: UTSJSONObject): number | null {
	let hitTokens = usage['prompt_cache_hit_tokens'] as number | null
	if (hitTokens == null) hitTokens = usage['cache_read_input_tokens'] as number | null
	if (hitTokens == null) hitTokens = usage['prompt_cache_read_tokens'] as number | null
	if (hitTokens == null) hitTokens = usage['cached_tokens'] as number | null
	const promptDetails = usage['prompt_tokens_details'] as UTSJSONObject | null
	if (hitTokens == null && promptDetails != null) {
		hitTokens = promptDetails['cached_tokens'] as number | null
	}
	const inputDetails = usage['input_tokens_details'] as UTSJSONObject | null
	if (hitTokens == null && inputDetails != null) {
		hitTokens = inputDetails['cached_tokens'] as number | null
		if (hitTokens == null) hitTokens = inputDetails['cache_read_tokens'] as number | null
	}
	return hitTokens
}

/** 标准化 Token 用量字段，兼容 OpenAI/Anthropic 命名。 */
function normalizeTokenUsage(usage: UTSJSONObject): UTSJSONObject {
	let promptTokens = usage['prompt_tokens'] as number | null
	let completionTokens = usage['completion_tokens'] as number | null
	let totalTokens = usage['total_tokens'] as number | null
	const promptCacheHitTokens = readPromptCacheHitTokens(usage)
	if (promptTokens == null) promptTokens = usage['input_tokens'] as number | null
	if (completionTokens == null) completionTokens = usage['output_tokens'] as number | null
	if (totalTokens == null && promptTokens != null && completionTokens != null) {
		totalTokens = promptTokens + completionTokens
	}
	const obj: UTSJSONObject = {} as UTSJSONObject
	if (promptTokens != null) obj['prompt_tokens'] = promptTokens
	if (completionTokens != null) obj['completion_tokens'] = completionTokens
	if (totalTokens != null) obj['total_tokens'] = totalTokens
	if (promptCacheHitTokens != null) {
		obj['prompt_cache_hit_tokens'] = promptCacheHitTokens
		obj['prompt_cache_hit_tokens_reported'] = true
	}
	return obj
}

/** 保存最近一次 API 调用的 Token 用量。 */
function saveLastTokenUsage(usage: UTSJSONObject): UTSJSONObject {
	const obj = normalizeTokenUsage(usage)
	const json = JSON.stringify(obj)
	uni.setStorageSync(LAST_TOKEN_USAGE_KEY, json)
	console.log('[LLM] Token 用量已保存: ' + json)
	return obj
}

function clearLastTokenUsage(): void {
	uni.setStorageSync(LAST_TOKEN_USAGE_KEY, '')
}

function readLastTokenUsageForCall(): UTSJSONObject | null {
	try {
		const rawUsage = uni.getStorageSync(LAST_TOKEN_USAGE_KEY) as string | null
		if (rawUsage != null && rawUsage != '') {
			return JSON.parse(rawUsage) as UTSJSONObject
		}
	} catch (_e: any) {}
	return null
}

function saveLastLLMCall(
	success: boolean,
	streamEnabled: boolean,
	model: string,
	baseUrl: string,
	statusCode: number,
	errorMessage: string,
	usage: UTSJSONObject | null,
	messageCount: number,
	toolCount: number,
	textLength: number,
	hasToolCalls: boolean,
	conversationId: string = ''
): void {
	const now = Date.now()
	const obj: UTSJSONObject = {
		success: success,
		stream: streamEnabled,
		model: model,
		baseUrl: baseUrl,
		statusCode: statusCode,
		errorMessage: errorMessage,
		messageCount: messageCount,
		toolCount: toolCount,
		textLength: textLength,
		hasToolCalls: hasToolCalls,
		timestamp: now,
		timeText: formatMemoryMessageTime(now),
	} as UTSJSONObject
	if (usage != null) {
		obj['usage'] = usage
		const cacheReported = usage['prompt_cache_hit_tokens_reported'] as boolean | null
		if (success == true && cacheReported == true && conversationId != '') {
			const promptTokens = usage['prompt_tokens'] as number | null
			const cacheHitTokens = usage['prompt_cache_hit_tokens'] as number | null
			try {
				addConversationTokenUsage(
					conversationId,
					promptTokens != null ? promptTokens : 0,
					cacheHitTokens != null ? cacheHitTokens : 0
				)
			} catch (_e: any) {}
		}
	}
	const json = JSON.stringify(obj)
	uni.setStorageSync(LAST_LLM_CALL_KEY, json)
}

/**
 * ArrayBuffer → UTF-8 字符串（手动解码，支持中文）
 */
function decodeArrayBuffer(buffer: ArrayBuffer): string {
	const bytes = new Uint8Array(buffer)
	let result = ''
	let i = 0
	while (i < bytes.length) {
		const b1 = bytes[i]
		if (b1 < 0x80) {
			result += String.fromCharCode(b1)
			i += 1
		} else if (b1 >= 0xC0 && b1 < 0xE0) {
			const b2 = bytes[i + 1]
			result += String.fromCharCode(((b1 & 0x1F) << 6) | (b2 & 0x3F))
			i += 2
		} else if (b1 >= 0xE0 && b1 < 0xF0) {
			const b2 = bytes[i + 1]
			const b3 = bytes[i + 2]
			result += String.fromCharCode(((b1 & 0x0F) << 12) | ((b2 & 0x3F) << 6) | (b3 & 0x3F))
			i += 3
		} else if (b1 >= 0xF0) {
			const b2 = bytes[i + 1]
			const b3 = bytes[i + 2]
			const b4 = bytes[i + 3]
			const code = ((b1 & 0x07) << 18) | ((b2 & 0x3F) << 12) | ((b3 & 0x3F) << 6) | (b4 & 0x3F)
			const sc = code - 0x10000
			result += String.fromCharCode(0xD800 + (sc >> 10))
			result += String.fromCharCode(0xDC00 + (sc & 0x3FF))
			i += 4
		} else {
			i += 1
		}
	}
	return result
}

/**
 * 流式调用 Chat Completions API（SSE）
 * 通过 enableChunked + onChunkReceived 实现真实流式传输
 */
function callChatAPIStream(
	baseUrl: string,
	apiKey: string,
	model: string,
	systemPrompt: string,
	messages: UTSJSONObject[],
	tools: UTSJSONObject[],
	settings: GenerationSettings,
	onChunk: ((text: string) => void) | null,
	done: (text: string | null, toolCalls: ToolCallInfo[] | null, thinking: string | null) => void,
	cacheKey: string = '',
	onThinking: ((text: string) => void) | null = null,
	conversationId: string = ''
): RequestTask {
	const apiMessages = buildOpenAIMessages(systemPrompt, messages)
	clearLastTokenUsage()

	const url = baseUrl + '/v1/chat/completions'
	const headers: UTSJSONObject = {
		'Content-Type': 'application/json',
		'Authorization': 'Bearer ' + apiKey,
	}
	const body: UTSJSONObject = {
		model: model,
		messages: apiMessages,
		max_tokens: settings.maxTokens,
		temperature: settings.temperature,
		stream: true,
	}
	if (tools.length > 0) {
		const openaiTools: UTSJSONObject[] = []
		for (let i = 0; i < tools.length; i++) {
			const t = tools[i]
			openaiTools.push({
				type: 'function',
				function: {
					name: t['name'] as string,
					description: t['description'] as string,
					parameters: t['parameters'],
				},
			} as UTSJSONObject)
		}
		body['tools'] = openaiTools
	}

	if (cacheKey != '') {
		body['cache_key'] = cacheKey
	}

	console.log('[LLM] ====== STREAM REQUEST ======')
	console.log('[LLM] URL: ' + url)
	console.log('[LLM] Model: ' + model + ' | Messages: ' + apiMessages.length + ' | Tools: ' + tools.length + (cacheKey != '' ? ' | Cache: ' + cacheKey : ''))
	console.log('[LLM] Body: ' + JSON.stringify(body))
	console.log('[LLM] =============================')

	// 序列化再反序列化，避免 UTSJSONObject 内嵌数组序列化问题
	const bodyStr = JSON.stringify(body)
	const finalBody = JSON.parse(bodyStr)

	// 流式状态（用单元素数组模拟引用传递，兼容 UTS 闭包限制）
	const fullTextRef: string[] = ['']
	const sseBufferRef: string[] = ['']
	const toolCallList: UTSJSONObject[] = []
	const hasToolCallsRef: boolean[] = [false]
	const fullThinkingRef: string[] = ['']
	let streamEnded = false

	const task = uni.request({
		url: url,
		method: 'POST',
		header: headers,
		data: finalBody,
		enableChunked: true,
		success: (res) => {
			streamEnded = true
			const statusCode = res.statusCode as number
			if (statusCode != 200) {
				let errDetail = ''
				try {
					if (fullTextRef[0] != '') {
						const errData = JSON.parse(fullTextRef[0]) as UTSJSONObject
						const errObj = errData['error'] as UTSJSONObject
						if (errObj != null) {
							const errMessage = errObj['message'] as string | null
							errDetail = ': ' + (errMessage != null ? errMessage : '')
						}
					}
				} catch (_) {}
				console.log('[LLM] ====== STREAM ERROR ======')
				console.log('[LLM] Status: ' + statusCode + errDetail)
				console.log('[LLM] ===========================')
				saveLastLLMCall(false, true, model, baseUrl, statusCode, 'API 请求失败' + errDetail, null, apiMessages.length, tools.length, fullTextRef[0].length, false, conversationId)
				done('API 请求失败 (状态码: ' + statusCode + errDetail + ')', null, null)
				return
			}
			// 处理剩余 buffer
			if (sseBufferRef[0] != '') {
				processSSELine(sseBufferRef[0], fullTextRef, sseBufferRef, toolCallList, hasToolCallsRef, onChunk, fullThinkingRef, onThinking)
				sseBufferRef[0] = ''
			}
			// 组装结果
			if (hasToolCallsRef[0] == true) {
				const tcList: ToolCallInfo[] = []
				let tcNames = ''
				for (let i = 0; i < toolCallList.length; i++) {
					const tc = toolCallList[i]
					const rawId = tc['id'] as string | null
					const rawName = tc['name'] as string | null
					const rawArgs = tc['arguments'] as string | null
					if (rawName != null) {
						if (tcNames != '') { tcNames = tcNames + ',' }
						tcNames = tcNames + rawName
					}
					tcList.push({
						id: rawId != null ? rawId : '',
						name: rawName != null ? rawName : '',
						arguments: rawArgs != null ? rawArgs : '{}',
					} as ToolCallInfo)
				}
				const preview = fullTextRef[0] != '' ? fullTextRef[0].substring(0, fullTextRef[0].length < 200 ? fullTextRef[0].length : 200) : ''
				console.log('[LLM] ====== STREAM RESPONSE ======')
				console.log('[LLM] Status: 200 tools:' + tcNames + ' | ' + preview)
				console.log('[LLM] ==============================')
				saveLastLLMCall(true, true, model, baseUrl, statusCode, '', readLastTokenUsageForCall(), apiMessages.length, tools.length, fullTextRef[0].length, true, conversationId)
				done(fullTextRef[0], tcList, fullThinkingRef[0])
			} else {
				const preview = fullTextRef[0] != '' ? fullTextRef[0].substring(0, fullTextRef[0].length < 200 ? fullTextRef[0].length : 200) : ''
				console.log('[LLM] ====== STREAM RESPONSE ======')
				console.log('[LLM] Status: 200 | ' + preview)
				console.log('[LLM] ==============================')
				saveLastLLMCall(true, true, model, baseUrl, statusCode, '', readLastTokenUsageForCall(), apiMessages.length, tools.length, fullTextRef[0].length, false, conversationId)
				done(fullTextRef[0], null, fullThinkingRef[0])
			}
		},
	fail: (_err: any) => {
			saveLastLLMCall(false, true, model, baseUrl, -1, '网络请求失败: ' + _err, null, apiMessages.length, tools.length, fullTextRef[0].length, false, conversationId)
			done('网络请求失败: ' + _err, null, null)
		},
	})

	task.onChunkReceived((res: RequestTaskOnChunkReceivedListenerResult) => {
		if (streamEnded == true) return
		const data = res.data
		if (data == null) return
		const chunk = decodeArrayBuffer(data as ArrayBuffer)
		sseBufferRef[0] += chunk

		// 按行拆分处理
		const parts = sseBufferRef[0].split('\n')
		sseBufferRef[0] = parts[parts.length - 1]
		for (let i = 0; i < parts.length - 1; i++) {
			processSSELine(parts[i], fullTextRef, sseBufferRef, toolCallList, hasToolCallsRef, onChunk, fullThinkingRef, onThinking)
		}
	})

	return task
}

/**
 * 执行 Agent 循环（内部实现）
 */
function runAgentLoop(
	messages: UTSJSONObject[],
	systemPrompt: string,
	providerId: string,
	model: string,
	agentId: string,
	settings: GenerationSettings,
	stream: AgentEventStream,
	conversationId: string,
	allowCoreMemoryWrite: boolean = false,
	enableMemoryManager: boolean = true
): void {
	const config = resolveLLMConfig(providerId, model)
	if (config == null) {
		saveLastLLMCall(false, settings.streamEnabled, model, '', 0, '未配置 LLM，请先在设置中添加 API 提供商', null, messages.length, 0, 0, false)
		stream.error('（未配置 LLM，请先在设置中添加 API 提供商）')
		return
	}
	const apiKey = config.apiKey
	let baseUrl = config.baseUrl
	const mdl = config.model
	baseUrl = normalizeBaseUrl(baseUrl)

	// 上下文截断和记忆管理递归开关解耦：管理 Agent 不递归整理，但仍需要正常截断。
	const prepared = prepareAgentContext(messages, systemPrompt, agentId, conversationId, allowCoreMemoryWrite, true)
	const workingMessages = prepared.workingMessages
	const personId = 'default'
	const tools = createAgentTools(agentId, conversationId, personId, allowCoreMemoryWrite)
	const toolDefs = prepared.toolDefs

	if (enableMemoryManager == true && getMemoryEnabled() == true && prepared.droppedScore > 0 && prepared.truncateDropScore > 0 && isMemoryCompactionRunning(agentId, conversationId) == false) {
		const cursor = getMemoryCompactionCursor(agentId, conversationId)
		const compactCandidates = collectUncompactedMemoryCandidates(messages, cursor.lastMessageKey, cursor.lastMessageTimestamp)
		const compactThreshold = prepared.truncateDropScore
		if (compactCandidates.messages.length > 0 && compactCandidates.score + 0.0001 >= compactThreshold && compactCandidates.lastMessageKey != '') {
			const started = startMemoryManagerLoop?.invoke(
				compactCandidates.messages,
				providerId,
				model,
				agentId,
				conversationId,
				findLatestMessageTimestamp(messages),
				compactCandidates.lastMessageKey,
				compactCandidates.lastMessageTimestamp,
				compactCandidates.messages.length
			)
			if (started == true) {
				stream.push({ type: 'memory_organize_start', message: '记忆整理已开始' })
			}
		}
	}

	stream.push({ type: 'agent_start' })

	// 缓存键：agentId:conversationId，仅当智能体启用缓存时注入请求体
	const agentForCache = getAgentById(agentId)
	let cacheKey = ''
	if (enableMemoryManager == true && agentForCache != null && (agentForCache['cacheEnabled'] as boolean | null) == true) {
		cacheKey = agentId
		if (conversationId != '') {
			cacheKey = cacheKey + ':' + conversationId
		}
	}

	// ReAct 循环
	let iteration = 0
	let runLoop: (() => void) | null = null
	let activeTask: RequestTask | null = null
	stream.setAbortHandler((): void => {
		const task = activeTask
		if (task != null) {
			try {
				task.abort()
			} catch (_e: any) {}
		}
		activeTask = null
	})
	const continueLoop = (): void => {
		if (stream.aborted == true) return
		runLoop?.invoke()
	}
	runLoop = (): void => {
		if (stream.aborted == true) return
		if (settings.maxIterations > 0 && iteration >= settings.maxIterations) {
			stream.push({ type: 'error', error: '（已达到最大迭代次数 ' + settings.maxIterations + '，无法完成请求）' })
			stream.end()
			return
		}
		iteration++

		stream.push({ type: 'turn_start' })

	let chunkHandler: ((text: string) => void) | null = null
		let thinkingHandler: ((text: string) => void) | null = null
		if (settings.streamEnabled == true) {
			chunkHandler = (text: string): void => {
				stream.push({ type: 'text_delta', text: text })
			}
			thinkingHandler = (text: string): void => {
				stream.push({ type: 'thinking_delta', thinkingText: text })
			}
		}

		activeTask = callChatAPIStream(baseUrl, apiKey, mdl, '', workingMessages, toolDefs, settings,
			// onChunk
			chunkHandler,
			// done
			(text: string | null, toolCalls: ToolCallInfo[] | null, thinking: string | null) => {
				activeTask = null
				if (stream.aborted == true) return
				// 思考内容结束
				if (thinking != null && thinking != '') {
					stream.push({ type: 'thinking_end', fullThinking: thinking })
				}
				if (toolCalls == null || toolCalls.length == 0) {
					// 纯文本回复，结束
					stream.push({ type: 'text_end', fullText: text != null ? text : '' })
					stream.push({ type: 'turn_end' })
					stream.end()
					return
				}

				// 有工具调用
				stream.push({ type: 'text_end', fullText: text != null ? text : '' })

				// 构建包含 tool_calls 的 assistant 消息
				const assistantMsg: UTSJSONObject = {
					role: 'assistant',
					content: text != null ? text : '',
				} as UTSJSONObject
				const tcArray: UTSJSONObject[] = []
				for (let i = 0; i < toolCalls.length; i++) {
					tcArray.push({
						id: toolCalls[i].id,
						type: 'function',
						function: {
							name: toolCalls[i].name,
							arguments: toolCalls[i].arguments,
						},
					} as UTSJSONObject)
				}
				assistantMsg['tool_calls'] = tcArray
				workingMessages.push(assistantMsg)
				stream.push({
					type: 'tool_call',
					fullText: text != null ? text : '',
					toolCalls: tcArray
				})

				// 串行执行工具
				let execIndex = 0
				let executeNext: (() => void) | null = null
				executeNext = (): void => {
					if (stream.aborted == true) return
					if (execIndex >= toolCalls.length) {
						stream.push({ type: 'turn_end' })
						continueLoop()
						return
					}

					const tc = toolCalls[execIndex]
					execIndex++

					stream.push({
						type: 'tool_execution_start',
						toolCallId: tc.id,
						toolName: tc.name,
						toolArgs: tc.arguments
					})

					// 查找工具
					let tool: any | null = null
					for (let i = 0; i < tools.length; i++) {
						if (tools[i].name == tc.name) {
							tool = tools[i]
							break
						}
					}

					if (tool == null) {
						const errMsg = '错误：未知工具 "' + tc.name + '"'
						stream.push({
							type: 'tool_execution_end',
							toolCallId: tc.id,
							toolName: tc.name,
							toolResult: errMsg,
							isError: true
						})
						const toolErrMsg: UTSJSONObject = {
							role: 'toolResult',
							tool_call_id: tc.id,
							toolCallId: tc.id,
							toolName: tc.name,
							content: errMsg,
							isError: true,
						} as UTSJSONObject
						workingMessages.push(toolErrMsg)
						executeNext?.invoke()
						return
					}

					let argsObj: UTSJSONObject
					try {
						argsObj = JSON.parse(tc.arguments) as UTSJSONObject
					} catch (_) {
						argsObj = {} as UTSJSONObject
					}

					// 执行工具
					const p = (tool as AgentTool).execute(argsObj)
					p.then((res: ToolResult): void => {
						if (stream.aborted == true) return
						stream.push({
							type: 'tool_execution_end',
							toolCallId: tc.id,
							toolName: tc.name,
							toolResult: res.content,
							isError: res.isError
						})
						const toolResMsg: UTSJSONObject = {
							role: 'toolResult',
							tool_call_id: tc.id,
							toolCallId: tc.id,
							toolName: tc.name,
							content: res.content,
							isError: res.isError,
						} as UTSJSONObject
						workingMessages.push(toolResMsg)
						executeNext?.invoke()
					})
					p.catch((err) => {
						if (stream.aborted == true) return
						const errMsg = '工具执行异常: ' + err
						stream.push({
							type: 'tool_execution_end',
							toolCallId: tc.id,
							toolName: tc.name,
							toolResult: errMsg,
							isError: true
						})
						const toolErrMsg: UTSJSONObject = {
							role: 'toolResult',
							tool_call_id: tc.id,
							toolCallId: tc.id,
							toolName: tc.name,
							content: errMsg,
							isError: true,
						} as UTSJSONObject
						workingMessages.push(toolErrMsg)
						executeNext?.invoke()
					})
				}

				executeNext?.invoke()
			},
			cacheKey,
			thinkingHandler,
			conversationId
		)
	}
	continueLoop()
}

startMemoryManagerLoop = (allMessages: UTSJSONObject[], providerId: string, model: string, agentId: string, conversationId: string, conversationLatestTimestamp: number, lastMessageKey: string, lastMessageTimestamp: number, compactedCount: number): boolean => {
	const managerMessages = buildMemoryManagerMessages(allMessages, conversationLatestTimestamp)
	if (managerMessages.length == 0) return false
	markMemoryCompactionRunning(agentId, conversationId)
	const settings = getMemoryOrganizerGenerationSettings()
	settings.streamEnabled = false
	const managerSystemPrompt = buildMemoryManagerSystemPrompt(agentId, conversationId, settings.maxIterations)
	let managerProviderId = providerId
	let managerModel = model
	const managerTaskModel = getMemoryOrganizeTaskModel()
	if (managerTaskModel != null) {
		const rawProvider = managerTaskModel['providerId'] as string | null
		const rawModel = managerTaskModel['model'] as string | null
		if (rawProvider != null && rawProvider != '') {
			managerProviderId = rawProvider
		}
		if (rawModel != null && rawModel != '') {
			managerModel = rawModel
		}
	}
	// 记录本次整理的操作明细
	const toolOps: UTSJSONObject[] = []
	let savedCount = 0
	let forgottenCount = 0
	let summaryText = ''
	let hasError = false
	const managerStream = new AgentEventStream()
	managerStream.on((event: AgentEvent): void => {
		if (event.type == 'tool_call' && event.toolName != null) {
			toolOps.push({
				tool: event.toolName,
				args: event.toolArgs != null ? event.toolArgs : '',
			} as UTSJSONObject)
			if (event.toolName == 'memory_core_save') {
				savedCount++
			} else if (event.toolName == 'memory_core_forget') {
				forgottenCount++
			}
		} else if (event.type == 'text_end' && event.fullText != null) {
			summaryText = event.fullText
		} else if (event.type == 'error') {
			hasError = true
		} else if (event.type == 'agent_end') {
			clearMemoryCompactionRunning(agentId, conversationId)
			if (hasError == true) {
				return
			}
			// Agent 循环结束，写入日志
			const now = Date.now()
			const logId = 'mmlog_' + now + '_' + allMessages.length
			const opsJson = toolOps.length > 0 ? JSON.stringify(toolOps) : ''
			const log: MemoryManagerLog = {
				id: logId,
				agentId: agentId,
				conversationId: conversationId,
				executedAt: now,
				messageCount: compactedCount,
				savedCount: savedCount,
				forgottenCount: forgottenCount,
				summary: summaryText,
				details: opsJson,
			} as MemoryManagerLog
			saveMemoryManagerLog(log)
			if (lastMessageKey != '') {
				saveMemoryCompactionCursor(agentId, conversationId, lastMessageKey, lastMessageTimestamp)
			}
		}
	})
	setTimeout(() => {
		runAgentLoop(managerMessages, managerSystemPrompt, managerProviderId, managerModel, agentId, settings, managerStream, conversationId, true, false)
	}, 0)
	return true
}

export function buildAgentContextPreview(
	messages: UTSJSONObject[],
	systemPrompt: string,
	providerId: string,
	model: string,
	agentId: string,
	maxIterations: number = 0,
	conversationId: string = ''
): UTSJSONObject {
	const agent = getAgentById(agentId)
	const settings = getEffectiveGenerationSettings(agent)
	if (maxIterations > 0) {
		settings.maxIterations = maxIterations
	}
	const prepared = prepareAgentContext(messages, systemPrompt, agentId, conversationId)
	const config = resolveLLMConfig(providerId, model)
	let requestModel = ''
	let normalizedBaseUrl = ''
	let resolvedProviderId = ''
	if (config != null) {
		requestModel = config.model
		normalizedBaseUrl = normalizeBaseUrl(config.baseUrl)
		resolvedProviderId = config.providerId
	}
	const apiMessages = buildOpenAIMessages('', prepared.workingMessages)
	// 读取上次调用的真实 Token 用量
	let lastTokenUsage: UTSJSONObject | null = null
	let lastCallInfo: UTSJSONObject | null = null
	try {
		const rawUsage = uni.getStorageSync(LAST_TOKEN_USAGE_KEY) as string | null
		if (rawUsage != null && rawUsage != '') {
			lastTokenUsage = JSON.parse(rawUsage) as UTSJSONObject
		}
	} catch (_e: any) {}
	try {
		const rawCall = uni.getStorageSync(LAST_LLM_CALL_KEY) as string | null
		if (rawCall != null && rawCall != '') {
			lastCallInfo = JSON.parse(rawCall) as UTSJSONObject
		}
	} catch (_e2: any) {}
	const openaiTools: UTSJSONObject[] = []
	for (let i = 0; i < prepared.toolDefs.length; i++) {
		const t = prepared.toolDefs[i]
		openaiTools.push({
			type: 'function',
			function: {
				name: t['name'] as string,
				description: t['description'] as string,
				parameters: t['parameters'],
			},
		} as UTSJSONObject)
	}
	return {
		providerId: resolvedProviderId,
		baseUrl: normalizedBaseUrl,
		model: requestModel,
		importantMemory: prepared.importantMemory,
		bufferInjection: prepared.bufferInjection,
		lastUserIndex: prepared.lastUserIndex,
		totalMessages: messages.length,
		droppedCount: prepared.droppedCount,
		droppedScore: prepared.droppedScore,
		droppedPreview: buildDroppedMessagesPreview(prepared.droppedMessages),
		lastTokenUsage: lastTokenUsage,
		lastCallInfo: lastCallInfo,
		conversationTokenUsageStats: getConversationTokenUsageStats(conversationId),
		workingMessages: prepared.workingMessages,
		openaiMessages: apiMessages,
		toolDefs: prepared.toolDefs,
		openaiTools: openaiTools,
		settings: {
			temperature: settings.temperature,
			maxTokens: settings.maxTokens,
			maxIterations: settings.maxIterations,
			streamEnabled: settings.streamEnabled,
		} as UTSJSONObject,
	} as UTSJSONObject
}

/**
 * 发送消息给 LLM 并获取回复文本
 * @param messages 消息列表
 * @param systemPrompt 可选的系统提示词
 * @param providerId 提供商 ID（传空字符串则使用默认配置）
 * @param model 模型名（传空字符串则使用默认配置）
 */
export function chatWithLLM(
	messages: UTSJSONObject[],
	systemPrompt: string = '',
	providerId: string = '',
	model: string = ''
): Promise<string | null> {
	return new Promise<string | null>((resolve) => {
		const config = resolveLLMConfig(providerId, model)
		if (config == null) {
			resolve('（未配置 LLM，请先在设置中添加 API 提供商）')
			return
		}

		const apiKey = config.apiKey
		let baseUrl = config.baseUrl
		const mdl = config.model

		baseUrl = normalizeBaseUrl(baseUrl)
		const settings = getGlobalGenerationSettings()

		// 构建 API 请求并发送
		callChatAPI(baseUrl, apiKey, mdl, systemPrompt, messages, [], settings, (text, toolCalls) => {
			resolve(text != null ? text : null)
		})
	})
}

/**
 * ReAct Agent 循环（事件流模式）
 * 在 chatWithLLM 基础上增加工具调用能力：
 *   思考 → 调用工具 → 获取结果 → 继续思考 → 最终回复
 *
 * @param messages 历史消息（UTSJSONObject[] 格式）
 * @param systemPrompt 系统提示词
 * @param providerId 提供商 ID
 * @param model 模型名
 * @param agentId 智能体 ID（用于沙箱文件工具）
 * @param maxIterations 临时最大循环次数；传 0 时使用全局/智能体设置，设置值为 0 表示不限制
 * @returns AgentEventStream 事件流
 */
export function agentChat(
	messages: UTSJSONObject[],
	systemPrompt: string,
	providerId: string,
	model: string,
	agentId: string,
	maxIterations: number = 0,
	conversationId: string = ''
): AgentEventStream {
	const stream = new AgentEventStream()
	const agent = getAgentById(agentId)
	const settings = getEffectiveGenerationSettings(agent)
	if (maxIterations > 0) {
		settings.maxIterations = maxIterations
	}

	// 异步执行 Agent 循环
	setTimeout(() => {
		runAgentLoop(messages, systemPrompt, providerId, model, agentId, settings, stream, conversationId)
	}, 0)

	return stream
}
