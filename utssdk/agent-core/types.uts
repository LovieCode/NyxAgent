/**
 * LLM Provider 类型定义
 * 参考 Pi Agent 的 @earendil-works/pi-ai 和 @earendil-works/pi-agent-core
 * 简化适配移动端 UTS 环境
 */

/** 停止原因 */
export type StopReason = "stop" | "length" | "toolUse" | "error" | "aborted"

/** 文本内容块 */
export type TextContent = {
	type : "text"
	text : string
}

/** 思考内容块 */
export type ThinkingContent = {
	type : "thinking"
	thinking : string
}

/** 工具调用内容块 */
export type ToolCall = {
	type : "toolCall"
	id : string
	name : string
	arguments : UTSJSONObject
}

/** 图片内容块 */
export type ImageContent = {
	type : "image"
	data : string
	mimeType : string
}

/** 内容块联合类型 */
export type ContentBlock = TextContent | ThinkingContent | ToolCall

/** 用户消息 */
export type UserMessage = {
	role : "user"
	content : string
	timestamp : number
}

/** 助手消息 */
export type AssistantMessage = {
	role : "assistant"
	content : ContentBlock[]
	model : string
	stopReason : StopReason
	errorMessage : string | null
	usage : Usage
	timestamp : number
}

/** 工具结果消息 */
export type ToolResultMessage = {
	role : "toolResult"
	toolCallId : string
	toolName : string
	content : string
	isError : boolean
	timestamp : number
}

/** 消息联合类型 */
export type Message = UserMessage | AssistantMessage | ToolResultMessage

/** Token 用量 */
export type Usage = {
	inputTokens : number
	outputTokens : number
}

/** 工具参数定义 */
export type ParamDef = {
	type : string
	description : string | null
	enum : string[] | null
	required : boolean | null
}

/** 工具定义（给 LLM 看） */
export type ToolDefinition = {
	name : string
	description : string
	parameters : UTSJSONObject
}

/** LLM 请求 */
export type ChatRequest = {
	model : string
	system : string
	messages : Message[]
	tools : ToolDefinition[]
	maxTokens : number
	temperature : number | null
}

/** LLM 流式事件 */
export type ChatEvent =
  | { type : "text_delta"; text : string }
  | { type : "thinking_delta"; thinking : string }
  | { type : "tool_call"; id : string; name : string; args : UTSJSONObject }
  | { type : "done"; stopReason : StopReason; usage : Usage }

/** Agent 事件 */
export type AgentEvent =
  | { type : "agent_start" }
  | { type : "agent_end" }
  | { type : "turn_start" }
  | { type : "turn_end" }
  | { type : "message_start"; message : Message }
  | { type : "message_update"; message : AssistantMessage }
  | { type : "message_end"; message : Message }
  | { type : "tool_execution_start"; toolCallId : string; toolName : string; args : UTSJSONObject }
  | { type : "tool_execution_end"; toolCallId : string; toolName : string; result : string; isError : boolean }

/** 工具执行结果 */
export type ToolResult = {
	content : string
	isError : boolean
}

/** Agent 工具接口 */
export interface AgentTool {
	name : string
	description : string
	parameters : UTSJSONObject
	execute(args : UTSJSONObject) : Promise<ToolResult>
}

/** 模型配置 */
export type ModelConfig = {
	id : string
	name : string
	provider : string
	baseUrl : string
	apiKey : string
	maxTokens : number
	contextWindow : number
}
