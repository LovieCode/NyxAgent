/**
 * 会话管理器
 * 使用 JSONL 格式持久化消息历史
 * 每个会话对应一个 .jsonl 文件，每行一条消息
 */

import {
	Message,
	UserMessage,
	AssistantMessage,
	ToolResultMessage,
	ContentBlock,
	TextContent,
	ThinkingContent,
	ToolCall,
	Usage,
	StopReason
} from './types'

/**
 * 会话管理器
 * 负责会话的创建、加载、持久化和删除
 * 使用 JSONL 格式存储，每行一条消息的 JSON 序列化
 */
export class SessionManager {
	/** 会话文件存储的基础目录 */
	private baseDir : string

	/**
	 * 构造函数
	 * 初始化会话存储目录，确保目录存在
	 */
	constructor() {
		// #ifdef APP-ANDROID
		const context = UTSAndroid.getUniAppContext()!
		this.baseDir = context.filesDir.absolutePath + '/sessions'
		// #endif
		// #ifndef APP-ANDROID
		const userDataPath = uni.env.USER_DATA_PATH
		this.baseDir = userDataPath + '/sessions'
		// #endif
		// 确保会话目录存在
		if (this.baseDir.length > 0) {
			const dir = new File(this.baseDir)
			if (!dir.exists()) {
				dir.mkdirs()
			}
		}
	}

	/**
	 * 保存消息到指定会话
	 * 以追加方式写入 JSONL 文件
	 * @param sessionId 会话 ID
	 * @param message 要保存的消息
	 */
	appendMessage(sessionId : string, message : Message) : void {
		const line = this.serializeMessage(message)
		if (line.length == 0) return

		const filePath = this.getSessionFilePath(sessionId)
		try {
			const file = new File(filePath)
			// 确保父目录存在
			const parentDir = file.parentFile
			if (parentDir != null && !parentDir.exists()) {
				parentDir.mkdirs()
			}
			// 追加写入
			file.appendText(line + '\n')
		} catch (_) {
			// 写入失败静默处理
		}
	}

	/**
	 * 加载会话的所有消息
	 * 逐行读取 JSONL 文件并反序列化
	 * @param sessionId 会话 ID
	 * @returns 消息数组
	 */
	loadSession(sessionId : string) : Message[] {
		const filePath = this.getSessionFilePath(sessionId)
		const messages = new Array<Message>()

		try {
			const file = new File(filePath)
			if (!file.exists()) {
				return messages
			}

			const content = file.readText()
			if (content.length == 0) {
				return messages
			}

			const lines = content.split('\n')
			for (let i = 0; i < lines.length; i++) {
				const line = lines[i].trim()
				if (line.length == 0) continue

				const msg = this.deserializeMessage(line)
				if (msg != null) {
					messages.push(msg)
				}
			}
		} catch (_) {
			// 读取失败返回已解析的消息
		}

		return messages
	}

	/**
	 * 列出所有会话
	 * 扫描会话目录下的 .jsonl 文件
	 * @returns 会话 ID 数组
	 */
	listSessions() : string[] {
		const result = new Array<string>()
		try {
			const dir = new File(this.baseDir)
			if (!dir.exists() || !dir.isDirectory()) {
				return result
			}

			const files = dir.listFiles()
			if (files == null) return result

			for (let i = 0; i < files.length; i++) {
				const name = files[i].name
				if (name.endsWith('.jsonl')) {
					// 去掉 .jsonl 后缀得到会话 ID
					result.push(name.substring(0, name.length - 6))
				}
			}
		} catch (_) {
			// 扫描失败返回空列表
		}

		return result
	}

	/**
	 * 删除会话
	 * 删除对应的 JSONL 文件
	 * @param sessionId 会话 ID
	 */
	deleteSession(sessionId : string) : void {
		const filePath = this.getSessionFilePath(sessionId)
		try {
			const file = new File(filePath)
			if (file.exists()) {
				file.delete()
			}
		} catch (_) {
			// 删除失败静默处理
		}
	}

	/**
	 * 创建新会话
	 * 生成基于时间戳的唯一会话 ID，并创建空的会话文件
	 * @returns 新会话的 ID
	 */
	createSession() : string {
		const sessionId = 'session_' + Date.now().toString()
		const filePath = this.getSessionFilePath(sessionId)
		try {
			const file = new File(filePath)
			file.writeText('')
		} catch (_) {
			// 创建失败静默处理
		}
		return sessionId
	}

	/**
	 * 获取会话文件路径
	 * @param sessionId 会话 ID
	 * @returns JSONL 文件的完整路径
	 */
	private getSessionFilePath(sessionId : string) : string {
		return this.baseDir + '/' + sessionId + '.jsonl'
	}

	/**
	 * 将消息序列化为 JSONL 行
	 * @param message 消息对象
	 * @returns JSON 字符串，序列化失败返回空字符串
	 */
	private serializeMessage(message : Message) : string {
		try {
			const role = message['role'] as string
			const obj : UTSJSONObject = {
				'role': role,
				'timestamp': message['timestamp'] as number
			} as UTSJSONObject

			if (role == 'user') {
				const userMsg = message as UserMessage
				obj['content'] = userMsg.content
			} else if (role == 'assistant') {
				const assistantMsg = message as AssistantMessage
				obj['model'] = assistantMsg.model
				obj['stopReason'] = assistantMsg.stopReason
				obj['errorMessage'] = assistantMsg.errorMessage
				obj['usage'] = {
					'inputTokens': assistantMsg.usage.inputTokens,
					'outputTokens': assistantMsg.usage.outputTokens
				} as UTSJSONObject
				// 序列化内容块
				const contentArr = new Array<UTSJSONObject>()
				for (let i = 0; i < assistantMsg.content.length; i++) {
					const block = assistantMsg.content[i]
					contentArr.push(this.serializeContentBlock(block))
				}
				obj['content'] = contentArr
			} else if (role == 'toolResult') {
				const toolMsg = message as ToolResultMessage
				obj['toolCallId'] = toolMsg.toolCallId
				obj['toolName'] = toolMsg.toolName
				obj['content'] = toolMsg.content
				obj['isError'] = toolMsg.isError
			}

			return JSON.stringify(obj)
		} catch (_) {
			return ''
		}
	}

	/**
	 * 序列化内容块
	 * @param block 内容块
	 * @returns JSON 对象
	 */
	private serializeContentBlock(block : ContentBlock) : UTSJSONObject {
		const blockType = block['type'] as string
		if (blockType == 'text') {
			const textBlock = block as TextContent
			return {
				'type': 'text',
				'text': textBlock.text
			} as UTSJSONObject
		} else if (blockType == 'thinking') {
			const thinkBlock = block as ThinkingContent
			return {
				'type': 'thinking',
				'thinking': thinkBlock.thinking
			} as UTSJSONObject
		} else if (blockType == 'toolCall') {
			const toolBlock = block as ToolCall
			return {
				'type': 'toolCall',
				'id': toolBlock.id,
				'name': toolBlock.name,
				'arguments': toolBlock.arguments
			} as UTSJSONObject
		}
		return {} as UTSJSONObject
	}

	/**
	 * 从 JSONL 行反序列化消息
	 * @param line JSON 字符串
	 * @returns 消息对象，解析失败返回 null
	 */
	private deserializeMessage(line : string) : Message | null {
		try {
			const obj = JSON.parse(line) as UTSJSONObject
			const role = obj['role'] as string
			const timestamp = obj['timestamp'] as number | null
			const ts = timestamp != null ? timestamp : Date.now()

			if (role == 'user') {
				return {
					role: 'user',
					content: obj['content'] as string,
					timestamp: ts
				} as UserMessage
			} else if (role == 'assistant') {
				// 解析内容块
				const contentArray = obj['content'] as Array<UTSJSONObject> | null
				const contentBlocks = new Array<ContentBlock>()
				if (contentArray != null) {
					for (let i = 0; i < contentArray.length; i++) {
						const block = this.deserializeContentBlock(contentArray[i])
						if (block != null) {
							contentBlocks.push(block)
						}
					}
				}

				// 解析用量
				const usageObj = obj['usage'] as UTSJSONObject | null
				let inputTokens : number = 0
				let outputTokens : number = 0
				if (usageObj != null) {
					const it = usageObj['inputTokens'] as number | null
					const ot = usageObj['outputTokens'] as number | null
					inputTokens = it != null ? it : 0
					outputTokens = ot != null ? ot : 0
				}

				// 解析模型名称
				const modelValue = obj['model'] as string | null
				const model : string = modelValue != null ? modelValue : ''
				// 解析停止原因
				const stopReasonValue = obj['stopReason'] as string | null
				const stopReasonStr = stopReasonValue != null ? stopReasonValue : 'stop'
				const stopReason : StopReason = this.validateStopReason(stopReasonStr)

				return {
					role: 'assistant',
					content: contentBlocks,
					model: model,
					stopReason: stopReason,
					errorMessage: obj['errorMessage'] as string | null,
					usage: { inputTokens: inputTokens, outputTokens: outputTokens } as Usage,
					timestamp: ts
				} as AssistantMessage
			} else if (role == 'toolResult') {
				const isErrorValue = obj['isError'] as boolean | null
				const isError : boolean = isErrorValue != null ? isErrorValue : false
				return {
					role: 'toolResult',
					toolCallId: obj['toolCallId'] as string,
					toolName: obj['toolName'] as string,
					content: obj['content'] as string,
					isError: isError,
					timestamp: ts
				} as ToolResultMessage
			}

			return null
		} catch (_) {
			return null
		}
	}

	/**
	 * 反序列化内容块
	 * @param obj JSON 对象
	 * @returns 内容块，解析失败返回 null
	 */
	private deserializeContentBlock(obj : UTSJSONObject) : ContentBlock | null {
		const blockType = obj['type'] as string

		if (blockType == 'text') {
			return {
				type: 'text',
				text: obj['text'] as string
			} as TextContent
		} else if (blockType == 'thinking') {
			return {
				type: 'thinking',
				thinking: obj['thinking'] as string
			} as ThinkingContent
		} else if (blockType == 'toolCall') {
			return {
				type: 'toolCall',
				id: obj['id'] as string,
				name: obj['name'] as string,
				arguments: obj['arguments'] as UTSJSONObject
			} as ToolCall
		}

		return null
	}

	/**
	 * 校验停止原因是否为合法的 StopReason 值
	 * @param value 待校验的字符串
	 * @returns 合法的 StopReason 值，不合法则返回 'error'
	 */
	private validateStopReason(value : string) : StopReason {
		if (value == 'stop' || value == 'length' || value == 'toolUse' || value == 'error' || value == 'aborted') {
			return value as StopReason
		}
		return 'error'
	}
}
