}

/** 解压导入 ZIP 中的用户工作区文件。 */
export function importUserWorkspaceFiles(zipPath: string): number {
	// #ifdef APP-ANDROID
	let stageRoot: File | null = null
	try {
		const importRoot = getImportRoot()
		const context = UTSAndroid.getAppContext()
