		return count
	} catch (_e: any) {
		if (stageRoot != null) {
			deleteRecursive(stageRoot)
		}
		return -1
	}
	// #endif
	return 0
}

/** 解压备份 ZIP 中的头像、图片等资源，返回 ref -> 本机路径。 */
export function importBackupAssets(zipPath: string, assets: UTSJSONObject[]): UTSJSONObject {
	const mapping: UTSJSONObject = {}
	// #ifdef APP-ANDROID
	try {
		const root = getImportedAssetsRoot()
		if (root == null) {
			return mapping
		}
		const zipFile = prepareImportZipFile(zipPath)
		if (zipFile == null) {
			return mapping
		}
		const zip = new ZipFile(zipFile)
		for (let i = 0; i < assets.length; i++) {
			const asset = assets[i]
			const ref = asset['ref'] as string | null
			const zipPathValue = asset['zipPath'] as string | null
			if (ref != null && ref != '' && zipPathValue != null && zipPathValue != '' && isSafeExtractPath(zipPathValue)) {
				const entry = zip.getEntry(zipPathValue)
				if (entry != null) {
					const target = new File(root.absolutePath + '/' + zipPathValue)
					const saved = extractAssetEntry(zip, entry, target)
					if (saved != '') {
						mapping[ref] = saved
					}
				}
			}
		}
		zip.close()
		return mapping
	} catch (_e: any) {
		return mapping
	}
	// #endif
	return mapping
}
