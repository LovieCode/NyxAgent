			zip.close()
			return 0
		}
		const userRoot = new File((context.filesDir as File).absolutePath + '/user')
		const stage = new File(importRoot.absolutePath + '/user-files-stage')
		stageRoot = stage
		const backupRoot = new File(importRoot.absolutePath + '/user-files-backup')
		if (resetDirectory(stage) == false) {
			zip.close()
			return -1
		}
		let count = 0
		const entries = zip.entries()
		while (entries.hasMoreElements()) {
			const entry = entries.nextElement() as ZipEntry
			count = count + extractUserWorkspaceEntry(zip, entry, stage)
		}
		zip.close()
		if (replaceDirectoryFromStage(stage, userRoot, backupRoot) == false) {
			deleteRecursive(stage)
			return -1
