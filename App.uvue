		/* 表面色 */
		--rice-background: #F7F7F9;
		--rice-background-2: #FFFFFF;
		--rice-border-color: #E5E7EB;

		/* rice-ui 组件覆盖 */
		--rice-cell-background: #FFFFFF;
		--rice-button-default-background: #FFFFFF;
		--rice-button-default-border: #E5E7EB;
		--rice-button-primary-background: #FB8FAB;
		--rice-button-info-background: #F3F4F6;
		--rice-navbar-background: #FFFFFF;
		--rice-tabs-background: #FFFFFF;
		--rice-search-background: #F3F4F6;

		/* ===== App 语义令牌（对话页精致化，不污染 rice-ui 组件） ===== */
		/* 卡片 / 内容层 */
		--app-card-bg: #FFFFFF;
		--app-divider: #F0F0F2;
		--app-tint-pink: #FDE8EF;

		/* 气泡 */
		--app-bubble-ai-bg: #FFFFFF;
		--app-bubble-ai-border: #F0F0F2;
		--app-bubble-user-from: #FB8FAB;
		--app-bubble-user-to: #E8729A;

		/* 柔和阴影：ucss 阴影兼容性弱，用浅边框模拟层次 */
		--app-hairline: #F0F0F2;
		--app-soft-border: rgba(251, 143, 171, 0.16);
	}

	/* ===== 全局字体图标 ===== */
	@font-face {
		font-family: 'oui-icons';
		src: url('./uni_modules/oui-icon-unix/components/oui-icon-unix/iconfont.ttf') format('truetype');
	}

	/* ===== 全局公共样式 ===== */
	/* CSS_DIFF_WEB: uni-app x App 端与 Web CSS 存在差异，固定视觉尺寸统一用 px，避免宽屏设备按响应式单位放大。未来重做设计系统时可搜索此标记清理。 */
	.uni-row { flex-direction: row; }
	.uni-column { flex-direction: column; }

	/* 页面外壳 - 深灰底色让 TabBar 浮动效果更明显 */
	.page-shell {
		flex: 1;
		flex-direction: column;
		background-color: var(--rice-background);
	}

	/* 页面内容容器 - 白色内容区域 */
	.page-content {
		flex: 1;
		background-color: #F5F5F7;
		border-radius: 20px;
		margin-left: 0px;
		margin-right: 0px;
		margin-top: 0px;
		overflow: hidden;
	}

	/* 通用卡片 */
	.card {
		background-color: #FFFFFF;
