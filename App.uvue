<script lang="uts">
	import { initDatabase, initDefaultProviders } from '@/utils/database.uts'
	import { isDataImportRecoveryBlocked, recoverInterruptedDataImport } from '@/utils/data-import.uts'
	import { tryResumeGroupSpeakIntentWakes } from '@/utils/group-chat-turn-runtime.uts'
	import { APP_ERROR_CATEGORY_RUNTIME, reportAppErrorFromCause } from '@/utils/app-error.uts'
	let appDataReady = false
	let lastWakeRecoveryNoticeAt = 0

	function notifyWakeRecoveryFailure(): void {
		const now = Date.now()
		if (now - lastWakeRecoveryNoticeAt < 5000) { return }
		lastWakeRecoveryNoticeAt = now
		uni.showToast({ title: '后台任务恢复失败，请稍后重试', icon: 'none', duration: 3000 })
	}

	function reportUnhandledAppError(operation: string, cause: any | null): void {
		reportAppErrorFromCause(
			'APP_UNHANDLED_RUNTIME_ERROR',
			APP_ERROR_CATEGORY_RUNTIME,
			operation,
			'应用发生异常，请重试；详情已记录到运行诊断',
			cause,
			true,
		)
		uni.showToast({ title: '应用发生异常，详情已记录', icon: 'none', duration: 3000 })
	}

	// #ifdef APP-ANDROID || APP-HARMONY
	let firstBackTime = 0
	// #endif
	export default {
		onLaunch: function () {
			console.log('App Launch')
			appDataReady = false
			try {
				// 初始化失败时停止后续数据库写入，避免在残缺 schema 上继续运行。
				initDatabase()
				if (recoverInterruptedDataImport() == false) {
					throw new Error('上次数据导入恢复失败')
				}
				initDefaultProviders()
				appDataReady = true
				if (tryResumeGroupSpeakIntentWakes() == false) { notifyWakeRecoveryFailure() }
			} catch (e: any) {
				reportAppErrorFromCause(
					'APP_INITIALIZATION_FAILED',
					APP_ERROR_CATEGORY_RUNTIME,
					'app_launch_initialize',
					'本地数据初始化或恢复失败',
					e,
					false,
				)
				// 恢复失败后不能继续写混合状态；用不可取消弹窗阻断首屏操作。
				setTimeout(() => {
					uni.showModal({
						title: '本地数据需要恢复',
						content: '上次导入或数据库初始化没有完整结束。应用将退出，请重新启动并等待自动恢复。',
						showCancel: false,
						success: (_result) => {
							// #ifdef APP-ANDROID || APP-HARMONY
							uni.exit()
							// #endif
						},
						fail: (_error: any) => {
							// #ifdef APP-ANDROID || APP-HARMONY
							uni.exit()
							// #endif
						},
					})
				}, 500)
			}
		},
		onShow: function () {
			console.log('App Show')
			if (appDataReady == false || isDataImportRecoveryBlocked() == true) { return }
			if (tryResumeGroupSpeakIntentWakes() == false) { notifyWakeRecoveryFailure() }
		},
		onError: function (error: any) {
			reportUnhandledAppError('App onError', error)
		},
		onHide: function () {
			console.log('App Hide')
		},
		// #ifdef APP-ANDROID || APP-HARMONY
		onLastPageBackPress: function () {
			console.log('App LastPageBackPress')
			if (firstBackTime == 0) {
				uni.showToast({
					title: '再按一次退出应用',
					position: 'bottom',
				})
				firstBackTime = Date.now()
				setTimeout(() => {
					firstBackTime = 0
				}, 2000)
			} else if (Date.now() - firstBackTime < 2000) {
				firstBackTime = Date.now()
				uni.exit()
			}
		},
		// #endif
		onExit: function () {
			console.log('App Exit')
		},
	}
</script>

<style>
	/* ===== RiceUI 基础样式 ===== */
	@import "@/uni_modules/rice-ui/libs/style/index.css";

	/* ===== Pink/White 主题色覆盖 ===== */
	.rice-theme-light {
		/* 主色系 - 清新淡粉（强调用） */
		--rice-primary-color: #ff99af;
		--rice-primary-color-1: #FDE8EF;
		--rice-primary-color-7: #E8729A;

		/* 文字色 */
		--rice-text-color: #111827;
		--rice-text-color-2: #6B7280;
		--rice-text-color-3: #9CA3AF;
		--rice-text-color-white: #FFFFFF;

		/* 表面色 */
		--rice-background: #F7F7F9;
		--rice-background-2: #FFFFFF;
		--rice-border-color: #E5E7EB;

		/* rice-ui 组件覆盖 */
		--rice-cell-background: #FFFFFF;
		--rice-button-default-background: #FFFFFF;
		--rice-button-default-border: #E5E7EB;
		--rice-button-primary-background: #FB8FAB;
		--rice-button-info-background: #F3F4F6;
		--rice-navbar-background: #FFFFFF;
		--rice-tabs-background: #FFFFFF;
		--rice-search-background: #F3F4F6;

		/* ===== App 语义令牌（对话页精致化，不污染 rice-ui 组件） ===== */
		/* 卡片 / 内容层 */
		--app-card-bg: #FFFFFF;
		--app-divider: #F0F0F2;
		--app-tint-pink: #FDE8EF;

		/* 气泡 */
		--app-bubble-ai-bg: #FFFFFF;
		--app-bubble-ai-border: #F0F0F2;
		--app-bubble-user-from: #FB8FAB;
		--app-bubble-user-to: #E8729A;

		/* 柔和阴影：ucss 阴影兼容性弱，用浅边框模拟层次 */
		--app-hairline: #F0F0F2;
		--app-soft-border: rgba(251, 143, 171, 0.16);
	}

	/* ===== 全局字体图标 ===== */
	@font-face {
		font-family: 'oui-icons';
		src: url('./uni_modules/oui-icon-unix/components/oui-icon-unix/iconfont.ttf') format('truetype');
	}

	/* ===== 全局公共样式 ===== */
	/* CSS_DIFF_WEB: uni-app x App 端与 Web CSS 存在差异，固定视觉尺寸统一用 px，避免宽屏设备按响应式单位放大。未来重做设计系统时可搜索此标记清理。 */
	.uni-row { flex-direction: row; }
	.uni-column { flex-direction: column; }

	/* 页面外壳 - 深灰底色让 TabBar 浮动效果更明显 */
	.page-shell {
		flex: 1;
		flex-direction: column;
		background-color: var(--rice-background);
	}

	/* 页面内容容器 - 白色内容区域 */
	.page-content {
		flex: 1;
		background-color: #F5F5F7;
		border-radius: 20px;
		margin-left: 0px;
		margin-right: 0px;
		margin-top: 0px;
		overflow: hidden;
	}

	/* 通用卡片 */
	.card {
		background-color: #FFFFFF;
		border-radius: 16px;
		padding: 16px;
		margin-bottom: 12px;
		border-width: 1px;
		border-color: #F0F0F2;
		border-style: solid;
	}

	/* 通用标题 */
	.page-title {
		font-size: 24px;
		font-weight: bold;
		color: #111827;
	}

	/* 通用次要文字 */
	.text-muted {
		font-size: 13px;
		color: #9CA3AF;
	}
</style>
