		justify-content: center;
		align-items: center;
	}

	/* 空状态 */
	.empty-state {
		flex: 1;
		justify-content: center;
		align-items: center;
		padding-top: 120px;
	}

	.empty-text {
		font-size: 24px;
		color: var(--rice-text-color);
		font-weight: bold;
		margin-bottom: 8px;
	}

