<template>
	<view class="page-shell rice-theme-light" ref="shellRef">
		<NavBar :title="headerTitle" showBack @back="goBack">
			<template #right>
				<view style="flex-direction:row;align-items:center;">
					<view class="nav-icon-btn" @click="goAgentSettings">
						<oui-icon-unix name="setting" size="18px" color="#FFFFFF" />
					</view>
					<view class="nav-icon-btn" @click="goHistory" style="margin-left:4px;">
						<oui-icon-unix name="time-circle" size="20px" color="#FFFFFF" />
					</view>
				</view>
			</template>
		</NavBar>

		<!-- 消息列表 -->
		<scroll-view class="message-list" :scroll-y="true" :scroll-top="scrollTop">
			<view v-for="(msg, index) in messages" :key="index">
				<ToolExecution
					v-if="msg.role == 'toolResult'"
					:toolName="msg.toolName != null ? msg.toolName : ''"
					:status="msg.toolStatus != null ? msg.toolStatus : 'completed'"
					:result="msg.content"
				/>
				<ChatBubble
					v-else
					:role="msg.role"
					:content="msg.content"
					:msgType="msg.msgType != null ? msg.msgType : 'text'"
					:imageUrl="msg.imageUrl != null ? msg.imageUrl : ''"
					:agentAvatar="currentAgentAvatar"
					:toolName="msg.toolName != null ? msg.toolName : ''"
					:isError="msg.isError == true"
					:isStreaming="msg.isStreaming == true"
				/>
			</view>
			<view v-if="messages.length == 0" class="empty-state">
				<text class="empty-text">开始对话</text>
				<text class="empty-hint">输入文字或长按语音按钮</text>
			</view>
		</scroll-view>

		<!-- 底部区域（输入栏 + 工具栏） -->
		<view class="chat-bottom">
			<!-- 输入栏 -->
			<view class="input-bar">
				<view class="toolbar-toggle" @click="showToolPanel = !showToolPanel">
					<oui-icon-unix name="plus" size="18px" color="#374151" />
				</view>
				<view class="input-wrap">
					<textarea
						class="text-input"
						v-model="inputText"
						:style="{ height: inputHeight + 'px' }"
						placeholder="输入消息..."
						placeholder-style="color:var(--rice-text-color-3)"
						@linechange="onInputLineChange"
						:disabled="isGenerating == true"
					/>
				</view>
				<VoiceInput :isListening="isListening ? true : false" @startListening="startVoice" @stopListening="stopVoice" />
				<rice-button type="primary" text="发送" size="small" shape="round" @click="sendMessage" style="margin-left:6px" />
			</view>
			<!-- 工具栏面板（输入栏下方展开） -->
			<view v-if="showToolPanel" class="toolbar-panel">
				<view class="toolbar-grid">
					<view class="toolbar-grid-item" @click="pickImage; showToolPanel = false">
						<view class="toolbar-grid-icon"><oui-icon-unix name="image" size="22px" color="var(--rice-primary-color)" /></view>
						<text class="toolbar-grid-label">图片</text>
					</view>
					<view class="toolbar-grid-item" @click="takePhoto; showToolPanel = false">
						<view class="toolbar-grid-icon"><oui-icon-unix name="camera" size="22px" color="var(--rice-primary-color)" /></view>
						<text class="toolbar-grid-label">拍照</text>
					</view>
					<view class="toolbar-grid-item" @click="pickFile; showToolPanel = false">
						<view class="toolbar-grid-icon"><oui-icon-unix name="file" size="22px" color="var(--rice-primary-color)" /></view>
						<text class="toolbar-grid-label">文件</text>
					</view>
					<view class="toolbar-grid-item" @click="pickLocation; showToolPanel = false">
						<view class="toolbar-grid-icon"><oui-icon-unix name="map-pin" size="22px" color="var(--rice-primary-color)" /></view>
						<text class="toolbar-grid-label">位置</text>
					</view>
				</view>
			</view>
		</view>
	</view>
</template>

<script lang="uts">
	/**
	 * 对话页面 - AI Agent 主聊天界面
	 * 扁平化粉白主题
	 */
	import { saveConversation, getMessages } from '@/utils/database.uts'
	import { chatWithLLM } from '@/utils/llm.uts'
	import { getAgentById } from '@/utils/agent.uts'

	export default {
		data() {
			return {
				/** 消息列表 */
				messages: [] as UTSJSONObject[],
				/** 当前输入文本 */
				inputText: '',
				/** 是否正在语音输入 */
				isListening: false as boolean,
				/** AI 是否正在生成回复 */
				isGenerating: false as boolean,
				/** 当前智能体 ID */
				currentAgentId: '' as string,
				/** 当前智能体名称 */
				currentAgentName: '' as string,
				/** 当前智能体头像 */
				currentAgentAvatar: '' as string,
				/** 滚动位置 */
				scrollTop: 0,
				/** 当前对话唯一 ID */
				conversationId: '' as string,
				/** 是否已存过当前对话（防止重复存） */
				savedFlag: false as boolean,
				/** 输入框 JS 驱动高度 */
				inputHeight: 40,
				/** 是否显示工具栏面板 */
				showToolPanel: false as boolean,
			}
		},
		computed: {
			/** 头部标题 */
			headerTitle(): string {
				return this.currentAgentName != '' ? this.currentAgentName : 'AI 助手'
			}
		},
		onLoad() {
			// 加载当前智能体信息
			this.loadCurrentAgent()
			// 检查是否因历史记录跳转过来的（加载已有对话）
			this.loadExistingConversation()
			if (this.conversationId == '') {
				this.conversationId = '' + Date.now()
			}
		},

		onShow() {
			// 每次显示页面时刷新智能体信息
			this.loadCurrentAgent()
		},

		onHide() {
			// 离开页面时保存当前对话
			this.saveCurrentConversation()
		},

		methods: {
			/** 加载当前智能体信息 */
			loadCurrentAgent() {
				const id = uni.getStorageSync('active_agent_id') as string
				if (id == null || id == '') { return }
				this.currentAgentId = id
				const agent = getAgentById(id)
				if (agent != null) {
					this.currentAgentName = agent['name'] as string
					const rawAvatar = agent['avatar']
					this.currentAgentAvatar = rawAvatar != null ? (rawAvatar as string) : ''
				}
			},

			/** 从历史记录跳转时加载已有对话 */
			loadExistingConversation() {
				const convId = uni.getStorageSync('active_conversation_id') as string
				if (convId == null || convId == '') { return }
				uni.removeStorageSync('active_conversation_id')
				this.conversationId = convId
				this.savedFlag = true
				try {
					const msgs = getMessages(convId)
					if (msgs != null && msgs.length > 0) {
						this.messages = msgs
						this.scrollToBottom()
					}
				} catch (_e: any) {
					// 加载失败，开始新对话
				}
			},

			/** 根据行数 JS 动态调整输入框高度 */
			onInputLineChange(e: UniTextareaLineChangeEvent) {
				const lineCount = e.detail.lineCount
				if (lineCount <= 1) {
					this.inputHeight = 40
				} else {
					this.inputHeight = Math.min(lineCount * 22 + 16, 200)
				}
			},

			sendMessage() {
				const text = this.inputText.trim()
				if (text == '' || this.isGenerating) {
					return
				}
				if (this.messages.length == 0) {
					this.conversationId = '' + Date.now()
					this.savedFlag = false
				}
				this.addTextMessage('user', text)
				this.inputText = ''
				this.scrollToBottom()
				this.simulateAIResponse(text)
			},

			/** 添加文本消息 */
			addTextMessage(role: string, content: string) {
				this.messages.push({
					role: role,
					content: content,
					msgType: 'text',
					timestamp: Date.now()
				} as UTSJSONObject)
			},

			/** 添加图片消息 */
			addImageMessage(imagePath: string) {
				if (imagePath == '') { return }
				this.messages.push({
					role: 'user',
					content: '[图片]',
					msgType: 'image',
					imageUrl: imagePath,
					timestamp: Date.now()
				} as UTSJSONObject)
				this.scrollToBottom()
			},

			/** 添加文件消息 */
			addFileMessage(fileInfo: UTSJSONObject) {
				const name = fileInfo['name'] as string ?? '文件'
				const path = fileInfo['path'] as string ?? ''
				this.messages.push({
					role: 'user',
					content: '[文件] ' + name,
					msgType: 'file',
					imageUrl: path,
					timestamp: Date.now()
				} as UTSJSONObject)
				this.scrollToBottom()
			},

			/** 添加位置消息 */
			addLocationMessage(location: UTSJSONObject) {
				const name = location['name'] as string ?? '未知位置'
				const addr = location['address'] as string ?? ''
				const lat = location['latitude'] as number ?? 0
				const lng = location['longitude'] as number ?? 0
				const content = '📍 ' + name + (addr != '' ? ' - ' + addr : '') + ' (' + lat + ', ' + lng + ')'
				this.messages.push({
					role: 'user',
					content: content,
					msgType: 'location',
					timestamp: Date.now()
				} as UTSJSONObject)
				this.scrollToBottom()
			},

			/** 添加语音消息 */
			addVoiceMessage(tempPath: string) {
				if (tempPath == '') { return }
				this.messages.push({
					role: 'user',
					content: '[语音消息]',
					msgType: 'voice',
					imageUrl: tempPath,
					timestamp: Date.now()
				} as UTSJSONObject)
				this.scrollToBottom()
			},

			// ===== 工具栏 =====

			/** 从相册选择图片 */
			pickImage() {
				this.showToolPanel = false
				uni.chooseImage({
					count: 1,
					sourceType: ['album'],
					sizeType: ['compressed'],
					success: (res: any) => {
						const raw = JSON.stringify(res)
						if (raw == null || raw == '') { return }
						const parsed = JSON.parse(raw) as UTSJSONObject
						const paths = parsed['tempFilePaths'] as string[]
						if (paths != null && paths.length > 0) {
							this.addImageMessage(paths[0])
							// 发完图片后调用 AI
							this.simulateAIResponse('用户发送了一张图片')
						}
					}
				})
			},

			/** 拍照 */
			takePhoto() {
				this.showToolPanel = false
				uni.chooseImage({
					count: 1,
					sourceType: ['camera'],
					sizeType: ['compressed'],
					success: (res: any) => {
						const raw = JSON.stringify(res)
						if (raw == null || raw == '') { return }
						const parsed = JSON.parse(raw) as UTSJSONObject
						const paths = parsed['tempFilePaths'] as string[]
						if (paths != null && paths.length > 0) {
							this.addImageMessage(paths[0])
							this.simulateAIResponse('用户拍摄了一张照片')
						}
					}
				})
			},

			/** 选择文件 */
			pickFile() {
				this.showToolPanel = false
				uni.chooseFile({
					count: 1,
					success: (res: any) => {
						const raw = JSON.stringify(res)
						if (raw == null || raw == '') { return }
						const parsed = JSON.parse(raw) as UTSJSONObject
						this.addFileMessage(parsed)
					}
				})
			},

			/** 选择位置 */
			pickLocation() {
				this.showToolPanel = false
				uni.chooseLocation({
					success: (res: any) => {
						const raw = JSON.stringify(res)
						if (raw == null || raw == '') { return }
						const parsed = JSON.parse(raw) as UTSJSONObject
						this.addLocationMessage(parsed)
					}
				})
			},

			// ===== 语音输入 =====

			startVoice() {
				this.isListening = true
				const recorder = uni.getRecorderManager()
				recorder.onStop((res: any): void => {
					this.isListening = false
					const raw = JSON.stringify(res)
					if (raw == null || raw == '') { return }
					const parsed = JSON.parse(raw) as UTSJSONObject
					const tempPath = parsed['tempFilePath'] as string ?? ''
					if (tempPath != '') {
						this.addVoiceMessage(tempPath)
					}
				})
				const startOpts: RecorderManagerStartOptions = {
					format: 'aac',
				}
				recorder.start(startOpts)
			},

			stopVoice() {
				const recorder = uni.getRecorderManager()
				recorder.stop()
			},

			goAgentSettings() {
				uni.navigateTo({
					url: '/pages/agent-settings/agent-settings'
				})
			},

			goHistory() {
				uni.navigateTo({
					url: '/pages/history/history'
				})
			},

			goBack() {
				uni.navigateBack()
			},

			saveCurrentConversation() {
				if (this.messages.length == 0 || this.savedFlag) {
					return
				}
				this.savedFlag = true

				let title = '新对话'
				for (let i = 0; i < this.messages.length; i++) {
					const msg = this.messages[i]
					if (msg['role'] == 'user') {
						const c = msg['content'] as string
						if (c != null && c != '') {
							title = c.length > 20 ? c.substring(0, 20) + '...' : c
						}
						break
					}
				}

				const modelName = uni.getStorageSync('settings_model') as string

				saveConversation(
					this.conversationId,
					title,
					modelName != null && modelName != '' ? modelName : 'deepseek-v4-flash',
					this.currentAgentId,
					this.messages
				)
			},

			scrollToBottom() {
				this.scrollTop = this.scrollTop + 9999
			},

			simulateAIResponse(_userText: string) {
				this.isGenerating = true

				const aiMsgIndex = this.messages.length
				this.messages.push({
					role: 'assistant',
					content: '',
					msgType: 'text',
					isStreaming: true,
					timestamp: Date.now()
				} as UTSJSONObject)
				this.scrollToBottom()

				chatWithLLM(this.messages).then((response: string | null) => {
					const text = response ?? '抱歉，调用 LLM 失败，请检查 API 配置。'

					let charIndex = 0
					let timer: number = 0
					timer = setInterval(() => {
						if (charIndex < text.length) {
							this.messages.splice(aiMsgIndex, 1, {
								role: 'assistant',
								content: text.substring(0, charIndex + 1),
								msgType: 'text',
								isStreaming: true,
								timestamp: Date.now()
							} as UTSJSONObject)
							charIndex++
							this.scrollToBottom()
						} else {
							this.messages.splice(aiMsgIndex, 1, {
								role: 'assistant',
								content: text,
								msgType: 'text',
								isStreaming: false,
								timestamp: Date.now()
							} as UTSJSONObject)
							this.isGenerating = false
							clearInterval(timer)
							this.saveCurrentConversation()
						}
					}, 50)
				})
			}
		}
	};
</script>

<style>
	/* 页面内容区域 */
	.chat-page {
		flex: 1;
		flex-direction: column;
	}

	/* 消息列表 */
	.message-list {
		flex: 1;
		flex-direction: column;
	}

	/* NavBar 右侧图标按钮 */
	.nav-icon-btn {
		width: 32px;
		height: 32px;
		justify-content: center;
		align-items: center;
	}

	/* 空状态 */
	.empty-state {
		flex: 1;
		justify-content: center;
		align-items: center;
		padding-top: 120px;
	}

	.empty-text {
		font-size: 24px;
		color: var(--rice-text-color);
		font-weight: bold;
		margin-bottom: 8px;
	}

	.empty-hint {
		font-size: 14px;
		color: var(--rice-text-color-3);
	}

	/* 底部区域（工具栏面板 + 输入栏） */
	.chat-bottom {
		background-color: var(--rice-background-2);
		border-top-width: 1px;
		border-top-color: var(--rice-border-color);
		border-top-style: solid;
	}

	/* 工具栏面板（输入栏上方展开） */
	.toolbar-panel {
		background-color: var(--rice-background);
		padding: 12px 8px 8px 8px;
	}
	.toolbar-grid {
		flex-direction: row;
		justify-content: flex-start;
	}
	.toolbar-grid-item {
		width: 25%;
		align-items: center;
	}
	.toolbar-grid-icon {
		width: 40px;
		height: 40px;
		border-radius: 10px;
		background-color: var(--rice-background-2);
		justify-content: center;
		align-items: center;
		margin-bottom: 4px;
	}
	.toolbar-grid-label {
		font-size: 11px;
		color: var(--rice-text-color-2);
	}

	/* 输入栏 */
	.input-bar {
		flex-direction: row;
		align-items: center;
		padding-left: 6px;
		padding-right: 8px;
		padding-top: 6px;
		padding-bottom: 6px;
	}

	/* 输入框容器 */
	.input-wrap {
		flex: 1;
		flex-direction: row;
		align-items: flex-end;
		background-color: var(--rice-background);
		border-radius: 16px;
		padding-left: 8px;
		padding-right: 8px;
		margin-left: 6px;
		margin-right: 6px;
	}

	/* 工具栏切换按钮 */
	.toolbar-toggle {
		width: 32px;
		height: 32px;
		border-radius: 16px;
		justify-content: center;
		align-items: center;
	}



	/* 文本输入框 */
	.text-input {
		width: 100%;
		min-height: 32px;
		max-height: 200px;
		padding-left: 4px;
		padding-right: 4px;
		padding-top: 8px;
		padding-bottom: 8px;
		font-size: 15px;
		color: var(--rice-text-color);
		background-color: transparent;
		line-height: 22px;
	}
</style>
