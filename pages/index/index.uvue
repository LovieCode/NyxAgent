		font-size: 14px;
		color: var(--rice-text-color-3);
	}

	/* 底部区域（工具栏面板 + 输入栏） */
	.chat-bottom {
		background-color: var(--rice-background-2);
		border-top-width: 1px;
		border-top-color: var(--rice-border-color);
		border-top-style: solid;
	}

	/* 工具栏面板（输入栏上方展开） */
	.toolbar-panel {
		background-color: var(--rice-background);
		padding: 12px 8px 8px 8px;
	}
	.toolbar-grid {
		flex-direction: row;
		justify-content: flex-start;
	}
	.toolbar-grid-item {
		width: 25%;
		align-items: center;
	}
	.toolbar-grid-icon {
		width: 52px;
		height: 52px;
		border-radius: 14px;
		background-color: var(--rice-background-2);
		justify-content: center;
		align-items: center;
		margin-bottom: 4px;
	}
	.toolbar-grid-label {
		font-size: 12px;
		color: var(--rice-text-color-2);
	}

	/* 输入栏 */
	.input-bar {
		flex-direction: row;
		align-items: center;
		padding-left: 6px;
		padding-right: 8px;
		padding-top: 6px;
		padding-bottom: 6px;
	}

	/* 输入框容器 */
	.input-wrap {
		flex: 1;
		flex-direction: row;
		align-items: flex-end;
		background-color: var(--rice-background);
		border-radius: 16px;
		padding-left: 8px;
		padding-right: 8px;
		margin-left: 6px;
		margin-right: 6px;
	}

	/* 工具栏切换按钮 */
	.toolbar-toggle {
		width: 32px;
		height: 32px;
		border-radius: 16px;
		justify-content: center;
		align-items: center;
	}



	/* 文本输入框 */
	.text-input {
		width: 100%;
		min-height: 32px;
		max-height: 200px;
		padding-left: 4px;
		padding-right: 4px;
		padding-top: 8px;
		padding-bottom: 8px;
		font-size: 15px;
		color: var(--rice-text-color);
		background-color: transparent;
		line-height: 22px;
	}

	/* 行内编辑 */
	.inline-edit-wrap {
		padding: 10px;
		margin: 8px 10px;
		border-radius: 16px;
	}

	.inline-edit-user {
		background-color: #FFF0F3;
		margin-left: 50px;
		margin-right: 10px;
	}

	.inline-edit-ai {
		background-color: var(--rice-background-2);
		margin-left: 10px;
		margin-right: 50px;
	}

	.inline-edit-input {
		width: 100%;
		min-height: 60px;
		font-size: 15px;
		color: var(--rice-text-color);
		line-height: 22px;
		padding: 6px;
		background-color: #FFFFFF;
		border-radius: 8px;
	}

	.inline-edit-actions {
		flex-direction: row;
		justify-content: flex-end;
		margin-top: 8px;
	}

	.inline-edit-save {
		font-size: 14px;
		color: var(--rice-primary-color);
		font-weight: bold;
		padding: 4px 12px;
