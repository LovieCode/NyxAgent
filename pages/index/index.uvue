<template>
	<view class="page-shell rice-theme-light" ref="shellRef">
		<NavBar :title="headerTitle" showBack @back="goBack">
			<template #right>
				<view style="flex-direction:row;align-items:center;">
					<view class="nav-icon-btn" @click="startNewConversation">
						<oui-icon-unix name="plus-circle" size="18px" color="#FFFFFF" />
					</view>
					<view class="nav-icon-btn" @click="goAgentSettings" style="margin-left:4px;">
						<oui-icon-unix name="setting" size="18px" color="#FFFFFF" />
					</view>
					<view class="nav-icon-btn" @click="goHistory" style="margin-left:4px;">
						<oui-icon-unix name="time-circle" size="20px" color="#FFFFFF" />
					</view>
				</view>
			</template>
		</NavBar>

		<!-- 消息列表 -->
		<scroll-view class="message-list" :scroll-y="true" :scroll-top="scrollTop" @scroll="onMsgScroll" @touchmove="onMsgTouchMove">
			<view v-for="(msg, index) in messages" :key="index">
				<!-- 工具执行记录（toolResult 角色） -->
				<ToolExecution
					v-if="msg.role == 'toolResult'"
					:toolName="msg.toolName != null ? msg.toolName : ''"
					:status="msg.toolStatus != null ? msg.toolStatus : 'completed'"
					:result="msg.content"
					:args="msg.args != null ? msg.args : ''"
				/>
				<!-- 跳过空内容且带 tool_calls 的 assistant 上下文消息 -->
				<view v-else-if="msg.role == 'assistant' && msg.tool_calls != null && (msg.content == null || msg.content == '')">
				</view>
				<!-- 行内编辑模式 -->
				<view v-else-if="editingIndex == index" class="inline-edit-wrap" :class="msg.role == 'user' ? 'inline-edit-user' : 'inline-edit-ai'">
					<textarea class="inline-edit-input" v-model="editBuffer" auto-height />
					<view class="inline-edit-actions">
						<text class="inline-edit-cancel" @click="cancelEdit">取消</text>
						<text class="inline-edit-save" @click="saveEdit">保存</text>
						<text class="inline-edit-send" @click="saveAndSend">发送</text>
					</view>
				</view>
				<ChatBubble
					v-else
					:role="msg.role"
					:content="msg.content"
					:msgType="msg.msgType != null ? msg.msgType : 'text'"
					:imageUrl="msg.imageUrl != null ? msg.imageUrl : ''"
					:agentAvatar="currentAgentAvatar"
					:userNickname="userNickname"
					:userAvatar="userAvatar"
					:toolName="msg.toolName != null ? msg.toolName : ''"
					:thinking="msg.thinking != null ? msg.thinking : ''"
					:hideThinking="hideThinking"
					:isError="msg.isError == true"
					:isStreaming="msg.isStreaming == true"
					:cancelToken="longpressCancelToken"
					@bubbleLongpress="onMessageLongpress(index)"
				/>
			</view>
			<view v-if="messages.length == 0" class="empty-state">
				<text class="empty-text">开始对话</text>
				<text class="empty-hint">输入文字或长按语音按钮</text>
			</view>
		</scroll-view>

		<!-- 底部区域（输入栏 + 工具栏） -->
		<view class="chat-bottom">
			<!-- 输入栏 -->
			<view class="input-bar">
					<view class="toolbar-toggle" @click="toggleToolPanel">
					<oui-icon-unix name="plus" size="18px" color="#374151" />
				</view>
				<view class="input-wrap">
					<textarea
						class="text-input"
						v-model="inputText"
						:style="{ height: inputHeight + 'px' }"
						placeholder="输入消息..."
						placeholder-style="color:var(--rice-text-color-3)"
						@linechange="onInputLineChange"
						:disabled="isGenerating == true"
					/>
				</view>
				<VoiceInput :isListening="isListening ? true : false" @startListening="startVoice" @stopListening="stopVoice" />
				<rice-button v-if="isGenerating == false" type="primary" text="发送" size="small" shape="round" @click="sendMessage" style="margin-left:6px" />
				<rice-button v-else type="primary" text="停止" size="small" shape="round" @click="stopGenerating" style="margin-left:6px" />
			</view>
			<!-- 工具栏面板（输入栏下方展开） -->
			<view v-if="showToolPanel" class="toolbar-panel">
				<view class="toolbar-grid">
					<view class="toolbar-grid-item" @click="pickImage; showToolPanel = false">
						<view class="toolbar-grid-icon"><oui-icon-unix name="image" size="26px" color="var(--rice-primary-color)" /></view>
						<text class="toolbar-grid-label">图片</text>
					</view>
					<view class="toolbar-grid-item" @click="takePhoto; showToolPanel = false">
						<view class="toolbar-grid-icon"><oui-icon-unix name="camera" size="26px" color="var(--rice-primary-color)" /></view>
						<text class="toolbar-grid-label">拍照</text>
					</view>
					<view class="toolbar-grid-item" @click="pickFile; showToolPanel = false">
						<view class="toolbar-grid-icon"><oui-icon-unix name="file" size="26px" color="var(--rice-primary-color)" /></view>
						<text class="toolbar-grid-label">文件</text>
					</view>
					<view class="toolbar-grid-item" @click="pickLocation; showToolPanel = false">
						<view class="toolbar-grid-icon"><oui-icon-unix name="location" size="26px" color="var(--rice-primary-color)" /></view>
						<text class="toolbar-grid-label">位置</text>
					</view>
					<view class="toolbar-grid-item" @click="goMemoryManager">
						<view class="toolbar-grid-icon"><oui-icon-unix name="robot" size="26px" color="var(--rice-primary-color)" /></view>
						<text class="toolbar-grid-label">记忆管理</text>
					</view>
					<view class="toolbar-grid-item" @click="organizeMemoryFromToolbar">
						<view class="toolbar-grid-icon"><oui-icon-unix name="robot" size="26px" color="var(--rice-primary-color)" /></view>
						<text class="toolbar-grid-label">记忆整理</text>
					</view>
					<view class="toolbar-grid-item" @click="openContextPreview">
						<view class="toolbar-grid-icon"><oui-icon-unix name="eye" size="26px" color="var(--rice-primary-color)" /></view>
						<text class="toolbar-grid-label">原始上下文</text>
					</view>
					<view class="toolbar-grid-item" @click="stopTaskFromToolbar">
						<view class="toolbar-grid-icon"><oui-icon-unix name="stop" size="26px" color="#EF4444" /></view>
						<text class="toolbar-grid-label">终止任务</text>
					</view>
				</view>
			</view>
		</view>
	</view>
</template>

<script lang="uts">
	/**
	 * 对话页面 - AI Agent 主聊天界面
	 * 扁平化粉白主题
	 */
	import { saveConversation, getMessages, getConversationsByAgent } from '@/utils/database.uts'
	import { agentChat, buildAgentContextPreview, organizeAgentMemory } from '@/utils/llm.uts'
	import { AgentEvent, AgentEventStream } from '@/utils/event.uts'
	import { getAgentById } from '@/utils/agent.uts'

	export default {
		data() {
			return {
				/** 消息列表 */
				messages: [] as UTSJSONObject[],
				/** 当前输入文本 */
				inputText: '',
				/** 是否正在语音输入 */
				isListening: false as boolean,
				/** AI 是否正在生成回复 */
				isGenerating: false as boolean,
				/** 当前 Agent 事件流，用于停止生成 */
				currentStream: null as AgentEventStream | null,
				/** 当前智能体 ID */
				currentAgentId: '' as string,
				/** 当前智能体名称 */
				currentAgentName: '' as string,
				/** 当前智能体头像 */
				currentAgentAvatar: '' as string,
				/** 用户昵称（用于消息气泡头像） */
				userNickname: '' as string,
				/** 用户头像路径 */
				userAvatar: '' as string,
				/** 是否隐藏思考内容（来自智能体设置） */
				hideThinking: false as boolean,
				/** 流式滚动节拍计数器 */
				_streamScrollTick: 0 as number,
				/** 滚动位置 */
				scrollTop: 0,
				/** 当前对话唯一 ID */
				conversationId: '' as string,
				/** 是否已存过当前对话（防止重复存） */
				savedFlag: false as boolean,
				/** 输入框 JS 驱动高度 */
				inputHeight: 40,
				/** 是否显示工具栏面板 */
				showToolPanel: false as boolean,
				/** 行内编辑 */
				editingIndex: -1 as number,
				editBuffer: '' as string,
				/** 滚动时通知 ChatBubble 取消长按的 token */
				longpressCancelToken: 0 as number,
				/** 消息长按菜单锁，避免重复弹出 */
				messageActionSheetOpen: false as boolean,
			}
		},
		computed: {
			/** 头部标题 */
			headerTitle(): string {
				return this.currentAgentName != '' ? this.currentAgentName : 'AI 助手'
			}
		},
		onLoad() {
			// 加载用户昵称
			this.loadUserNickname()
			// 加载当前智能体信息
			this.loadCurrentAgent()
			// 检查是否因历史记录跳转过来的（加载已有对话）
			this.loadExistingConversation()
			// 无指定历史时，自动加载该智能体最近对话
			if (this.conversationId == '') {
				this.loadRecentConversation()
			}
			// 仍然没有，生成新对话 ID
			if (this.conversationId == '') {
				this.conversationId = '' + Date.now()
			}
		},

	onShow() {
				// 每次显示页面时刷新智能体信息和用户昵称
				this.loadUserNickname()
				this.loadCurrentAgent()
			},

			onReady() {
				// DOM 就绪后滚动到底部
				this.scrollToBottom()
			},

			onHide() {
			// 离开页面时保存当前对话
			this.saveCurrentConversation()
		},

		methods: {
			/** 加载当前智能体信息 */
			/** 加载用户昵称 */
			loadUserNickname() {
				const v = uni.getStorageSync('profile_nickname') as string
				this.userNickname = (v != null && v != '') ? v : '用户'
				const avatar = uni.getStorageSync('profile_avatar') as string
				this.userAvatar = (avatar != null) ? avatar : ''
			},

			loadCurrentAgent() {
				const id = uni.getStorageSync('active_agent_id') as string
				if (id == null || id == '') { return }
				this.currentAgentId = id
				const agent = getAgentById(id)
				if (agent != null) {
					this.currentAgentName = agent['name'] as string
					const rawAvatar = agent['avatar']
					this.currentAgentAvatar = rawAvatar != null ? (rawAvatar as string) : ''
					const rawHideThinking = agent['hideThinking']
					this.hideThinking = rawHideThinking != null ? (rawHideThinking as boolean) : false
				}
			},

			/** 从历史记录跳转时加载已有对话 */
			loadExistingConversation() {
				const convId = uni.getStorageSync('active_conversation_id') as string
				if (convId == null || convId == '') { return }
				uni.removeStorageSync('active_conversation_id')
				this.conversationId = convId
				this.savedFlag = true
				try {
					const msgs = getMessages(convId)
					if (msgs != null && msgs.length > 0) {
						this.messages = msgs
					}
				} catch (_e: any) {
					// 加载失败，开始新对话
				}
			},

			/** 自动加载当前智能体最近的一条对话 */
			loadRecentConversation() {
				if (this.currentAgentId == '') { return }
				try {
					const convs = getConversationsByAgent(this.currentAgentId)
					if (convs != null && convs.length > 0) {
						const latest = convs[0]
						const convId = latest['id'] as string
						if (convId != null && convId != '') {
							this.conversationId = convId
							this.savedFlag = true
							const msgs = getMessages(convId)
							if (msgs != null && msgs.length > 0) {
								this.messages = msgs
							}
						}
					}
				} catch (_e: any) {
					// 加载失败则开始新对话
				}
			},

			/** 根据行数 JS 动态调整输入框高度 */
			onInputLineChange(e: UniTextareaLineChangeEvent) {
				const lineCount = e.detail.lineCount
				if (lineCount <= 1) {
					this.inputHeight = 40
				} else {
					this.inputHeight = Math.min(lineCount * 22 + 16, 200)
				}
			},

			/** 滚动时通知所有 ChatBubble 取消长按 */
			onMsgScroll() {
				this.longpressCancelToken++
			},

			sendMessage() {
				const text = this.inputText.trim()
				if (text == '' || this.isGenerating) {
					return
				}
				if (this.messages.length == 0) {
					this.conversationId = '' + Date.now()
				}
				// 发新消息时允许保存（从历史加载后 savedFlag 为 true 会阻止保存）
				this.savedFlag = false
				this.addTextMessage('user', text)
				this.inputText = ''
				this.scrollToBottom()
				this.simulateAIResponse(text)
			},

			/** 长按消息弹出操作菜单 */
			onMessageLongpress(index: number) {
				if (this.isGenerating) { return }
				if (this.messageActionSheetOpen) { return }
				const msg = this.messages[index]
				if (msg == null) { return }
				const roleRaw = msg['role']
				if (roleRaw == null) { return }
				const role = roleRaw as string
				let actions: string[] = []
				if (role == 'user' || role == 'assistant') {
					actions = ['删除', '编辑']
					if (role == 'assistant') {
						actions.push('重新回答')
					}
				} else {
					actions = ['删除']
				}
				const msgIndex = index
				this.messageActionSheetOpen = true
				uni.showActionSheet({
					itemList: actions,
					success: (res) => {
						const tapIdx = res.tapIndex
						if (tapIdx < 0 || tapIdx >= actions.length) { return }
						const action = actions[tapIdx]
						if (action == '删除') {
							this.deleteMessage(msgIndex)
						} else if (action == '编辑') {
							this.editMessage(msgIndex)
						} else if (action == '重新回答') {
							this.regenerateResponse(msgIndex)
						}
					},
					fail: (_err) => {
					},
					complete: () => {
						this.messageActionSheetOpen = false
					}
				})
			},

			/** 删除指定消息 */
			deleteMessage(index: number) {
				if (index < 0 || index >= this.messages.length) { return }
				this.messages.splice(index, 1)
				this.savedFlag = false
			},

			/** 原地编辑消息 */
			editMessage(index: number) {
				const msg = this.messages[index]
				if (msg == null) { return }
				const rawContent = msg['content']
				this.editBuffer = rawContent != null ? (rawContent as string) : ''
				this.editingIndex = index
			},

			/** 保存行内编辑 */
			saveEdit() {
				const idx = this.editingIndex
				if (idx < 0 || idx >= this.messages.length) { return }
				const msg = this.messages[idx]
				if (msg == null) { return }
				msg['content'] = this.editBuffer
				this.messages.splice(idx, 1, msg)
				this.cancelEdit()
				this.savedFlag = false
			},

			/** 保存并发送：更新内容后从该消息截断并重新触发 AI */
			saveAndSend() {
				const idx = this.editingIndex
				if (idx < 0 || idx >= this.messages.length) { return }
				const msg = this.messages[idx]
				if (msg == null) { return }
				msg['content'] = this.editBuffer
				this.messages.splice(idx, 1, msg)
				this.editingIndex = -1
				this.editBuffer = ''
				this.savedFlag = false

				// 截断该消息之后的内容，重新触发 AI
				this.messages.splice(idx + 1, this.messages.length - idx - 1)
				// 取最后一条用户消息发往 AI
				let lastUserText = ''
				for (let i = this.messages.length - 1; i >= 0; i--) {
					const m = this.messages[i]
					const roleRaw = m['role']
					if (roleRaw != null && (roleRaw as string) == 'user') {
						const contentRaw = m['content']
						if (contentRaw != null) {
							lastUserText = contentRaw as string
						}
						break
					}
				}
				if (lastUserText != '') {
					this.simulateAIResponse(lastUserText)
				}
			},

			/** 取消行内编辑 */
			cancelEdit() {
				this.editingIndex = -1
				this.editBuffer = ''
			},

			/** 重新生成 AI 回答：删除该 AI 消息，重新触发 AI */
			regenerateResponse(index: number) {
				// 从 index 开始截断（包括该 AI 消息和之后的消息）
				this.messages.splice(index, this.messages.length - index)
				this.savedFlag = false
				// 取上一条用户消息作为输入重新触发
				let lastUserText = ''
				for (let i = this.messages.length - 1; i >= 0; i--) {
					const m = this.messages[i]
					const roleRaw = m['role']
					if (roleRaw != null && (roleRaw as string) == 'user') {
						const contentRaw = m['content']
						if (contentRaw != null) {
							lastUserText = contentRaw as string
						}
						break
					}
				}
				if (lastUserText != '') {
					this.simulateAIResponse(lastUserText)
				}
			},

			/** 添加文本消息 */
			addTextMessage(role: string, content: string) {
				this.messages.push({
					role: role,
					content: content,
					msgType: 'text',
					timestamp: Date.now()
				} as UTSJSONObject)
			},

			/** 添加图片消息 */
			addImageMessage(imagePath: string) {
				if (imagePath == '') { return }
				this.messages.push({
					role: 'user',
					content: '[图片]',
					msgType: 'image',
					imageUrl: imagePath,
					timestamp: Date.now()
				} as UTSJSONObject)
				this.scrollToBottom()
			},

			/** 添加文件消息 */
			addFileMessage(fileInfo: UTSJSONObject) {
				const rawName = fileInfo['name'] as string | null
				const rawPath = fileInfo['path'] as string | null
				const name = rawName != null ? rawName : '文件'
				const path = rawPath != null ? rawPath : ''
				this.messages.push({
					role: 'user',
					content: '[文件] ' + name,
					msgType: 'file',
					imageUrl: path,
					timestamp: Date.now()
				} as UTSJSONObject)
				this.scrollToBottom()
			},

			/** 添加位置消息 */
			addLocationMessage(location: UTSJSONObject) {
				const rawName = location['name'] as string | null
				const rawAddr = location['address'] as string | null
				const rawLat = location['latitude'] as number | null
				const rawLng = location['longitude'] as number | null
				const name = rawName != null ? rawName : '未知位置'
				const addr = rawAddr != null ? rawAddr : ''
				const lat = rawLat != null ? rawLat : 0
				const lng = rawLng != null ? rawLng : 0
				const content = '📍 ' + name + (addr != '' ? ' - ' + addr : '') + ' (' + lat + ', ' + lng + ')'
				this.messages.push({
					role: 'user',
					content: content,
					msgType: 'location',
					timestamp: Date.now()
				} as UTSJSONObject)
				this.scrollToBottom()
			},

			/** 添加语音消息 */
			addVoiceMessage(tempPath: string) {
				if (tempPath == '') { return }
				this.messages.push({
					role: 'user',
					content: '[语音消息]',
					msgType: 'voice',
					imageUrl: tempPath,
					timestamp: Date.now()
				} as UTSJSONObject)
				this.scrollToBottom()
			},

			// ===== 工具栏 =====

			/** 切换工具栏面板，打开后滚动到底 */
			toggleToolPanel() {
				this.showToolPanel = !this.showToolPanel
				if (this.showToolPanel == true) {
					this.scrollToBottom()
				}
			},

			/** 滚动时通知 ChatBubble 取消长按 */
			onMsgTouchMove() {
				this.longpressCancelToken++
			},

			/** 从相册选择图片 */
			pickImage() {
				this.showToolPanel = false
				uni.chooseImage({
					count: 1,
					sourceType: ['album'],
					sizeType: ['compressed'],
					success: (res: any) => {
						const raw = JSON.stringify(res)
						if (raw == null || raw == '') { return }
						const parsed = JSON.parse(raw) as UTSJSONObject
						const paths = parsed['tempFilePaths'] as string[]
						if (paths != null && paths.length > 0) {
							this.addImageMessage(paths[0])
							// 发完图片后调用 AI
							this.simulateAIResponse('用户发送了一张图片')
						}
					}
				})
			},

			/** 拍照 */
			takePhoto() {
				this.showToolPanel = false
				uni.chooseImage({
					count: 1,
					sourceType: ['camera'],
					sizeType: ['compressed'],
					success: (res: any) => {
						const raw = JSON.stringify(res)
						if (raw == null || raw == '') { return }
						const parsed = JSON.parse(raw) as UTSJSONObject
						const paths = parsed['tempFilePaths'] as string[]
						if (paths != null && paths.length > 0) {
							this.addImageMessage(paths[0])
							this.simulateAIResponse('用户拍摄了一张照片')
						}
					}
				})
			},

			/** 选择文件 */
			pickFile() {
				this.showToolPanel = false
				uni.chooseFile({
					count: 1,
					success: (res: any) => {
						const raw = JSON.stringify(res)
						if (raw == null || raw == '') { return }
						const parsed = JSON.parse(raw) as UTSJSONObject
						this.addFileMessage(parsed)
					}
				})
			},

			/** 选择位置 */
			pickLocation() {
				this.showToolPanel = false
				uni.chooseLocation({
					success: (res: any) => {
						const raw = JSON.stringify(res)
						if (raw == null || raw == '') { return }
						const parsed = JSON.parse(raw) as UTSJSONObject
						this.addLocationMessage(parsed)
					}
				})
			},

			/** 手动触发记忆管理 Agent 整理当前对话。 */
			organizeMemoryFromToolbar() {
				this.showToolPanel = false
				if (this.isGenerating == true) {
					uni.showToast({ position: 'bottom', 
						title: '当前任务进行中',
						icon: 'none'
					})
					return
				}
				if (this.messages.length == 0) {
					uni.showToast({ position: 'bottom', 
						title: '暂无可整理内容',
						icon: 'none'
					})
					return
				}
				let agentModel = ''
				if (this.currentAgentId != '') {
					const agent = getAgentById(this.currentAgentId)
					if (agent != null) {
						const rawModel = agent['model'] as string | null
						agentModel = rawModel != null ? rawModel : ''
					}
				}
				const started = organizeAgentMemory(
					this.messages,
					'',
					agentModel,
					this.currentAgentId,
					this.conversationId
				)
				uni.showToast({ position: 'bottom', 
					title: started == true ? '记忆整理已开始' : '暂无可整理内容',
					icon: 'none'
				})
			},

			/** 工具栏终止当前任务。 */
			stopTaskFromToolbar() {
				this.showToolPanel = false
				if (this.isGenerating == true) {
					this.stopGenerating()
					uni.showToast({ position: 'bottom', 
						title: '已终止',
						icon: 'none'
					})
					return
				}
				uni.showToast({ position: 'bottom', 
					title: '当前没有运行中的任务',
					icon: 'none'
				})
			},

			// ===== 语音输入 =====

			startVoice() {
				this.isListening = true
				const recorder = uni.getRecorderManager()
				recorder.onStop((res: any): void => {
					this.isListening = false
					const raw = JSON.stringify(res)
					if (raw == null || raw == '') { return }
					const parsed = JSON.parse(raw) as UTSJSONObject
					const rawTempPath = parsed['tempFilePath'] as string | null
					const tempPath = rawTempPath != null ? rawTempPath : ''
					if (tempPath != '') {
						this.addVoiceMessage(tempPath)
					}
				})
				const startOpts: RecorderManagerStartOptions = {
					format: 'aac',
				}
				recorder.start(startOpts)
			},

			stopVoice() {
				const recorder = uni.getRecorderManager()
				recorder.stop()
			},

			/** 停止当前 AI 生成 */
			stopGenerating() {
				const stream = this.currentStream
				if (stream != null) {
					stream.abort()
					this.currentStream = null
				}
				this.finishAssistantMessage('')
				this.isGenerating = false
				this.saveCurrentConversation()
			},

			goAgentSettings() {
				uni.navigateTo({
					url: '/pages/agent-settings/agent-settings'
				})
			},

			goHistory() {
				uni.navigateTo({
					url: '/pages/history/history'
				})
			},

			goMemoryManager() {
				this.showToolPanel = false
				uni.setStorageSync('memory_agent_id', this.currentAgentId)
				uni.setStorageSync('memory_conversation_id', this.conversationId)
				uni.navigateTo({
					url: '/pages/memory/memory'
				})
			},

			openContextPreview() {
				this.showToolPanel = false
				let systemPrompt = ''
				let agentModel = ''
				if (this.currentAgentId != '') {
					const agent = getAgentById(this.currentAgentId)
					if (agent != null) {
						const rawPrompt = agent['systemPrompt'] as string | null
						const rawModel = agent['model'] as string | null
						systemPrompt = rawPrompt != null ? rawPrompt : ''
						agentModel = rawModel != null ? rawModel : ''
					}
				}
				const preview = buildAgentContextPreview(
					this.messages,
					systemPrompt,
					'',
					agentModel,
					this.currentAgentId,
					0,
					this.conversationId
				)
				let previewText = ''
				try {
					previewText = JSON.stringify(preview, null, 2)
				} catch (_e: any) {
					previewText = JSON.stringify(preview)
				}
				uni.setStorageSync('context_preview_payload', previewText)
				uni.navigateTo({
					url: '/pages/context-preview/context-preview'
				})
			},

			goBack() {
				uni.navigateBack()
			},

			/** 开启新对话 */
			startNewConversation() {
				if (this.isGenerating) {
					uni.showToast({ position: 'bottom',  title: '请等待当前回复完成', icon: 'none' })
					return
				}
				// 先保存当前对话
				this.saveCurrentConversation()
				// 清空消息
				this.messages = [] as UTSJSONObject[]
				// 新对话 ID
				this.conversationId = '' + Date.now()
				this.savedFlag = false
				// 重置输入
				this.inputText = ''
				this.showToolPanel = false
			},

			saveCurrentConversation() {
				if (this.messages.length == 0 || this.savedFlag) {
					return
				}
				this.savedFlag = true

				let title = '新对话'
				for (let i = 0; i < this.messages.length; i++) {
					const msg = this.messages[i]
					if (msg['role'] == 'user') {
						const c = msg['content'] as string
						if (c != null && c != '') {
							title = c.length > 20 ? c.substring(0, 20) + '...' : c
						}
						break
					}
				}

				// 优先使用智能体自己的模型，回退到全局设置
				let modelName = 'deepseek-v4-flash'
				if (this.currentAgentId != '') {
					const agent = getAgentById(this.currentAgentId)
					if (agent != null) {
						const rawModel = agent['model']
						if (rawModel != null) {
							modelName = rawModel as string
						}
					}
				}
				if (modelName == 'deepseek-v4-flash') {
					const globalModel = uni.getStorageSync('settings_model') as string
					if (globalModel != null && globalModel != '') {
						modelName = globalModel
					}
				}

				saveConversation(
					this.conversationId,
					title,
					modelName,
					this.currentAgentId,
					this.getCurrentSystemPrompt(),
					this.messages
				)
			},

			scrollToBottom() {
				// 流式生成时使用计数器递增确保每次值不同，非生成时用 toggle 触发滚动
				if (this.isGenerating == true) {
					this._streamScrollTick++
					this.scrollTop = 100000 + this._streamScrollTick
				} else {
					this.scrollTop = 0
					const self = this
					setTimeout(() => {
						self.scrollTop = 99999
					}, 50)
				}
			},

			/** 获取当前智能体的系统提示词 */
			getCurrentSystemPrompt(): string {
				if (this.currentAgentId != '') {
					const agent = getAgentById(this.currentAgentId)
					if (agent != null) {
						const raw = agent['systemPrompt']
						if (raw != null) {
							return raw as string
						}
					}
				}
				return ''
			},

			/** 追加流式文本到最后一条 assistant 消息 */
			appendAssistantDelta(text: string) {
				if (text == '') return
				const lastIdx = this.messages.length - 1
				if (lastIdx >= 0 && (this.messages[lastIdx]['role'] as string) == 'assistant' &&
					(this.messages[lastIdx]['isStreaming'] as boolean | null) == true) {
					const existing = this.messages[lastIdx]
					const oldContent = existing['content'] as string | null
					const oldThinking = existing['thinking'] as string | null
					this.messages.splice(lastIdx, 1, {
						role: 'assistant',
						content: (oldContent != null ? oldContent : '') + text,
						thinking: oldThinking != null ? oldThinking : '',
						msgType: 'text',
						isStreaming: true,
						timestamp: Date.now()
					} as UTSJSONObject)
				} else {
					this.messages.push({
						role: 'assistant',
						content: text,
						thinking: '',
						msgType: 'text',
						isStreaming: true,
						timestamp: Date.now()
					} as UTSJSONObject)
				}
				this.scrollToBottom()
			},

			/** 结束最后一条流式 assistant 消息 */
			finishAssistantMessage(response: string) {
				const lastIdx = this.messages.length - 1
				if (lastIdx >= 0 && (this.messages[lastIdx]['role'] as string) == 'assistant' &&
					(this.messages[lastIdx]['isStreaming'] as boolean | null) == true) {
					const existing = this.messages[lastIdx]
					const oldContent = existing['content'] as string | null
					const oldThinking = existing['thinking'] as string | null
					let finalContent = oldContent != null ? oldContent : ''
					if (finalContent == '' && response != '') {
						finalContent = response
					}
					this.messages.splice(lastIdx, 1, {
						role: 'assistant',
						content: finalContent,
						thinking: oldThinking != null ? oldThinking : '',
						msgType: 'text',
						isStreaming: false,
						timestamp: Date.now()
					} as UTSJSONObject)
				} else if (response != '') {
					this.messages.push({
						role: 'assistant',
						content: response,
						thinking: '',
						msgType: 'text',
						isStreaming: false,
						timestamp: Date.now()
					} as UTSJSONObject)
				}
				this.scrollToBottom()
			},

			/** 追加思考增量内容到最后一条流式 assistant */
			appendThinkingDelta(text: string) {
				if (text == '') return
				const lastIdx = this.messages.length - 1
				if (lastIdx >= 0 && (this.messages[lastIdx]['role'] as string) == 'assistant' &&
					(this.messages[lastIdx]['isStreaming'] as boolean | null) == true) {
					const existing = this.messages[lastIdx]
					const oldThinking = existing['thinking'] as string | null
					const oldContent = existing['content'] as string | null
					this.messages.splice(lastIdx, 1, {
						role: 'assistant',
						content: oldContent != null ? oldContent : '',
						thinking: (oldThinking != null ? oldThinking : '') + text,
						msgType: 'text',
						isStreaming: true,
						timestamp: Date.now()
					} as UTSJSONObject)
				}
			},

			/** 结束思考内容追加 */
			finishAssistantThinking(text: string) {
				const lastIdx = this.messages.length - 1
				if (lastIdx >= 0 && (this.messages[lastIdx]['role'] as string) == 'assistant' &&
					(this.messages[lastIdx]['isStreaming'] as boolean | null) == true) {
					const existing = this.messages[lastIdx]
					const oldContent = existing['content'] as string | null
					this.messages.splice(lastIdx, 1, {
						role: 'assistant',
						content: oldContent != null ? oldContent : '',
						thinking: text,
						msgType: 'text',
						isStreaming: true,
						timestamp: Date.now()
					} as UTSJSONObject)
				}
			},

			/** 插入 assistant 工具调用上下文消息 */
			addToolCallMessage(fullText: string, toolCalls: UTSJSONObject[] | null) {
				if (toolCalls == null || toolCalls.length == 0) return
				const lastIdx = this.messages.length - 1
				if (lastIdx >= 0 && (this.messages[lastIdx]['role'] as string) == 'assistant' && this.messages[lastIdx]['tool_calls'] == null) {
					const existing = this.messages[lastIdx]
					const existingContent = existing['content'] as string | null
					const content = existingContent != null && existingContent != '' ? existingContent : fullText
					const existingTimestamp = existing['timestamp'] as number | null
					this.messages.splice(lastIdx, 1, {
						role: 'assistant',
						content: content,
						msgType: 'text',
						isStreaming: false,
						tool_calls: toolCalls,
						timestamp: existingTimestamp != null ? existingTimestamp : Date.now()
					} as UTSJSONObject)
					return
				}
				this.messages.push({
					role: 'assistant',
					content: fullText,
					tool_calls: toolCalls,
					timestamp: Date.now()
				} as UTSJSONObject)
			},

			/** 工具开始执行：插入一条 toolResult 展示消息 */
			addToolExecutionStart(toolCallId: string, toolName: string, argsStr: string) {
				this.messages.push({
					role: 'toolResult',
					tool_call_id: toolCallId,
					toolCallId: toolCallId,
					toolName: toolName,
					toolStatus: 'running',
					content: '',
					args: argsStr,
					timestamp: Date.now()
				} as UTSJSONObject)
				this.scrollToBottom()
			},

			/** 工具结束执行：更新对应 toolResult 消息 */
			updateToolExecutionEnd(toolCallId: string, toolName: string, result: string, isError: boolean) {
				for (let i = this.messages.length - 1; i >= 0; i--) {
					const m = this.messages[i]
					const msgToolCallId = m['tool_call_id'] as string | null
					if ((m['role'] as string) == 'toolResult' && (msgToolCallId != null ? msgToolCallId : '') == toolCallId) {
						const oldArgs = m['args'] as string | null
						this.messages.splice(i, 1, {
							role: 'toolResult',
							tool_call_id: toolCallId,
							toolCallId: toolCallId,
							toolName: toolName,
							toolStatus: isError ? 'error' : 'completed',
							content: result,
							args: oldArgs != null ? oldArgs : '',
							isError: isError,
							timestamp: Date.now()
						} as UTSJSONObject)
						this.scrollToBottom()
						return
					}
				}
				this.messages.push({
					role: 'toolResult',
					tool_call_id: toolCallId,
					toolCallId: toolCallId,
					toolName: toolName,
					toolStatus: isError ? 'error' : 'completed',
					content: result,
					args: '',
					isError: isError,
					timestamp: Date.now()
				} as UTSJSONObject)
				this.scrollToBottom()
			},

			/** Agent 事件流统一入口 */
			handleAgentEvent(event: AgentEvent) {
				if (event.type == 'text_delta') {
					this.appendAssistantDelta(event.text != null ? (event.text as string) : '')
				} else if (event.type == 'text_end') {
					this.finishAssistantMessage(event.fullText != null ? (event.fullText as string) : '')
				} else if (event.type == 'thinking_delta') {
					this.appendThinkingDelta(event.thinkingText != null ? (event.thinkingText as string) : '')
				} else if (event.type == 'thinking_end') {
					this.finishAssistantThinking(event.fullThinking != null ? (event.fullThinking as string) : '')
				} else if (event.type == 'tool_call') {
					this.addToolCallMessage(event.fullText != null ? (event.fullText as string) : '', event.toolCalls != null ? (event.toolCalls as UTSJSONObject[]) : null)
				} else if (event.type == 'tool_execution_start') {
					this.addToolExecutionStart(
						event.toolCallId != null ? (event.toolCallId as string) : '',
						event.toolName != null ? (event.toolName as string) : '',
						event.toolArgs != null ? (event.toolArgs as string) : ''
					)
				} else if (event.type == 'tool_execution_end') {
					this.updateToolExecutionEnd(
						event.toolCallId != null ? (event.toolCallId as string) : '',
						event.toolName != null ? (event.toolName as string) : '',
						event.toolResult != null ? (event.toolResult as string) : '',
						event.isError == true
					)
				} else if (event.type == 'error') {
					this.finishAssistantMessage(event.error != null ? (event.error as string) : '请求失败')
				} else if (event.type == 'memory_organize_start') {
					uni.showToast({ position: 'bottom', 
						title: event.message != null ? (event.message as string) : '记忆整理已开始',
						icon: 'none'
					})
				} else if (event.type == 'agent_end') {
					this.isGenerating = false
					this.currentStream = null
					this.saveCurrentConversation()
				}
			},

			simulateAIResponse(_userText: string) {
				this.isGenerating = true
				this._streamScrollTick = 0

				// 读取当前智能体的系统提示词和模型
				let systemPrompt = ''
				let agentModel = ''
				if (this.currentAgentId != '') {
					const agent = getAgentById(this.currentAgentId)
					if (agent != null) {
						const raw = agent['systemPrompt']
						if (raw != null) {
							systemPrompt = raw as string
						}
						const rawModel = agent['model']
						if (rawModel != null) {
							agentModel = rawModel as string
						}
					}
				}

				// 使用 ReAct Agent Loop（带沙箱文件工具）
				const stream: AgentEventStream = agentChat(
					this.messages,
					systemPrompt,
					'',           // providerId → 自动从 DB 读取
					agentModel,
					this.currentAgentId,
					0,
					this.conversationId
				)
				this.currentStream = stream
				stream.on((event: AgentEvent) => {
					this.handleAgentEvent(event)
				})
			}

		}
	};
</script>

<style>
	/* 页面内容区域 */
	.chat-page {
		flex: 1;
		flex-direction: column;
	}

	/* 消息列表 */
	.message-list {
		flex: 1;
		flex-direction: column;
	}

	/* NavBar 右侧图标按钮 */
	.nav-icon-btn {
		width: 32px;
		height: 32px;
		justify-content: center;
		align-items: center;
	}

	/* 空状态 */
	.empty-state {
		flex: 1;
		justify-content: center;
		align-items: center;
		padding-top: 120px;
	}

	.empty-text {
		font-size: 24px;
		color: var(--rice-text-color);
		font-weight: bold;
		margin-bottom: 8px;
	}

	.empty-hint {
		font-size: 14px;
		color: var(--rice-text-color-3);
	}

	/* 底部区域（工具栏面板 + 输入栏） */
	.chat-bottom {
		flex-shrink: 0;
		background-color: var(--rice-background-2);
		border-top-width: 1px;
		border-top-color: var(--rice-border-color);
		border-top-style: solid;
	}

	/* 工具栏面板（输入栏上方展开） */
	.toolbar-panel {
		background-color: var(--rice-background);
		padding: 12px 8px 8px 8px;
	}
	.toolbar-grid {
		flex-direction: row;
		justify-content: flex-start;
		flex-wrap: wrap;
	}
	.toolbar-grid-item {
		width: 25%;
		align-items: center;
		margin-bottom: 12px;
	}
	.toolbar-grid-icon {
		width: 52px;
		height: 52px;
		border-radius: 14px;
		background-color: var(--rice-background-2);
		justify-content: center;
		align-items: center;
		margin-bottom: 4px;
	}
	.toolbar-grid-label {
		font-size: 12px;
		color: var(--rice-text-color-2);
	}

	/* 输入栏 */
	.input-bar {
		flex-direction: row;
		align-items: center;
		padding-left: 6px;
		padding-right: 8px;
		padding-top: 6px;
		padding-bottom: 6px;
	}

	/* 输入框容器 */
	.input-wrap {
		flex: 1;
		flex-direction: row;
		align-items: flex-end;
		background-color: var(--rice-background);
		border-radius: 16px;
		padding-left: 8px;
		padding-right: 8px;
		margin-left: 6px;
		margin-right: 6px;
	}

	/* 工具栏切换按钮 */
	.toolbar-toggle {
		width: 32px;
		height: 32px;
		border-radius: 16px;
		justify-content: center;
		align-items: center;
	}



	/* 文本输入框 */
	.text-input {
		width: 100%;
		min-height: 32px;
		max-height: 200px;
		padding-left: 4px;
		padding-right: 4px;
		padding-top: 8px;
		padding-bottom: 8px;
		font-size: 15px;
		color: var(--rice-text-color);
		background-color: transparent;
		line-height: 22px;
	}

	/* 行内编辑 */
	.inline-edit-wrap {
		padding: 10px;
		margin: 8px 10px;
		border-radius: 16px;
	}

	.inline-edit-user {
		background-color: #FFF0F3;
		margin-left: 50px;
		margin-right: 10px;
	}

	.inline-edit-ai {
		background-color: var(--rice-background-2);
		margin-left: 10px;
		margin-right: 50px;
	}

	.inline-edit-input {
		width: 100%;
		min-height: 60px;
		font-size: 15px;
		color: var(--rice-text-color);
		line-height: 22px;
		padding: 6px;
		background-color: #FFFFFF;
		border-radius: 8px;
	}

	.inline-edit-actions {
		flex-direction: row;
		justify-content: flex-end;
		margin-top: 8px;
	}

	.inline-edit-save {
		font-size: 14px;
		color: var(--rice-primary-color);
		font-weight: bold;
		padding: 4px 12px;
		margin-left: 12px;
	}

	.inline-edit-send {
		font-size: 14px;
		color: #FFFFFF;
		font-weight: bold;
		padding: 4px 12px;
		background-color: var(--rice-primary-color);
		border-radius: 12px;
		margin-left: 12px;
	}

	.inline-edit-cancel {
		font-size: 14px;
		color: var(--rice-text-color-3);
		padding: 4px 12px;
	}
</style>
