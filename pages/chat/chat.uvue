<template>
	<view class="page-shell rice-theme-light" ref="shellRef">
		<NavBar :title="headerTitle" showBack variant="light" @back="goBack">
			<template #right>
				<view style="flex-direction:row;align-items:center;">
					<view class="nav-icon-btn" @click="startNewConversation">
						<oui-icon-unix name="plus-circle" size="18px" color="#25242A" />
					</view>
					<view class="nav-icon-btn" @click="goAgentSettings" style="margin-left:4px;">
						<oui-icon-unix name="setting" size="18px" color="#25242A" />
					</view>
					<view class="nav-icon-btn" @click="goHistory" style="margin-left:4px;">
						<oui-icon-unix name="time-circle" size="18px" color="#25242A" />
					</view>
				</view>
			</template>
		</NavBar>

		<!-- 消息列表 -->
		<view class="message-scroll-wrap">
			<scroll-view id="chat-message-scroll" class="message-list" :scroll-y="true" :scroll-with-animation="false" :show-scrollbar="false" :scroll-top="scrollTop" @scroll="onMsgScroll" @touchmove="onMsgTouchMove">
				<view v-for="item in visibleMessageItems" :key="messageViewKey(item.sourceMessage, item.sourceIndex)" :id="messageWindowItemId(item.sourceIndex)" class="message-window-item">
					<view v-if="editingIndex == item.sourceIndex" class="inline-edit-wrap" :class="item.sourceMessage.role == 'user' ? 'inline-edit-user' : 'inline-edit-ai'">
							<textarea class="inline-edit-input" v-model="editBuffer" :adjust-position="false" auto-height />
						<view class="inline-edit-actions">
							<text class="inline-edit-cancel" @click="cancelEdit">取消</text>
							<text class="inline-edit-save" @click="saveEdit">保存</text>
							<text class="inline-edit-send" @click="saveAndSend">发送</text>
						</view>
					</view>
					<ChatBubble v-else
						:role="item.renderMessage.role"
						:content="item.renderMessage.content != null ? item.renderMessage.content : ''"
						:parts="getMessagePartsForView(item.renderMessage)"
						:agentAvatar="currentAgentAvatar"
						:userNickname="userNickname"
						:userDisplayName="item.renderMessage.role == 'user' ? userNickname : ''"
						:userAvatar="userAvatar"
						:toolName="item.renderMessage.toolName != null ? item.renderMessage.toolName : ''"
						:hideThinking="hideThinking"
						:msgSegmentation="msgSegmentation"
						:isError="item.renderMessage.isError == true"
							:isStreaming="item.renderMessage.isStreaming == true"
							:windowAnchorPrefix="messageWindowUnitAnchorPrefix(item.sourceIndex)"
							:cancelToken="longpressCancelToken"
							@contentResize="onMessageContentResize"
							@bubbleLongpress="onMessageLongpress(item.sourceIndex)"
					/>
				</view>
				<view v-if="messages.length == 0" class="empty-state">
					<text class="empty-text">开始对话</text>
					<text class="empty-hint">输入文字或长按语音按钮</text>
				</view>
				<view id="chat-scroll-anchor" class="scroll-anchor"></view>
			</scroll-view>
			<view class="chat-custom-scrollbar" v-if="showCustomScrollbar == true" @touchstart="onScrollbarTrackTap" @touchend="onScrollbarTouchEnd" @touchcancel="onScrollbarTouchEnd">
				<view class="chat-scrollbar-thumb" :style="scrollbarThumbStyle" @touchstart.stop="onScrollbarThumbStart" @touchmove.stop.prevent="onScrollbarThumbMove" />
			</view>
			<view class="back-bottom-btn" v-if="showBackToBottom == true" @click="scrollToBottomFromButton">
				<text class="back-bottom-text">↓ 到底部</text>
			</view>
		</view>

		<!-- 底部区域（输入栏 + 工具栏） -->
		<view id="chat-bottom" class="chat-bottom" :style="{ marginBottom: keyboardInset + 'px' }">
			<!-- 输入栏 -->
			<view class="input-bar">
				<view class="toolbar-toggle" @click="toggleToolPanel">
					<oui-icon-unix name="plus" size="18px" color="#FFFFFF" />
				</view>
				<view class="input-wrap">
					<textarea
						class="text-input"
						v-model="inputText"
						:style="{ height: inputHeight + 'px' }"
						:adjust-position="false"
						placeholder="输入消息..."
						placeholder-style="color:#9CA3AF"
						@linechange="onInputLineChange"
						:disabled="isGenerating == true"
					/>
					<VoiceInput :isListening="isListening ? true : false" @startListening="startVoice" @stopListening="stopVoice" />
				</view>
				<view v-if="isGenerating == false" class="send-chip" @click="sendMessage">
					<text class="send-chip-text">发送</text>
				</view>
				<view v-else class="send-chip send-chip-stop" @click="stopGenerating">
					<text class="send-chip-text">停止</text>
				</view>
			</view>
			<!-- 工具栏面板（输入栏下方展开） -->
			<view v-if="showToolPanel" class="toolbar-panel">
				<view class="toolbar-panel-card">
					<view class="toolbar-panel-handle"></view>
					<view class="toolbar-grid">
						<view class="toolbar-grid-item" @click="pickImage">
							<view class="toolbar-grid-icon"><oui-icon-unix name="image" size="26px" color="var(--rice-primary-color)" /></view>
							<text class="toolbar-grid-label">图片</text>
						</view>
						<view class="toolbar-grid-item" @click="takePhoto">
							<view class="toolbar-grid-icon"><oui-icon-unix name="camera" size="26px" color="var(--rice-primary-color)" /></view>
							<text class="toolbar-grid-label">拍照</text>
						</view>
						<view class="toolbar-grid-item" @click="pickFile">
							<view class="toolbar-grid-icon"><oui-icon-unix name="file" size="26px" color="var(--rice-primary-color)" /></view>
							<text class="toolbar-grid-label">文件</text>
						</view>
						<view class="toolbar-grid-item" @click="pickLocation">
							<view class="toolbar-grid-icon"><oui-icon-unix name="location" size="26px" color="var(--rice-primary-color)" /></view>
							<text class="toolbar-grid-label">位置</text>
						</view>
						<view class="toolbar-grid-item" @click="goMemoryManager">
							<view class="toolbar-grid-icon"><oui-icon-unix name="file-text" size="26px" color="var(--rice-primary-color)" /></view>
							<text class="toolbar-grid-label">记忆</text>
						</view>
						<view class="toolbar-grid-item" @click="organizeMemoryFromToolbar">
							<view class="toolbar-grid-icon"><oui-icon-unix name="robot" size="26px" color="var(--rice-primary-color)" /></view>
							<text class="toolbar-grid-label">整理</text>
						</view>
						<view class="toolbar-grid-item" @click="openContextPreview">
							<view class="toolbar-grid-icon"><oui-icon-unix name="eye" size="26px" color="var(--rice-primary-color)" /></view>
							<text class="toolbar-grid-label">上下文</text>
						</view>
						<view class="toolbar-grid-item" @click="stopTaskFromToolbar">
							<view class="toolbar-grid-icon"><oui-icon-unix name="stop" size="26px" color="#EF4444" /></view>
							<text class="toolbar-grid-label">停止</text>
						</view>
					</view>
				</view>
			</view>
		</view>
	</view>
</template>

<script lang="uts">
	/**
	 * 对话页面 - AI Agent 主聊天界面
	 * 扁平化粉白主题
	 */
	import { readLastLLMRequestSnapshot, organizeAgentMemory } from '@/uni_modules/agent-core/utssdk/llm-client.uts'
	import { getDefaultTaskModel } from '@/uni_modules/agent-core/utssdk/provider.uts'
	import { getAgentById } from '@/utils/agent.uts'
	import { buildChatDatetimePrefix } from '@/utils/datetime-context.uts'
	import {
		loadChatUserProfile,
		loadActiveAgentSnapshot,
		loadInitialConversation,
		getCurrentAgentSystemPrompt,
		recoverInterruptedChatConversation,
		saveChatConversation,
	} from '@/utils/chat-conversation-service.uts'
	import { getMessageContent } from '@/utils/chat-models.uts'
	import {
		deleteChatMessage,
		updateChatMessageContent,
		saveEditAndFindLastUserText,
		truncateFromMessage,
		buildRuntimeMessages as buildRuntimeChatMessages,
	} from '@/utils/chat-message-reducer.uts'
	import { getActiveAgentRuntimeId, getActiveConversationRuntimeId, setActiveAgentRuntimeId, setActiveChatRouteState, setContextPreviewPayload, setMemoryRouteState } from '@/utils/runtime-state.uts'
	import { transcribeAudio, synthesizeSpeech } from '@/utils/speech-service.uts'
	import {
		buildChatVoiceStartGuard,
		clearChatSpeechCachePath,
		createSpeechPlayer,
		destroySpeechPlayer,
		parseRecorderTempPath,
		readChatSpeechCacheState,
		shouldIgnoreSpeechPlayerError,
		writeChatSpeechCachePath,
	} from '@/utils/chat-speech-runtime.uts'
	import {
		appendChatFileMessage,
		appendChatImageMessage,
		appendChatLocationMessage,
		appendChatTextMessage,
		appendChatVoiceMessage,
		buildChatMessageActionContext,
		buildChatLocationContent,
		calcChatInputHeight,
		CHAT_MESSAGE_ACTION_DELETE,
		CHAT_MESSAGE_ACTION_EDIT,
		CHAT_MESSAGE_ACTION_PLAY_SPEECH,
		CHAT_MESSAGE_ACTION_REGENERATE,
		findLastChatAssistantMessage,
		getChatMessagePartsForView,
		hasChatMessageRef,
		hasConfiguredChatDefaultTaskModel,
		isChatAssistantMessage,
		readChatMessageActionAt,
		readChatMessageContentForEdit,
		stringifyChatContextPreview,
	} from '@/utils/chat-page-helpers.uts'
	import {
		buildChatStreamScrollTop,
		CHAT_IDLE_SCROLL_BOTTOM_TOP,
		CHAT_STREAM_SCROLL_DELAY_MS,
		nextChatStreamScrollTick,
	} from '@/utils/chat-stream-events.uts'
	import {
		getChatTurnCompletionRevision,
		getChatTurnErrorMessage,
		getChatTurnErrorRevision,
		getChatTurnLastCompletionSucceeded,
		getChatTurnMemoryNotice,
		getChatTurnMemoryNoticeRevision,
		getChatTurnMessages,
		isChatTurnAvailable,
		isChatTurnRunning,
		isChatTurnSaveFailed,
		releaseChatTurn,
		retainChatTurn,
		reportChatTurnSaveFailure,
		rollbackFailedChatTurnStart,
		saveChatTurn,
		startChatImageTurn,
		startChatTurn,
		stopChatTurn,
		subscribeChatTurn,
		unsubscribeChatTurn,
	} from '@/utils/chat-turn-runtime.uts'
	import {
		buildChatVirtualScrollbarThumbStyle,
		buildChatScrollbarThumbStyle,
		clampChatScrollTarget,
		isChatScrollAtBottom,
		resolveChatVirtualScrollbarCurrentUnit,
		resolveChatVirtualScrollbarDragUnit,
		resolveChatVirtualScrollbarTarget,
		resolveChatVirtualScrollbarTrackUnit,
		resolveChatScrollbarDragTarget,
		resolveChatScrollbarTrackTarget,
	} from '@/utils/chat-scroll-helpers.uts'
	import {
		CHAT_MESSAGE_WINDOW_BASE_UNITS,
		CHAT_MESSAGE_WINDOW_EDGE_THRESHOLD_PX,
		type ChatMessageWindowItem,
		buildChatMessageWindowRangeFromMetrics,
		isChatMessageWindowAtRecentEnd,
		refreshChatMessageWindowMetrics,
		resolveChatMessageWindowAnchor,
		resolveChatMessageWindowUnitEnd,
		resolveRecentChatMessageWindowUnitStart,
		resolveShiftedChatMessageWindowUnitStart,
	} from '@/utils/chat-message-window.uts'
	import { isChooseCancelError, parsePickedImagePath, readPickedFileSelection, readPickedImageSelection } from '@/utils/attachment-reader.uts'
	import { eventBus } from '@/utils/event-bus.uts'
	import { resolveKeyboardInsetFromLayout } from '@/utils/keyboard-inset.uts'
	import { NYX_FLOAT_CONTEXT_CHAT, NYX_FLOAT_VOICE_EVENT, activateNyxFloatVoiceContext, consumePendingNyxFloatVoiceText, deactivateNyxFloatVoiceContext, readNyxFloatVoiceContext } from '@/utils/nyx-float-voice.uts'
	import { APP_ERROR_CATEGORY_RUNTIME, formatAppErrorForUser, reportAppErrorFromCause } from '@/utils/app-error.uts'
	import { handleCameraPickerFailure } from '@/utils/media-permission.uts'

	let chatNyxFloatVoiceCallback: (() => void) | null = null

	function showChatRuntimeStateFailure(operation: string, userMessage: string): void {
		const error = reportAppErrorFromCause(
			'CHAT_RUNTIME_STATE_SAVE_FAILED',
			APP_ERROR_CATEGORY_RUNTIME,
			operation,
			userMessage,
			'跨页运行状态写入 SQLite 失败',
			true,
		)
		uni.showToast({ position: 'bottom', title: formatAppErrorForUser(error), icon: 'none' })
	}

	function showChatNavigationFailure(operation: string, userMessage: string, cause: any | null): void {
		const error = reportAppErrorFromCause('CHAT_NAVIGATION_FAILED', APP_ERROR_CATEGORY_RUNTIME, operation, userMessage, cause, true)
		uni.showToast({ position: 'bottom', title: formatAppErrorForUser(error), icon: 'none' })
	}

	export default {
		data() {
			return {
				/** 消息列表 */
				messages: [] as UTSJSONObject[],
				/** 当前输入文本 */
				inputText: '' as string,
				/** 是否正在语音输入 */
				isListening: false as boolean,
				/** 是否正在把录音转成文字 */
				isTranscribing: false as boolean,
				/** 是否正在把助手回复转成语音 */
				isSynthesizingSpeech: false as boolean,
				/** 录音会话序号，避免旧 onStop 回调重复处理 */
				voiceSessionId: 0 as number,
				/** 当前播放中的 TTS 音频 */
				playingSpeechPath: '' as string,
				/** 主动停止播放时忽略播放器后续错误事件 */
				isStoppingSpeechPlayback: false as boolean,
				/** TTS 播放器实例 */
				speechPlayer: null as InnerAudioContext | null,
				/** AI 是否正在生成回复 */
				isGenerating: false as boolean,
				/** 流式期间滚动节流定时器 */
				streamScrollTimer: -1 as number,
				/** 私聊后台回合订阅 token；页面不直接持有网络流。 */
				chatTurnSubscriptionToken: '' as string,
				boundChatAgentId: '' as string,
				boundChatConversationId: '' as string,
				chatTurnInvalidated: false as boolean,
				chatTurnInvalidationScheduled: false as boolean,
				seenChatTurnErrorRevision: 0 as number,
				seenChatTurnMemoryNoticeRevision: 0 as number,
				seenChatTurnCompletionRevision: 0 as number,
				/** 当前智能体 ID */
				currentAgentId: '' as string,
				/** 当前智能体名称 */
				currentAgentName: '' as string,
				/** 当前智能体头像 */
				currentAgentAvatar: '' as string,
				/** 当前智能体模型 */
				currentAgentModel: '' as string,
				/** 当前智能体系统提示词 */
				currentSystemPrompt: '' as string,
				/** 每轮临时注入到最新用户消息前的对话规则 */
				currentInteractionRules: '' as string,
				/** 用户昵称（用于消息气泡头像） */
				userNickname: '' as string,
				/** 用户头像路径 */
				userAvatar: '' as string,
				/** 是否隐藏思考内容（来自智能体设置） */
				hideThinking: false as boolean,
				/** 是否注入日期时间（来自智能体设置） */
				injectDatetime: true as boolean,
				/** 是否按段落拆分消息气泡 */
				msgSegmentation: true as boolean,
				/** 流式滚动节拍计数器 */
				_streamScrollTick: 0 as number,
				/** 滚动位置 */
				scrollTop: 0 as number,
				/** 当前 UI 渲染的消息窗口范围，完整上下文不受影响 */
				messageWindowStartUnit: 0 as number,
				messageWindowEndUnit: 0 as number,
				messageTotalUnits: 0 as number,
				messageTotalCount: 0 as number,
				messageWindowUnitCounts: [] as number[],
				messageWindowUnitPrefix: [] as number[],
				messageWindowMetricsSegmentation: true as boolean,
				messageWindowMetricsDirtyAll: true as boolean,
				messageWindowShifting: false as boolean,
					messageWindowShiftToken: 0 as number,
					messageWindowShiftLockUntil: 0 as number,
					messagesRevision: 0 as number,
				/** 流式期间是否跟随尾部，只由用户主动上滑取消 */
				streamFollowBottom: true as boolean,
				/** 消息滚动容器高度 */
				scrollViewHeight: 0 as number,
				/** 消息内容总高度 */
				scrollContentHeight: 0 as number,
				/** 当前滚动偏移 */
				scrollOffset: 0 as number,
				/** 是否停在底部，离底部后流式更新不再强拉 */
				isAtBottom: true as boolean,
				/** 自定义滚动条拖动状态 */
				scrollbarDragging: false as boolean,
				scrollbarDragStartY: 0 as number,
				scrollbarDragStartTop: 0 as number,
				scrollbarDragStartGlobalUnit: 0 as number,
				scrollbarTrackTop: 0 as number,
				/** 当前对话唯一 ID */
				conversationId: '' as string,
				/** 是否已存过当前对话（防止重复存） */
				savedFlag: false as boolean,
				/** 输入框 JS 驱动高度 */
				inputHeight: 36 as number,
				/** 是否显示工具栏面板 */
				showToolPanel: false as boolean,
				/** 行内编辑 */
				editingIndex: -1 as number,
				editBuffer: '' as string,
				/** 滚动时通知 ChatBubble 取消长按的 token */
				longpressCancelToken: 0 as number,
				/** 消息长按菜单锁，避免重复弹出 */
				messageActionSheetOpen: false as boolean,
				/** 软键盘高度（>0 表示键盘弹出） */
				keyboardHeight: 0 as number,
				/** 系统未通过 resize 消化的键盘高度，只用于抬升底部输入区 */
				keyboardInset: 0 as number,
				/** 键盘关闭时的页面窗口高度，用于避免 adjustResize 与手动补偿叠加 */
				keyboardBaseWindowHeight: 0 as number,
					/** 软键盘监听 ID，卸载时只移除本页监听 */
					keyboardHeightListenerId: -1 as number,
					measureScrollTimer: -1 as number,
					measureStableTimer: -1 as number,
				/** 页面不可见时仍消费事件，但不再触发 UI 副作用 */
				pageVisible: true as boolean,
				/** 页面隐藏期间保存失败，返回页面后再明确提示。 */
				conversationSaveFailed: false as boolean,
			}
		},
		computed: {
			/** 头部标题 */
			headerTitle(): string {
				return this.currentAgentName != '' ? this.currentAgentName : 'AI 助手'
			},
			visibleMessageItems(): ChatMessageWindowItem[] {
				const revision = this.messagesRevision
				if (revision < 0) { return [] as ChatMessageWindowItem[] }
				return buildChatMessageWindowRangeFromMetrics(this.messages, this.messageWindowUnitCounts, this.messageWindowUnitPrefix, this.messageWindowStartUnit, this.messageWindowEndUnit, this.msgSegmentation)
			},
			scrollbarThumbStyle(): string {
				if (this.messageTotalUnits > CHAT_MESSAGE_WINDOW_BASE_UNITS) {
					return buildChatVirtualScrollbarThumbStyle(this.messageTotalUnits, this.messageWindowStartUnit, this.messageWindowEndUnit, this.scrollContentHeight, this.scrollViewHeight, this.scrollOffset)
				}
				return buildChatScrollbarThumbStyle(this.scrollContentHeight, this.scrollViewHeight, this.scrollOffset)
			},
			showCustomScrollbar(): boolean {
				if (this.scrollViewHeight <= 0) { return false }
				if (this.messageTotalUnits > CHAT_MESSAGE_WINDOW_BASE_UNITS) { return true }
				return this.scrollContentHeight > this.scrollViewHeight + 2
			},
			showBackToBottom(): boolean {
				return this.messageTotalCount > 0 && this.isAtBottom == false
			}
		},
		onLoad() {
			// 加载用户昵称
			this.loadUserNickname()
			// 加载当前智能体信息
			const agentLoaded = this.loadCurrentAgent()
			// 检查是否因历史记录跳转过来的（加载已有对话）
			const conversationLoaded = agentLoaded == true ? this.loadExistingConversation() : false
			// 无指定历史时，自动加载该智能体最近对话
			if (conversationLoaded == true && this.conversationId == '') {
				this.loadRecentConversation()
			}
			// 仍然没有，生成新对话 ID
			if (agentLoaded == true && this.conversationId == '') {
				this.conversationId = '' + Date.now()
			}
			if (agentLoaded == true) {
				this.bindChatTurnRuntime()
			}
			this.resetMessageWindowToRecent()
			try {
				const windowInfo = uni.getWindowInfo()
				this.keyboardBaseWindowHeight = windowInfo.windowHeight
			} catch (error) {
				this.keyboardBaseWindowHeight = 0
			}
			// 监听软键盘高度变化：键盘弹出时自动收起工具栏面板，避免遮挡消息列表
			this.keyboardHeightListenerId = uni.onKeyboardHeightChange((res: OnKeyboardHeightChangeCallbackResult) => {
				const keepBottom = this.isAtBottom
				this.keyboardHeight = res.height
				if (res.height == 0) {
					this.keyboardInset = 0
					try {
						const windowInfo = uni.getWindowInfo()
						if (windowInfo.windowHeight > 0) { this.keyboardBaseWindowHeight = windowInfo.windowHeight }
					} catch (_error: any) {}
				} else {
					this.measureKeyboardInset(res.height)
					setTimeout(() => {
						if (this.pageVisible == true && this.keyboardHeight == res.height) { this.measureKeyboardInset(res.height) }
					}, 120)
				}
				if (res.height > 0 && this.showToolPanel == true) {
					this.showToolPanel = false
				}
				setTimeout(() => {
					if (this.pageVisible == false) { return }
					this.scheduleMeasureMessageScroll()
					if (keepBottom == true) {
						this.scrollToBottom()
					}
				}, 120)
			})
			chatNyxFloatVoiceCallback = () => {
				this.consumeNyxFloatVoiceText()
			}
			const callback = chatNyxFloatVoiceCallback
			if (callback != null) {
				eventBus.on(NYX_FLOAT_VOICE_EVENT, callback)
			}
		},

		onShow() {
			this.pageVisible = true
			if (this.chatTurnInvalidated == true) {
				this.handleChatTurnInvalidated()
				return
			}
			if (this.conversationSaveFailed == true && this.chatTurnSubscriptionToken == '') {
				uni.showToast({ position: 'bottom', title: '对话保存失败，内容仍保留，请重试', icon: 'none' })
				this.conversationSaveFailed = false
			}
			// 每次显示页面时刷新智能体信息和用户昵称
			this.loadUserNickname()
			// 页面栈里可能同时存在多个私聊页；恢复本页绑定的联系人，避免返回后串线保存。
			if (this.currentAgentId != '') {
				if (setActiveAgentRuntimeId(this.currentAgentId) == false) {
					showChatRuntimeStateFailure('chat_restore_active_agent', '当前联系人状态恢复失败')
					return
				}
			}
			this.loadCurrentAgent()
			this.syncChatTurnRuntime(false)
			if (activateNyxFloatVoiceContext(NYX_FLOAT_CONTEXT_CHAT) == false) {
				showChatRuntimeStateFailure('chat_activate_voice_context', '语音入口状态保存失败')
			}
			this.consumeNyxFloatVoiceText()
		},

		onReady() {
			// DOM 就绪后滚动到底部
			this.scheduleMeasureMessageScroll()
			this.scrollToBottom()
		},

		onHide() {
			// 页面只停止 UI 副作用；后台回合由 ChatTurnRuntime 继续持有。
			this.pageVisible = false
			this.cancelMessageWindowShift()
			this.clearStreamScrollTimer()
			if (this.measureScrollTimer != -1) { clearTimeout(this.measureScrollTimer); this.measureScrollTimer = -1 }
			if (this.measureStableTimer != -1) { clearTimeout(this.measureStableTimer); this.measureStableTimer = -1 }
			this.stopSpeechPlayback()
			if (this.saveCurrentConversation() == false) {
				this.conversationSaveFailed = true
			}
			if (deactivateNyxFloatVoiceContext(NYX_FLOAT_CONTEXT_CHAT) == false) {
				reportAppErrorFromCause('CHAT_RUNTIME_STATE_SAVE_FAILED', APP_ERROR_CATEGORY_RUNTIME, 'chat_deactivate_voice_context', '语音入口状态清理失败', '跨页运行状态写入 SQLite 失败', true)
			}
		},

		onUnload() {
			// 页面卸载时移除软键盘高度监听，防止内存泄漏
			this.pageVisible = false
			this.cancelMessageWindowShift()
			this.clearStreamScrollTimer()
			if (this.measureScrollTimer != -1) { clearTimeout(this.measureScrollTimer); this.measureScrollTimer = -1 }
			if (this.measureStableTimer != -1) { clearTimeout(this.measureStableTimer); this.measureStableTimer = -1 }
			this.stopSpeechPlayback()
			this.unbindChatTurnRuntime()
			if (this.keyboardHeightListenerId != -1) {
				uni.offKeyboardHeightChange(this.keyboardHeightListenerId)
				this.keyboardHeightListenerId = -1
			}
			const callback = chatNyxFloatVoiceCallback
			if (callback != null) {
				eventBus.off(NYX_FLOAT_VOICE_EVENT, callback)
			}
			chatNyxFloatVoiceCallback = null
			if (deactivateNyxFloatVoiceContext(NYX_FLOAT_CONTEXT_CHAT) == false) {
				reportAppErrorFromCause('CHAT_RUNTIME_STATE_SAVE_FAILED', APP_ERROR_CATEGORY_RUNTIME, 'chat_unload_voice_context', '语音入口状态清理失败', '跨页运行状态写入 SQLite 失败', true)
			}
		},

		methods: {
			measureKeyboardInset(keyboardHeight: number): void {
				if (keyboardHeight <= 0) { this.keyboardInset = 0; return }
				const appliedInset = this.keyboardInset
				const query = uni.createSelectorQuery().in(this)
				query.select('#chat-bottom').boundingClientRect()
				query.exec((res: any) => {
					if (this.pageVisible == false || this.keyboardHeight != keyboardHeight) { return }
					const rows = res as UTSArray<any> | null
					if (rows == null || rows.length == 0) { this.keyboardInset = keyboardHeight; return }
					const rect = rows[0] as NodeInfo | null
					const bottom = rect != null ? (rect.bottom as number | null) : null
					if (bottom == null || bottom <= 0) { this.keyboardInset = keyboardHeight; return }
					this.keyboardInset = resolveKeyboardInsetFromLayout(keyboardHeight, this.keyboardBaseWindowHeight, bottom + appliedInset)
				})
			},
			/** 加载当前智能体信息 */
			/** 加载用户昵称 */
			hasValidDefaultTaskModel(type: string): boolean {
				return hasConfiguredChatDefaultTaskModel(getDefaultTaskModel(type))
			},

			getMessagePartsForView(msg: UTSJSONObject): UTSJSONObject[] {
				return getChatMessagePartsForView(msg)
			},

			findLastAssistantMessage(): UTSJSONObject | null {
				return findLastChatAssistantMessage(this.messages)
			},

			hasMessageRef(target: UTSJSONObject): boolean {
				return hasChatMessageRef(this.messages, target)
			},

			bindChatTurnRuntime(): void {
				if (this.currentAgentId == '' || this.conversationId == '') { return }
				if (this.chatTurnSubscriptionToken != '') { this.unbindChatTurnRuntime() }
				this.messages = retainChatTurn(this.currentAgentId, this.conversationId, this.messages)
				this.invalidateMessageWindowMetrics()
				this.boundChatAgentId = this.currentAgentId
				this.boundChatConversationId = this.conversationId
				this.chatTurnInvalidated = false
				const running = isChatTurnRunning(this.boundChatAgentId, this.boundChatConversationId)
				let saveFailed = isChatTurnSaveFailed(this.boundChatAgentId, this.boundChatConversationId)
				if (running == false) {
					const recovered = recoverInterruptedChatConversation(
						this.boundChatConversationId,
						this.boundChatAgentId,
						this.getCurrentSystemPrompt(),
						this.messages
					)
					if (recovered == false) {
						this.conversationSaveFailed = true
						reportChatTurnSaveFailure(this.boundChatAgentId, this.boundChatConversationId, '中断状态保存失败，内容仍保留，请重试')
						saveFailed = true
					}
				}
				this.seenChatTurnCompletionRevision = getChatTurnCompletionRevision(this.boundChatAgentId, this.boundChatConversationId)
				this.seenChatTurnErrorRevision = running == true || saveFailed == true ? 0 : getChatTurnErrorRevision(this.boundChatAgentId, this.boundChatConversationId)
				this.seenChatTurnMemoryNoticeRevision = running == true ? 0 : getChatTurnMemoryNoticeRevision(this.boundChatAgentId, this.boundChatConversationId)
				this.chatTurnSubscriptionToken = subscribeChatTurn(this.boundChatAgentId, this.boundChatConversationId, () => {
					this.syncChatTurnRuntime(false)
				})
				this.isGenerating = running
				if (saveFailed == true) { this.conversationSaveFailed = true }
				this.syncChatTurnRuntime(false)
			},

			unbindChatTurnRuntime(): void {
				const token = this.chatTurnSubscriptionToken
				if (token != '') {
					unsubscribeChatTurn(token)
					this.chatTurnSubscriptionToken = ''
				}
				if (this.boundChatAgentId != '' && this.boundChatConversationId != '') {
					releaseChatTurn(this.boundChatAgentId, this.boundChatConversationId)
				}
				this.boundChatAgentId = ''
				this.boundChatConversationId = ''
			},

			scheduleChatTurnInvalidation(): void {
				this.chatTurnInvalidated = true
				this.isGenerating = false
				if (this.chatTurnInvalidationScheduled == true) { return }
				this.chatTurnInvalidationScheduled = true
				setTimeout(() => {
					this.chatTurnInvalidationScheduled = false
					if (this.pageVisible == true && this.chatTurnInvalidated == true) {
						this.handleChatTurnInvalidated()
					}
				}, 0)
			},

			handleChatTurnInvalidated(): void {
				const agentId = this.boundChatAgentId
				this.unbindChatTurnRuntime()
				this.isGenerating = false
				this.messages = [] as UTSJSONObject[]
				this.invalidateMessageWindowMetrics()
				if (agentId == '' || getAgentById(agentId) == null) {
					this.chatTurnInvalidated = false
					uni.showToast({ position: 'bottom', title: '当前联系人已被删除', icon: 'none' })
					uni.reLaunch({ url: '/pages/agents/agents' })
					return
				}
				if (setActiveAgentRuntimeId(agentId) == false) {
					this.chatTurnInvalidated = false
					showChatRuntimeStateFailure('chat_recover_active_agent', '对话恢复状态保存失败')
					uni.reLaunch({ url: '/pages/agents/agents' })
					return
				}
				if (this.loadCurrentAgent() == false) {
					uni.reLaunch({ url: '/pages/agents/agents' })
					return
				}
				const loaded = loadInitialConversation(agentId)
				this.conversationId = loaded.conversationId
				this.messages = loaded.messages
				this.invalidateMessageWindowMetrics()
				this.savedFlag = loaded.saved
				this.conversationSaveFailed = false
				this.chatTurnInvalidated = false
				this.bindChatTurnRuntime()
				this.resetMessageWindowToRecent()
				this.scrollToBottom()
				if (activateNyxFloatVoiceContext(NYX_FLOAT_CONTEXT_CHAT) == false) {
					showChatRuntimeStateFailure('chat_recover_voice_context', '语音入口状态保存失败')
				}
				this.consumeNyxFloatVoiceText()
				uni.showToast({ position: 'bottom', title: '原对话已失效，已切换到可用对话', icon: 'none' })
			},

			syncChatTurnRuntime(initial: boolean): void {
				if (this.boundChatAgentId == '' || this.boundChatConversationId == '') { return }
				if (isChatTurnAvailable(this.boundChatAgentId, this.boundChatConversationId) == false) {
					this.scheduleChatTurnInvalidation()
					return
				}
				const wasGenerating = this.isGenerating
				this.messages = getChatTurnMessages(this.boundChatAgentId, this.boundChatConversationId, this.messages)
				const running = isChatTurnRunning(this.boundChatAgentId, this.boundChatConversationId)
				this.isGenerating = running
				const errorRevision = getChatTurnErrorRevision(this.boundChatAgentId, this.boundChatConversationId)
				if (this.pageVisible == true && errorRevision > this.seenChatTurnErrorRevision) {
					this.seenChatTurnErrorRevision = errorRevision
					const message = getChatTurnErrorMessage(this.boundChatAgentId, this.boundChatConversationId)
					if (message != '') {
						uni.showToast({ position: 'bottom', title: message, icon: 'none' })
					}
				}
				const noticeRevision = getChatTurnMemoryNoticeRevision(this.boundChatAgentId, this.boundChatConversationId)
				if (this.pageVisible == true && noticeRevision > this.seenChatTurnMemoryNoticeRevision) {
					this.seenChatTurnMemoryNoticeRevision = noticeRevision
					const message = getChatTurnMemoryNotice(this.boundChatAgentId, this.boundChatConversationId)
					if (message != '') {
						uni.showToast({ position: 'bottom', title: message, icon: 'none' })
					}
				}
				const completionRevision = getChatTurnCompletionRevision(this.boundChatAgentId, this.boundChatConversationId)
				if (completionRevision > this.seenChatTurnCompletionRevision) {
					this.seenChatTurnCompletionRevision = completionRevision
					const completionSucceeded = getChatTurnLastCompletionSucceeded(this.boundChatAgentId, this.boundChatConversationId)
					if (completionSucceeded == true) {
						this.savedFlag = true
						this.conversationSaveFailed = false
					}
					if (this.pageVisible == true && wasGenerating == true && completionSucceeded == true) {
						this.maybeSynthesizeLatestAssistantSpeech()
					}
				}
				if (this.pageVisible == true && initial == false) {
					this.refreshMessagesView()
					this.scrollToBottomIfPinned()
				}
			},

			loadUserNickname() {
				const profile = loadChatUserProfile()
				this.userNickname = profile.nickname
				this.userAvatar = profile.avatar
			},

			loadCurrentAgent(): boolean {
				try {
					const agent = loadActiveAgentSnapshot()
					this.currentAgentId = agent.id
					this.currentAgentName = agent.name
					this.currentAgentAvatar = agent.avatar
					this.currentAgentModel = agent.model
					this.currentSystemPrompt = agent.systemPrompt
					this.currentInteractionRules = agent.interactionRules
					this.hideThinking = agent.hideThinking
					this.injectDatetime = agent.injectDatetime
					this.msgSegmentation = agent.msgSegmentation
					return true
				} catch (_e: any) {
					uni.showToast({ position: 'bottom', title: '当前智能体加载失败，请重试', icon: 'none' })
					return false
				}
			},

			/** 从历史记录跳转时加载已有对话 */
			loadExistingConversation(): boolean {
				try {
					const loaded = loadInitialConversation(this.currentAgentId)
					this.conversationId = loaded.conversationId
					this.messages = loaded.messages
					this.invalidateMessageWindowMetrics()
					this.savedFlag = loaded.saved
					return true
				} catch (_e: any) {
					uni.showToast({ position: 'bottom', title: '对话加载失败，请重试', icon: 'none' })
					return false
				}
			},

			/** 自动加载当前智能体最近的一条对话 */
			loadRecentConversation() {
				if (this.conversationId != '') { return }
				try {
					const loaded = loadInitialConversation(this.currentAgentId)
					this.conversationId = loaded.conversationId
					this.messages = loaded.messages
					this.invalidateMessageWindowMetrics()
					this.savedFlag = loaded.saved
				} catch (_e: any) {
					uni.showToast({ position: 'bottom', title: '最近对话加载失败，请重试', icon: 'none' })
				}
			},

			/** 根据行数 JS 动态调整输入框高度 */
			onInputLineChange(e: UniTextareaLineChangeEvent) {
				this.inputHeight = calcChatInputHeight(e.detail.lineCount)
				this.scheduleMeasureMessageScroll()
			},

			/** 滚动时通知所有 ChatBubble 取消长按 */
			onMsgScroll(e: UniScrollEvent) {
				this.longpressCancelToken++
				this.scrollOffset = e.detail.scrollTop
				this.updateBottomState()
				if (this.streamFollowBottom == false) {
					this.clearStreamScrollTimer()
				}
				this.maybeShiftMessageWindow()
			},

			updateBottomState(): void {
				const windowAtRecentEnd = isChatMessageWindowAtRecentEnd(this.messageTotalUnits, this.messageWindowEndUnit)
				this.isAtBottom = windowAtRecentEnd == true && isChatScrollAtBottom(this.scrollOffset, this.scrollContentHeight, this.scrollViewHeight)
			},

			scheduleMeasureMessageScroll(): void {
				if (this.measureScrollTimer != -1) { clearTimeout(this.measureScrollTimer); this.measureScrollTimer = -1 }
				this.measureScrollTimer = setTimeout(() => {
					this.measureScrollTimer = -1
					if (this.pageVisible == true) { this.measureMessageScrollSize() }
				}, 60)
				// 高频流式刷新使用 max-wait，避免每次重置后稳定测量永远无法执行。
				if (this.measureStableTimer == -1) {
					this.measureStableTimer = setTimeout(() => {
						this.measureStableTimer = -1
						if (this.pageVisible == true) { this.measureMessageScrollSize() }
					}, 260)
				}
			},

			measureMessageScrollSize(): void {
				const query = uni.createSelectorQuery().in(this)
				query.select('#chat-message-scroll').boundingClientRect()
				query.select('#chat-scroll-anchor').boundingClientRect()
				query.exec((res: any) => {
					const rows = res as UTSArray<any> | null
					if (rows == null || rows.length < 2) { return }
					const viewRect = rows[0] as NodeInfo | null
					const anchorRect = rows[1] as NodeInfo | null
					if (viewRect != null) {
						const viewHeight = viewRect.height as number | null
						if (viewHeight != null && viewHeight > 0) {
							this.scrollViewHeight = viewHeight
						}
						const viewTop = viewRect.top as number | null
						if (viewTop != null) {
							this.scrollbarTrackTop = viewTop
						}
					}
					if (viewRect != null && anchorRect != null) {
						const anchorTop = anchorRect.top as number | null
						const viewTop = viewRect.top as number | null
						const anchorHeight = anchorRect.height as number | null
						if (anchorTop != null && viewTop != null && anchorHeight != null) {
							const nextHeight = anchorTop - viewTop + anchorHeight + this.scrollOffset
							if (nextHeight > 0) {
								this.scrollContentHeight = nextHeight
							}
						}
					}
					this.updateBottomState()
				})
			},

			getScrollbarTouchY(e: UniTouchEvent): number | null {
				if (e.touches.length == 0) { return null }
				if (this.scrollbarTrackTop <= 0) { return null }
				return e.touches[0].pageY - this.scrollbarTrackTop
			},

			commitMessageScrollTop(targetTop: number): void {
				const safeTop = clampChatScrollTarget(targetTop, this.scrollContentHeight, this.scrollViewHeight)
				this.scrollTop = safeTop
				this.scrollOffset = safeTop
				this.updateBottomState()
			},
			commitVirtualScrollbarUnit(globalUnit: number): void {
				const target = resolveChatVirtualScrollbarTarget(globalUnit, this.messageTotalUnits, CHAT_MESSAGE_WINDOW_BASE_UNITS, this.scrollContentHeight, this.scrollViewHeight)
				this.cancelMessageWindowShift()
				this.messageWindowStartUnit = target.windowStartUnit
				this.messageWindowEndUnit = resolveChatMessageWindowUnitEnd(this.messageTotalUnits, target.windowStartUnit)
				this.messageWindowShiftLockUntil = Date.now() + 180
				let localMax = this.scrollContentHeight - this.scrollViewHeight
				if (localMax < 0) { localMax = 0 }
				const targetTop = target.localScrollRatio * localMax
				this.scrollTop = targetTop
				this.scrollOffset = targetTop
				this.updateBottomState()
				this.scheduleMeasureMessageScroll()
				const shiftToken = this.messageWindowShiftToken
				setTimeout(() => {
					if (this.pageVisible == false || shiftToken != this.messageWindowShiftToken) { return }
					this.measureMessageScrollSize()
					setTimeout(() => {
						if (this.pageVisible == false || shiftToken != this.messageWindowShiftToken) { return }
						let measuredMax = this.scrollContentHeight - this.scrollViewHeight
						if (measuredMax < 0) { measuredMax = 0 }
						const measuredTop = target.localScrollRatio * measuredMax
						this.scrollTop = measuredTop
						this.scrollOffset = measuredTop
						this.updateBottomState()
					}, 48)
				}, 48)
			},

			onScrollbarTrackTap(e: UniTouchEvent): void {
				const y = this.getScrollbarTouchY(e)
				if (y == null) { return }
				if (this.isGenerating == true) { this.streamFollowBottom = false }
				this.clearStreamScrollTimer()
				if (this.messageTotalUnits > CHAT_MESSAGE_WINDOW_BASE_UNITS) {
					this.commitVirtualScrollbarUnit(resolveChatVirtualScrollbarTrackUnit(y, this.messageTotalUnits, this.messageWindowStartUnit, this.messageWindowEndUnit, this.scrollContentHeight, this.scrollViewHeight))
					return
				}
				this.commitMessageScrollTop(resolveChatScrollbarTrackTarget(y, this.scrollContentHeight, this.scrollViewHeight))
			},

				onScrollbarThumbStart(e: UniTouchEvent): void {
				const y = this.getScrollbarTouchY(e)
				if (y == null) { return }
				if (this.isGenerating == true) { this.streamFollowBottom = false }
				this.scrollbarDragging = true
				this.scrollbarDragStartY = y
				this.scrollbarDragStartTop = this.scrollOffset
				if (this.messageTotalUnits > CHAT_MESSAGE_WINDOW_BASE_UNITS) {
					this.scrollbarDragStartGlobalUnit = resolveChatVirtualScrollbarCurrentUnit(this.messageTotalUnits, this.messageWindowStartUnit, this.messageWindowEndUnit, this.scrollContentHeight, this.scrollViewHeight, this.scrollOffset)
				}
				this.clearStreamScrollTimer()
			},

				onScrollbarThumbMove(e: UniTouchEvent): void {
				if (this.scrollbarDragging == false) { return }
				const y = this.getScrollbarTouchY(e)
				if (y == null) { return }
				if (this.messageTotalUnits > CHAT_MESSAGE_WINDOW_BASE_UNITS) {
					const targetUnit = resolveChatVirtualScrollbarDragUnit(this.scrollbarDragStartGlobalUnit, y - this.scrollbarDragStartY, this.messageTotalUnits, this.messageWindowStartUnit, this.messageWindowEndUnit, this.scrollContentHeight, this.scrollViewHeight)
					this.commitVirtualScrollbarUnit(targetUnit)
					return
				}
				const target = resolveChatScrollbarDragTarget(this.scrollbarDragStartTop, y - this.scrollbarDragStartY, this.scrollContentHeight, this.scrollViewHeight)
				this.commitMessageScrollTop(target)
			},

			onScrollbarTouchEnd(_e: UniTouchEvent): void {
				this.scrollbarDragging = false
			},

			scrollToBottomFromButton(): void {
				this.scrollToBottom()
			},

			messageViewKey(msg: UTSJSONObject, index: number): string {
				const rawId = msg['id']
				if (rawId != null) {
					const id = '' + rawId
					if (id != '') { return 'id-' + id }
				}
				const timestamp = msg['timestamp'] as number | null
				if (timestamp != null && timestamp > 0) { return 'timestamp-' + timestamp.toString() }
				return 'index-' + index.toString()
			},

			messageWindowItemId(sourceIndex: number): string {
				return 'chat-window-message-' + sourceIndex
			},

			messageWindowUnitAnchorPrefix(sourceIndex: number): string {
				return this.messageWindowItemId(sourceIndex) + '-unit-'
			},

			messageWindowUnitAnchorId(sourceIndex: number, localUnit: number): string {
				return this.messageWindowUnitAnchorPrefix(sourceIndex) + localUnit.toString()
			},

			invalidateMessageWindowMetrics(): void {
				this.messageWindowMetricsDirtyAll = true
			},

			refreshMessagesView(): void {
				const keepRecent = this.isGenerating == true ? this.streamFollowBottom : this.isAtBottom == true
				this.messagesRevision++
				this.syncMessageWindowBounds(keepRecent)
			},

			onMessageContentResize(): void {
				const shouldFollow = this.isGenerating == true ? this.streamFollowBottom : this.isAtBottom == true
				if (shouldFollow == true) {
					this.scrollToBottom()
					return
				}
				this.scheduleMeasureMessageScroll()
			},

			syncMessageWindowBounds(keepRecent: boolean): void {
				const total = this.messages.length
				this.messageTotalCount = total
				const forceFull = this.messageWindowMetricsDirtyAll == true || this.messageWindowMetricsSegmentation != this.msgSegmentation
				const totalUnits = refreshChatMessageWindowMetrics(this.messages, this.messageWindowUnitCounts, this.messageWindowUnitPrefix, this.msgSegmentation, forceFull)
				this.messageWindowMetricsDirtyAll = false
				this.messageWindowMetricsSegmentation = this.msgSegmentation
				this.messageTotalUnits = totalUnits
				let start = this.messageWindowStartUnit
				if (keepRecent == true || this.messageWindowEndUnit <= this.messageWindowStartUnit) {
					start = resolveRecentChatMessageWindowUnitStart(totalUnits)
				} else {
					start = resolveShiftedChatMessageWindowUnitStart(totalUnits, start, 0)
				}
				this.messageWindowStartUnit = start
				this.messageWindowEndUnit = resolveChatMessageWindowUnitEnd(totalUnits, start)
			},

			cancelMessageWindowShift(): void {
				this.messageWindowShiftToken++
				this.messageWindowShifting = false
				this.messageWindowShiftLockUntil = Date.now() + 80
			},

			resetMessageWindowToRecent(): void {
				this.cancelMessageWindowShift()
				this.syncMessageWindowBounds(true)
				this.scheduleMeasureMessageScroll()
			},

			maybeShiftMessageWindow(): void {
				if (this.messageWindowShifting == true || Date.now() < this.messageWindowShiftLockUntil) { return }
				if (this.messageTotalUnits <= CHAT_MESSAGE_WINDOW_BASE_UNITS || this.scrollViewHeight <= 0) { return }
				if (this.scrollOffset <= CHAT_MESSAGE_WINDOW_EDGE_THRESHOLD_PX && this.messageWindowStartUnit > 0) {
					this.shiftMessageWindow(-1)
					return
				}
				const bottomGap = this.scrollContentHeight - this.scrollOffset - this.scrollViewHeight
				if (bottomGap <= CHAT_MESSAGE_WINDOW_EDGE_THRESHOLD_PX && this.messageWindowEndUnit < this.messageTotalUnits) {
					this.shiftMessageWindow(1)
				}
			},

			shiftMessageWindow(direction: number): void {
				const nextStart = resolveShiftedChatMessageWindowUnitStart(this.messageTotalUnits, this.messageWindowStartUnit, direction)
				if (nextStart == this.messageWindowStartUnit) { return }
				const items = this.visibleMessageItems
				if (items.length == 0) { return }
				const anchorUnit = direction < 0 ? this.messageWindowStartUnit : nextStart
				const anchor = resolveChatMessageWindowAnchor(items, anchorUnit)
				if (anchor == null) { return }
				const anchorSelector = '#' + this.messageWindowUnitAnchorId(anchor.sourceIndex, anchor.localUnit)
				const oldScrollOffset = this.scrollOffset
				const oldStart = this.messageWindowStartUnit
				this.messageWindowShifting = true
				this.messageWindowShiftToken++
				const shiftToken = this.messageWindowShiftToken
				const query = uni.createSelectorQuery().in(this)
				query.select(anchorSelector).boundingClientRect()
				query.exec((res: any) => {
					const rows = res as UTSArray<any> | null
					const oldRect = rows != null && rows.length > 0 ? rows[0] as NodeInfo | null : null
					const oldTop = oldRect != null ? oldRect.top as number | null : null
					if (oldTop == null) {
						this.messageWindowShifting = false
						this.messageWindowShiftLockUntil = Date.now() + 80
						return
					}
					this.messageWindowStartUnit = nextStart
					this.messageWindowEndUnit = resolveChatMessageWindowUnitEnd(this.messageTotalUnits, nextStart)
					setTimeout(() => {
						this.finishMessageWindowShift(anchorSelector, oldTop, oldScrollOffset, oldStart, shiftToken, 0)
					}, 32)
				})
			},

			finishMessageWindowShift(anchorSelector: string, oldTop: number, oldScrollOffset: number, oldStart: number, shiftToken: number, attempt: number): void {
				if (shiftToken != this.messageWindowShiftToken) { return }
				const nextQuery = uni.createSelectorQuery().in(this)
				nextQuery.select(anchorSelector).boundingClientRect()
				nextQuery.exec((nextRes: any) => {
					if (shiftToken != this.messageWindowShiftToken) { return }
					const nextRows = nextRes as UTSArray<any> | null
					const nextRect = nextRows != null && nextRows.length > 0 ? nextRows[0] as NodeInfo | null : null
					const nextTop = nextRect != null ? nextRect.top as number | null : null
					if (nextTop == null && attempt < 2) {
						setTimeout(() => {
							this.finishMessageWindowShift(anchorSelector, oldTop, oldScrollOffset, oldStart, shiftToken, attempt + 1)
						}, 32)
						return
					}
					if (nextTop == null) {
						this.messageWindowStartUnit = oldStart
						this.messageWindowEndUnit = resolveChatMessageWindowUnitEnd(this.messageTotalUnits, oldStart)
					} else {
						let targetTop = oldScrollOffset + nextTop - oldTop
						if (targetTop < 0) { targetTop = 0 }
						this.scrollTop = targetTop
						this.scrollOffset = targetTop
					}
					this.messageWindowShifting = false
					this.messageWindowShiftLockUntil = Date.now() + 80
					this.scheduleMeasureMessageScroll()
				})
			},

			sendUserPlainText(content: string): void {
				const text = content.trim()
				if (text == '' || this.isGenerating == true) {
					return
				}
				const messageStartIndex = this.messages.length
				const previousSavedFlag = this.savedFlag
				// 发新消息时允许保存（从历史加载后 savedFlag 为 true 会阻止保存）
				this.savedFlag = false
				this.addTextMessage('user', text)
				this.resetMessageWindowToRecent()
				this.scrollToBottom()
				const started = this.simulateAIResponse(text)
				if (started == false && this.rollbackFailedOutgoingMessages(messageStartIndex, previousSavedFlag) == true) {
					this.inputText = text
					return
				}
				this.inputText = ''
			},

			sendMessage() {
				this.sendUserPlainText(this.inputText)
			},

			/** 构建日期时间注入前缀（含农历、节气、节日） */
			buildDatetimePrefix(): string {
				return buildChatDatetimePrefix()
			},

			/** 构建运行时消息副本：日期时间和对话规则只临时注入给 Agent，不写入消息列表/数据库/UI。 */
			buildRuntimeMessages(): UTSJSONObject[] {
				return buildRuntimeChatMessages(this.messages, {
					injectDatetime: this.injectDatetime,
					datetimePrefix: this.buildDatetimePrefix(),
					interactionRules: this.currentInteractionRules,
				})
			},

			/** 长按消息弹出操作菜单 */
			onMessageLongpress(index: number) {
				if (this.isGenerating == true) { return }
				if (this.messageActionSheetOpen == true) { return }
				const msg = this.messages[index]
				const actionContext = buildChatMessageActionContext(msg, this.hasValidDefaultTaskModel('tts'))
				if (actionContext.ok == false) { return }
				const actions = actionContext.actions
				const msgIndex = index
				this.messageActionSheetOpen = true
				uni.showActionSheet({
					itemList: actions,
					success: (res) => {
						const action = readChatMessageActionAt(actions, res.tapIndex)
						if (action == CHAT_MESSAGE_ACTION_DELETE) {
							this.deleteMessage(msgIndex)
						} else if (action == CHAT_MESSAGE_ACTION_EDIT) {
							this.editMessage(msgIndex)
						} else if (action == CHAT_MESSAGE_ACTION_PLAY_SPEECH) {
							this.playAssistantSpeech(msgIndex)
						} else if (action == CHAT_MESSAGE_ACTION_REGENERATE) {
							this.regenerateResponse(msgIndex)
						}
					},
					fail: (_err) => {
					},
					complete: () => {
						this.messageActionSheetOpen = false
					}
				})
			},

			/** 删除指定消息 */
			deleteMessage(index: number) {
				const keepRecent = this.isAtBottom == true
				deleteChatMessage(this.messages, index)
				this.invalidateMessageWindowMetrics()
				this.savedFlag = false
				this.syncMessageWindowBounds(keepRecent)
				this.scheduleMeasureMessageScroll()
			},

			/** 原地编辑消息 */
			editMessage(index: number) {
				const msg = this.messages[index]
				if (msg == null) { return }
				this.editBuffer = readChatMessageContentForEdit(msg)
				this.editingIndex = index
			},

			/** 保存行内编辑 */
			saveEdit() {
				const idx = this.editingIndex
				updateChatMessageContent(this.messages, idx, this.editBuffer)
				this.invalidateMessageWindowMetrics()
				this.cancelEdit()
				this.savedFlag = false
				this.syncMessageWindowBounds(this.isAtBottom == true)
				this.scheduleMeasureMessageScroll()
			},

			/** 保存并发送：更新内容后从该消息截断并重新触发 AI */
			saveAndSend() {
				const idx = this.editingIndex
				if (idx < 0 || idx >= this.messages.length) { return }
				const lastUserText = saveEditAndFindLastUserText(this.messages, idx, this.editBuffer)
				this.invalidateMessageWindowMetrics()
				this.editingIndex = -1
				this.editBuffer = ''
				this.savedFlag = false
				if (lastUserText != '') {
					this.streamFollowBottom = true
					this.resetMessageWindowToRecent()
					this.scrollToBottom()
					this.simulateAIResponse(lastUserText)
				}
			},

			/** 取消行内编辑 */
			cancelEdit() {
				this.editingIndex = -1
				this.editBuffer = ''
			},

			/** 重新生成 AI 回答：删除该 AI 消息，重新触发 AI */
			regenerateResponse(index: number) {
				const lastUserText = truncateFromMessage(this.messages, index)
				this.invalidateMessageWindowMetrics()
				this.savedFlag = false
				if (lastUserText != '') {
					this.streamFollowBottom = true
					this.resetMessageWindowToRecent()
					this.scrollToBottom()
					this.simulateAIResponse(lastUserText)
				}
			},

			startGenerationForMedia(prompt: string): boolean {
				if (this.isGenerating == true) {
					return false
				}
				this.savedFlag = false
				return this.simulateAIResponse(prompt)
			},

			rollbackFailedOutgoingMessages(messageStartIndex: number, previousSavedFlag: boolean): boolean {
				let rolledBack = rollbackFailedChatTurnStart(this.boundChatAgentId, this.boundChatConversationId, messageStartIndex)
				if (rolledBack == false && (isChatTurnRunning(this.boundChatAgentId, this.boundChatConversationId) == true || isChatTurnAvailable(this.boundChatAgentId, this.boundChatConversationId) == false)) {
					if (messageStartIndex >= 0 && messageStartIndex <= this.messages.length && this.messages.length > messageStartIndex) {
						this.messages.splice(messageStartIndex, this.messages.length - messageStartIndex)
					}
					rolledBack = true
				}
				if (rolledBack == false) { return false }
				this.savedFlag = previousSavedFlag
				this.invalidateMessageWindowMetrics()
				this.syncMessageWindowBounds(this.isAtBottom == true)
				this.scheduleMeasureMessageScroll()
				return true
			},

			/** 添加文本消息 */
			addTextMessage(role: string, content: string) {
				appendChatTextMessage(this.messages, role, content)
			},

			/** 添加图片消息，返回消息下标用于后续写入转述 */
			addImageMessage(imagePath: string): number {
				const index = appendChatImageMessage(this.messages, imagePath)
				if (index < 0) { return -1 }
				this.resetMessageWindowToRecent()
				this.scrollToBottom()
				return index
			},

			handlePickedImagePath(imagePath: string, fallbackPrompt: string): void {
				if (this.canAppendMediaMessage() == false) { return }
				if (imagePath == '') {
					uni.showToast({ position: 'bottom', title: '未选择图片', icon: 'none' })
					return
				}
				const previousSavedFlag = this.savedFlag
				const msgIndex = this.addImageMessage(imagePath)
				const started = this.startGenerationForImage(imagePath, fallbackPrompt, msgIndex)
				if (started == false) {
					this.rollbackFailedOutgoingMessages(msgIndex, previousSavedFlag)
				}
			},

			/** 参考 AstrBot：先用默认图片转述模型生成 caption，再把 caption 注入普通对话上下文。 */
			startGenerationForImage(imagePath: string, _fallbackPrompt: string, messageIndex: number): boolean {
				if (this.isGenerating == true) {
					return false
				}
				this.savedFlag = false
				this.streamFollowBottom = this.isAtBottom == true
				this._streamScrollTick = 0
				const started = startChatImageTurn(
					this.boundChatAgentId,
					this.boundChatConversationId,
					this.messages,
					imagePath,
					messageIndex,
					this.getCurrentSystemPrompt(),
					this.currentAgentModel,
					this.msgSegmentation,
					this.injectDatetime,
					this.buildDatetimePrefix(),
					this.currentInteractionRules
				)
				this.isGenerating = started
				this.syncChatTurnRuntime(false)
				return started
			},

			/** 添加文件消息 */
			addFileMessage(fileInfo: any) {
				if (this.canAppendMediaMessage() == false) { return }
				const picked = readPickedFileSelection(fileInfo)
				if (picked.ok == false) {
					uni.showToast({ position: 'bottom', title: picked.error, icon: 'none' })
					return
				}
				if (picked.isImage == true) {
					this.handlePickedImagePath(picked.file.path, '用户通过文件发送了一张图片')
					return
				}
				const messageStartIndex = this.messages.length
				const previousSavedFlag = this.savedFlag
				appendChatFileMessage(this.messages, picked.file.name, picked.file.path, picked.contextText)
				this.resetMessageWindowToRecent()
				this.scrollToBottom()
				if (this.startGenerationForMedia('用户发送了一个文件：' + picked.file.name) == false) {
					this.rollbackFailedOutgoingMessages(messageStartIndex, previousSavedFlag)
				}
			},

			/** 添加位置消息 */
			addLocationMessage(location: UTSJSONObject) {
				if (this.canAppendMediaMessage() == false) { return }
				const content = buildChatLocationContent(location)
				const messageStartIndex = this.messages.length
				const previousSavedFlag = this.savedFlag
				appendChatLocationMessage(this.messages, content)
				this.resetMessageWindowToRecent()
				this.scrollToBottom()
				if (this.startGenerationForMedia(content) == false) {
					this.rollbackFailedOutgoingMessages(messageStartIndex, previousSavedFlag)
				}
			},

			/** 添加语音消息 */
			addVoiceMessage(tempPath: string) {
				if (appendChatVoiceMessage(this.messages, tempPath) == false) { return }
				this.resetMessageWindowToRecent()
				this.scrollToBottom()
				this.savedFlag = false
				this.saveCurrentConversation()
			},

			/** 发送语音识别后的纯文本：Record -> Plain，不把录音路径喂给 Agent。 */
			sendTranscribedVoiceMessage(text: string) {
				this.sendUserPlainText(text)
			},

			consumeNyxFloatVoiceText(): void {
				if (readNyxFloatVoiceContext() != NYX_FLOAT_CONTEXT_CHAT) { return }
				const content = consumePendingNyxFloatVoiceText()
				if (content == '') { return }
				if (this.isGenerating == true || this.isTranscribing == true) {
					this.inputText = content
					uni.showToast({ position: 'bottom', title: '已填入输入框，等当前回复结束再发', icon: 'none' })
					return
				}
				this.sendTranscribedVoiceMessage(content)
			},

			// ===== 工具栏 =====

			canAppendMediaMessage(): boolean {
				if (this.isGenerating == false) { return true }
				uni.showToast({ position: 'bottom', title: '当前回复进行中，请稍后发送', icon: 'none' })
				return false
			},

			/** 切换工具栏面板：只有原本贴底时才保持到底，避免中途阅读被强拉 */
			toggleToolPanel() {
				const keepBottom = this.isAtBottom == true
				this.showToolPanel = !this.showToolPanel
				if (this.showToolPanel == true) {
					this.measureMessageScrollSize()
				}
				if (keepBottom == true) {
					this.scrollToBottom()
				} else {
					this.scheduleMeasureMessageScroll()
				}
			},

			/** 滚动时通知 ChatBubble 取消长按 */
			onMsgTouchMove() {
				this.longpressCancelToken++
				if (this.isGenerating == true) {
					this.streamFollowBottom = false
					this.clearStreamScrollTimer()
				}
			},

			/** 从相册选择图片 */
			pickImage() {
				this.showToolPanel = false
				if (this.canAppendMediaMessage() == false) { return }
				uni.chooseImage({
					count: 1,
					sourceType: ['album'],
					sizeType: ['compressed'],
					success: (res: any) => {
						const imagePath = parsePickedImagePath(res)
						this.handlePickedImagePath(imagePath, '用户发送了一张图片')
					},
					fail: (err: any) => {
						if (isChooseCancelError(err) == true) { return }
						console.log('[Chat] chooseImage 相册失败，尝试 chooseMedia: ' + JSON.stringify(err))
						this.pickImageFromMediaFallback('用户发送了一张图片')
					}
				})
			},

			/** 拍照 */
			takePhoto() {
				this.showToolPanel = false
				if (this.canAppendMediaMessage() == false) { return }
				uni.chooseImage({
					count: 1,
					sourceType: ['camera'],
					sizeType: ['compressed'],
					success: (res: any) => {
						const imagePath = parsePickedImagePath(res)
						this.handlePickedImagePath(imagePath, '用户拍摄了一张照片')
					},
					fail: (err: any) => {
						if (isChooseCancelError(err) == true) { return }
						handleCameraPickerFailure(err, 'chat_camera_picker')
					}
				})
			},

			/** 选择文件 */
			pickFile() {
				this.showToolPanel = false
				if (this.canAppendMediaMessage() == false) { return }
				uni.chooseFile({
					count: 1,
					success: (res: any) => {
						this.addFileMessage(res)
					},
					fail: (err: any) => {
						if (isChooseCancelError(err) == true) { return }
						reportAppErrorFromCause('CHAT_FILE_PICK_FAILED', APP_ERROR_CATEGORY_RUNTIME, 'chat_file_picker', '选择文件失败', err, true)
						uni.showToast({ position: 'bottom', title: '选择文件失败', icon: 'none' })
					}
				})
			},

			pickImageFromMediaFallback(fallbackPrompt: string): void {
				uni.chooseMedia({
					count: 1,
					sourceType: ['album'],
					success: (res: any) => {
						const picked = readPickedImageSelection(res)
						if (picked.ok == false) {
							uni.showToast({ position: 'bottom', title: picked.error, icon: 'none' })
							return
						}
						this.handlePickedImagePath(picked.path, fallbackPrompt)
					},
					fail: (err: any) => {
						if (isChooseCancelError(err) == true) { return }
						console.log('[Chat] chooseMedia 相册失败，切换文件选图: ' + JSON.stringify(err))
						reportAppErrorFromCause('CHAT_ALBUM_PICK_FALLBACK', APP_ERROR_CATEGORY_RUNTIME, 'chat_album_picker', '相册媒体选择失败，已改用文件选择', err, true)
						uni.showToast({ position: 'bottom', title: '相册打开失败，请从文件选择图片', icon: 'none' })
						this.pickImageFromFileFallback(fallbackPrompt)
					}
				})
			},

			pickImageFromFileFallback(fallbackPrompt: string): void {
				uni.chooseFile({
					count: 1,
					success: (res: any) => {
						const picked = readPickedImageSelection(res)
						if (picked.ok == false) {
							uni.showToast({ position: 'bottom', title: picked.error, icon: 'none' })
							return
						}
						this.handlePickedImagePath(picked.path, fallbackPrompt)
					},
					fail: (err: any) => {
						if (isChooseCancelError(err) == true) { return }
						reportAppErrorFromCause('CHAT_IMAGE_PICK_FAILED', APP_ERROR_CATEGORY_RUNTIME, 'chat_image_file_picker', '选择图片失败', err, true)
						uni.showToast({ position: 'bottom', title: '选择图片失败', icon: 'none' })
					}
				})
			},

			/** 选择位置 */
			pickLocation() {
				this.showToolPanel = false
				if (this.canAppendMediaMessage() == false) { return }
				uni.chooseLocation({
					success: (res: any) => {
						const raw = JSON.stringify(res)
						if (raw == null || raw == '') { return }
						const parsed = JSON.parse(raw) as UTSJSONObject
						this.addLocationMessage(parsed)
					},
					fail: (err: any) => {
						if (isChooseCancelError(err) == true) { return }
						reportAppErrorFromCause('CHAT_LOCATION_PICK_FAILED', APP_ERROR_CATEGORY_RUNTIME, 'chat_pick_location', '位置选择失败', err, true)
						uni.showToast({ position: 'bottom', title: '位置选择失败，请检查定位权限', icon: 'none' })
					}
				})
			},

			/** 手动触发记忆管理 Agent 整理当前对话。 */
			organizeMemoryFromToolbar() {
				this.showToolPanel = false
				if (this.isGenerating == true) {
					uni.showToast({ position: 'bottom',
						title: '当前任务进行中',
						icon: 'none'
					})
					return
				}
				if (this.messages.length == 0) {
					uni.showToast({ position: 'bottom',
						title: '暂无可整理内容',
						icon: 'none'
					})
					return
				}
				const started = organizeAgentMemory(
					this.messages,
					'',
					this.currentAgentModel,
					this.currentAgentId,
					this.conversationId
				)
				uni.showToast({ position: 'bottom',
					title: started == true ? '记忆整理已开始' : '暂无可整理内容',
					icon: 'none'
				})
			},

			/** 工具栏终止当前任务。 */
			stopTaskFromToolbar() {
				this.showToolPanel = false
				if (this.isGenerating == true) {
					this.stopGenerating()
					uni.showToast({ position: 'bottom',
						title: '已终止',
						icon: 'none'
					})
					return
				}
				uni.showToast({ position: 'bottom',
					title: '当前没有运行中的任务',
					icon: 'none'
				})
			},

			// ===== 语音输入 =====

			startVoice() {
				const guard = buildChatVoiceStartGuard(this.isGenerating, this.isTranscribing, this.isListening, this.hasValidDefaultTaskModel('stt'))
				if (guard.ok == false) {
					if (guard.message != '') {
						uni.showToast({ position: 'bottom',  title: guard.message, icon: 'none' })
					}
					return
				}
				this.isListening = true
				this.voiceSessionId++
				const sessionId = this.voiceSessionId
				const recorder = uni.getRecorderManager()
				recorder.onStop((res: any): void => {
					if (sessionId != this.voiceSessionId) { return }
					this.isListening = false
					const tempPath = parseRecorderTempPath(res)
					if (tempPath != '') {
						this.handleVoiceRecordStopped(tempPath)
					}
				})
				recorder.onError((err: any): void => {
					if (sessionId != this.voiceSessionId) { return }
					this.isListening = false
					console.log('[Speech] 录音失败: ' + err)
					uni.showToast({ position: 'bottom',  title: '录音失败', icon: 'none' })
				})
				const startOpts: RecorderManagerStartOptions = {
					// PROVIDER_AUDIO_API: OpenAI-compatible STT 优先 wav；部分平台录音格式支持不同，后续统一抽 provider 能力。
					format: 'wav',
				}
				recorder.start(startOpts)
			},

			stopVoice() {
				if (this.isListening == false) { return }
				const recorder = uni.getRecorderManager()
				recorder.stop()
			},

			handleVoiceRecordStopped(tempPath: string) {
				if (tempPath == '') { return }
				if (this.isGenerating == true) {
					uni.showToast({ position: 'bottom',  title: '请等待当前回复完成', icon: 'none' })
					return
				}
				this.isTranscribing = true
				uni.showLoading({ title: '识别中...' })
				transcribeAudio(tempPath).then((result) => {
					this.isTranscribing = false
					uni.hideLoading()
					if (result.ok == true) {
						this.sendTranscribedVoiceMessage(result.text)
						return
					}
					uni.showToast({ position: 'bottom',  title: result.error, icon: 'none' })
				})
			},

			stopSpeechPlayback(): void {
				const player = this.speechPlayer
				if (player != null) {
					this.isStoppingSpeechPlayback = true
					this.speechPlayer = null
					this.playingSpeechPath = ''
					destroySpeechPlayer(player)
					return
				}
				this.playingSpeechPath = ''
			},

			playSpeechPath(path: string): void {
				if (path == '') {
					uni.showToast({ position: 'bottom',  title: '语音路径为空', icon: 'none' })
					return
				}
				if (this.playingSpeechPath == path) {
					this.stopSpeechPlayback()
					return
				}
				this.stopSpeechPlayback()
				// PROVIDER_AUDIO_API: TTS 当前落本地临时音频文件，播放时绝对路径要转 file://。
				this.isStoppingSpeechPlayback = false
				const audio = createSpeechPlayer(path)
				if (audio == null) {
					uni.showToast({ position: 'bottom',  title: '语音路径为空', icon: 'none' })
					return
				}
				this.speechPlayer = audio
				this.playingSpeechPath = path
				audio.onEnded(() => {
					this.stopSpeechPlayback()
				})
				audio.onError((err: any) => {
					if (shouldIgnoreSpeechPlayerError(this.isStoppingSpeechPlayback, this.speechPlayer, audio, this.playingSpeechPath, path) == true) {
						return
					}
					console.log('[Speech] 播放失败: ' + err)
					this.stopSpeechPlayback()
					uni.showToast({ position: 'bottom',  title: '语音播放失败', icon: 'none' })
				})
				audio.play()
			},

			playCachedAssistantSpeech(msg: UTSJSONObject): boolean {
				const cache = readChatSpeechCacheState(msg)
				if (cache.path == '') { return false }
				if (cache.playable == true) {
					this.playSpeechPath(cache.path)
					return true
				}
				if (cache.stale == true) {
					clearChatSpeechCachePath(msg)
					this.savedFlag = false
					this.saveCurrentConversation()
				}
				return false
			},

			synthesizeAssistantSpeech(msg: UTSJSONObject, autoPlay: boolean): void {
				if (this.isSynthesizingSpeech == true) {
					if (autoPlay == false) {
						uni.showToast({ position: 'bottom',  title: '语音合成中', icon: 'none' })
					}
					return
				}
				const text = getMessageContent(msg).trim()
				if (text == '') { return }
				const conversationId = this.conversationId
				const agentId = this.currentAgentId
				this.isSynthesizingSpeech = true
				synthesizeSpeech(text, agentId).then((result) => {
					this.isSynthesizingSpeech = false
					if (this.conversationId != conversationId) { return }
					if (this.hasMessageRef(msg) == false) { return }
					if (result.ok == true) {
						writeChatSpeechCachePath(msg, result.path)
						this.savedFlag = false
						this.saveCurrentConversation()
						if (autoPlay == true) {
							this.playSpeechPath(result.path)
						}
						return
					}
					console.log('[Speech] 语音合成失败: ' + result.error)
					uni.showToast({ position: 'bottom',  title: result.error, icon: 'none' })
				})
			},

			playAssistantSpeech(index: number): void {
				if (index < 0 || index >= this.messages.length) { return }
				const msg = this.messages[index]
				if (msg == null) { return }
				if (isChatAssistantMessage(msg) == false) { return }
				if (this.playCachedAssistantSpeech(msg) == true) { return }
				uni.showToast({ position: 'bottom',  title: '语音生成中', icon: 'none' })
				this.synthesizeAssistantSpeech(msg, true)
			},

			maybeSynthesizeLatestAssistantSpeech(): void {
				if (this.hasValidDefaultTaskModel('tts') == false) { return }
				const msg = this.findLastAssistantMessage()
				if (msg == null) { return }
				if (this.playCachedAssistantSpeech(msg) == true) { return }
				this.synthesizeAssistantSpeech(msg, true)
			},

			clearStreamScrollTimer() {
				if (this.streamScrollTimer != -1) {
					clearTimeout(this.streamScrollTimer)
					this.streamScrollTimer = -1
				}
			},

			/** 停止当前 AI 生成 */
			stopGenerating() {
				stopChatTurn(this.boundChatAgentId, this.boundChatConversationId)
				this.syncChatTurnRuntime(false)
				this.clearStreamScrollTimer()
			},

			goAgentSettings() {
				let previousAgentId = ''
				let previousConversationId = ''
				try {
					previousAgentId = getActiveAgentRuntimeId()
					previousConversationId = getActiveConversationRuntimeId()
				} catch (e: any) {
					showChatNavigationFailure('chat_agent_settings_state_read', '无法准备联系人设置', e)
					return
				}
				if (setActiveChatRouteState(this.currentAgentId, previousConversationId) == false) {
					showChatRuntimeStateFailure('chat_open_agent_settings', '无法打开联系人设置')
					return
				}
				uni.navigateTo({
					url: '/pages/agent-settings/agent-settings',
					fail: (err: any) => {
						if (setActiveChatRouteState(previousAgentId, previousConversationId) == false) {
							showChatRuntimeStateFailure('chat_agent_settings_state_rollback', '联系人设置路由状态恢复失败')
						}
						showChatNavigationFailure('chat_navigate_agent_settings', '无法打开联系人设置', err)
					}
				})
			},

			goHistory() {
				let previousAgentId = ''
				let previousConversationId = ''
				try {
					previousAgentId = getActiveAgentRuntimeId()
					previousConversationId = getActiveConversationRuntimeId()
				} catch (e: any) {
					showChatNavigationFailure('chat_history_state_read', '无法准备历史记录', e)
					return
				}
				if (setActiveChatRouteState(this.currentAgentId, previousConversationId) == false) {
					showChatRuntimeStateFailure('chat_open_history', '无法打开历史记录')
					return
				}
				uni.navigateTo({
					url: '/pages/history/history',
					fail: (err: any) => {
						if (setActiveChatRouteState(previousAgentId, previousConversationId) == false) {
							showChatRuntimeStateFailure('chat_history_state_rollback', '历史记录路由状态恢复失败')
						}
						showChatNavigationFailure('chat_navigate_history', '无法打开历史记录', err)
					}
				})
			},

			goMemoryManager() {
				this.showToolPanel = false
				if (setMemoryRouteState(this.currentAgentId, this.conversationId) == false) {
					showChatRuntimeStateFailure('chat_open_memory', '无法打开记忆管理')
					return
				}
				uni.navigateTo({
					url: '/pages/memory/memory',
					fail: (err: any) => {
						if (setMemoryRouteState('', '') == false) {
							showChatRuntimeStateFailure('chat_memory_navigation_rollback', '记忆管理路由状态清理失败')
						}
						showChatNavigationFailure('chat_navigate_memory', '无法打开记忆管理', err)
					}
				})
			},

			openContextPreview() {
				this.showToolPanel = false
				const preview = readLastLLMRequestSnapshot(this.currentAgentId, this.conversationId)
				if (preview == null) {
					uni.showToast({ position: 'bottom', title: '还没有真实请求快照', icon: 'none' })
					return
				}
				if (setContextPreviewPayload(stringifyChatContextPreview(preview)) == false) {
					showChatRuntimeStateFailure('chat_open_context_preview', '无法打开上下文预览')
					return
				}
				uni.navigateTo({
					url: '/pages/context-preview/context-preview',
					fail: (err: any) => {
						if (setContextPreviewPayload('') == false) {
							showChatRuntimeStateFailure('chat_context_navigation_rollback', '上下文预览路由状态清理失败')
						}
						showChatNavigationFailure('chat_navigate_context_preview', '无法打开上下文预览', err)
					}
				})
			},

			goBack() {
				uni.navigateBack()
			},

			/** 开启新对话 */
			startNewConversation() {
				if (this.isGenerating == true) {
					uni.showToast({ position: 'bottom',  title: '请等待当前回复完成', icon: 'none' })
					return
				}
				// 先保存当前对话
				if (this.saveCurrentConversation() == false) {
					uni.showToast({ position: 'bottom', title: '保存失败，请重试', icon: 'none' })
					return
				}
				this.unbindChatTurnRuntime()
				// 清空消息
				this.messages = [] as UTSJSONObject[]
				this.invalidateMessageWindowMetrics()
				// 新对话 ID
				this.conversationId = '' + Date.now()
				this.savedFlag = false
				// 重置输入
				this.inputText = ''
				this.showToolPanel = false
				this.scrollOffset = 0
				this.scrollContentHeight = 0
				this.isAtBottom = true
				this.bindChatTurnRuntime()
				this.resetMessageWindowToRecent()
			},

			saveCurrentConversation(force: boolean = false): boolean {
				if (this.messages.length == 0 || (this.savedFlag == true && force == false)) {
					return true
				}
				const saved = this.chatTurnSubscriptionToken != ''
					? saveChatTurn(this.boundChatAgentId, this.boundChatConversationId, this.getCurrentSystemPrompt(), this.messages)
					: saveChatConversation(this.conversationId, this.currentAgentId, this.getCurrentSystemPrompt(), this.messages)
				this.savedFlag = saved
				this.conversationSaveFailed = saved == false
				return saved
			},

			performStreamScrollToBottom() {
				this.syncMessageWindowBounds(true)
				this._streamScrollTick = nextChatStreamScrollTick(this._streamScrollTick)
				this.scrollTop = buildChatStreamScrollTop(this._streamScrollTick)
				this.isAtBottom = true
				this.scheduleMeasureMessageScroll()
			},

			scheduleStreamScroll() {
				if (this.streamFollowBottom == false) { return }
				if (this.streamScrollTimer != -1) { return }
				const self = this
				this.streamScrollTimer = setTimeout(() => {
					self.streamScrollTimer = -1
					if (self.streamFollowBottom == false) { return }
					if (self.isGenerating == true) {
						self.performStreamScrollToBottom()
					} else {
						self.scrollToBottom()
					}
				}, CHAT_STREAM_SCROLL_DELAY_MS)
			},

				scrollToBottom() {
					this.streamFollowBottom = true
					this.resetMessageWindowToRecent()
					this.isAtBottom = true
					this.messageWindowShiftLockUntil = Date.now() + 240
					// 真机流式阶段 scroll-view 高频 scrollTop 会抖；生成中只按帧节流滚动。
				if (this.isGenerating == true) {
					this.scheduleStreamScroll()
					return
				}
				this.clearStreamScrollTimer()
				this.scrollTop = 0
				const self = this
				setTimeout(() => {
					self.scrollTop = CHAT_IDLE_SCROLL_BOTTOM_TOP
					self.isAtBottom = true
					self.scheduleMeasureMessageScroll()
				}, 50)
			},

			scrollToBottomIfPinned(): void {
				this.scheduleMeasureMessageScroll()
				const shouldFollow = this.isGenerating == true ? this.streamFollowBottom : this.isAtBottom == true
				if (shouldFollow == true) {
					this.scrollToBottom()
				}
			},

			/** 获取当前智能体的系统提示词 */
			getCurrentSystemPrompt(): string {
				if (this.currentSystemPrompt != '') {
					return this.currentSystemPrompt
				}
				return getCurrentAgentSystemPrompt(this.currentAgentId)
			},

			simulateAIResponse(_userText: string): boolean {
				this.streamFollowBottom = this.isAtBottom == true
				this._streamScrollTick = 0
				const runtimeMessages = this.buildRuntimeMessages()
				const started = startChatTurn(
					this.boundChatAgentId,
					this.boundChatConversationId,
					this.messages,
					runtimeMessages,
					this.getCurrentSystemPrompt(),
					this.currentAgentModel,
					this.msgSegmentation
				)
				this.isGenerating = started == true
				this.syncChatTurnRuntime(false)
				return started
			}

		}
	};
</script>

<style>
	.page-shell {
		background-color: #FAF7F5;
	}

	/* 页面内容区域 */
	.chat-page {
