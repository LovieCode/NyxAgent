<template>
	<view class="page-shell rice-theme-light" ref="shellRef">
		<NavBar :title="headerTitle" showBack :showNyxFloat="false" @back="goBack">
			<template #right>
				<view style="flex-direction:row;align-items:center;">
					<view class="nav-icon-btn" @click="startNewConversation">
						<oui-icon-unix name="plus-circle" size="20px" color="#FFFFFF" />
					</view>
					<view class="nav-icon-btn" @click="goAgentSettings" style="margin-left:4px;">
						<oui-icon-unix name="setting" size="20px" color="#FFFFFF" />
					</view>
					<view class="nav-icon-btn" @click="goHistory" style="margin-left:4px;">
						<oui-icon-unix name="time-circle" size="22px" color="#FFFFFF" />
					</view>
				</view>
			</template>
		</NavBar>

		<!-- 消息列表 -->
		<scroll-view class="message-list" :scroll-y="true" :scroll-top="scrollTop" @scroll="onMsgScroll" @touchmove="onMsgTouchMove">
			<view v-for="(msg, index) in messages" :key="index">
				<view v-if="editingIndex == index" class="inline-edit-wrap" :class="msg.role == 'user' ? 'inline-edit-user' : 'inline-edit-ai'">
					<textarea class="inline-edit-input" v-model="editBuffer" auto-height />
					<view class="inline-edit-actions">
						<text class="inline-edit-cancel" @click="cancelEdit">取消</text>
						<text class="inline-edit-save" @click="saveEdit">保存</text>
						<text class="inline-edit-send" @click="saveAndSend">发送</text>
					</view>
				</view>
				<ChatBubble v-else
					:role="msg.role"
					:content="msg.content != null ? msg.content : ''"
					:parts="getMessagePartsForView(msg)"
					:agentAvatar="currentAgentAvatar"
					:userNickname="userNickname"
					:userDisplayName="msg.role == 'user' ? userNickname : ''"
					:userAvatar="userAvatar"
					:toolName="msg.toolName != null ? msg.toolName : ''"
					:hideThinking="hideThinking"
					:msgSegmentation="msgSegmentation"
					:isError="msg.isError == true"
					:isStreaming="msg.isStreaming == true"
					:cancelToken="longpressCancelToken"
					@bubbleLongpress="onMessageLongpress(index)"
				/>
			</view>
			<view v-if="messages.length == 0" class="empty-state">
				<text class="empty-text">开始对话</text>
				<text class="empty-hint">输入文字或长按语音按钮</text>
			</view>
		</scroll-view>

		<!-- 底部区域（输入栏 + 工具栏） -->
		<view class="chat-bottom">
			<!-- 输入栏 -->
			<view class="input-bar">
					<view class="toolbar-toggle" @click="toggleToolPanel">
					<oui-icon-unix name="plus" size="18px" color="#374151" />
				</view>
				<view class="input-wrap">
					<textarea
						class="text-input"
						v-model="inputText"
						:style="{ height: inputHeight + 'px' }"
						placeholder="输入消息..."
						placeholder-style="color:var(--rice-text-color-3)"
						@linechange="onInputLineChange"
						:disabled="isGenerating == true"
					/>
				</view>
				<VoiceInput :isListening="isListening ? true : false" @startListening="startVoice" @stopListening="stopVoice" />
				<rice-button v-if="isGenerating == false" type="primary" text="发送" size="small" shape="round" @click="sendMessage" style="margin-left:6px" />
				<rice-button v-else type="primary" text="停止" size="small" shape="round" @click="stopGenerating" style="margin-left:6px" />
			</view>
			<!-- 工具栏面板（输入栏下方展开） -->
			<view v-if="showToolPanel" class="toolbar-panel">
				<view class="toolbar-grid">
					<view class="toolbar-grid-item" @click="pickImage">
						<view class="toolbar-grid-icon"><oui-icon-unix name="image" size="26px" color="var(--rice-primary-color)" /></view>
						<text class="toolbar-grid-label">图片</text>
					</view>
					<view class="toolbar-grid-item" @click="takePhoto">
						<view class="toolbar-grid-icon"><oui-icon-unix name="camera" size="26px" color="var(--rice-primary-color)" /></view>
						<text class="toolbar-grid-label">拍照</text>
					</view>
					<view class="toolbar-grid-item" @click="pickFile">
						<view class="toolbar-grid-icon"><oui-icon-unix name="file" size="26px" color="var(--rice-primary-color)" /></view>
						<text class="toolbar-grid-label">文件</text>
					</view>
					<view class="toolbar-grid-item" @click="pickLocation">
						<view class="toolbar-grid-icon"><oui-icon-unix name="location" size="26px" color="var(--rice-primary-color)" /></view>
						<text class="toolbar-grid-label">位置</text>
					</view>
					<view class="toolbar-grid-item" @click="goMemoryManager">
						<view class="toolbar-grid-icon"><oui-icon-unix name="file-text" size="26px" color="var(--rice-primary-color)" /></view>
						<text class="toolbar-grid-label">记忆管理</text>
					</view>
					<view class="toolbar-grid-item" @click="organizeMemoryFromToolbar">
						<view class="toolbar-grid-icon"><oui-icon-unix name="robot" size="26px" color="var(--rice-primary-color)" /></view>
						<text class="toolbar-grid-label">记忆整理</text>
					</view>
					<view class="toolbar-grid-item" @click="openContextPreview">
						<view class="toolbar-grid-icon"><oui-icon-unix name="eye" size="26px" color="var(--rice-primary-color)" /></view>
						<text class="toolbar-grid-label">原始上下文</text>
					</view>
					<view class="toolbar-grid-item" @click="stopTaskFromToolbar">
						<view class="toolbar-grid-icon"><oui-icon-unix name="stop" size="26px" color="#EF4444" /></view>
						<text class="toolbar-grid-label">终止任务</text>
					</view>
				</view>
			</view>
		</view>
	</view>
</template>

<script lang="uts">
	/**
	 * 对话页面 - AI Agent 主聊天界面
	 * 扁平化粉白主题
	 */
	import { agentChat, readLastLLMRequestSnapshot, organizeAgentMemory, captionImage, appendResponseToSnapshot } from '@/uni_modules/agent-core/utssdk/llm-client.uts'
	import { AgentEvent, AgentEventStream } from '@/utils/event.uts'
	import { getDefaultTaskModel } from '@/uni_modules/agent-core/utssdk/provider.uts'
	import { buildChatDatetimePrefix } from '@/utils/datetime-context.uts'
	import {
		loadChatUserProfile,
		loadActiveAgentSnapshot,
		loadInitialConversation,
		getCurrentAgentSystemPrompt,
		saveChatConversation,
	} from '@/utils/chat-conversation-service.uts'
	import {
		createImageMessage,
		createFileMessage,
		createLocationMessage,
		createVoiceMessage,
		createTextMessage,
		setImageMessageCaption,
		getMessageContent,
		getMessageThinking,
	} from '@/utils/chat-models.uts'
	import {
		pushUserTextMessage,
		deleteChatMessage,
		updateChatMessageContent,
		saveEditAndFindLastUserText,
		truncateFromMessage,
		buildRuntimeMessages as buildRuntimeChatMessages,
		finishAssistantMessage as reduceFinishAssistantMessage,
		finalizeAssistantTurn,
		reduceAgentEvent,
	} from '@/utils/chat-message-reducer.uts'
	import { getAgentConversationDir, exists } from '@/utils/file-manager.uts'
	import { setContextPreviewPayload, setMemoryRouteState } from '@/utils/runtime-state.uts'
	import { transcribeAudio, synthesizeSpeech } from '@/utils/speech-service.uts'
	import { buildPickedFileContextText, isChooseCancelError, isPickedImageFile, parsePickedFileInfo, parsePickedImagePath, type PickedLocalFile } from '@/utils/attachment-reader.uts'
	import { eventBus } from '@/utils/event-bus.uts'
	import { NYX_FLOAT_CONTEXT_CHAT, NYX_FLOAT_VOICE_EVENT, activateNyxFloatVoiceContext, consumePendingNyxFloatVoiceText, deactivateNyxFloatVoiceContext, readNyxFloatVoiceContext } from '@/utils/nyx-float-voice.uts'

	const STREAM_FLUSH_DELAY_MS = 48
	const STREAM_SCROLL_DELAY_MS = 96
	let chatNyxFloatVoiceCallback: (() => void) | null = null

	export default {
		data() {
			return {
				/** 消息列表 */
				messages: [] as UTSJSONObject[],
				/** 当前输入文本 */
				inputText: '',
				/** 是否正在语音输入 */
				isListening: false as boolean,
				/** 是否正在把录音转成文字 */
				isTranscribing: false as boolean,
				/** 是否正在把助手回复转成语音 */
				isSynthesizingSpeech: false as boolean,
				/** 录音会话序号，避免旧 onStop 回调重复处理 */
				voiceSessionId: 0 as number,
				/** 当前播放中的 TTS 音频 */
				playingSpeechPath: '' as string,
				/** 主动停止播放时忽略播放器后续错误事件 */
				isStoppingSpeechPlayback: false as boolean,
				/** TTS 播放器实例 */
				speechPlayer: null as InnerAudioContext | null,
				/** AI 是否正在生成回复 */
				isGenerating: false as boolean,
				/** 当前 Agent 事件流，用于停止生成 */
				currentStream: null as AgentEventStream | null,
				/** 流式 token 事件缓冲队列，避免真机每个 token 都重绘页面 */
				streamEventQueue: [] as AgentEvent[],
				/** 流式事件批量刷新定时器 */
				streamFlushTimer: -1 as number,
				/** 流式期间滚动节流定时器 */
				streamScrollTimer: -1 as number,
				/** 图片转述任务序号，用于取消过期的 caption 回调 */
				imageCaptionTaskId: 0,
				/** 当前智能体 ID */
				currentAgentId: '' as string,
				/** 当前智能体名称 */
				currentAgentName: '' as string,
				/** 当前智能体头像 */
				currentAgentAvatar: '' as string,
				/** 当前智能体模型 */
				currentAgentModel: '' as string,
				/** 当前智能体系统提示词 */
				currentSystemPrompt: '' as string,
				/** 用户昵称（用于消息气泡头像） */
				userNickname: '' as string,
				/** 用户头像路径 */
				userAvatar: '' as string,
				/** 是否隐藏思考内容（来自智能体设置） */
				hideThinking: false as boolean,
				/** 是否注入日期时间（来自智能体设置） */
				injectDatetime: true as boolean,
				/** 是否按段落拆分消息气泡 */
				msgSegmentation: true as boolean,
				/** 流式滚动节拍计数器 */
				_streamScrollTick: 0 as number,
				/** 滚动位置 */
				scrollTop: 0,
				/** 当前对话唯一 ID */
				conversationId: '' as string,
				/** 是否已存过当前对话（防止重复存） */
				savedFlag: false as boolean,
				/** 输入框 JS 驱动高度 */
				inputHeight: 36,
				/** 是否显示工具栏面板 */
				showToolPanel: false as boolean,
				/** 行内编辑 */
				editingIndex: -1 as number,
				editBuffer: '' as string,
				/** 滚动时通知 ChatBubble 取消长按的 token */
				longpressCancelToken: 0 as number,
				/** 消息长按菜单锁，避免重复弹出 */
				messageActionSheetOpen: false as boolean,
				/** 软键盘高度（>0 表示键盘弹出） */
				keyboardHeight: 0 as number,
			}
		},
		computed: {
			/** 头部标题 */
			headerTitle(): string {
				return this.currentAgentName != '' ? this.currentAgentName : 'AI 助手'
			}
		},
		onLoad() {
			// 加载用户昵称
			this.loadUserNickname()
			// 加载当前智能体信息
			this.loadCurrentAgent()
			// 检查是否因历史记录跳转过来的（加载已有对话）
			this.loadExistingConversation()
			// 无指定历史时，自动加载该智能体最近对话
			if (this.conversationId == '') {
				this.loadRecentConversation()
			}
			// 仍然没有，生成新对话 ID
			if (this.conversationId == '') {
				this.conversationId = '' + Date.now()
			}
			// 监听软键盘高度变化：键盘弹出时自动收起工具栏面板，避免遮挡消息列表
			uni.onKeyboardHeightChange((res: OnKeyboardHeightChangeCallbackResult) => {
				this.keyboardHeight = res.height
				if (res.height > 0 && this.showToolPanel == true) {
					this.showToolPanel = false
				}
			})
			chatNyxFloatVoiceCallback = () => {
				this.consumeNyxFloatVoiceText()
			}
			const callback = chatNyxFloatVoiceCallback
			if (callback != null) {
				eventBus.on(NYX_FLOAT_VOICE_EVENT, callback)
			}
		},

		onShow() {
			// 每次显示页面时刷新智能体信息和用户昵称
			this.loadUserNickname()
			this.loadCurrentAgent()
			activateNyxFloatVoiceContext(NYX_FLOAT_CONTEXT_CHAT)
			this.consumeNyxFloatVoiceText()
		},

		onReady() {
			// DOM 就绪后滚动到底部
			this.scrollToBottom()
		},

		onHide() {
			// 离开页面时保存当前对话，并停止后台朗读。
			this.flushStreamEvents()
			this.clearStreamScrollTimer()
			this.stopSpeechPlayback()
			this.saveCurrentConversation()
			deactivateNyxFloatVoiceContext(NYX_FLOAT_CONTEXT_CHAT)
		},

		onUnload() {
			// 页面卸载时移除软键盘高度监听，防止内存泄漏
			this.flushStreamEvents()
			this.clearStreamFlushTimer()
			this.clearStreamScrollTimer()
			this.stopSpeechPlayback()
			uni.offKeyboardHeightChange()
			const callback = chatNyxFloatVoiceCallback
			if (callback != null) {
				eventBus.off(NYX_FLOAT_VOICE_EVENT, callback)
			}
			chatNyxFloatVoiceCallback = null
			deactivateNyxFloatVoiceContext(NYX_FLOAT_CONTEXT_CHAT)
		},

		methods: {
			/** 加载当前智能体信息 */
			/** 加载用户昵称 */
			hasValidDefaultTaskModel(type: string): boolean {
				const config = getDefaultTaskModel(type)
				if (config == null) { return false }
				const providerIdRaw = config['providerId'] as string | null
				const modelRaw = config['model'] as string | null
				const providerId = providerIdRaw != null ? providerIdRaw : ''
				const model = modelRaw != null ? modelRaw : ''
				return providerId != '' && model != ''
			},

			getMessagePartsForView(msg: UTSJSONObject): UTSJSONObject[] {
				const parts = msg['message'] as UTSJSONObject[] | null
				if (parts != null) {
					return parts
				}
				return [] as UTSJSONObject[]
			},

			findLastAssistantMessage(): UTSJSONObject | null {
				for (let i = this.messages.length - 1; i >= 0; i--) {
					const msg = this.messages[i]
					const role = msg['role'] as string | null
					if (role == 'assistant') {
						return msg
					}
				}
				return null
			},

			hasMessageRef(target: UTSJSONObject): boolean {
				for (let i = 0; i < this.messages.length; i++) {
					if (this.messages[i] == target) {
						return true
					}
				}
				return false
			},

			appendLatestResponseSnapshot(): void {
				const msg = this.findLastAssistantMessage()
				if (msg == null) { return }
				const responseText = getMessageContent(msg)
				const thinkingText = getMessageThinking(msg)
				if (responseText == '' && thinkingText == '') { return }
				appendResponseToSnapshot(this.currentAgentId, this.conversationId, responseText, thinkingText)
			},

			loadUserNickname() {
				const profile = loadChatUserProfile()
				this.userNickname = profile.nickname
				this.userAvatar = profile.avatar
			},

			loadCurrentAgent() {
				const agent = loadActiveAgentSnapshot()
				this.currentAgentId = agent.id
				this.currentAgentName = agent.name
				this.currentAgentAvatar = agent.avatar
				this.currentAgentModel = agent.model
				this.currentSystemPrompt = agent.systemPrompt
				this.hideThinking = agent.hideThinking
				this.injectDatetime = agent.injectDatetime
				this.msgSegmentation = agent.msgSegmentation
			},

			/** 从历史记录跳转时加载已有对话 */
			loadExistingConversation() {
				const loaded = loadInitialConversation(this.currentAgentId)
				this.conversationId = loaded.conversationId
				this.messages = loaded.messages
				this.savedFlag = loaded.saved
			},

			/** 自动加载当前智能体最近的一条对话 */
			loadRecentConversation() {
				if (this.conversationId != '') { return }
				const loaded = loadInitialConversation(this.currentAgentId)
				this.conversationId = loaded.conversationId
				this.messages = loaded.messages
				this.savedFlag = loaded.saved
			},

			/** 根据行数 JS 动态调整输入框高度 */
			onInputLineChange(e: UniTextareaLineChangeEvent) {
				const lineCount = e.detail.lineCount
				if (lineCount <= 1) {
					this.inputHeight = 36
				} else {
					this.inputHeight = Math.min(lineCount * 22 + 12, 200)
				}
			},

			/** 滚动时通知所有 ChatBubble 取消长按 */
			onMsgScroll() {
				this.longpressCancelToken++
			},

			sendMessage() {
				const text = this.inputText.trim()
				if (text == '' || this.isGenerating) {
					return
				}
				if (this.messages.length == 0) {
					this.conversationId = '' + Date.now()
				}
				// 发新消息时允许保存（从历史加载后 savedFlag 为 true 会阻止保存）
				this.savedFlag = false
				this.addTextMessage('user', text)
				this.inputText = ''
				this.scrollToBottom()
				this.simulateAIResponse(text)
			},

			/** 构建日期时间注入前缀（含农历、节气、节日） */
			buildDatetimePrefix(): string {
				return buildChatDatetimePrefix()
			},

			/** 构建运行时消息副本：日期时间只临时注入给 Agent，不写入消息列表/数据库/UI。 */
			buildRuntimeMessages(): UTSJSONObject[] {
				return buildRuntimeChatMessages(this.messages, {
					injectDatetime: this.injectDatetime,
					datetimePrefix: this.buildDatetimePrefix(),
				})
			},

			/** 长按消息弹出操作菜单 */
			onMessageLongpress(index: number) {
				if (this.isGenerating == true) { return }
				if (this.messageActionSheetOpen == true) { return }
				const msg = this.messages[index]
				if (msg == null) { return }
				const roleRaw = msg['role']
				if (roleRaw == null) { return }
				const role = roleRaw as string
				let actions: string[] = []
				if (role == 'user' || role == 'assistant') {
					actions = ['删除', '编辑']
					if (role == 'assistant') {
						const content = getMessageContent(msg).trim()
						if (this.hasValidDefaultTaskModel('tts') == true && content != '') {
							actions.push('播放语音')
						}
						actions.push('重新回答')
					}
				} else {
					actions = ['删除']
				}
				const msgIndex = index
				this.messageActionSheetOpen = true
				uni.showActionSheet({
					itemList: actions,
					success: (res) => {
						const tapIdx = res.tapIndex
						if (tapIdx < 0 || tapIdx >= actions.length) { return }
						const action = actions[tapIdx]
						if (action == '删除') {
							this.deleteMessage(msgIndex)
						} else if (action == '编辑') {
							this.editMessage(msgIndex)
						} else if (action == '播放语音') {
							this.playAssistantSpeech(msgIndex)
						} else if (action == '重新回答') {
							this.regenerateResponse(msgIndex)
						}
					},
					fail: (_err) => {
					},
					complete: () => {
						this.messageActionSheetOpen = false
					}
				})
			},

			/** 删除指定消息 */
			deleteMessage(index: number) {
				deleteChatMessage(this.messages, index)
				this.savedFlag = false
			},

			/** 原地编辑消息 */
			editMessage(index: number) {
				const msg = this.messages[index]
				if (msg == null) { return }
				const rawContent = msg['content']
				this.editBuffer = rawContent != null ? (rawContent as string) : ''
				this.editingIndex = index
			},

			/** 保存行内编辑 */
			saveEdit() {
				const idx = this.editingIndex
				updateChatMessageContent(this.messages, idx, this.editBuffer)
				this.cancelEdit()
				this.savedFlag = false
			},

			/** 保存并发送：更新内容后从该消息截断并重新触发 AI */
			saveAndSend() {
				const idx = this.editingIndex
				if (idx < 0 || idx >= this.messages.length) { return }
				const lastUserText = saveEditAndFindLastUserText(this.messages, idx, this.editBuffer)
				this.editingIndex = -1
				this.editBuffer = ''
				this.savedFlag = false
				if (lastUserText != '') {
					this.simulateAIResponse(lastUserText)
				}
			},

			/** 取消行内编辑 */
			cancelEdit() {
				this.editingIndex = -1
				this.editBuffer = ''
			},

			/** 重新生成 AI 回答：删除该 AI 消息，重新触发 AI */
			regenerateResponse(index: number) {
				const lastUserText = truncateFromMessage(this.messages, index)
				this.savedFlag = false
				if (lastUserText != '') {
					this.simulateAIResponse(lastUserText)
				}
			},

			startGenerationForMedia(prompt: string) {
				if (this.isGenerating == true) {
					return
				}
				this.savedFlag = false
				this.simulateAIResponse(prompt)
			},

			/** 添加文本消息 */
			addTextMessage(role: string, content: string) {
				if (role == 'user') {
					pushUserTextMessage(this.messages, content)
				} else {
					this.messages.push(createTextMessage(role, content))
				}
			},

			/** 添加图片消息，返回消息下标用于后续写入转述 */
			addImageMessage(imagePath: string): number {
				if (imagePath == '') { return -1 }
				this.messages.push(createImageMessage(imagePath))
				this.scrollToBottom()
				return this.messages.length - 1
			},

			handlePickedImagePath(imagePath: string, fallbackPrompt: string): void {
				if (imagePath == '') {
					uni.showToast({ position: 'bottom', title: '未选择图片', icon: 'none' })
					return
				}
				const msgIndex = this.addImageMessage(imagePath)
				this.startGenerationForImage(imagePath, fallbackPrompt, msgIndex)
			},

			/** 参考 AstrBot：先用默认图片转述模型生成 caption，再把 caption 注入普通对话上下文。 */
			startGenerationForImage(imagePath: string, fallbackPrompt: string, messageIndex: number) {
				if (this.isGenerating == true) {
					return
				}
				this.isGenerating = true
				this.savedFlag = false
				this.imageCaptionTaskId++
				const taskId = this.imageCaptionTaskId
				captionImage(imagePath).then((caption: string | null) => {
					if (taskId != this.imageCaptionTaskId) {
						return
					}
					if (messageIndex >= 0 && messageIndex < this.messages.length && caption != null && caption != '') {
						setImageMessageCaption(this.messages[messageIndex], caption)
						this.messages.splice(messageIndex, 1, this.messages[messageIndex])
					}
					this.isGenerating = false
					if (caption == null || caption == '') {
						uni.showToast({ position: 'bottom', title: '图片转述未配置或失败，已直接发送', icon: 'none' })
					}
					this.startGenerationForMedia(fallbackPrompt)
				})
			},

			/** 添加文件消息 */
			addFileMessage(fileInfo: any) {
				const file = parsePickedFileInfo(fileInfo)
				if (file.path == '') {
					uni.showToast({ position: 'bottom', title: '未选择文件', icon: 'none' })
					return
				}
				if (isPickedImageFile(file) == true) {
					this.handlePickedImagePath(file.path, '用户通过文件发送了一张图片')
					return
				}
				const fileText = buildPickedFileContextText(file)
				this.messages.push(createFileMessage(file.name, file.path, fileText))
				this.scrollToBottom()
				this.startGenerationForMedia('用户发送了一个文件：' + file.name)
			},

			/** 添加位置消息 */
			addLocationMessage(location: UTSJSONObject) {
				const rawName = location['name'] as string | null
				const rawAddr = location['address'] as string | null
				const rawLat = location['latitude'] as number | null
				const rawLng = location['longitude'] as number | null
				const name = rawName != null ? rawName : '未知位置'
				const addr = rawAddr != null ? rawAddr : ''
				const lat = rawLat != null ? rawLat : 0
				const lng = rawLng != null ? rawLng : 0
				const content = '📍 ' + name + (addr != '' ? ' - ' + addr : '') + ' (' + lat + ', ' + lng + ')'
				this.messages.push(createLocationMessage(content))
				this.scrollToBottom()
				this.startGenerationForMedia(content)
			},

			/** 添加语音消息 */
			addVoiceMessage(tempPath: string) {
				if (tempPath == '') { return }
				this.messages.push(createVoiceMessage(tempPath))
				this.scrollToBottom()
				this.savedFlag = false
				this.saveCurrentConversation()
			},

			/** 发送语音识别后的纯文本：Record -> Plain，不把录音路径喂给 Agent。 */
			sendTranscribedVoiceMessage(text: string) {
				const content = text.trim()
				if (content == '' || this.isGenerating == true) { return }
				if (this.messages.length == 0) {
					this.conversationId = '' + Date.now()
				}
				this.savedFlag = false
				this.messages.push(createTextMessage('user', content))
				this.inputText = ''
				this.scrollToBottom()
				this.simulateAIResponse(content)
			},

			consumeNyxFloatVoiceText(): void {
				if (readNyxFloatVoiceContext() != NYX_FLOAT_CONTEXT_CHAT) { return }
				const content = consumePendingNyxFloatVoiceText()
				if (content == '') { return }
				if (this.isGenerating == true || this.isTranscribing == true) {
					this.inputText = content
					uni.showToast({ position: 'bottom', title: '已填入输入框，等当前回复结束再发', icon: 'none' })
					return
				}
				this.sendTranscribedVoiceMessage(content)
			},

			// ===== 工具栏 =====

			/** 切换工具栏面板，打开后滚动到底 */
			toggleToolPanel() {
				this.showToolPanel = !this.showToolPanel
				if (this.showToolPanel == true) {
					this.scrollToBottom()
				}
			},

			/** 滚动时通知 ChatBubble 取消长按 */
			onMsgTouchMove() {
				this.longpressCancelToken++
			},

			/** 从相册选择图片 */
			pickImage() {
				this.showToolPanel = false
				uni.chooseImage({
					count: 1,
					sourceType: ['album'],
					sizeType: ['compressed'],
					success: (res: any) => {
						const imagePath = parsePickedImagePath(res)
						this.handlePickedImagePath(imagePath, '用户发送了一张图片')
					},
					fail: (err: any) => {
						if (isChooseCancelError(err) == true) { return }
						console.log('[Chat] chooseImage 相册失败，尝试 chooseMedia: ' + JSON.stringify(err))
						this.pickImageFromMediaFallback('用户发送了一张图片')
					}
				})
			},

			/** 拍照 */
			takePhoto() {
				this.showToolPanel = false
				uni.chooseImage({
					count: 1,
					sourceType: ['camera'],
					sizeType: ['compressed'],
					success: (res: any) => {
						const imagePath = parsePickedImagePath(res)
						this.handlePickedImagePath(imagePath, '用户拍摄了一张照片')
					},
					fail: (err: any) => {
						if (isChooseCancelError(err) == true) { return }
						uni.showToast({ position: 'bottom', title: '拍照失败', icon: 'none' })
					}
				})
			},

			/** 选择文件 */
			pickFile() {
				this.showToolPanel = false
				uni.chooseFile({
					count: 1,
					success: (res: any) => {
						this.addFileMessage(res)
					},
					fail: (err: any) => {
						if (isChooseCancelError(err) == true) { return }
						uni.showToast({ position: 'bottom', title: '选择文件失败', icon: 'none' })
					}
				})
			},

			pickImageFromMediaFallback(fallbackPrompt: string): void {
				uni.chooseMedia({
					count: 1,
					sourceType: ['album'],
					success: (res: any) => {
						const file: PickedLocalFile = parsePickedFileInfo(res)
						if (file.path == '') {
							uni.showToast({ position: 'bottom', title: '未选择图片', icon: 'none' })
							return
						}
						if (isPickedImageFile(file) == false) {
							uni.showToast({ position: 'bottom', title: '请选择图片文件', icon: 'none' })
							return
						}
						this.handlePickedImagePath(file.path, fallbackPrompt)
					},
					fail: (err: any) => {
						if (isChooseCancelError(err) == true) { return }
						console.log('[Chat] chooseMedia 相册失败，切换文件选图: ' + JSON.stringify(err))
						uni.showToast({ position: 'bottom', title: '相册打开失败，请从文件选择图片', icon: 'none' })
						this.pickImageFromFileFallback(fallbackPrompt)
					}
				})
			},

			pickImageFromFileFallback(fallbackPrompt: string): void {
				uni.chooseFile({
					count: 1,
					success: (res: any) => {
						const file: PickedLocalFile = parsePickedFileInfo(res)
						if (file.path == '') {
							uni.showToast({ position: 'bottom', title: '未选择图片', icon: 'none' })
							return
						}
						if (isPickedImageFile(file) == false) {
							uni.showToast({ position: 'bottom', title: '请选择图片文件', icon: 'none' })
							return
						}
						this.handlePickedImagePath(file.path, fallbackPrompt)
					},
					fail: (err: any) => {
						if (isChooseCancelError(err) == true) { return }
						uni.showToast({ position: 'bottom', title: '选择图片失败', icon: 'none' })
					}
				})
			},

			/** 选择位置 */
			pickLocation() {
				this.showToolPanel = false
				uni.chooseLocation({
					success: (res: any) => {
						const raw = JSON.stringify(res)
						if (raw == null || raw == '') { return }
						const parsed = JSON.parse(raw) as UTSJSONObject
						this.addLocationMessage(parsed)
					}
				})
			},

			/** 手动触发记忆管理 Agent 整理当前对话。 */
			organizeMemoryFromToolbar() {
				this.showToolPanel = false
				if (this.isGenerating == true) {
					uni.showToast({ position: 'bottom', 
						title: '当前任务进行中',
						icon: 'none'
					})
					return
				}
				if (this.messages.length == 0) {
					uni.showToast({ position: 'bottom', 
						title: '暂无可整理内容',
						icon: 'none'
					})
					return
				}
				const started = organizeAgentMemory(
					this.messages,
					'',
					this.currentAgentModel,
					this.currentAgentId,
					this.conversationId
				)
				uni.showToast({ position: 'bottom', 
					title: started == true ? '记忆整理已开始' : '暂无可整理内容',
					icon: 'none'
				})
			},

			/** 工具栏终止当前任务。 */
			stopTaskFromToolbar() {
				this.showToolPanel = false
				if (this.isGenerating == true) {
					this.stopGenerating()
					uni.showToast({ position: 'bottom', 
						title: '已终止',
						icon: 'none'
					})
					return
				}
				uni.showToast({ position: 'bottom', 
					title: '当前没有运行中的任务',
					icon: 'none'
				})
			},

			// ===== 语音输入 =====

			startVoice() {
				if (this.isGenerating == true || this.isTranscribing == true) {
					uni.showToast({ position: 'bottom',  title: '当前任务进行中', icon: 'none' })
					return
				}
				if (this.isListening == true) {
					return
				}
				if (this.hasValidDefaultTaskModel('stt') == false) {
					uni.showToast({ position: 'bottom',  title: '请先在设置中配置语音识别模型', icon: 'none' })
					return
				}
				this.isListening = true
				this.voiceSessionId++
				const sessionId = this.voiceSessionId
				const recorder = uni.getRecorderManager()
				recorder.onStop((res: any): void => {
					if (sessionId != this.voiceSessionId) { return }
					this.isListening = false
					const raw = JSON.stringify(res)
					if (raw == null || raw == '') { return }
					const parsed = JSON.parse(raw) as UTSJSONObject
					const rawTempPath = parsed['tempFilePath'] as string | null
					const tempPath = rawTempPath != null ? rawTempPath : ''
					if (tempPath != '') {
						this.handleVoiceRecordStopped(tempPath)
					}
				})
				recorder.onError((err: any): void => {
					if (sessionId != this.voiceSessionId) { return }
					this.isListening = false
					console.log('[Speech] 录音失败: ' + err)
					uni.showToast({ position: 'bottom',  title: '录音失败', icon: 'none' })
				})
				const startOpts: RecorderManagerStartOptions = {
					// PROVIDER_AUDIO_API: OpenAI-compatible STT 优先 wav；部分平台录音格式支持不同，后续统一抽 provider 能力。
					format: 'wav',
				}
				recorder.start(startOpts)
			},

			stopVoice() {
				if (this.isListening == false) { return }
				const recorder = uni.getRecorderManager()
				recorder.stop()
			},

			handleVoiceRecordStopped(tempPath: string) {
				if (tempPath == '') { return }
				if (this.isGenerating == true) {
					uni.showToast({ position: 'bottom',  title: '请等待当前回复完成', icon: 'none' })
					return
				}
				this.isTranscribing = true
				uni.showLoading({ title: '识别中...' })
				transcribeAudio(tempPath).then((result) => {
					this.isTranscribing = false
					uni.hideLoading()
					if (result.ok == true) {
						this.sendTranscribedVoiceMessage(result.text)
						return
					}
					uni.showToast({ position: 'bottom',  title: result.error, icon: 'none' })
				})
			},

			stopSpeechPlayback(): void {
				const player = this.speechPlayer
				if (player != null) {
					this.isStoppingSpeechPlayback = true
					try {
						player.pause()
						player.src = ''
					} catch (_e: any) {
					}
				}
				this.speechPlayer = null
				this.playingSpeechPath = ''
			},

			buildPlayableSpeechPath(path: string): string {
				if (path == '') { return '' }
				if (path.startsWith('file://') || path.startsWith('http://') || path.startsWith('https://') || path.startsWith('unifile://')) {
					return path
				}
				if (path.startsWith('/')) {
					return 'file://' + path
				}
				return path
			},

			isPlayableSpeechCache(path: string): boolean {
				if (path == '') { return false }
				if (path.startsWith('http://') || path.startsWith('https://') || path.startsWith('unifile://')) { return true }
				if (path.startsWith('file://')) {
					const rawPath = path.substring(7)
					return exists(rawPath)
				}
				if (path.startsWith('/')) { return exists(path) }
				return true
			},

			playSpeechPath(path: string): void {
				if (path == '') {
					uni.showToast({ position: 'bottom',  title: '语音路径为空', icon: 'none' })
					return
				}
				if (this.playingSpeechPath == path) {
					this.stopSpeechPlayback()
					return
				}
				this.stopSpeechPlayback()
				// PROVIDER_AUDIO_API: TTS 当前落本地临时音频文件，播放时绝对路径要转 file://。
				this.isStoppingSpeechPlayback = false
				const audio = uni.createInnerAudioContext()
				this.speechPlayer = audio
				const playablePath = this.buildPlayableSpeechPath(path)
				this.playingSpeechPath = path
				audio.src = playablePath
				audio.onEnded(() => {
					this.stopSpeechPlayback()
				})
				audio.onError((err: any) => {
					if (this.isStoppingSpeechPlayback == true || this.speechPlayer != audio || this.playingSpeechPath != path) {
						console.log('[Speech] 忽略已停止播放器错误: ' + err)
						return
					}
					console.log('[Speech] 播放失败: ' + err)
					this.stopSpeechPlayback()
					uni.showToast({ position: 'bottom',  title: '语音播放失败', icon: 'none' })
				})
				audio.play()
			},

			synthesizeAssistantSpeech(msg: UTSJSONObject, autoPlay: boolean): void {
				if (this.isSynthesizingSpeech == true) {
					if (autoPlay == false) {
						uni.showToast({ position: 'bottom',  title: '语音合成中', icon: 'none' })
					}
					return
				}
				const text = getMessageContent(msg).trim()
				if (text == '') { return }
				const conversationId = this.conversationId
				this.isSynthesizingSpeech = true
				synthesizeSpeech(text, this.agentId).then((result) => {
					this.isSynthesizingSpeech = false
					if (this.conversationId != conversationId) { return }
					if (this.hasMessageRef(msg) == false) { return }
					if (result.ok == true) {
						msg['ttsAudioPath'] = result.path
						this.savedFlag = false
						this.saveCurrentConversation()
						if (autoPlay == true) {
							this.playSpeechPath(result.path)
						}
						return
					}
					console.log('[Speech] 语音合成失败: ' + result.error)
					uni.showToast({ position: 'bottom',  title: result.error, icon: 'none' })
				})
			},

			playAssistantSpeech(index: number): void {
				if (index < 0 || index >= this.messages.length) { return }
				const msg = this.messages[index]
				if (msg == null) { return }
				const role = msg['role'] as string | null
				if (role != 'assistant') { return }
				const existing = msg['ttsAudioPath'] as string | null
				if (existing != null && existing != '') {
					if (this.isPlayableSpeechCache(existing) == true) {
						this.playSpeechPath(existing)
						return
					}
					msg['ttsAudioPath'] = ''
					this.savedFlag = false
					this.saveCurrentConversation()
				}
				uni.showToast({ position: 'bottom',  title: '语音生成中', icon: 'none' })
				this.synthesizeAssistantSpeech(msg, true)
			},

			maybeSynthesizeLatestAssistantSpeech(): void {
				if (this.hasValidDefaultTaskModel('tts') == false) { return }
				const msg = this.findLastAssistantMessage()
				if (msg == null) { return }
				const existing = msg['ttsAudioPath'] as string | null
				if (existing != null && existing != '') {
					if (this.isPlayableSpeechCache(existing) == true) {
						this.playSpeechPath(existing)
						return
					}
					msg['ttsAudioPath'] = ''
					this.savedFlag = false
					this.saveCurrentConversation()
				}
				this.synthesizeAssistantSpeech(msg, true)
			},

			isBufferedAgentEvent(event: AgentEvent): boolean {
				return event.type == 'text_delta' || event.type == 'thinking_delta'
			},

			clearStreamFlushTimer() {
				if (this.streamFlushTimer != -1) {
					clearTimeout(this.streamFlushTimer)
					this.streamFlushTimer = -1
				}
			},

			clearStreamScrollTimer() {
				if (this.streamScrollTimer != -1) {
					clearTimeout(this.streamScrollTimer)
					this.streamScrollTimer = -1
				}
			},

			appendBufferedAgentEvent(event: AgentEvent) {
				const lastIndex = this.streamEventQueue.length - 1
				if (lastIndex >= 0) {
					const last = this.streamEventQueue[lastIndex]
					if (last.type == event.type) {
						if (event.type == 'text_delta') {
							const oldText = last.text != null ? (last.text as string) : ''
							const nextText = event.text != null ? (event.text as string) : ''
							last.text = oldText + nextText
							return
						}
						if (event.type == 'thinking_delta') {
							const oldThinking = last.thinkingText != null ? (last.thinkingText as string) : ''
							const nextThinking = event.thinkingText != null ? (event.thinkingText as string) : ''
							last.thinkingText = oldThinking + nextThinking
							return
						}
					}
				}
				this.streamEventQueue.push(event)
			},

			scheduleStreamFlush() {
				if (this.streamFlushTimer != -1) { return }
				const self = this
				this.streamFlushTimer = setTimeout(() => {
					self.streamFlushTimer = -1
					self.flushStreamEvents()
				}, STREAM_FLUSH_DELAY_MS)
			},

			flushStreamEvents() {
				this.clearStreamFlushTimer()
				if (this.streamEventQueue.length == 0) { return }
				const pending = this.streamEventQueue
				this.streamEventQueue = [] as AgentEvent[]
				let messageChanged = false
				for (let i = 0; i < pending.length; i++) {
					if (reduceAgentEvent(this.messages, pending[i]) == true) {
						messageChanged = true
					}
				}
				if (messageChanged == true) {
					this.scrollToBottom()
				}
			},

			enqueueAgentEvent(event: AgentEvent) {
				if (this.isBufferedAgentEvent(event) == true) {
					this.appendBufferedAgentEvent(event)
					this.scheduleStreamFlush()
					return
				}
				this.flushStreamEvents()
				this.handleAgentEvent(event)
			},

			/** 停止当前 AI 生成 */
			stopGenerating() {
				this.imageCaptionTaskId++
				this.flushStreamEvents()
				const stream = this.currentStream
				if (stream != null) {
					stream.abort()
					this.currentStream = null
				}
				reduceFinishAssistantMessage(this.messages, '')
				finalizeAssistantTurn(this.messages, this.msgSegmentation)
				this.isGenerating = false
				this.clearStreamFlushTimer()
				this.clearStreamScrollTimer()
				this.scrollToBottom()
				this.saveCurrentConversation()
			},

			goAgentSettings() {
				uni.navigateTo({
					url: '/pages/agent-settings/agent-settings'
				})
			},

			goHistory() {
				uni.navigateTo({
					url: '/pages/history/history'
				})
			},

			goMemoryManager() {
				this.showToolPanel = false
				setMemoryRouteState(this.currentAgentId, this.conversationId)
				uni.navigateTo({
					url: '/pages/memory/memory'
				})
			},

			openContextPreview() {
				this.showToolPanel = false
				const preview = readLastLLMRequestSnapshot(this.currentAgentId, this.conversationId)
				if (preview == null) {
					uni.showToast({ position: 'bottom', title: '还没有真实请求快照', icon: 'none' })
					return
				}
				let previewText = ''
				try {
					previewText = JSON.stringify(preview, null, 2)
				} catch (_e: any) {
					previewText = JSON.stringify(preview)
				}
				setContextPreviewPayload(previewText)
				uni.navigateTo({
					url: '/pages/context-preview/context-preview'
				})
			},

			goBack() {
				uni.navigateBack()
			},

			/** 开启新对话 */
			startNewConversation() {
				if (this.isGenerating == true) {
					uni.showToast({ position: 'bottom',  title: '请等待当前回复完成', icon: 'none' })
					return
				}
				// 先保存当前对话
				this.saveCurrentConversation()
				// 清空消息
				this.messages = [] as UTSJSONObject[]
				// 新对话 ID
				this.conversationId = '' + Date.now()
				this.savedFlag = false
				// 重置输入
				this.inputText = ''
				this.showToolPanel = false
			},

			saveCurrentConversation() {
				if (this.messages.length == 0 || this.savedFlag) {
					return
				}
				this.savedFlag = true
				saveChatConversation(this.conversationId, this.currentAgentId, this.getCurrentSystemPrompt(), this.messages)
			},

			performStreamScrollToBottom() {
				this._streamScrollTick++
				this.scrollTop = 100000 + this._streamScrollTick
			},

			scheduleStreamScroll() {
				if (this.streamScrollTimer != -1) { return }
				const self = this
				this.streamScrollTimer = setTimeout(() => {
					self.streamScrollTimer = -1
					if (self.isGenerating == true) {
						self.performStreamScrollToBottom()
					} else {
						self.scrollToBottom()
					}
				}, STREAM_SCROLL_DELAY_MS)
			},

			scrollToBottom() {
				// 真机流式阶段 scroll-view 高频 scrollTop 会抖；生成中只按帧节流滚动。
				if (this.isGenerating == true) {
					this.scheduleStreamScroll()
					return
				}
				this.clearStreamScrollTimer()
				this.scrollTop = 0
				const self = this
				setTimeout(() => {
					self.scrollTop = 99999
				}, 50)
			},

			/** 获取当前智能体的系统提示词 */
			getCurrentSystemPrompt(): string {
				if (this.currentSystemPrompt != '') {
					return this.currentSystemPrompt
				}
				return getCurrentAgentSystemPrompt(this.currentAgentId)
			},

			/** Agent 事件流统一入口 */
			handleAgentEvent(event: AgentEvent) {
				const messageChanged = reduceAgentEvent(this.messages, event)
				if (messageChanged == true) {
					this.scrollToBottom()
					return
				}
				if (event.type == 'memory_organize_start') {
					uni.showToast({ position: 'bottom', 
						title: event.message != null ? (event.message as string) : '记忆整理已开始',
						icon: 'none'
					})
				} else if (event.type == 'agent_end') {
					finalizeAssistantTurn(this.messages, this.msgSegmentation)
					this.appendLatestResponseSnapshot()
					this.isGenerating = false
					this.currentStream = null
					this.clearStreamFlushTimer()
					this.clearStreamScrollTimer()
					this.scrollToBottom()
					this.saveCurrentConversation()
					this.maybeSynthesizeLatestAssistantSpeech()
				}
			},
			simulateAIResponse(_userText: string) {
				this.isGenerating = true
				this._streamScrollTick = 0

				// 使用 ReAct Agent Loop（带沙箱文件工具）
				const runtimeMessages = this.buildRuntimeMessages()
				const workspaceRoot = getAgentConversationDir(this.currentAgentId, this.conversationId)
				const stream: AgentEventStream = agentChat(
					runtimeMessages,
					this.getCurrentSystemPrompt(),
					'',           // providerId → 自动从 DB 读取
					this.currentAgentModel,
					this.currentAgentId,
					0,
					this.conversationId,
					workspaceRoot
				)
				this.currentStream = stream
				stream.on((event: AgentEvent) => {
					this.enqueueAgentEvent(event)
				})
			}

		}
	};
</script>

