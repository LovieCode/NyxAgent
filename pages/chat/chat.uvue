		margin-bottom: 11px;
	}
	.toolbar-grid-icon {
		width: 48px;
		height: 48px;
		border-radius: 18px;
		background-color: #FFF4F7;
		justify-content: center;
		align-items: center;
		margin-bottom: 6px;
		border-width: 1px;
		border-style: solid;
		border-color: rgba(251, 143, 171, 0.15);
	}
	.toolbar-grid-label {
		font-size: 11px;
		color: #8A7B84;
