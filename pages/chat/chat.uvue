	.load-older-wrap {
		margin-left: 52px;
		margin-right: 52px;
		margin-top: 4px;
		margin-bottom: 8px;
		height: 34px;
		border-radius: 17px;
		background-color: rgba(255, 255, 255, 0.78);
		border-width: 1px;
		border-style: solid;
		border-color: rgba(241, 229, 234, 0.92);
		align-items: center;
		justify-content: center;
	}

	.load-older-text {
		font-size: 12px;
		line-height: 16px;
		color: #DB6F92;
		font-weight: bold;
	}

	.chat-custom-scrollbar {
		position: absolute;
		right: 3px;
		top: 0;
		bottom: 0;
		width: 14px;
		border-radius: 7px;
		background-color: transparent;
	}

	.chat-scrollbar-thumb {
		position: absolute;
		left: 6px;
		right: 6px;
		border-radius: 999px;
		background-color: rgba(219, 111, 146, 0.28);
	}

	.back-bottom-btn {
		position: absolute;
		right: 18px;
		bottom: 14px;
		height: 32px;
		padding-left: 13px;
		padding-right: 13px;
		border-radius: 16px;
		background-color: rgba(255, 255, 255, 0.96);
		border-width: 1px;
		border-style: solid;
		border-color: rgba(251, 143, 171, 0.28);
		box-shadow: 0 6px 14px rgba(216, 140, 165, 0.10);
		align-items: center;
		justify-content: center;
	}

	.back-bottom-text {
		font-size: 12px;
		line-height: 16px;
		color: #DB6F92;
		font-weight: bold;
	}

	/* NavBar 右侧图标按钮 */
	.nav-icon-btn {
		width: 30px;
		height: 34px;
		border-radius: 17px;
		background-color: transparent;
		align-items: center;
		justify-content: center;
		border-width: 0;
		border-style: solid;
		border-color: transparent;
	}

	/* 空状态 */
	.empty-state {
		flex: 1;
		justify-content: center;
		align-items: center;
		padding-top: 120px;
	}

	.empty-text {
		font-size: 24px;
		color: var(--rice-text-color);
		font-weight: bold;
		margin-bottom: 8px;
	}

	.empty-hint {
		font-size: 14px;
		color: var(--rice-text-color-3);
	}

	/* 底部区域（工具栏面板 + 输入栏） */
	.chat-bottom {
		flex-shrink: 0;
		background-color: transparent;
		border-top-left-radius: 0;
		border-top-right-radius: 0;
		border-width: 0;
		border-style: solid;
		border-color: transparent;
		box-shadow: none;
	}

	/* 工具栏面板（输入栏上方展开） */
	.toolbar-panel {
		background-color: transparent;
		padding: 6px 10px 8px 10px;
	}
	.toolbar-panel-card {
		background-color: rgba(255, 253, 253, 0.96);
		border-radius: 21px;
		border-width: 1px;
		border-style: solid;
		border-color: rgba(241, 229, 234, 0.95);
		padding-top: 8px;
		padding-left: 8px;
		padding-right: 8px;
		padding-bottom: 0;
		box-shadow: 0 8px 18px rgba(216, 140, 165, 0.055);
	}
	.toolbar-panel-handle {
		width: 34px;
		height: 4px;
		border-radius: 999px;
		background-color: rgba(153, 143, 150, 0.30);
		align-self: center;
		margin-bottom: 10px;
	}
	.toolbar-grid {
		flex-direction: row;
		justify-content: flex-start;
		flex-wrap: wrap;
	}
	.toolbar-grid-item {
		width: 25%;
