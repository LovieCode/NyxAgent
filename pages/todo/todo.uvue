<template>
	<view class="page-shell rice-theme-light">
		<NyxPageHeader :title="activeView == 'todo' ? '待办' : '笔记'" subtitle="把聊天里的灵感和要做的事收好。" />
		<view class="container">
			<!-- 顶部 Segment 切换 -->
			<view class="segment-bar">
				<view :class="['segment-tab', activeView == 'todo' ? 'segment-active' : '']" @click="switchView('todo')">
					<text :class="['segment-text', activeView == 'todo' ? 'segment-text-active' : '']">待办</text>
				</view>
				<view :class="['segment-tab', activeView == 'note' ? 'segment-active' : '']" @click="switchView('note')">
					<text :class="['segment-text', activeView == 'note' ? 'segment-text-active' : '']">笔记</text>
				</view>
			</view>

			<!-- ============ 待办视图 ============ -->
			<view v-if="activeView == 'todo'" class="view-container">
				<!-- 筛选标签 -->
				<view class="filter-bar">
					<view :class="['filter-tab', filter == 'all' ? 'filter-active' : '']" @click="setFilter('all')">
						<text :class="['filter-text', filter == 'all' ? 'filter-text-active' : '']">全部</text>
					</view>
					<view :class="['filter-tab', filter == 'pending' ? 'filter-active' : '']" @click="setFilter('pending')">
						<text :class="['filter-text', filter == 'pending' ? 'filter-text-active' : '']">待办</text>
					</view>
					<view :class="['filter-tab', filter == 'done' ? 'filter-active' : '']" @click="setFilter('done')">
						<text :class="['filter-text', filter == 'done' ? 'filter-text-active' : '']">已完成</text>
					</view>
				</view>

				<!-- Todo 列表 -->
				<scroll-view class="todo-list" :scroll-y="true">
					<view v-if="filteredTodos.length == 0" class="empty-state">
						<text class="empty-text">暂无待办事项</text>
					</view>
					<view v-else>
						<view v-for="(agent, agIdx) in agents" :key="'agent-todo-' + (agent['id'] as string)">
							<view v-if="getAgentTodos(agent['id'] as string).length > 0" class="agent-section-header">
								<text class="agent-section-name">{{ agent['name'] }}</text>
							</view>
							<view
								v-for="todo in getAgentTodos(agent['id'] as string)"
								:key="todo['id'] as string"
								class="todo-item"
								@click="toggleTodo(todo['id'] as string)"
							>
								<view class="todo-left" @click.stop="toggleTodo(todo['id'] as string)">
									<rice-checkbox
										:model-value="(todo['completed'] as boolean)"
										shape="round"
										checked-color="#FB8FAB"
										icon-size="20px"
									/>
								</view>
								<view class="todo-content">
									<text :class="['todo-title', (todo['completed'] as boolean) ? 'todo-title-done' : '']">
										{{ todo['title'] }}
									</text>
									<view class="todo-meta">
										<view v-if="(todo['priority'] as string) == 'high'" class="priority-urgent">
											<text class="priority-urgent-icon">!</text>
											<text class="priority-urgent-text">先做</text>
										</view>
										<text class="todo-time">{{ formatTodoTime(todo['createdAt'] as string) }}</text>
									</view>
								</view>
								<view class="todo-right" @click.stop="deleteTodo(todo['id'] as string)">
									<rice-icon name="delete" size="16px" color="#9CA3AF" />
								</view>
							</view>
						</view>
					</view>
					<view class="tabbar-list-spacer"></view>
				</scroll-view>

				<!-- FAB 悬浮按钮 -->
				<rice-float-fab icon="plus" bg-color="#FB8FAB" :gap-bottom="102" @click="showAddTodoDialog" />

				<!-- 添加待办弹窗 -->
				<rice-dialog
					v-model:show="showAddTodo"
					title="新建待办"
					:show-cancel-button="true"
					:cancel-button-text="'取消'"
					:confirm-button-text="'确认'"
					@confirm="addTodo"
					@cancel="cancelAddTodo"
				>
					<view class="dialog-content">
						<rice-input v-model="newTodoTitle" placeholder="输入待办标题" border="none" />
						<view class="priority-selector">
							<text class="form-label">优先级</text>
							<view class="priority-options">
								<view
									:class="['priority-option', newTodoPriority == 'high' ? 'priority-option-active-high' : '']"
									@click="newTodoPriority = 'high'"
								>
									<text class="priority-option-text">高</text>
								</view>
								<view
									:class="['priority-option', newTodoPriority == 'medium' ? 'priority-option-active-medium' : '']"
									@click="newTodoPriority = 'medium'"
								>
									<text class="priority-option-text">中</text>
								</view>
								<view
									:class="['priority-option', newTodoPriority == 'low' ? 'priority-option-active-low' : '']"
									@click="newTodoPriority = 'low'"
								>
									<text class="priority-option-text">低</text>
								</view>
							</view>
						</view>
						<view class="agent-selector">
							<text class="form-label">所属联系人</text>
							<view class="agent-options">
								<view
									v-for="(agent, agIdx) in agents"
									:key="'at-' + agIdx"
									:class="['agent-option', newTodoAgentIndex == agIdx ? 'agent-option-active' : '']"
									@click="newTodoAgentIndex = agIdx"
								>
									<text class="agent-option-text">{{ agent['name'] }}</text>
								</view>
							</view>
						</view>
					</view>
				</rice-dialog>
			</view>

			<!-- ============ 笔记视图 ============ -->
			<view v-else class="view-container">
				<!-- 搜索栏 -->
				<view class="search-bar">
					<rice-search v-model="searchQuery" placeholder="搜索笔记..." shape="round" :clearable="true" bgColor="transparent" />
				</view>

				<!-- 笔记列表 -->
				<scroll-view class="notes-list" :scroll-y="true">
					<view v-if="filteredNotes.length == 0" class="empty-state">
						<text class="empty-text">{{ searchQuery != '' ? '未找到匹配笔记' : '暂无笔记' }}</text>
					</view>
					<view v-else>
						<view v-for="(agent, agIdx) in agents" :key="'agent-note-' + (agent['id'] as string)">
							<view v-if="getAgentNotes(agent['id'] as string).length > 0" class="agent-section-header">
								<text class="agent-section-name">{{ agent['name'] }}</text>
							</view>
							<view
								v-for="note in getAgentNotes(agent['id'] as string)"
								:key="note['id'] as string"
								class="note-card"
								@click="editNote(note)"
								@longpress="confirmDeleteNote(note['id'] as string)"
							>
								<text class="note-title">{{ note['title'] }}</text>
								<view class="note-render-preview">
									<view
										v-for="(block, blockIndex) in getNoteRenderBlocks(note)"
										:key="'note-block-' + (note['id'] as string) + '-' + blockIndex"
										:class="['note-render-line', block.type == 'todo' ? 'note-render-todo' : '']"
									>
										<view v-if="block.type == 'todo'" :class="['note-checkbox', block.checked ? 'note-checkbox-checked' : '']">
											<text v-if="block.checked" class="note-checkbox-mark">✓</text>
										</view>
										<text v-if="block.type == 'bullet'" class="note-bullet">•</text>
										<text :class="['note-render-text', block.type == 'todo' && block.checked ? 'note-render-text-done' : '', block.type == 'heading' ? 'note-render-heading' : '']">{{ block.text }}</text>
									</view>
								</view>
								<view class="note-meta-row">
									<text class="note-time">{{ note['updatedAt'] }}</text>
									<text v-if="getInlineTodoCount(note) > 0" class="note-todo-count">Todo {{ getInlineTodoCount(note) }}</text>
								</view>
							</view>
						</view>
					</view>
					<view class="tabbar-list-spacer"></view>
				</scroll-view>

				<!-- 添加笔记 FAB -->
				<rice-float-fab icon="plus" bg-color="#FB8FAB" :gap-bottom="102" @click="createNote" />
			</view>
		</view>
		<NyxTabDock current="pages/todo/todo" />
	</view>
</template>

<script lang="uts">
	import { getAgentDir, getUserDir, migrateLegacyUserDir, readContent, writeContent, listDir, deleteItem, joinPath, type FileItem } from '@/utils/file-manager.uts'
	import { parseTodoMarkdown, parseNoteMarkdown, buildTodoMarkdown, buildNoteMarkdown, type KnowledgeRenderBlock } from '@/utils/markdown.uts'
	import { getAgents } from '@/utils/agent.uts'
	import { getAppSetting } from '@/utils/database.uts'
	import {
		applyNoteEditorState,
		buildFilteredNoteList,
		buildFilteredTodoList,
		buildNotePreviewBlocks,
		clearNoteEditorResultRuntimeState,
		clearNoteEditorRuntimeState,
		consumeNoteEditorRuntimeState,
		countNoteInlineTodos,
		filterKnowledgeItemsByAgent,
		formatNoteUpdatedAtNow,
		formatTodoCreatedAt,
		formatTodoCreatedAtNow,
		prepareNoteEditorRuntimeState,
		readNoteEditorStateFromNote,
		type NoteEditorState,
	} from '@/utils/todo-page-helpers.uts'

	/**
	 * 待办 + 笔记 合并页面
	 * 顶部 Segment 切换两个视图，复用 knowledge-workspace 数据层。
	 * 扁平化粉白主题，使用 rice-ui 组件。
	 */

	export default {
		data() {
			return {
				// 视图切换
				activeView: 'todo' as string,

				// 智能体列表
				agents: [] as UTSJSONObject[],

				// 待办数据
				todos: [] as UTSJSONObject[],
				filter: 'all' as string,
				showAddTodo: false as boolean,
				newTodoTitle: '' as string,
				newTodoPriority: 'medium' as string,
				newTodoAgentIndex: 0 as number,

				// 笔记数据
				notes: [] as UTSJSONObject[],
				searchQuery: '' as string,
			}
		},
		computed: {
			filteredTodos() : UTSJSONObject[] {
				return buildFilteredTodoList(this.todos, this.filter)
			},
			filteredNotes() : UTSJSONObject[] {
				return buildFilteredNoteList(this.notes, this.searchQuery)
			}
		},
		onLoad() {
			this.loadAgents()
			this.loadTodos()
			this.loadNotes()
		},
		onShow() {
			this.loadAgents()
			this.loadTodos()
			this.loadNotes()
			this.consumeNoteEditorResult()
		},
		methods: {
			getUserDisplayName(): string {
				const raw = getAppSetting('profile_nickname')
				const name = raw != null ? raw.trim() : ''
				return name != '' ? name : '我'
			},

			/** 加载 agent 列表（预置用户条目在最前） */
			loadAgents() {
				migrateLegacyUserDir()
				const list = getAgents()
				const userEntry = {
					id: '__user__',
					name: this.getUserDisplayName(),
				} as UTSJSONObject
				const result = [userEntry] as UTSJSONObject[]
				for (let i = 0; i < list.length; i++) {
					result.push(list[i])
				}
				this.agents = result
			},

			/** 获取用户/Agent 对应的文件目录 */
			getOwnerDir(ownerId: string): string {
				if (ownerId == '__user__') {
					return getUserDir()
				}
				return getAgentDir(ownerId)
			},

			/** 获取某 agent 的已筛选待办（用于 template） */
			getAgentTodos(agentId: string): UTSJSONObject[] {
				return filterKnowledgeItemsByAgent(this.filteredTodos, agentId)
			},

			/** 获取某 agent 的已筛选笔记（用于 template） */
			getAgentNotes(agentId: string): UTSJSONObject[] {
				return filterKnowledgeItemsByAgent(this.filteredNotes, agentId)
			},
			// ===== 视图切换 =====
			switchView(view : string) {
				if (this.activeView == view) {
					return
				}
				this.activeView = view
				if (view == 'todo') {
					this.loadTodos()
				} else {
					this.loadNotes()
				}
			},

			// ===== 待办相关 =====
			loadTodos() {
				const all: UTSJSONObject[] = []
				for (let ai = 0; ai < this.agents.length; ai++) {
					const agent = this.agents[ai]
					const agentId = agent['id'] as string
					const agentName = agent['name'] as string
					if (agentId == '' || agentName == '') continue
					const agentDir = this.getOwnerDir(agentId)
					if (agentDir == '') continue
					const mdPath = joinPath(agentDir, 'todo.md')
					const content = readContent(mdPath)
					if (content == null || content == '') continue
					const parsed = parseTodoMarkdown(content)
					for (let j = 0; j < parsed.length; j++) {
						const item = parsed[j]
						item['agentId'] = agentId
						item['agentName'] = agentName
						all.push(item)
					}
				}
				this.todos = all
			},

			saveTodosForAgent(agentId: string): boolean {
				if (agentId == '') { return false }
				const agentTodos: UTSJSONObject[] = []
				for (let i = 0; i < this.todos.length; i++) {
					if ((this.todos[i]['agentId'] as string) == agentId) {
						agentTodos.push(this.todos[i])
					}
				}
				const agentDir = this.getOwnerDir(agentId)
				if (agentDir == '') { return false }
				const result = writeContent(joinPath(agentDir, 'todo.md'), buildTodoMarkdown(agentTodos))
				if (result.ok == false) {
					console.log('[Todo] 写入失败: ' + result.error)
				}
				return result.ok
			},

			setFilter(f : string) {
				this.filter = f
			},

			toggleTodo(id : string) {
				let agentId = ''
				for (let i = 0; i < this.todos.length; i++) {
					if ((this.todos[i]['id'] as string) == id) {
						agentId = this.todos[i]['agentId'] as string
						this.todos[i]['completed'] = !((this.todos[i]['completed'] as boolean))
						break
					}
				}
				if (agentId == '') { return }
				if (this.saveTodosForAgent(agentId) == false) {
					this.loadTodos()
					uni.showToast({ position: 'bottom', title: '保存待办失败', icon: 'none' })
				}
			},

			deleteTodo(id : string) {
				uni.showModal({
					title: '确认删除',
					content: '确定要删除这个待办事项吗？',
					success: (res) => {
						if (res.confirm == true) {
							let agentId = ''
							const newTodos = [] as UTSJSONObject[]
							for (let i = 0; i < this.todos.length; i++) {
								if ((this.todos[i]['id'] as string) != id) {
									newTodos.push(this.todos[i])
								} else {
									agentId = this.todos[i]['agentId'] as string
								}
							}
							if (agentId == '') { return }
							this.todos = newTodos
							if (this.saveTodosForAgent(agentId) == false) {
								this.loadTodos()
								uni.showToast({ position: 'bottom', title: '删除待办失败', icon: 'none' })
							}
						}
					},
					fail: () => {
						uni.showToast({ position: 'bottom', title: '无法打开删除确认框', icon: 'none' })
					}
				})
			},

			showAddTodoDialog() {
				this.newTodoTitle = ''
				this.newTodoPriority = 'medium'
				this.showAddTodo = true
			},

			cancelAddTodo() {
				this.showAddTodo = false
			},

			addTodo() {
				if (this.newTodoTitle.trim() == '') {
					uni.showToast({ position: 'bottom',
						title: '请输入标题',
						icon: 'none'
					})
					return
				}
				// 确定所属 agent
				let targetAgent: UTSJSONObject | null = null
				if (this.newTodoAgentIndex >= 0 && this.newTodoAgentIndex < this.agents.length) {
					targetAgent = this.agents[this.newTodoAgentIndex]
				}
				const agentId = targetAgent != null ? (targetAgent['id'] as string) : ''
				const agentName = targetAgent != null ? (targetAgent['name'] as string) : ''
				if (agentId == '' || agentName == '') {
					uni.showToast({ position: 'bottom', title: '请选择所属联系人', icon: 'none' })
					return
				}
				const timeStr = formatTodoCreatedAtNow()
				const newTodo = {
					id: '' + Date.now(),
					title: this.newTodoTitle.trim(),
					priority: this.newTodoPriority,
					completed: false,
					createdAt: timeStr,
					agentId: agentId,
					agentName: agentName
				} as UTSJSONObject
				this.todos.unshift(newTodo)
				if (this.saveTodosForAgent(agentId) == false) {
					this.loadTodos()
					uni.showToast({ position: 'bottom', title: '添加待办失败', icon: 'none' })
					return
				}
				this.showAddTodo = false
				uni.showToast({ position: 'bottom',
					title: '已添加',
					icon: 'success'
				})
			},

			formatTodoTime(value : string) : string {
				return formatTodoCreatedAt(value)
			},


			// ===== 笔记相关 =====
			loadNotes() {
				const all: UTSJSONObject[] = []
				for (let ai = 0; ai < this.agents.length; ai++) {
					const agent = this.agents[ai]
					const agentId = agent['id'] as string
					const agentName = agent['name'] as string
					if (agentId == '' || agentName == '') continue
					const agentDir = this.getOwnerDir(agentId)
					if (agentDir == '') continue
					const notesDir = joinPath(agentDir, 'notes')
					const files = listDir(notesDir)
					for (let fi = 0; fi < files.length; fi++) {
						const file = files[fi] as FileItem
						if (file.isDirectory) continue
						if (file.name.endsWith('.md') == false) { continue }
						const content = readContent(file.path)
						if (content == null) continue
						const noteId = file.name.substring(0, file.name.length - 3)
						const note = parseNoteMarkdown(content, noteId)
						note['agentId'] = agentId
						note['agentName'] = agentName
						all.push(note)
					}
				}
				// 按 updatedAt 降序
				all.sort((a: UTSJSONObject, b: UTSJSONObject): number => {
					const aTime = a['updatedAt'] as string
					const bTime = b['updatedAt'] as string
					if (aTime > bTime) return -1
					if (aTime < bTime) return 1
					return 0
				})
				this.notes = all
			},

			writeNote(note: UTSJSONObject): boolean {
				const noteId = note['id'] as string
				const agentId = note['agentId'] as string
				if (noteId == '' || agentId == '') { return false }
				const agentDir = this.getOwnerDir(agentId)
				if (agentDir == '') { return false }
				const title = note['title'] as string
				const content = note['content'] as string
				const result = writeContent(joinPath(joinPath(agentDir, 'notes'), noteId + '.md'), buildNoteMarkdown(title, content, noteId))
				if (result.ok == false) {
					console.log('[Notes] 写入失败: ' + result.error)
				}
				return result.ok
			},

			formatNow() : string {
				return formatNoteUpdatedAtNow()
			},

			getNoteRenderBlocks(note : UTSJSONObject) : KnowledgeRenderBlock[] {
				return buildNotePreviewBlocks(note)
			},

			getInlineTodoCount(note : UTSJSONObject) : number {
				return countNoteInlineTodos(note)
			},

			openNoteEditor(noteId: string, title: string, content: string, agentId: string) {
				try {
					prepareNoteEditorRuntimeState(noteId, title, content, agentId)
				} catch (_e: any) {
					uni.showToast({ position: 'bottom', title: '无法准备笔记编辑页面', icon: 'none' })
					return
				}
				uni.navigateTo({
					url: '/pages/note-editor/note-editor',
					fail: () => {
						clearNoteEditorRuntimeState()
						uni.showToast({ position: 'bottom', title: '无法打开笔记编辑页面', icon: 'none' })
					}
				})
			},

			consumeNoteEditorResult() {
				const payload = consumeNoteEditorRuntimeState()
				if (payload == null) {
					return
				}
				this.notes = applyNoteEditorState(this.notes, payload, this.formatNow())
				let savedNote: UTSJSONObject | null = null
				for (let i = 0; i < this.notes.length; i++) {
					if ((this.notes[i]['id'] as string) == payload.noteId) {
						savedNote = this.notes[i]
						break
					}
				}
				if (savedNote == null || this.writeNote(savedNote) == false) {
					this.loadNotes()
					uni.showToast({ position: 'bottom', title: '保存笔记失败', icon: 'none' })
					return
				}
				if (clearNoteEditorResultRuntimeState() == false) {
					uni.showToast({ position: 'bottom', title: '笔记已保存，但编辑状态清理失败', icon: 'none' })
					return
				}
				uni.showToast({ position: 'bottom',
					title: '已保存',
					icon: 'success'
				})
			},

			createNote() {
				this.openNoteEditor('', '', '', '__user__')
			},

			editNote(note : UTSJSONObject) {
				const state: NoteEditorState = readNoteEditorStateFromNote(note)
				this.openNoteEditor(state.noteId, state.title, state.content, state.agentId)
			},

			confirmDeleteNote(id : string) {
				uni.showModal({
					title: '确认删除',
					content: '确定要删除这条笔记吗？',
					success: (res) => {
						if (res.confirm == true) {
							this.deleteNote(id)
						}
					},
					fail: () => {
						uni.showToast({ position: 'bottom', title: '无法打开删除确认框', icon: 'none' })
					}
				})
			},

			deleteNote(id : string) {
				let target: UTSJSONObject | null = null
				for (let i = 0; i < this.notes.length; i++) {
					if ((this.notes[i]['id'] as string) == id) {
						target = this.notes[i]
						break
					}
				}
				if (target == null) { return }
				const agentId = target['agentId'] as string
				const agentDir = this.getOwnerDir(agentId)
				if (agentDir == '') {
					uni.showToast({ position: 'bottom', title: '删除笔记失败', icon: 'none' })
					return
				}
				const result = deleteItem(joinPath(joinPath(agentDir, 'notes'), id + '.md'), false)
				if (result.ok == false) {
					uni.showToast({ position: 'bottom', title: '删除笔记失败: ' + result.error, icon: 'none' })
					return
				}
				this.loadNotes()
				uni.showToast({ position: 'bottom',
					title: '已删除',
					icon: 'success'
				})
			}
		}
	}
</script>

