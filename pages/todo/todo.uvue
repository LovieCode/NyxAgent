<template>
	<view class="page-shell rice-theme-light">
		<NavBar :title="activeView == 'todo' ? '待办' : '笔记'" />
		<view class="container">
			<!-- 顶部 Segment 切换 -->
			<view class="segment-bar">
				<view :class="['segment-tab', activeView == 'todo' ? 'segment-active' : '']" @click="switchView('todo')">
					<text :class="['segment-text', activeView == 'todo' ? 'segment-text-active' : '']">待办</text>
				</view>
				<view :class="['segment-tab', activeView == 'note' ? 'segment-active' : '']" @click="switchView('note')">
					<text :class="['segment-text', activeView == 'note' ? 'segment-text-active' : '']">笔记</text>
				</view>
			</view>

			<!-- ============ 待办视图 ============ -->
			<view v-if="activeView == 'todo'" class="view-container">
				<!-- 筛选标签 -->
				<view class="filter-bar">
					<view :class="['filter-tab', filter == 'all' ? 'filter-active' : '']" @click="setFilter('all')">
						<text :class="['filter-text', filter == 'all' ? 'filter-text-active' : '']">全部</text>
					</view>
					<view :class="['filter-tab', filter == 'pending' ? 'filter-active' : '']" @click="setFilter('pending')">
						<text :class="['filter-text', filter == 'pending' ? 'filter-text-active' : '']">待办</text>
					</view>
					<view :class="['filter-tab', filter == 'done' ? 'filter-active' : '']" @click="setFilter('done')">
						<text :class="['filter-text', filter == 'done' ? 'filter-text-active' : '']">已完成</text>
					</view>
				</view>

				<!-- Todo 列表 -->
				<scroll-view class="todo-list" :scroll-y="true">
					<view v-if="filteredTodos.length == 0" class="empty-state">
						<text class="empty-text">暂无待办事项</text>
					</view>
					<view v-else>
						<view v-for="(agent, agIdx) in agents" :key="'agent-todo-' + (agent['id'] as string)">
							<view v-if="getAgentTodos(agent['id'] as string).length > 0" class="agent-section-header">
								<text class="agent-section-name">{{ agent['name'] }}</text>
							</view>
							<view
								v-for="todo in getAgentTodos(agent['id'] as string)"
								:key="todo['id'] as string"
								class="todo-item"
								@click="toggleTodo(todo['id'] as string)"
							>
								<view class="todo-left">
									<rice-checkbox
										:model-value="(todo['completed'] as boolean)"
										shape="round"
										checked-color="#FB8FAB"
										icon-size="40rpx"
										@change="toggleTodo(todo['id'] as string)"
									/>
								</view>
								<view class="todo-content">
									<text :class="['todo-title', (todo['completed'] as boolean) ? 'todo-title-done' : '']">
										{{ todo['title'] }}
									</text>
									<view class="todo-meta">
										<view v-if="(todo['priority'] as string) == 'high'" class="priority-urgent">
											<text class="priority-urgent-icon">!</text>
											<text class="priority-urgent-text">先做</text>
										</view>
										<text class="todo-time">{{ formatTodoTime(todo['createdAt'] as string) }}</text>
									</view>
								</view>
								<view class="todo-right" @click.stop="deleteTodo(todo['id'] as string)">
									<rice-icon name="delete" size="32rpx" color="#9CA3AF" />
								</view>
							</view>
						</view>
					</view>
				</scroll-view>

				<!-- FAB 悬浮按钮 -->
				<rice-float-fab icon="plus" :gap-bottom="80" @click="showAddTodoDialog" />

				<!-- 添加待办弹窗 -->
				<rice-dialog
					v-model:show="showAddTodo"
					title="新建待办"
					:show-cancel-button="true"
					:cancel-button-text="'取消'"
					:confirm-button-text="'确认'"
					@confirm="addTodo"
					@cancel="cancelAddTodo"
				>
					<view class="dialog-content">
						<rice-input v-model="newTodoTitle" placeholder="输入待办标题" border="none" />
						<view class="priority-selector">
							<text class="form-label">优先级</text>
							<view class="priority-options">
								<view
									:class="['priority-option', newTodoPriority == 'high' ? 'priority-option-active-high' : '']"
									@click="newTodoPriority = 'high'"
								>
									<text class="priority-option-text">高</text>
								</view>
								<view
									:class="['priority-option', newTodoPriority == 'medium' ? 'priority-option-active-medium' : '']"
									@click="newTodoPriority = 'medium'"
								>
									<text class="priority-option-text">中</text>
								</view>
								<view
									:class="['priority-option', newTodoPriority == 'low' ? 'priority-option-active-low' : '']"
									@click="newTodoPriority = 'low'"
								>
									<text class="priority-option-text">低</text>
								</view>
							</view>
						</view>
						<view class="agent-selector">
							<text class="form-label">所属智能体</text>
							<view class="agent-options">
								<view
									v-for="(agent, agIdx) in agents"
									:key="'at-' + agIdx"
									:class="['agent-option', newTodoAgentIndex == agIdx ? 'agent-option-active' : '']"
									@click="newTodoAgentIndex = agIdx"
								>
									<text class="agent-option-text">{{ agent['name'] }}</text>
								</view>
							</view>
						</view>
					</view>
				</rice-dialog>
			</view>

			<!-- ============ 笔记视图 ============ -->
			<view v-else class="view-container">
				<!-- 搜索栏 -->
				<view class="search-bar">
					<rice-search v-model="searchQuery" placeholder="搜索笔记..." shape="round" :clearable="true" bgColor="transparent" />
				</view>

				<!-- 笔记列表 -->
				<scroll-view class="notes-list" :scroll-y="true">
					<view v-if="filteredNotes.length == 0" class="empty-state">
						<text class="empty-text">{{ searchQuery != '' ? '未找到匹配笔记' : '暂无笔记' }}</text>
					</view>
					<view v-else>
						<view v-for="(agent, agIdx) in agents" :key="'agent-note-' + (agent['id'] as string)">
							<view v-if="getAgentNotes(agent['id'] as string).length > 0" class="agent-section-header">
								<text class="agent-section-name">{{ agent['name'] }}</text>
							</view>
							<view
								v-for="note in getAgentNotes(agent['id'] as string)"
								:key="note['id'] as string"
								class="note-card"
								@click="editNote(note)"
								@longpress="confirmDeleteNote(note['id'] as string)"
							>
								<text class="note-title">{{ note['title'] }}</text>
								<view class="note-render-preview">
									<view
										v-for="(block, blockIndex) in getNoteRenderBlocks(note)"
										:key="'note-block-' + (note['id'] as string) + '-' + blockIndex"
										:class="['note-render-line', block.type == 'todo' ? 'note-render-todo' : '']"
									>
										<view v-if="block.type == 'todo'" :class="['note-checkbox', block.checked ? 'note-checkbox-checked' : '']">
											<text v-if="block.checked" class="note-checkbox-mark">✓</text>
										</view>
										<text v-if="block.type == 'bullet'" class="note-bullet">•</text>
										<text :class="['note-render-text', block.type == 'todo' && block.checked ? 'note-render-text-done' : '', block.type == 'heading' ? 'note-render-heading' : '']">{{ block.text }}</text>
									</view>
								</view>
								<view class="note-meta-row">
									<text class="note-time">{{ note['updatedAt'] }}</text>
									<text v-if="getInlineTodoCount(note) > 0" class="note-todo-count">Todo {{ getInlineTodoCount(note) }}</text>
								</view>
							</view>
						</view>
					</view>
				</scroll-view>

				<!-- 添加笔记 FAB -->
				<rice-float-fab icon="plus" bg-color="#FB8FAB" :gap-bottom="80" @click="createNote" />
			</view>
		</view>
		<TabBar current="pages/todo/todo" />
	</view>
</template>

<script lang="uts">
	import { getAgentDir, getUserDir, migrateLegacyUserDir, readContent, writeContent, listDir, deleteItem, joinPath, type FileItem } from '@/utils/file-manager.uts'
	import { renderKnowledgeMarkdown, countInlineTodos, parseTodoMarkdown, parseNoteMarkdown, buildTodoMarkdown, buildNoteMarkdown, type KnowledgeRenderBlock } from '@/utils/markdown.uts'
	import { getAgents } from '@/utils/agent.uts'

	/** 虚拟用户条目，显示在所有 agent 之前 */
	const USER_AGENT_ENTRY: UTSJSONObject = {
		id: '__user__',
		name: '用户',
	} as UTSJSONObject

	/**
	 * 待办 + 笔记 合并页面
	 * 顶部 Segment 切换两个视图，复用 knowledge-workspace 数据层。
	 * 扁平化粉白主题，使用 rice-ui 组件。
	 */

	export default {
		data() {
			return {
				// 视图切换
				activeView: 'todo' as string,

				// 智能体列表
				agents: [] as UTSJSONObject[],

				// 待办数据
				todos: [] as UTSJSONObject[],
				filter: 'all' as string,
				showAddTodo: false as boolean,
				newTodoTitle: '' as string,
				newTodoPriority: 'medium' as string,
				newTodoAgentIndex: 0 as number,

				// 笔记数据
				notes: [] as UTSJSONObject[],
				searchQuery: '' as string,
			}
		},
		computed: {
			filteredTodos() : UTSJSONObject[] {
				let list: UTSJSONObject[] = []
				if (this.filter == 'pending') {
					list = this.todos.filter((todo : UTSJSONObject) : boolean => {
						return (todo['completed'] as boolean) == false
					})
				} else if (this.filter == 'done') {
					list = this.todos.filter((todo : UTSJSONObject) : boolean => {
						return (todo['completed'] as boolean) == true
					})
				} else {
					for (let i = 0; i < this.todos.length; i++) {
						list.push(this.todos[i])
					}
				}
				list.sort((a: UTSJSONObject, b: UTSJSONObject): number => {
					const aDone = a['completed'] as boolean
					const bDone = b['completed'] as boolean
					if (aDone != bDone) {
						return aDone ? 1 : -1
					}
					const aScore = this.getPriorityScore(a['priority'] as string)
					const bScore = this.getPriorityScore(b['priority'] as string)
					if (aScore != bScore) {
						return bScore - aScore
					}
					const aTime = a['createdAt'] as string
					const bTime = b['createdAt'] as string
					if (aTime > bTime) return -1
					if (aTime < bTime) return 1
					return 0
				})
				return list
			},
			filteredNotes() : UTSJSONObject[] {
				if (this.searchQuery == '') {
					return this.notes
				}
				let query = this.searchQuery.toLowerCase()
				return this.notes.filter((note : UTSJSONObject) : boolean => {
					let title = (note['title'] as string).toLowerCase()
					let content = (note['content'] as string).toLowerCase()
					return title.indexOf(query) >= 0 || content.indexOf(query) >= 0
				})
			}
		},
		onLoad() {
			this.loadAgents()
			this.loadTodos()
			this.loadNotes()
		},
		onShow() {
			this.loadAgents()
			this.loadTodos()
			this.loadNotes()
			this.consumeNoteEditorResult()
		},
		methods: {
			/** 加载 agent 列表（预置用户条目在最前） */
			loadAgents() {
				migrateLegacyUserDir()
				const list = getAgents()
				const result = [USER_AGENT_ENTRY] as UTSJSONObject[]
				for (let i = 0; i < list.length; i++) {
					result.push(list[i])
				}
				this.agents = result
			},

			/** 获取用户/Agent 对应的文件目录 */
			getOwnerDir(ownerId: string): string {
				if (ownerId == '__user__') {
					return getUserDir()
				}
				return getAgentDir(ownerId)
			},

			/** 获取某 agent 的已筛选待办（用于 template） */
			getAgentTodos(agentId: string): UTSJSONObject[] {
				const result: UTSJSONObject[] = []
				for (let i = 0; i < this.filteredTodos.length; i++) {
					if ((this.filteredTodos[i]['agentId'] as string) == agentId) {
						result.push(this.filteredTodos[i])
					}
				}
				return result
			},

			/** 获取某 agent 的已筛选笔记（用于 template） */
			getAgentNotes(agentId: string): UTSJSONObject[] {
				const result: UTSJSONObject[] = []
				for (let i = 0; i < this.filteredNotes.length; i++) {
					if ((this.filteredNotes[i]['agentId'] as string) == agentId) {
						result.push(this.filteredNotes[i])
					}
				}
				return result
			},
			// ===== 视图切换 =====
			switchView(view : string) {
				if (this.activeView == view) {
					return
				}
				this.activeView = view
				if (view == 'todo') {
					this.loadTodos()
				} else {
					this.loadNotes()
				}
			},

			// ===== 待办相关 =====
			loadTodos() {
				const all: UTSJSONObject[] = []
				for (let ai = 0; ai < this.agents.length; ai++) {
					const agent = this.agents[ai]
					const agentId = agent['id'] as string
					const agentName = agent['name'] as string
					if (agentId == '' || agentName == '') continue
					const agentDir = this.getOwnerDir(agentId)
					if (agentDir == '') continue
					const mdPath = joinPath(agentDir, 'todo.md')
					const content = readContent(mdPath)
					if (content == null || content == '') continue
					const parsed = parseTodoMarkdown(content)
					for (let j = 0; j < parsed.length; j++) {
						const item = parsed[j]
						item['agentId'] = agentId
						item['agentName'] = agentName
						all.push(item)
					}
				}
				this.todos = all
			},

			saveTodos() {
				for (let ai = 0; ai < this.agents.length; ai++) {
					const agentId = this.agents[ai]['id'] as string
					if (agentId == '') continue
					const agentTodos: UTSJSONObject[] = []
					for (let j = 0; j < this.todos.length; j++) {
						if ((this.todos[j]['agentId'] as string) == agentId) {
							agentTodos.push(this.todos[j])
						}
					}
					const agentDir = this.getOwnerDir(agentId)
					if (agentDir == '') continue
					const markdown = buildTodoMarkdown(agentTodos)
					writeContent(joinPath(agentDir, 'todo.md'), markdown)
				}
			},

			setFilter(f : string) {
				this.filter = f
			},

			toggleTodo(id : string) {
				for (let i = 0; i < this.todos.length; i++) {
					if ((this.todos[i]['id'] as string) == id) {
						this.todos[i]['completed'] = !((this.todos[i]['completed'] as boolean))
						break
					}
				}
				this.saveTodos()
			},

			deleteTodo(id : string) {
				uni.showModal({
					title: '确认删除',
					content: '确定要删除这个待办事项吗？',
					success: (res) => {
						if (res.confirm == true) {
							let newTodos = [] as UTSJSONObject[]
							for (let i = 0; i < this.todos.length; i++) {
								if ((this.todos[i]['id'] as string) != id) {
									newTodos.push(this.todos[i])
								}
							}
							this.todos = newTodos
							this.saveTodos()
						}
					}
				})
			},

			showAddTodoDialog() {
				this.newTodoTitle = ''
				this.newTodoPriority = 'medium'
				this.showAddTodo = true
			},

			cancelAddTodo() {
				this.showAddTodo = false
			},

			addTodo() {
				if (this.newTodoTitle.trim() == '') {
					uni.showToast({ position: 'bottom',
						title: '请输入标题',
						icon: 'none'
					})
					return
				}
				// 确定所属 agent
				let targetAgent: UTSJSONObject | null = null
				if (this.newTodoAgentIndex >= 0 && this.newTodoAgentIndex < this.agents.length) {
					targetAgent = this.agents[this.newTodoAgentIndex]
				}
				const agentId = targetAgent != null ? (targetAgent['id'] as string) : ''
				const agentName = targetAgent != null ? (targetAgent['name'] as string) : ''
				let now = new Date()
				let timeStr = now.getFullYear() + '-' +
					this.padZero(now.getMonth() + 1) + '-' +
					this.padZero(now.getDate()) + ' ' +
					this.padZero(now.getHours()) + ':' +
					this.padZero(now.getMinutes()) + ':' +
					this.padZero(now.getSeconds())
				let newTodo = {
					id: '' + Date.now(),
					title: this.newTodoTitle.trim(),
					priority: this.newTodoPriority,
					completed: false,
					createdAt: timeStr,
					agentId: agentId,
					agentName: agentName
				} as UTSJSONObject
				this.todos.unshift(newTodo)
				this.saveTodos()
				this.showAddTodo = false
				uni.showToast({ position: 'bottom',
					title: '已添加',
					icon: 'success'
				})
			},

			getPriorityLabel(priority : string) : string {
				if (priority == 'high') {
					return '高'
				} else if (priority == 'medium') {
					return '中'
				}
				return '低'
			},

			getPriorityScore(priority : string) : number {
				if (priority == 'high') {
					return 3
				}
				if (priority == 'medium') {
					return 2
				}
				return 1
			},

			formatTodoTime(value : string) : string {
				if (value.length == 16) {
					return value + ':00'
				}
				return value
			},


			// ===== 笔记相关 =====
			loadNotes() {
				const all: UTSJSONObject[] = []
				for (let ai = 0; ai < this.agents.length; ai++) {
					const agent = this.agents[ai]
					const agentId = agent['id'] as string
					const agentName = agent['name'] as string
					if (agentId == '' || agentName == '') continue
					const agentDir = this.getOwnerDir(agentId)
					if (agentDir == '') continue
					const notesDir = joinPath(agentDir, 'notes')
					const files = listDir(notesDir)
					for (let fi = 0; fi < files.length; fi++) {
						const file = files[fi] as FileItem
						if (file.isDirectory) continue
						if (!file.name.endsWith('.md')) continue
						const content = readContent(file.path)
						if (content == null) continue
						const noteId = file.name.substring(0, file.name.length - 3)
						const note = parseNoteMarkdown(content, noteId)
						note['agentId'] = agentId
						note['agentName'] = agentName
						all.push(note)
					}
				}
				// 按 updatedAt 降序
				all.sort((a: UTSJSONObject, b: UTSJSONObject): number => {
					const aTime = a['updatedAt'] as string
					const bTime = b['updatedAt'] as string
					if (aTime > bTime) return -1
					if (aTime < bTime) return 1
					return 0
				})
				this.notes = all
			},

			saveNotes() {
				for (let ai = 0; ai < this.agents.length; ai++) {
					const agentId = this.agents[ai]['id'] as string
					if (agentId == '') continue
					// 筛选此 agent 的笔记
					const notes: UTSJSONObject[] = []
					for (let ni = 0; ni < this.notes.length; ni++) {
						if ((this.notes[ni]['agentId'] as string) == agentId) {
							notes.push(this.notes[ni])
						}
					}
					const agentDir = this.getOwnerDir(agentId)
					if (agentDir == '') continue
					const notesDir = joinPath(agentDir, 'notes')
					// 收集当前笔记 ID
					const currentIds: string[] = []
					for (let ni = 0; ni < notes.length; ni++) {
						currentIds.push(notes[ni]['id'] as string)
					}
					// 清理已删除的文件
					const existingFiles = listDir(notesDir)
					for (let ei = 0; ei < existingFiles.length; ei++) {
						const file = existingFiles[ei] as FileItem
						if (file.isDirectory) continue
						if (!file.name.endsWith('.md')) continue
						const noteId = file.name.substring(0, file.name.length - 3)
						let found = false
						for (let ci = 0; ci < currentIds.length; ci++) {
							if (currentIds[ci] == noteId) {
								found = true
								break
							}
						}
						if (!found) {
							deleteItem(file.path, false)
						}
					}
					// 写入当前笔记
					for (let ni = 0; ni < notes.length; ni++) {
						const note = notes[ni]
						const noteId = note['id'] as string
						const title = note['title'] as string
						const content = note['content'] as string
						const md = buildNoteMarkdown(title, content, noteId)
						const filePath = joinPath(notesDir, noteId + '.md')
						writeContent(filePath, md)
					}
				}
			},

			formatNow() : string {
				let now = new Date()
				return now.getFullYear() + '-' +
					this.padZero(now.getMonth() + 1) + '-' +
					this.padZero(now.getDate()) + ' ' +
					this.padZero(now.getHours()) + ':' +
					this.padZero(now.getMinutes())
			},

			getNoteRenderBlocks(note : UTSJSONObject) : KnowledgeRenderBlock[] {
				const content = note['content'] as string | null
				if (content == null || content == '') {
					return [] as KnowledgeRenderBlock[]
				}
				const blocks = renderKnowledgeMarkdown(content)
				const result: KnowledgeRenderBlock[] = []
				for (let i = 0; i < blocks.length && result.length < 4; i++) {
					const block = blocks[i] as KnowledgeRenderBlock
					result.push(block)
				}
				return result
			},

			getInlineTodoCount(note : UTSJSONObject) : number {
				const content = note['content'] as string | null
				if (content == null || content == '') {
					return 0
				}
				return countInlineTodos(content)
			},

			clearNoteEditorStorage() {
				uni.removeStorageSync('note_editor_id')
				uni.removeStorageSync('note_editor_title')
				uni.removeStorageSync('note_editor_content')
				uni.removeStorageSync('note_editor_agent_id')
				uni.removeStorageSync('note_editor_result')
			},

			openNoteEditor(noteId: string, title: string, content: string, agentId: string) {
				this.clearNoteEditorStorage()
				uni.setStorageSync('note_editor_id', noteId)
				uni.setStorageSync('note_editor_title', title)
				uni.setStorageSync('note_editor_content', content)
				uni.setStorageSync('note_editor_agent_id', agentId)
				uni.navigateTo({
					url: '/pages/note-editor/note-editor'
				})
			},

			consumeNoteEditorResult() {
				const raw = uni.getStorageSync('note_editor_result') as string | null
				if (raw == null || raw == '') {
					return
				}

				uni.removeStorageSync('note_editor_result')

				try {
					const payload = JSON.parse(raw) as UTSJSONObject
					const noteIdValue = payload['id'] as string | null
					const titleValue = payload['title'] as string | null
					const contentValue = payload['content'] as string | null
					const agentIdValue = payload['agentId'] as string | null
					const agentNameValue = payload['agentName'] as string | null

					let noteId = ''
					if (noteIdValue != null) {
						noteId = noteIdValue
					}
					let title = ''
					if (titleValue != null) {
						title = titleValue.trim()
					}
					if (title == '') {
						title = '无标题'
					}
					let content = ''
					if (contentValue != null) {
						content = contentValue
					}
					if (content.trim() == '') {
						return
					}
					let agentId = '__user__'
					if (agentIdValue != null) {
						if (agentIdValue != '') {
							agentId = agentIdValue
						}
					}
					let agentName = ''
					if (agentNameValue != null) {
						agentName = agentNameValue
					}
					if (agentName == '') {
						agentName = '用户'
					}
					const timeStr = this.formatNow()

					if (noteId == '') {
						const newNote = {
							id: '' + Date.now(),
							title: title,
							content: content,
							updatedAt: timeStr,
							agentId: agentId,
							agentName: agentName
						} as UTSJSONObject
						this.notes.unshift(newNote)
					} else {
						let updated = false
						for (let i = 0; i < this.notes.length; i++) {
							if ((this.notes[i]['id'] as string) == noteId) {
								this.notes[i]['title'] = title
								this.notes[i]['content'] = content
								this.notes[i]['updatedAt'] = timeStr
								this.notes[i]['agentId'] = agentId
								this.notes[i]['agentName'] = agentName
								updated = true
								break
							}
						}
						if (!updated) {
							const restoredNote = {
								id: noteId,
								title: title,
								content: content,
								updatedAt: timeStr,
								agentId: agentId,
								agentName: agentName
							} as UTSJSONObject
							this.notes.unshift(restoredNote)
						}
					}

					this.saveNotes()
					uni.showToast({ position: 'bottom',
						title: '已保存',
						icon: 'success'
					})
				} catch (_e: any) {
				}
			},

			createNote() {
				this.openNoteEditor('', '', '', '__user__')
			},

			editNote(note : UTSJSONObject) {
				const noteIdValue = note['id'] as string | null
				const titleValue = note['title'] as string | null
				const contentValue = note['content'] as string | null
				const agentIdValue = note['agentId'] as string | null
				let noteId = ''
				if (noteIdValue != null) {
					noteId = noteIdValue
				}
				let title = ''
				if (titleValue != null) {
					title = titleValue
				}
				let content = ''
				if (contentValue != null) {
					content = contentValue
				}
				let agentId = '__user__'
				if (agentIdValue != null) {
					if (agentIdValue != '') {
						agentId = agentIdValue
					}
				}
				this.openNoteEditor(noteId, title, content, agentId)
			},

			confirmDeleteNote(id : string) {
				uni.showModal({
					title: '确认删除',
					content: '确定要删除这条笔记吗？',
					success: (res) => {
						if (res.confirm == true) {
							this.deleteNote(id)
						}
					}
				})
			},

			deleteNote(id : string) {
				let newNotes = [] as UTSJSONObject[]
				for (let i = 0; i < this.notes.length; i++) {
					if ((this.notes[i]['id'] as string) != id) {
						newNotes.push(this.notes[i])
					}
				}
				this.notes = newNotes
				this.saveNotes()
				uni.showToast({ position: 'bottom',
					title: '已删除',
					icon: 'success'
				})
			},

			// ===== 通用 =====
			padZero(n : number) : string {
				if (n < 10) {
					return '0' + n
				}
				return '' + n
			}
		}
	}
</script>

