<template>
	<view class="page-shell rice-theme-light">
		<NavBar :title="headerTitle" showBack @back="goBack">
			<template #right>
				<view style="flex-direction:row;align-items:center;">
					<view class="nav-icon-btn" @click="goSessions">
						<oui-icon-unix name="time-circle" size="40rpx" color="#FFFFFF" />
					</view>
					<view class="nav-icon-btn" @click="goSettings" style="margin-left:8rpx;">
						<oui-icon-unix name="setting" size="40rpx" color="#FFFFFF" />
					</view>
				</view>
			</template>
		</NavBar>

		<scroll-view class="message-list" :scroll-y="true" :scroll-top="scrollTop" @scroll="onMsgScroll">
			<view v-for="(msg, index) in visibleMessages" :key="msg.id != null ? msg.id : index">
				<ChatBubble
					:role="msg.role"
					:content="msg.content != null ? msg.content : ''"
					:parts="getMessagePartsForView(msg)"
					:agentAvatar="msg.senderAvatar != null ? msg.senderAvatar : ''"
					:assistantName="isAgentMessage(msg) ? readMessageSenderName(msg) : ''"
					:userNickname="userNickname"
					:userDisplayName="isUserMessage(msg) ? readUserMessageSenderName(msg) : ''"
					:userAvatar="userAvatar"
					:toolName="msg.toolName != null ? msg.toolName : ''"
					:hideThinking="readMessageHideThinking(msg)"
					:msgSegmentation="readMessageMsgSegmentation(msg)"
					:isError="msg.isError == true"
					:isStreaming="msg.isStreaming == true"
					:cancelToken="longpressCancelToken"
					@bubbleLongpress="onMessageLongpress(msg)"
					@avatarClick="openAgentPrivateChat(msg)"
				/>
			</view>
			<view v-if="visibleMessages.length == 0" class="empty-state">
				<text class="empty-text">{{emptyTitle}}</text>
				<text class="empty-hint">发一句话，调度 Agent 会在幕后安排成员接招。</text>
			</view>
		</scroll-view>

		<view class="chat-bottom">
			<view class="input-bar">
				<view class="toolbar-toggle" @click="toggleToolPanel">
					<oui-icon-unix name="plus" size="36rpx" color="#374151" />
				</view>
				<view class="input-wrap">
					<textarea class="text-input" v-model="inputText" :style="{ height: inputHeight + 'px' }" placeholder="给群里发消息..." placeholder-style="color:var(--rice-text-color-3)" @linechange="onInputLineChange" :disabled="isGenerating == true" />
				</view>
				<rice-button v-if="isGenerating == false" type="primary" text="发送" size="small" shape="round" @click="sendMessage" style="margin-left:12rpx" />
				<rice-button v-else type="primary" text="停止" size="small" shape="round" @click="stopDiscussion" style="margin-left:12rpx" />
			</view>
			<view v-if="showToolPanel" class="toolbar-panel">
				<view id="toolbar-slider-viewport" class="toolbar-slider-viewport" @touchstart="onToolbarTouchStart" @touchmove="onToolbarTouchMove" @touchend="onToolbarTouchEnd" @touchcancel="onToolbarTouchCancel">
					<view class="toolbar-slider-track" :class="toolbarDragging == true ? '' : 'toolbar-slider-track-anim'" :style="toolbarTrackStyle">
						<view class="toolbar-slide-page">
							<view class="toolbar-grid">
								<view class="toolbar-grid-item" @click="pickImage">
									<view class="toolbar-grid-icon"><oui-icon-unix name="image" size="52rpx" color="var(--rice-primary-color)" /></view>
									<text class="toolbar-grid-label">图片</text>
								</view>
								<view class="toolbar-grid-item" @click="takePhoto">
									<view class="toolbar-grid-icon"><oui-icon-unix name="camera" size="52rpx" color="var(--rice-primary-color)" /></view>
									<text class="toolbar-grid-label">拍照</text>
								</view>
								<view class="toolbar-grid-item" @click="pickFile">
									<view class="toolbar-grid-icon"><oui-icon-unix name="file" size="52rpx" color="var(--rice-primary-color)" /></view>
									<text class="toolbar-grid-label">文件</text>
								</view>
								<view class="toolbar-grid-item" @click="chooseAgentForMemory">
									<view class="toolbar-grid-icon"><oui-icon-unix name="file-text" size="52rpx" color="var(--rice-primary-color)" /></view>
									<text class="toolbar-grid-label">记忆管理</text>
								</view>
								<view class="toolbar-grid-item" @click="chooseAgentForContext">
									<view class="toolbar-grid-icon"><oui-icon-unix name="eye" size="52rpx" color="var(--rice-primary-color)" /></view>
									<text class="toolbar-grid-label">原始上下文</text>
								</view>
								<view class="toolbar-grid-item" @click="openGroupWorkspace">
									<view class="toolbar-grid-icon"><oui-icon-unix name="folder" size="52rpx" color="var(--rice-primary-color)" /></view>
									<text class="toolbar-grid-label">工作区</text>
								</view>
								<view class="toolbar-grid-item" @click="stopDiscussion">
									<view class="toolbar-grid-icon"><oui-icon-unix name="stop" size="52rpx" color="#EF4444" /></view>
									<text class="toolbar-grid-label">停止讨论</text>
								</view>
								<view class="toolbar-grid-item" @click="continueDiscussion">
									<view class="toolbar-grid-icon"><oui-icon-unix name="plus-circle" size="52rpx" color="var(--rice-primary-color)" /></view>
									<text class="toolbar-grid-label">继续讨论</text>
								</view>
							</view>
						</view>
						<view class="toolbar-slide-page">
							<view class="toolbar-grid">
								<view class="toolbar-grid-item" @click="goSessions">
									<view class="toolbar-grid-icon"><oui-icon-unix name="time-circle" size="52rpx" color="var(--rice-primary-color)" /></view>
									<text class="toolbar-grid-label">会话分支</text>
								</view>
								<view class="toolbar-grid-item" @click="goSettings">
									<view class="toolbar-grid-icon"><oui-icon-unix name="setting" size="52rpx" color="var(--rice-primary-color)" /></view>
									<text class="toolbar-grid-label">群聊设置</text>
								</view>
								<view class="toolbar-grid-item" @click="showDispatchHistory">
									<view class="toolbar-grid-icon"><oui-icon-unix name="file-text" size="52rpx" color="var(--rice-primary-color)" /></view>
									<text class="toolbar-grid-label">调度历史</text>
								</view>
							</view>
						</view>
					</view>
				</view>
				<view class="toolbar-pager">
					<view class="toolbar-page-arrow" :class="toolbarPageIndex == 0 ? 'toolbar-page-arrow-disabled' : ''" @click="prevToolbarPage">
						<text class="toolbar-page-arrow-text">‹</text>
					</view>
					<view class="toolbar-page-dot" :class="toolbarPageIndex == 0 ? 'toolbar-page-dot-active' : ''" @click="setToolbarPage(0)" />
					<view class="toolbar-page-dot" :class="toolbarPageIndex == 1 ? 'toolbar-page-dot-active' : ''" @click="setToolbarPage(1)" />
					<view class="toolbar-page-arrow" :class="toolbarPageIndex == 1 ? 'toolbar-page-arrow-disabled' : ''" @click="nextToolbarPage">
						<text class="toolbar-page-arrow-text">›</text>
					</view>
				</view>
			</view>
		</view>
	</view>
</template>

<script lang="uts">
	import { agentChat, readLastLLMRequestSnapshot, captionImage, appendResponseToSnapshot } from '@/uni_modules/agent-core/utssdk/llm-client.uts'
	import { AgentEvent, AgentEventStream } from '@/utils/event.uts'
	import { getAgentById } from '@/utils/agent.uts'
	import { loadChatUserProfile } from '@/utils/chat-conversation-service.uts'
	import { buildChatDatetimePrefix } from '@/utils/datetime-context.uts'
	import { CHAT_ROLE_ASSISTANT, createPlainPart, getMessageContent, getMessageParts, getMessageThinking, setImageMessageCaption } from '@/utils/chat-models.uts'
	import { reduceAgentEvent, finalizeAssistantTurn } from '@/utils/chat-message-reducer.uts'
	import { detectSchedulerLeakCandidate, getSchedulerLeakHoldSize } from '@/utils/group-chat-moderation.uts'
	import { setActiveAgentRuntimeId, setContextPreviewPayload, setFilesInitialPath, setMemoryRouteState } from '@/utils/runtime-state.uts'
	import {
		GROUP_MESSAGE_SENDER_AGENT,
		GROUP_MESSAGE_SENDER_REVIEWER,
		GROUP_MESSAGE_SENDER_SCHEDULER,
		GROUP_MESSAGE_SENDER_USER,
		type GroupChat,
		type GroupChatSession,
		applyGroupSessionTitleSuggestion,
		buildGroupReviewMessages,
		buildGroupReviewSystemPrompt,
		buildMemberRuntimeMessages,
		buildMemberSystemPrompt,
		buildSchedulerRuntimeMessages,
		buildSchedulerReviewMessages,
		buildSchedulerReviewSystemPrompt,
		createGroupAgentContextRecord,
		buildSchedulerSystemPrompt,
		createDefaultWritingGroupChat,
		createGroupAgentStreamingMessage,
		createGroupHiddenMessage,
		createGroupUserFileMessage,
		createGroupUserImageMessage,
		createGroupUserMessage,
		displaySessionTitle,
		ensureGroupActiveSession,
		getActiveGroupMembers,
		getActiveGroupChatId,
		getGroupChatById,
		getGroupMessages,
		getGroupSessionById,
		getGroupSessionWorkspaceDir,
		getVisibleGroupMessages,
		parseGroupReviewDecision,
		parseSchedulerDecision,
		parseSchedulerReviewDecision,
		persistGroupReviewEffects,
		recordGroupAgentSpeak,
		isAgentInGroup,
		markGroupAgentMessageRevoked,
		readAgentModel,
		readAgentName,
		readAgentInjectDatetime,
		readAgentMsgSegmentation,
		revokeGroupAgentMessage,
		saveGroupAgentContextRecord,
		saveGroupMessages,
		setActiveGroupChat,
		setActiveGroupSessionId,
		syncGroupStreamingMessage,
	} from '@/utils/group-chat-service.uts'

	export default {
		data() {
			return {
				groupId: '' as string,
				sessionId: '' as string,
				group: null as GroupChat | null,
				session: null as GroupChatSession | null,
				messages: [] as UTSJSONObject[],
				inputText: '' as string,
				inputHeight: 40 as number,
				isGenerating: false as boolean,
				showToolPanel: false as boolean,
				toolbarPageIndex: 0 as number,
				toolbarTouchStartX: 0 as number,
				toolbarTouchStartY: 0 as number,
				toolbarTouchCurrentX: 0 as number,
				toolbarDragOffset: 0 as number,
				toolbarViewportWidth: 0 as number,
				toolbarDragging: false as boolean,
				toolbarSwipeMoved: false as boolean,
				toolbarSwipeLockedUntil: 0 as number,
				scrollTop: 0 as number,
				longpressCancelToken: 0 as number,
				currentStream: null as AgentEventStream | null,
				loopTurns: 0 as number,
				discussionStopped: false as boolean,
				userNickname: '' as string,
				userAvatar: '' as string,
				imageCaptionTaskId: 0 as number,
			}
		},
		computed: {
			headerTitle(): string {
				const session = this.session
				return session != null ? displaySessionTitle(session) : '群聊'
			},
			emptyTitle(): string {
				const group = this.group
				return group != null ? group.name : '群聊'
			},
			visibleMessages(): UTSJSONObject[] {
				return getVisibleGroupMessages(this.messages)
			},
			toolbarTrackStyle(): string {
				let width = this.toolbarViewportWidth
				if (width <= 0) { width = 375 }
				const base = -this.toolbarPageIndex * width
				const offset = base + this.toolbarDragOffset
				return 'transform: translateX(' + offset + 'px);'
			}
		},
		onLoad() {
			this.loadUserProfile()
			this.loadGroup()
		},
		onShow() {
			this.loadUserProfile()
			this.loadGroup()
		},
		methods: {
			loadUserProfile(): void {
				const profile = loadChatUserProfile()
				this.userNickname = profile.nickname
				this.userAvatar = profile.avatar
			},
			loadGroup(): void {
				let groupId = getActiveGroupChatId()
				if (groupId == '') {
					const group = createDefaultWritingGroupChat()
					groupId = group.id
					setActiveGroupChat(group.id)
				}
				let group = getGroupChatById(groupId)
				if (group == null) {
					group = createDefaultWritingGroupChat()
					groupId = group.id
					setActiveGroupChat(group.id)
				}
				const session = ensureGroupActiveSession(group)
				this.groupId = group.id
				this.sessionId = session.id
				this.group = group
				this.session = session
				setActiveGroupSessionId(session.id)
				this.messages = getGroupMessages(group.id, session.id)
				this.normalizeUserSenderNames()
				this.scrollToBottom()
			},
			goBack(): void { uni.navigateBack() },
			goSettings(): void {
				if (this.consumeToolbarSwipeClick() == true) { return }
				uni.navigateTo({ url: '/pages/group-chat-settings/group-chat-settings' })
			},
			goSessions(): void {
				if (this.consumeToolbarSwipeClick() == true) { return }
				uni.navigateTo({ url: '/pages/group-chat-sessions/group-chat-sessions' })
			},
			toggleToolPanel(): void {
				this.showToolPanel = !this.showToolPanel
				if (this.showToolPanel == true) {
					this.toolbarPageIndex = 0
					this.toolbarDragOffset = 0
					this.measureToolbarViewport()
				}
			},
			setToolbarPage(index: number): void {
				if (index < 0 || index > 1) { return }
				this.toolbarPageIndex = index
				this.toolbarDragOffset = 0
				this.toolbarDragging = false
			},
			prevToolbarPage(): void {
				if (this.toolbarPageIndex <= 0) { return }
				this.setToolbarPage(this.toolbarPageIndex - 1)
			},
			nextToolbarPage(): void {
				if (this.toolbarPageIndex >= 1) { return }
				this.setToolbarPage(this.toolbarPageIndex + 1)
			},
			measureToolbarViewport(): void {
				setTimeout(() => {
					const query = uni.createSelectorQuery().in(this)
					query.select('#toolbar-slider-viewport').boundingClientRect()
					query.exec((res: any) => {
						const rows = res as UTSArray<any> | null
						if (rows == null || rows.length == 0) { return }
						const rect = rows[0] as NodeInfo | null
						if (rect == null) { return }
						const width = rect.width as number | null
						if (width != null && width > 0) {
							this.toolbarViewportWidth = width
						}
					})
				}, 40)
			},
			onToolbarTouchStart(e: UniTouchEvent): void {
				if (e.touches.length == 0) { return }
				this.measureToolbarViewport()
				this.toolbarTouchStartX = e.touches[0].screenX
				this.toolbarTouchStartY = e.touches[0].screenY
				this.toolbarTouchCurrentX = this.toolbarTouchStartX
				this.toolbarDragOffset = 0
				this.toolbarSwipeMoved = false
				this.toolbarDragging = true
			},
			onToolbarTouchMove(e: UniTouchEvent): void {
				if (e.touches.length == 0) { return }
				const currentX = e.touches[0].screenX
				const currentY = e.touches[0].screenY
				const dx = currentX - this.toolbarTouchStartX
				const dy = currentY - this.toolbarTouchStartY
				const absX = Math.abs(dx)
				const absY = Math.abs(dy)
				this.toolbarTouchCurrentX = currentX
				if (absX <= 8 || absX <= absY * 1.15) {
					return
				}
				this.toolbarSwipeMoved = true
				this.toolbarSwipeLockedUntil = Date.now() + 350
				let offset = dx
				if ((this.toolbarPageIndex == 0 && dx > 0) || (this.toolbarPageIndex == 1 && dx < 0)) {
					offset = dx * 0.28
				}
				this.toolbarDragOffset = offset
			},
			onToolbarTouchEnd(e: UniTouchEvent): void {
				if (e.changedTouches.length == 0) { return }
				const endX = e.changedTouches[0].screenX
				const endY = e.changedTouches[0].screenY
				const dx = endX - this.toolbarTouchStartX
				const dy = endY - this.toolbarTouchStartY
				const absX = Math.abs(dx)
				const absY = Math.abs(dy)
				this.toolbarDragging = false
				this.toolbarDragOffset = 0
				if (this.toolbarSwipeMoved == true) {
					this.toolbarSwipeLockedUntil = Date.now() + 350
				}
				if (absX < 40 || absX <= absY * 1.4) { return }
				if (dx < 0 && this.toolbarPageIndex < 1) {
					this.nextToolbarPage()
				} else if (dx > 0 && this.toolbarPageIndex > 0) {
					this.prevToolbarPage()
				}
			},
			onToolbarTouchCancel(): void {
				this.toolbarDragging = false
				this.toolbarDragOffset = 0
				if (this.toolbarSwipeMoved == true) {
					this.toolbarSwipeLockedUntil = Date.now() + 350
				}
			},
			consumeToolbarSwipeClick(): boolean {
				const now = Date.now()
				if (this.toolbarSwipeMoved == true || now < this.toolbarSwipeLockedUntil) {
					this.toolbarSwipeMoved = false
					return true
				}
				return false
			},
			onMsgScroll(): void { this.longpressCancelToken++ },
			onInputLineChange(e: UniTextareaLineChangeEvent): void {
				const lineCount = e.detail.lineCount
				if (lineCount <= 1) {
					this.inputHeight = 40
				} else {
					this.inputHeight = Math.min(lineCount * 22 + 16, 120)
				}
			},
			getMessagePartsForView(msg: UTSJSONObject): UTSJSONObject[] { return getMessageParts(msg) },
			readMessageHideThinking(msg: UTSJSONObject): boolean {
				const raw = msg['hideThinking'] as boolean | null
				return raw == true
			},
			readMessageMsgSegmentation(msg: UTSJSONObject): boolean {
				const raw = msg['msgSegmentation'] as boolean | null
				return raw != null ? raw : true
			},
			isAgentMessage(msg: UTSJSONObject): boolean {
				const senderType = msg['senderType'] as string | null
				return senderType == GROUP_MESSAGE_SENDER_AGENT
			},
			isUserMessage(msg: UTSJSONObject): boolean {
				const senderType = msg['senderType'] as string | null
				return senderType == GROUP_MESSAGE_SENDER_USER
			},
			readMessageSenderName(msg: UTSJSONObject): string {
				const raw = msg['senderName'] as string | null
				return raw != null ? raw : ''
			},
			readUserMessageSenderName(msg: UTSJSONObject): string {
				const raw = msg['senderName'] as string | null
				const name = raw != null ? raw.trim() : ''
				if (name != '' && name != '用户') { return name }
				return this.userNickname != '' ? this.userNickname : '用户'
			},
			normalizeUserSenderNames(): void {
				const displayName = this.userNickname != '' ? this.userNickname : '用户'
				if (displayName == '用户') { return }
				let changed = false
				for (let i = 0; i < this.messages.length; i++) {
					const msg = this.messages[i]
					const senderType = msg['senderType'] as string | null
					if (senderType == GROUP_MESSAGE_SENDER_USER) {
						const raw = msg['senderName'] as string | null
						const name = raw != null ? raw.trim() : ''
						if (name == '' || name == '用户') {
							msg['senderName'] = displayName
							changed = true
						}
					}
				}
				if (changed == true) {
					this.saveMessages()
				}
			},
			scrollToBottom(): void {
				setTimeout(() => { this.scrollTop = this.scrollTop + 999999 }, 80)
			},
			findLastAssistantMessage(list: UTSJSONObject[]): UTSJSONObject | null {
				for (let i = list.length - 1; i >= 0; i--) {
					const role = list[i]['role'] as string | null
					if (role == CHAT_ROLE_ASSISTANT) {
						return list[i]
					}
				}
				return null
			},
			findLastAssistantMessageFrom(list: UTSJSONObject[], startIndex: number): UTSJSONObject | null {
				for (let i = list.length - 1; i >= startIndex; i--) {
					const role = list[i]['role'] as string | null
					if (role == CHAT_ROLE_ASSISTANT) {
						return list[i]
					}
				}
				return null
			},
			appendVisiblePlainText(msg: UTSJSONObject, text: string): void {
				if (text == '') { return }
				const parts = msg['message'] as UTSJSONObject[] | null
				let list: UTSJSONObject[] = []
				if (parts != null) {
					list = parts
				}
				if (parts == null) {
					msg['message'] = list
				}
				const lastIndex = list.length - 1
				if (lastIndex >= 0) {
					const last = list[lastIndex]
					const type = last['type'] as string | null
					if (type == 'plain') {
						const oldText = last['text'] as string | null
						last['text'] = (oldText != null ? oldText : '') + text
					} else {
						list.push(createPlainPart(text))
					}
				} else {
					list.push(createPlainPart(text))
				}
				const oldContent = msg['content'] as string | null
				msg['content'] = (oldContent != null ? oldContent : '') + text
			},
			replaceVisiblePlainText(msg: UTSJSONObject, text: string): void {
				msg['content'] = text
				if (text != '') {
					msg['message'] = [createPlainPart(text)]
				} else {
					msg['message'] = [] as UTSJSONObject[]
				}
			},
			saveMessages(): void {
				if (this.groupId == '' || this.sessionId == '') { return }
				saveGroupMessages(this.groupId, this.sessionId, this.messages)
			},
			sendMessage(): void {
				const text = this.inputText.trim()
				if (text == '') { return }
				if (this.isGenerating == true) { return }
				this.inputText = ''
				this.showToolPanel = false
				const profile = loadChatUserProfile()
				this.userNickname = profile.nickname
				this.userAvatar = profile.avatar
				const msg = createGroupUserMessage(this.groupId, this.sessionId, text, profile.nickname)
				this.messages.push(msg)
				this.saveMessages()
				this.scrollToBottom()
				this.loopTurns = 0
				this.runScheduler('用户发送消息')
			},
			continueDiscussion(): void {
				if (this.consumeToolbarSwipeClick() == true) { return }
				if (this.isGenerating == true) { return }
				this.showToolPanel = false
				this.runScheduler('用户要求继续讨论')
			},
			stopDiscussion(): void {
				if (this.consumeToolbarSwipeClick() == true) { return }
				this.discussionStopped = true
				const stream = this.currentStream
				if (stream != null) {
					stream.abort()
				}
				this.currentStream = null
				this.isGenerating = false
				const note = createGroupHiddenMessage(this.groupId, this.sessionId, 'system', '用户请求暂停本轮讨论。仍在 loop 的成员不要继续发言。')
				this.messages.push(note)
				this.saveMessages()
				uni.showToast({ position: 'bottom', title: '已停止讨论', icon: 'none' })
			},
			addGroupImageMessage(imagePath: string): number {
				if (imagePath == '') { return -1 }
				const profile = loadChatUserProfile()
				this.userNickname = profile.nickname
				this.userAvatar = profile.avatar
				const msg = createGroupUserImageMessage(this.groupId, this.sessionId, imagePath, profile.nickname)
				this.messages.push(msg)
				this.saveMessages()
				this.scrollToBottom()
				return this.messages.length - 1
			},
			startGroupGenerationForMedia(reason: string): void {
				if (this.isGenerating == true) { return }
				this.runScheduler(reason)
			},
			startGenerationForImage(imagePath: string, fallbackReason: string, messageIndex: number): void {
				if (this.isGenerating == true) { return }
				this.isGenerating = true
				this.imageCaptionTaskId++
				const taskId = this.imageCaptionTaskId
				captionImage(imagePath).then((caption: string | null) => {
					if (taskId != this.imageCaptionTaskId) { return }
					if (messageIndex >= 0 && messageIndex < this.messages.length && caption != null && caption != '') {
						setImageMessageCaption(this.messages[messageIndex], caption)
						this.messages.splice(messageIndex, 1, this.messages[messageIndex])
						this.saveMessages()
					}
					this.isGenerating = false
					if (caption == null || caption == '') {
						uni.showToast({ position: 'bottom', title: '图片转述未配置或失败，已直接发送', icon: 'none' })
					}
					this.startGroupGenerationForMedia(fallbackReason)
				})
			},
			pickImage(): void {
				if (this.consumeToolbarSwipeClick() == true) { return }
				this.showToolPanel = false
				if (this.isGenerating == true) { return }
				uni.chooseImage({
					count: 1,
					sourceType: ['album'],
					sizeType: ['compressed'],
					success: (res: any) => {
						const raw = JSON.stringify(res)
						if (raw == null || raw == '') { return }
						const parsed = JSON.parse(raw) as UTSJSONObject
						const paths = parsed['tempFilePaths'] as string[] | null
						if (paths != null && paths.length > 0) {
							const msgIndex = this.addGroupImageMessage(paths[0])
							this.startGenerationForImage(paths[0], '用户发送了一张图片', msgIndex)
						}
					}
				})
			},
			takePhoto(): void {
				if (this.consumeToolbarSwipeClick() == true) { return }
				this.showToolPanel = false
				if (this.isGenerating == true) { return }
				uni.chooseImage({
					count: 1,
					sourceType: ['camera'],
					sizeType: ['compressed'],
					success: (res: any) => {
						const raw = JSON.stringify(res)
						if (raw == null || raw == '') { return }
						const parsed = JSON.parse(raw) as UTSJSONObject
						const paths = parsed['tempFilePaths'] as string[] | null
						if (paths != null && paths.length > 0) {
							const msgIndex = this.addGroupImageMessage(paths[0])
							this.startGenerationForImage(paths[0], '用户拍摄了一张照片', msgIndex)
						}
					}
				})
			},
			pickFile(): void {
				if (this.consumeToolbarSwipeClick() == true) { return }
				this.showToolPanel = false
				if (this.isGenerating == true) { return }
				uni.chooseFile({
					count: 1,
					success: (res: any) => {
						const raw = JSON.stringify(res)
						if (raw == null || raw == '') { return }
						const parsed = JSON.parse(raw) as UTSJSONObject
						this.addGroupFileMessage(parsed)
					}
				})
			},
			addGroupFileMessage(fileInfo: UTSJSONObject): void {
				const rawName = fileInfo['name'] as string | null
				const rawPath = fileInfo['path'] as string | null
				const tempFiles = fileInfo['tempFiles'] as UTSJSONObject[] | null
				let name = rawName != null ? rawName : '文件'
				let path = rawPath != null ? rawPath : ''
				if (tempFiles != null && tempFiles.length > 0) {
					const first = tempFiles[0]
					const firstName = first['name'] as string | null
					const firstPath = first['path'] as string | null
					if (firstName != null && firstName != '') { name = firstName }
					if (firstPath != null && firstPath != '') { path = firstPath }
				}
				const profile = loadChatUserProfile()
				this.userNickname = profile.nickname
				this.userAvatar = profile.avatar
				this.messages.push(createGroupUserFileMessage(this.groupId, this.sessionId, name, path, profile.nickname))
				this.saveMessages()
				this.scrollToBottom()
				this.startGroupGenerationForMedia('用户发送了一个文件：' + name)
			},
			buildGroupMemberAgentItems(): UTSJSONObject[] {
				const members = getActiveGroupMembers(this.groupId)
				const result: UTSJSONObject[] = []
				result.push({
					agentId: 'scheduler',
					name: '调度',
				} as UTSJSONObject)
				for (let i = 0; i < members.length; i++) {
					const agent = getAgentById(members[i].agentId)
					result.push({
						agentId: members[i].agentId,
						name: readAgentName(agent),
					} as UTSJSONObject)
				}
				return result
			},
			chooseAgentForMemory(): void {
				if (this.consumeToolbarSwipeClick() == true) { return }
				this.showToolPanel = false
				this.chooseAgentAndRun('选择要查看记忆的 Agent', 'memory')
			},
			chooseAgentForContext(): void {
				if (this.consumeToolbarSwipeClick() == true) { return }
				this.showToolPanel = false
				this.chooseAgentAndRun('选择要查看上下文的 Agent', 'context')
			},
			chooseAgentAndRun(_title: string, action: string): void {
				const items = this.buildGroupMemberAgentItems()
				if (items.length == 0) {
					uni.showToast({ position: 'bottom', title: '群里还没有成员', icon: 'none' })
					return
				}
				const names: string[] = []
				for (let i = 0; i < items.length; i++) {
					const name = items[i]['name'] as string | null
					names.push(name != null ? name : 'Agent')
				}
				uni.showActionSheet({
					itemList: names,
					success: (res) => {
						const index = res.tapIndex
						if (index < 0 || index >= items.length) { return }
						const agentId = items[index]['agentId'] as string | null
						if (agentId == null || agentId == '') { return }
						if (action == 'memory') {
							this.openMemoryForAgent(agentId)
						} else {
							this.openContextForAgent(agentId)
						}
					}
				})
			},
			openMemoryForAgent(agentId: string): void {
				if (agentId != 'scheduler' && getAgentById(agentId) == null) {
					uni.showToast({ position: 'bottom', title: '该智能体已删除', icon: 'none' })
					return
				}
				setMemoryRouteState(agentId, this.sessionId)
				uni.navigateTo({ url: '/pages/memory/memory' })
			},
			openContextForAgent(agentId: string): void {
				const session = this.session
				if (session == null) { return }
				if (agentId != 'scheduler' && getAgentById(agentId) == null) {
					uni.showToast({ position: 'bottom', title: '该智能体已删除', icon: 'none' })
					return
				}
				const preview = readLastLLMRequestSnapshot(agentId, session.id)
				if (preview == null) {
					uni.showToast({ position: 'bottom', title: '该 Agent 还没有真实请求快照', icon: 'none' })
					return
				}
				let previewText = ''
				try {
					previewText = JSON.stringify(preview, null, 2)
				} catch (_e: any) {
					previewText = JSON.stringify(preview)
				}
				setContextPreviewPayload(previewText)
				uni.navigateTo({ url: '/pages/context-preview/context-preview' })
			},
			openGroupWorkspace(): void {
				if (this.consumeToolbarSwipeClick() == true) { return }
				this.showToolPanel = false
				const group = this.group
				const session = this.session
				if (group == null || session == null) { return }
				const workspaceRoot = getGroupSessionWorkspaceDir(group.id, session.id)
				if (workspaceRoot == '') {
					uni.showToast({ position: 'bottom', title: '工作区不可用', icon: 'none' })
					return
				}
				setFilesInitialPath(workspaceRoot)
				uni.navigateTo({ url: '/pages/files/files' })
			},
			onMessageLongpress(msg: UTSJSONObject): void {
				const senderType = msg['senderType'] as string | null
				if (senderType != GROUP_MESSAGE_SENDER_AGENT) { return }
				const id = msg['id'] as string | null
				if (id == null || id == '') { return }
				uni.showActionSheet({
					itemList: ['撤回这条 Agent 消息', '跳转私聊'],
					success: (res) => {
						if (res.tapIndex == 0) {
							revokeGroupAgentMessage(this.groupId, this.sessionId, id)
							this.messages = getGroupMessages(this.groupId, this.sessionId)
						} else if (res.tapIndex == 1) {
							this.openAgentPrivateChat(msg)
						}
					}
				})
			},
			openAgentPrivateChat(msg: UTSJSONObject): void {
				const agentId = msg['senderAgentId'] as string | null
				if (agentId == null || agentId == '') { return }
				if (getAgentById(agentId) == null) {
					uni.showToast({ position: 'bottom', title: '该智能体已删除', icon: 'none' })
					return
				}
				setActiveAgentRuntimeId(agentId)
				uni.navigateTo({ url: '/pages/chat/chat' })
			},
			showDispatchHistory(): void {
				if (this.consumeToolbarSwipeClick() == true) { return }
				this.showToolPanel = false
				const lines: string[] = []
				for (let i = this.messages.length - 1; i >= 0; i--) {
					const msg = this.messages[i]
					const senderType = msg['senderType'] as string | null
					if (senderType != GROUP_MESSAGE_SENDER_SCHEDULER && senderType != GROUP_MESSAGE_SENDER_REVIEWER) { continue }
					const reason = msg['triggerReason'] as string | null
					const visibility = msg['visibility'] as string | null
					const kind = senderType != null ? senderType : 'internal'
					const level = visibility != null && visibility != '' ? visibility : 'internal'
					const ts = msg['timestamp'] as number | null
					const d = ts != null && ts > 0 ? new Date(ts) : new Date()
					const hh = d.getHours() < 10 ? '0' + d.getHours().toString() : d.getHours().toString()
					const mm = d.getMinutes() < 10 ? '0' + d.getMinutes().toString() : d.getMinutes().toString()
					lines.push('=== ' + hh + ':' + mm + ' [' + kind + '/' + level + '] ' + (reason != null ? reason : '') + ' ===')
					const content = msg['content'] as string | null
					const text = content != null ? content : ''
					const first = text.indexOf('{')
					const last = text.lastIndexOf('}')
					if (first >= 0 && last > first) {
						try {
							const parsed = JSON.parse(text.substring(first, last + 1)) as UTSJSONObject
							lines.push(JSON.stringify(parsed, null, 2))
						} catch (_e: any) {
							lines.push(text)
						}
					} else {
						lines.push(text)
					}
					lines.push('')
					if (lines.length >= 200) { break }
				}
				if (lines.length == 0) {
					uni.showToast({ position: 'bottom', title: '还没有调度记录', icon: 'none' })
					return
				}
				setContextPreviewPayload(lines.join('\n'))
				uni.navigateTo({ url: '/pages/context-preview/context-preview' })
			},
			runScheduler(reason: string): void {
				const group = this.group
				const session = this.session
				if (group == null || session == null) { return }
				const members = getActiveGroupMembers(group.id)
				if (members.length == 0) {
					uni.showToast({ position: 'bottom', title: '群里还没有成员', icon: 'none' })
					return
				}
				this.discussionStopped = false
				this.isGenerating = true
				const schedulerStartedAt = Date.now()
				const schedulerMessages = buildSchedulerRuntimeMessages(group, session, this.messages, reason, this.loopTurns)
				const schedulerAgentId = 'scheduler'
				let schedulerText = ''
				let schedulerThinking = ''
				const schedulerStream = agentChat(schedulerMessages, buildSchedulerSystemPrompt(), '', '', schedulerAgentId, 1, session.id, '')
				this.currentStream = schedulerStream
				schedulerStream.on((event: AgentEvent) => {
					if (event.type == 'text_delta' && event.text != null) {
						schedulerText += event.text
					} else if (event.type == 'text_end' && event.fullText != null && schedulerText == '') {
						schedulerText = event.fullText as string
					} else if (event.type == 'thinking_delta' && event.thinkingText != null) {
						schedulerThinking += (event.thinkingText as string)
					} else if (event.type == 'thinking_end' && event.fullThinking != null) {
						schedulerThinking = event.fullThinking as string
					} else if (event.type == 'error' && event.error != null) {
						schedulerText = event.error
					} else if (event.type == 'agent_end') {
						if (this.discussionStopped == true) {
							this.isGenerating = false
							this.currentStream = null
							return
						}
						const decision = parseSchedulerDecision(schedulerText, group.id)
						const title = decision['titleSuggestion'] as string | null
						if (title != null && title.trim() != '') {
							applyGroupSessionTitleSuggestion(group.id, session.id, title)
							const freshSession = getGroupSessionById(group.id, session.id)
							this.session = freshSession != null ? freshSession : session
						}
						const hidden = createGroupHiddenMessage(group.id, session.id, GROUP_MESSAGE_SENDER_SCHEDULER, schedulerText)
						appendResponseToSnapshot(schedulerAgentId, session.id, schedulerText, schedulerThinking)
						const schedulerSnapshot = readLastLLMRequestSnapshot(schedulerAgentId, session.id)
						if (schedulerSnapshot != null) {
							const capturedAt = schedulerSnapshot['capturedAt'] as number | null
							if (capturedAt != null && capturedAt >= schedulerStartedAt) {
								hidden['requestSnapshot'] = schedulerSnapshot
							}
						}
						hidden['triggerReason'] = reason
						hidden['runtimeMessages'] = JSON.parse(JSON.stringify(schedulerMessages)) as UTSJSONObject[]
						this.messages.push(hidden)
						this.saveMessages()
						this.currentStream = null
						this.runDecisionActions(decision)
					}
				})
			},
			runDecisionActions(decision: UTSJSONObject): void {
				const actions = decision['actions'] as UTSJSONObject[] | null
				if (actions == null || actions.length == 0) {
					this.isGenerating = false
					return
				}
				const shouldContinue = (decision['shouldContinue'] as boolean | null) == true
				this.runActionAt(actions, 0, shouldContinue)
			},
			runActionAt(actions: UTSJSONObject[], index: number, shouldContinue: boolean): void {
				if (this.discussionStopped == true) {
					this.isGenerating = false
					this.currentStream = null
					this.saveMessages()
					return
				}
				if (index >= actions.length) {
					this.finishDecisionRound(shouldContinue)
					return
				}
				const action = actions[index]
				const actionType = action['type'] as string | null
				const agentId = action['agentId'] as string | null
				if (actionType != 'speak' || agentId == null || agentId == '' || getAgentById(agentId) == null || isAgentInGroup(this.groupId, agentId) == false) {
					this.runActionAt(actions, index + 1, shouldContinue)
					return
				}
				this.runMemberSpeak(agentId, action, () => { this.runActionAt(actions, index + 1, shouldContinue) })
			},
			finishDecisionRound(shouldContinue: boolean): void {
				this.loopTurns++
				this.saveMessages()
				this.runGroupReview('成员发言结束，进入回合复盘', shouldContinue)
			},
			runGroupReview(reason: string, schedulerShouldContinue: boolean): void {
				const group = this.group
				const session = this.session
				if (group == null || session == null) {
					this.isGenerating = false
					this.currentStream = null
					return
				}
				const reviewStartedAt = Date.now()
				const reviewMessages = buildGroupReviewMessages(group, session, this.messages, reason, this.loopTurns)
				const reviewerAgentId = 'reviewer'
				let reviewText = ''
				let reviewThinking = ''
				const reviewStream = agentChat(reviewMessages, buildGroupReviewSystemPrompt(), '', '', reviewerAgentId, 1, session.id, '')
				this.currentStream = reviewStream
				reviewStream.on((event: AgentEvent) => {
					if (event.type == 'text_delta' && event.text != null) {
						reviewText += event.text
					} else if (event.type == 'text_end' && event.fullText != null && reviewText == '') {
						reviewText = event.fullText as string
					} else if (event.type == 'thinking_delta' && event.thinkingText != null) {
						reviewThinking += (event.thinkingText as string)
					} else if (event.type == 'thinking_end' && event.fullThinking != null) {
						reviewThinking = event.fullThinking as string
					} else if (event.type == 'error' && event.error != null) {
						reviewText = event.error
					} else if (event.type == 'agent_end') {
						if (this.discussionStopped == true) {
							this.isGenerating = false
							this.currentStream = null
							this.saveMessages()
							return
						}
						const review = parseGroupReviewDecision(reviewText)
						const hidden = createGroupHiddenMessage(group.id, session.id, GROUP_MESSAGE_SENDER_REVIEWER, reviewText)
						appendResponseToSnapshot(reviewerAgentId, session.id, reviewText, reviewThinking)
						const reviewerSnapshot = readLastLLMRequestSnapshot(reviewerAgentId, session.id)
						if (reviewerSnapshot != null) {
							const capturedAt = reviewerSnapshot['capturedAt'] as number | null
							if (capturedAt != null && capturedAt >= reviewStartedAt) {
								hidden['requestSnapshot'] = reviewerSnapshot
							}
						}
						hidden['triggerReason'] = reason
						hidden['runtimeMessages'] = JSON.parse(JSON.stringify(reviewMessages)) as UTSJSONObject[]
						hidden['review'] = review
						this.messages.push(hidden)
						const hiddenId = hidden['id'] as string | null
						persistGroupReviewEffects(group, session, review, hiddenId != null ? hiddenId : '')
						this.saveMessages()
						this.currentStream = null
						let nextShouldContinue = schedulerShouldContinue
						const advice = review['continueAdvice'] as string | null
						if (advice == 'continue') {
							nextShouldContinue = true
						} else if (advice == 'stop') {
							nextShouldContinue = false
						}
						if (this.loopTurns >= 10) {
							this.loopTurns = 0
							this.runScheduler('连续讨论轮数过多，判断是否继续')
						} else if (nextShouldContinue == true) {
							this.runScheduler('复盘建议继续讨论')
						} else {
							this.isGenerating = false
						}
					}
				})
			},
			runMemberSpeak(agentId: string, action: UTSJSONObject, done: () => void): void {
				this.runMemberSpeakWithReview(agentId, action, false, done)
			},
			runMemberSpeakWithReview(agentId: string, action: UTSJSONObject, isRevision: boolean, done: () => void): void {
				const group = this.group
				const session = this.session
				if (group == null || session == null) {
					done()
					return
				}
				const agent = getAgentById(agentId)
				if (agent == null) {
					done()
					return
				}
				const streamingMsg = createGroupAgentStreamingMessage(group.id, session.id, agentId)
				streamingMsg['revisionAttempt'] = isRevision
				this.messages.push(streamingMsg)
				const agentName = readAgentName(agent)
				const injectDatetime = readAgentInjectDatetime(agent)
				const msgSegmentation = readAgentMsgSegmentation(agent)
				const tempMessages = buildMemberRuntimeMessages(group, session, this.messages, action, agentName, injectDatetime, buildChatDatetimePrefix())
				const systemPrompt = buildMemberSystemPrompt(agent, group.sharedPrompt)
				const contextRecord = createGroupAgentContextRecord(group, session, agentId, agentName, action, tempMessages, systemPrompt)
				saveGroupAgentContextRecord(contextRecord)
				streamingMsg['contextRecordId'] = contextRecord['id'] as string | null
				const workspaceRoot = getGroupSessionWorkspaceDir(group.id, session.id)
				const newMsgStartIndex = tempMessages.length
				const stream = agentChat(tempMessages, systemPrompt, '', readAgentModel(agent), agentId, 0, session.id, workspaceRoot)
				this.currentStream = stream
				const holdSize = getSchedulerLeakHoldSize()
				let renderTail = ''
				let heldText = ''
				let candidateText = ''
				let reviewHolding = false
				let hitKeyword = ''
				stream.on((event: AgentEvent) => {
					if (event.type == 'agent_end') {
						if (this.discussionStopped == true) {
							if (reviewHolding == true) {
								markGroupAgentMessageRevoked(streamingMsg)
							} else if (renderTail != '') {
								this.appendVisiblePlainText(streamingMsg, renderTail)
								renderTail = ''
							}
							streamingMsg['isStreaming'] = false
							this.currentStream = null
							this.saveMessages()
							done()
							return
						}
						finalizeAssistantTurn(tempMessages, msgSegmentation)
						const lastAssistant = this.findLastAssistantMessageFrom(tempMessages, newMsgStartIndex)
						if (lastAssistant != null) {
							const finalText = getMessageContent(lastAssistant)
							if (reviewHolding == true) {
								heldText = finalText
								const visibleNow = streamingMsg['content'] as string | null
								if (visibleNow == null || visibleNow == '') {
									this.replaceVisiblePlainText(streamingMsg, '正在整理发言...')
								}
							} else {
								if (renderTail != '') {
									this.appendVisiblePlainText(streamingMsg, renderTail)
									renderTail = ''
								}
								syncGroupStreamingMessage(streamingMsg, lastAssistant)
							}
							const responseText = reviewHolding == true ? finalText : (streamingMsg['content'] as string | null)
							const thinkingText = getMessageThinking(lastAssistant)
							if ((responseText != null && responseText != '') || thinkingText != '') {
								appendResponseToSnapshot(agentId, session.id, responseText != null ? responseText : '', thinkingText)
							}
						} else {
							streamingMsg['visible'] = false
						}
						recordGroupAgentSpeak(group.id, session.id, agentId)
						const requestSnapshot = readLastLLMRequestSnapshot(agentId, session.id)
						if (requestSnapshot != null) {
							contextRecord['requestSnapshot'] = requestSnapshot
							saveGroupAgentContextRecord(contextRecord)
						}
						streamingMsg['isStreaming'] = false
						this.currentStream = null
						if (reviewHolding == true) {
							this.saveMessages()
							this.scrollToBottom()
							this.runSchedulerReview(agentId, agentName, streamingMsg, heldText, hitKeyword, action, done)
						} else {
							this.saveMessages()
							this.scrollToBottom()
							done()
						}
						return
					}
					reduceAgentEvent(tempMessages, event)
					const lastAssistant = this.findLastAssistantMessageFrom(tempMessages, newMsgStartIndex)
					if (lastAssistant != null) {
						if ((event.type == 'text_delta' && event.text != null) || (event.type == 'text_end' && event.fullText != null && candidateText == '')) {
							const delta = event.type == 'text_delta' ? (event.text as string) : (event.fullText as string)
							candidateText += delta
							if (reviewHolding == false) {
								const detection = detectSchedulerLeakCandidate(renderTail + delta)
								if (detection.hit == true) {
									reviewHolding = true
									hitKeyword = detection.keyword
									heldText = candidateText
									const visibleNow = streamingMsg['content'] as string | null
									if (visibleNow == null || visibleNow == '') {
										this.replaceVisiblePlainText(streamingMsg, '正在整理发言...')
									}
								} else {
									let merged = renderTail + delta
									if (merged.length > holdSize) {
										const safeLen = merged.length - holdSize
										const safeText = merged.substring(0, safeLen)
										renderTail = merged.substring(safeLen)
										this.appendVisiblePlainText(streamingMsg, safeText)
									} else {
										renderTail = merged
									}
								}
							}
						}
					}
					this.scrollToBottom()
				})
			},
			runSchedulerReview(agentId: string, agentName: string, streamingMsg: UTSJSONObject, candidateText: string, keyword: string, originalAction: UTSJSONObject, done: () => void): void {
				const group = this.group
				const session = this.session
				if (group == null || session == null) {
					done()
					return
				}
				let schedulerText = ''
				let schedulerThinking = ''
				const reviewStartedAt = Date.now()
				const reviewMessages = buildSchedulerReviewMessages(group, session, this.messages, agentId, agentName, keyword, candidateText)
				const reviewStream = agentChat(reviewMessages, buildSchedulerReviewSystemPrompt(), '', '', 'scheduler', 1, session.id, '')
				this.currentStream = reviewStream
				reviewStream.on((event: AgentEvent) => {
					if (event.type == 'text_delta' && event.text != null) {
						schedulerText += event.text
					} else if (event.type == 'text_end' && event.fullText != null && schedulerText == '') {
						schedulerText = event.fullText as string
					} else if (event.type == 'thinking_delta' && event.thinkingText != null) {
						schedulerThinking += (event.thinkingText as string)
					} else if (event.type == 'thinking_end' && event.fullThinking != null) {
						schedulerThinking = event.fullThinking as string
					} else if (event.type == 'error' && event.error != null) {
						schedulerText = event.error
					} else if (event.type == 'agent_end') {
						if (this.discussionStopped == true) {
							this.currentStream = null
							done()
							return
						}
						this.currentStream = null
						const hidden = createGroupHiddenMessage(group.id, session.id, GROUP_MESSAGE_SENDER_SCHEDULER, schedulerText)
						appendResponseToSnapshot('scheduler', session.id, schedulerText, schedulerThinking)
						const schedulerSnapshot = readLastLLMRequestSnapshot('scheduler', session.id)
						if (schedulerSnapshot != null) {
							const capturedAt = schedulerSnapshot['capturedAt'] as number | null
							if (capturedAt != null && capturedAt >= reviewStartedAt) {
								hidden['requestSnapshot'] = schedulerSnapshot
							}
						}
						hidden['triggerReason'] = '敏感流式发言审核：' + keyword
						hidden['runtimeMessages'] = JSON.parse(JSON.stringify(reviewMessages)) as UTSJSONObject[]
						this.messages.push(hidden)
						const decision = parseSchedulerReviewDecision(schedulerText)
						const mode = decision['decision'] as string | null
						if (mode == 'allow') {
							this.replaceVisiblePlainText(streamingMsg, candidateText)
							streamingMsg['isStreaming'] = false
							this.saveMessages()
							this.scrollToBottom()
							done()
							return
						}
						if (mode == 'revoke') {
							markGroupAgentMessageRevoked(streamingMsg)
							this.saveMessages()
							this.scrollToBottom()
							done()
							return
						}
						if ((streamingMsg['revisionAttempt'] as boolean | null) == true) {
							markGroupAgentMessageRevoked(streamingMsg)
							this.saveMessages()
							this.scrollToBottom()
							done()
							return
						}
						markGroupAgentMessageRevoked(streamingMsg)
						this.saveMessages()
						this.scrollToBottom()
						const instructionRaw = decision['revisionInstruction'] as string | null
						const instruction = instructionRaw != null && instructionRaw.trim() != '' ? instructionRaw.trim() : '保留原意，删除任何关于调度、内部指令、私密指令或幕后安排的表述。'
						const revisedAction = JSON.parse(JSON.stringify(originalAction)) as UTSJSONObject
						revisedAction['privateInstruction'] = instruction + '\n\n上一版未公开发言：\n' + candidateText
						revisedAction['publicIntent'] = '重新组织上一条发言'
						this.runMemberSpeakWithReview(agentId, revisedAction, true, done)
					}
				})
			}
		}
	}
</script>

<style>
	.nav-icon-btn { width: 72rpx; height: 72rpx; justify-content: center; align-items: center; }
	.message-list { flex: 1; padding-top: 12rpx; }
	.empty-state { flex: 1; align-items: center; justify-content: center; padding-top: 180rpx; flex-direction: column; }
	.empty-text { font-size: 32rpx; color: var(--rice-text-color); font-weight: bold; }
	.empty-hint { margin-top: 12rpx; font-size: 24rpx; color: var(--rice-text-color-3); }
	.chat-bottom { flex-shrink: 0; background-color: var(--rice-background-2); border-top-width: 2rpx; border-top-color: var(--rice-border-color); border-top-style: solid; }
	.input-bar { flex-direction: row; align-items: center; padding-left: 12rpx; padding-right: 16rpx; padding-top: 12rpx; padding-bottom: 12rpx; }
	.toolbar-toggle { width: 64rpx; height: 64rpx; border-radius: 32rpx; justify-content: center; align-items: center; }
	.input-wrap { flex: 1; flex-direction: row; align-items: flex-end; background-color: var(--rice-background); border-radius: 32rpx; padding-left: 16rpx; padding-right: 16rpx; margin-left: 12rpx; margin-right: 12rpx; }
	.text-input { width: 100%; min-height: 64rpx; max-height: 400rpx; padding-left: 8rpx; padding-right: 8rpx; padding-top: 16rpx; padding-bottom: 16rpx; font-size: 30rpx; color: var(--rice-text-color); background-color: transparent; line-height: 44rpx; }
	.toolbar-panel { background-color: var(--rice-background); padding: 24rpx 16rpx 16rpx 16rpx; }
	.toolbar-slider-viewport { width: 100%; overflow: hidden; }
	.toolbar-slider-track { width: 200%; flex-direction: row; }
	.toolbar-slider-track-anim { transition-property: transform; transition-duration: 180ms; transition-timing-function: ease-out; }
	.toolbar-slide-page { width: 50%; flex-shrink: 0; }
	.toolbar-grid { flex-direction: row; justify-content: flex-start; flex-wrap: wrap; }
	.toolbar-grid-item { width: 25%; align-items: center; margin-bottom: 24rpx; }
	.toolbar-grid-icon { width: 104rpx; height: 104rpx; border-radius: 28rpx; background-color: var(--rice-background-2); justify-content: center; align-items: center; margin-bottom: 8rpx; }
	.toolbar-grid-label { font-size: 24rpx; color: var(--rice-text-color-2); }
	.toolbar-pager { flex-direction: row; align-items: center; justify-content: center; height: 42rpx; }
	.toolbar-page-arrow { width: 56rpx; height: 42rpx; justify-content: center; align-items: center; margin-left: 8rpx; margin-right: 8rpx; }
	.toolbar-page-arrow-disabled { opacity: 0.25; }
	.toolbar-page-arrow-text { font-size: 34rpx; color: var(--rice-text-color-2); line-height: 38rpx; }
	.toolbar-page-dot { width: 10rpx; height: 10rpx; border-radius: 5rpx; background-color: #D1D5DB; margin-left: 8rpx; margin-right: 8rpx; }
	.toolbar-page-dot-active { width: 28rpx; background-color: var(--rice-primary-color); }
</style>
