<template>
	<view class="page-shell rice-theme-light">
		<NavBar :title="headerTitle" showBack variant="light" @back="goBack">
			<template #right>
				<view style="flex-direction:row;align-items:center;">
					<view class="nav-icon-btn" @click="goSessions">
						<oui-icon-unix name="time-circle" size="18px" color="#25242A" />
					</view>
					<view class="nav-icon-btn" @click="goSettings" style="margin-left:4px;">
						<oui-icon-unix name="setting" size="18px" color="#25242A" />
					</view>
				</view>
			</template>
		</NavBar>

		<view class="message-scroll-wrap">
			<scroll-view id="group-message-scroll" class="message-list" :scroll-y="true" :scroll-with-animation="false" :show-scrollbar="false" :scroll-top="scrollTop" @scroll="onMsgScroll" @touchmove="onMsgTouchMove">
				<view v-for="item in visibleMessageItems" :key="messageViewKey(item.sourceMessage, item.sourceIndex)" :id="messageWindowItemId(item.sourceIndex)" class="message-window-item">
					<ChatBubble
						:role="item.renderMessage.role"
						:content="item.renderMessage.content != null ? item.renderMessage.content : ''"
						:parts="getMessagePartsForView(item.renderMessage)"
						:agentAvatar="item.renderMessage.senderAvatar != null ? item.renderMessage.senderAvatar : ''"
						:assistantName="isAgentMessage(item.renderMessage) ? readMessageSenderName(item.renderMessage) : ''"
						:userNickname="userNickname"
						:userDisplayName="isUserMessage(item.renderMessage) ? readUserMessageSenderName(item.renderMessage) : ''"
						:userAvatar="userAvatar"
						:toolName="item.renderMessage.toolName != null ? item.renderMessage.toolName : ''"
						:hideThinking="readMessageHideThinking(item.renderMessage)"
						:msgSegmentation="readMessageMsgSegmentation(item.renderMessage)"
						:isError="item.renderMessage.isError == true"
							:isStreaming="item.renderMessage.isStreaming == true"
							:isPrivateMessage="isPrivateMessage(item.renderMessage)"
						:cancelToken="longpressCancelToken"
						@contentResize="onMessageContentResize"
						@bubbleLongpress="onMessageLongpress(item.sourceMessage)"
						@avatarClick="openAgentPrivateChat(item.sourceMessage)"
					/>
				</view>
				<view v-if="allVisibleMessageCount == 0" class="empty-state">
					<text class="empty-text">{{emptyTitle}}</text>
					<text class="empty-hint">发一句话，本群调度会安排成员接招。</text>
				</view>
				<view id="group-scroll-anchor" class="scroll-anchor"></view>
			</scroll-view>
			<view class="chat-custom-scrollbar" v-if="showCustomScrollbar == true" @touchstart="onScrollbarTrackTap" @touchend="onScrollbarTouchEnd" @touchcancel="onScrollbarTouchEnd">
				<view class="chat-scrollbar-thumb" :style="scrollbarThumbStyle" @touchstart.stop="onScrollbarThumbStart" @touchmove.stop.prevent="onScrollbarThumbMove" />
			</view>
			<view class="back-bottom-btn" v-if="showBackToBottom == true" @click="scrollToBottomFromButton">
				<text class="back-bottom-text">↓ 到底部</text>
			</view>
		</view>

		<view class="chat-bottom" :style="{ marginBottom: keyboardInset + 'px' }">
			<view class="input-bar">
				<view class="toolbar-toggle" @click="toggleToolPanel">
					<oui-icon-unix name="plus" size="18px" color="#FFFFFF" />
				</view>
				<view class="input-wrap">
					<textarea class="text-input" v-model="inputText" :style="{ height: inputHeight + 'px' }" :adjust-position="false" placeholder="给群里发消息..." placeholder-style="color:#9CA3AF" @linechange="onInputLineChange" :disabled="isGenerating == true" />
				</view>
				<view v-if="isGenerating == false" class="send-chip" @click="sendMessage">
					<text class="send-chip-text">发送</text>
				</view>
				<view v-else class="send-chip send-chip-stop" @click="stopDiscussion">
					<text class="send-chip-text">停止</text>
				</view>
			</view>
			<view v-if="showToolPanel" class="toolbar-panel">
				<view class="toolbar-panel-card">
					<view class="toolbar-panel-handle"></view>
					<view id="toolbar-slider-viewport" class="toolbar-slider-viewport" @touchstart="onToolbarTouchStart" @touchmove="onToolbarTouchMove" @touchend="onToolbarTouchEnd" @touchcancel="onToolbarTouchCancel">
						<view class="toolbar-slider-track" :class="toolbarDragging == true ? '' : 'toolbar-slider-track-anim'" :style="toolbarTrackStyle">
							<view class="toolbar-slide-page">
								<view class="toolbar-grid">
									<view class="toolbar-grid-item" @click="pickImage">
										<view class="toolbar-grid-icon"><oui-icon-unix name="image" size="26px" color="var(--rice-primary-color)" /></view>
										<text class="toolbar-grid-label">图片</text>
									</view>
									<view class="toolbar-grid-item" @click="takePhoto">
										<view class="toolbar-grid-icon"><oui-icon-unix name="camera" size="26px" color="var(--rice-primary-color)" /></view>
										<text class="toolbar-grid-label">拍照</text>
									</view>
									<view class="toolbar-grid-item" @click="pickFile">
										<view class="toolbar-grid-icon"><oui-icon-unix name="file" size="26px" color="var(--rice-primary-color)" /></view>
										<text class="toolbar-grid-label">文件</text>
									</view>
									<view class="toolbar-grid-item" @click="chooseAgentForMemory">
										<view class="toolbar-grid-icon"><oui-icon-unix name="file-text" size="26px" color="var(--rice-primary-color)" /></view>
										<text class="toolbar-grid-label">记忆</text>
									</view>
									<view class="toolbar-grid-item" @click="chooseAgentForContext">
										<view class="toolbar-grid-icon"><oui-icon-unix name="eye" size="26px" color="var(--rice-primary-color)" /></view>
										<text class="toolbar-grid-label">上下文</text>
									</view>
									<view class="toolbar-grid-item" @click="openGroupWorkspace">
										<view class="toolbar-grid-icon"><oui-icon-unix name="folder" size="26px" color="var(--rice-primary-color)" /></view>
										<text class="toolbar-grid-label">工作区</text>
									</view>
									<view class="toolbar-grid-item" @click="stopDiscussion">
										<view class="toolbar-grid-icon"><oui-icon-unix name="stop" size="26px" color="#EF4444" /></view>
										<text class="toolbar-grid-label">停止</text>
									</view>
									<view class="toolbar-grid-item" @click="continueDiscussion">
										<view class="toolbar-grid-icon"><oui-icon-unix name="plus-circle" size="26px" color="var(--rice-primary-color)" /></view>
										<text class="toolbar-grid-label">继续</text>
									</view>
								</view>
							</view>
							<view class="toolbar-slide-page">
								<view class="toolbar-grid">
									<view class="toolbar-grid-item" @click="goSessions">
										<view class="toolbar-grid-icon"><oui-icon-unix name="time-circle" size="26px" color="var(--rice-primary-color)" /></view>
										<text class="toolbar-grid-label">会话分支</text>
									</view>
									<view class="toolbar-grid-item" @click="goSettings">
										<view class="toolbar-grid-icon"><oui-icon-unix name="setting" size="26px" color="var(--rice-primary-color)" /></view>
										<text class="toolbar-grid-label">群聊设置</text>
									</view>
									<view class="toolbar-grid-item" @click="showDispatchHistory">
										<view class="toolbar-grid-icon"><oui-icon-unix name="file-text" size="26px" color="var(--rice-primary-color)" /></view>
										<text class="toolbar-grid-label">调度记录</text>
									</view>
								</view>
							</view>
						</view>
					</view>
					<view class="toolbar-pager">
						<view class="toolbar-page-arrow" :class="toolbarPageIndex == 0 ? 'toolbar-page-arrow-disabled' : ''" @click="prevToolbarPage">
							<text class="toolbar-page-arrow-text">‹</text>
						</view>
						<view class="toolbar-page-dot" :class="toolbarPageIndex == 0 ? 'toolbar-page-dot-active' : ''" @click="setToolbarPage(0)" />
						<view class="toolbar-page-dot" :class="toolbarPageIndex == 1 ? 'toolbar-page-dot-active' : ''" @click="setToolbarPage(1)" />
						<view class="toolbar-page-arrow" :class="toolbarPageIndex == 1 ? 'toolbar-page-arrow-disabled' : ''" @click="nextToolbarPage">
							<text class="toolbar-page-arrow-text">›</text>
						</view>
					</view>
				</view>
			</view>
		</view>
	</view>
</template>

<script lang="uts">
	import { readLastLLMRequestSnapshot, captionImage } from '@/uni_modules/agent-core/utssdk/llm-client.uts'
	import { getAgentById } from '@/utils/agent.uts'
	import { loadChatUserProfile } from '@/utils/chat-conversation-service.uts'
	import { setImageMessageCaption } from '@/utils/chat-models.uts'
	import { setActiveAgentRuntimeId, setContextPreviewPayload, setFilesInitialPath, setMemoryRouteState } from '@/utils/runtime-state.uts'
	import { buildPickedFileContextText, isChooseCancelError, isPickedImageFile, parsePickedFileInfo, parsePickedImagePath, type PickedLocalFile } from '@/utils/attachment-reader.uts'
	import { handleCameraPickerFailure } from '@/utils/media-permission.uts'
	import {
		buildGroupDispatchHistoryText,
		buildGroupMemberAgentItems as buildGroupMemberAgentItemsForPage,
		buildGroupMemberAgentNames,
		buildGroupToolbarTrackStyle,
		calcGroupInputHeight,
		getGroupMessagePartsForView,
		isGroupAgentMessage,
		isGroupUserMessage,
		normalizeGroupUserSenderNames,
		readGroupMessageHideThinking,
		readGroupMessageMsgSegmentation,
		readGroupMessageSenderName,
		readGroupUserMessageSenderName,
		stringifyGroupContextPreview,
	} from '@/utils/group-chat-page-helpers.uts'
		import {
			buildChatStreamScrollTop,
			CHAT_IDLE_SCROLL_BOTTOM_TOP,
			CHAT_STREAM_SCROLL_DELAY_MS,
			nextChatStreamScrollTick,
		} from '@/utils/chat-stream-events.uts'
		import {
			buildChatScrollbarThumbStyle,
		clampChatScrollTarget,
		isChatScrollAtBottom,
		resolveChatScrollbarDragTarget,
		resolveChatScrollbarTrackTarget,
	} from '@/utils/chat-scroll-helpers.uts'
	import {
		CHAT_MESSAGE_WINDOW_BASE_SIZE,
		CHAT_MESSAGE_WINDOW_EDGE_THRESHOLD_PX,
		type ChatMessageWindowItem,
		buildChatMessageWindowRange,
		isChatMessageWindowAtRecentEnd,
		resolveChatMessageWindowEnd,
		resolveRecentChatMessageWindowStart,
		resolveShiftedChatMessageWindowStart,
	} from '@/utils/chat-message-window.uts'
	import { eventBus } from '@/utils/event-bus.uts'
	import { resolveKeyboardInset } from '@/utils/keyboard-inset.uts'
	import { NYX_FLOAT_CONTEXT_GROUP, NYX_FLOAT_VOICE_EVENT, activateNyxFloatVoiceContext, consumePendingNyxFloatVoiceText, deactivateNyxFloatVoiceContext, readNyxFloatVoiceContext } from '@/utils/nyx-float-voice.uts'
	import {
		acknowledgeGroupChatTurnError,
		getGroupChatRuntimeEventName,
		getGroupChatTurnErrorMessage,
		getGroupChatTurnErrorRevision,
		getGroupChatTurnMessages,
		isGroupChatTurnRunning,
		startGroupChatTurn,
		stopGroupChatTurn,
	} from '@/utils/group-chat-turn-runtime.uts'
	import {
		GROUP_MESSAGE_SENDER_AGENT,
		GROUP_MESSAGE_AUDIENCE_USER,
		GROUP_MESSAGE_VISIBILITY_PRIVATE,
		type GroupChat,
		type GroupChatSession,
		createDefaultWritingGroupChat,
		createGroupUserFileMessage,
		createGroupUserImageMessage,
		createGroupUserMessage,
		displaySessionTitle,
		ensureGroupActiveSession,
		getActiveGroupChatId,
		getGroupChatById,
		getGroupMessages,
		getGroupSessionById,
		getGroupSessionWorkspaceDir,
		getGroupMessagesVisibleToUser,
		resolveGroupReviewerAgentId,
		resolveGroupSchedulerAgentId,
		revokeGroupAgentMessage,
		saveGroupMessages,
		setActiveGroupSession,
	} from '@/utils/group-chat-service.uts'

	let groupNyxFloatVoiceCallback: (() => void) | null = null
let groupTurnRuntimeCallback: (() => void) | null = null
let groupTurnRuntimeEventName: string = ''
let groupTurnRuntimeSyncTimer: number = -1

	export default {
		data() {
			return {
				groupId: '' as string,
				sessionId: '' as string,
				group: null as GroupChat | null,
				session: null as GroupChatSession | null,
				messages: [] as UTSJSONObject[],
				inputText: '' as string,
				inputHeight: 36 as number,
				isGenerating: false as boolean,
				showToolPanel: false as boolean,
				toolbarPageIndex: 0 as number,
				toolbarTouchStartX: 0 as number,
				toolbarTouchStartY: 0 as number,
				keyboardHeight: 0 as number,
				keyboardInset: 0 as number,
				keyboardBaseWindowHeight: 0 as number,
				toolbarTouchCurrentX: 0 as number,
				toolbarDragOffset: 0 as number,
				toolbarViewportWidth: 0 as number,
				toolbarDragging: false as boolean,
					toolbarSwipeMoved: false as boolean,
					toolbarSwipeLockedUntil: 0 as number,
					_streamScrollTick: 0 as number,
					streamScrollTimer: -1 as number,
					scrollTop: 0 as number,
				messageWindowStartIndex: 0 as number,
				messageWindowEndIndex: 0 as number,
				messageTotalCount: 0 as number,
				messageWindowShifting: false as boolean,
				messageWindowShiftToken: 0 as number,
				messageWindowShiftLockUntil: 0 as number,
				messagesRevision: 0 as number,
				/** 流式期间是否跟随尾部，只由用户主动上滑取消 */
				streamFollowBottom: true as boolean,
				scrollViewHeight: 0 as number,
				scrollContentHeight: 0 as number,
				scrollOffset: 0 as number,
				isAtBottom: true as boolean,
				scrollbarDragging: false as boolean,
				scrollbarDragStartY: 0 as number,
				scrollbarDragStartTop: 0 as number,
				scrollbarTrackTop: 0 as number,
				longpressCancelToken: 0 as number,
				userNickname: '' as string,
				userAvatar: '' as string,
					imageCaptionTaskId: 0 as number,
					keyboardHeightListenerId: -1 as number,
					measureScrollTimer: -1 as number,
					measureStableTimer: -1 as number,
					pageVisible: true as boolean,
					seenRuntimeErrorRevision: 0 as number,
				}
		},
		computed: {
			headerTitle(): string {
				const session = this.session
				return session != null ? displaySessionTitle(session) : '群聊'
			},
			emptyTitle(): string {
				const group = this.group
				return group != null ? group.name : '群聊'
			},
			allVisibleMessages(): UTSJSONObject[] {
				const revision = this.messagesRevision
				if (revision < 0) { return [] as UTSJSONObject[] }
				return getGroupMessagesVisibleToUser(this.messages)
			},
			visibleMessageItems(): ChatMessageWindowItem[] {
				return buildChatMessageWindowRange(this.allVisibleMessages, this.messageWindowStartIndex, this.messageWindowEndIndex)
			},
			allVisibleMessageCount(): number {
				return this.allVisibleMessages.length
			},
			toolbarTrackStyle(): string {
				return buildGroupToolbarTrackStyle(this.toolbarPageIndex, this.toolbarViewportWidth, this.toolbarDragOffset)
			},
			scrollbarThumbStyle(): string {
				return buildChatScrollbarThumbStyle(this.scrollContentHeight, this.scrollViewHeight, this.scrollOffset)
			},
			showCustomScrollbar(): boolean {
				return this.messageTotalCount <= CHAT_MESSAGE_WINDOW_BASE_SIZE && this.scrollViewHeight > 0 && this.scrollContentHeight > this.scrollViewHeight + 2
			},
			showBackToBottom(): boolean {
				return this.messageTotalCount > 0 && this.isAtBottom == false
			}
		},
		onLoad() {
			this.loadUserProfile()
			this.loadGroup()
			try {
				const windowInfo = uni.getWindowInfo()
				this.keyboardBaseWindowHeight = windowInfo.windowHeight
			} catch (error) {
				this.keyboardBaseWindowHeight = 0
			}
			this.keyboardHeightListenerId = uni.onKeyboardHeightChange((res: OnKeyboardHeightChangeCallbackResult) => {
				const keepBottom = this.isAtBottom
				let currentWindowHeight = this.keyboardBaseWindowHeight
				try {
					const windowInfo = uni.getWindowInfo()
					currentWindowHeight = windowInfo.windowHeight
				} catch (error) {
					currentWindowHeight = this.keyboardBaseWindowHeight
				}
				if (res.height == 0 && currentWindowHeight > 0) {
					this.keyboardBaseWindowHeight = currentWindowHeight
				}
				this.keyboardHeight = res.height
				this.keyboardInset = resolveKeyboardInset(res.height, this.keyboardBaseWindowHeight, currentWindowHeight)
				if (res.height > 0 && this.showToolPanel == true) {
					this.showToolPanel = false
				}
					setTimeout(() => {
						if (this.pageVisible == false) { return }
						this.scheduleMeasureMessageScroll()
					if (keepBottom == true) {
						this.scrollToBottom()
					}
				}, 120)
			})
			groupNyxFloatVoiceCallback = () => {
				this.consumeNyxFloatVoiceText()
			}
			const callback = groupNyxFloatVoiceCallback
			if (callback != null) {
				eventBus.on(NYX_FLOAT_VOICE_EVENT, callback)
			}
		},
			onShow() {
				this.pageVisible = true
					this.loadUserProfile()
				this.loadGroup()
				this.syncGroupTurnRuntime()
				activateNyxFloatVoiceContext(NYX_FLOAT_CONTEXT_GROUP)
			this.consumeNyxFloatVoiceText()
		},
		onReady() {
			this.scheduleMeasureMessageScroll()
			this.scrollToBottom()
		},
			onHide() {
				this.pageVisible = false
				if (this.streamScrollTimer != -1) { clearTimeout(this.streamScrollTimer); this.streamScrollTimer = -1 }
				if (this.measureScrollTimer != -1) { clearTimeout(this.measureScrollTimer); this.measureScrollTimer = -1 }
				if (this.measureStableTimer != -1) { clearTimeout(this.measureStableTimer); this.measureStableTimer = -1 }
				deactivateNyxFloatVoiceContext(NYX_FLOAT_CONTEXT_GROUP)
			},
			onUnload() {
				this.pageVisible = false
				if (this.streamScrollTimer != -1) { clearTimeout(this.streamScrollTimer); this.streamScrollTimer = -1 }
				if (this.measureScrollTimer != -1) { clearTimeout(this.measureScrollTimer); this.measureScrollTimer = -1 }
				if (this.measureStableTimer != -1) { clearTimeout(this.measureStableTimer); this.measureStableTimer = -1 }
			if (groupTurnRuntimeSyncTimer != -1) {
				clearTimeout(groupTurnRuntimeSyncTimer)
				groupTurnRuntimeSyncTimer = -1
			}
			if (this.keyboardHeightListenerId != -1) {
				uni.offKeyboardHeightChange(this.keyboardHeightListenerId)
				this.keyboardHeightListenerId = -1
			}
			const callback = groupNyxFloatVoiceCallback
			if (callback != null) {
				eventBus.off(NYX_FLOAT_VOICE_EVENT, callback)
			}
			groupNyxFloatVoiceCallback = null
			const runtimeCallback = groupTurnRuntimeCallback
			if (runtimeCallback != null && groupTurnRuntimeEventName != '') {
				eventBus.off(groupTurnRuntimeEventName, runtimeCallback)
			}
			groupTurnRuntimeCallback = null
			groupTurnRuntimeEventName = ''
			deactivateNyxFloatVoiceContext(NYX_FLOAT_CONTEXT_GROUP)
		},
		methods: {
			loadUserProfile(): void {
				const profile = loadChatUserProfile()
				this.userNickname = profile.nickname
				this.userAvatar = profile.avatar
			},
			loadGroup(): void {
				try {
					this.imageCaptionTaskId++
					let groupId = getActiveGroupChatId()
					if (groupId == '') {
						const group = createDefaultWritingGroupChat()
						groupId = group.id
					}
					let group = getGroupChatById(groupId)
					if (group == null) {
						group = createDefaultWritingGroupChat()
						groupId = group.id
					}
					const session = ensureGroupActiveSession(group)
					if (setActiveGroupSession(group.id, session.id) == false) {
						uni.showToast({ position: 'bottom', title: '群聊状态保存失败，请重试', icon: 'none' })
						return
					}
					if (this.sessionId != session.id) {
						this.seenRuntimeErrorRevision = 0
					}
					this.groupId = group.id
					this.sessionId = session.id
					this.group = group
					this.session = session
					this.messages = getGroupChatTurnMessages(group.id, session.id)
					this.isGenerating = isGroupChatTurnRunning(session.id)
					this.bindGroupTurnRuntime()
					this.normalizeUserSenderNames()
					this.resetMessageWindowToRecent()
					this.scrollToBottom()
				} catch (e: any) {
					uni.showToast({ position: 'bottom', title: '群聊加载失败，请重试', icon: 'none' })
				}
			},
			goBack(): void { uni.navigateBack() },
			bindGroupTurnRuntime(): void {
				const oldCallback = groupTurnRuntimeCallback
				if (oldCallback != null && groupTurnRuntimeEventName != '') {
					eventBus.off(groupTurnRuntimeEventName, oldCallback)
				}
					groupTurnRuntimeEventName = getGroupChatRuntimeEventName(this.sessionId)
					groupTurnRuntimeCallback = () => {
						if (this.pageVisible == false) { return }
						if (groupTurnRuntimeSyncTimer != -1) { return }
					groupTurnRuntimeSyncTimer = setTimeout(() => {
						groupTurnRuntimeSyncTimer = -1
						this.syncGroupTurnRuntime()
					}, 40)
				}
				const callback = groupTurnRuntimeCallback
				if (callback != null && groupTurnRuntimeEventName != '') {
					eventBus.on(groupTurnRuntimeEventName, callback)
				}
			},
			syncGroupTurnRuntime(): void {
				if (this.groupId == '' || this.sessionId == '') { return }
				const keepBottom = this.streamFollowBottom
				this.messages = getGroupChatTurnMessages(this.groupId, this.sessionId)
				this.messagesRevision++
				this.isGenerating = isGroupChatTurnRunning(this.sessionId)
				const errorRevision = getGroupChatTurnErrorRevision(this.sessionId)
				if (errorRevision > this.seenRuntimeErrorRevision) {
					this.seenRuntimeErrorRevision = errorRevision
					const errorMessage = getGroupChatTurnErrorMessage(this.sessionId)
					if (errorMessage != '') {
						uni.showToast({ position: 'bottom', title: errorMessage, icon: 'none' })
					}
					acknowledgeGroupChatTurnError(this.sessionId, errorRevision)
				}
				const freshSession = getGroupSessionById(this.groupId, this.sessionId)
				if (freshSession != null) { this.session = freshSession }
				this.syncMessageWindowBounds(keepBottom)
				if (keepBottom == true) {
					this.scrollToBottom()
				} else {
					this.scheduleMeasureMessageScroll()
				}
			},
			goSettings(): void {
				if (this.consumeToolbarSwipeClick() == true) { return }
				uni.navigateTo({ url: '/pages/group-chat-settings/group-chat-settings' })
			},
			goSessions(): void {
				if (this.consumeToolbarSwipeClick() == true) { return }
				uni.navigateTo({ url: '/pages/group-chat-sessions/group-chat-sessions' })
			},
			toggleToolPanel(): void {
				const keepBottom = this.isAtBottom == true
				this.showToolPanel = !this.showToolPanel
				if (this.showToolPanel == true) {
					this.toolbarPageIndex = 0
					this.toolbarDragOffset = 0
					this.measureToolbarViewport()
				}
				if (keepBottom == true) {
					this.scrollToBottom()
				} else {
					this.scheduleMeasureMessageScroll()
				}
			},
			setToolbarPage(index: number): void {
				if (index < 0 || index > 1) { return }
				this.toolbarPageIndex = index
				this.toolbarDragOffset = 0
				this.toolbarDragging = false
			},
			prevToolbarPage(): void {
				if (this.toolbarPageIndex <= 0) { return }
				this.setToolbarPage(this.toolbarPageIndex - 1)
			},
			nextToolbarPage(): void {
				if (this.toolbarPageIndex >= 1) { return }
				this.setToolbarPage(this.toolbarPageIndex + 1)
			},
			measureToolbarViewport(): void {
				setTimeout(() => {
					const query = uni.createSelectorQuery().in(this)
					query.select('#toolbar-slider-viewport').boundingClientRect()
					query.exec((res: any) => {
						const rows = res as UTSArray<any> | null
						if (rows == null || rows.length == 0) { return }
						const rect = rows[0] as NodeInfo | null
						if (rect == null) { return }
						const width = rect.width as number | null
						if (width != null && width > 0) {
							this.toolbarViewportWidth = width
						}
					})
				}, 40)
			},
			onToolbarTouchStart(e: UniTouchEvent): void {
				if (e.touches.length == 0) { return }
				this.measureToolbarViewport()
				this.toolbarTouchStartX = e.touches[0].screenX
				this.toolbarTouchStartY = e.touches[0].screenY
				this.toolbarTouchCurrentX = this.toolbarTouchStartX
				this.toolbarDragOffset = 0
				this.toolbarSwipeMoved = false
				this.toolbarDragging = true
			},
			onToolbarTouchMove(e: UniTouchEvent): void {
				if (e.touches.length == 0) { return }
				const currentX = e.touches[0].screenX
				const currentY = e.touches[0].screenY
				const dx = currentX - this.toolbarTouchStartX
				const dy = currentY - this.toolbarTouchStartY
				const absX = Math.abs(dx)
				const absY = Math.abs(dy)
				this.toolbarTouchCurrentX = currentX
				if (absX <= 8 || absX <= absY * 1.15) {
					return
				}
				this.toolbarSwipeMoved = true
				this.toolbarSwipeLockedUntil = Date.now() + 350
				let offset = dx
				if ((this.toolbarPageIndex == 0 && dx > 0) || (this.toolbarPageIndex == 1 && dx < 0)) {
					offset = dx * 0.28
				}
				this.toolbarDragOffset = offset
			},
			onToolbarTouchEnd(e: UniTouchEvent): void {
				if (e.changedTouches.length == 0) { return }
				const endX = e.changedTouches[0].screenX
				const endY = e.changedTouches[0].screenY
				const dx = endX - this.toolbarTouchStartX
				const dy = endY - this.toolbarTouchStartY
				const absX = Math.abs(dx)
				const absY = Math.abs(dy)
				this.toolbarDragging = false
				this.toolbarDragOffset = 0
				if (this.toolbarSwipeMoved == true) {
					this.toolbarSwipeLockedUntil = Date.now() + 350
				}
				if (absX < 40 || absX <= absY * 1.4) { return }
				if (dx < 0 && this.toolbarPageIndex < 1) {
					this.nextToolbarPage()
				} else if (dx > 0 && this.toolbarPageIndex > 0) {
					this.prevToolbarPage()
				}
			},
			onToolbarTouchCancel(): void {
				this.toolbarDragging = false
				this.toolbarDragOffset = 0
				if (this.toolbarSwipeMoved == true) {
					this.toolbarSwipeLockedUntil = Date.now() + 350
				}
			},
			consumeToolbarSwipeClick(): boolean {
				const now = Date.now()
				if (this.toolbarSwipeMoved == true || now < this.toolbarSwipeLockedUntil) {
					this.toolbarSwipeMoved = false
					return true
				}
				return false
			},
			onMsgScroll(e: UniScrollEvent): void {
				this.longpressCancelToken++
				this.scrollOffset = e.detail.scrollTop
				this.updateBottomState()
				this.maybeShiftMessageWindow()
			},
			onMsgTouchMove(): void {
				this.longpressCancelToken++
				if (this.isGenerating == true) {
					this.streamFollowBottom = false
					if (this.streamScrollTimer != -1) {
						clearTimeout(this.streamScrollTimer)
						this.streamScrollTimer = -1
					}
				}
			},
			updateBottomState(): void {
				const windowAtRecentEnd = isChatMessageWindowAtRecentEnd(this.messageTotalCount, this.messageWindowEndIndex)
				this.isAtBottom = windowAtRecentEnd == true && isChatScrollAtBottom(this.scrollOffset, this.scrollContentHeight, this.scrollViewHeight)
			},
				scheduleMeasureMessageScroll(): void {
					if (this.measureScrollTimer != -1) { clearTimeout(this.measureScrollTimer); this.measureScrollTimer = -1 }
					if (this.measureStableTimer != -1) { clearTimeout(this.measureStableTimer); this.measureStableTimer = -1 }
					this.measureScrollTimer = setTimeout(() => {
						this.measureScrollTimer = -1
						if (this.pageVisible == true) { this.measureMessageScrollSize() }
					}, 60)
					this.measureStableTimer = setTimeout(() => {
						this.measureStableTimer = -1
						if (this.pageVisible == true) { this.measureMessageScrollSize() }
					}, 260)
				},
			measureMessageScrollSize(): void {
				const query = uni.createSelectorQuery().in(this)
				query.select('#group-message-scroll').boundingClientRect()
				query.select('#group-scroll-anchor').boundingClientRect()
				query.exec((res: any) => {
					const rows = res as UTSArray<any> | null
					if (rows == null || rows.length < 2) { return }
					const viewRect = rows[0] as NodeInfo | null
					const anchorRect = rows[1] as NodeInfo | null
					if (viewRect != null) {
						const viewHeight = viewRect.height as number | null
						if (viewHeight != null && viewHeight > 0) {
							this.scrollViewHeight = viewHeight
						}
						const viewTop = viewRect.top as number | null
						if (viewTop != null) {
							this.scrollbarTrackTop = viewTop
						}
					}
					if (viewRect != null && anchorRect != null) {
						const anchorTop = anchorRect.top as number | null
						const viewTop = viewRect.top as number | null
						const anchorHeight = anchorRect.height as number | null
						if (anchorTop != null && viewTop != null && anchorHeight != null) {
							const nextHeight = anchorTop - viewTop + anchorHeight + this.scrollOffset
							if (nextHeight > 0) {
								this.scrollContentHeight = nextHeight
							}
						}
					}
					this.updateBottomState()
				})
			},
			getScrollbarTouchY(e: UniTouchEvent): number | null {
				if (e.touches.length == 0) { return null }
				if (this.scrollbarTrackTop <= 0) { return null }
				return e.touches[0].pageY - this.scrollbarTrackTop
			},
			commitMessageScrollTop(targetTop: number): void {
				const safeTop = clampChatScrollTarget(targetTop, this.scrollContentHeight, this.scrollViewHeight)
				this.scrollTop = safeTop
				this.scrollOffset = safeTop
				this.updateBottomState()
			},
			onScrollbarTrackTap(e: UniTouchEvent): void {
				const y = this.getScrollbarTouchY(e)
				if (y == null) { return }
				if (this.isGenerating == true) { this.streamFollowBottom = false }
				this.clearGroupStreamScrollTimer()
				this.commitMessageScrollTop(resolveChatScrollbarTrackTarget(y, this.scrollContentHeight, this.scrollViewHeight))
			},
			onScrollbarThumbStart(e: UniTouchEvent): void {
				const y = this.getScrollbarTouchY(e)
				if (y == null) { return }
				if (this.isGenerating == true) { this.streamFollowBottom = false }
				this.clearGroupStreamScrollTimer()
				this.scrollbarDragging = true
				this.scrollbarDragStartY = y
				this.scrollbarDragStartTop = this.scrollOffset
			},
			onScrollbarThumbMove(e: UniTouchEvent): void {
				if (this.scrollbarDragging == false) { return }
				const y = this.getScrollbarTouchY(e)
				if (y == null) { return }
				const target = resolveChatScrollbarDragTarget(this.scrollbarDragStartTop, y - this.scrollbarDragStartY, this.scrollContentHeight, this.scrollViewHeight)
				this.commitMessageScrollTop(target)
			},
			onScrollbarTouchEnd(_e: UniTouchEvent): void {
				this.scrollbarDragging = false
			},
			scrollToBottomFromButton(): void {
				this.scrollToBottom()
			},

			messageViewKey(_msg: UTSJSONObject, index: number): string {
				// 不读取数据库原生主键，避免 Android Long 被强转为 string。
				return 'index-' + index
			},

			messageWindowItemId(sourceIndex: number): string {
				return 'group-window-message-' + sourceIndex
			},

			refreshMessagesView(): void {
				const keepRecent = this.isGenerating == true ? this.streamFollowBottom : this.isAtBottom == true
				this.messagesRevision++
				this.syncMessageWindowBounds(keepRecent)
			},

			onMessageContentResize(): void {
				this.scheduleMeasureMessageScroll()
			},

			syncMessageWindowBounds(keepRecent: boolean): void {
				const source = this.allVisibleMessages
				const total = source.length
				this.messageTotalCount = total
				let start = this.messageWindowStartIndex
				if (keepRecent == true || this.messageWindowEndIndex <= this.messageWindowStartIndex) {
					start = resolveRecentChatMessageWindowStart(total)
				} else {
					start = resolveShiftedChatMessageWindowStart(total, start, 0)
				}
				this.messageWindowStartIndex = start
				this.messageWindowEndIndex = resolveChatMessageWindowEnd(total, start)
			},
			resetMessageWindowToRecent(): void {
				this.syncMessageWindowBounds(true)
				this.scheduleMeasureMessageScroll()
			},
			maybeShiftMessageWindow(): void {
				if (this.messageWindowShifting == true || Date.now() < this.messageWindowShiftLockUntil) { return }
				if (this.messageTotalCount <= CHAT_MESSAGE_WINDOW_BASE_SIZE || this.scrollViewHeight <= 0) { return }
				if (this.scrollOffset <= CHAT_MESSAGE_WINDOW_EDGE_THRESHOLD_PX && this.messageWindowStartIndex > 0) {
					this.shiftMessageWindow(-1)
					return
				}
				const bottomGap = this.scrollContentHeight - this.scrollOffset - this.scrollViewHeight
				if (bottomGap <= CHAT_MESSAGE_WINDOW_EDGE_THRESHOLD_PX && this.messageWindowEndIndex < this.messageTotalCount) {
					this.shiftMessageWindow(1)
				}
			},
			shiftMessageWindow(direction: number): void {
				const nextStart = resolveShiftedChatMessageWindowStart(this.messageTotalCount, this.messageWindowStartIndex, direction)
				if (nextStart == this.messageWindowStartIndex) { return }
				const items = this.visibleMessageItems
				if (items.length == 0) { return }
				let anchorPosition = direction < 0 ? 1 : items.length - 2
				if (anchorPosition < 0) { anchorPosition = 0 }
				if (anchorPosition >= items.length) { anchorPosition = items.length - 1 }
				const anchorIndex = items[anchorPosition].sourceIndex
				const anchorSelector = '#' + this.messageWindowItemId(anchorIndex)
				const oldScrollOffset = this.scrollOffset
				const oldStart = this.messageWindowStartIndex
				this.messageWindowShifting = true
				this.messageWindowShiftToken++
				const shiftToken = this.messageWindowShiftToken
				const query = uni.createSelectorQuery().in(this)
				query.select(anchorSelector).boundingClientRect()
				query.exec((res: any) => {
					const rows = res as UTSArray<any> | null
					const oldRect = rows != null && rows.length > 0 ? rows[0] as NodeInfo | null : null
					const oldTop = oldRect != null ? oldRect.top as number | null : null
					if (oldTop == null) {
						this.messageWindowShifting = false
						this.messageWindowShiftLockUntil = Date.now() + 80
						return
					}
					this.messageWindowStartIndex = nextStart
					this.messageWindowEndIndex = resolveChatMessageWindowEnd(this.messageTotalCount, nextStart)
					setTimeout(() => {
						this.finishMessageWindowShift(anchorSelector, oldTop, oldScrollOffset, oldStart, shiftToken, 0)
					}, 32)
				})
			},
			finishMessageWindowShift(anchorSelector: string, oldTop: number, oldScrollOffset: number, oldStart: number, shiftToken: number, attempt: number): void {
				if (shiftToken != this.messageWindowShiftToken) { return }
				const nextQuery = uni.createSelectorQuery().in(this)
				nextQuery.select(anchorSelector).boundingClientRect()
				nextQuery.exec((nextRes: any) => {
					if (shiftToken != this.messageWindowShiftToken) { return }
					const nextRows = nextRes as UTSArray<any> | null
					const nextRect = nextRows != null && nextRows.length > 0 ? nextRows[0] as NodeInfo | null : null
					const nextTop = nextRect != null ? nextRect.top as number | null : null
					if (nextTop == null && attempt < 2) {
						setTimeout(() => {
							this.finishMessageWindowShift(anchorSelector, oldTop, oldScrollOffset, oldStart, shiftToken, attempt + 1)
						}, 32)
						return
					}
					if (nextTop == null) {
						this.messageWindowStartIndex = oldStart
						this.messageWindowEndIndex = resolveChatMessageWindowEnd(this.messageTotalCount, oldStart)
					} else {
						let targetTop = oldScrollOffset + nextTop - oldTop
						if (targetTop < 0) { targetTop = 0 }
						this.scrollTop = targetTop
						this.scrollOffset = targetTop
					}
					this.messageWindowShifting = false
					this.messageWindowShiftLockUntil = Date.now() + 80
					this.scheduleMeasureMessageScroll()
				})
			},
			onInputLineChange(e: UniTextareaLineChangeEvent): void {
				this.inputHeight = calcGroupInputHeight(e.detail.lineCount)
				this.scheduleMeasureMessageScroll()
			},
			getMessagePartsForView(msg: UTSJSONObject): UTSJSONObject[] { return getGroupMessagePartsForView(msg) },
			readMessageHideThinking(msg: UTSJSONObject): boolean {
				return readGroupMessageHideThinking(msg)
			},
			readMessageMsgSegmentation(msg: UTSJSONObject): boolean {
				return readGroupMessageMsgSegmentation(msg)
			},
			isAgentMessage(msg: UTSJSONObject): boolean {
				return isGroupAgentMessage(msg)
			},
			isUserMessage(msg: UTSJSONObject): boolean {
				return isGroupUserMessage(msg)
			},
			isPrivateMessage(msg: UTSJSONObject): boolean {
				const visibility = msg['visibility'] as string | null
				const audience = msg['audience'] as string | null
				return visibility == GROUP_MESSAGE_VISIBILITY_PRIVATE && audience == GROUP_MESSAGE_AUDIENCE_USER
			},
			readMessageSenderName(msg: UTSJSONObject): string {
				return readGroupMessageSenderName(msg)
			},
			readUserMessageSenderName(msg: UTSJSONObject): string {
				return readGroupUserMessageSenderName(msg, this.userNickname)
			},
			normalizeUserSenderNames(): void {
				if (normalizeGroupUserSenderNames(this.messages, this.userNickname) == true) {
					this.saveMessages()
				}
			},
				clearGroupStreamScrollTimer(): void {
					if (this.streamScrollTimer != -1) {
						clearTimeout(this.streamScrollTimer)
						this.streamScrollTimer = -1
					}
				},
				performGroupStreamScrollToBottom(): void {
					this.syncMessageWindowBounds(true)
					this._streamScrollTick = nextChatStreamScrollTick(this._streamScrollTick)
					this.scrollTop = buildChatStreamScrollTop(this._streamScrollTick)
					this.isAtBottom = true
					this.scheduleMeasureMessageScroll()
				},
				scheduleGroupStreamScroll(): void {
					if (this.pageVisible == false || this.streamFollowBottom == false || this.streamScrollTimer != -1) { return }
					this.streamScrollTimer = setTimeout(() => {
						this.streamScrollTimer = -1
						if (this.pageVisible == false || this.streamFollowBottom == false) { return }
						if (this.isGenerating == true) {
							this.performGroupStreamScrollToBottom()
						} else {
							this.scrollToBottom()
						}
					}, CHAT_STREAM_SCROLL_DELAY_MS)
				},
					scrollToBottom(): void {
						this.streamFollowBottom = true
						this.resetMessageWindowToRecent()
						this.isAtBottom = true
						this.messageWindowShiftLockUntil = Date.now() + 280
						if (this.isGenerating == true) {
						this.scheduleGroupStreamScroll()
						return
					}
					this.clearGroupStreamScrollTimer()
					this.scrollTop = 0
					setTimeout(() => {
						if (this.pageVisible == false) { return }
						this.scrollTop = CHAT_IDLE_SCROLL_BOTTOM_TOP
					this.isAtBottom = true
					this.scheduleMeasureMessageScroll()
				}, 80)
			},
			scrollToBottomIfPinned(): void {
				this.refreshMessagesView()
				this.scheduleMeasureMessageScroll()
				const shouldFollow = this.isGenerating == true ? this.streamFollowBottom : this.isAtBottom == true
				if (shouldFollow == true) {
					this.scrollToBottom()
				}
			},
			saveMessages(): boolean {
				if (this.groupId == '' || this.sessionId == '') { return false }
				return saveGroupMessages(this.groupId, this.sessionId, this.messages)
			},
			sendMessage(): void {
				const text = this.inputText.trim()
				if (text == '') { return }
				if (this.isGenerating == true) { return }
				const profile = loadChatUserProfile()
				this.userNickname = profile.nickname
				this.userAvatar = profile.avatar
				const msg = createGroupUserMessage(this.groupId, this.sessionId, text, profile.nickname)
				this.messages.push(msg)
				if (this.saveMessages() == false) {
					this.messages.splice(this.messages.length - 1, 1)
					uni.showToast({ position: 'bottom', title: '消息保存失败', icon: 'none' })
					return
				}
				this.inputText = ''
				this.showToolPanel = false
				this.resetMessageWindowToRecent()
				this.scrollToBottom()
				const started = startGroupChatTurn(this.groupId, this.sessionId, '用户发送消息', true)
				if (started == false) {
					uni.showToast({ position: 'bottom', title: '讨论启动失败，请检查成员或存储', icon: 'none' })
				}
				this.isGenerating = isGroupChatTurnRunning(this.sessionId)
			},
			consumeNyxFloatVoiceText(): void {
				if (readNyxFloatVoiceContext() != NYX_FLOAT_CONTEXT_GROUP) { return }
				const content = consumePendingNyxFloatVoiceText()
				if (content == '') { return }
				if (this.isGenerating == true) {
					this.inputText = content
					uni.showToast({ position: 'bottom', title: '已填入输入框，等本轮结束再发', icon: 'none' })
					return
				}
				this.inputText = content
				this.sendMessage()
			},
			continueDiscussion(): void {
				if (this.consumeToolbarSwipeClick() == true) { return }
				if (this.isGenerating == true) { return }
				this.showToolPanel = false
				this.scrollToBottom()
				const started = startGroupChatTurn(this.groupId, this.sessionId, '用户要求继续讨论', true)
				if (started == false) {
					uni.showToast({ position: 'bottom', title: '讨论启动失败，请检查成员或存储', icon: 'none' })
				}
				this.isGenerating = isGroupChatTurnRunning(this.sessionId)
			},
			stopDiscussion(): void {
				if (this.consumeToolbarSwipeClick() == true) { return }
				this.imageCaptionTaskId++
				this.isGenerating = false
				stopGroupChatTurn(this.sessionId)
				this.syncGroupTurnRuntime()
				uni.showToast({ position: 'bottom', title: '已停止讨论', icon: 'none' })
			},
			addGroupImageMessage(imagePath: string): number {
				if (imagePath == '') { return -1 }
				const profile = loadChatUserProfile()
				this.userNickname = profile.nickname
				this.userAvatar = profile.avatar
				const msg = createGroupUserImageMessage(this.groupId, this.sessionId, imagePath, profile.nickname)
				this.messages.push(msg)
				if (this.saveMessages() == false) {
					this.messages.splice(this.messages.length - 1, 1)
					return -1
				}
				this.resetMessageWindowToRecent()
				this.scrollToBottom()
				return this.messages.length - 1
			},
			handlePickedGroupImagePath(imagePath: string, fallbackReason: string): void {
				if (imagePath == '') {
					uni.showToast({ position: 'bottom', title: '未选择图片', icon: 'none' })
					return
				}
				const msgIndex = this.addGroupImageMessage(imagePath)
				if (msgIndex < 0) {
					uni.showToast({ position: 'bottom', title: '图片消息保存失败', icon: 'none' })
					return
				}
				this.startGenerationForImage(imagePath, fallbackReason, msgIndex)
			},
			startGroupGenerationForMedia(reason: string): void {
				if (this.isGenerating == true) { return }
				const started = startGroupChatTurn(this.groupId, this.sessionId, reason, true)
				if (started == false) {
					uni.showToast({ position: 'bottom', title: '讨论启动失败，请检查成员或存储', icon: 'none' })
				}
				this.isGenerating = isGroupChatTurnRunning(this.sessionId)
			},
			startGenerationForImage(imagePath: string, fallbackReason: string, messageIndex: number): void {
				if (this.isGenerating == true) { return }
				if (messageIndex < 0 || messageIndex >= this.messages.length) { return }
				this.isGenerating = true
				this.imageCaptionTaskId++
				const taskId = this.imageCaptionTaskId
				const taskGroupId = this.groupId
				const taskSessionId = this.sessionId
				const taskMessageId = this.messages[messageIndex].id
				captionImage(imagePath).then((caption: string | null) => {
					if (taskId != this.imageCaptionTaskId) { return }
					if (this.groupId != taskGroupId || this.sessionId != taskSessionId) { return }
					if (messageIndex >= 0 && messageIndex < this.messages.length && this.messages[messageIndex].id == taskMessageId && caption != null && caption != '') {
						setImageMessageCaption(this.messages[messageIndex], caption)
						this.messages.splice(messageIndex, 1, this.messages[messageIndex])
						this.saveMessages()
					}
					this.isGenerating = false
					if (caption == null || caption == '') {
						uni.showToast({ position: 'bottom', title: '图片转述未配置或失败，已直接发送', icon: 'none' })
					}
					this.startGroupGenerationForMedia(fallbackReason)
				})
			},
			pickImage(): void {
				if (this.consumeToolbarSwipeClick() == true) { return }
				this.showToolPanel = false
				if (this.isGenerating == true) { return }
				uni.chooseImage({
					count: 1,
					sourceType: ['album'],
					sizeType: ['compressed'],
					success: (res: any) => {
						const imagePath = parsePickedImagePath(res)
						this.handlePickedGroupImagePath(imagePath, '用户发送了一张图片')
					},
					fail: (err: any) => {
						if (isChooseCancelError(err) == true) { return }
						console.log('[GroupChat] chooseImage 相册失败，尝试 chooseMedia: ' + JSON.stringify(err))
						this.pickGroupImageFromMediaFallback('用户发送了一张图片')
					}
				})
			},
			takePhoto(): void {
				if (this.consumeToolbarSwipeClick() == true) { return }
				this.showToolPanel = false
				if (this.isGenerating == true) { return }
				uni.chooseImage({
					count: 1,
					sourceType: ['camera'],
					sizeType: ['compressed'],
					success: (res: any) => {
						const imagePath = parsePickedImagePath(res)
						this.handlePickedGroupImagePath(imagePath, '用户拍摄了一张照片')
					},
					fail: (err: any) => {
						if (isChooseCancelError(err) == true) { return }
						handleCameraPickerFailure(err, 'group_chat_camera_picker')
					}
				})
			},
			pickFile(): void {
				if (this.consumeToolbarSwipeClick() == true) { return }
				this.showToolPanel = false
				if (this.isGenerating == true) { return }
				uni.chooseFile({
					count: 1,
					success: (res: any) => {
						this.addGroupFileMessage(res)
					},
					fail: (err: any) => {
						if (isChooseCancelError(err) == true) { return }
						uni.showToast({ position: 'bottom', title: '选择文件失败', icon: 'none' })
					}
				})
			},
			pickGroupImageFromMediaFallback(fallbackReason: string): void {
				uni.chooseMedia({
					count: 1,
					sourceType: ['album'],
					success: (res: any) => {
						const file: PickedLocalFile = parsePickedFileInfo(res)
						if (file.path == '') {
							uni.showToast({ position: 'bottom', title: '未选择图片', icon: 'none' })
							return
						}
						if (isPickedImageFile(file) == false) {
							uni.showToast({ position: 'bottom', title: '请选择图片文件', icon: 'none' })
							return
						}
						this.handlePickedGroupImagePath(file.path, fallbackReason)
					},
					fail: (err: any) => {
						if (isChooseCancelError(err) == true) { return }
						console.log('[GroupChat] chooseMedia 相册失败，切换文件选图: ' + JSON.stringify(err))
						uni.showToast({ position: 'bottom', title: '相册打开失败，请从文件选择图片', icon: 'none' })
						this.pickGroupImageFromFileFallback(fallbackReason)
					}
				})
			},
			pickGroupImageFromFileFallback(fallbackReason: string): void {
				uni.chooseFile({
					count: 1,
					success: (res: any) => {
						const file: PickedLocalFile = parsePickedFileInfo(res)
						if (file.path == '') {
							uni.showToast({ position: 'bottom', title: '未选择图片', icon: 'none' })
							return
						}
						if (isPickedImageFile(file) == false) {
							uni.showToast({ position: 'bottom', title: '请选择图片文件', icon: 'none' })
							return
						}
						this.handlePickedGroupImagePath(file.path, fallbackReason)
					},
					fail: (err: any) => {
						if (isChooseCancelError(err) == true) { return }
						uni.showToast({ position: 'bottom', title: '选择图片失败', icon: 'none' })
					}
				})
			},
			addGroupFileMessage(fileInfo: any): void {
				if (this.isGenerating == true) { return }
				const file = parsePickedFileInfo(fileInfo)
				if (file.path == '') {
					uni.showToast({ position: 'bottom', title: '未选择文件', icon: 'none' })
					return
				}
				if (isPickedImageFile(file) == true) {
					this.handlePickedGroupImagePath(file.path, '用户通过文件发送了一张图片')
					return
				}
				const fileText = buildPickedFileContextText(file)
				const profile = loadChatUserProfile()
				this.userNickname = profile.nickname
				this.userAvatar = profile.avatar
				this.messages.push(createGroupUserFileMessage(this.groupId, this.sessionId, file.name, file.path, profile.nickname, fileText))
				if (this.saveMessages() == false) {
					this.messages.splice(this.messages.length - 1, 1)
					uni.showToast({ position: 'bottom', title: '文件消息保存失败', icon: 'none' })
					return
				}
				this.resetMessageWindowToRecent()
				this.scrollToBottom()
				this.startGroupGenerationForMedia('用户发送了一个文件：' + file.name)
			},
			buildGroupMemberAgentItems(): UTSJSONObject[] {
				return buildGroupMemberAgentItemsForPage(this.groupId, this.group)
			},
			chooseAgentForMemory(): void {
				if (this.consumeToolbarSwipeClick() == true) { return }
				this.showToolPanel = false
				this.chooseAgentAndRun('选择要查看记忆的成员', 'memory')
			},
			chooseAgentForContext(): void {
				if (this.consumeToolbarSwipeClick() == true) { return }
				this.showToolPanel = false
				this.chooseAgentAndRun('选择要查看上下文的成员', 'context')
			},
			chooseAgentAndRun(_title: string, action: string): void {
				const items = this.buildGroupMemberAgentItems()
				if (items.length == 0) {
					uni.showToast({ position: 'bottom', title: '群里还没有成员', icon: 'none' })
					return
				}
				const names = buildGroupMemberAgentNames(items)
				uni.showActionSheet({
					itemList: names,
					success: (res) => {
						const index = res.tapIndex
						if (index < 0 || index >= items.length) { return }
						const agentId = items[index]['agentId'] as string | null
						if (agentId == null || agentId == '') { return }
						if (action == 'memory') {
							this.openMemoryForAgent(agentId)
						} else {
							this.openContextForAgent(agentId)
						}
					}
				})
			},
			openMemoryForAgent(agentId: string): void {
				const groupSchedulerAgentId = resolveGroupSchedulerAgentId(this.group)
				const groupReviewerAgentId = resolveGroupReviewerAgentId(this.group)
				if (agentId != groupSchedulerAgentId && agentId != groupReviewerAgentId && getAgentById(agentId) == null) {
					uni.showToast({ position: 'bottom', title: '该联系人已删除', icon: 'none' })
					return
				}
				setMemoryRouteState(agentId, this.sessionId)
				uni.navigateTo({ url: '/pages/memory/memory' })
			},
			openContextForAgent(agentId: string): void {
				const session = this.session
				if (session == null) { return }
				const groupSchedulerAgentId = resolveGroupSchedulerAgentId(this.group)
				const groupReviewerAgentId = resolveGroupReviewerAgentId(this.group)
				if (agentId != groupSchedulerAgentId && agentId != groupReviewerAgentId && getAgentById(agentId) == null) {
					uni.showToast({ position: 'bottom', title: '该联系人已删除', icon: 'none' })
					return
				}
				const preview = readLastLLMRequestSnapshot(agentId, session.id)
				if (preview == null) {
					uni.showToast({ position: 'bottom', title: '该成员还没有真实请求快照', icon: 'none' })
					return
				}
				setContextPreviewPayload(stringifyGroupContextPreview(preview))
				uni.navigateTo({ url: '/pages/context-preview/context-preview' })
			},
			openGroupWorkspace(): void {
				if (this.consumeToolbarSwipeClick() == true) { return }
				this.showToolPanel = false
				const group = this.group
				const session = this.session
				if (group == null || session == null) { return }
				const workspaceRoot = getGroupSessionWorkspaceDir(group.id, session.id)
				if (workspaceRoot == '') {
					uni.showToast({ position: 'bottom', title: '工作区不可用', icon: 'none' })
					return
				}
				setFilesInitialPath(workspaceRoot)
				uni.navigateTo({ url: '/pages/files/files' })
			},
			onMessageLongpress(msg: UTSJSONObject): void {
				if (this.isGenerating == true) {
					uni.showToast({ position: 'bottom', title: '本轮结束后再操作消息', icon: 'none' })
					return
				}
				const senderType = msg['senderType'] as string | null
				if (senderType != GROUP_MESSAGE_SENDER_AGENT) { return }
				const id = msg['id'] as string | null
				if (id == null || id == '') { return }
				uni.showActionSheet({
					itemList: ['撤回这条成员消息', '跳转私聊'],
					success: (res) => {
						if (res.tapIndex == 0) {
							const keepRecent = this.isAtBottom == true
							if (revokeGroupAgentMessage(this.groupId, this.sessionId, id) == false) {
								uni.showToast({ position: 'bottom', title: '撤回失败，请重试', icon: 'none' })
								return
							}
							this.messages = getGroupMessages(this.groupId, this.sessionId)
							this.syncMessageWindowBounds(keepRecent)
							this.scheduleMeasureMessageScroll()
						} else if (res.tapIndex == 1) {
							this.openAgentPrivateChat(msg)
						}
					}
				})
			},
			openAgentPrivateChat(msg: UTSJSONObject): void {
				const agentId = msg['senderAgentId'] as string | null
				if (agentId == null || agentId == '') { return }
				if (getAgentById(agentId) == null) {
					uni.showToast({ position: 'bottom', title: '该联系人已删除', icon: 'none' })
					return
				}
				setActiveAgentRuntimeId(agentId)
				uni.navigateTo({ url: '/pages/chat/chat' })
			},
			showDispatchHistory(): void {
				if (this.consumeToolbarSwipeClick() == true) { return }
				this.showToolPanel = false
				const previewText = buildGroupDispatchHistoryText(this.messages)
				if (previewText == '') {
					uni.showToast({ position: 'bottom', title: '还没有调度记录', icon: 'none' })
					return
				}
				setContextPreviewPayload(previewText)
				uni.navigateTo({ url: '/pages/context-preview/context-preview' })
			},
		}
	}
</script>

