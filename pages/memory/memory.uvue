<template>
	<view class="page-shell rice-theme-light">
		<NavBar variant="light" title="记忆管理" showBack />
		<scroll-view class="container" :scroll-y="true">
			<view class="hero-card">
				<text class="hero-title">聊天记忆</text>
				<text class="hero-desc">这里管理当前联系人的短缓存和重要信息库。短缓存最多 64 字，用来记录当前任务、临时要求或下一步动作，只会临时注入当前用户的下一次请求；重要信息按范围注入，不保存工具调用细节。</text>
			</view>

			<view class="card">
				<view class="setting-row">
					<view class="setting-text">
						<text class="setting-title">启用记忆</text>
						<text class="setting-desc">关闭后不会自动注入短缓存和重要信息，工具仍可由你手动管理。</text>
					</view>
					<rice-switch v-model="memoryEnabled" @change="saveMemoryEnabled" />
				</view>
			</view>

			<view class="card">
				<view class="card-header">
					<oui-icon-unix name="edit" size="14px" color="#6B7280" style="margin-right:6px" />
					<text class="card-title">64 字短缓存</text>
				</view>
				<textarea class="textarea" v-model="bufferContent" placeholder="例如：当前任务：修群聊工具栏误触；临时要求：回复简短。" placeholder-style="color:#9CA3AF" />
				<view class="meta-row">
					<text class="field-tip">{{bufferContent.length}}/64，适合当前任务/临时要求/下一步，超过会自动截断</text>
					<view class="inline-actions">
						<text class="text-btn" @click="clearBuffer">清空</text>
						<text class="primary-mini" @click="saveBuffer">保存</text>
					</view>
				</view>
			</view>

			<view class="card">
				<view class="card-header">
					<oui-icon-unix name="robot" size="14px" color="#6B7280" style="margin-right:6px" />
					<text class="card-title">新增重要信息</text>
				</view>
				<text class="field-label">使用范围</text>
				<scroll-view class="chip-scroll" :scroll-x="true" :show-scrollbar="false">
					<view class="chip-row">
						<view v-for="(s, si) in scopes" :key="si" class="chip" :class="newScope == s ? 'chip-active' : ''" @click="newScope = s">
							<text class="chip-text" :class="newScope == s ? 'chip-text-active' : ''">{{scopeLabel(s)}}</text>
						</view>
					</view>
				</scroll-view>

				<text class="field-label" style="margin-top:11px;">分类</text>
				<scroll-view class="chip-scroll" :scroll-x="true" :show-scrollbar="false">
					<view class="chip-row">
						<view v-for="(c, ci) in categories" :key="ci" class="chip" :class="newCategory == c ? 'chip-active' : ''" @click="newCategory = c">
							<text class="chip-text" :class="newCategory == c ? 'chip-text-active' : ''">{{categoryLabel(c)}}</text>
						</view>
					</view>
				</scroll-view>

				<view v-if="newScope == 'person_only' || newScope == 'manual_only'" class="target-panel">
					<text class="field-label">面对对象</text>
					<scroll-view class="chip-scroll" :scroll-x="true" :show-scrollbar="false">
						<view class="chip-row">
							<view class="chip" :class="newTargetType == 'user' ? 'chip-active' : ''" @click="selectNewTargetType('user')">
								<text class="chip-text" :class="newTargetType == 'user' ? 'chip-text-active' : ''">当前用户</text>
							</view>
							<view class="chip" :class="newTargetType == 'agent' ? 'chip-active' : ''" @click="selectNewTargetType('agent')">
								<text class="chip-text" :class="newTargetType == 'agent' ? 'chip-text-active' : ''">其他联系人</text>
							</view>
							<view class="chip" :class="newTargetType == 'custom' ? 'chip-active' : ''" @click="selectNewTargetType('custom')">
								<text class="chip-text" :class="newTargetType == 'custom' ? 'chip-text-active' : ''">自定义对象</text>
							</view>
						</view>
					</scroll-view>
					<scroll-view v-if="newTargetType == 'agent'" class="chip-scroll target-select" :scroll-x="true" :show-scrollbar="false">
						<view class="chip-row">
							<view v-for="(agent, ai) in agents" :key="ai" class="chip" :class="newTargetId == readAgentId(agent) ? 'chip-active' : ''" @click="selectNewAgentTarget(agent)">
								<text class="chip-text" :class="newTargetId == readAgentId(agent) ? 'chip-text-active' : ''">{{readAgentName(agent)}}</text>
							</view>
						</view>
					</scroll-view>
					<input
						v-if="newTargetType == 'custom'"
						class="flat-input target-input"
						type="text"
						v-model="newTargetId"
						placeholder="输入对象名称，比如：产品经理 / 家人 / 某个项目"
						placeholder-style="color:#D1D5DB"
					/>
					<text class="field-tip">当前新增目标：{{newTargetLabel}}</text>
				</view>

				<text class="field-label" style="margin-top:11px;">内容</text>
				<textarea class="textarea" v-model="newContent" placeholder="写一句值得长期保存的信息。别写密钥、工具参数或流水账。" placeholder-style="color:#9CA3AF" />
				<view class="param-row">
					<view class="param-item">
						<text class="field-label">优先级</text>
						<input class="flat-input" type="text" v-model="newPriority" placeholder="1-5" placeholder-style="color:#D1D5DB" />
					</view>
					<view class="pin-box">
						<text class="field-label">置顶</text>
						<rice-switch v-model="newPinned" />
					</view>
				</view>
				<view class="save-btn" @click="saveNewMemory">
					<text class="save-btn-text">保存重要信息</text>
				</view>
			</view>

			<view class="card">
				<view class="card-title-row">
					<text class="card-title">当前可见记忆</text>
					<text class="refresh-btn" @click="loadMemory">刷新</text>
				</view>

				<!-- 搜索区域 -->
				<view class="search-section">
					<view class="search-input-row">
						<input
							class="search-input"
							type="text"
							v-model="searchQuery"
							placeholder="搜索记忆内容..."
							placeholder-style="color:#9CA3AF"
							@confirm="onSearchConfirm"
						/>
						<text class="search-action" @click="loadMemory">搜索</text>
						<text v-if="searchQuery != ''" class="search-clear" @click="clearSearchFilter">✕</text>
					</view>
					<text class="field-tip search-tip">按内容关键词搜索；范围用下方「查看对象」切换。</text>
				</view>

				<text class="field-label" style="margin-top:9px;">查看对象</text>
				<scroll-view class="chip-scroll" :scroll-x="true" :show-scrollbar="false">
					<view class="chip-row">
						<view class="chip" :class="viewTargetType == 'user' ? 'chip-active' : ''" @click="selectViewTargetType('user')">
							<text class="chip-text" :class="viewTargetType == 'user' ? 'chip-text-active' : ''">当前用户</text>
						</view>
						<view class="chip" :class="viewTargetType == 'agent' ? 'chip-active' : ''" @click="selectViewTargetType('agent')">
							<text class="chip-text" :class="viewTargetType == 'agent' ? 'chip-text-active' : ''">其他联系人</text>
						</view>
						<view class="chip" :class="viewTargetType == 'custom' ? 'chip-active' : ''" @click="selectViewTargetType('custom')">
							<text class="chip-text" :class="viewTargetType == 'custom' ? 'chip-text-active' : ''">自定义对象</text>
						</view>
					</view>
				</scroll-view>
				<scroll-view v-if="viewTargetType == 'agent'" class="chip-scroll target-select" :scroll-x="true" :show-scrollbar="false">
					<view class="chip-row">
						<view v-for="(agent, vai) in agents" :key="vai" class="chip" :class="viewTargetId == readAgentId(agent) ? 'chip-active' : ''" @click="selectViewAgentTarget(agent)">
							<text class="chip-text" :class="viewTargetId == readAgentId(agent) ? 'chip-text-active' : ''">{{readAgentName(agent)}}</text>
						</view>
					</view>
				</scroll-view>
				<input
					v-if="viewTargetType == 'custom'"
					class="flat-input target-input"
					type="text"
					v-model="viewTargetId"
					placeholder="输入对象名称后点刷新"
					placeholder-style="color:#D1D5DB"
				/>
				<text class="field-tip">当前列表目标：{{viewTargetLabel}}</text>
				<view v-if="memoryList.length == 0" class="empty-card">
					<text class="empty-text">还没有记忆，存档槽空着。</text>
				</view>
				<view v-for="(item, index) in memoryList" :key="index" class="memory-item">
					<view class="memory-head">
						<text class="memory-tag">{{itemScopeLabel(item)}} / {{itemCategoryLabel(item)}}</text>
						<text class="memory-forget" @click="forgetMemoryByItem(item)">遗忘</text>
					</view>
					<text class="memory-content">{{item['content']}}</text>
					<text class="memory-meta">P{{itemPriorityText(item)}} · {{itemPinnedText(item)}} · 面对 {{itemTargetLabel(item)}}</text>
				</view>
			</view>

			<view class="danger-card">
				<text class="danger-title">危险区</text>
				<text class="danger-desc">清空会归档当前联系人面向当前查看对象的所有可见重要记忆，短缓存不受影响。</text>
				<view class="danger-btn" @click="confirmClearCore">
					<text class="danger-btn-text">清空当前联系人记忆</text>
				</view>
			</view>

			<!-- 记忆整理日志 -->
			<view class="card log-card">
				<view class="card-header">
					<text class="card-label">📋 整理记录</text>
					<text class="log-refresh" @click="loadManagerLogs">刷新</text>
				</view>
				<view v-if="managerLogs.length == 0" class="empty-card">
					<text class="empty-text">暂无整理记录</text>
				</view>
				<view v-for="(log, lIdx) in managerLogs" :key="lIdx" class="log-item">
					<view class="log-head">
						<text class="log-time">{{formatLogTime(log)}}</text>
						<view class="log-badges">
							<text class="log-badge" v-if="parseLogNumber(log, 'dropped_count') > 0">整理 {{parseLogNumber(log, 'dropped_count')}} 条</text>
							<text class="log-badge log-badge-save" v-if="parseLogNumber(log, 'saved_count') > 0">保存 {{parseLogNumber(log, 'saved_count')}}</text>
							<text class="log-badge log-badge-forget" v-if="parseLogNumber(log, 'forgotten_count') > 0">遗忘 {{parseLogNumber(log, 'forgotten_count')}}</text>
						</view>
					</view>
					<text class="log-summary" v-if="parseLogString(log, 'summary') != ''">{{parseLogString(log, 'summary')}}</text>
					<view class="log-detail-row" v-if="parseLogString(log, 'details') != ''" @click="toggleLogDetail(log, lIdx)">
						<text class="log-detail-toggle">{{logDetailExpanded[lIdx] == true ? '收起操作明细 ▲' : '展开操作明细 ▼'}}</text>
					</view>
					<view class="log-detail-list" v-if="logDetailExpanded[lIdx] == true">
						<view v-for="(op, oIdx) in parseLogOps(log)" :key="oIdx" class="log-op-item">
							<text class="log-op-tool">{{parseLogString(op, 'tool')}}</text>
							<text class="log-op-args">{{parseLogString(op, 'args')}}</text>
						</view>
					</view>
				</view>
			</view>
		</scroll-view>
	</view>
</template>

<script lang="uts">
	import {
		getMemoryEnabled,
		setMemoryEnabled,
		getMemoryBuffer,
		updateMemoryBuffer,
		clearMemoryBuffer,
		listCoreMemory,
		saveCoreMemory,
		archiveCoreMemory,
		clearCoreMemoryForTarget,
		searchCoreMemoryAdvanced,
		listMemoryManagerLogs,
	} from '@/uni_modules/agent-core/utssdk/memory.uts'
	import { getAgents } from '@/utils/agent.uts'
	import {
		buildMemoryCoreInput,
		buildMemoryForgetPreview,
		buildMemorySearchFilter,
		buildMemoryTargetDisplayLabel,
		buildMemoryTargetPersonKey,
		formatMemoryCategoryLabel,
		formatMemoryItemCategoryLabel,
		formatMemoryItemPinnedText,
		formatMemoryItemPriorityText,
		formatMemoryItemScopeLabel,
		formatMemoryItemTargetLabel,
		formatMemoryLogTime,
		formatMemoryScopeLabel,
		parseMemoryLogNumber,
		parseMemoryLogOps,
		parseMemoryLogString,
		readMemoryAgentId,
		readMemoryAgentName,
		readMemoryItemId,
		readUniModalConfirm,
		resolveMemoryTargetId,
	} from '@/utils/memory-page-helpers.uts'
	import { consumeMemoryRouteAgentId, consumeMemoryRouteConversationId, getActiveAgentRuntimeId, getActiveConversationRuntimeId } from '@/utils/runtime-state.uts'

	export default {
		data() {
			return {
				agentId: '' as string,
				conversationId: '' as string,
				personId: 'default' as string,
				memoryEnabled: true as boolean,
				bufferContent: '' as string,
				memoryList: [] as UTSJSONObject[],
				agents: [] as UTSJSONObject[],
				// 搜索
				searchQuery: '' as string,
				scopes: ['person_only', 'always', 'conversation_only', 'manual_only', 'rule'] as string[],
				categories: ['important', 'preference', 'fact', 'impression', 'rule'] as string[],
				newScope: 'person_only' as string,
				newCategory: 'important' as string,
				newTargetType: 'user' as string,
				newTargetId: '' as string,
				newContent: '' as string,
				newPriority: '3' as string,
				newPinned: false as boolean,
				viewTargetType: 'user' as string,
				viewTargetId: '' as string,
				/** 记忆整理日志 */
				managerLogs: [] as UTSJSONObject[],
				logDetailExpanded: {} as UTSJSONObject,
			}
		},
		computed: {
			newTargetLabel(): string {
				return buildMemoryTargetDisplayLabel(this.newTargetType, this.newTargetId)
			},

			viewTargetLabel(): string {
				return buildMemoryTargetDisplayLabel(this.viewTargetType, this.viewTargetId)
			},
		},
		onLoad() {
			this.agentId = consumeMemoryRouteAgentId()
			this.conversationId = consumeMemoryRouteConversationId()
			if (this.agentId == '') {
				this.agentId = getActiveAgentRuntimeId()
			}
			if (this.conversationId == '') {
				this.conversationId = getActiveConversationRuntimeId()
			}
			if (this.agentId == '') {
				this.agentId = 'default_agent'
			}
			if (this.conversationId == '') {
				this.conversationId = 'global'
			}
			this.agents = getAgents()
			this.loadMemory()
			this.loadManagerLogs()
		},
		methods: {
			readAgentId(agent: UTSJSONObject): string {
				return readMemoryAgentId(agent)
			},

			readAgentName(agent: UTSJSONObject): string {
				return readMemoryAgentName(agent)
			},

			scopeLabel(scope: string): string {
				return formatMemoryScopeLabel(scope)
			},

			categoryLabel(category: string): string {
				return formatMemoryCategoryLabel(category)
			},

			itemScopeLabel(item: UTSJSONObject): string {
				return formatMemoryItemScopeLabel(item)
			},

			itemCategoryLabel(item: UTSJSONObject): string {
				return formatMemoryItemCategoryLabel(item)
			},

			itemPriorityText(item: UTSJSONObject): string {
				return formatMemoryItemPriorityText(item)
			},

			itemPinnedText(item: UTSJSONObject): string {
				return formatMemoryItemPinnedText(item)
			},

			itemTargetLabel(item: UTSJSONObject): string {
				return formatMemoryItemTargetLabel(item)
			},

			buildNewTargetPersonId(): string {
				return buildMemoryTargetPersonKey(this.newTargetType, this.newTargetId)
			},

			buildViewTargetPersonId(): string {
				return buildMemoryTargetPersonKey(this.viewTargetType, this.viewTargetId)
			},

			selectNewTargetType(targetType: string) {
				this.newTargetType = targetType
				this.newTargetId = resolveMemoryTargetId(targetType, this.newTargetId, this.agents)
			},

			selectViewTargetType(targetType: string) {
				this.viewTargetType = targetType
				this.viewTargetId = resolveMemoryTargetId(targetType, this.viewTargetId, this.agents)
				this.loadMemory()
			},

			selectNewAgentTarget(agent: UTSJSONObject) {
				this.newTargetId = this.readAgentId(agent)
			},

			selectViewAgentTarget(agent: UTSJSONObject) {
				this.viewTargetId = this.readAgentId(agent)
				this.loadMemory()
			},

			loadMemory() {
				this.memoryEnabled = getMemoryEnabled()
				const viewPersonId = this.buildViewTargetPersonId()
				this.bufferContent = getMemoryBuffer(this.agentId, this.personId, this.conversationId)
				// 有搜索关键词时执行内容搜索，否则使用普通列表
				if (this.searchQuery.trim() != '') {
					this.doSearch(viewPersonId)
				} else {
					this.memoryList = listCoreMemory(this.agentId, viewPersonId, this.conversationId, true)
				}
			},

			/** 执行关键词搜索 */
			doSearch(personId: string) {
				const filter = buildMemorySearchFilter(this.searchQuery)
				this.memoryList = searchCoreMemoryAdvanced(this.agentId, personId, this.conversationId, filter)
			},

			/** 搜索确认 */
			onSearchConfirm() {
				this.loadMemory()
			},

			/** 清空搜索 */
			clearSearchFilter() {
				this.searchQuery = ''
				this.loadMemory()
			},

			saveMemoryEnabled() {
				setMemoryEnabled(this.memoryEnabled)
				uni.showToast({ position: 'bottom',  title: '已保存', icon: 'success' })
			},

			saveBuffer() {
				const finalContent = updateMemoryBuffer(this.agentId, this.personId, this.conversationId, this.bufferContent)
				this.bufferContent = finalContent
				uni.showToast({ position: 'bottom',  title: '短缓存已保存', icon: 'success' })
			},

			clearBuffer() {
				uni.showModal({
					title: '清空短缓存',
					content: '确认清空 64 字短缓存？',
					success: (res: any) => {
						if (readUniModalConfirm(res) == true) {
							clearMemoryBuffer(this.agentId, this.personId, this.conversationId)
							this.bufferContent = ''
							uni.showToast({ position: 'bottom',  title: '已清空', icon: 'none' })
						}
					}
				})
			},

			saveNewMemory() {
				if (this.newContent.trim() == '') {
					uni.showToast({ position: 'bottom',  title: '先写内容', icon: 'none' })
					return
				}
				let targetPersonId = this.buildViewTargetPersonId()
				if (this.newScope == 'person_only' || this.newScope == 'manual_only') {
					targetPersonId = this.buildNewTargetPersonId()
				}
				const input = buildMemoryCoreInput(this.newScope, this.newCategory, this.newContent, this.newPriority, this.newPinned)
				const id = saveCoreMemory(this.agentId, targetPersonId, this.conversationId, input)
				if (id == '') {
					uni.showToast({ position: 'bottom',  title: '保存失败', icon: 'none' })
					return
				}
				this.newContent = ''
				this.newPriority = '3'
				this.newPinned = false
				this.loadMemory()
				uni.showToast({ position: 'bottom',  title: '已保存', icon: 'success' })
			},

			forgetMemory(id: string) {
				archiveCoreMemory(id)
				this.loadMemory()
				uni.showToast({ position: 'bottom',  title: '已遗忘', icon: 'none' })
			},

			forgetMemoryByItem(item: UTSJSONObject) {
				const id = readMemoryItemId(item)
				if (id == '') {
					uni.showToast({ position: 'bottom',  title: '记忆 id 异常', icon: 'none' })
					return
				}
				const memoryId = id
				const preview = buildMemoryForgetPreview(item)
				uni.showModal({
					title: '遗忘记忆',
					content: '确认遗忘这条重要记忆？\n' + preview,
					success: (res: any) => {
						if (readUniModalConfirm(res) == true) {
							this.forgetMemory(memoryId)
						}
					}
				})
			},

			confirmClearCore() {
				uni.showModal({
					title: '清空记忆',
					content: '确认清空当前联系人面向当前查看对象的可见重要记忆？',
					success: (res: any) => {
						if (readUniModalConfirm(res) == true) {
							clearCoreMemoryForTarget(this.agentId, this.buildViewTargetPersonId(), this.conversationId)
							this.loadMemory()
							uni.showToast({ position: 'bottom',  title: '已清空', icon: 'none' })
						}
					}
				})
			},

			// ===== 记忆整理日志 =====

			loadManagerLogs() {
				this.managerLogs = listMemoryManagerLogs(this.agentId, this.conversationId)
			},

			formatLogTime(log: UTSJSONObject): string {
				return formatMemoryLogTime(log)
			},

			/** 从 UTSJSONObject 安全读取数字 */
			parseLogNumber(obj: UTSJSONObject, key: string): number {
				return parseMemoryLogNumber(obj, key)
			},

			/** 从 UTSJSONObject 安全读取字符串 */
			parseLogString(obj: UTSJSONObject, key: string): string {
				return parseMemoryLogString(obj, key)
			},

			/** 解析操作明细 JSON 数组 */
			parseLogOps(log: UTSJSONObject): UTSJSONObject[] {
				return parseMemoryLogOps(log)
			},

			toggleLogDetail(_log: UTSJSONObject, idx: number) {
				const key = idx + ''
				const current: boolean = (this.logDetailExpanded[key] as boolean | null) == true
				this.logDetailExpanded[key] = current ? false : true
			},
		}
	}
</script>

<style>
	.container {
		flex: 1;
		padding: 16px;
	}

	.hero-card,
	.card,
	.danger-card {
		background-color: #FFFFFF;
		border-radius: 10px;
		padding: 16px;
		margin-bottom: 12px;
	}

	.hero-title {
		font-size: 16px;
		font-weight: bold;
		color: #111827;
		margin-bottom: 6px;
	}

	.hero-desc,
	.setting-desc,
	.field-tip,
	.danger-desc {
		font-size: 12px;
		color: #6B7280;
		line-height: 18px;
	}

	.setting-row,
	.card-header,
	.card-title-row,
	.meta-row,
	.memory-head,
	.param-row,
	.inline-actions,
	.pin-box {
		flex-direction: row;
		align-items: center;
	}

	.setting-row,
	.card-title-row,
	.meta-row,
	.memory-head {
		justify-content: space-between;
	}

	.setting-text {
		flex: 1;
