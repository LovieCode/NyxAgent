<template>
	<view class="page-shell rice-theme-light">
		<NavBar variant="light" title="裁剪头像" showBack @back="goBack">
			<template #right>
				<text class="done-btn" @click="doCrop">完成</text>
			</template>
		</NavBar>
		<view
			class="crop-bg"
			@touchstart="onTouchStart"
			@touchmove="onTouchMove"
			@touchend="onTouchEnd"
		>
			<view id="cropArea" class="crop-area" :style="'width:'+areaSize+'px;height:'+areaSize+'px'">
				<view id="imageWrapper" class="image-wrapper">
					<image
						:src="imagePath"
						class="crop-image"
							mode="aspectFill"
							@load="onImageLoad"
							@error="onImageError"
					/>
				</view>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
	/**
	 * 方形头像裁剪页
	 * 使用 takeSnapshot 实现导出（App 端）
	 * 调用方：写入 crop_image_path → 裁剪 → 写 crop_result
	 *
	 * 触摸事件直接操作元素样式（style.setProperty），
	 * 不依赖 Vue 响应式绑定，因为 uni-app x UTS 中 :style 字符串
	 * 绑定可能不会重新求值。
	 */

	import { ref, onMounted } from 'vue'
	import { getRuntimeState, setRuntimeState } from '@/utils/database.uts'
	import { APP_ERROR_CATEGORY_RUNTIME, formatAppErrorForUser, reportAppErrorFromCause } from '@/utils/app-error.uts'

	const imagePath = ref('' as string)
	const areaSize = ref(300 as number)
	let imgEl: UniElement | null = null

	// 触摸拖动状态（普通变量，非响应式 — 直接操作 DOM）
	let touchStartX = 0 as number
	let touchStartY = 0 as number
	let imgLeft = 0 as number
	let imgTop = 0 as number
	let imgW = 0 as number
	let imgH = 0 as number

	// 捏合缩放状态
	let touchDist = 0 as number
	let startImgW = 0 as number
	let startImgH = 0 as number

	let loaded = false as boolean
	let cropping = false as boolean
	let imageErrorReported = false as boolean

	function showCropFailure(code: string, operation: string, userMessage: string, cause: any | null): void {
		const error = reportAppErrorFromCause(
			code,
			APP_ERROR_CATEGORY_RUNTIME,
			operation,
			userMessage,
			cause,
			true,
		)
		uni.showToast({ position: 'bottom', title: formatAppErrorForUser(error), icon: 'none' })
	}

	function navigateCropBack(operation: string): void {
		uni.navigateBack({
			fail: (err: any) => {
				cropping = false
				showCropFailure('CROP_BACK_FAILED', operation, '无法返回上一页', err)
			}
		})
	}

	onMounted(() => {
		let pathRaw = ''
		try {
			pathRaw = getRuntimeState('crop_image_path')
		} catch (e: any) {
			showCropFailure('CROP_SOURCE_READ_FAILED', 'crop_page_load', '待裁剪图片读取失败', e)
			return
		}
		if (pathRaw == '') {
			showCropFailure('CROP_SOURCE_MISSING', 'crop_page_load', '找不到待裁剪图片', 'crop_image_path 为空')
			navigateCropBack('crop_source_missing_back')
			return
		}
		imagePath.value = pathRaw
		try {
			const win = uni.getWindowInfo()
			const wwRaw = win['windowWidth']
			const ww = wwRaw != null ? (wwRaw as number) : 300
			areaSize.value = ww > 0 ? ww : 300
		} catch (e: any) {
			areaSize.value = 300
			showCropFailure('CROP_WINDOW_INFO_FAILED', 'crop_window_info', '无法读取裁剪区域尺寸', e)
		}
	})

	function applyImageStyle() {
		const el = imgEl
		if (el == null) { return }
		el.style.setProperty('width', imgW + 'px')
		el.style.setProperty('height', imgH + 'px')
		// Wrapper transform（已验证 rice-popup 在 View 上可用）
		el.style.setProperty('transform', 'translate(' + imgLeft + 'px, ' + imgTop + 'px)')
	}

	function clampPosition() {
		const fs = areaSize.value
		if (imgLeft > 0) { imgLeft = 0 }
		if (imgTop > 0) { imgTop = 0 }
		if (imgLeft + imgW < fs) { imgLeft = fs - imgW }
		if (imgTop + imgH < fs) { imgTop = fs - imgH }
	}

	function applyImageInfo(res: any): void {
		try {
			const raw = JSON.stringify(res)
			if (raw == null || raw == '') {
				showCropFailure('CROP_IMAGE_INFO_EMPTY', 'crop_get_image_info', '图片信息读取失败', 'getImageInfo 返回为空')
				return
			}
			const parsed = JSON.parse(raw) as UTSJSONObject
			const wRaw = parsed['width']
			const hRaw = parsed['height']
			if (wRaw == null || hRaw == null) {
				showCropFailure('CROP_IMAGE_SIZE_MISSING', 'crop_get_image_info', '图片尺寸读取失败', raw)
				return
			}
			const nw = wRaw as number
			const nh = hRaw as number
			if (nw <= 0 || nh <= 0) {
				showCropFailure('CROP_IMAGE_SIZE_INVALID', 'crop_get_image_info', '图片尺寸无效', 'width=' + nw + ', height=' + nh)
				return
			}

			const fs = areaSize.value
			const scaleRatio = (nw > nh) ? (fs / nh) : (fs / nw)
			imgW = nw * scaleRatio
			imgH = nh * scaleRatio
			imgLeft = (fs - imgW) / 2
			imgTop = (fs - imgH) / 2
			applyImageStyle()
			loaded = true
		} catch (e: any) {
			showCropFailure('CROP_IMAGE_INFO_PARSE_FAILED', 'crop_get_image_info', '图片信息解析失败', e)
		}
	}

	function onImageLoad(e: any) {
		if (loaded == true) { return }

		// 获取 wrapper View 引用
		imgEl = uni.getElementById('imageWrapper') as UniElement | null
		if (imgEl == null) {
			showCropFailure('CROP_IMAGE_ELEMENT_MISSING', 'crop_bind_image_element', '裁剪视图初始化失败', 'imageWrapper 元素不存在')
			return
		}

		// @load 事件不携带尺寸，用 getImageInfo 获取
		uni.getImageInfo({
			src: imagePath.value,
			success: (res: any) => {
				applyImageInfo(res)
			},
			fail: (err: any) => {
				showCropFailure('CROP_IMAGE_INFO_FAILED', 'crop_get_image_info', '图片加载失败', err)
			}
		})
	}

	function onImageError(e: any): void {
		loaded = false
		if (imageErrorReported == true) { return }
		imageErrorReported = true
		showCropFailure('CROP_IMAGE_RENDER_FAILED', 'crop_image_render', '图片加载失败', e)
	}

	function onTouchStart(e: UniTouchEvent) {
		if (loaded == false || e.touches.length == 0) { return }
		touchStartX = e.touches[0].screenX
		touchStartY = e.touches[0].screenY

		if (e.touches.length >= 2) {
			const dx = e.touches[1].screenX - e.touches[0].screenX
			const dy = e.touches[1].screenY - e.touches[0].screenY
			touchDist = Math.sqrt(dx * dx + dy * dy)
			startImgW = imgW
			startImgH = imgH
		}
	}

	function onTouchMove(e: UniTouchEvent) {
		if (loaded == false || e.touches.length == 0) { return }

		if (e.touches.length >= 2 && touchDist > 0) {
			// === 捏合缩放：以手指初始距离为基准计算缩放比 ===
			const dx = e.touches[1].screenX - e.touches[0].screenX
			const dy = e.touches[1].screenY - e.touches[0].screenY
			const dist = Math.sqrt(dx * dx + dy * dy)
			let ratio = dist / touchDist
			const fs = areaSize.value
			const minWidthRatio = fs / startImgW
			const minHeightRatio = fs / startImgH
			const minRatio = minWidthRatio > minHeightRatio ? minWidthRatio : minHeightRatio
			const startMaxSize = startImgW > startImgH ? startImgW : startImgH
			const maxRatio = (fs * 5) / startMaxSize
			if (ratio < minRatio) { ratio = minRatio }
			if (ratio > maxRatio) { ratio = maxRatio }
			// 以图片中心为基准缩放
			const cx = imgLeft + imgW / 2
			const cy = imgTop + imgH / 2
			imgW = startImgW * ratio
			imgH = startImgH * ratio
			imgLeft = cx - imgW / 2
			imgTop = cy - imgH / 2
			clampPosition()
			applyImageStyle()
		} else if (e.touches.length == 1) {
			// === 单指拖动（增量式）===
			const dx = e.touches[0].screenX - touchStartX
			const dy = e.touches[0].screenY - touchStartY
			imgLeft += dx
			imgTop += dy
			clampPosition()
			applyImageStyle()
			touchStartX = e.touches[0].screenX
			touchStartY = e.touches[0].screenY
		}
	}

	function onTouchEnd(e: UniTouchEvent) {
		touchDist = 0
		// 双指缩放后若仍有一根手指停留，重置拖动基点，避免下一帧跳位。
		if (e.touches.length > 0) {
			touchStartX = e.touches[0].screenX
			touchStartY = e.touches[0].screenY
		}
	}

	function doCrop() {
		if (loaded == false) {
			uni.showToast({ position: 'bottom', title: '图片尚未加载完成', icon: 'none' })
			return
		}
		if (cropping == true) { return }
		const target = uni.getElementById('cropArea') as UniElement | null
		if (target == null) {
			showCropFailure('CROP_TARGET_MISSING', 'crop_snapshot_target', '裁剪视图不可用', 'cropArea 元素不存在')
			return
		}
		cropping = true
		uni.showLoading({ title: '裁剪中...' })
		target.takeSnapshot({
			type: 'file',
			format: 'png',
			success: (res) => {
				const path = res.tempFilePath
				if (path == null || path == '') {
					cropping = false
					uni.hideLoading()
					showCropFailure('CROP_SNAPSHOT_EMPTY', 'crop_snapshot', '裁剪结果为空', res)
					return
				}
				if (setRuntimeState('crop_result', path) == false) {
					cropping = false
					uni.hideLoading()
					showCropFailure('CROP_RESULT_SAVE_FAILED', 'crop_result_save', '裁剪结果保存失败', 'crop_result 写入失败')
					return
				}
				uni.hideLoading()
				navigateCropBack('crop_result_back')
			},
			fail: (err: any) => {
				cropping = false
				uni.hideLoading()
				showCropFailure('CROP_SNAPSHOT_FAILED', 'crop_snapshot', '裁剪失败', err)
			}
		})
	}

	function goBack() {
		navigateCropBack('crop_cancel_back')
	}
</script>

<style>
	.crop-bg {
		flex: 1;
		background-color: #000000;
		justify-content: center;
		align-items: center;
		position: relative;
	}

	.crop-area {
		overflow: hidden;
		position: relative;
		background-color: #000000;
		border-width: 2px;
		border-style: solid;
		border-color: rgba(255,255,255,0.7);
	}

	.image-wrapper {
		position: absolute;
		left: 0;
		top: 0;
	}

	.crop-image {
		width: 100%;
		height: 100%;
	}

	.done-btn {
		font-size: 15px;
		color: #FFFFFF;
		font-weight: bold;
		padding: 8px 4px;
	}


/* ===== Nyx 子页面视觉重制 ===== */
	.page-shell { background-color: #FAF7F5; }
	.done-btn { color: #DB6F92; font-weight: bold; }
	.crop-bg { background-color: #19151A; }
	.crop-area { border-color: rgba(255, 240, 245, 0.82); border-radius: 18px; }
</style>
