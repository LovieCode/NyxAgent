<template>
	<view class="page-shell rice-theme-light">
		<NavBar :title="navTitle" showBack @back="onBack">
			<template #right>
				<text v-if="readOnly == false" class="done-btn" @click="saveAndBack">保存</text>
			</template>
		</NavBar>
		<view class="editor-wrap">
			<view class="editor-meta" v-if="subTitle != ''">
				<text class="editor-meta-text">{{ subTitle }}</text>
			</view>
			<textarea
				class="editor-input"
				v-model="editText"
				:disabled="readOnly"
				:placeholder="placeholder"
				placeholder-style="color:#D1D5DB;font-size:30rpx;"
				:auto-height="false"
				@input="onInput"
			/>
			<view class="editor-footer">
				<text class="footer-text">{{ dirty ? '未保存' : '已同步' }}</text>
				<text class="footer-text">{{ editText.length }} 字</text>
			</view>
		</view>
	</view>
</template>

<script lang="uts">
	import { readContent, writeContent, basename } from '@/utils/file-manager.uts'

	/**
	 * 通用全屏编辑器。
	 *
	 * storage 协议：
	 * - editor_mode: text | file，默认 text
	 * - editor_title: 导航标题
	 * - editor_placeholder: 占位提示
	 * - editor_target: 调用方标识
	 * - text 模式：editor_content -> editor_result，保存后 editor_result_ready = true
	 * - file 模式：editor_file_path，保存后直接写文件并设置 editor_saved = true
	 */
	export default {
		data() {
			return {
				editText: '' as string,
				initialText: '' as string,
				navTitle: '编辑' as string,
				subTitle: '' as string,
				placeholder: '输入内容...' as string,
				mode: 'text' as string,
				target: '' as string,
				filePath: '' as string,
				draftKey: 'editor_draft' as string,
				readOnly: false as boolean,
				dirty: false as boolean,
			}
		},
		onLoad() {
			this.loadEditorConfig()
		},
		methods: {
			/** 读取调用方配置并加载初始文本 */
			loadEditorConfig() {
				const rawMode = uni.getStorageSync('editor_mode') as string | null
				this.mode = rawMode == 'file' ? 'file' : 'text'
				const targetText = uni.getStorageSync('editor_target') as string | null
				const filePathText = uni.getStorageSync('editor_file_path') as string | null
				this.target = targetText != null ? targetText : ''
				this.filePath = filePathText != null ? filePathText : ''

				const title = uni.getStorageSync('editor_title') as string | null
				if (title != null && title != '') {
					this.navTitle = title
				} else if (this.mode == 'file' && this.filePath != '') {
					this.navTitle = basename(this.filePath)
				}

				const placeholderText = uni.getStorageSync('editor_placeholder') as string | null
				if (placeholderText != null && placeholderText != '') {
					this.placeholder = placeholderText
				}

				const readOnlyText = uni.getStorageSync('editor_readonly') as string | null
				this.readOnly = readOnlyText == 'true'
				this.draftKey = this.buildDraftKey()
				this.subTitle = this.buildSubTitle()

				let content = ''
				if (this.mode == 'file') {
					if (this.filePath == '') {
						uni.showToast({ position: 'bottom', title: '文件路径为空', icon: 'none' })
					} else {
						const fileContent = readContent(this.filePath)
						content = fileContent != null ? fileContent : ''
					}
				} else {
					const storedContent = uni.getStorageSync('editor_content') as string | null
					content = storedContent != null ? storedContent : ''
				}

				this.editText = content
				this.initialText = content
				this.dirty = false
				this.restoreDraftIfNeeded(content)
			},

			buildDraftKey(): string {
				if (this.mode == 'file' && this.filePath != '') {
					return 'editor_draft_file_' + this.safeKey(this.filePath)
				}
				if (this.target != '') {
					return 'editor_draft_' + this.safeKey(this.target)
				}
				return 'editor_draft'
			},

			buildSubTitle(): string {
				if (this.mode == 'file') {
					return this.filePath
				}
				if (this.target != '') {
					return this.target
				}
				return ''
			},

			safeKey(text: string): string {
				let result = ''
				for (let i = 0; i < text.length; i++) {
					const ch = text.charAt(i)
					const rawCode = ch.charCodeAt(0)
					if (rawCode == null) {
						continue
					}
					const code = rawCode as number
					const isLower = code >= 97 && code <= 122
					const isUpper = code >= 65 && code <= 90
					const isNumber = code >= 48 && code <= 57
					if (isLower || isUpper || isNumber) {
						result = result + ch
					} else {
						result = result + '_'
					}
				}
				return result
			},

			/** 检查是否恢复草稿 */
			restoreDraftIfNeeded(content: string) {
				if (this.readOnly == true) {
					return
				}
				const legacyDraft = uni.getStorageSync('editor_draft') as string | null
				const scopedDraft = uni.getStorageSync(this.draftKey) as string | null
				const draft = scopedDraft != null && scopedDraft != '' ? scopedDraft : legacyDraft
				if (draft != null && draft != '' && draft != content) {
					uni.showModal({
						title: '恢复草稿',
						content: '检测到上次未保存的内容，是否继续编辑？',
						cancelText: '放弃草稿',
						confirmText: '继续编辑',
						success: (res) => {
							if (res.confirm == true) {
								this.editText = draft
								this.dirty = this.editText != this.initialText
							} else {
								this.clearDraft()
								this.editText = content
								this.dirty = false
							}
						}
					})
				}
			},

			/** 输入变化时自动保存草稿 */
			onInput() {
				this.dirty = this.editText != this.initialText
				this.saveDraft()
			},

			saveDraft() {
				if (this.readOnly == true) {
					return
				}
				uni.setStorageSync(this.draftKey, this.editText)
				// 兼容旧调用方/旧草稿。
				uni.setStorageSync('editor_draft', this.editText)
			},

			clearDraft() {
				uni.removeStorageSync(this.draftKey)
				uni.removeStorageSync('editor_draft')
			},

			onBack() {
				if (this.readOnly == true || this.editText == this.initialText) {
					uni.navigateBack()
					return
				}
				this.saveDraft()
				uni.showModal({
					title: '放弃编辑？',
					content: '内容尚未保存',
					cancelText: '继续编辑',
					confirmText: '放弃',
					confirmColor: '#EF4444',
					success: (res) => {
						if (res.confirm == true) {
							this.clearDraft()
							uni.navigateBack()
						}
					}
				})
			},

			saveAndBack() {
				if (this.readOnly == true) {
					uni.navigateBack()
					return
				}
				if (this.mode == 'file') {
					this.saveFileAndBack()
				} else {
					this.saveTextAndBack()
				}
			},

			saveTextAndBack() {
				uni.setStorageSync('editor_result', this.editText)
				uni.setStorageSync('editor_result_ready', 'true')
				this.initialText = this.editText
				this.dirty = false
				this.clearDraft()
				uni.navigateBack()
			},

			saveFileAndBack() {
				if (this.filePath == '') {
					uni.showToast({ position: 'bottom', title: '文件路径为空', icon: 'none' })
					return
				}
				const result = writeContent(this.filePath, this.editText)
				if (result.ok == true) {
					uni.setStorageSync('editor_saved', 'true')
					uni.setStorageSync('editor_saved_path', this.filePath)
					this.initialText = this.editText
					this.dirty = false
					this.clearDraft()
					uni.showToast({ position: 'bottom', title: '已保存', icon: 'success' })
					uni.navigateBack()
				} else {
					uni.showToast({ position: 'bottom', title: '保存失败: ' + result.error, icon: 'none' })
				}
			},
		}
	}
</script>

<style>
	.page-shell {
		flex: 1;
		background-color: #FFFFFF;
	}

	.editor-wrap {
		flex: 1;
		background-color: #FFFFFF;
		padding: 24rpx 28rpx 18rpx;
	}

	.editor-meta {
		padding: 0 0 18rpx 0;
	}

	.editor-meta-text {
		font-size: 22rpx;
		color: #9CA3AF;
		lines: 1;
		text-overflow: ellipsis;
	}

	.editor-input {
		flex: 1;
		font-size: 30rpx;
		color: #111827;
		line-height: 48rpx;
		padding: 0;
		background-color: transparent;
	}

	.editor-footer {
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		padding-top: 16rpx;
	}

	.footer-text {
		font-size: 22rpx;
		color: #9CA3AF;
	}

	.done-btn {
		font-size: 30rpx;
		color: #FFFFFF;
		font-weight: bold;
		padding: 16rpx 8rpx;
	}
</style>
