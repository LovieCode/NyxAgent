<template>
	<view class="page-shell rice-theme-light">
		<NavBar :title="navTitle" showBack @back="onBack">
			<template #right>
				<text class="done-btn" @click="saveAndBack">完成</text>
			</template>
		</NavBar>
		<view class="editor-wrap">
			<textarea
				class="editor-input"
				v-model="editText"
				placeholder="输入内容..."
				placeholder-style="color:#D1D5DB;font-size:16px;"
				:auto-height="true"
			/>
		</view>
	</view>
</template>

<script lang="uts">
	/**
	 * 全屏编辑器页�?	 * 通过 uni.storage 与调用方传值：
	 *   - 调用方先写入 editor_content（初始文本）和 editor_title（导航标题）
	 *   - 本页面保存时写入 editor_result
	 *   - 调用方在 onShow 中读取 editor_result
	 */
	export default {
		data() {
			return {
				editText: '' as string,
				initialText: '' as string,
				navTitle: '编辑' as string,
				draftTimer: -1 as number,
			}
		},
		onLoad() {
			// 读取调用方传入的标题
			const title = uni.getStorageSync('editor_title') as string
			if (title != null && title != '') {
				this.navTitle = title
			}
			// 优先读取草稿，没有则用调用方传入的内容
			const draft = uni.getStorageSync('editor_draft') as string
			const content = (draft != null && draft != '') ? draft : (uni.getStorageSync('editor_content') as string)
			this.editText = (content != null) ? content : ''
			this.initialText = this.editText
			// 定时自动保存草稿（每1.5秒）
			this.draftTimer = setInterval(() => {
				this.saveDraft()
			}, 1500)
		},
		onUnload() {
			if (this.draftTimer >= 0) {
				clearInterval(this.draftTimer)
				this.draftTimer = -1
			}
		},
		methods: {
			/** 保存草稿到本地 */
			saveDraft() {
				uni.setStorageSync('editor_draft', this.editText)
			},
			onBack() {
				// 离开前保存一次草稿
				this.saveDraft()
				if (this.editText != this.initialText) {
					uni.showModal({
						title: '放弃编辑?',
						content: '内容尚未保存',
						success: (res) => {
							if (res.confirm == true) {
								this.clearTimer()
								uni.navigateBack()
							}
						}
					})
				} else {
					this.clearTimer()
					uni.navigateBack()
				}
			},
			saveAndBack() {
				this.saveDraft()
				// 将结果写回调用方
				uni.setStorageSync('editor_result', this.editText)
				uni.removeStorageSync('editor_draft')
				this.clearTimer()
				uni.navigateBack()
			},
			clearTimer() {
				if (this.draftTimer >= 0) {
					clearInterval(this.draftTimer)
					this.draftTimer = -1
				}
			}
		}
	}
</script>

<style>
	.editor-wrap {
		flex: 1;
		background-color: #FFFFFF;
		padding: 16px;
	}

	.editor-input {
		flex: 1;
		font-size: 16px;
		color: #111827;
		line-height: 26px;
		padding: 0;
		background-color: transparent;
	}

	.done-btn {
		font-size: 15px;
		color: #FFFFFF;
		font-weight: bold;
		padding: 8px 4px;
	}
</style>
