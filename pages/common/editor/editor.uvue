<template>
	<FullscreenTextEditor
		:title="navTitle"
		:subtitle="subTitle"
		:value="editText"
		:placeholder="placeholder"
		:readOnly="readOnly"
		:dirty="dirty"
		@change="onEditorChange"
		@save="saveAndBack"
		@back="onBack"
	/>
</template>

<script lang="uts">
	import { readContent, writeContent, basename } from '@/utils/file-manager.uts'
	import {
		clearEditorDraft,
		publishFileEditorSavedState,
		publishTextEditorResult,
		readEditorDraft,
		readEditorRuntimeConfig,
		saveEditorDraft,
	} from '@/utils/editor-runtime-state.uts'
	import { APP_ERROR_CATEGORY_RUNTIME, formatAppErrorForUser, reportAppErrorFromCause } from '@/utils/app-error.uts'

	function showEditorFailure(code: string, operation: string, userMessage: string, cause: any | null): void {
		const error = reportAppErrorFromCause(
			code,
			APP_ERROR_CATEGORY_RUNTIME,
			operation,
			userMessage,
			cause,
			true,
		)
		uni.showToast({ position: 'bottom', title: formatAppErrorForUser(error), icon: 'none' })
	}

	/**
	 * 通用全屏编辑路由适配器。
	 * UI 由 FullscreenTextEditor 组件提供；本页只处理 runtime_state/file 模式。
	 */
	export default {
		data() {
			return {
				editText: '' as string,
				initialText: '' as string,
				navTitle: '编辑' as string,
				subTitle: '' as string,
				placeholder: '输入内容...' as string,
				mode: 'text' as string,
				owner: '' as string,
				target: '' as string,
				filePath: '' as string,
				draftKey: '' as string,
				readOnly: false as boolean,
				dirty: false as boolean,
				draftTouched: false as boolean,
				draftSaveFailed: false as boolean,
				allowBackNavigation: false as boolean,
			}
		},
		onLoad() {
			try {
				this.loadEditorConfig()
			} catch (e: any) {
				this.readOnly = true
				showEditorFailure('EDITOR_CONFIG_LOAD_FAILED', 'editor_load_config', '编辑器配置读取失败', e)
			}
		},
		onBackPress(): boolean {
			if (this.allowBackNavigation == true) { return false }
			this.onBack()
			return true
		},
		methods: {
			loadEditorConfig() {
				const config = readEditorRuntimeConfig()
				this.mode = config.mode == 'file' ? 'file' : 'text'
				this.owner = config.owner
				this.target = config.target
				this.filePath = config.filePath

				if (config.title != '') {
					this.navTitle = config.title
				} else if (this.mode == 'file' && this.filePath != '') {
					this.navTitle = basename(this.filePath)
				}

				if (config.placeholder != '') {
					this.placeholder = config.placeholder
				}

				this.readOnly = config.readOnly
				if (this.owner == '' || this.target == '') {
					this.readOnly = true
					showEditorFailure('EDITOR_CONFIG_INVALID', 'editor_validate_config', '编辑器配置已失效，请返回重试', 'owner 或 target 为空')
				}
				this.draftKey = this.buildDraftKey()
				this.subTitle = this.buildSubTitle()

				let content = ''
				if (this.mode == 'file') {
					if (this.filePath == '') {
						uni.showToast({ position: 'bottom', title: '文件路径为空', icon: 'none' })
					} else {
						const fileContent = readContent(this.filePath)
						if (fileContent == null) {
							this.readOnly = true
							uni.showToast({ position: 'bottom', title: '文件读取失败，已禁止覆盖保存', icon: 'none' })
						} else {
							content = fileContent
						}
					}
				} else {
					content = config.content
				}

				this.editText = content
				this.initialText = content
				this.dirty = false
				this.restoreDraftIfNeeded(content)
			},

			buildDraftKey(): string {
				if (this.owner == '') { return '' }
				if (this.mode == 'file' && this.filePath != '') {
					return 'editor_draft_file_' + this.safeKey(this.owner + '\u0000' + this.filePath)
				}
				if (this.target != '') {
					return 'editor_draft_text_' + this.safeKey(this.owner + '\u0000' + this.target)
				}
				return ''
			},

			buildSubTitle(): string {
				if (this.mode == 'file') {
					return this.filePath
				}
				if (this.target != '') {
					return this.target
				}
				return ''
			},

			safeKey(text: string): string {
				let result = ''
				for (let i = 0; i < text.length; i++) {
					const ch = text.charAt(i)
					const rawCode = ch.charCodeAt(0)
					if (rawCode == null) {
						continue
					}
					const code = rawCode as number
					let hex = code.toString(16)
					while (hex.length < 4) {
						hex = '0' + hex
					}
					result = result + hex
				}
				return result
			},

			restoreDraftIfNeeded(content: string) {
				if (this.readOnly == true) {
					return
				}
				const draft = readEditorDraft(this.draftKey)
				if (draft != null) {
					const safeDraft = draft as string
					if (safeDraft != content) {
						uni.showModal({
							title: '恢复草稿',
							content: '检测到上次未保存的内容，是否继续编辑？',
							cancelText: '放弃草稿',
							confirmText: '继续编辑',
							success: (res) => {
								if (res.confirm == true) {
									this.editText = safeDraft
									this.dirty = this.editText != this.initialText
									this.draftTouched = true
								} else {
									if (this.clearDraft() == false) { return }
									this.editText = content
									this.dirty = false
								}
							}
						})
					} else {
						this.draftTouched = true
						this.clearDraft()
					}
				}
			},

			onEditorChange(value: string) {
				this.editText = value
				this.dirty = this.editText != this.initialText
				this.draftTouched = true
				this.saveDraft()
			},

			saveDraft(): boolean {
				if (this.readOnly == true) {
					return true
				}
				const scopedSaved = saveEditorDraft(this.draftKey, this.editText)
				this.draftSaveFailed = scopedSaved == false
				return this.draftSaveFailed == false
			},

			clearDraft(): boolean {
				const cleared = clearEditorDraft(this.draftKey)
				if (cleared == false) {
					showEditorFailure('EDITOR_DRAFT_CLEAR_FAILED', 'editor_clear_draft', '草稿清理失败，请重试', 'clearEditorDraft 返回 false')
				} else {
					this.draftTouched = false
				}
				return cleared
			},

			onBack() {
				if (this.readOnly == true) {
					this.navigateBackSafely()
					return
				}
				if (this.editText == this.initialText) {
					if (this.draftTouched == true && this.clearDraft() == false) { return }
					this.navigateBackSafely()
					return
				}
				if (this.saveDraft() == false) {
					showEditorFailure('EDITOR_DRAFT_SAVE_FAILED', 'editor_save_draft', '草稿保存失败，请先复制重要内容', 'saveEditorDraft 返回 false')
				}
				uni.showModal({
					title: '放弃编辑？',
					content: '内容尚未保存',
					cancelText: '继续编辑',
					confirmText: '放弃',
					confirmColor: '#EF4444',
					success: (res) => {
						if (res.confirm == true) {
							if (this.clearDraft() == false) { return }
							this.dirty = false
							this.navigateBackSafely()
						}
					}
				})
			},

			saveAndBack(value: string) {
				this.editText = value
				if (this.readOnly == true) {
					this.navigateBackSafely()
					return
				}
				if (this.mode == 'file') {
					this.saveFileAndBack()
				} else {
					this.saveTextAndBack()
				}
			},

			saveTextAndBack() {
				if (publishTextEditorResult(this.owner, this.target, this.editText, this.draftKey) == false) {
					showEditorFailure('EDITOR_RESULT_PUBLISH_FAILED', 'editor_publish_text_result', '保存编辑结果失败，请重试', '编辑结果状态事务未提交')
					return
				}
				this.initialText = this.editText
				this.dirty = false
				this.draftTouched = false
				this.navigateBackSafely()
			},

			saveFileAndBack() {
				if (this.filePath == '') {
					uni.showToast({ position: 'bottom', title: '文件路径为空', icon: 'none' })
					return
				}
				const result = writeContent(this.filePath, this.editText)
				if (result.ok == true) {
					const stateSaved = publishFileEditorSavedState(this.owner, this.target, this.filePath, this.draftKey)
					if (stateSaved == false) {
						showEditorFailure('EDITOR_FILE_RESULT_PUBLISH_FAILED', 'editor_publish_file_result', '文件已保存，但页面通知失败，请重试', '文件保存状态事务未提交')
						return
					}
					this.initialText = this.editText
					this.dirty = false
					this.draftTouched = false
					uni.showToast({
						position: 'bottom',
						title: '已保存',
						icon: 'success'
					})
					this.navigateBackSafely()
				} else {
					uni.showToast({ position: 'bottom', title: '保存失败: ' + result.error, icon: 'none' })
				}
			},

			navigateBackSafely() {
				this.allowBackNavigation = true
				uni.navigateBack({
					fail: (err: any) => {
						this.allowBackNavigation = false
						showEditorFailure('EDITOR_BACK_FAILED', 'editor_navigate_back', '无法返回上一页', err)
					}
				})
			},
		}
	}
</script>
