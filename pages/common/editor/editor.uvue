<template>
	<view class="page-shell rice-theme-light">
		<NavBar :title="navTitle" showBack @back="onBack">
			<template #right>
				<text class="done-btn" @click="saveAndBack">完成</text>
			</template>
		</NavBar>
		<view class="editor-wrap">
			<textarea
				class="editor-input"
				v-model="editText"
				placeholder="输入内容..."
				placeholder-style="color:#D1D5DB;font-size:16px;"
				:auto-height="true"
				@input="onInput"
			/>
		</view>
	</view>
</template>

<script lang="uts">
	/**
	 * 全屏编辑器页�?	 * 通过 uni.storage 与调用方传值：
	 *   - 调用方先写入 editor_content（初始文本）和 editor_title（导航标题）
	 *   - 本页面保存时写入 editor_result
	 *   - 调用方在 onShow 中读取 editor_result
	 */
	export default {
		data() {
			return {
				editText: '' as string,
				initialText: '' as string,
				navTitle: '编辑' as string,
			}
		},
		onLoad() {
			// 读取调用方传入的标题
			const title = uni.getStorageSync('editor_title') as string
			if (title != null && title != '') {
				this.navTitle = title
			}
			// 先加载原始内容（保证无弹窗时文本正常显示）
			const content = (uni.getStorageSync('editor_content') as string) ?? ''
			this.editText = content
			this.initialText = content
			// 检查是否有草稿需要恢复
			const draft = uni.getStorageSync('editor_draft') as string
			if (draft != null && draft != '' && draft != content) {
				uni.showModal({
					title: '恢复草稿',
					content: '检测到上次未保存的内容，是否继续编辑？',
					cancelText: '放弃草稿',
					confirmText: '继续编辑',
					success: (res) => {
						if (res.confirm == true) {
							this.editText = draft
							this.initialText = draft
						} else {
							// 二次确认放弃
							uni.showModal({
								title: '确认放弃',
								content: '确定要放弃未保存的内容吗？此操作不可撤销。',
								cancelText: '取消',
								confirmText: '确定放弃',
								confirmColor: '#EF4444',
								success: (res2) => {
									if (res2.confirm == true) {
										uni.removeStorageSync('editor_draft')
										this.editText = content
										this.initialText = content
									}
									// 取消→保持当前显示的原始内容
								}
							})
						}
					}
				})
			}
		},
		methods: {
			/** 输入变化时自动保存草稿 */
			onInput() {
				uni.setStorageSync('editor_draft', this.editText)
			},
			/** 保存草稿到本地 */
			saveDraft() {
				uni.setStorageSync('editor_draft', this.editText)
			},
			onBack() {
				// 离开前保存一次草稿
				this.saveDraft()
				if (this.editText != this.initialText) {
					uni.showModal({
						title: '放弃编辑?',
						content: '内容尚未保存',
						success: (res) => {
							if (res.confirm == true) {
								uni.navigateBack()
							}
						}
					})
				} else {
					uni.navigateBack()
				}
			},
			saveAndBack() {
				this.saveDraft()
				// 将结果写回调用方
				uni.setStorageSync('editor_result', this.editText)
				uni.removeStorageSync('editor_draft')
				uni.navigateBack()
			},
		}
	}
</script>

<style>
	.editor-wrap {
		flex: 1;
		background-color: #FFFFFF;
		padding: 16px;
	}

	.editor-input {
		flex: 1;
		font-size: 16px;
		color: #111827;
		line-height: 26px;
		padding: 0;
		background-color: transparent;
	}

	.done-btn {
		font-size: 15px;
		color: #FFFFFF;
		font-weight: bold;
		padding: 8px 4px;
	}
</style>
