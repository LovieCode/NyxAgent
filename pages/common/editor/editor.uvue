<template>
	<FullscreenTextEditor
		:title="navTitle"
		:subtitle="subTitle"
		:value="editText"
		:placeholder="placeholder"
		:readOnly="readOnly"
		:dirty="dirty"
		@change="onEditorChange"
		@save="saveAndBack"
		@back="onBack"
	/>
</template>

<script lang="uts">
	import { readContent, writeContent, basename } from '@/utils/file-manager.uts'
	import { deleteRuntimeState, getRuntimeState, setRuntimeState } from '@/utils/database.uts'

	/**
	 * 通用全屏编辑路由适配器。
	 * UI 由 FullscreenTextEditor 组件提供；本页只处理 runtime_state/file 模式。
	 */
	export default {
		data() {
			return {
				editText: '' as string,
				initialText: '' as string,
				navTitle: '编辑' as string,
				subTitle: '' as string,
				placeholder: '输入内容...' as string,
				mode: 'text' as string,
				target: '' as string,
				filePath: '' as string,
				draftKey: 'editor_draft' as string,
				readOnly: false as boolean,
					dirty: false as boolean,
					draftSaveFailed: false as boolean,
					allowBackNavigation: false as boolean,
			}
		},
		onLoad() {
			this.loadEditorConfig()
		},
		onBackPress(): boolean {
			if (this.allowBackNavigation == true) { return false }
			this.onBack()
			return true
		},
		methods: {
			loadEditorConfig() {
				const rawMode = getRuntimeState('editor_mode')
				this.mode = rawMode == 'file' ? 'file' : 'text'
				const targetText = getRuntimeState('editor_target')
				const filePathText = getRuntimeState('editor_file_path')
				this.target = targetText
				this.filePath = filePathText

				const title = getRuntimeState('editor_title')
				if (title != '') {
					this.navTitle = title
				} else if (this.mode == 'file' && this.filePath != '') {
					this.navTitle = basename(this.filePath)
				}

				const placeholderText = getRuntimeState('editor_placeholder')
				if (placeholderText != '') {
					this.placeholder = placeholderText
				}

				const readOnlyText = getRuntimeState('editor_readonly')
				this.readOnly = readOnlyText == 'true'
				this.draftKey = this.buildDraftKey()
				this.subTitle = this.buildSubTitle()

				let content = ''
				if (this.mode == 'file') {
					if (this.filePath == '') {
						uni.showToast({ position: 'bottom', title: '文件路径为空', icon: 'none' })
					} else {
						const fileContent = readContent(this.filePath)
						if (fileContent == null) {
							this.readOnly = true
							uni.showToast({ position: 'bottom', title: '文件读取失败，已禁止覆盖保存', icon: 'none' })
						} else {
							content = fileContent
						}
					}
				} else {
					content = getRuntimeState('editor_content')
				}

				this.editText = content
				this.initialText = content
				this.dirty = false
				this.restoreDraftIfNeeded(content)
			},

			buildDraftKey(): string {
				if (this.mode == 'file' && this.filePath != '') {
					return 'editor_draft_file_' + this.safeKey(this.filePath)
				}
				if (this.target != '') {
					return 'editor_draft_' + this.safeKey(this.target)
				}
				return 'editor_draft'
			},

			buildSubTitle(): string {
				if (this.mode == 'file') {
					return this.filePath
				}
				if (this.target != '') {
					return this.target
				}
				return ''
			},

			safeKey(text: string): string {
				let result = ''
				for (let i = 0; i < text.length; i++) {
					const ch = text.charAt(i)
					const rawCode = ch.charCodeAt(0)
					if (rawCode == null) {
						continue
					}
					const code = rawCode as number
					const isLower = code >= 97 && code <= 122
					const isUpper = code >= 65 && code <= 90
					const isNumber = code >= 48 && code <= 57
					if (isLower || isUpper || isNumber) {
						result = result + ch
					} else {
						result = result + '_'
					}
				}
				return result
			},

			restoreDraftIfNeeded(content: string) {
				if (this.readOnly == true) {
					return
				}
				const legacyDraft = getRuntimeState('editor_draft')
				const scopedDraft = getRuntimeState(this.draftKey)
				let draft = legacyDraft
				if (scopedDraft != '') {
					draft = scopedDraft
				}
				if (draft != '') {
					const safeDraft = draft
					if (safeDraft != content) {
						uni.showModal({
							title: '恢复草稿',
							content: '检测到上次未保存的内容，是否继续编辑？',
							cancelText: '放弃草稿',
							confirmText: '继续编辑',
							success: (res) => {
								if (res.confirm == true) {
									this.editText = safeDraft
									this.dirty = this.editText != this.initialText
								} else {
									this.clearDraft()
									this.editText = content
									this.dirty = false
								}
							}
						})
					}
				}
			},

			onEditorChange(value: string) {
				this.editText = value
				this.dirty = this.editText != this.initialText
				this.saveDraft()
			},

			saveDraft(): boolean {
				if (this.readOnly == true) {
					return true
				}
				const scopedSaved = setRuntimeState(this.draftKey, this.editText)
				const legacySaved = setRuntimeState('editor_draft', this.editText)
				this.draftSaveFailed = scopedSaved == false || legacySaved == false
				return this.draftSaveFailed == false
			},

			clearDraft() {
				deleteRuntimeState(this.draftKey)
				deleteRuntimeState('editor_draft')
			},

			onBack() {
				if (this.readOnly == true || this.editText == this.initialText) {
					this.navigateBackSafely()
					return
				}
				if (this.saveDraft() == false) {
					uni.showToast({ position: 'bottom', title: '草稿保存失败，请先复制重要内容', icon: 'none' })
				}
				uni.showModal({
					title: '放弃编辑？',
					content: '内容尚未保存',
					cancelText: '继续编辑',
					confirmText: '放弃',
					confirmColor: '#EF4444',
					success: (res) => {
						if (res.confirm == true) {
							this.clearDraft()
							this.dirty = false
							this.navigateBackSafely()
						}
					}
				})
			},

			saveAndBack(value: string) {
				this.editText = value
				if (this.readOnly == true) {
					this.navigateBackSafely()
					return
				}
				if (this.mode == 'file') {
					this.saveFileAndBack()
				} else {
					this.saveTextAndBack()
				}
			},

			saveTextAndBack() {
				if (setRuntimeState('editor_result', this.editText) == false) {
					uni.showToast({ position: 'bottom', title: '保存编辑结果失败，请重试', icon: 'none' })
					return
				}
				if (setRuntimeState('editor_result_ready', 'true') == false) {
					uni.showToast({ position: 'bottom', title: '编辑结果通知失败，请重试', icon: 'none' })
					return
				}
				this.initialText = this.editText
				this.dirty = false
				this.clearDraft()
				this.navigateBackSafely()
			},

			saveFileAndBack() {
				if (this.filePath == '') {
					uni.showToast({ position: 'bottom', title: '文件路径为空', icon: 'none' })
					return
				}
				const result = writeContent(this.filePath, this.editText)
				if (result.ok == true) {
					const savedState = setRuntimeState('editor_saved', 'true')
					const pathState = setRuntimeState('editor_saved_path', this.filePath)
					this.initialText = this.editText
					this.dirty = false
					this.clearDraft()
					uni.showToast({
						position: 'bottom',
						title: savedState == true && pathState == true ? '已保存' : '文件已保存，页面状态通知失败',
						icon: savedState == true && pathState == true ? 'success' : 'none'
					})
					this.navigateBackSafely()
				} else {
					uni.showToast({ position: 'bottom', title: '保存失败: ' + result.error, icon: 'none' })
				}
			},

			navigateBackSafely() {
				this.allowBackNavigation = true
				uni.navigateBack({
					fail: () => {
						this.allowBackNavigation = false
						uni.showToast({ position: 'bottom', title: '无法返回上一页', icon: 'none' })
					}
				})
			},
		}
	}
</script>
