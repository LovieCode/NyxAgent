<template>
	<view class="page-shell rice-theme-light">
		<NavBar variant="light" title="聊天设置" showBack @back="goBack" />
		<scroll-view class="container" :scroll-y="true">
			<!-- 头部：头像 -->
			<view class="profile-header" @click="pickAvatar">
				<image v-if="agentAvatar != ''" :src="agentAvatar" class="agent-avatar" mode="aspectFill" />
				<view v-else class="agent-avatar agent-avatar-placeholder">
					<text class="agent-avatar-text">{{agentName.substring(0, 1)}}</text>
				</view>
				<text class="avatar-hint">点击更换头像</text>
			</view>

			<!-- 全部设置项合并到一个卡片 -->
			<view class="card">
				<!-- 名称 -->
				<view class="card-header">
					<oui-icon-unix name="edit" size="11px" color="#6B7280" style="margin-right:5px" />
					<text class="card-label">名称</text>
				</view>
			<input
				class="flat-input"
				type="text"
				v-model="agentName"
				placeholder="输入昵称"
				placeholder-class="input-placeholder"
				@input="hasUnsaved = true"
			/>

				<view class="card-header" style="margin-top:10px;">
					<oui-icon-unix name="file-text" size="11px" color="#6B7280" style="margin-right:5px" />
					<text class="card-label">备注</text>
					<text class="card-hint">（群聊里会用到）</text>
				</view>
				<view class="desc-wrap" @click="openDescEditor">
					<text class="desc-preview" lines="2" text-overflow="ellipsis">{{agentDesc != '' ? agentDesc : '点击输入联系人备注'}}</text>
					<view class="desc-edit-btn">
						<text class="desc-edit-text">全屏编辑</text>
					</view>
				</view>

				<view class="card-header" style="margin-top:10px;">
					<oui-icon-unix name="info-circle" size="11px" color="#6B7280" style="margin-right:5px" />
					<text class="card-label">提示词</text>
				</view>
				<view class="desc-wrap" @click="openSystemPromptEditor">
					<scroll-view class="prompt-scroll" :scroll-y="true">
						<text class="desc-preview">{{agentSystemPrompt}}</text>
					</scroll-view>
					<view class="desc-edit-btn">
						<text class="desc-edit-text">全屏编辑</text>
					</view>
				</view>

				<view class="card-header" style="margin-top:10px;">
					<oui-icon-unix name="file-text" size="11px" color="#6B7280" style="margin-right:5px" />
					<text class="card-label">对话规则</text>
				</view>
				<view class="desc-wrap" @click="openInteractionRulesEditor">
					<scroll-view class="prompt-scroll" :scroll-y="true">
						<text class="desc-preview">{{agentInteractionRules}}</text>
					</scroll-view>
					<view class="desc-edit-btn">
						<text class="desc-edit-text">全屏编辑</text>
					</view>
				</view>

				<!-- 模型 -->
				<view class="model-row" style="margin-top:10px;" @click="toggleModelPanel">
					<view class="card-header" style="margin-bottom:0;">
						<oui-icon-unix name="robot" size="11px" color="#6B7280" style="margin-right:5px" />
						<text class="card-label">对话模型</text>
					</view>
					<view class="model-right">
						<text class="model-value">{{currentModelLabel}}</text>
						<text class="model-arrow">{{showModelPanel ? '▾' : '›'}}</text>
					</view>
				</view>

				<!-- 展开模型选择 -->
				<view v-if="showModelPanel" class="model-panel">
					<text class="panel-label">选择提供商</text>
					<scroll-view class="chip-scroll" :scroll-x="true" :show-scrollbar="false">
						<view class="chip-row">
							<view
								v-for="(p, pi) in enabledProviders"
								:key="pi"
								class="chip"
								:class="selectedProviderId == (p['id'] as string) ? 'chip-active' : ''"
								@click="selectProvider(p['id'] as string)"
							>
								<text class="chip-text" :class="selectedProviderId == (p['id'] as string) ? 'chip-text-active' : ''">{{p['name']}}</text>
							</view>
						</view>
					</scroll-view>

					<text class="panel-label" style="margin-top:8px;">选择模型</text>
					<view v-if="providerModels.length == 0" class="panel-empty">
						<text class="panel-empty-text">请先在提供商管理中配置模型</text>
					</view>
					<view v-else class="model-grid">
						<view
							v-for="(m, mi) in providerModels"
							:key="mi"
							class="model-pill"
							:class="selectedModelId == m.id ? 'pill-active' : ''"
							@click="selectModel(m.id)"
						>
							<text class="pill-text" :class="selectedModelId == m.id ? 'pill-text-active' : ''">{{m.id}}</text>
						</view>
					</view>
				</view>

				<view class="setting-divider"></view>
				<view class="card-header">
					<oui-icon-unix name="setting" size="11px" color="#6B7280" style="margin-right:5px" />
					<text class="card-label">语音音色</text>
				</view>
				<text class="voice-section-desc">当前联系人专属 TTS 覆盖；留空就继承 设置 / 默认模型 里的全局参数。</text>
				<view class="param-row">
					<view class="param-item">
						<text class="param-label">音色 / Voice</text>
						<input class="param-input" type="text" v-model="ttsVoice" placeholder="留空继承默认音色" @input="hasUnsaved = true" />
					</view>
				</view>
				<view class="param-row">
					<view class="param-item">
						<text class="param-label">音量</text>
						<input class="param-input" type="text" v-model="ttsVolume" placeholder="留空继承，火山等支持" @input="hasUnsaved = true" />
					</view>
					<view class="param-item">
						<text class="param-label">音高</text>
						<input class="param-input" type="text" v-model="ttsPitch" placeholder="留空继承，火山等支持" @input="hasUnsaved = true" />
					</view>
				</view>

				<view class="setting-divider"></view>
				<view class="card-header">
					<oui-icon-unix name="setting" size="11px" color="#6B7280" style="margin-right:5px" />
					<text class="card-label">生成参数</text>
				</view>
				<view class="setting-row">
					<view class="setting-text">
						<text class="setting-title">继承全局设置</text>
						<text class="setting-desc">{{globalGenerationHint}}</text>
					</view>
					<rice-switch v-model="useGlobalGeneration" @change="onGenerationSwitch" />
				</view>
				<view v-if="useGlobalGeneration == false" class="generation-panel">
					<view class="param-row">
						<view class="param-item">
							<text class="param-label">温度</text>
							<input class="param-input" type="text" v-model="temperatureStr" placeholder="0 - 2" @input="onGenerationInput" />
						</view>
						<view class="param-item">
							<text class="param-label">输出上限</text>
							<input class="param-input" type="text" v-model="maxTokensStr" placeholder="256 - 65536" @input="onGenerationInput" />
						</view>
					</view>
					<view class="param-row">
						<view class="param-item">
							<text class="param-label">最大迭代</text>
							<input class="param-input" type="text" v-model="maxIterationsStr" placeholder="0 - 100，0 不限制" @input="onGenerationInput" />
						</view>
						<view class="param-switch">
							<view>
								<text class="param-label">流式显示</text>
								<text class="param-tip">关闭后等完整回复再显示</text>
							</view>
							<rice-switch v-model="streamEnabled" @change="onGenerationSwitch" />
						</view>
					</view>
				</view>
			</view>

			<!-- Skills -->
			<view class="card">
				<view class="card-header">
					<oui-icon-unix name="book" size="11px" color="#6B7280" style="margin-right:5px" />
					<text class="card-label">Skills</text>
				</view>
				<text class="skill-section-desc">为当前私聊启用纯文本技能包。不同联系人可以使用不同 Skills。</text>
				<view v-if="allSkills.length == 0" class="panel-empty">
					<text class="panel-empty-text">还没有 Skill，请到 设置 / Skills 创建。</text>
				</view>
				<view v-else class="skill-grid">
					<view
						v-for="(skill, si) in allSkills"
						:key="si"
						class="skill-card"
						:class="isAgentSkillSelected(skill) ? 'skill-card-active' : ''"
						@click="toggleAgentSkill(skill)"
					>
						<view class="skill-card-top">
							<text class="skill-card-name">{{getSkillName(skill)}}</text>
							<text class="skill-card-check">{{isAgentSkillSelected(skill) ? '✓' : '+'}}</text>
						</view>
						<text class="skill-card-desc" lines="2" text-overflow="ellipsis">{{getSkillDesc(skill)}}</text>
						<text class="skill-card-meta">{{getSkillMeta(skill)}}</text>
					</view>
				</view>
			</view>

			<!-- 工具设置 -->
			<view class="card">
				<view class="card-header">
					<oui-icon-unix name="setting" size="11px" color="#6B7280" style="margin-right:5px" />
					<text class="card-label">工具设置</text>
				</view>
				<text class="skill-section-desc">为当前私聊启用可调用工具。不启用的工具不会注入模型上下文，也不会被执行。</text>
				<view class="tool-list">
					<view
						v-for="(row, ri) in toolRows"
						:key="ri"
						class="tool-row"
					>
						<view
							v-for="(tool, ti) in row"
							:key="ti"
							class="tool-card"
							:class="getToolCardClass(tool, ti)"
							@click="toggleAgentTool(tool)"
						>
							<view class="tool-card-main">
								<view class="tool-card-text">
									<text class="tool-card-name">{{getToolName(tool)}}</text>
									<text class="tool-card-desc" lines="1" text-overflow="ellipsis">{{getToolDesc(tool)}}</text>
								</view>
								<text class="tool-card-check">{{isAgentToolSelected(tool) ? '✓' : '+'}}</text>
							</view>
						</view>
					</view>
				</view>
			</view>

			<!-- 上下文截断 -->
			<view class="card">
				<view class="card-header">
					<oui-icon-unix name="scissors" size="11px" color="#6B7280" style="margin-right:5px" />
					<text class="card-label">上下文截断</text>
				</view>
				<view class="context-tip">
					<text class="context-tip-text">按权重计算上下文长度：用户消息 1 分，普通回复 0.3 分，工具调用/结果 0.1 分。达到阈值会截断早期消息，并自动触发记忆整理。</text>
				</view>
				<view class="setting-row">
					<view class="setting-text">
						<text class="setting-title">截断阈值（分）</text>
						<text class="setting-desc">达到该分数后整理记忆并截断，0 不启用</text>
					</view>
					<input class="param-input short-input" type="text" v-model="truncateThresholdStr" placeholder="0" @input="hasUnsaved = true" />
				</view>
				<view class="setting-row">
					<view class="setting-text">
						<text class="setting-title">丢弃分数</text>
						<text class="setting-desc">达到阈值后回落的分数，例如阈值 40、丢弃 20，则保留约 20 分上下文</text>
					</view>
					<input class="param-input short-input" type="text" v-model="truncateDropCountStr" placeholder="20" @input="hasUnsaved = true" />
				</view>
				<view class="setting-row">
					<view class="setting-text">
						<text class="setting-title">启用缓存ID</text>
						<text class="setting-desc">开启后请求会携带 cache_key（联系人ID:对话ID）</text>
					</view>
					<rice-switch v-model="cacheEnabled" @change="hasUnsaved = true" />
				</view>
				<view class="setting-row">
					<view class="setting-text">
						<text class="setting-title">隐藏思考过程</text>
						<text class="setting-desc">AI 回复中的思考折叠区不显示</text>
					</view>
					<rice-switch v-model="hideThinking" @change="hasUnsaved = true" />
				</view>
				<view class="setting-row">
					<view class="setting-text">
						<text class="setting-title">注入日期时间</text>
						<text class="setting-desc">每条消息前自动附加当前日期、星期、节日</text>
					</view>
					<rice-switch v-model="injectDatetime" @change="hasUnsaved = true" />
				</view>
				<view class="setting-row">
					<view class="setting-text">
						<text class="setting-title">消息分段</text>
						<text class="setting-desc">AI 回复按换行符分成多个相邻气泡</text>
					</view>
					<rice-switch v-model="msgSegmentation" @change="hasUnsaved = true" />
				</view>
			</view>

			<!-- 保存按钮 -->
			<view class="save-wrap">
				<view class="save-btn" @click="saveSettingsAndBack">
					<text class="save-btn-text">保存修改</text>
				</view>
			</view>

			<!-- 删除按钮 -->
			<view v-if="canDeleteAgent == true" class="delete-wrap">
				<view class="delete-btn" @click="confirmDelete">
					<text class="delete-btn-text">删除该私聊</text>
				</view>
			</view>
		</scroll-view>
	</view>
</template>

<script lang="uts">
	/**
	 * 私聊设置页面 - 编辑昵称/备注/头像/删除私聊
	 */
	import { getAgentById, deleteAgent, getAgentEnabledToolIds, NYX_ADMIN_AGENT_ID, type AgentDeleteResult } from '@/utils/agent.uts'
	import { getAllProviders, type ModelInfo } from '@/uni_modules/agent-core/utssdk/provider.uts'
	import { getAppSetting, getRuntimeState } from '@/utils/database.uts'
	import { getGlobalGenerationSettings } from '@/utils/generation-settings.uts'
	import { chooseAvatarImage, consumeAvatarCropResult, discardManagedAvatarFile, openAvatarCrop } from '@/utils/avatar-image-picker.uts'
	import { clearActiveAgentRuntimeId } from '@/utils/runtime-state.uts'
	import { getSkills, getAgentSkillIds, filterExistingSkillIds } from '@/utils/skills.uts'
	import {
		buildAgentCurrentModelLabel,
		buildAgentSettingsToolRows,
		buildEnabledAgentProviders,
		readAgentGenerationForm,
		readAgentProviderModels,
		resolveAgentModelSelection,
	} from '@/utils/agent-settings-models.uts'
	import { saveAgentSettings, type AgentSettingsSaveInput, type AgentSettingsSaveResult } from '@/utils/agent-settings-save-service.uts'
	import { APP_ERROR_CATEGORY_RUNTIME, formatAppErrorForUser, reportAppErrorFromCause } from '@/utils/app-error.uts'
	import {
		buildAgentSettingsToolOptions,
		getAgentSettingsToolCardClass,
		isAgentSettingsToolSelected,
		isLockedNyxTeachingTool,
		readAgentSettingsToolDesc,
		readAgentSettingsToolField,
		readAgentSettingsToolId,
		readAgentSettingsToolName,
		toggleAgentSettingsToolSelection,
	} from '@/utils/agent-settings-tools.uts'
	import {
		clearAgentSettingsEditorRuntime,
		readAgentSettingsProfileForm,
		readAgentSettingsSkillDesc,
		readAgentSettingsSkillMeta,
		readAgentSettingsSkillId,
		readAgentSettingsSkillName,
		isAgentSettingsSkillSelected,
		toggleAgentSettingsSkillSelection,
		tryPrepareAgentSettingsTextEditor,
	} from '@/utils/agent-settings-page-helpers.uts'

	function showAgentSettingsFailure(code: string, operation: string, userMessage: string, cause: any | null): void {
		const error = reportAppErrorFromCause(
			code,
			APP_ERROR_CATEGORY_RUNTIME,
			operation,
			userMessage,
			cause,
			true,
		)
		uni.showToast({ position: 'bottom', title: formatAppErrorForUser(error), icon: 'none' })
	}

	export default {
		data() {
			return {
				agentId: '' as string,
				agentName: '' as string,
				agentDesc: '' as string,
				agentSystemPrompt: '' as string,
				agentInteractionRules: '' as string,
				agentAvatar: '' as string,
				savedAvatarPath: '' as string,
				currentModel: 'deepseek-v4-flash',
				allProviders: [] as UTSJSONObject[],
				allSkills: [] as UTSJSONObject[],
				selectedSkillIds: [] as string[],
				availableTools: [] as UTSJSONObject[],
				selectedToolIds: [] as string[],
				showModelPanel: false as boolean,
				selectedProviderId: '' as string,
				selectedModelId: '' as string,
				ttsVoice: '' as string,
				ttsVolume: '' as string,
				ttsPitch: '' as string,
				useGlobalGeneration: true as boolean,
				temperatureStr: '' as string,
				maxTokensStr: '' as string,
				maxIterationsStr: '' as string,
				streamEnabled: true as boolean,
				/** 上下文截断阈值（分），0 不启用 */
				truncateThresholdStr: '40' as string,
				/** 触发截断时按积分回落的分数 */
				truncateDropCountStr: '20' as string,
				/** 启用缓存 ID */
				cacheEnabled: true as boolean,
				/** 隐藏思考过程 */
				hideThinking: false as boolean,
				/** 注入日期时间 */
				injectDatetime: true as boolean,
				/** AI 消息分段 */
				msgSegmentation: true as boolean,
				globalGenerationHint: '' as string,
				/** 编辑器返回后标记未保存 */
				hasUnsaved: false as boolean,
				/** 防止重复弹出确认离开对话框 */
				isConfirmingLeave: false as boolean,
				/** 系统相册或全屏编辑器返回时保留当前页尚未保存的其他字段。 */
				loadedOnce: false as boolean,
			}
		},
		computed: {
			/** 已启用的提供商列表 */
			enabledProviders(): UTSJSONObject[] {
				return buildEnabledAgentProviders(this.allProviders)
			},
			/** 当前选中提供商的模型列表 */
			providerModels(): ModelInfo[] {
				return readAgentProviderModels(this.selectedProviderId)
			},
			toolRows(): UTSJSONObject[][] {
				return buildAgentSettingsToolRows(this.availableTools, 2)
			},
			/** 显示文本：提供商 / 模型（向后兼容纯模型名） */
			currentModelLabel(): string {
				return buildAgentCurrentModelLabel(this.currentModel, this.allProviders)
			},
			canDeleteAgent(): boolean {
				return this.agentId != NYX_ADMIN_AGENT_ID
			}
		},
		onShow() {
			try {
				if (this.loadedOnce == false) {
					this.loadAgent()
					if (this.agentId == '') { return }
					this.loadedOnce = true
				}
				// 检查全屏编辑器是否有返回结果
				const ready = getRuntimeState('editor_result_ready')
				const result = getRuntimeState('editor_result')
				if (ready == 'true' || result != '') {
					const target = getRuntimeState('editor_target')
					if (target == 'systemPrompt' || target == 'interactionRules' || target == 'desc') {
						if (target == 'systemPrompt') {
							this.agentSystemPrompt = result
						} else if (target == 'interactionRules') {
							this.agentInteractionRules = result
						} else {
							this.agentDesc = result
						}
						clearAgentSettingsEditorRuntime()
						this.hasUnsaved = true
					}
				}
				// 检查裁剪页面是否有返回结果
				const cropResult = consumeAvatarCropResult('agent_avatar')
				if (cropResult != '') {
					if (this.agentAvatar != this.savedAvatarPath) {
						discardManagedAvatarFile(this.agentAvatar)
					}
					this.agentAvatar = cropResult
					this.hasUnsaved = true
				}
			} catch (e: any) {
				showAgentSettingsFailure('AGENT_SETTINGS_RETURN_STATE_FAILED', 'agent_settings_consume_page_result', '页面返回结果读取失败', e)
			}
		},
		/** Android 系统返回键 / iOS 滑动返回 */
		onBackPress(): boolean {
			if (this.hasUnsaved == false) {
				return false
			}
			this.confirmLeave()
			return true
		},
		methods: {
			loadAgent() {
				try {
					const id = getRuntimeState('active_agent_id')
					if (id == '') {
						showAgentSettingsFailure('AGENT_SETTINGS_ID_MISSING', 'agent_settings_load', '未选择联系人', 'active_agent_id 为空')
						return
					}
					const agent = getAgentById(id)
					if (agent == null) {
						showAgentSettingsFailure('AGENT_SETTINGS_AGENT_MISSING', 'agent_settings_load', '联系人不存在或已被删除', id)
						return
					}
					this.agentId = id
					this.hasUnsaved = false
					this.allProviders = getAllProviders()
					this.allSkills = getSkills()
					this.availableTools = this.buildToolOptions()
					const profile = readAgentSettingsProfileForm(agent, this.currentModel)
					this.agentName = profile.name
					this.agentDesc = profile.desc
					this.agentSystemPrompt = profile.systemPrompt
					this.agentInteractionRules = profile.interactionRules
					this.agentAvatar = profile.avatar
					this.savedAvatarPath = profile.avatar
					this.currentModel = profile.model
					this.ttsVoice = profile.ttsVoice
					this.ttsVolume = profile.ttsVolume
					this.ttsPitch = profile.ttsPitch
					this.selectedSkillIds = filterExistingSkillIds(getAgentSkillIds(agent))
					this.selectedToolIds = getAgentEnabledToolIds(agent, false)
					this.loadGenerationSettings(agent)
					this.initModelSelection()
				} catch (e: any) {
					showAgentSettingsFailure('AGENT_SETTINGS_LOAD_FAILED', 'agent_settings_load', '联系人设置加载失败', e)
				}
			},

			loadGenerationSettings(agent: UTSJSONObject) {
				const form = readAgentGenerationForm(agent, getGlobalGenerationSettings())
				this.globalGenerationHint = form.globalGenerationHint
				this.useGlobalGeneration = form.useGlobalGeneration
				this.temperatureStr = form.temperatureStr
				this.maxTokensStr = form.maxTokensStr
				this.maxIterationsStr = form.maxIterationsStr
				this.streamEnabled = form.streamEnabled
				this.truncateThresholdStr = form.truncateThresholdStr
				this.truncateDropCountStr = form.truncateDropCountStr
				this.cacheEnabled = form.cacheEnabled
				this.hideThinking = form.hideThinking
				this.injectDatetime = form.injectDatetime
				this.msgSegmentation = form.msgSegmentation
			},

			/** 从 currentModel 解析出选中的提供商和模型 */
			initModelSelection() {
				const selection = resolveAgentModelSelection(this.currentModel, this.enabledProviders)
				this.selectedProviderId = selection.providerId
				this.selectedModelId = selection.modelId
			},

			toggleModelPanel() {
				this.showModelPanel = !this.showModelPanel
				if (this.showModelPanel == true) {
					this.initModelSelection()
				}
			},

			selectProvider(id: string) {
				this.selectedProviderId = id
				this.selectedModelId = ''
				this.hasUnsaved = true
			},

			selectModel(id: string) {
				this.selectedModelId = id
				this.currentModel = this.selectedProviderId + '||' + id
				this.hasUnsaved = true
				// 选择后自动收起面板
				this.showModelPanel = false
			},

			getSkillName(skill: UTSJSONObject): string {
				return readAgentSettingsSkillName(skill)
			},

			getSkillDesc(skill: UTSJSONObject): string {
				return readAgentSettingsSkillDesc(skill)
			},

			getSkillMeta(skill: UTSJSONObject): string {
				return readAgentSettingsSkillMeta(skill)
			},

			isAgentSkillSelected(skill: UTSJSONObject): boolean {
				return isAgentSettingsSkillSelected(this.selectedSkillIds, skill)
			},

			toggleAgentSkill(skill: UTSJSONObject) {
				if (readAgentSettingsSkillId(skill) == '') { return }
				this.selectedSkillIds = toggleAgentSettingsSkillSelection(this.selectedSkillIds, skill)
				this.hasUnsaved = true
			},

			buildToolOptions(): UTSJSONObject[] {
				return buildAgentSettingsToolOptions(this.agentId)
			},

			readToolField(tool: UTSJSONObject, key: string): string {
				return readAgentSettingsToolField(tool, key)
			},

			getToolId(tool: UTSJSONObject): string {
				return readAgentSettingsToolId(tool)
			},

			getToolName(tool: UTSJSONObject): string {
				return readAgentSettingsToolName(tool)
			},

			getToolDesc(tool: UTSJSONObject): string {
				return readAgentSettingsToolDesc(tool)
			},

			isAgentToolSelected(tool: UTSJSONObject): boolean {
				return isAgentSettingsToolSelected(this.selectedToolIds, tool)
			},

			getToolCardClass(tool: UTSJSONObject, index: number): string {
				return getAgentSettingsToolCardClass(this.selectedToolIds, tool, index)
			},

			toggleAgentTool(tool: UTSJSONObject) {
				const toolId = this.getToolId(tool)
				if (toolId == '') {
					return
				}
				if (isLockedNyxTeachingTool(this.agentId, toolId) == true) {
					uni.showToast({ position: 'bottom', title: '眠汐内置教学不能关闭', icon: 'none' })
					return
				}
				this.selectedToolIds = toggleAgentSettingsToolSelection(this.selectedToolIds, toolId)
				this.hasUnsaved = true
			},

			/** 上传/更换私聊头像 */
			pickAvatar() {
				chooseAvatarImage((path: string) => {
					openAvatarCrop(path, 'agent_avatar')
				})
			},

			/** 打开全屏编辑器编辑联系人备注 */
			openDescEditor() {
				this.openTextEditor(this.agentDesc, '编辑描述', 'desc', '写一下这个联系人的人设、用途或备注')
			},

			/** 打开全屏编辑器编辑系统提示词 */
			openSystemPromptEditor() {
				this.openTextEditor(this.agentSystemPrompt, '编辑提示词', 'systemPrompt', '定义说话风格、能力边界和输出习惯')
			},

			/** 打开每轮临时注入规则的全屏编辑器。 */
			openInteractionRulesEditor() {
				this.openTextEditor(this.agentInteractionRules, '编辑对话规则', 'interactionRules', '定义距离感、回复长度、知识边界和对话习惯')
			},

			openTextEditor(content: string, title: string, target: string, placeholder: string): void {
				if (tryPrepareAgentSettingsTextEditor(content, title, target, placeholder) == false) {
					showAgentSettingsFailure('AGENT_SETTINGS_EDITOR_STATE_FAILED', 'agent_settings_editor_prepare', '无法准备全屏编辑器', '编辑器临时状态保存失败')
					return
				}
				uni.navigateTo({
					url: '/pages/common/editor/editor',
					fail: (err: any) => {
						clearAgentSettingsEditorRuntime()
						showAgentSettingsFailure('AGENT_SETTINGS_EDITOR_ROUTE_FAILED', 'agent_settings_editor_navigate', '无法打开全屏编辑器', err)
					}
				})
			},

			loadModel() {
				const model = getAppSetting('settings_model')
				if (model != null && model != '') {
					this.currentModel = model
				}
			},

			onGenerationInput(_event: any) {
				this.hasUnsaved = true
			},

			onGenerationSwitch(_value: any) {
				this.hasUnsaved = true
			},

			saveSettingsOnly(): boolean {
				const input: AgentSettingsSaveInput = {
					agentId: this.agentId,
					name: this.agentName,
					desc: this.agentDesc,
					avatar: this.agentAvatar,
					systemPrompt: this.agentSystemPrompt,
					interactionRules: this.agentInteractionRules,
					model: this.currentModel,
					ttsVoice: this.ttsVoice,
					ttsVolume: this.ttsVolume,
					ttsPitch: this.ttsPitch,
					useGlobalGeneration: this.useGlobalGeneration,
					temperatureStr: this.temperatureStr,
					maxTokensStr: this.maxTokensStr,
					maxIterationsStr: this.maxIterationsStr,
					streamEnabled: this.streamEnabled,
					truncateThresholdStr: this.truncateThresholdStr,
					truncateDropCountStr: this.truncateDropCountStr,
					cacheEnabled: this.cacheEnabled,
					hideThinking: this.hideThinking,
					injectDatetime: this.injectDatetime,
					msgSegmentation: this.msgSegmentation,
					selectedSkillIds: this.selectedSkillIds,
					selectedToolIds: this.selectedToolIds,
				} as AgentSettingsSaveInput
				let result = null as AgentSettingsSaveResult | null
				try {
					result = saveAgentSettings(input, getGlobalGenerationSettings())
				} catch (e: any) {
					showAgentSettingsFailure('AGENT_SETTINGS_SAVE_FAILED', 'agent_settings_save', '联系人设置保存失败', e)
					return false
				}
				if (result == null) {
					showAgentSettingsFailure('AGENT_SETTINGS_SAVE_EMPTY', 'agent_settings_save', '联系人设置保存失败', '保存服务未返回结果')
					return false
				}
				if (result.ok == false) {
					showAgentSettingsFailure('AGENT_SETTINGS_SAVE_REJECTED', 'agent_settings_save', result.error, result.error)
					return false
				}
				const generation = result.generation
				if (generation == null) {
					uni.showToast({ position: 'bottom', title: '保存失败', icon: 'none' })
					return false
				}
				if (this.useGlobalGeneration == false) {
					this.temperatureStr = generation.temperatureStr
					this.maxTokensStr = generation.maxTokensStr
					this.maxIterationsStr = generation.maxIterationsStr
				}
				if (this.savedAvatarPath != this.agentAvatar) {
					discardManagedAvatarFile(this.savedAvatarPath)
					this.savedAvatarPath = this.agentAvatar
				}
				this.hasUnsaved = false
				uni.showToast({ position: 'bottom',
					title: '已保存',
					icon: 'success'
				})
				return true
			},

			saveSettingsAndBack() {
				if (this.saveSettingsOnly() == false) {
					return
				}
				uni.navigateBack({
					fail: (err: any) => {
						showAgentSettingsFailure('AGENT_SETTINGS_BACK_FAILED', 'agent_settings_save_back', '设置已保存，但无法返回上一页', err)
					}
				})
			},

			confirmDelete() {
				if (this.agentId == NYX_ADMIN_AGENT_ID) {
					uni.showToast({ position: 'bottom', title: '眠汐不能删除', icon: 'none' })
					return
				}
				uni.showModal({
					title: '删除私聊',
					content: '确定要删除「' + this.agentName + '」吗？此操作无法撤销。',
					success: (res) => {
						if (res.confirm == true) {
							let deleteResult = null as AgentDeleteResult | null
							try {
								deleteResult = deleteAgent(this.agentId)
							} catch (e: any) {
								showAgentSettingsFailure('AGENT_DELETE_FAILED', 'agent_delete', '删除联系人失败', e)
								return
							}
							if (deleteResult == null) {
								showAgentSettingsFailure('AGENT_DELETE_EMPTY', 'agent_delete', '删除联系人失败', '删除服务未返回结果')
								return
							}
							if (deleteResult.ok == false) {
								showAgentSettingsFailure('AGENT_DELETE_REJECTED', 'agent_delete', '删除联系人失败', 'deleteAgent 返回失败')
								return
							}
							discardManagedAvatarFile(this.agentAvatar)
							if (this.savedAvatarPath != this.agentAvatar) {
								discardManagedAvatarFile(this.savedAvatarPath)
							}
							// 如果删除的是当前选中的私聊，清除 active_agent_id
							const activeId = getRuntimeState('active_agent_id')
							if (activeId == this.agentId) {
								clearActiveAgentRuntimeId()
							}
							uni.showToast({ position: 'bottom',
								title: deleteResult.filesCleared == true ? '已删除' : '已删除，文件清理失败',
								icon: deleteResult.filesCleared == true ? 'success' : 'none'
							})
							// 删除后清空已失效的私聊详情栈，回到会话列表。
							uni.reLaunch({
								url: '/pages/agents/agents',
								fail: (err: any) => {
									showAgentSettingsFailure('AGENT_DELETE_ROUTE_FAILED', 'agent_delete_relaunch', '联系人已删除，但无法返回会话列表', err)
								}
							})
						}
					},
					fail: (err: any) => {
						showAgentSettingsFailure('AGENT_DELETE_CONFIRM_FAILED', 'agent_delete_confirm', '无法打开删除确认框', err)
					}
				})
			},

			/** 弹出确认离开对话框，供 goBack / onBackPress 共用 */
			confirmLeave() {
				if (this.hasUnsaved == false) {
					uni.navigateBack({
						fail: (err: any) => {
							showAgentSettingsFailure('AGENT_SETTINGS_BACK_FAILED', 'agent_settings_back', '无法返回上一页', err)
						}
					})
					return
				}
				if (this.isConfirmingLeave == true) {
					return
				}
				this.isConfirmingLeave = true
				uni.showModal({
					title: '未保存的更改',
					content: '有未保存的更改，是否保存？',
					cancelText: '不保存',
					confirmText: '保存',
					success: (res) => {
						this.isConfirmingLeave = false
						if (res.confirm == true) {
							if (this.saveSettingsOnly() == true) {
								uni.navigateBack({
									fail: (err: any) => {
										showAgentSettingsFailure('AGENT_SETTINGS_BACK_FAILED', 'agent_settings_confirm_save_back', '设置已保存，但无法返回上一页', err)
									}
								})
							}
						} else {
							if (this.agentAvatar != this.savedAvatarPath) {
								discardManagedAvatarFile(this.agentAvatar)
								this.agentAvatar = this.savedAvatarPath
							}
							this.hasUnsaved = false
							uni.navigateBack({
								fail: (err: any) => {
									showAgentSettingsFailure('AGENT_SETTINGS_BACK_FAILED', 'agent_settings_discard_back', '无法返回上一页', err)
								}
							})
						}
					},
					fail: (err: any) => {
						this.isConfirmingLeave = false
						showAgentSettingsFailure('AGENT_SETTINGS_LEAVE_CONFIRM_FAILED', 'agent_settings_leave_confirm', '无法打开退出确认框', err)
					}
				})
			},

			/** NavBar 返回按钮事件 */
			goBack() {
				this.confirmLeave()
			},
		}
	}
</script>

<style>
	.container {
		flex: 1;
		padding: 16px;
