<template>
	<view class="page-shell rice-theme-light">
		<NavBar title="智能体设置" showBack @back="goBack" />
		<scroll-view class="container" :scroll-y="true">
			<!-- 头部：头像 -->
			<view class="profile-header" @click="pickAvatar">
				<image v-if="agentAvatar != ''" :src="agentAvatar" class="agent-avatar" mode="aspectFill" />
				<view v-else class="agent-avatar agent-avatar-placeholder">
					<text class="agent-avatar-text">{{agentName.substring(0, 1)}}</text>
				</view>
				<text class="avatar-hint">点击更换头像</text>
			</view>

			<!-- 全部设置项合并到一个卡片 -->
			<view class="card">
				<!-- 名称 -->
				<view class="card-header">
					<oui-icon-unix name="edit" size="22rpx" color="#6B7280" style="margin-right:10rpx" />
					<text class="card-label">名称</text>
				</view>
				<input
					class="flat-input"
					type="text"
					v-model="agentName"
					placeholder="输入智能体名称"
					placeholder-class="input-placeholder"
				/>

				<view class="card-header" style="margin-top:20rpx;">
					<oui-icon-unix name="file-text" size="22rpx" color="#6B7280" style="margin-right:10rpx" />
					<text class="card-label">描述</text>
				</view>
				<view class="desc-wrap" @click="openDescEditor">
					<text class="desc-preview" lines="2" text-overflow="ellipsis">{{agentDesc != '' ? agentDesc : '点击输入智能体描述'}}</text>
					<view class="desc-edit-btn">
						<text class="desc-edit-text">全屏编辑</text>
					</view>
				</view>

				<view class="card-header" style="margin-top:20rpx;">
					<oui-icon-unix name="info-circle" size="22rpx" color="#6B7280" style="margin-right:10rpx" />
					<text class="card-label">提示词</text>
				</view>
				<view class="desc-wrap" @click="openSystemPromptEditor">
					<scroll-view class="prompt-scroll" :scroll-y="true">
						<text class="desc-preview">{{agentSystemPrompt}}</text>
					</scroll-view>
					<view class="desc-edit-btn">
						<text class="desc-edit-text">全屏编辑</text>
					</view>
				</view>

				<!-- 模型 -->
				<view class="model-row" style="margin-top:20rpx;" @click="toggleModelPanel">
					<view class="card-header" style="margin-bottom:0;">
						<oui-icon-unix name="robot" size="22rpx" color="#6B7280" style="margin-right:10rpx" />
						<text class="card-label">对话模型</text>
					</view>
					<view class="model-right">
						<text class="model-value">{{currentModelLabel}}</text>
						<text class="model-arrow">{{showModelPanel ? '▾' : '›'}}</text>
					</view>
				</view>

				<!-- 展开模型选择 -->
				<view v-if="showModelPanel" class="model-panel">
					<text class="panel-label">选择提供商</text>
					<scroll-view class="chip-scroll" :scroll-x="true" :show-scrollbar="false">
						<view class="chip-row">
							<view
								v-for="(p, pi) in enabledProviders"
								:key="pi"
								class="chip"
								:class="selectedProviderId == (p['id'] as string) ? 'chip-active' : ''"
								@click="selectProvider(p['id'] as string)"
							>
								<text class="chip-text">{{p['name']}}</text>
							</view>
						</view>
					</scroll-view>

					<text class="panel-label" style="margin-top:16rpx;">选择模型</text>
					<view v-if="providerModels.length == 0" class="panel-empty">
						<text class="panel-empty-text">请先在提供商管理中配置模型</text>
					</view>
					<view v-else class="model-grid">
						<view
							v-for="(m, mi) in providerModels"
							:key="mi"
							class="model-pill"
							:class="selectedModelId == m.id ? 'pill-active' : ''"
							@click="selectModel(m.id)"
						>
							<text class="pill-text" :class="selectedModelId == m.id ? 'pill-text-active' : ''">{{m.id}}</text>
						</view>
					</view>
				</view>

				<view class="setting-divider"></view>
				<view class="card-header">
					<oui-icon-unix name="setting" size="22rpx" color="#6B7280" style="margin-right:10rpx" />
					<text class="card-label">生成参数</text>
				</view>
				<view class="setting-row">
					<view class="setting-text">
						<text class="setting-title">继承全局设置</text>
						<text class="setting-desc">{{globalGenerationHint}}</text>
					</view>
					<rice-switch v-model="useGlobalGeneration" @change="onGenerationSwitch" />
				</view>
				<view v-if="useGlobalGeneration == false" class="generation-panel">
					<view class="param-row">
						<view class="param-item">
							<text class="param-label">温度</text>
							<input class="param-input" type="text" v-model="temperatureStr" placeholder="0 - 2" @input="onGenerationInput" />
						</view>
						<view class="param-item">
							<text class="param-label">输出上限</text>
							<input class="param-input" type="text" v-model="maxTokensStr" placeholder="256 - 65536" @input="onGenerationInput" />
						</view>
					</view>
					<view class="param-row">
						<view class="param-item">
							<text class="param-label">最大迭代</text>
							<input class="param-input" type="text" v-model="maxIterationsStr" placeholder="0 - 100，0 不限制" @input="onGenerationInput" />
						</view>
						<view class="param-switch">
							<view>
								<text class="param-label">流式显示</text>
								<text class="param-tip">关闭后等完整回复再显示</text>
							</view>
							<rice-switch v-model="streamEnabled" @change="onGenerationSwitch" />
						</view>
					</view>
				</view>
			</view>

			<!-- 上下文截断 -->
			<view class="card">
				<view class="card-header">
					<oui-icon-unix name="scissors" size="22rpx" color="#6B7280" style="margin-right:10rpx" />
					<text class="card-label">上下文截断</text>
				</view>
				<view class="setting-row">
					<view class="setting-text">
						<text class="setting-title">截断阈值（分）</text>
						<text class="setting-desc">超分后丢弃较早对话，0 不启用</text>
					</view>
					<input class="param-input short-input" type="text" v-model="truncateThresholdStr" placeholder="0" />
				</view>
				<view class="setting-row">
					<view class="setting-text">
						<text class="setting-title">丢弃条数</text>
						<text class="setting-desc">触发截断时移除的对话对数</text>
					</view>
					<input class="param-input short-input" type="text" v-model="truncateDropCountStr" placeholder="20" />
				</view>
				<view class="setting-row">
					<view class="setting-text">
						<text class="setting-title">缓存启用</text>
						<text class="setting-desc">开启后重复请求使用缓存加速</text>
					</view>
					<rice-switch v-model="cacheEnabled" />
				</view>
				<view class="setting-row">
					<view class="setting-text">
						<text class="setting-title">隐藏思考过程</text>
						<text class="setting-desc">AI 回复中的思考折叠区不显示</text>
					</view>
					<rice-switch v-model="hideThinking" />
				</view>
				<view class="setting-row">
					<view class="setting-text">
						<text class="setting-title">注入日期时间</text>
						<text class="setting-desc">每条消息前自动附加当前日期、星期、节日</text>
					</view>
					<rice-switch v-model="injectDatetime" />
				</view>
			</view>

			<!-- 保存按钮 -->
			<view class="save-wrap">
				<view class="save-btn" @click="saveSettings">
					<text class="save-btn-text">保存修改</text>
				</view>
			</view>

			<!-- 删除按钮 -->
			<view class="delete-wrap">
				<view class="delete-btn" @click="confirmDelete">
					<text class="delete-btn-text">删除该智能体</text>
				</view>
			</view>
		</scroll-view>
	</view>
</template>

<script lang="uts">
	/**
	 * 智能体设置页面 - 编辑名称/描述/头像/删除智能体
	 */
	import { getAgentById, updateAgent, deleteAgent, updateAgentAvatar, updateAgentModel, updateAgentGenerationSettings, updateAgentTruncation, updateAgentCache, updateAgentHideThinking, updateAgentInjectDatetime } from '@/utils/agent.uts'
	import { getAllProviders, getProviderModels, type ModelInfo } from '@/utils/provider.uts'
	import { updateSystemPromptForAgent } from '@/utils/database.uts'
	import { getGlobalGenerationSettings, type GenerationSettings } from '@/utils/generation-settings.uts'

	export default {
		data() {
			return {
				agentId: '' as string,
				agentName: '' as string,
				agentDesc: '' as string,
				agentSystemPrompt: '' as string,
				agentAvatar: '' as string,
				currentModel: 'deepseek-v4-flash',
				allProviders: [] as UTSJSONObject[],
				showModelPanel: false as boolean,
				selectedProviderId: '' as string,
				selectedModelId: '' as string,
				useGlobalGeneration: true as boolean,
				temperatureStr: '' as string,
				maxTokensStr: '' as string,
				maxIterationsStr: '' as string,
				streamEnabled: true as boolean,
				/** 上下文截断阈值（分），0 不启用 */
				truncateThresholdStr: '40' as string,
				/** 触发截断时丢弃的对话对数 */
				truncateDropCountStr: '20' as string,
				/** 缓存启用 */
				cacheEnabled: false as boolean,
				/** 隐藏思考过程 */
				hideThinking: false as boolean,
				/** 注入日期时间 */
				injectDatetime: false as boolean,
				globalGenerationHint: '' as string,
				/** 编辑器返回后标记未保存 */
				hasUnsaved: false as boolean,
			}
		},
		computed: {
			/** 已启用的提供商列表 */
			enabledProviders(): UTSJSONObject[] {
				const list: UTSJSONObject[] = []
				for (let i = 0; i < this.allProviders.length; i++) {
					if ((this.allProviders[i]['enabled'] as number) == 1) {
						list.push(this.allProviders[i])
					}
				}
				return list
			},
			/** 当前选中提供商的模型列表 */
			providerModels(): ModelInfo[] {
				if (this.selectedProviderId == '') return []
				return getProviderModels(this.selectedProviderId)
			},
			/** 显示文本：提供商 / 模型 或纯模型名（向后兼容） */
			currentModelLabel(): string {
				const sep = '||'
				const idx = this.currentModel.indexOf(sep)
				if (idx >= 0) {
					const providerId = this.currentModel.substring(0, idx)
					const modelId = this.currentModel.substring(idx + sep.length)
					// 查找提供商名称
					for (let i = 0; i < this.allProviders.length; i++) {
						if ((this.allProviders[i]['id'] as string) == providerId) {
							return (this.allProviders[i]['name'] as string) + ' / ' + modelId
						}
					}
					return providerId + ' / ' + modelId
				}
				return this.currentModel
			}
		},
		onLoad() {
			this.loadAgent()
		},
		onShow() {
			// 先从数据库加载（避免后续被覆盖）
			this.loadAgent()
			// 检查全屏编辑器是否有返回结果
			const result = uni.getStorageSync('editor_result') as string
			if (result != null && result != '') {
				const target = uni.getStorageSync('editor_target') as string
				if (target == 'systemPrompt') {
					this.agentSystemPrompt = result
				} else {
					this.agentDesc = result
				}
				uni.removeStorageSync('editor_result')
				uni.removeStorageSync('editor_target')
				// 标记有未保存的更改
				this.hasUnsaved = true
			}
			// 检查裁剪页面是否有返回结果
			const cropTarget = uni.getStorageSync('crop_target') as string
			const cropResult = uni.getStorageSync('crop_result') as string
			if (cropTarget == 'agent_avatar' && cropResult != null && cropResult != '') {
				this.agentAvatar = cropResult
				updateAgentAvatar(this.agentId, cropResult)
				uni.removeStorageSync('crop_result')
				uni.removeStorageSync('crop_target')
				uni.removeStorageSync('crop_image_path')
			}
		},
		methods: {
			loadAgent() {
				const id = uni.getStorageSync('active_agent_id') as string
				if (id == null || id == '') {
					uni.showToast({ position: 'bottom', 
						title: '未选择智能体',
						icon: 'none'
					})
					return
				}
				this.agentId = id
				this.hasUnsaved = false
				this.allProviders = getAllProviders()
				const agent = getAgentById(id)
				if (agent != null) {
					this.agentName = agent['name'] as string
					this.agentDesc = agent['desc'] as string
					const rawPrompt = agent['systemPrompt']
					this.agentSystemPrompt = rawPrompt != null ? (rawPrompt as string) : ''
					const rawAvatar = agent['avatar']
					this.agentAvatar = rawAvatar != null ? (rawAvatar as string) : ''
					const rawModel = agent['model']
					if (rawModel != null) {
						this.currentModel = rawModel as string
					}
					this.loadGenerationSettings(agent)
				}
				this.initModelSelection()
			},

			clampNumber(value: number, min: number, max: number): number {
				if (value < min) return min
				if (value > max) return max
				return value
			},

			parseFloatSetting(value: string, fallback: number, min: number, max: number): number {
				const parsed = parseFloat(value)
				if (isNaN(parsed)) {
					return fallback
				}
				return this.clampNumber(parsed, min, max)
			},

			parseIntSetting(value: string, fallback: number, min: number, max: number): number {
				const parsed = parseInt(value)
				if (isNaN(parsed)) {
					return fallback
				}
				return this.clampNumber(parsed, min, max)
			},

			buildGenerationHint(settings: GenerationSettings): string {
				const iterationText = settings.maxIterations == 0 ? '不限制' : (settings.maxIterations + '')
				return '温度 ' + settings.temperature + ' · 输出 ' + settings.maxTokens + ' · 迭代 ' + iterationText + ' · ' + (settings.streamEnabled ? '流式' : '非流式')
			},

			loadGenerationSettings(agent: UTSJSONObject) {
				const global = getGlobalGenerationSettings()
				this.globalGenerationHint = this.buildGenerationHint(global)
				const rawTemperature = agent['temperature'] as number | null
				const rawMaxTokens = agent['maxTokens'] as number | null
				const rawMaxIterations = agent['maxIterations'] as number | null
				const rawStreamEnabled = agent['streamEnabled'] as boolean | null
				const hasOverride = rawTemperature != null || rawMaxTokens != null || rawMaxIterations != null || rawStreamEnabled != null
				this.useGlobalGeneration = hasOverride == false
				this.temperatureStr = (rawTemperature != null ? rawTemperature : global.temperature) + ''
				this.maxTokensStr = (rawMaxTokens != null ? rawMaxTokens : global.maxTokens) + ''
				this.maxIterationsStr = (rawMaxIterations != null ? rawMaxIterations : global.maxIterations) + ''
				this.streamEnabled = rawStreamEnabled != null ? rawStreamEnabled : global.streamEnabled

				// 截断/缓存/隐藏思考/注入日期
				const rawThreshold = agent['truncateThreshold'] as number | null
				const rawDropCount = agent['truncateDropCount'] as number | null
				const rawCacheEnabled = agent['cacheEnabled'] as boolean | null
				const rawHideThinking = agent['hideThinking'] as boolean | null
				const rawInjectDatetime = agent['injectDatetime'] as boolean | null
				this.truncateThresholdStr = (rawThreshold != null ? rawThreshold : 40) + ''
				this.truncateDropCountStr = (rawDropCount != null ? rawDropCount : 20) + ''
				this.cacheEnabled = rawCacheEnabled == true
				this.hideThinking = rawHideThinking == true
				this.injectDatetime = rawInjectDatetime == true
			},

			/** 从 currentModel 解析出选中的提供商和模型 */
			initModelSelection() {
				const sep = '||'
				const idx = this.currentModel.indexOf(sep)
				if (idx >= 0) {
					this.selectedProviderId = this.currentModel.substring(0, idx)
					this.selectedModelId = this.currentModel.substring(idx + sep.length)
				} else {
					this.selectedModelId = this.currentModel
					// 尝试从已启用的提供商中找匹配
					const enabled = this.enabledProviders
					if (enabled.length > 0) {
						this.selectedProviderId = enabled[0]['id'] as string
					}
				}
			},

			toggleModelPanel() {
				this.showModelPanel = !this.showModelPanel
				if (this.showModelPanel) {
					this.initModelSelection()
				}
			},

			selectProvider(id: string) {
				this.selectedProviderId = id
				this.selectedModelId = ''
				this.hasUnsaved = true
			},

			selectModel(id: string) {
				this.selectedModelId = id
				this.currentModel = this.selectedProviderId + '||' + id
				this.hasUnsaved = true
				// 选择后自动收起面板
				this.showModelPanel = false
			},

			/** 上传/更换智能体头像 */
			pickAvatar() {
				uni.chooseImage({
					count: 1,
					sourceType: ['album', 'camera'],
					sizeType: ['compressed'],
					success: (res: any) => {
						const raw = JSON.stringify(res)
						if (raw == null || raw == '') { return }
						const parsed = JSON.parse(raw) as UTSJSONObject
						const paths = parsed['tempFilePaths'] as string[]
						if (paths != null && paths.length > 0) {
							uni.removeStorageSync('crop_result')
							uni.setStorageSync('crop_target', 'agent_avatar')
							uni.setStorageSync('crop_image_path', paths[0])
							uni.navigateTo({
								url: '/pages/common/crop/crop'
							})
						}
					}
				})
			},

			/** 打开全屏编辑器编辑智能体描述 */
			openDescEditor() {
				uni.removeStorageSync('editor_draft')
				uni.setStorageSync('editor_content', this.agentDesc)
				uni.setStorageSync('editor_title', '编辑描述')
				uni.setStorageSync('editor_target', 'desc')
				uni.navigateTo({
					url: '/pages/common/editor/editor'
				})
			},

			/** 打开全屏编辑器编辑系统提示词 */
			openSystemPromptEditor() {
				uni.removeStorageSync('editor_draft')
				uni.setStorageSync('editor_content', this.agentSystemPrompt)
				uni.setStorageSync('editor_title', '编辑提示词')
				uni.setStorageSync('editor_target', 'systemPrompt')
				uni.navigateTo({
					url: '/pages/common/editor/editor'
				})
			},

			loadModel() {
				const model = uni.getStorageSync('settings_model') as string
				if (model != null && model != '') {
					this.currentModel = model
				}
			},

			onGenerationInput(_event: any) {
				this.hasUnsaved = true
			},

			onGenerationSwitch(_value: any) {
				this.hasUnsaved = true
			},

			saveSettings() {
				const name = this.agentName.trim()
				const desc = this.agentDesc.trim()
				if (name == '') {
					uni.showToast({ position: 'bottom', 
						title: '名称不能为空',
						icon: 'none'
					})
					return
				}
				updateAgent(this.agentId, name, desc, '', this.agentSystemPrompt)
				updateAgentModel(this.agentId, this.currentModel)
				const globalGeneration = getGlobalGenerationSettings()
				let temperature: number | null = null
				let maxTokens: number | null = null
				let maxIterations: number | null = null
				let streamEnabled: boolean | null = null
				if (this.useGlobalGeneration == false) {
					const parsedTemperature = this.parseFloatSetting(this.temperatureStr, globalGeneration.temperature, 0, 2)
					const parsedMaxTokens = this.parseIntSetting(this.maxTokensStr, globalGeneration.maxTokens, 256, 65536)
					const parsedMaxIterations = this.parseIntSetting(this.maxIterationsStr, globalGeneration.maxIterations, 0, 100)
					temperature = parsedTemperature
					maxTokens = parsedMaxTokens
					maxIterations = parsedMaxIterations
					streamEnabled = this.streamEnabled
					this.temperatureStr = parsedTemperature + ''
					this.maxTokensStr = parsedMaxTokens + ''
					this.maxIterationsStr = parsedMaxIterations + ''
				}
				updateAgentGenerationSettings(this.agentId, temperature, maxTokens, maxIterations, streamEnabled)
				// 保存截断/缓存/隐藏思考
				const threshold = parseFloat(this.truncateThresholdStr)
				const dropCount = parseInt(this.truncateDropCountStr)
				updateAgentTruncation(this.agentId, isNaN(threshold) ? 40 : threshold, isNaN(dropCount) ? 20 : dropCount)
				updateAgentCache(this.agentId, this.cacheEnabled)
				updateAgentHideThinking(this.agentId, this.hideThinking)
				updateAgentInjectDatetime(this.agentId, this.injectDatetime)
				// 同步更新所有历史对话的 system_prompt
				updateSystemPromptForAgent(this.agentId, this.agentSystemPrompt)
				this.hasUnsaved = false
				uni.showToast({ position: 'bottom', 
					title: '已保存',
					icon: 'success'
				})
				uni.navigateBack()
			},

			confirmDelete() {
				uni.showModal({
					title: '删除智能体',
					content: '确定要删除「' + this.agentName + '」吗？此操作无法撤销。',
					success: (res) => {
						if (res.confirm == true) {
							deleteAgent(this.agentId)
							// 如果删除的是当前选中的智能体，清除 active_agent_id
							const activeId = uni.getStorageSync('active_agent_id') as string
							if (activeId == this.agentId) {
								uni.removeStorageSync('active_agent_id')
							}
							uni.showToast({ position: 'bottom', 
								title: '已删除',
								icon: 'success'
							})
							// 跳转到智能体列表页
							uni.redirectTo({
								url: '/pages/agents/agents'
							})
						}
					}
				})
			},

			goBack() {
				if (this.hasUnsaved) {
					uni.showModal({
						title: '未保存的更改',
						content: '有未保存的更改，是否保存？',
						cancelText: '不保存',
						confirmText: '保存',
						success: (res) => {
							if (res.confirm == true) {
								this.saveSettings()
							} else {
								this.hasUnsaved = false
								uni.navigateBack()
							}
						}
					})
				} else {
					uni.navigateBack()
				}
			},
		}
	}
</script>

<style>
	.container {
		flex: 1;
		padding: 32rpx;
	}

	/* 卡片 */
	.card {
		background-color: #FFFFFF;
		border-radius: 20rpx;
		padding: 32rpx;
		margin-bottom: 24rpx;
	}

