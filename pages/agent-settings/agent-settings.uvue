<template>
	<view class="page-shell rice-theme-light">
		<NavBar title="智能体设置" showBack @back="goBack" />
		<scroll-view class="container" :scroll-y="true">
			<!-- 头部：头像 -->
			<view class="profile-header" @click="pickAvatar">
				<image v-if="agentAvatar != ''" :src="agentAvatar" class="agent-avatar" mode="aspectFill" />
				<view v-else class="agent-avatar agent-avatar-placeholder">
					<text class="agent-avatar-text">{{agentName.substring(0, 1)}}</text>
				</view>
				<text class="avatar-hint">点击更换头像</text>
			</view>

			<!-- 全部设置项合并到一个卡片 -->
			<view class="card">
				<!-- 名称 -->
				<view class="card-header">
					<oui-icon-unix name="edit" size="22rpx" color="#6B7280" style="margin-right:10rpx" />
					<text class="card-label">名称</text>
				</view>
			<input
				class="flat-input"
				type="text"
				v-model="agentName"
				placeholder="输入智能体名称"
				placeholder-class="input-placeholder"
				@input="hasUnsaved = true"
			/>

				<view class="card-header" style="margin-top:20rpx;">
					<oui-icon-unix name="file-text" size="22rpx" color="#6B7280" style="margin-right:10rpx" />
					<text class="card-label">介绍</text>
					<text class="card-hint">（会用于其他 Agent 读取）</text>
				</view>
				<view class="desc-wrap" @click="openDescEditor">
					<text class="desc-preview" lines="2" text-overflow="ellipsis">{{agentDesc != '' ? agentDesc : '点击输入智能体介绍'}}</text>
					<view class="desc-edit-btn">
						<text class="desc-edit-text">全屏编辑</text>
					</view>
				</view>

				<view class="card-header" style="margin-top:20rpx;">
					<oui-icon-unix name="info-circle" size="22rpx" color="#6B7280" style="margin-right:10rpx" />
					<text class="card-label">提示词</text>
				</view>
				<view class="desc-wrap" @click="openSystemPromptEditor">
					<scroll-view class="prompt-scroll" :scroll-y="true">
						<text class="desc-preview">{{agentSystemPrompt}}</text>
					</scroll-view>
					<view class="desc-edit-btn">
						<text class="desc-edit-text">全屏编辑</text>
					</view>
				</view>

				<!-- 模型 -->
				<view class="model-row" style="margin-top:20rpx;" @click="toggleModelPanel">
					<view class="card-header" style="margin-bottom:0;">
						<oui-icon-unix name="robot" size="22rpx" color="#6B7280" style="margin-right:10rpx" />
						<text class="card-label">对话模型</text>
					</view>
					<view class="model-right">
						<text class="model-value">{{currentModelLabel}}</text>
						<text class="model-arrow">{{showModelPanel ? '▾' : '›'}}</text>
					</view>
				</view>

				<!-- 展开模型选择 -->
				<view v-if="showModelPanel" class="model-panel">
					<text class="panel-label">选择提供商</text>
					<scroll-view class="chip-scroll" :scroll-x="true" :show-scrollbar="false">
						<view class="chip-row">
							<view
								v-for="(p, pi) in enabledProviders"
								:key="pi"
								class="chip"
								:class="selectedProviderId == (p['id'] as string) ? 'chip-active' : ''"
								@click="selectProvider(p['id'] as string)"
							>
								<text class="chip-text">{{p['name']}}</text>
							</view>
						</view>
					</scroll-view>

					<text class="panel-label" style="margin-top:16rpx;">选择模型</text>
					<view v-if="providerModels.length == 0" class="panel-empty">
						<text class="panel-empty-text">请先在提供商管理中配置模型</text>
					</view>
					<view v-else class="model-grid">
						<view
							v-for="(m, mi) in providerModels"
							:key="mi"
							class="model-pill"
							:class="selectedModelId == m.id ? 'pill-active' : ''"
							@click="selectModel(m.id)"
						>
							<text class="pill-text" :class="selectedModelId == m.id ? 'pill-text-active' : ''">{{m.id}}</text>
						</view>
					</view>
				</view>

				<view class="setting-divider"></view>
				<view class="card-header">
					<oui-icon-unix name="setting" size="22rpx" color="#6B7280" style="margin-right:10rpx" />
					<text class="card-label">生成参数</text>
				</view>
				<view class="setting-row">
					<view class="setting-text">
						<text class="setting-title">继承全局设置</text>
						<text class="setting-desc">{{globalGenerationHint}}</text>
					</view>
					<rice-switch v-model="useGlobalGeneration" @change="onGenerationSwitch" />
				</view>
				<view v-if="useGlobalGeneration == false" class="generation-panel">
					<view class="param-row">
						<view class="param-item">
							<text class="param-label">温度</text>
							<input class="param-input" type="text" v-model="temperatureStr" placeholder="0 - 2" @input="onGenerationInput" />
						</view>
						<view class="param-item">
							<text class="param-label">输出上限</text>
							<input class="param-input" type="text" v-model="maxTokensStr" placeholder="256 - 65536" @input="onGenerationInput" />
						</view>
					</view>
					<view class="param-row">
						<view class="param-item">
							<text class="param-label">最大迭代</text>
							<input class="param-input" type="text" v-model="maxIterationsStr" placeholder="0 - 100，0 不限制" @input="onGenerationInput" />
						</view>
						<view class="param-switch">
							<view>
								<text class="param-label">流式显示</text>
								<text class="param-tip">关闭后等完整回复再显示</text>
							</view>
							<rice-switch v-model="streamEnabled" @change="onGenerationSwitch" />
						</view>
					</view>
				</view>
			</view>

			<!-- Skills -->
			<view class="card">
				<view class="card-header">
					<oui-icon-unix name="book" size="22rpx" color="#6B7280" style="margin-right:10rpx" />
					<text class="card-label">Skills</text>
				</view>
				<text class="skill-section-desc">为当前智能体启用纯文本技能包。不同 Agent 可以使用不同 Skills。</text>
				<view v-if="allSkills.length == 0" class="panel-empty">
					<text class="panel-empty-text">还没有 Skill，请到 设置 / Skills 创建。</text>
				</view>
				<view v-else class="skill-grid">
					<view
						v-for="(skill, si) in allSkills"
						:key="si"
						class="skill-card"
						:class="isAgentSkillSelected(skill) ? 'skill-card-active' : ''"
						@click="toggleAgentSkill(skill)"
					>
						<view class="skill-card-top">
							<text class="skill-card-name">{{getSkillName(skill)}}</text>
							<text class="skill-card-check">{{isAgentSkillSelected(skill) ? '✓' : '+'}}</text>
						</view>
						<text class="skill-card-desc" lines="2" text-overflow="ellipsis">{{getSkillDesc(skill)}}</text>
						<text class="skill-card-meta">{{getSkillMeta(skill)}}</text>
					</view>
				</view>
			</view>

			<!-- 工具设置 -->
			<view class="card">
				<view class="card-header">
					<oui-icon-unix name="setting" size="22rpx" color="#6B7280" style="margin-right:10rpx" />
					<text class="card-label">工具设置</text>
				</view>
				<text class="skill-section-desc">为当前智能体启用可调用工具。不启用的工具不会注入模型上下文，也不会被执行。</text>
				<view class="tool-list">
					<view
						v-for="(tool, ti) in availableTools"
						:key="ti"
						class="skill-card tool-card"
						:class="isAgentToolSelected(tool) ? 'skill-card-active' : ''"
						@click="toggleAgentTool(tool)"
					>
						<view class="skill-card-top">
							<text class="skill-card-name">{{getToolName(tool)}}</text>
							<text class="skill-card-check">{{isAgentToolSelected(tool) ? '✓' : '+'}}</text>
						</view>
						<text class="skill-card-desc" lines="2" text-overflow="ellipsis">{{getToolDesc(tool)}}</text>
						<text class="skill-card-meta">{{getToolMeta(tool)}}</text>
					</view>
				</view>
			</view>

			<!-- 上下文截断 -->
			<view class="card">
				<view class="card-header">
					<oui-icon-unix name="scissors" size="22rpx" color="#6B7280" style="margin-right:10rpx" />
					<text class="card-label">上下文截断</text>
				</view>
				<view class="context-tip">
					<text class="context-tip-text">按权重计算上下文长度：用户消息 1 分，普通 Agent 回复 0.3 分，工具调用/结果 0.1 分。达到阈值会截断早期消息，并自动触发记忆整理。</text>
				</view>
				<view class="setting-row">
					<view class="setting-text">
						<text class="setting-title">截断阈值（分）</text>
						<text class="setting-desc">达到该分数后整理记忆并截断，0 不启用</text>
					</view>
					<input class="param-input short-input" type="text" v-model="truncateThresholdStr" placeholder="0" @input="hasUnsaved = true" />
				</view>
				<view class="setting-row">
					<view class="setting-text">
						<text class="setting-title">丢弃分数</text>
						<text class="setting-desc">达到阈值后回落的分数，例如阈值 40、丢弃 20，则保留约 20 分上下文</text>
					</view>
					<input class="param-input short-input" type="text" v-model="truncateDropCountStr" placeholder="20" @input="hasUnsaved = true" />
				</view>
				<view class="setting-row">
					<view class="setting-text">
						<text class="setting-title">启用缓存ID</text>
						<text class="setting-desc">开启后请求会携带 cache_key（智能体ID:对话ID）</text>
					</view>
					<rice-switch v-model="cacheEnabled" @change="hasUnsaved = true" />
				</view>
				<view class="setting-row">
					<view class="setting-text">
						<text class="setting-title">隐藏思考过程</text>
						<text class="setting-desc">AI 回复中的思考折叠区不显示</text>
					</view>
					<rice-switch v-model="hideThinking" @change="hasUnsaved = true" />
				</view>
				<view class="setting-row">
					<view class="setting-text">
						<text class="setting-title">注入日期时间</text>
						<text class="setting-desc">每条消息前自动附加当前日期、星期、节日</text>
					</view>
					<rice-switch v-model="injectDatetime" @change="hasUnsaved = true" />
				</view>
				<view class="setting-row">
					<view class="setting-text">
						<text class="setting-title">消息分段</text>
						<text class="setting-desc">AI 回复按换行符分成多个相邻气泡</text>
					</view>
					<rice-switch v-model="msgSegmentation" @change="hasUnsaved = true" />
				</view>
			</view>

			<!-- 保存按钮 -->
			<view class="save-wrap">
				<view class="save-btn" @click="saveSettings">
					<text class="save-btn-text">保存修改</text>
				</view>
			</view>

			<!-- 删除按钮 -->
			<view class="delete-wrap">
				<view class="delete-btn" @click="confirmDelete">
					<text class="delete-btn-text">删除该智能体</text>
				</view>
			</view>
		</scroll-view>
	</view>
</template>

<script lang="uts">
	/**
	 * 智能体设置页面 - 编辑名称/描述/头像/删除智能体
	 */
	import { getAgentById, updateAgent, deleteAgent, updateAgentAvatar, updateAgentModel, updateAgentGenerationSettings, updateAgentTruncation, updateAgentCache, updateAgentHideThinking, updateAgentInjectDatetime, updateAgentMsgSegmentation, updateAgentSkills, updateAgentTools, getAgentEnabledToolIds, agentToolIdListContains, AGENT_TOOL_WORKSPACE_FILE, AGENT_TOOL_MEMORY_SEARCH, AGENT_TOOL_MEMORY_BUFFER_WRITE, AGENT_TOOL_WEB_SEARCH, AGENT_TOOL_MEMORY_CORE_LIST, AGENT_TOOL_MEMORY_CORE_SAVE, AGENT_TOOL_MEMORY_CORE_FORGET } from '@/utils/agent.uts'
	import { getAllProviders, getProviderModels, type ModelInfo } from '@/uni_modules/agent-core/utssdk/provider.uts'
	import { updateSystemPromptForAgent } from '@/utils/database.uts'
	import { getGlobalGenerationSettings, type GenerationSettings } from '@/utils/generation-settings.uts'
	import { getSkills, getAgentSkillIds, filterExistingSkillIds, skillIdListContains, readSkillId, readSkillName, readSkillDescription, readSkillEnabled, getSkillDocumentCount } from '@/utils/skills.uts'

	export default {
		data() {
			return {
				agentId: '' as string,
				agentName: '' as string,
				agentDesc: '' as string,
				agentSystemPrompt: '' as string,
				agentAvatar: '' as string,
				currentModel: 'deepseek-v4-flash',
				allProviders: [] as UTSJSONObject[],
				allSkills: [] as UTSJSONObject[],
				selectedSkillIds: [] as string[],
				availableTools: [] as UTSJSONObject[],
				selectedToolIds: [] as string[],
				showModelPanel: false as boolean,
				selectedProviderId: '' as string,
				selectedModelId: '' as string,
				useGlobalGeneration: true as boolean,
				temperatureStr: '' as string,
				maxTokensStr: '' as string,
				maxIterationsStr: '' as string,
				streamEnabled: true as boolean,
				/** 上下文截断阈值（分），0 不启用 */
				truncateThresholdStr: '40' as string,
				/** 触发截断时按积分回落的分数 */
				truncateDropCountStr: '20' as string,
				/** 启用缓存 ID */
				cacheEnabled: true as boolean,
				/** 隐藏思考过程 */
				hideThinking: false as boolean,
				/** 注入日期时间 */
				injectDatetime: true as boolean,
				/** AI 消息分段 */
				msgSegmentation: true as boolean,
				globalGenerationHint: '' as string,
				/** 编辑器返回后标记未保存 */
				hasUnsaved: false as boolean,
				/** 防止重复弹出确认离开对话框 */
				isConfirmingLeave: false as boolean,
			}
		},
		computed: {
			/** 已启用的提供商列表 */
			enabledProviders(): UTSJSONObject[] {
				const list: UTSJSONObject[] = []
				for (let i = 0; i < this.allProviders.length; i++) {
					if ((this.allProviders[i]['enabled'] as number) == 1) {
						list.push(this.allProviders[i])
					}
				}
				return list
			},
			/** 当前选中提供商的模型列表 */
			providerModels(): ModelInfo[] {
				if (this.selectedProviderId == '') return []
				return getProviderModels(this.selectedProviderId)
			},
			/** 显示文本：提供商 / 模型（向后兼容纯模型名） */
			currentModelLabel(): string {
				const sep = '||'
				const idx = this.currentModel.indexOf(sep)
				if (idx >= 0) {
					const providerId = this.currentModel.substring(0, idx)
					const modelId = this.currentModel.substring(idx + sep.length)
					for (let i = 0; i < this.allProviders.length; i++) {
						if ((this.allProviders[i]['id'] as string) == providerId) {
							return (this.allProviders[i]['name'] as string) + ' / ' + modelId
						}
					}
					if (providerId == '') {
						return '（默认提供商） / ' + modelId
					}
					return providerId + ' / ' + modelId
				}
				// 旧格式：纯模型名 → 在所有启用的提供商中查找匹配
				if (this.currentModel != '') {
					for (let i = 0; i < this.allProviders.length; i++) {
						if ((this.allProviders[i]['enabled'] as number) == 1) {
							const providerId = this.allProviders[i]['id'] as string
							const models = getProviderModels(providerId)
							for (let j = 0; j < models.length; j++) {
								if (models[j].id == this.currentModel) {
									return (this.allProviders[i]['name'] as string) + ' / ' + this.currentModel
								}
							}
						}
					}
					return this.currentModel + '（未关联提供商）'
				}
				return '未选择模型'
			}
		},
		onLoad() {
			this.loadAgent()
		},
		onShow() {
			// 先从数据库加载（避免后续被覆盖）
			this.loadAgent()
			// 检查全屏编辑器是否有返回结果
			const ready = uni.getStorageSync('editor_result_ready') as string | null
			const result = uni.getStorageSync('editor_result') as string | null
			if (ready == 'true' || (result != null && result != '')) {
				const target = uni.getStorageSync('editor_target') as string | null
				if (target == 'systemPrompt' || target == 'desc' || target == null || target == '') {
					const safeResult = result != null ? result : ''
					if (target == 'systemPrompt') {
						this.agentSystemPrompt = safeResult
					} else {
						this.agentDesc = safeResult
					}
					uni.removeStorageSync('editor_result')
					uni.removeStorageSync('editor_result_ready')
					uni.removeStorageSync('editor_target')
					uni.removeStorageSync('editor_mode')
					uni.removeStorageSync('editor_content')
					uni.removeStorageSync('editor_title')
					uni.removeStorageSync('editor_placeholder')
					uni.removeStorageSync('editor_readonly')
					// 标记有未保存的更改
					this.hasUnsaved = true
				}
			}
			// 检查裁剪页面是否有返回结果
			const cropTarget = uni.getStorageSync('crop_target') as string
			const cropResult = uni.getStorageSync('crop_result') as string
			if (cropTarget == 'agent_avatar' && cropResult != null && cropResult != '') {
				this.agentAvatar = cropResult
				updateAgentAvatar(this.agentId, cropResult)
				uni.removeStorageSync('crop_result')
				uni.removeStorageSync('crop_target')
				uni.removeStorageSync('crop_image_path')
			}
		},
		/** Android 系统返回键 / iOS 滑动返回 */
		onBackPress(): boolean {
			if (this.hasUnsaved == false) {
				return false
			}
			this.confirmLeave()
			return true
		},
		methods: {
			loadAgent() {
				const id = uni.getStorageSync('active_agent_id') as string
				if (id == null || id == '') {
					uni.showToast({ position: 'bottom', 
						title: '未选择智能体',
						icon: 'none'
					})
					return
				}
				this.agentId = id
				this.hasUnsaved = false
				this.allProviders = getAllProviders()
				this.allSkills = getSkills()
				this.availableTools = this.buildToolOptions()
				const agent = getAgentById(id)
				if (agent != null) {
					this.agentName = agent['name'] as string
					this.agentDesc = agent['desc'] as string
					const rawPrompt = agent['systemPrompt']
					this.agentSystemPrompt = rawPrompt != null ? (rawPrompt as string) : ''
					const rawAvatar = agent['avatar']
					this.agentAvatar = rawAvatar != null ? (rawAvatar as string) : ''
					const rawModel = agent['model']
					if (rawModel != null) {
						this.currentModel = rawModel as string
					}
					this.selectedSkillIds = filterExistingSkillIds(getAgentSkillIds(agent))
					this.selectedToolIds = getAgentEnabledToolIds(agent, true)
					this.loadGenerationSettings(agent)
				}
				this.initModelSelection()
			},

			clampNumber(value: number, min: number, max: number): number {
				if (value < min) return min
				if (value > max) return max
				return value
			},

			parseFloatSetting(value: string, fallback: number, min: number, max: number): number {
				const parsed = parseFloat(value)
				if (isNaN(parsed)) {
					return fallback
				}
				return this.clampNumber(parsed, min, max)
			},

			parseIntSetting(value: string, fallback: number, min: number, max: number): number {
				const parsed = parseInt(value)
				if (isNaN(parsed)) {
					return fallback
				}
				return this.clampNumber(parsed, min, max)
			},

			buildGenerationHint(settings: GenerationSettings): string {
				const iterationText = settings.maxIterations == 0 ? '不限制' : (settings.maxIterations + '')
				return '温度 ' + settings.temperature + ' · 输出 ' + settings.maxTokens + ' · 迭代 ' + iterationText + ' · ' + (settings.streamEnabled ? '流式' : '非流式')
			},

			loadGenerationSettings(agent: UTSJSONObject) {
				const global = getGlobalGenerationSettings()
				this.globalGenerationHint = this.buildGenerationHint(global)
				const rawTemperature = agent['temperature'] as number | null
				const rawMaxTokens = agent['maxTokens'] as number | null
				const rawMaxIterations = agent['maxIterations'] as number | null
				const rawStreamEnabled = agent['streamEnabled'] as boolean | null
				const hasOverride = rawTemperature != null || rawMaxTokens != null || rawMaxIterations != null || rawStreamEnabled != null
				this.useGlobalGeneration = hasOverride == false
				this.temperatureStr = (rawTemperature != null ? rawTemperature : global.temperature) + ''
				this.maxTokensStr = (rawMaxTokens != null ? rawMaxTokens : global.maxTokens) + ''
				this.maxIterationsStr = (rawMaxIterations != null ? rawMaxIterations : global.maxIterations) + ''
				this.streamEnabled = rawStreamEnabled != null ? rawStreamEnabled : global.streamEnabled

				// 截断/缓存 ID/隐藏思考/注入日期
				const rawThreshold = agent['truncateThreshold'] as number | null
				const rawDropCount = agent['truncateDropCount'] as number | null
				const rawCacheEnabled = agent['cacheEnabled'] as boolean | null
				const rawHideThinking = agent['hideThinking'] as boolean | null
				const rawInjectDatetime = agent['injectDatetime'] as boolean | null
				const rawMsgSeg = agent['msgSegmentation'] as boolean | null
				this.truncateThresholdStr = (rawThreshold != null ? rawThreshold : 40) + ''
				this.truncateDropCountStr = (rawDropCount != null ? rawDropCount : 20) + ''
				this.cacheEnabled = rawCacheEnabled == true
				this.hideThinking = rawHideThinking == true
				this.injectDatetime = rawInjectDatetime == true
				this.msgSegmentation = rawMsgSeg != null ? rawMsgSeg : true
			},

			/** 从 currentModel 解析出选中的提供商和模型 */
			initModelSelection() {
				const sep = '||'
				const idx = this.currentModel.indexOf(sep)
				if (idx >= 0) {
					this.selectedProviderId = this.currentModel.substring(0, idx)
					this.selectedModelId = this.currentModel.substring(idx + sep.length)
				} else {
					this.selectedModelId = this.currentModel
					// 尝试从已启用的提供商中找匹配
					const enabled = this.enabledProviders
					if (enabled.length > 0) {
						this.selectedProviderId = enabled[0]['id'] as string
					}
				}
			},

			toggleModelPanel() {
				this.showModelPanel = !this.showModelPanel
				if (this.showModelPanel) {
					this.initModelSelection()
				}
			},

			selectProvider(id: string) {
				this.selectedProviderId = id
				this.selectedModelId = ''
				this.hasUnsaved = true
			},

			selectModel(id: string) {
				this.selectedModelId = id
				this.currentModel = this.selectedProviderId + '||' + id
				this.hasUnsaved = true
				// 选择后自动收起面板
				this.showModelPanel = false
			},

			getSkillName(skill: UTSJSONObject): string {
				return readSkillName(skill)
			},

			getSkillDesc(skill: UTSJSONObject): string {
				return readSkillDescription(skill)
			},

			getSkillMeta(skill: UTSJSONObject): string {
				return getSkillDocumentCount(skill) + ' 文档 · ' + (readSkillEnabled(skill) ? '可用' : '已停用')
			},

			isAgentSkillSelected(skill: UTSJSONObject): boolean {
				return skillIdListContains(this.selectedSkillIds, readSkillId(skill))
			},

			toggleAgentSkill(skill: UTSJSONObject) {
				const skillId = readSkillId(skill)
				if (skillId == '') {
					return
				}
				const next: string[] = []
				let removed = false
				for (let i = 0; i < this.selectedSkillIds.length; i++) {
					if (this.selectedSkillIds[i] == skillId) {
						removed = true
					} else {
						next.push(this.selectedSkillIds[i])
					}
				}
				if (removed == false) {
					next.push(skillId)
				}
				this.selectedSkillIds = next
				this.hasUnsaved = true
			},

			buildToolOption(id: string, name: string, desc: string): UTSJSONObject {
				return {
					id: id,
					name: name,
					desc: desc,
				} as UTSJSONObject
			},

			buildToolOptions(): UTSJSONObject[] {
				const list: UTSJSONObject[] = []
				list.push(this.buildToolOption(AGENT_TOOL_WORKSPACE_FILE, '工作区文件', '读写当前私聊或群聊会话工作区文件'))
				list.push(this.buildToolOption(AGENT_TOOL_MEMORY_SEARCH, '记忆搜索', '查询当前智能体可见记忆和历史记录'))
				list.push(this.buildToolOption(AGENT_TOOL_MEMORY_BUFFER_WRITE, '短记忆缓存', '写入 64 字以内的临时记忆缓存'))
				list.push(this.buildToolOption(AGENT_TOOL_WEB_SEARCH, '网络搜索', '联网搜索实时事实、资料和网页信息'))
				list.push(this.buildToolOption(AGENT_TOOL_MEMORY_CORE_LIST, '长期记忆列表', '记忆整理时读取长期记忆清单'))
				list.push(this.buildToolOption(AGENT_TOOL_MEMORY_CORE_SAVE, '长期记忆保存', '记忆整理时写入重要长期记忆'))
				list.push(this.buildToolOption(AGENT_TOOL_MEMORY_CORE_FORGET, '长期记忆遗忘', '记忆整理时归档重复或过期记忆'))
				return list
			},

			readToolField(tool: UTSJSONObject, key: string): string {
				const raw = tool[key] as string | null
				return raw != null ? raw : ''
			},

			getToolId(tool: UTSJSONObject): string {
				return this.readToolField(tool, 'id')
			},

			getToolName(tool: UTSJSONObject): string {
				return this.readToolField(tool, 'name')
			},

			getToolDesc(tool: UTSJSONObject): string {
				return this.readToolField(tool, 'desc')
			},

			getToolMeta(tool: UTSJSONObject): string {
				return this.isAgentToolSelected(tool) ? '已启用' : '未启用'
			},

			isAgentToolSelected(tool: UTSJSONObject): boolean {
				return agentToolIdListContains(this.selectedToolIds, this.getToolId(tool))
			},

			toggleAgentTool(tool: UTSJSONObject) {
				const toolId = this.getToolId(tool)
				if (toolId == '') {
					return
				}
				const next: string[] = []
				let removed = false
				for (let i = 0; i < this.selectedToolIds.length; i++) {
					if (this.selectedToolIds[i] == toolId) {
						removed = true
					} else {
						next.push(this.selectedToolIds[i])
					}
				}
				if (removed == false) {
					next.push(toolId)
				}
				this.selectedToolIds = next
				this.hasUnsaved = true
			},

			/** 上传/更换智能体头像 */
			pickAvatar() {
				uni.chooseImage({
					count: 1,
					sourceType: ['album', 'camera'],
					sizeType: ['compressed'],
					success: (res: any) => {
						const raw = JSON.stringify(res)
						if (raw == null || raw == '') { return }
						const parsed = JSON.parse(raw) as UTSJSONObject
						const paths = parsed['tempFilePaths'] as string[]
						if (paths != null && paths.length > 0) {
							uni.removeStorageSync('crop_result')
							uni.setStorageSync('crop_target', 'agent_avatar')
							uni.setStorageSync('crop_image_path', paths[0])
							uni.navigateTo({
								url: '/pages/common/crop/crop'
							})
						}
					}
				})
			},

			/** 打开全屏编辑器编辑智能体描述 */
			openDescEditor() {
				uni.removeStorageSync('editor_draft')
				uni.removeStorageSync('editor_result')
				uni.removeStorageSync('editor_result_ready')
				uni.removeStorageSync('editor_file_path')
				uni.removeStorageSync('editor_saved')
				uni.removeStorageSync('editor_saved_path')
				uni.setStorageSync('editor_mode', 'text')
				uni.setStorageSync('editor_content', this.agentDesc)
				uni.setStorageSync('editor_title', '编辑描述')
				uni.setStorageSync('editor_target', 'desc')
				uni.setStorageSync('editor_placeholder', '写一下这个智能体的人设、用途或备注')
				uni.navigateTo({
					url: '/pages/common/editor/editor'
				})
			},

			/** 打开全屏编辑器编辑系统提示词 */
			openSystemPromptEditor() {
				uni.removeStorageSync('editor_draft')
				uni.removeStorageSync('editor_result')
				uni.removeStorageSync('editor_result_ready')
				uni.removeStorageSync('editor_file_path')
				uni.removeStorageSync('editor_saved')
				uni.removeStorageSync('editor_saved_path')
				uni.setStorageSync('editor_mode', 'text')
				uni.setStorageSync('editor_content', this.agentSystemPrompt)
				uni.setStorageSync('editor_title', '编辑提示词')
				uni.setStorageSync('editor_target', 'systemPrompt')
				uni.setStorageSync('editor_placeholder', '定义说话风格、能力边界和输出习惯')
				uni.navigateTo({
					url: '/pages/common/editor/editor'
				})
			},

			loadModel() {
				const model = uni.getStorageSync('settings_model') as string
				if (model != null && model != '') {
					this.currentModel = model
				}
			},

			onGenerationInput(_event: any) {
				this.hasUnsaved = true
			},

			onGenerationSwitch(_value: any) {
				this.hasUnsaved = true
			},

			saveSettings() {
				const name = this.agentName.trim()
				const desc = this.agentDesc.trim()
				if (name == '') {
					uni.showToast({ position: 'bottom', 
						title: '名称不能为空',
						icon: 'none'
					})
					return
				}
				updateAgent(this.agentId, name, desc, '', this.agentSystemPrompt)
				updateAgentModel(this.agentId, this.currentModel)
				const globalGeneration = getGlobalGenerationSettings()
				let temperature: number | null = null
				let maxTokens: number | null = null
				let maxIterations: number | null = null
				let streamEnabled: boolean | null = null
				if (this.useGlobalGeneration == false) {
					const parsedTemperature = this.parseFloatSetting(this.temperatureStr, globalGeneration.temperature, 0, 2)
					const parsedMaxTokens = this.parseIntSetting(this.maxTokensStr, globalGeneration.maxTokens, 256, 65536)
					const parsedMaxIterations = this.parseIntSetting(this.maxIterationsStr, globalGeneration.maxIterations, 0, 100)
					temperature = parsedTemperature
					maxTokens = parsedMaxTokens
					maxIterations = parsedMaxIterations
					streamEnabled = this.streamEnabled
					this.temperatureStr = parsedTemperature + ''
					this.maxTokensStr = parsedMaxTokens + ''
					this.maxIterationsStr = parsedMaxIterations + ''
				}
				updateAgentGenerationSettings(this.agentId, temperature, maxTokens, maxIterations, streamEnabled)
				// 保存截断/缓存 ID/隐藏思考
				const threshold = parseFloat(this.truncateThresholdStr)
				const dropScore = parseFloat(this.truncateDropCountStr)
				updateAgentTruncation(this.agentId, isNaN(threshold) ? 40 : threshold, isNaN(dropScore) ? 20 : dropScore)
				updateAgentCache(this.agentId, this.cacheEnabled)
				updateAgentHideThinking(this.agentId, this.hideThinking)
				updateAgentInjectDatetime(this.agentId, this.injectDatetime)
				updateAgentMsgSegmentation(this.agentId, this.msgSegmentation)
				updateAgentSkills(this.agentId, filterExistingSkillIds(this.selectedSkillIds))
				updateAgentTools(this.agentId, this.selectedToolIds)
				// 同步更新所有历史对话的 system_prompt
				updateSystemPromptForAgent(this.agentId, this.agentSystemPrompt)
				this.hasUnsaved = false
				uni.showToast({ position: 'bottom', 
					title: '已保存',
					icon: 'success'
				})
				uni.navigateBack()
			},

			confirmDelete() {
				uni.showModal({
					title: '删除智能体',
					content: '确定要删除「' + this.agentName + '」吗？此操作无法撤销。',
					success: (res) => {
						if (res.confirm == true) {
							deleteAgent(this.agentId)
							// 如果删除的是当前选中的智能体，清除 active_agent_id
							const activeId = uni.getStorageSync('active_agent_id') as string
							if (activeId == this.agentId) {
								uni.removeStorageSync('active_agent_id')
							}
							uni.showToast({ position: 'bottom', 
								title: '已删除',
								icon: 'success'
							})
							// 跳转到智能体列表页
							uni.redirectTo({
								url: '/pages/agents/agents'
							})
						}
					}
				})
			},

			/** 弹出确认离开对话框，供 goBack / onBackPress 共用 */
			confirmLeave() {
				if (this.hasUnsaved == false) {
					uni.navigateBack()
					return
				}
				if (this.isConfirmingLeave == true) {
					return
				}
				this.isConfirmingLeave = true
				uni.showModal({
					title: '未保存的更改',
					content: '有未保存的更改，是否保存？',
					cancelText: '不保存',
					confirmText: '保存',
					success: (res) => {
						this.isConfirmingLeave = false
						if (res.confirm == true) {
							this.saveSettings()
						} else {
							this.hasUnsaved = false
							uni.navigateBack()
						}
					}
				})
			},

			/** NavBar 返回按钮事件 */
			goBack() {
				this.confirmLeave()
			},
		}
	}
</script>

<style>
	.container {
		flex: 1;
		padding: 32rpx;
	}

	/* 卡片 */
	.card {
		background-color: #FFFFFF;
		border-radius: 20rpx;
		padding: 32rpx;
		margin-bottom: 24rpx;
	}

	/* 头部：头像 + 名称 */
	.profile-header {
		align-items: center;
		padding: 40rpx 0 16rpx;
	}

	.agent-avatar {
		width: 200rpx;
		height: 200rpx;
		border-radius: 40rpx;
	}

	.agent-avatar-placeholder {
		background-color: #FB8FAB;
		justify-content: center;
		align-items: center;
	}

	.agent-avatar-text {
		font-size: 80rpx;
		color: #FFFFFF;
		font-weight: bold;
	}

	.avatar-hint {
		font-size: 24rpx;
		color: var(--rice-text-color-3);
		margin-top: 16rpx;
	}

	.flat-input {
		background-color: var(--rice-background);
		border-radius: 14rpx;
		padding: 24rpx;
		font-size: 28rpx;
		color: var(--rice-text-color);
	}

	.card-header {
		flex-direction: row;
		align-items: center;
		margin-bottom: 16rpx;
	}

	.card-label {
		font-size: 28rpx;
		font-weight: bold;
		color: var(--rice-text-color);
	}

	/* 描述区域 - 跳转全屏编辑 */
	.desc-wrap {
		position: relative;
		background-color: var(--rice-background);
		border-radius: 14rpx;
		padding: 16rpx 20rpx;
		min-height: 80rpx;
	}

	.desc-preview {
		font-size: 28rpx;
		color: var(--rice-text-color);
		line-height: 40rpx;
	}

	.prompt-scroll {
		max-height: 240rpx;
		overflow: hidden;
	}

	.desc-edit-btn {
		position: absolute;
		top: 8rpx;
		right: 8rpx;
		padding: 4rpx 12rpx;
		border-radius: 10rpx;
		background-color: var(--rice-primary-color-1);
		justify-content: center;
		align-items: center;
	}

	.desc-edit-text {
		font-size: 22rpx;
		color: var(--rice-primary-color);
		font-weight: bold;
	}

	.input-placeholder {
		color: var(--rice-text-color-3);
	}

	/* 模型卡片 - 可点击跳转 */
	.model-card {
		/* 点击触发 goModelSettings */
	}

	.model-row {
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
	}

	.model-right {
		flex-direction: row;
		align-items: center;
	}

	.model-value {
		font-size: 28rpx;
		color: var(--rice-primary-color-7);
		font-weight: bold;
	}

	.model-arrow {
		font-size: 32rpx;
		color: var(--rice-text-color-3);
		padding-left: 8rpx;
	}

	/* 展开模型面板 */
	.model-panel {
		margin-top: 20rpx;
		padding-top: 20rpx;
		border-top-width: 0.10rpx;
		border-top-style: solid;
		border-top-color: #F3F4F6;
	}

	.panel-label {
		font-size: 24rpx;
		color: #6B7280;
		margin-bottom: 12rpx;
	}

	.panel-empty {
		padding: 20rpx 0;
	}

	.panel-empty-text {
		font-size: 24rpx;
		color: #9CA3AF;
	}

	.skill-section-desc {
		font-size: 24rpx;
		color: #6B7280;
		line-height: 36rpx;
		margin-bottom: 16rpx;
	}

	.skill-grid {
		flex-direction: row;
		flex-wrap: wrap;
	}

	.skill-card {
		width: 300rpx;
		background-color: var(--rice-background);
		border-radius: 16rpx;
		padding: 20rpx;
		margin-right: 14rpx;
		margin-bottom: 14rpx;
		border-width: 2rpx;
		border-style: solid;
		border-color: #F3F4F6;
	}

	.tool-list {
		flex-direction: column;
	}

	.tool-card {
		width: auto;
		margin-right: 0;
		margin-bottom: 14rpx;
	}

	.skill-card-active {
		background-color: #FDE8EF;
		border-color: #FB8FAB;
	}

	.skill-card-top {
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 8rpx;
	}

	.skill-card-name {
		font-size: 26rpx;
		font-weight: bold;
		color: #111827;
		flex: 1;
	}

	.skill-card-check {
		font-size: 28rpx;
		font-weight: bold;
		color: var(--rice-primary-color);
		margin-left: 10rpx;
	}

	.skill-card-desc {
		font-size: 22rpx;
		color: #6B7280;
		line-height: 32rpx;
	}

	.skill-card-meta {
		font-size: 20rpx;
		color: #9CA3AF;
		margin-top: 10rpx;
	}

	.chip-scroll {
		flex-direction: row;
	}

	.chip-row {
		flex-direction: row;
	}

	.chip {
		background-color: #F3F4F6;
		border-radius: 12rpx;
		padding: 12rpx 24rpx;
		margin: 4rpx;
		border-width: 2rpx;
		border-style: solid;
		border-color: #E5E7EB;
	}

	.chip-active {
		background-color: #FDE8EF;
		border-color: #FB8FAB;
	}

	.chip-text {
		font-size: 24rpx;
		color: #374151;
		white-space: nowrap;
	}

	.model-grid {
		flex-direction: row;
		flex-wrap: wrap;
	}

	.setting-divider {
		height: 2rpx;
		background-color: #F3F4F6;
		margin: 28rpx 0 20rpx;
	}

	.setting-row {
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		background-color: var(--rice-background);
		border-radius: 14rpx;
		padding: 20rpx;
	}

	.setting-text {
		flex: 1;
		padding-right: 20rpx;
	}

	.setting-title {
		font-size: 28rpx;
		color: var(--rice-text-color);
		font-weight: bold;
		margin-bottom: 6rpx;
	}

	.setting-desc {
		font-size: 22rpx;
		color: var(--rice-text-color-3);
		line-height: 32rpx;
	}

	.context-tip {
		background-color: rgba(124, 58, 237, 0.07);
		border-radius: 14rpx;
		padding: 16rpx 18rpx;
		margin-bottom: 16rpx;
	}

	.context-tip-text {
		font-size: 22rpx;
		color: var(--rice-text-color-2);
		line-height: 34rpx;
	}

	.generation-panel {
		margin-top: 18rpx;
	}

	.param-row {
		flex-direction: row;
		margin-bottom: 14rpx;
	}

	.param-item {
		flex: 1;
		background-color: var(--rice-background);
		border-radius: 14rpx;
		padding: 18rpx;
		margin-right: 12rpx;
	}

	.param-switch {
		flex: 1;
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		background-color: var(--rice-background);
		border-radius: 14rpx;
		padding: 18rpx;
		margin-right: 12rpx;
	}

	.param-label {
		font-size: 24rpx;
		color: #6B7280;
		margin-bottom: 10rpx;
	}

	.param-tip {
		font-size: 20rpx;
		color: #9CA3AF;
	}

	.param-input {
		background-color: #FFFFFF;
		border-radius: 10rpx;
		padding: 16rpx;
		font-size: 26rpx;
		color: #111827;
	}

	.short-input {
		width: 120rpx;
		flex-shrink: 0;
	}

	.model-pill {
		background-color: #F3F4F6;
		border-radius: 10rpx;
		padding: 12rpx 20rpx;
		margin: 4rpx;
		border-width: 2rpx;
		border-style: solid;
		border-color: #E5E7EB;
	}

	.pill-active {
		background-color: #FDE8EF;
		border-color: #FB8FAB;
	}

	.pill-text {
		font-size: 22rpx;
		color: #6B7280;
	}

	.pill-text-active {
		color: #DB2777;
		font-weight: bold;
	}

	/* 保存按钮 */
	.save-wrap {
		padding: 8rpx 0;
	}

	.save-btn {
		background-color: var(--rice-primary-color);
		border-radius: 16rpx;
		padding: 28rpx;
		align-items: center;
		justify-content: center;
	}

	.save-btn-text {
		font-size: 30rpx;
		font-weight: bold;
		color: #FFFFFF;
	}

	/* 删除按钮 */
	.delete-wrap {
		padding: 16rpx 0 60rpx 0;
	}

	.delete-btn {
		background-color: #FFFFFF;
		border-radius: 16rpx;
		padding: 28rpx;
		align-items: center;
		justify-content: center;
		border-width: 2rpx;
		border-style: solid;
		border-color: #FCA5A5;
	}

	.delete-btn-text {
		font-size: 30rpx;
		font-weight: bold;
		color: #EF4444;
	}
</style>
