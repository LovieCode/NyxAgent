<template>
	<view class="page-shell rice-theme-light">
		<NavBar title="群聊">
			<template #right>
				<view class="add-btn" @click="createWritingGroup">
					<oui-icon-unix name="plus" size="22px" color="#FFFFFF" />
				</view>
			</template>
		</NavBar>

		<scroll-view class="group-scroll" :scroll-y="true">
			<view class="hero-card" @click="createWritingGroup">
				<view class="hero-icon">
					<oui-icon-unix name="edit" size="28px" color="#FFFFFF" />
				</view>
				<view class="hero-info">
					<text class="hero-title">故事 / 写作交流群</text>
					<text class="hero-desc">默认模板：多个群成员互相接话，每个群都有自己的隐藏调度负责控场。</text>
				</view>
				<text class="hero-action">创建</text>
			</view>

			<view class="list-content">
				<view v-for="(group, index) in groupList" :key="group.id" class="group-item" @click="openGroup(group)">
					<view class="group-avatar" :class="'avatar-' + ((index % 5) + 1)">
						<image v-if="group.avatar != ''" :src="group.avatar" class="group-avatar-image" mode="aspectFill" />
						<oui-icon-unix v-else name="robot" size="24px" color="#FFFFFF" />
					</view>
					<view class="group-info">
						<view class="group-top">
							<text class="group-name">{{group.name}}</text>
							<text class="group-time">{{formatTime(group.updatedAt)}}</text>
						</view>
						<text class="group-desc">{{getGroupSummary(group)}}</text>
					</view>
					<oui-icon-unix name="right" size="14px" color="var(--rice-text-color-3)" />
				</view>
				<view v-if="groupList.length == 0" class="empty-state">
					<text class="empty-title">还没有群聊</text>
					<text class="empty-desc">点上面的模板开一个故事工坊。</text>
				</view>
			</view>
		</scroll-view>

		<TabBar current="pages/group-chats/group-chats" />
	</view>
</template>

<script lang="uts">
	import {
		GroupChat,
		createDefaultWritingGroupChat,
		displaySessionTitle,
		ensureGroupActiveSession,
		getActiveGroupChatId,
		getActiveGroupSessionId,
		getActiveGroupMembers,
		getGroupChats,
		restoreActiveGroupRouteState,
		setActiveGroupSession,
	} from '@/utils/group-chat-service.uts'

	export default {
		data() {
			return {
				groupList: [] as GroupChat[],
			}
		},
		onLoad() {
			this.loadGroups()
		},
		onShow() {
			this.loadGroups()
		},
		methods: {
			loadGroups(): void {
				this.groupList = getGroupChats()
			},
			createWritingGroup(): void {
				const group = createDefaultWritingGroupChat()
				this.loadGroups()
				this.openGroup(group)
			},
			openGroup(group: GroupChat): void {
				let previousGroupId = ''
				let previousSessionId = ''
				try {
					previousGroupId = getActiveGroupChatId()
					previousSessionId = getActiveGroupSessionId()
					const session = ensureGroupActiveSession(group)
					if (setActiveGroupSession(group.id, session.id) == false) {
						uni.showToast({ position: 'bottom', title: '群聊状态保存失败，请重试', icon: 'none' })
						return
					}
					uni.navigateTo({
						url: '/pages/group-chat/group-chat',
						fail: (_err: any) => {
							if (restoreActiveGroupRouteState(previousGroupId, previousSessionId) == false) {
								uni.showToast({ position: 'bottom', title: '群聊状态恢复失败，请重试', icon: 'none' })
								return
							}
							uni.showToast({ position: 'bottom', title: '无法打开群聊，请重试', icon: 'none' })
						}
					})
				} catch (e: any) {
					uni.showToast({ position: 'bottom', title: '群聊准备失败，请重试', icon: 'none' })
				}
			},
			getGroupSummary(group: GroupChat): string {
				const members = getActiveGroupMembers(group.id)
				const session = ensureGroupActiveSession(group)
				return members.length.toString() + ' 个成员 · 当前会话：' + displaySessionTitle(session)
			},
			formatTime(timestamp: number): string {
				if (timestamp <= 0) { return '' }
				const d = new Date(timestamp)
				const month = (d.getMonth() + 1).toString()
				const day = d.getDate().toString()
				const hour = d.getHours() < 10 ? '0' + d.getHours().toString() : d.getHours().toString()
				const minute = d.getMinutes() < 10 ? '0' + d.getMinutes().toString() : d.getMinutes().toString()
				return month + '/' + day + ' ' + hour + ':' + minute
			}
		}
	}
</script>

<style>
	.add-btn { width: 40px; height: 40px; justify-content: center; align-items: center; }
	.group-scroll { flex: 1; }
	.hero-card { flex-direction: row; align-items: center; margin: 10px 12px 4px; padding: 14px; border-radius: 18px; background-color: var(--rice-primary-color); }
	.hero-icon { width: 52px; height: 52px; border-radius: 16px; background-color: rgba(255,255,255,0.18); justify-content: center; align-items: center; margin-right: 12px; }
	.hero-info { flex: 1; flex-direction: column; }
	.hero-title { font-size: 17px; color: #FFFFFF; font-weight: bold; }
	.hero-desc { font-size: 12px; color: rgba(255,255,255,0.78); margin-top: 4px; lines: 2; }
	.hero-action { color: #FFFFFF; font-size: 13px; font-weight: bold; margin-left: 9px; }
	.list-content { flex-direction: column; background-color: var(--rice-background-2); margin: 8px 12px 12px; border-radius: 18px; overflow: hidden; }
	.group-item { flex-direction: row; align-items: center; padding: 14px 16px; border-bottom-width: 1px; border-bottom-color: var(--rice-border-color); border-bottom-style: solid; }
	.group-avatar { width: 48px; height: 48px; border-radius: 14px; justify-content: center; align-items: center; margin-right: 14px; overflow: hidden; }
	.group-avatar-image { width: 48px; height: 48px; border-radius: 14px; }
	.avatar-1 { background-color: var(--rice-primary-color); }
	.avatar-2 { background-color: #60A5FA; }
	.avatar-3 { background-color: #34D399; }
	.avatar-4 { background-color: #FBBF24; }
	.avatar-5 { background-color: #A78BFA; }
	.group-info { flex: 1; flex-direction: column; }
	.group-top { flex-direction: row; align-items: center; justify-content: space-between; margin-bottom: 4px; }
	.group-name { font-size: 16px; font-weight: bold; color: var(--rice-text-color); }
	.group-time { font-size: 11px; color: var(--rice-text-color-3); }
	.group-desc { font-size: 13px; color: var(--rice-text-color-3); lines: 1; text-overflow: ellipsis; }
	.group-arrow { font-size: 22px; color: var(--rice-text-color-3); margin-left: 8px; }
	.empty-state { padding: 40px 16px; align-items: center; justify-content: center; flex-direction: column; }
	.empty-title { font-size: 15px; font-weight: bold; color: var(--rice-text-color); }
	.empty-desc { margin-top: 4px; font-size: 12px; color: var(--rice-text-color-3); }
</style>
