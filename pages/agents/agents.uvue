		font-size: 22px;
		font-weight: bold;
		color: #111827;
	}

	.header-actions {
		flex-direction: row;
		align-items: center;
	}

	.add-btn {
		width: 36px;
		height: 36px;
		justify-content: center;
		align-items: center;
	}

	/* 列表滚动区 */
	.agent-scroll {
		flex: 1;
	}

	.list-content {
		flex-direction: column;
		background-color: #FFFFFF;
		margin-top: 8px;
		border-radius: 18px;
		margin-left: 12px;
		margin-right: 12px;
	}

	/* 单个智能体行 */
	.agent-item {
		flex-direction: row;
		align-items: center;
		padding: 14px 16px;
		border-bottom-width: 0.5px;
		border-bottom-color: #F0F0F2;
		border-bottom-style: solid;
	}

	/* 左侧头像 - 纯色背景 */
	.agent-avatar {
		width: 48px;
		height: 48px;
		border-radius: 14px;
		justify-content: center;
		align-items: center;
		margin-right: 14px;
	}

	.avatar-1 { background-color: #FB8FAB; }
	.avatar-2 { background-color: #60A5FA; }
	.avatar-3 { background-color: #34D399; }
	.avatar-4 { background-color: #FBBF24; }
	.avatar-5 { background-color: #A78BFA; }

	/* 中间信息 */
	.agent-info {
		flex: 1;
		flex-direction: column;
	}

	.agent-top {
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 4px;
	}

	.agent-name {
		font-size: 16px;
		font-weight: bold;
		color: #111827;
	}

	.agent-time {
		font-size: 12px;
		color: #B0B3BF;
		margin-left: 8px;
	}

	.agent-desc {
		font-size: 13px;
