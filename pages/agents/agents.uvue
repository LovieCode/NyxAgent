		border-radius: 28rpx;
		margin-right: 28rpx;
	}

	.avatar-1 { background-color: var(--rice-primary-color); }
	.avatar-2 { background-color: #60A5FA; }
	.avatar-3 { background-color: #34D399; }
	.avatar-4 { background-color: #FBBF24; }
	.avatar-5 { background-color: #A78BFA; }

	/* 中间信息 */
	.agent-info {
		flex: 1;
		flex-direction: column;
	}

	.agent-top {
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 8rpx;
	}

	.agent-name {
		font-size: 32rpx;
		font-weight: bold;
		color: var(--rice-text-color);
