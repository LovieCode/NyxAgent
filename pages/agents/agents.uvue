		border-bottom-color: var(--rice-border-color);
		border-bottom-style: solid;
	}

	/* 左侧头像 - 纯色背景 */
	.agent-avatar {
		width: 96rpx;
		height: 96rpx;
		border-radius: 28rpx;
		justify-content: center;
		align-items: center;
		margin-right: 28rpx;
	}

	/* 自定义头像图片 */
	.agent-avatar-img {
