<template>
	<view class="page-shell" ref="shellRef">
		<!-- 顶部标题栏 -->
		<view class="header-wrap">
			<view :style="{ height: statusBarHeight + 'px' }"></view>
			<view class="header">
				<text class="header-title">智能体</text>
				<view class="header-actions">
					<view class="add-btn" @click="createAgent">
						<oui-icon-unix name="plus" size="22px" color="#FB8FAB" />
					</view>
				</view>
			</view>
		</view>

		<!-- 智能体列表 -->
		<scroll-view class="agent-scroll" :scroll-y="true">
			<share-element share-key="agent-list">
				<view class="list-content">
					<view
						v-for="(agent, index) in agentList"
						:key="index"
						class="agent-item"
						@click="openAgent(agent)"
					>
						<!-- 左侧头像 -->
						<view :class="'agent-avatar avatar-' + (index + 1)">
							<oui-icon-unix :name="agent['icon']" size="24px" color="#FFFFFF" />
						</view>
						<!-- 中间文字 -->
						<view class="agent-info">
							<view class="agent-top">
								<text class="agent-name">{{ agent['name'] }}</text>
								<text class="agent-time">{{ agent['time'] }}</text>
							</view>
							<text class="agent-desc">{{ agent['desc'] }}</text>
						</view>
						<!-- 右侧箭头 -->
						<text class="agent-arrow">›</text>
					</view>
				</view>
			</share-element>
		</scroll-view>

		<TabBar current="pages/agents/agents" />
	</view>
</template>

<script lang="uts">
	export default {
		data() {
			return {
				statusBarHeight: 0,
				agentList: [] as UTSJSONObject[],
			}
		},
		onLoad() {
			const sysInfo = uni.getSystemInfoSync()
			this.statusBarHeight = sysInfo.statusBarHeight
			this.loadAgents()
		},
		onShow() {
			this.loadAgents()
		},
		methods: {
			loadAgents() {
				this.agentList = [
					{
						id: 'ai-assistant',
						icon: 'robot',
						name: 'AI 助手',
						desc: '通用智能助手，回答问题、提供建议',
						time: '刚刚',
					} as UTSJSONObject,
					{
						id: 'coding-helper',
						icon: 'code',
						name: '编程助手',
						desc: '帮你写代码、调试、解释技术问题',
						time: '昨天',
					} as UTSJSONObject,
					{
						id: 'writing-helper',
						icon: 'edit',
						name: '写作助手',
						desc: '文章润色、翻译、创意写作',
						time: '3天前',
					} as UTSJSONObject,
					{
						id: 'translate',
						icon: 'translate',
						name: '翻译助手',
						desc: '多语言翻译、本地化支持',
						time: '5天前',
					} as UTSJSONObject,
					{
						id: 'idea-lab',
						icon: 'bulb',
						name: '创意工坊',
						desc: '头脑风暴、方案策划、创意发散',
						time: '1周前',
					} as UTSJSONObject,
				]
			},

			openAgent(agent: UTSJSONObject) {
				// 选中智能体后跳转到对话页（带滑动动画）
				uni.setStorageSync('active_agent_id', agent['id'] as string)
				uni.navigateTo({
					url: '/pages/index/index'
				})
			},

			goSettings() {
				uni.redirectTo({
					url: '/pages/settings/settings'
				})
			},

			createAgent() {
				// TODO: 弹出创建智能体对话框
				uni.showToast({
					title: '创建智能体（待实现）',
					icon: 'none'
				})
			},
		}
	}
</script>

<style>
	/* 顶部标题栏 */
	.header-wrap {
		background-color: #FFFFFF;
	}

	.header {
		flex-direction: row;
