<template>
	<view class="page-shell rice-theme-light" ref="shellRef">
		<NavBar title="聊天">
			<template #right>
				<view class="add-btn" @click.stop="toggleCreateMenu">
					<oui-icon-unix name="plus" size="44rpx" color="#FFFFFF" />
				</view>
			</template>
		</NavBar>

		<view v-if="showCreateMenu" class="create-menu-mask" @click="closeCreateMenu"></view>
		<view v-if="showCreateMenu" class="create-menu-card">
			<view class="create-menu-item" @click="createAgentFromMenu">
				<view class="create-menu-icon">
					<oui-icon-unix name="robot" size="36rpx" color="var(--rice-primary-color)" />
				</view>
				<view class="create-menu-info">
					<text class="create-menu-title">新建私聊</text>
					<text class="create-menu-desc">创建一个 AI 联系人</text>
				</view>
			</view>
			<view class="create-menu-line"></view>
			<view class="create-menu-item" @click="createWritingGroup">
				<view class="create-menu-icon">
					<oui-icon-unix name="edit" size="36rpx" color="var(--rice-primary-color)" />
				</view>
				<view class="create-menu-info">
					<text class="create-menu-title">新建群聊</text>
					<text class="create-menu-desc">故事 / 写作交流模板</text>
				</view>
			</view>
		</view>

		<!-- 会话列表：私聊 + 群聊混排 -->
		<scroll-view class="agent-scroll" :scroll-y="true">
			<share-element share-key="agent-list">
				<view class="list-content">
					<view
						v-for="(item, index) in chatList"
						:key="getChatKey(item)"
						class="agent-item"
						@click="openChatItem(item)"
					>
						<!-- 左侧头像：私聊可显示自定义头像，群聊使用模板图标 -->
						<image v-if="getChatAvatar(item) != ''" :src="getChatAvatar(item)" class="agent-avatar-img" mode="aspectFill" />
						<view v-else :class="'agent-avatar avatar-' + ((index % 5) + 1)">
							<oui-icon-unix :name="getChatIcon(item)" size="48rpx" color="var(--rice-background-2)" />
						</view>
						<!-- 中间文字 -->
						<view class="agent-info">
							<view class="agent-top">
								<view class="agent-title-row">
									<text class="agent-name">{{ getChatName(item) }}</text>
									<text v-if="isGroupItem(item)" class="chat-type-badge">群聊</text>
								</view>
								<text class="agent-time">{{ formatChatTime(item) }}</text>
							</view>
							<text class="agent-desc">{{ getChatDesc(item) }}</text>
						</view>
						<!-- 右侧箭头 -->
						<oui-icon-unix name="right" size="28rpx" color="var(--rice-text-color-3)" />
					</view>
					<view v-if="chatList.length == 0" class="empty-state">
						<text class="empty-title">还没有会话</text>
						<text class="empty-desc">点右上角 +，新建私聊或群聊。</text>
					</view>
				</view>
			</share-element>
		</scroll-view>

		<!-- 创建私聊弹窗 -->
		<view v-if="showCreateDialog" class="dialog-overlay" @click="closeCreateDialog">
			<view class="dialog-card" @click.stop>
				<view class="dialog-handle"></view>
				<view class="dialog-header">
					<view class="dialog-title-wrap">
						<text class="dialog-title">创建私聊</text>
						<text class="dialog-subtitle">设置头像、昵称和说话方式</text>
					</view>
					<view class="dialog-close" @click="closeCreateDialog">
						<oui-icon-unix name="close" size="40rpx" color="var(--rice-text-color-3)" />
					</view>
				</view>

				<scroll-view class="dialog-scroll" :scroll-y="true">
					<view class="create-preview-card">
						<image v-if="createAvatar() != ''" :src="createAvatar()" class="preview-avatar-img" mode="aspectFill" />
						<view v-else class="preview-avatar">
							<oui-icon-unix :name="createIcon()" size="60rpx" color="#FFFFFF" />
						</view>
						<view class="preview-info">
							<text class="preview-name">{{createPreviewName}}</text>
							<text class="preview-desc">{{createPreviewDesc}}</text>
						</view>
					</view>

					<view class="dialog-section">
						<view class="section-title-row">
							<text class="dialog-label dialog-label-inline">快速模板</text>
							<text class="dialog-label-sub">默认聊天风格</text>
						</view>
						<scroll-view class="template-scroll" :scroll-x="true" :show-scrollbar="false">
							<view class="template-row">
								<view
									v-for="(tpl, ti) in templateList"
									:key="ti"
									class="template-card"
									:class="createTemplateKey() == templateKey(tpl) ? 'template-card-active' : ''"
									@click="selectCreateTemplate(tpl)"
								>
									<view class="template-card-icon" :class="createTemplateKey() == templateKey(tpl) ? 'template-card-icon-active' : ''">
										<oui-icon-unix :name="templateIcon(tpl)" size="40rpx" :color="createTemplateKey() == templateKey(tpl) ? '#FFFFFF' : 'var(--rice-primary-color)'" />
									</view>
									<view class="template-card-info">
										<text class="template-card-name">{{templateName(tpl)}}</text>
										<text class="template-card-desc">{{templateDesc(tpl)}}</text>
									</view>
								</view>
							</view>
						</scroll-view>
					</view>

					<view class="dialog-section">
						<text class="dialog-label">基础信息</text>
						<input class="dialog-input" v-model="createData.name" placeholder="昵称，比如：小夜 / 零 / 千夏" placeholder-style="color:var(--rice-text-color-3)" />
						<input class="dialog-input dialog-input-gap" v-model="createData.desc" placeholder="一句话备注它擅长什么" placeholder-style="color:var(--rice-text-color-3)" />
					</view>

					<view class="dialog-section">
						<view class="section-title-row">
							<text class="dialog-label dialog-label-inline">头像与图标</text>
							<text class="section-action" @click="pickCreateAvatar">选择图片</text>
						</view>
						<view class="icon-grid">
							<view
								v-for="(icon, i) in iconList"
								:key="i"
								:class="['icon-item', createData.icon == icon ? 'icon-item-active' : '']"
								@click="createData.icon = icon"
							>
								<oui-icon-unix :name="icon" size="44rpx" :color="createData.icon == icon ? '#FFFFFF' : 'var(--rice-text-color-2)'" />
							</view>
						</view>
						<text v-if="createAvatar() != ''" class="field-tip" @click="clearCreateAvatar">已选择自定义头像，点这里移除</text>
					</view>

					<view class="dialog-section">
						<view class="section-title-row">
							<text class="dialog-label dialog-label-inline">系统提示词</text>
							<text class="section-action" @click="resetPromptByTemplate">重置模板</text>
						</view>
						<textarea class="prompt-input" v-model="createData.systemPrompt" placeholder="定义说话风格、能力边界和输出习惯。" placeholder-style="color:var(--rice-text-color-3)" />
						<text class="field-tip">创建后还能在聊天设置里继续修改。</text>
					</view>
				</scroll-view>

				<view class="dialog-footer">
					<view class="dialog-secondary-btn" @click="closeCreateDialog">
						<text class="dialog-secondary-text">取消</text>
					</view>
					<view class="dialog-btn" @click="doCreateAgent">
						<text class="dialog-btn-text">创建并开始</text>
					</view>
				</view>
			</view>
		</view>

		<!-- 首启引导：不改聊天列表结构，只在没有可用模型时轻量提示。 -->
		<view v-if="showFirstRunGuide" class="first-run-overlay" @click="dismissFirstRunGuide">
			<view class="first-run-card" @click.stop>
				<view class="dialog-handle"></view>
				<view class="first-run-header">
					<view class="first-run-title-wrap">
						<text class="first-run-title">先接入一个模型</text>
						<text class="first-run-desc">填一次 API Key，就能像普通聊天软件一样开始私聊和群聊。之后可以随时去设置里改。</text>
					</view>
					<view class="dialog-close" @click="dismissFirstRunGuide">
						<oui-icon-unix name="close" size="40rpx" color="var(--rice-text-color-3)" />
					</view>
				</view>

				<view class="first-run-section">
					<text class="dialog-label">选择提供商</text>
					<view class="first-run-provider-grid">
						<view class="first-run-provider-row">
							<view :class="firstRunProviderCardClass(0)" @click="selectFirstRunProvider(0)">
								<text class="first-run-provider-name">{{ firstRunProviderName(firstRunProviderItem(0)) }}</text>
								<text class="first-run-provider-desc">{{ firstRunProviderDesc(firstRunProviderItem(0)) }}</text>
							</view>
							<view :class="firstRunProviderCardClass(1)" @click="selectFirstRunProvider(1)">
								<text class="first-run-provider-name">{{ firstRunProviderName(firstRunProviderItem(1)) }}</text>
								<text class="first-run-provider-desc">{{ firstRunProviderDesc(firstRunProviderItem(1)) }}</text>
							</view>
						</view>
						<view class="first-run-provider-row">
							<view :class="firstRunProviderCardClass(2)" @click="selectFirstRunProvider(2)">
								<text class="first-run-provider-name">{{ firstRunProviderName(firstRunProviderItem(2)) }}</text>
								<text class="first-run-provider-desc">{{ firstRunProviderDesc(firstRunProviderItem(2)) }}</text>
							</view>
							<view :class="firstRunProviderCardClass(3)" @click="selectFirstRunProvider(3)">
								<text class="first-run-provider-name">{{ firstRunProviderName(firstRunProviderItem(3)) }}</text>
								<text class="first-run-provider-desc">{{ firstRunProviderDesc(firstRunProviderItem(3)) }}</text>
							</view>
						</view>
					</view>
				</view>

				<view class="first-run-hint-card">
					<text class="first-run-hint-title">下一步会打开完整提供商编辑页</text>
					<text class="first-run-hint-desc">在那里填写 API Key、点「获取模型列表」、勾选模型并保存。保存后就能开始私聊和群聊。</text>
				</view>

				<view class="first-run-actions">
					<view class="dialog-secondary-btn first-run-secondary" @click="dismissFirstRunGuide">
						<text class="dialog-secondary-text">稍后</text>
					</view>
					<view class="dialog-btn first-run-primary" @click="openProviderEditorFromGuide">
						<text class="dialog-btn-text">去配置提供商</text>
					</view>
				</view>
			</view>
		</view>

		<TabBar current="pages/agents/agents" />
	</view>
</template>

<script lang="uts">
	/**
	 * 聊天会话列表页
	 * 扁平化粉白主题
	 */
	import { getAgents, saveAgents, MINXI_BASE_STYLE } from '@/utils/agent.uts'
	import { getAgentDir } from '@/utils/file-manager.uts'
	import { deleteRuntimeState, getAppSetting, getConversationsByAgent, getRuntimeState, setAppSetting, setRuntimeState } from '@/utils/database.uts'
	import { getAllProviders } from '@/uni_modules/agent-core/utssdk/provider.uts'
	import {
		type GroupChat,
		createDefaultWritingGroupChat,
		displaySessionTitle,
		ensureGroupActiveSession,
		getActiveGroupMembers,
		getGroupChats,
		setActiveGroupChat,
		setActiveGroupSessionId,
	} from '@/utils/group-chat-service.uts'
	import { setActiveAgentRuntimeId } from '@/utils/runtime-state.uts'

	/** 可用图标列表 */
	const AVAILABLE_ICONS: string[] = [
		'robot', 'code', 'edit', 'translate', 'bulb',
		'star', 'heart', 'camera', 'sound', 'fire'
	]
	const DEFAULT_ICON = 'robot'
	const CREATE_TEMPLATES: UTSJSONObject[] = [
		{
			key: 'ai-assistant',
			icon: 'robot',
			name: '小夜',
			desc: '沉稳可靠，有问必答，话不多但句句到位',
			prompt: MINXI_BASE_STYLE + '\n你的角色：你叫小夜，通用助手，冷静可靠，话少但到位。先给结论，再补必要信息。用户只是闲聊时，轻松接话；用户要办事时，效率优先，主动拆步骤、查事实、给可执行方案。别说空话，别装神秘。\n参考用语：马上、搞定、有道理、稍等、说重点、别急、嗯、可以、辛苦了、跟着走就行'
		} as UTSJSONObject,
		{
			key: 'coding-helper',
			icon: 'code',
			name: '零',
			desc: '毒舌代码审查官，骂完还是会帮你改',
			prompt: MINXI_BASE_STYLE + '\n你的角色：你叫零，代码搭档和审查官。看到烂代码可以吐槽，但先定位问题，再给最小可行修复。解释技术问题用简单比喻，代码、变量名、命令保持英文。改代码前先看上下文，别乱重构；不确定库版本、接口行为或报错原因时先求证。\n参考用语：你来真的？、编译过了？、加个空安全、重构成这样、别偷懒、基本功啊、还不笨、行吧、先跑一遍、抽象一下'
		} as UTSJSONObject,
		{
			key: 'writing-helper',
			icon: 'edit',
			name: '千夏',
			desc: '对文字有强迫症，改完让你的句子发光',
			prompt: MINXI_BASE_STYLE + '\n你的角色：你叫千夏，文字编辑和写作搭档。你挑剔但不卖弄，优先保留原意、语气和节奏，只把表达变干净、准确、有质感。润色先给成稿，必要时再说明改动。写长文时结构清楚，别堆形容词，别把话写油。\n参考用语：这里不通顺、换个词更好、节奏不对、精简一下、保留原意、这版可以、你再看看、有感觉了、有点啰嗦、清透了'
		} as UTSJSONObject,
		{
			key: 'translate',
			icon: 'translate',
			name: '凛',
			desc: '多语种无缝切换，干净利落不废话',
			prompt: MINXI_BASE_STYLE + '\n你的角色：你叫凛，翻译和本地化搭档。准确优先，兼顾语境、语气、文化差异和术语一致性。不添油加醋，不偷工减料。用户只要翻译时直接给译文；需要对照时再给原文/译文。遇到歧义要点出来，别硬猜。\n参考用语：准确优先、原文是这个意思、这里需要意译、术语统一了、语境优先、搞定了、保持风格、你说得对、保留原味'
		} as UTSJSONObject,
		{
			key: 'idea-lab',
			icon: 'bulb',
			name: '星',
			desc: '脑洞清奇，话题跳脱但总能绕回来',
			prompt: MINXI_BASE_STYLE + '\n你的角色：你叫星，灵感和方案搭档。可以脑洞大，但最后要落回可执行方案。头脑风暴时先铺选项，再标出最推荐的一条；区分"靠谱方案"和"好玩但冒险"。聊天可以跳一点，但别散，记得把线拉回来。\n参考用语：换个角度想想、这个有点意思、脑洞时间、不一定靠谱但好玩、落地方案是、先铺选项、你觉得呢、总之、有点意思吧、节奏对了'
		} as UTSJSONObject,
		{
			key: 'custom',
			icon: 'star',
			name: '自定义',
			desc: '从空白人设开始配置',
			prompt: '你是一个由用户自定义的 AI 联系人。请遵循用户设定的人设、能力范围和输出习惯，用中文自然回复。'
		} as UTSJSONObject
	]
	const FIRST_RUN_GUIDE_DONE_KEY = 'first_run_model_guide_done'
	const FIRST_RUN_PROVIDER_EDIT_SOURCE_KEY = 'provider_edit_source'
	const FIRST_RUN_PROVIDER_EDIT_SOURCE_VALUE = 'first_run_guide'
	const FIRST_RUN_PROVIDER_EDIT_PRESET_KEY = 'provider_edit_preset'
	const FIRST_RUN_PROVIDER_EDIT_ID_KEY = 'provider_edit_id'
	// DEV_ONLY_FORCE_FIRST_RUN_GUIDE: 临时强制展示首启引导，验完 UI 后改回 false。
	const DEV_ONLY_FORCE_FIRST_RUN_GUIDE = true
	const FIRST_RUN_PROVIDER_OPTIONS: UTSJSONObject[] = [
		{
			id: 'deepseek',
			name: 'DeepSeek',
			desc: '推荐，地址已填好',
			baseUrl: 'https://api.deepseek.com',
			model: 'deepseek-v4-flash',
		} as UTSJSONObject,
		{
			id: 'openai',
			name: 'OpenAI',
			desc: '适合 GPT 系列',
			baseUrl: 'https://api.openai.com',
			model: 'gpt-4o-mini',
		} as UTSJSONObject,
		{
			id: 'volcengine',
			name: '豆包',
			desc: '火山引擎，国内访问友好',
			baseUrl: 'https://ark.cn-beijing.volces.com/api/v3',
			model: 'doubao-seed-1-6-flash-250615',
		} as UTSJSONObject,
		{
			id: 'custom',
			name: '自定义',
			desc: '兼容 OpenAI 格式',
			baseUrl: '',
			model: '',
		} as UTSJSONObject,
	]

	export default {
		data() {
			return {
				agentList: [] as UTSJSONObject[],
				groupList: [] as GroupChat[],
				chatList: [] as UTSJSONObject[],
				showCreateMenu: false as boolean,
				showCreateDialog: false as boolean,
				showFirstRunGuide: false as boolean,
				firstRunProviderIndex: 0 as number,
				/** 创建表单数据 */
				createData: {
					templateKey: 'ai-assistant',
					icon: DEFAULT_ICON,
					name: '' as string,
					desc: '' as string,
					avatar: '' as string,
					systemPrompt: '' as string,
				} as UTSJSONObject,
			}
		},
		computed: {
			iconList(): string[] {
				return AVAILABLE_ICONS
			},

			templateList(): UTSJSONObject[] {
				return CREATE_TEMPLATES
			},

			firstRunProviderOptions(): UTSJSONObject[] {
				return FIRST_RUN_PROVIDER_OPTIONS
			},

			createPreviewName(): string {
				const raw = this.createData['name'] as string | null
				const name = raw != null ? raw.trim() : ''
				return name != '' ? name : '未命名联系人'
			},

			createPreviewDesc(): string {
				const raw = this.createData['desc'] as string | null
				const desc = raw != null ? raw.trim() : ''
				return desc != '' ? desc : '选择模板后，补一句它擅长什么。'
			}
		},
		onLoad() {
			this.loadChats()
			this.checkFirstRunGuide()
		},
		onShow() {
			this.loadChats()
			this.consumeCreateAvatarCropResult()
			this.checkFirstRunGuide()
		},
		methods: {
			templateKey(tpl: UTSJSONObject): string {
				const value = tpl['key'] as string | null
				return value != null ? value : ''
			},

			templateIcon(tpl: UTSJSONObject): string {
				const value = tpl['icon'] as string | null
				return value != null ? value : DEFAULT_ICON
			},

			templateName(tpl: UTSJSONObject): string {
				const value = tpl['name'] as string | null
				return value != null ? value : '模板'
			},

			templateDesc(tpl: UTSJSONObject): string {
				const value = tpl['desc'] as string | null
				return value != null ? value : ''
			},

			templatePrompt(tpl: UTSJSONObject): string {
				const value = tpl['prompt'] as string | null
				return value != null ? value : ''
			},

			createTemplateKey(): string {
				const value = this.createData['templateKey'] as string | null
				return value != null ? value : 'ai-assistant'
			},

			createIcon(): string {
				const value = this.createData['icon'] as string | null
				return value != null && value != '' ? value : DEFAULT_ICON
			},

			createAvatar(): string {
				const value = this.createData['avatar'] as string | null
				return value != null ? value : ''
			},

			firstRunProviderName(item: UTSJSONObject): string {
				const value = item['name'] as string | null
				return value != null ? value : ''
			},

			firstRunProviderDesc(item: UTSJSONObject): string {
				const value = item['desc'] as string | null
				return value != null ? value : ''
			},

			firstRunProviderItem(index: number): UTSJSONObject {
				if (index >= 0 && index < FIRST_RUN_PROVIDER_OPTIONS.length) {
					return FIRST_RUN_PROVIDER_OPTIONS[index]
				}
				return FIRST_RUN_PROVIDER_OPTIONS[0]
			},

			firstRunProviderCardClass(index: number): string {
				return this.firstRunProviderIndex == index ? 'first-run-provider first-run-provider-active' : 'first-run-provider'
			},

			getFirstRunProviderOption(): UTSJSONObject {
				if (this.firstRunProviderIndex >= 0 && this.firstRunProviderIndex < FIRST_RUN_PROVIDER_OPTIONS.length) {
					return FIRST_RUN_PROVIDER_OPTIONS[this.firstRunProviderIndex]
				}
				return FIRST_RUN_PROVIDER_OPTIONS[0]
			},

			selectFirstRunProvider(index: number): void {
				if (index < 0 || index >= FIRST_RUN_PROVIDER_OPTIONS.length) { return }
				this.firstRunProviderIndex = index
			},

			hasReadyChatProvider(): boolean {
				const providers = getAllProviders()
				for (let i = 0; i < providers.length; i++) {
					const provider = providers[i]
					const enabled = provider['enabled'] as number | null
					const apiKey = provider['api_key'] as string | null
					if (enabled != null && enabled == 1 && apiKey != null && apiKey.trim() != '') {
						return true
					}
				}
				return false
			},

			checkFirstRunGuide(): void {
				if (DEV_ONLY_FORCE_FIRST_RUN_GUIDE == true) {
					this.showFirstRunGuide = true
					return
				}
				const done = getAppSetting(FIRST_RUN_GUIDE_DONE_KEY)
				if (done == 'true') {
					this.showFirstRunGuide = false
					return
				}
				this.showFirstRunGuide = this.hasReadyChatProvider() == false
			},

			dismissFirstRunGuide(): void {
				setAppSetting(FIRST_RUN_GUIDE_DONE_KEY, 'true')
				this.showFirstRunGuide = false
			},

			firstRunProviderExists(providerId: string): boolean {
				if (providerId == '') { return false }
				const providers = getAllProviders()
				for (let i = 0; i < providers.length; i++) {
					const id = providers[i]['id'] as string | null
					if (id == providerId) { return true }
				}
				return false
			},

			openProviderEditorFromGuide(): void {
				const option = this.getFirstRunProviderOption()
				const rawProviderId = option['id'] as string | null
				const rawProviderName = option['name'] as string | null
				const providerId = rawProviderId != null ? rawProviderId : 'custom'
				const providerName = rawProviderName != null && rawProviderName != '' ? rawProviderName : '自定义'
				const apiBase = option['baseUrl'] as string | null
				const model = option['model'] as string | null
				const preset: UTSJSONObject = {
					id: providerId,
					name: providerName,
					apiBase: apiBase != null ? apiBase : '',
					model: model != null ? model : '',
				} as UTSJSONObject
				setRuntimeState(FIRST_RUN_PROVIDER_EDIT_SOURCE_KEY, FIRST_RUN_PROVIDER_EDIT_SOURCE_VALUE)
				setRuntimeState(FIRST_RUN_PROVIDER_EDIT_PRESET_KEY, JSON.stringify(preset))
				if (this.firstRunProviderExists(providerId) == true) {
					setRuntimeState(FIRST_RUN_PROVIDER_EDIT_ID_KEY, providerId)
				} else {
					setRuntimeState(FIRST_RUN_PROVIDER_EDIT_ID_KEY, '')
				}
				this.showFirstRunGuide = false
				uni.navigateTo({ url: '/pages/settings/basic/provider-edit' })
			},

			consumeCreateAvatarCropResult(): void {
				// 头像裁剪页通过 SQLite runtime_state 传参。
				const target = getRuntimeState('crop_target')
				if (target != 'create_agent_avatar') {
					return
				}
				const cropResult = getRuntimeState('crop_result')
				if (cropResult != null && cropResult != '') {
					this.createData['avatar'] = cropResult
				}
				deleteRuntimeState('crop_result')
				deleteRuntimeState('crop_target')
				deleteRuntimeState('crop_image_path')
			},

			parseChosenImagePath(res: any): string {
				try {
					const raw = JSON.stringify(res)
					if (raw == null || raw == '') { return '' }
					const parsed = JSON.parse(raw) as UTSJSONObject
					const tempFilePaths = parsed['tempFilePaths'] as string[] | null
					if (tempFilePaths != null && tempFilePaths.length > 0) {
						return tempFilePaths[0]
					}
					const tempFiles = parsed['tempFiles'] as UTSJSONObject[] | null
					if (tempFiles != null && tempFiles.length > 0) {
						const first = tempFiles[0]
						const path = first['path'] as string | null
						if (path != null && path != '') {
							return path
						}
						const tempFilePath = first['tempFilePath'] as string | null
						if (tempFilePath != null && tempFilePath != '') {
							return tempFilePath
						}
					}
				} catch (_e: any) {
				}
				return ''
			},

			resetCreateData(): void {
				const tpl = CREATE_TEMPLATES[0]
				this.createData = {
					templateKey: this.templateKey(tpl),
					icon: this.templateIcon(tpl),
					name: this.templateName(tpl),
					desc: this.templateDesc(tpl),
					avatar: '',
					systemPrompt: this.templatePrompt(tpl),
				} as UTSJSONObject
			},

			openCreateDialog(): void {
				this.resetCreateData()
				this.showCreateDialog = true
			},

			loadAgents() {
				this.agentList = getAgents()
			},

			loadGroups(): void {
				this.groupList = getGroupChats()
			},

			loadChats(): void {
				this.loadAgents()
				this.loadGroups()
				this.rebuildChatList()
			},

			rebuildChatList(): void {
				const result: UTSJSONObject[] = []
				for (let i = 0; i < this.agentList.length; i++) {
					const agent = this.agentList[i]
					const id = agent['id'] as string | null
					if (id == null || id == '') { continue }
					result.push({
						type: 'agent',
						id: id,
						name: agent['name'] as string,
						desc: this.getAgentStatus(agent),
						icon: agent['icon'] as string,
						avatar: this.getAgentAvatar(agent),
						updatedAt: this.getAgentUpdatedAt(id),
					} as UTSJSONObject)
				}
				for (let i = 0; i < this.groupList.length; i++) {
					const group = this.groupList[i]
					result.push({
						type: 'group',
						id: group.id,
						name: group.name,
						desc: this.getGroupSummary(group),
						icon: 'robot',
						avatar: '',
						updatedAt: group.updatedAt,
					} as UTSJSONObject)
				}
				result.sort((a: UTSJSONObject, b: UTSJSONObject): number => {
					const at = a['updatedAt'] as number | null
					const bt = b['updatedAt'] as number | null
					const av = at != null ? at : 0
					const bv = bt != null ? bt : 0
					if (av == bv) { return 0 }
					return av > bv ? -1 : 1
				})
				this.chatList = result
			},

			/** 安全获取私聊头像路径 */
			getAgentAvatar(agent: UTSJSONObject): string {
				const avatar = agent['avatar']
				if (avatar != null) {
					return avatar as string
				}
				return ''
			},

			/** 获取私聊状态描述（优先显示最新对话预览） */
			getAgentStatus(agent: UTSJSONObject): string {
				const id = agent['id'] as string
				if (id == null || id == '') { return agent['desc'] as string }
				try {
					const convs = getConversationsByAgent(id)
					if (convs != null && convs.length > 0) {
						const latest = convs[0]
						const preview = latest['preview'] as string
						if (preview != null && preview != '') {
							return preview
						}
					}
				} catch (_e: any) {
					// 忽略错误，回退到静态描述
				}
				return agent['desc'] as string
			},

			getAgentUpdatedAt(agentId: string): number {
				try {
					const convs = getConversationsByAgent(agentId)
					if (convs != null && convs.length > 0) {
						const latest = convs[0]
						const rawTime = latest['updated_at'] as number | null
						if (rawTime != null && rawTime > 0) {
							return rawTime
						}
					}
				} catch (_e: any) {
				}
				return 0
			},

			getGroupSummary(group: GroupChat): string {
				const members = getActiveGroupMembers(group.id)
				const session = ensureGroupActiveSession(group)
				return members.length.toString() + ' 个成员 · 当前会话：' + displaySessionTitle(session)
			},

			getChatKey(item: UTSJSONObject): string {
				const type = item['type'] as string | null
				const id = item['id'] as string | null
				return (type != null ? type : 'chat') + '-' + (id != null ? id : '')
			},

			isGroupItem(item: UTSJSONObject): boolean {
				const type = item['type'] as string | null
				return type == 'group'
			},

			getChatName(item: UTSJSONObject): string {
				const name = item['name'] as string | null
				return name != null && name != '' ? name : '未命名会话'
			},

			getChatDesc(item: UTSJSONObject): string {
				const desc = item['desc'] as string | null
				return desc != null && desc != '' ? desc : '点进去开始聊天'
			},

			getChatAvatar(item: UTSJSONObject): string {
				const avatar = item['avatar'] as string | null
				return avatar != null ? avatar : ''
			},

			getChatIcon(item: UTSJSONObject): string {
				const type = item['type'] as string | null
				if (type == 'group') { return 'robot' }
				const icon = item['icon'] as string | null
				return icon != null && icon != '' ? icon : 'robot'
			},

			formatChatTime(item: UTSJSONObject): string {
				const raw = item['updatedAt'] as number | null
				const timestamp = raw != null ? raw : 0
				if (timestamp <= 0) { return '' }
				const d = new Date(timestamp)
				const month = (d.getMonth() + 1).toString()
				const day = d.getDate().toString()
				const hour = d.getHours() < 10 ? '0' + d.getHours().toString() : d.getHours().toString()
				const minute = d.getMinutes() < 10 ? '0' + d.getMinutes().toString() : d.getMinutes().toString()
				return month + '/' + day + ' ' + hour + ':' + minute
			},

			openAgent(agent: UTSJSONObject) {
				setActiveAgentRuntimeId(agent['id'] as string)
				uni.navigateTo({
					url: '/pages/chat/chat'
				})
			},

			openGroup(group: GroupChat): void {
				const session = ensureGroupActiveSession(group)
				setActiveGroupChat(group.id)
				setActiveGroupSessionId(session.id)
				uni.navigateTo({ url: '/pages/group-chat/group-chat' })
			},

			openChatItem(item: UTSJSONObject): void {
				this.closeCreateMenu()
				const type = item['type'] as string | null
				if (type == 'group') {
					const groupId = item['id'] as string | null
					if (groupId == null || groupId == '') { return }
					for (let i = 0; i < this.groupList.length; i++) {
						if (this.groupList[i].id == groupId) {
							this.openGroup(this.groupList[i])
							return
						}
					}
					return
				}
				const agentId = item['id'] as string | null
				if (agentId == null || agentId == '') { return }
				for (let i = 0; i < this.agentList.length; i++) {
					const id = this.agentList[i]['id'] as string | null
					if (id == agentId) {
						this.openAgent(this.agentList[i])
						return
					}
				}
				setActiveAgentRuntimeId(agentId)
				uni.navigateTo({ url: '/pages/chat/chat' })
			},

			toggleCreateMenu(): void {
				this.showCreateMenu = !this.showCreateMenu
			},

			closeCreateMenu(): void {
				this.showCreateMenu = false
			},

			createAgentFromMenu(): void {
				this.closeCreateMenu()
				this.openCreateDialog()
			},

			createWritingGroup(): void {
				this.closeCreateMenu()
				const group = createDefaultWritingGroupChat()
				this.loadChats()
				this.openGroup(group)
			},

			goSettings() {
				uni.redirectTo({
					url: '/pages/settings/settings'
				})
			},

			/** 关闭创建弹窗 */
			closeCreateDialog() {
				this.showCreateDialog = false
			},

			selectCreateTemplate(tpl: UTSJSONObject): void {
				this.createData['templateKey'] = this.templateKey(tpl)
				this.createData['icon'] = this.templateIcon(tpl)
				this.createData['name'] = this.templateName(tpl)
				this.createData['desc'] = this.templateDesc(tpl)
				this.createData['systemPrompt'] = this.templatePrompt(tpl)
			},

			resetPromptByTemplate(): void {
				const key = this.createTemplateKey()
				for (let i = 0; i < CREATE_TEMPLATES.length; i++) {
					const tpl = CREATE_TEMPLATES[i]
					if (this.templateKey(tpl) == key) {
						this.createData['systemPrompt'] = this.templatePrompt(tpl)
						return
					}
				}
				this.createData['systemPrompt'] = this.templatePrompt(CREATE_TEMPLATES[0])
			},

			clearCreateAvatar(): void {
				this.createData['avatar'] = ''
			},

			/** 为新建私聊选择头像 */
			pickCreateAvatar(): void {
				uni.chooseImage({
					count: 1,
					sourceType: ['album', 'camera'],
					sizeType: ['compressed'],
					success: (res: any) => {
						const path = this.parseChosenImagePath(res)
						if (path == '') {
							uni.showToast({ position: 'bottom', title: '未选择图片', icon: 'none' })
							return
						}
						// 裁剪组件协议走 SQLite runtime_state，避免临时状态写 uni.storage。
						deleteRuntimeState('crop_result')
						setRuntimeState('crop_target', 'create_agent_avatar')
						setRuntimeState('crop_image_path', path)
						uni.navigateTo({
							url: '/pages/common/crop/crop'
						})
					},
					fail: () => {
						uni.showToast({ position: 'bottom', title: '选择图片失败', icon: 'none' })
					}
				})
			},

			/** 执行创建私聊 */
			doCreateAgent() {
				const rawName = this.createData['name'] as string | null
				const rawDesc = this.createData['desc'] as string | null
				const rawPrompt = this.createData['systemPrompt'] as string | null
				const name = (rawName != null ? rawName : '').trim()
				const desc = (rawDesc != null ? rawDesc : '').trim()
				const systemPrompt = (rawPrompt != null ? rawPrompt : '').trim()
				if (name == '') {
					uni.showToast({ position: 'bottom', 
						title: '请输入名称',
						icon: 'none'
					})
					return
				}

				// 生成唯一 ID
				const id = 'custom-' + Date.now() + '-' + Math.floor(Math.random() * 1000)
				const rawIcon = this.createData['icon'] as string | null
				const rawAvatar = this.createData['avatar'] as string | null
				const icon = rawIcon != null ? rawIcon : 'robot'
				const avatar = rawAvatar != null ? rawAvatar : ''
				const finalDesc = desc != '' ? desc : '自定义联系人'
				const finalPrompt = systemPrompt != '' ? systemPrompt : this.templatePrompt(CREATE_TEMPLATES[0])

				// 默认模型从 SQLite app_settings 读取，缺省时回退内置模型。
				const defaultModel = getAppSetting('settings_model')

				const newAgent: UTSJSONObject = {
					id: id,
					icon: icon,
					name: name,
					desc: finalDesc,
					systemPrompt: finalPrompt,
					model: defaultModel != null && defaultModel != '' ? defaultModel : 'deepseek-v4-flash',
					time: '刚刚',
				}

				// 写入头像
				if (avatar != '') {
					newAgent['avatar'] = avatar
				}

				// 初始化 agent 文件目录
				getAgentDir(id)

				// 添加到列表并保存
				const agents = getAgents()
				agents.push(newAgent)
				saveAgents(agents)

				this.showCreateDialog = false
				// 重置表单
				this.resetCreateData()

				// 刷新列表
				this.loadChats()

				uni.showToast({ position: 'bottom', 
					title: '创建成功',
					icon: 'success'
				})
				setActiveAgentRuntimeId(id)
				uni.navigateTo({
					url: '/pages/chat/chat'
				})
			}
		}
	}
</script>

