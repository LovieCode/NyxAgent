		align-items: center;
		flex: 1;
	}

	.agent-time {
		font-size: 22rpx;
		color: var(--rice-text-color-3);
		margin-left: 16rpx;
	}

	.chat-type-badge {
		margin-left: 12rpx;
		padding-left: 10rpx;
		padding-right: 10rpx;
		padding-top: 4rpx;
		padding-bottom: 4rpx;
		border-radius: 999rpx;
		background-color: rgba(251, 143, 171, 0.14);
		color: var(--rice-primary-color);
