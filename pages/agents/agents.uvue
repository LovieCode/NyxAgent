<template>
	<view class="page-shell rice-theme-light" ref="shellRef">
		<NavBar title="智能体">
			<template #right>
				<view class="add-btn" @click="openCreateDialog">
					<oui-icon-unix name="plus" size="22px" color="#FFFFFF" />
				</view>
			</template>
		</NavBar>

		<!-- 智能体列表 -->
		<scroll-view class="agent-scroll" :scroll-y="true">
			<share-element share-key="agent-list">
				<view class="list-content">
					<view
						v-for="(agent, index) in agentList"
						:key="index"
						class="agent-item"
						@click="openAgent(agent)"
					>
						<!-- 左侧头像：有自定义头像则显示图片，否则显示图标色块 -->
						<image v-if="getAgentAvatar(agent) != ''" :src="getAgentAvatar(agent)" class="agent-avatar-img" mode="aspectFill" />
						<view v-else :class="'agent-avatar avatar-' + ((index % 5) + 1)">
							<oui-icon-unix :name="agent['icon']" size="24px" color="var(--rice-background-2)" />
						</view>
						<!-- 中间文字 -->
						<view class="agent-info">
							<view class="agent-top">
								<text class="agent-name">{{ agent['name'] }}</text>
							</view>
							<text class="agent-desc">{{ getAgentStatus(agent) }}</text>
						</view>
						<!-- 右侧箭头 -->
						<text class="agent-arrow">›</text>
					</view>
				</view>
			</share-element>
		</scroll-view>

		<!-- 创建智能体弹窗 -->
		<view v-if="showCreateDialog" class="dialog-overlay" @click="closeCreateDialog">
			<view class="dialog-card" @click.stop>
				<view class="dialog-header">
					<view class="dialog-title-wrap">
						<text class="dialog-title">创建智能体</text>
						<text class="dialog-subtitle">先选人设模板，再微调细节</text>
					</view>
					<view class="dialog-close" @click="closeCreateDialog">
						<oui-icon-unix name="close" size="20px" color="var(--rice-text-color-3)" />
					</view>
				</view>

				<scroll-view class="dialog-scroll" :scroll-y="true">
					<view class="create-preview-card">
						<image v-if="createAvatar() != ''" :src="createAvatar()" class="preview-avatar-img" mode="aspectFill" />
						<view v-else class="preview-avatar">
							<oui-icon-unix :name="createIcon()" size="30px" color="#FFFFFF" />
						</view>
						<view class="preview-info">
							<text class="preview-name">{{createPreviewName}}</text>
							<text class="preview-desc">{{createPreviewDesc}}</text>
						</view>
					</view>

					<view class="dialog-section">
						<text class="dialog-label">快速模板</text>
						<scroll-view class="template-scroll" :scroll-x="true" :show-scrollbar="false">
							<view class="template-row">
								<view
									v-for="(tpl, ti) in templateList"
									:key="ti"
									class="template-chip"
									:class="createTemplateKey() == templateKey(tpl) ? 'template-chip-active' : ''"
									@click="selectCreateTemplate(tpl)"
								>
									<oui-icon-unix :name="templateIcon(tpl)" size="18px" :color="createTemplateKey() == templateKey(tpl) ? '#FFFFFF' : 'var(--rice-primary-color)'" />
									<text class="template-chip-text" :class="createTemplateKey() == templateKey(tpl) ? 'template-chip-text-active' : ''">{{templateName(tpl)}}</text>
								</view>
							</view>
						</scroll-view>
					</view>

					<view class="dialog-section">
						<text class="dialog-label">基础信息</text>
						<input class="dialog-input" v-model="createData.name" placeholder="名字，比如：岚 / Debug 猫 / 论文搭子" placeholder-style="color:var(--rice-text-color-3)" />
						<input class="dialog-input dialog-input-gap" v-model="createData.desc" placeholder="一句话说明它擅长什么" placeholder-style="color:var(--rice-text-color-3)" />
					</view>

					<view class="dialog-section">
						<view class="section-title-row">
							<text class="dialog-label">头像与图标</text>
							<text class="section-action" @click="pickCreateAvatar">选择图片</text>
						</view>
						<view class="icon-grid">
							<view
								v-for="(icon, i) in iconList"
								:key="i"
								:class="['icon-item', createData.icon == icon ? 'icon-item-active' : '']"
								@click="createData.icon = icon"
							>
								<oui-icon-unix :name="icon" size="22px" :color="createData.icon == icon ? '#FFFFFF' : 'var(--rice-text-color-2)'" />
							</view>
						</view>
						<text v-if="createAvatar() != ''" class="field-tip" @click="clearCreateAvatar">已选择自定义头像，点这里移除</text>
					</view>

					<view class="dialog-section">
						<view class="section-title-row">
							<text class="dialog-label">系统提示词</text>
							<text class="section-action" @click="resetPromptByTemplate">重置模板</text>
						</view>
						<textarea class="prompt-input" v-model="createData.systemPrompt" placeholder="定义说话风格、能力边界和输出习惯。" placeholder-style="color:var(--rice-text-color-3)" />
						<text class="field-tip">创建后还能在智能体设置里继续精修。</text>
					</view>
				</scroll-view>

				<view class="dialog-footer">
					<view class="dialog-secondary-btn" @click="closeCreateDialog">
						<text class="dialog-secondary-text">取消</text>
					</view>
					<view class="dialog-btn" @click="doCreateAgent">
						<text class="dialog-btn-text">创建并开始</text>
					</view>
				</view>
			</view>
		</view>

		<TabBar current="pages/agents/agents" />
	</view>
</template>

<script lang="uts">
	/**
	 * 智能体列表页
	 * 扁平化粉白主题
	 */
	import { getAgents, saveAgents } from '@/utils/agent.uts'
	import { initAgentStorage } from '@/utils/agent-fs.uts'
	import { getConversationsByAgent } from '@/utils/database.uts'

	/** 可用图标列表 */
	const AVAILABLE_ICONS: string[] = [
		'robot', 'code', 'edit', 'translate', 'bulb',
		'star', 'heart', 'camera', 'music', 'fire'
	]
	const DEFAULT_ICON = 'robot'
	const CREATE_TEMPLATES: UTSJSONObject[] = [
		{
			key: 'general',
			icon: 'robot',
			name: '小助手',
			desc: '可靠通用助手，回答简洁直接',
			prompt: '你是一个可靠的中文智能助手。回答要简洁、准确、有条理；不确定时直接说明不确定；需要步骤时用清单表达。'
		} as UTSJSONObject,
		{
			key: 'coder',
			icon: 'code',
			name: '代码搭子',
			desc: '写代码、查 Bug、做技术方案',
			prompt: '你是一个资深编程助手。用中文解释，代码和变量名保持英文；先定位问题，再给最小可行修改；遇到不确定的库/API 要提醒用户核查版本。'
		} as UTSJSONObject,
		{
			key: 'writer',
			icon: 'edit',
			name: '文字修理师',
			desc: '润色、改写、总结和起草内容',
			prompt: '你是一个文字编辑助手。保持原意，优化结构、语气和表达；给出可直接使用的版本，必要时说明改动重点。'
		} as UTSJSONObject,
		{
			key: 'planner',
			icon: 'bulb',
			name: '计划控',
			desc: '拆任务、排计划、做决策辅助',
			prompt: '你是一个计划与决策助手。先明确目标和约束，再拆解步骤；输出要可执行，主动标出风险、依赖和验收标准。'
		} as UTSJSONObject,
		{
			key: 'custom',
			icon: 'star',
			name: '自定义角色',
			desc: '从空白人设开始配置',
			prompt: '你是一个由用户自定义的智能体。请遵循用户设定的人设、能力范围和输出习惯，用中文自然回复。'
		} as UTSJSONObject
	]

	export default {
		data() {
			return {
				agentList: [] as UTSJSONObject[],
				showCreateDialog: false as boolean,
				/** 创建表单数据 */
				createData: {
					templateKey: 'general',
					icon: DEFAULT_ICON,
					name: '' as string,
					desc: '' as string,
					avatar: '' as string,
					systemPrompt: '' as string,
				} as UTSJSONObject,
			}
		},
		computed: {
			iconList(): string[] {
				return AVAILABLE_ICONS
			},

			templateList(): UTSJSONObject[] {
				return CREATE_TEMPLATES
			},

			createPreviewName(): string {
				const raw = this.createData['name'] as string | null
				const name = raw != null ? raw.trim() : ''
				return name != '' ? name : '未命名智能体'
			},

			createPreviewDesc(): string {
				const raw = this.createData['desc'] as string | null
				const desc = raw != null ? raw.trim() : ''
				return desc != '' ? desc : '选择模板后，补一句它擅长什么。'
			}
		},
		onLoad() {
			this.loadAgents()
		},
		onShow() {
			this.loadAgents()
		},
		methods: {
			templateKey(tpl: UTSJSONObject): string {
				const value = tpl['key'] as string | null
				return value != null ? value : ''
			},

			templateIcon(tpl: UTSJSONObject): string {
				const value = tpl['icon'] as string | null
				return value != null ? value : DEFAULT_ICON
			},

			templateName(tpl: UTSJSONObject): string {
				const value = tpl['name'] as string | null
				return value != null ? value : '模板'
			},

			templateDesc(tpl: UTSJSONObject): string {
				const value = tpl['desc'] as string | null
				return value != null ? value : ''
			},

			templatePrompt(tpl: UTSJSONObject): string {
				const value = tpl['prompt'] as string | null
				return value != null ? value : ''
			},

			createTemplateKey(): string {
				const value = this.createData['templateKey'] as string | null
				return value != null ? value : 'general'
			},

			createIcon(): string {
				const value = this.createData['icon'] as string | null
				return value != null && value != '' ? value : DEFAULT_ICON
			},

			createAvatar(): string {
				const value = this.createData['avatar'] as string | null
				return value != null ? value : ''
			},

			resetCreateData(): void {
				const tpl = CREATE_TEMPLATES[0]
				this.createData = {
					templateKey: this.templateKey(tpl),
					icon: this.templateIcon(tpl),
					name: this.templateName(tpl),
					desc: this.templateDesc(tpl),
					avatar: '',
					systemPrompt: this.templatePrompt(tpl),
				} as UTSJSONObject
			},

			openCreateDialog(): void {
				this.resetCreateData()
				this.showCreateDialog = true
			},

			loadAgents() {
				this.agentList = getAgents()
			},

			/** 安全获取智能体头像路径 */
			getAgentAvatar(agent: UTSJSONObject): string {
				const avatar = agent['avatar']
				if (avatar != null) {
					return avatar as string
				}
				return ''
			},

			/** 获取智能体的状态描述（优先显示最新对话预览） */
			getAgentStatus(agent: UTSJSONObject): string {
				const id = agent['id'] as string
				if (id == null || id == '') { return agent['desc'] as string }
				try {
					const convs = getConversationsByAgent(id)
					if (convs != null && convs.length > 0) {
						const latest = convs[0]
						const preview = latest['preview'] as string
						if (preview != null && preview != '') {
							return preview
						}
					}
				} catch (_e: any) {
					// 忽略错误，回退到静态描述
				}
				return agent['desc'] as string
			},

			openAgent(agent: UTSJSONObject) {
				uni.setStorageSync('active_agent_id', agent['id'] as string)
				uni.navigateTo({
					url: '/pages/index/index'
				})
			},

			goSettings() {
				uni.redirectTo({
					url: '/pages/settings/settings'
				})
			},

			/** 关闭创建弹窗 */
			closeCreateDialog() {
				this.showCreateDialog = false
			},

			selectCreateTemplate(tpl: UTSJSONObject): void {
				this.createData['templateKey'] = this.templateKey(tpl)
				this.createData['icon'] = this.templateIcon(tpl)
				this.createData['name'] = this.templateName(tpl)
				this.createData['desc'] = this.templateDesc(tpl)
				this.createData['systemPrompt'] = this.templatePrompt(tpl)
			},

			resetPromptByTemplate(): void {
				const key = this.createTemplateKey()
				for (let i = 0; i < CREATE_TEMPLATES.length; i++) {
					const tpl = CREATE_TEMPLATES[i]
					if (this.templateKey(tpl) == key) {
						this.createData['systemPrompt'] = this.templatePrompt(tpl)
						return
					}
				}
				this.createData['systemPrompt'] = this.templatePrompt(CREATE_TEMPLATES[0])
			},

			clearCreateAvatar(): void {
				this.createData['avatar'] = ''
			},

			/** 为新建智能体选择头像 */
			pickCreateAvatar() {
				uni.chooseImage({
					count: 1,
					sourceType: ['album', 'camera'],
					sizeType: ['compressed'],
					success: (res: any) => {
						const raw = JSON.stringify(res)
						if (raw == null || raw == '') { return }
						const parsed = JSON.parse(raw) as UTSJSONObject
						const paths = parsed['tempFilePaths'] as string[]
						if (paths != null && paths.length > 0) {
							this.createData['avatar'] = paths[0]
						}
					}
				})
			},

			/** 执行创建智能体 */
			doCreateAgent() {
				const rawName = this.createData['name'] as string | null
				const rawDesc = this.createData['desc'] as string | null
				const rawPrompt = this.createData['systemPrompt'] as string | null
				const name = (rawName != null ? rawName : '').trim()
				const desc = (rawDesc != null ? rawDesc : '').trim()
				const systemPrompt = (rawPrompt != null ? rawPrompt : '').trim()
				if (name == '') {
					uni.showToast({ position: 'bottom', 
						title: '请输入名称',
						icon: 'none'
					})
					return
				}

				// 生成唯一 ID
				const id = 'custom-' + Date.now() + '-' + Math.floor(Math.random() * 1000)
				const rawIcon = this.createData['icon'] as string | null
				const rawAvatar = this.createData['avatar'] as string | null
				const icon = rawIcon != null ? rawIcon : 'robot'
				const avatar = rawAvatar != null ? rawAvatar : ''
				const finalDesc = desc != '' ? desc : '自定义智能体'
				const finalPrompt = systemPrompt != '' ? systemPrompt : this.templatePrompt(CREATE_TEMPLATES[0])

				const defaultModel = uni.getStorageSync('settings_model') as string

				const newAgent: UTSJSONObject = {
					id: id,
					icon: icon,
					name: name,
					desc: finalDesc,
					systemPrompt: finalPrompt,
					model: defaultModel != null && defaultModel != '' ? defaultModel : 'deepseek-v4-flash',
					time: '刚刚',
				}

				// 写入头像
				if (avatar != '') {
					newAgent['avatar'] = avatar
				}

				// 初始化 agent 文件目录
				initAgentStorage(id)

				// 添加到列表并保存
				const agents = getAgents()
				agents.push(newAgent)
				saveAgents(agents)

				this.showCreateDialog = false
				// 重置表单
				this.resetCreateData()

				// 刷新列表
				this.loadAgents()

				uni.showToast({ position: 'bottom', 
					title: '创建成功',
					icon: 'success'
				})
				uni.setStorageSync('active_agent_id', id)
				uni.navigateTo({
					url: '/pages/index/index'
				})
			}
		}
	}
</script>

<style>
	.add-btn {
		width: 36px;
		height: 36px;
		justify-content: center;
		align-items: center;
	}

	/* 列表滚动区 */
	.agent-scroll {
		flex: 1;
	}

	.list-content {
		flex-direction: column;
		background-color: var(--rice-background-2);
		margin-top: 8px;
		border-radius: 18px;
		margin-left: 12px;
		margin-right: 12px;
	}

	/* 单个智能体行 */
	.agent-item {
		flex-direction: row;
		align-items: center;
		padding: 14px 16px;
		border-bottom-width: 0.5px;
		border-bottom-color: var(--rice-border-color);
		border-bottom-style: solid;
	}

	/* 左侧头像 - 纯色背景 */
	.agent-avatar {
		width: 48px;
		height: 48px;
		border-radius: 14px;
		justify-content: center;
		align-items: center;
		margin-right: 14px;
	}

	/* 自定义头像图片 */
	.agent-avatar-img {
		width: 48px;
		height: 48px;
		border-radius: 14px;
		margin-right: 14px;
	}

	.avatar-1 { background-color: var(--rice-primary-color); }
	.avatar-2 { background-color: #60A5FA; }
	.avatar-3 { background-color: #34D399; }
	.avatar-4 { background-color: #FBBF24; }
	.avatar-5 { background-color: #A78BFA; }

	/* 中间信息 */
	.agent-info {
		flex: 1;
		flex-direction: column;
	}

	.agent-top {
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 4px;
	}

	.agent-name {
		font-size: 16px;
		font-weight: bold;
		color: var(--rice-text-color);
	}

	.agent-desc {
		font-size: 13px;
		color: var(--rice-text-color-3);
		lines: 1;
		text-overflow: ellipsis;
	}

	/* 右侧箭头 */
	.agent-arrow {
		font-size: 22px;
		color: var(--rice-text-color-3);
		margin-left: 8px;
	}

	/* ===== 创建智能体弹窗 ===== */
	.dialog-overlay {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background-color: rgba(0, 0, 0, 0.4);
		justify-content: center;
		align-items: center;
		z-index: 1000;
	}

	.dialog-card {
		width: 344px;
		background-color: #FFFFFF;
		border-radius: 24px;
		padding: 18px 18px;
		max-height: 620px;
	}

	.dialog-header {
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 12px;
	}

	.dialog-title {
		font-size: 18px;
		font-weight: bold;
		color: var(--rice-text-color);
	}

	.dialog-title-wrap {
		flex-direction: column;
	}

	.dialog-subtitle {
		font-size: 12px;
		color: var(--rice-text-color-3);
		margin-top: 4px;
	}

	.dialog-close {
		width: 32px;
		height: 32px;
		justify-content: center;
		align-items: center;
	}

	.dialog-scroll {
		max-height: 490px;
	}

	.create-preview-card {
		flex-direction: row;
		align-items: center;
		background-color: #FFF7FA;
		border-radius: 18px;
		padding: 14px;
		margin-bottom: 16px;
		border-width: 1px;
		border-color: rgba(251, 143, 171, 0.22);
		border-style: solid;
	}

	.preview-avatar,
	.preview-avatar-img {
		width: 58px;
		height: 58px;
		border-radius: 18px;
		margin-right: 14px;
	}

	.preview-avatar {
		background-color: var(--rice-primary-color);
		justify-content: center;
		align-items: center;
	}

	.preview-info {
		flex: 1;
		flex-direction: column;
	}

	.preview-name {
		font-size: 18px;
		font-weight: bold;
		color: var(--rice-text-color);
		margin-bottom: 5px;
	}

	.preview-desc {
		font-size: 13px;
		color: var(--rice-text-color-2);
		lines: 2;
		text-overflow: ellipsis;
	}

	.dialog-section {
		margin-bottom: 16px;
	}

	.dialog-label {
		font-size: 13px;
		font-weight: bold;
		color: var(--rice-text-color-2);
		margin-bottom: 8px;
	}

	.section-title-row {
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 8px;
	}

	.section-action {
		font-size: 12px;
		color: var(--rice-primary-color);
		font-weight: bold;
		padding: 4px 0;
	}

	.template-scroll {
		flex-direction: row;
	}

	.template-row {
		flex-direction: row;
		padding-bottom: 4px;
	}

	.template-chip {
		flex-direction: row;
		align-items: center;
		padding: 10px 12px;
		border-radius: 999px;
		background-color: #F9FAFB;
		margin-right: 8px;
		border-width: 1px;
		border-color: #F3F4F6;
		border-style: solid;
	}

	.template-chip-active {
		background-color: var(--rice-primary-color);
		border-color: var(--rice-primary-color);
	}

	.template-chip-text {
		font-size: 13px;
		color: var(--rice-text-color-2);
		margin-left: 5px;
	}

	.template-chip-text-active {
		color: #FFFFFF;
		font-weight: bold;
	}

	/* 图标网格 */
	.icon-grid {
		flex-direction: row;
		flex-wrap: wrap;
	}

	.icon-item {
		width: 44px;
		height: 44px;
		border-radius: 10px;
		background-color: var(--rice-background);
		justify-content: center;
		align-items: center;
		margin-right: 8px;
		margin-bottom: 8px;
