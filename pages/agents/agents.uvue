		background-color: #FFF7FA;
		border-radius: 36rpx;
		padding: 24rpx;
		margin-bottom: 36rpx;
		border-width: 2rpx;
		border-color: rgba(251, 143, 171, 0.22);
		border-style: solid;
	}

	.preview-avatar,
	.preview-avatar-img {
		width: 104rpx;
		height: 104rpx;
		border-radius: 32rpx;
		margin-right: 28rpx;
	}

	.preview-avatar {
		background-color: var(--rice-primary-color);
		justify-content: center;
		align-items: center;
	}

	.preview-info {
		flex: 1;
		flex-direction: column;
	}

	.preview-name {
		font-size: 34rpx;
		font-weight: bold;
		color: var(--rice-text-color);
		margin-bottom: 10rpx;
	}

	.preview-desc {
		font-size: 26rpx;
		color: var(--rice-text-color-2);
		lines: 2;
		text-overflow: ellipsis;
	}

	.dialog-section {
		margin-bottom: 40rpx;
	}

	.dialog-label {
		font-size: 26rpx;
		font-weight: bold;
		color: var(--rice-text-color-2);
		margin-bottom: 16rpx;
	}

	.section-title-row {
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 16rpx;
	}

	.dialog-label-inline {
		margin-bottom: 0;
	}

	.section-action {
		font-size: 24rpx;
		color: var(--rice-primary-color);
		font-weight: bold;
		padding: 8rpx 0;
	}

	.dialog-label-sub {
		font-size: 24rpx;
		color: var(--rice-text-color-3);
	}

	.template-scroll {
		flex-direction: row;
	}

	.template-row {
		flex-direction: row;
		padding-bottom: 12rpx;
