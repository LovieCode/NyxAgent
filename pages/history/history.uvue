		color: var(--rice-text-color-2);
	}

	.preview-primary-text {
		font-size: 14px;
		font-weight: bold;
		color: #FFFFFF;
	}

	.history-tabs {
		flex-direction: row;
		margin-left: 16px;
		margin-right: 16px;
