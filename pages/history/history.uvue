<template>
	<view class="page-shell rice-theme-light">
		<NavBar title="历史记录" showBack @back="handleBack">
			<template #right>
				<view v-if="!editMode" class="nav-right">
					<text class="nav-btn" v-if="currentHistoryLength > 0" @click="enterEditMode">管理</text>
					<text class="nav-btn" v-if="currentHistoryLength > 0" @click="confirmClear">清空</text>
				</view>
				<view v-else class="nav-right">
					<text class="nav-btn" @click="selectAll">全选</text>
					<text class="nav-btn nav-btn-danger" @click="batchDelete">删除({{selectedIds.length}})</text>
					<text class="nav-btn" @click="exitEditMode">取消</text>
				</view>
			</template>
		</NavBar>
		<view class="history-page">
			<view class="history-tabs">
				<view class="history-tab" :class="activeTab == 'agent' ? 'history-tab-active' : ''" @click="switchTab('agent')">
					<text class="history-tab-text" :class="activeTab == 'agent' ? 'history-tab-text-active' : ''">私聊</text>
				</view>
				<view class="history-tab" :class="activeTab == 'group' ? 'history-tab-active' : ''" @click="switchTab('group')">
					<text class="history-tab-text" :class="activeTab == 'group' ? 'history-tab-text-active' : ''">群聊</text>
				</view>
			</view>

			<!-- 历史列表 -->
			<scroll-view class="list-scroll" :scroll-y="true">
				<view v-if="currentHistoryLength > 0" class="list-content">
					<view
						v-for="(item, index) in currentHistoryList"
						:key="index"
						class="history-card"
						:class="isSelected(item['id'] as string) ? 'card-selected' : ''"
						@click="onCardClick(item)"
						@longpress="onCardLongpress(item)"
					>
						<view class="card-row">
							<!-- 编辑模式下的复选框 -->
							<view v-if="editMode" class="check-col" @click.stop="toggleItem(item['id'] as string)">
								<view
									class="checkbox"
									:class="isSelected(item['id'] as string) ? 'checkbox-checked' : ''"
								>
									<text v-if="isSelected(item['id'] as string)" class="checkmark">✓</text>
								</view>
							</view>
							<view class="card-body">
								<view class="card-top">
									<text class="card-title">{{ item['title'] }}</text>
									<text class="card-time">{{ formatTime(item['created_at']) }}</text>
								</view>
								<text class="card-preview">{{ item['preview'] }}</text>
								<view class="card-meta">
									<text class="meta-msgs">{{ item['message_count'] }} 条消息</text>
									<text class="meta-model">{{ item['model'] }}</text>
								</view>
							</view>
						</view>
					</view>
				</view>

				<!-- 空状态 -->
				<view v-else class="empty-state">
					<oui-icon-unix name="time-circle" size="96rpx" color="#D1D5DB" />
					<text class="empty-text">暂无历史记录</text>
					<text class="empty-hint">{{activeTab == 'group' ? '群聊讨论后，会话记录会出现在这里' : '开始对话后，记录将自动保存在这里'}}</text>
				</view>
			</scroll-view>
		</view>

		<view v-if="previewVisible" class="preview-overlay">
			<view class="preview-card">
				<view class="preview-header">
					<view class="preview-title-wrap">
						<text class="preview-title">{{previewTitle}}</text>
						<text class="preview-subtitle">{{previewSubtitle}}</text>
					</view>
					<view class="preview-close" @click="closePreview">
						<text class="preview-close-text">×</text>
					</view>
				</view>
				<scroll-view class="preview-scroll" :scroll-y="true">
					<text class="preview-json-text">{{previewJson}}</text>
				</scroll-view>
				<view class="preview-actions">
					<view class="preview-secondary-btn" @click="closePreview">
						<text class="preview-secondary-text">返回列表</text>
					</view>
					<view class="preview-primary-btn" @click="switchPreviewConversation">
						<text class="preview-primary-text">切换到对话</text>
					</view>
				</view>
			</view>
		</view>
	</view>
</template>

<script lang="uts">
	/**
	 * 历史记录页面 - 展示过往对话列表，支持批量管理
	 */
	import { getConversations, getMessages, deleteConversation } from '@/utils/database.uts'
	import {
		ACTIVE_GROUP_CHAT_ID_KEY,
		ACTIVE_GROUP_SESSION_ID_KEY,
		deleteGroupSession,
		displaySessionTitle,
		getGroupChats,
		getGroupMessages,
		getGroupSessions,
	} from '@/utils/group-chat-service.uts'

	export default {
		data() {
			return {
				historyList: [] as UTSJSONObject[],
				groupHistoryList: [] as UTSJSONObject[],
				activeTab: 'agent' as string,
				editMode: false as boolean,
				/** 选中的对话 id 列表 */
				selectedIds: [] as string[],
				previewVisible: false as boolean,
				previewItem: null as UTSJSONObject | null,
				previewTab: 'agent' as string,
				previewTitle: '历史对话' as string,
				previewSubtitle: '' as string,
				previewJson: '[]' as string,
			}
		},
		computed: {
			currentHistoryList(): UTSJSONObject[] {
				return this.activeTab == 'group' ? this.groupHistoryList : this.historyList
			},
			currentHistoryLength(): number {
				return this.activeTab == 'group' ? this.groupHistoryList.length : this.historyList.length
			},
		},
		onLoad() {
			this.loadHistory()
		},
		onShow() {
			this.loadHistory()
		},
		methods: {
			renderMessagePartsMarkdown(msg: UTSJSONObject): string {
				const parts = msg['message'] as UTSJSONObject[] | null
				if (parts == null || parts.length == 0) {
					const contentRaw = msg['content'] as string | null
					return contentRaw != null ? contentRaw : ''
				}
				let text = ''
				for (let i = 0; i < parts.length; i++) {
					const part = parts[i]
					const typeRaw = part['type'] as string | null
					const type = typeRaw != null ? typeRaw : ''
					if (type == 'plain' || type == 'text') {
						const raw = part['text'] as string | null
						if (raw != null && raw != '') { text += raw + '\n\n' }
					} else if (type == 'think' || type == 'thinking') {
						let raw = part['think'] as string | null
						if (raw == null || raw == '') { raw = part['thinking'] as string | null }
						if (raw != null && raw != '') { text += '<details><summary>思考过程</summary>\n\n' + raw + '\n\n</details>\n\n' }
					} else if (type == 'tool_call' || type == 'toolCall') {
						const calls = part['tool_calls'] as UTSJSONObject[] | null
						if (calls != null) {
							for (let j = 0; j < calls.length; j++) {
								text += this.renderToolCallMarkdown(calls[j])
							}
						} else {
							text += this.renderToolCallMarkdown(part)
						}
					} else if (type == 'image') {
						const url = this.readPartPath(part)
						text += '![图片](' + url + ')\n\n'
					} else if (type == 'file') {
						const filename = part['filename'] as string | null
						const path = this.readPartPath(part)
						text += '[文件] ' + (filename != null && filename != '' ? filename : path) + '\n\n'
					} else if (type == 'record' || type == 'voice' || type == 'audio') {
						text += '[语音/音频] ' + this.readPartPath(part) + '\n\n'
					} else if (type == 'location') {
						const raw = part['text'] as string | null
						text += '[位置] ' + (raw != null ? raw : '') + '\n\n'
					}
				}
				return text.trim()
			},

			readPartPath(part: UTSJSONObject): string {
				const url = part['url'] as string | null
				if (url != null && url != '') { return url }
				const path = part['path'] as string | null
				return path != null ? path : ''
			},

			renderToolCallMarkdown(item: UTSJSONObject): string {
				const nameRaw = item['name'] as string | null
				const argsRaw = item['arguments'] as string | null
				const resultRaw = item['result'] as string | null
				let text = '**Tool:** ' + (nameRaw != null ? nameRaw : 'tool') + '\n\n'
				if (argsRaw != null && argsRaw != '') {
					text += '```json\n' + argsRaw + '\n```\n\n'
				}
				if (resultRaw != null && resultRaw != '') {
					text += '```text\n' + resultRaw + '\n```\n\n'
				}
				return text
			},

			loadHistory() {
				try {
					const list = getConversations()
					this.historyList = list
				} catch (_e: any) {
					this.historyList = []
				}
				this.loadGroupHistory()
			},

			loadGroupHistory(): void {
				const result: UTSJSONObject[] = []
				const groups = getGroupChats()
				for (let gi = 0; gi < groups.length; gi++) {
					const group = groups[gi]
					const sessions = getGroupSessions(group.id)
					for (let si = 0; si < sessions.length; si++) {
						const session = sessions[si]
						const messages = getGroupMessages(group.id, session.id)
						const visibleCount = this.countVisibleGroupMessages(messages)
						if (visibleCount <= 0) { continue }
						result.push({
							id: group.id + ':' + session.id,
							type: 'group',
							group_id: group.id,
							session_id: session.id,
							title: group.name + ' / ' + displaySessionTitle(session),
							created_at: session.createdAt,
							updated_at: session.updatedAt,
							message_count: visibleCount,
							preview: this.buildGroupPreview(messages),
							model: '群聊',
						} as UTSJSONObject)
					}
				}
				result.sort((a: UTSJSONObject, b: UTSJSONObject): number => {
					const at = a['updated_at'] as number | null
					const bt = b['updated_at'] as number | null
					const av = at != null ? at : 0
					const bv = bt != null ? bt : 0
					if (av == bv) { return 0 }
					return av > bv ? -1 : 1
				})
				this.groupHistoryList = result
			},

			switchTab(tab: string): void {
				if (this.activeTab == tab) { return }
				this.activeTab = tab
				this.exitEditMode()
			},

			countVisibleGroupMessages(messages: UTSJSONObject[]): number {
				let count = 0
				for (let i = 0; i < messages.length; i++) {
					const visible = messages[i]['visible'] as boolean | null
					if (visible != false) { count++ }
				}
				return count
			},

			resolveGroupPreviewSenderName(senderName: string | null, senderType: string | null, role: string | null): string {
				const name = senderName != null ? senderName.trim() : ''
				if (senderType == 'user' || role == 'user') {
					if (name != '' && name != '用户') { return name }
					const raw = uni.getStorageSync('profile_nickname') as string | null
					const profileName = raw != null ? raw.trim() : ''
					return profileName != '' ? profileName : '用户'
				}
				return name != '' ? name : '成员'
			},

			shouldIncludeDialogMessage(msg: UTSJSONObject): boolean {
				const roleRaw = msg['role'] as string | null
				const role = roleRaw != null ? roleRaw : ''
				if (role != 'user' && role != 'assistant') { return false }
				const visible = msg['visible'] as boolean | null
				if (visible == false) { return false }
				return true
			},

			isDialogPartType(type: string): boolean {
				return type == 'plain' || type == 'text' || type == 'image' || type == 'file' || type == 'location' || type == 'record' || type == 'voice' || type == 'audio'
			},

			copyStringField(source: UTSJSONObject, target: UTSJSONObject, key: string): void {
				const value = source[key] as string | null
				if (value != null && value != '') { target[key] = value }
			},

			copyDialogPart(part: UTSJSONObject): UTSJSONObject | null {
				const typeRaw = part['type'] as string | null
				const type = typeRaw != null ? typeRaw : ''
				if (this.isDialogPartType(type) == false) { return null }
				const clean: UTSJSONObject = { type: type } as UTSJSONObject
				this.copyStringField(part, clean, 'text')
				this.copyStringField(part, clean, 'url')
				this.copyStringField(part, clean, 'path')
				this.copyStringField(part, clean, 'filename')
				this.copyStringField(part, clean, 'caption')
				return clean
			},

			buildDialogParts(parts: UTSJSONObject[]): UTSJSONObject[] {
				const result: UTSJSONObject[] = []
				for (let i = 0; i < parts.length; i++) {
					const clean = this.copyDialogPart(parts[i])
					if (clean != null) { result.push(clean) }
				}
				return result
			},

			buildDialogMessageJson(msg: UTSJSONObject, includeSender: boolean): UTSJSONObject | null {
				if (this.shouldIncludeDialogMessage(msg) == false) { return null }
				const roleRaw = msg['role'] as string | null
				const contentRaw = msg['content'] as string | null
				const timestampRaw = msg['timestamp'] as number | null
				const partsRaw = msg['message'] as UTSJSONObject[] | null
				const content = contentRaw != null ? contentRaw : ''
				let cleanParts: UTSJSONObject[] = []
				if (partsRaw != null && partsRaw.length > 0) {
					cleanParts = this.buildDialogParts(partsRaw)
				}
				if (content == '' && cleanParts.length == 0) { return null }
				const clean: UTSJSONObject = {
					role: roleRaw != null ? roleRaw : '',
					content: content,
					timestamp: timestampRaw != null ? timestampRaw : 0,
				} as UTSJSONObject
				if (includeSender == true) {
					const senderType = msg['senderType'] as string | null
					const senderName = msg['senderName'] as string | null
					const senderAgentId = msg['senderAgentId'] as string | null
					const role = roleRaw != null ? roleRaw : ''
					clean['senderType'] = senderType != null ? senderType : ''
					clean['senderName'] = this.resolveGroupPreviewSenderName(senderName, senderType, role)
					if (senderAgentId != null && senderAgentId != '') { clean['senderAgentId'] = senderAgentId }
				}
				if (cleanParts.length > 0) { clean['message'] = cleanParts }
				return clean
			},

			buildDialogJson(messages: UTSJSONObject[], includeSender: boolean): UTSJSONObject[] {
				const result: UTSJSONObject[] = []
				for (let i = 0; i < messages.length; i++) {
					const clean = this.buildDialogMessageJson(messages[i], includeSender)
					if (clean != null) { result.push(clean) }
				}
				return result
			},

			buildGroupPreview(messages: UTSJSONObject[]): string {
				for (let i = messages.length - 1; i >= 0; i--) {
					const msg = messages[i]
					const visible = msg['visible'] as boolean | null
					if (visible == false) { continue }
					const senderName = msg['senderName'] as string | null
					const senderType = msg['senderType'] as string | null
					const role = msg['role'] as string | null
					const name = this.resolveGroupPreviewSenderName(senderName, senderType, role)
					const content = this.renderMessagePartsMarkdown(msg)
					if (content != '') {
						const text = content.length > 50 ? content.substring(0, 50) + '...' : content
						return name + '：' + text
					}
				}
				return '暂无预览'
			},

			formatTime(ts: any | null): string {
				if (ts == null) {
					return ''
				}
				const d = new Date(ts as number)
				const now = new Date()
				const today = new Date(now.getFullYear(), now.getMonth(), now.getDate())
				const msgDate = new Date(d.getFullYear(), d.getMonth(), d.getDate())
				const diffDays = (today.getTime() - msgDate.getTime()) / (1000 * 60 * 60 * 24)

				const h = (d.getHours() as number) < 10 ? '0' + d.getHours() : '' + d.getHours()
				const m = (d.getMinutes() as number) < 10 ? '0' + d.getMinutes() : '' + d.getMinutes()

				if (diffDays < 1) {
					return h + ':' + m
				} else if (diffDays < 2) {
					return '昨天 ' + h + ':' + m
				} else if (diffDays < 7) {
					const days = diffDays as number
					return days.toFixed(0) + '天前'
				} else {
					return (d.getMonth() + 1) + '/' + d.getDate()
				}
			},

			// ===== 编辑模式 =====

			handleBack() {
				if (this.previewVisible == true) {
					this.closePreview()
					return
				}
				if (this.editMode) {
					this.exitEditMode()
					return
				}
				uni.navigateBack()
			},

			enterEditMode() {
				this.editMode = true
				this.selectedIds = []
			},

			exitEditMode() {
				this.editMode = false
				this.selectedIds = []
			},

			isSelected(id: string): boolean {
				for (let i = 0; i < this.selectedIds.length; i++) {
					if (this.selectedIds[i] == id) {
						return true
					}
				}
				return false
			},

			toggleItem(id: string) {
				const idx = this.indexOfSelected(id)
				if (idx >= 0) {
					const newList: string[] = []
					for (let i = 0; i < this.selectedIds.length; i++) {
						if (i != idx) {
							newList.push(this.selectedIds[i])
						}
					}
					this.selectedIds = newList
				} else {
					this.selectedIds.push(id)
				}
			},

			indexOfSelected(id: string): number {
				for (let i = 0; i < this.selectedIds.length; i++) {
					if (this.selectedIds[i] == id) {
						return i
					}
				}
				return -1
			},

			selectAll() {
				const list = this.currentHistoryList
				if (this.selectedIds.length == list.length) {
					// 已全选 → 取消全选
					this.selectedIds = []
				} else {
					const all: string[] = []
					for (let i = 0; i < list.length; i++) {
						all.push(list[i]['id'] as string)
					}
					this.selectedIds = all
				}
			},

			batchDelete() {
				if (this.selectedIds.length == 0) {
					uni.showToast({ position: 'bottom', title: '请选择要删除的对话', icon: 'none' })
					return
				}
				uni.showModal({
					title: '批量删除',
					content: '确定要删除选中的 ' + this.selectedIds.length +  ' 条对话吗？',
					success: (res) => {
						if (res.confirm == true) {
							for (let i = 0; i < this.selectedIds.length; i++) {
								if (this.activeTab == 'group') {
									this.deleteGroupHistoryById(this.selectedIds[i])
								} else {
									deleteConversation(this.selectedIds[i])
								}
							}
							this.selectedIds = []
							this.editMode = false
							this.loadHistory()
							uni.showToast({ position: 'bottom',
								title: '已删除',
								icon: 'success'
							})
						}
					}
				})
			},

			// ===== 卡片交互 =====

			onCardClick(item: UTSJSONObject) {
				if (this.editMode) {
					this.toggleItem(item['id'] as string)
				} else {
					this.showHistoryPreview(item)
				}
			},

			onCardLongpress(item: UTSJSONObject) {
				if (this.editMode) {
					return
				}
				if (this.activeTab == 'group') {
					uni.showActionSheet({
						itemList: ['管理'],
						success: (res) => {
							if (res.tapIndex == 0) {
								this.enterEditMode()
								this.toggleItem(item['id'] as string)
							}
						}
					})
					return
				}
				uni.showActionSheet({
					itemList: ['导出 Markdown', '管理'],
					success: (res) => {
						const idx = res.tapIndex
						if (idx == 0) {
							this.exportConversation(item)
						} else if (idx == 1) {
							this.enterEditMode()
							this.toggleItem(item['id'] as string)
						}
					}
				})
			},

			showHistoryPreview(item: UTSJSONObject): void {
				const titleRaw = item['title'] as string | null
				const title = titleRaw != null && titleRaw != '' ? titleRaw : '历史对话'
				const tab = this.activeTab
				let messages: UTSJSONObject[] = []
				if (tab == 'group') {
					const groupId = item['group_id'] as string | null
					const sessionId = item['session_id'] as string | null
					if (groupId != null && groupId != '' && sessionId != null && sessionId != '') {
						messages = getGroupMessages(groupId, sessionId)
					}
				} else {
					const id = item['id'] as string | null
					if (id != null && id != '') { messages = getMessages(id) }
				}
				const clean = this.buildDialogJson(messages, tab == 'group')
				this.previewItem = item
				this.previewTab = tab
				this.previewTitle = title
				this.previewSubtitle = '仅展示对话 JSON，已过滤思考过程、工具调用和工具结果 · ' + clean.length + ' 条'
				this.previewJson = JSON.stringify(clean, null, 2)
				this.previewVisible = true
			},

			closePreview(): void {
				this.previewVisible = false
			},

			switchPreviewConversation(): void {
				const item = this.previewItem
				if (item == null) { return }
				this.openConversationWithTab(item, this.previewTab)
			},

			openConversation(item: UTSJSONObject) {
				this.openConversationWithTab(item, this.activeTab)
			},

			openConversationWithTab(item: UTSJSONObject, tab: string): void {
				if (tab == 'group') {
					this.openGroupConversation(item)
					return
				}
				uni.setStorageSync('active_conversation_id', item['id'] as string)
				uni.redirectTo({
					url: '/pages/chat/chat'
				})
			},

			openGroupConversation(item: UTSJSONObject): void {
				const groupId = item['group_id'] as string | null
				const sessionId = item['session_id'] as string | null
				if (groupId == null || groupId == '' || sessionId == null || sessionId == '') {
					uni.showToast({ position: 'bottom', title: '群聊会话不存在', icon: 'none' })
					return
				}
				uni.setStorageSync(ACTIVE_GROUP_CHAT_ID_KEY, groupId)
				uni.setStorageSync(ACTIVE_GROUP_SESSION_ID_KEY, sessionId)
				uni.redirectTo({ url: '/pages/group-chat/group-chat' })
			},

			deleteGroupHistoryById(id: string): void {
				for (let i = 0; i < this.groupHistoryList.length; i++) {
					const item = this.groupHistoryList[i]
					const itemId = item['id'] as string | null
					if (itemId == id) {
						const groupId = item['group_id'] as string | null
						const sessionId = item['session_id'] as string | null
						if (groupId != null && groupId != '' && sessionId != null && sessionId != '') {
							deleteGroupSession(groupId, sessionId, false)
						}
						return
					}
				}
			},

			/** 导出对话为 Markdown，并复制到剪贴板 */
			exportConversation(item: UTSJSONObject) {
				const id = item['id'] as string | null
				if (id == null || id == '') {
					uni.showToast({ position: 'bottom', title: '对话不存在', icon: 'none' })
					return
				}
				const titleRaw = item['title'] as string | null
				const modelRaw = item['model'] as string | null
				const title = titleRaw != null && titleRaw != '' ? titleRaw : '未命名对话'
				const model = modelRaw != null ? modelRaw : ''
				const msgs = getMessages(id)
				let markdown = '# ' + title + '\n\n'
				if (model != '') {
					markdown += '> Model: ' + model + '\n\n'
				}
				for (let i = 0; i < msgs.length; i++) {
					const msg = msgs[i]
					const roleRaw = msg['role'] as string | null
					const role = roleRaw != null ? roleRaw : ''
					const rendered = this.renderMessagePartsMarkdown(msg)
					if (role == 'user') {
						markdown += '## User\n\n' + rendered + '\n\n'
					} else if (role == 'assistant') {
						markdown += '## Assistant\n\n' + rendered + '\n\n'
					} else if (role == 'toolResult') {
						const toolNameRaw = msg['toolName'] as string | null
						const toolName = toolNameRaw != null ? toolNameRaw : 'tool'
						markdown += '## Tool: ' + toolName + '\n\n```text\n' + rendered + '\n```\n\n'
					}
				}
				uni.setClipboardData({
					data: markdown,
					success: () => {
						uni.showToast({ position: 'bottom', title: '已复制 Markdown', icon: 'success' })
					},
					fail: () => {
						uni.showToast({ position: 'bottom', title: '导出失败', icon: 'none' })
					}
				})
			},

			goBack() {
				this.handleBack()
			},

			confirmClear() {
				uni.showModal({
					title: '清空历史记录',
					content: this.activeTab == 'group' ? '确定要清空所有群聊会话历史吗？此操作无法撤销。' : '确定要清空所有对话历史吗？此操作无法撤销。',
					success: (res) => {
						if (res.confirm == true) {
							const list = this.currentHistoryList
							for (let i = 0; i < list.length; i++) {
								const id = list[i]['id'] as string
								if (this.activeTab == 'group') {
									this.deleteGroupHistoryById(id)
								} else {
									deleteConversation(id)
								}
							}
							this.loadHistory()
							uni.showToast({ position: 'bottom',
								title: '已清空',
								icon: 'success'
							})
						}
					}
				})
			}
		}
	}
</script>

