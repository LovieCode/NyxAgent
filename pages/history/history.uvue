	}

	.history-tab {
		flex: 1;
		align-items: center;
		justify-content: center;
		padding-top: 9px;
		padding-bottom: 9px;
		border-radius: 500px;
	}

	.history-tab-active {
		background-color: var(--rice-primary-color);
	}

	.history-tab-text {
		font-size: 14px;
		color: var(--rice-text-color-3);
