	}

	.checkbox-checked {
		background-color: var(--rice-primary-color);
		border-color: var(--rice-primary-color);
	}

	.checkmark {
		font-size: 28rpx;
		color: #FFFFFF;
		font-weight: bold;
	}

	.card-body {
		flex: 1;
	}

	.card-top {
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 16rpx;
	}

	.card-title {
		font-size: 32rpx;
		font-weight: bold;
		color: var(--rice-text-color);
		flex: 1;
	}

	.card-time {
		font-size: 24rpx;
		color: var(--rice-text-color-3);
		margin-left: 16rpx;
	}

	.card-preview {
		font-size: 28rpx;
		color: var(--rice-text-color-2);
		lines: 1;
		text-overflow: ellipsis;
		margin-bottom: 20rpx;
	}

	.card-meta {
		flex-direction: row;
		align-items: center;
	}

	.meta-msgs {
		font-size: 24rpx;
		color: var(--rice-text-color-3);
		margin-right: 24rpx;
	}

	.meta-model {
		font-size: 22rpx;
		color: var(--rice-primary-color);
		background-color: var(--rice-primary-color-1);
		padding-left: 12rpx;
		padding-right: 12rpx;
		padding-top: 4rpx;
		padding-bottom: 4rpx;
		border-radius: 12rpx;
	}

	/* 空状态 */
	.empty-state {
		flex: 1;
		justify-content: center;
		align-items: center;
		padding-top: 240rpx;
	}

	.empty-text {
		font-size: 36rpx;
		color: var(--rice-text-color-3);
		margin-top: 32rpx;
		font-weight: bold;
	}

	.empty-hint {
		font-size: 26rpx;
		color: var(--rice-text-color-3);
		margin-top: 12rpx;
		text-align: center;
	}
</style>
