<template>
	<view class="page-shell rice-theme-light">
		<NavBar title="历史记录" showBack @back="handleBack">
			<template #right>
				<view v-if="!editMode" class="nav-right">
					<text class="nav-btn" v-if="historyList.length > 0" @click="enterEditMode">管理</text>
					<text class="nav-btn" v-if="historyList.length > 0" @click="confirmClear">清空</text>
				</view>
				<view v-else class="nav-right">
					<text class="nav-btn" @click="selectAll">全选</text>
					<text class="nav-btn nav-btn-danger" @click="batchDelete">删除({{selectedIds.length}})</text>
					<text class="nav-btn" @click="exitEditMode">取消</text>
				</view>
			</template>
		</NavBar>
		<view class="history-page">

			<!-- 历史列表 -->
			<scroll-view class="list-scroll" :scroll-y="true">
				<view v-if="historyList.length > 0" class="list-content">
					<view
						v-for="(item, index) in historyList"
						:key="index"
						class="history-card"
						:class="isSelected(item['id'] as string) ? 'card-selected' : ''"
						@click="onCardClick(item)"
						@longpress="onCardLongpress(item)"
					>
						<view class="card-row">
							<!-- 编辑模式下的复选框 -->
							<view v-if="editMode" class="check-col" @click.stop="toggleItem(item['id'] as string)">
								<view
									class="checkbox"
									:class="isSelected(item['id'] as string) ? 'checkbox-checked' : ''"
								>
									<text v-if="isSelected(item['id'] as string)" class="checkmark">✓</text>
								</view>
							</view>
							<view class="card-body">
								<view class="card-top">
									<text class="card-title">{{ item['title'] }}</text>
									<text class="card-time">{{ formatTime(item['created_at']) }}</text>
								</view>
								<text class="card-preview">{{ item['preview'] }}</text>
								<view class="card-meta">
									<text class="meta-msgs">{{ item['message_count'] }} 条消息</text>
									<text class="meta-model">{{ item['model'] }}</text>
								</view>
							</view>
						</view>
					</view>
				</view>

				<!-- 空状态 -->
				<view v-else class="empty-state">
					<oui-icon-unix name="time-circle" size="96rpx" color="#D1D5DB" />
					<text class="empty-text">暂无历史记录</text>
					<text class="empty-hint">开始对话后，记录将自动保存在这里</text>
				</view>
			</scroll-view>
		</view>
	</view>
</template>

<script lang="uts">
	/**
	 * 历史记录页面 - 展示过往对话列表，支持批量管理
	 */
	import { getConversations, getMessages, deleteConversation } from '@/utils/database.uts'

	export default {
		data() {
			return {
				historyList: [] as UTSJSONObject[],
				editMode: false as boolean,
				/** 选中的对话 id 列表 */
				selectedIds: [] as string[],
			}
		},
		onLoad() {
			this.loadHistory()
		},
		onShow() {
			this.loadHistory()
		},
		methods: {
			loadHistory() {
				try {
					const list = getConversations()
					this.historyList = list
				} catch (_e: any) {
					this.historyList = []
				}
			},

			formatTime(ts: any | null): string {
				if (ts == null) {
					return ''
				}
				const d = new Date(ts as number)
				const now = new Date()
				const today = new Date(now.getFullYear(), now.getMonth(), now.getDate())
				const msgDate = new Date(d.getFullYear(), d.getMonth(), d.getDate())
				const diffDays = (today.getTime() - msgDate.getTime()) / (1000 * 60 * 60 * 24)

				const h = (d.getHours() as number) < 10 ? '0' + d.getHours() : '' + d.getHours()
				const m = (d.getMinutes() as number) < 10 ? '0' + d.getMinutes() : '' + d.getMinutes()

				if (diffDays < 1) {
					return h + ':' + m
				} else if (diffDays < 2) {
					return '昨天 ' + h + ':' + m
				} else if (diffDays < 7) {
					const days = diffDays as number
					return days.toFixed(0) + '天前'
				} else {
					return (d.getMonth() + 1) + '/' + d.getDate()
				}
			},

			// ===== 编辑模式 =====

			handleBack() {
				if (this.editMode) {
					this.exitEditMode()
					return
				}
				uni.navigateBack()
			},

			enterEditMode() {
				this.editMode = true
				this.selectedIds = []
			},

			exitEditMode() {
				this.editMode = false
				this.selectedIds = []
			},

			isSelected(id: string): boolean {
				for (let i = 0; i < this.selectedIds.length; i++) {
					if (this.selectedIds[i] == id) {
						return true
					}
				}
				return false
			},

			toggleItem(id: string) {
				const idx = this.indexOfSelected(id)
				if (idx >= 0) {
					const newList: string[] = []
					for (let i = 0; i < this.selectedIds.length; i++) {
						if (i != idx) {
							newList.push(this.selectedIds[i])
						}
					}
					this.selectedIds = newList
				} else {
					this.selectedIds.push(id)
				}
			},

			indexOfSelected(id: string): number {
				for (let i = 0; i < this.selectedIds.length; i++) {
					if (this.selectedIds[i] == id) {
						return i
					}
				}
				return -1
			},

			selectAll() {
				if (this.selectedIds.length == this.historyList.length) {
					// 已全选 → 取消全选
					this.selectedIds = []
				} else {
					const all: string[] = []
					for (let i = 0; i < this.historyList.length; i++) {
						all.push(this.historyList[i]['id'] as string)
					}
					this.selectedIds = all
				}
			},

			batchDelete() {
				if (this.selectedIds.length == 0) {
					uni.showToast({ position: 'bottom', title: '请选择要删除的对话', icon: 'none' })
					return
				}
				uni.showModal({
					title: '批量删除',
					content: '确定要删除选中的 ' + this.selectedIds.length +  ' 条对话吗？',
					success: (res) => {
						if (res.confirm == true) {
							for (let i = 0; i < this.selectedIds.length; i++) {
								deleteConversation(this.selectedIds[i])
							}
							this.selectedIds = []
							this.editMode = false
							this.loadHistory()
							uni.showToast({ position: 'bottom',
								title: '已删除',
								icon: 'success'
							})
						}
					}
				})
			},

			// ===== 卡片交互 =====

			onCardClick(item: UTSJSONObject) {
				if (this.editMode) {
					this.toggleItem(item['id'] as string)
				} else {
					this.openConversation(item)
				}
			},

			onCardLongpress(item: UTSJSONObject) {
				if (this.editMode) {
					return
				}
				uni.showActionSheet({
					itemList: ['导出 Markdown', '管理'],
					success: (res) => {
						const idx = res.tapIndex
						if (idx == 0) {
							this.exportConversation(item)
						} else if (idx == 1) {
							this.enterEditMode()
							this.toggleItem(item['id'] as string)
						}
					}
				})
			},

			openConversation(item: UTSJSONObject) {
				uni.setStorageSync('active_conversation_id', item['id'] as string)
				uni.redirectTo({
					url: '/pages/chat/chat'
				})
			},

			/** 导出对话为 Markdown，并复制到剪贴板 */
			exportConversation(item: UTSJSONObject) {
				const id = item['id'] as string | null
				if (id == null || id == '') {
					uni.showToast({ position: 'bottom', title: '对话不存在', icon: 'none' })
					return
				}
				const titleRaw = item['title'] as string | null
				const modelRaw = item['model'] as string | null
				const title = titleRaw != null && titleRaw != '' ? titleRaw : '未命名对话'
				const model = modelRaw != null ? modelRaw : ''
				const msgs = getMessages(id)
				let markdown = '# ' + title + '\n\n'
				if (model != '') {
					markdown += '> Model: ' + model + '\n\n'
				}
				for (let i = 0; i < msgs.length; i++) {
					const msg = msgs[i]
					const roleRaw = msg['role'] as string | null
					const contentRaw = msg['content'] as string | null
					const role = roleRaw != null ? roleRaw : ''
					const content = contentRaw != null ? contentRaw : ''
					if (role == 'user') {
						markdown += '## User\n\n' + content + '\n\n'
					} else if (role == 'assistant') {
						markdown += '## Assistant\n\n' + content + '\n\n'
					} else if (role == 'toolResult') {
						const toolNameRaw = msg['toolName'] as string | null
						const toolName = toolNameRaw != null ? toolNameRaw : 'tool'
						markdown += '## Tool: ' + toolName + '\n\n```text\n' + content + '\n```\n\n'
					}
				}
				uni.setClipboardData({
					data: markdown,
					success: () => {
						uni.showToast({ position: 'bottom', title: '已复制 Markdown', icon: 'success' })
					},
					fail: () => {
						uni.showToast({ position: 'bottom', title: '导出失败', icon: 'none' })
					}
				})
			},

			goBack() {
				if (this.editMode) {
					this.exitEditMode()
				} else {
					uni.navigateBack()
				}
			},

			confirmClear() {
				uni.showModal({
					title: '清空历史记录',
					content: '确定要清空所有对话历史吗？此操作无法撤销。',
					success: (res) => {
						if (res.confirm == true) {
							for (let i = 0; i < this.historyList.length; i++) {
								deleteConversation(this.historyList[i]['id'] as string)
							}
							this.historyList = []
							uni.showToast({ position: 'bottom',
								title: '已清空',
								icon: 'success'
							})
						}
					}
				})
			}
		}
	}
</script>

<style>
	.history-page {
		flex: 1;
		flex-direction: column;
		background-color: var(--rice-background);
	}

	.nav-right {
		flex-direction: row;
		align-items: center;
	}

	.nav-btn {
		font-size: 28rpx;
		color: var(--rice-primary-color);
		margin-left: 16rpx;
		font-weight: bold;
	}

	.nav-btn-danger {
		color: #EF4444;
	}

	/* 列表滚动区 */
	.list-scroll {
		flex: 1;
		padding: 32rpx;
	}

	.list-content {
		flex-direction: column;
	}

	/* 历史记录卡片 */
	.history-card {
		background-color: var(--rice-background-2);
		border-radius: 28rpx;
		padding: 32rpx;
		margin-bottom: 24rpx;
		border-width: 2rpx;
		border-style: solid;
		border-color: var(--rice-border-color);
	}

	.card-selected {
		border-color: var(--rice-primary-color);
		background-color: var(--rice-primary-color-1);
	}

	.card-row {
		flex-direction: row;
		align-items: flex-start;
	}

	/* 复选框列 */
	.check-col {
		width: 80rpx;
		height: 100%;
		justify-content: center;
		align-items: center;
		margin-right: 16rpx;
		padding-top: 4rpx;
	}

	.checkbox {
		width: 44rpx;
		height: 44rpx;
		border-radius: 22rpx;
		border-width: 4rpx;
		border-style: solid;
		border-color: #D1D5DB;
		justify-content: center;
		align-items: center;
	}

	.checkbox-checked {
		background-color: var(--rice-primary-color);
		border-color: var(--rice-primary-color);
	}

	.checkmark {
		font-size: 28rpx;
		color: #FFFFFF;
		font-weight: bold;
	}

	.card-body {
		flex: 1;
	}

	.card-top {
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 16rpx;
	}

	.card-title {
		font-size: 32rpx;
		font-weight: bold;
		color: var(--rice-text-color);
		flex: 1;
	}

	.card-time {
		font-size: 24rpx;
		color: var(--rice-text-color-3);
		margin-left: 16rpx;
	}

	.card-preview {
		font-size: 28rpx;
		color: var(--rice-text-color-2);
		lines: 1;
		text-overflow: ellipsis;
		margin-bottom: 20rpx;
	}

	.card-meta {
		flex-direction: row;
		align-items: center;
	}

	.meta-msgs {
		font-size: 24rpx;
		color: var(--rice-text-color-3);
		margin-right: 24rpx;
	}

	.meta-model {
		font-size: 22rpx;
		color: var(--rice-primary-color);
		background-color: var(--rice-primary-color-1);
		padding-left: 12rpx;
		padding-right: 12rpx;
		padding-top: 4rpx;
		padding-bottom: 4rpx;
		border-radius: 12rpx;
	}

	/* 空状态 */
	.empty-state {
		flex: 1;
		justify-content: center;
		align-items: center;
		padding-top: 240rpx;
	}

	.empty-text {
		font-size: 36rpx;
		color: var(--rice-text-color-3);
		margin-top: 32rpx;
		font-weight: bold;
	}

	.empty-hint {
		font-size: 26rpx;
		color: var(--rice-text-color-3);
		margin-top: 12rpx;
		text-align: center;
	}
</style>
