		align-items: center;
	}

	.nav-btn {
		font-size: 28rpx;
		color: var(--rice-primary-color);
		margin-left: 16rpx;
		font-weight: bold;
	}

	.nav-btn-danger {
		color: #EF4444;
	}

	.preview-overlay {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background-color: rgba(17, 24, 39, 0.38);
		z-index: 1000;
		justify-content: flex-end;
	}

	.preview-card {
		width: 100%;
		flex: 1;
		background-color: #FFFFFF;
		padding: 28rpx 32rpx 36rpx;
		flex-direction: column;
	}

	.preview-header {
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 22rpx;
		flex-shrink: 0;
	}

	.preview-title-wrap {
		flex: 1;
		flex-direction: column;
		margin-right: 20rpx;
	}

	.preview-title {
		font-size: 34rpx;
		font-weight: bold;
		color: var(--rice-text-color);
	}

	.preview-subtitle {
		font-size: 24rpx;
		color: var(--rice-text-color-3);
		margin-top: 8rpx;
	}

	.preview-close {
		width: 64rpx;
		height: 64rpx;
		border-radius: 32rpx;
		background-color: var(--rice-background-2);
		align-items: center;
		justify-content: center;
	}

	.preview-close-text {
		font-size: 42rpx;
		line-height: 50rpx;
		color: var(--rice-text-color-2);
	}

	.preview-scroll {
		flex: 1;
		background-color: #111827;
		border-radius: 24rpx;
		padding: 24rpx;
	}

	.preview-json-text {
		font-size: 24rpx;
		line-height: 36rpx;
		color: #E5E7EB;
	}

	.preview-actions {
		flex-direction: row;
		align-items: center;
		margin-top: 24rpx;
		flex-shrink: 0;
	}

	.preview-secondary-btn {
		flex: 1;
		height: 88rpx;
		border-radius: 999rpx;
		align-items: center;
		justify-content: center;
		background-color: var(--rice-background-2);
		margin-right: 16rpx;
	}

	.preview-secondary-btn-full {
		margin-right: 0;
	}

	.preview-primary-btn {
		flex: 1;
		height: 88rpx;
		border-radius: 999rpx;
		align-items: center;
		justify-content: center;
		background-color: var(--rice-primary-color);
	}

	.preview-secondary-text {
		font-size: 28rpx;
		font-weight: bold;
		color: var(--rice-text-color-2);
	}

	.preview-primary-text {
		font-size: 28rpx;
		font-weight: bold;
		color: #FFFFFF;
	}

	.history-tabs {
		flex-direction: row;
		margin-left: 32rpx;
		margin-right: 32rpx;
		margin-top: 24rpx;
		padding: 8rpx;
		border-radius: 999rpx;
		background-color: var(--rice-background-2);
	}

	.history-tab {
		flex: 1;
		align-items: center;
		justify-content: center;
		padding-top: 18rpx;
		padding-bottom: 18rpx;
		border-radius: 999rpx;
	}

	.history-tab-active {
		background-color: var(--rice-primary-color);
	}

	.history-tab-text {
		font-size: 28rpx;
		color: var(--rice-text-color-3);
		font-weight: bold;
	}

	.history-tab-text-active {
		color: #FFFFFF;
	}

	/* 列表滚动区 */
	.list-scroll {
		flex: 1;
		padding: 32rpx;
	}

	.list-content {
		flex-direction: column;
	}

	/* 历史记录卡片 */
	.history-card {
		background-color: var(--rice-background-2);
		border-radius: 28rpx;
		padding: 32rpx;
		margin-bottom: 24rpx;
		border-width: 2rpx;
		border-style: solid;
		border-color: var(--rice-border-color);
	}

	.card-selected {
		border-color: var(--rice-primary-color);
		background-color: var(--rice-primary-color-1);
	}

	.card-row {
		flex-direction: row;
		align-items: flex-start;
	}

	/* 复选框列 */
	.check-col {
		width: 80rpx;
		height: 100%;
		justify-content: center;
		align-items: center;
		margin-right: 16rpx;
