<template>
	<FullscreenTextEditor
		:title="pageTitle"
		:value="noteContent"
		placeholder="笔记内容，支持 - [ ] 待办 / - [x] 完成"
		:dirty="dirty"
		@change="onContentChange"
		@save="saveAndBack"
		@back="onBack"
	>
		<template #header>
			<view class="note-title-field">
				<input class="title-input" v-model="noteTitle" placeholder="未命名笔记" placeholder-style="color:#D1D5DB;font-size:17px;" @input="markDirty" />
			</view>
		</template>
	</FullscreenTextEditor>
</template>

<script lang="uts">
	import { getAgents } from '@/utils/agent.uts'
	import { deleteRuntimeState, getRuntimeState, setRuntimeState } from '@/utils/database.uts'

	const USER_AGENT_ENTRY: UTSJSONObject = {
		id: '__user__',
		name: '用户',
	} as UTSJSONObject

	export default {
		data() {
			return {
				noteId: '' as string,
				noteTitle: '' as string,
				noteContent: '' as string,
				initialTitle: '' as string,
				initialContent: '' as string,
				initialAgentId: '' as string,
				agents: [] as UTSJSONObject[],
				selectedAgentIndex: 0 as number,
				dirty: false as boolean,
			}
		},
		computed: {
			pageTitle(): string {
				return this.noteId == '' ? '新建笔记' : '编辑笔记'
			}
		},
		onLoad() {
			this.loadAgents()
			this.loadEditorPayload()
		},
		methods: {
			loadAgents() {
				const list = getAgents()
				const result = [USER_AGENT_ENTRY] as UTSJSONObject[]
				for (let i = 0; i < list.length; i++) {
					result.push(list[i])
				}
				this.agents = result
			},

			loadEditorPayload() {
				const rawId = getRuntimeState('note_editor_id')
				const rawTitle = getRuntimeState('note_editor_title')
				const rawContent = getRuntimeState('note_editor_content')
				const rawAgentId = getRuntimeState('note_editor_agent_id')
				this.noteId = rawId
				this.noteTitle = rawTitle
				this.noteContent = rawContent
				this.initialTitle = this.noteTitle
				this.initialContent = this.noteContent
				let agentId = '__user__'
				if (rawAgentId != '') {
					agentId = rawAgentId
				}
				this.initialAgentId = agentId
				this.selectedAgentIndex = this.findAgentIndex(this.initialAgentId)
				this.dirty = false
			},

			findAgentIndex(agentId: string): number {
				for (let i = 0; i < this.agents.length; i++) {
					if ((this.agents[i]['id'] as string) == agentId) {
						return i
					}
				}
				return 0
			},

			getSelectedAgentId(): string {
				if (this.selectedAgentIndex >= 0 && this.selectedAgentIndex < this.agents.length) {
					return this.agents[this.selectedAgentIndex]['id'] as string
				}
				return '__user__'
			},

			getSelectedAgentName(): string {
				if (this.selectedAgentIndex >= 0 && this.selectedAgentIndex < this.agents.length) {
					return this.agents[this.selectedAgentIndex]['name'] as string
				}
				return '用户'
			},

			onContentChange(value: string) {
				this.noteContent = value
				this.updateDirty()
			},

			markDirty() {
				this.updateDirty()
			},

			updateDirty() {
				this.dirty = this.noteTitle != this.initialTitle || this.noteContent != this.initialContent
			},

			onBack() {
				if (this.dirty == false) {
					uni.navigateBack()
					return
				}
				uni.showModal({
					title: '放弃编辑？',
					content: '笔记尚未保存',
					cancelText: '继续编辑',
					confirmText: '放弃',
					confirmColor: '#EF4444',
					success: (res) => {
						if (res.confirm == true) {
							uni.navigateBack()
						}
					}
				})
			},

			saveAndBack(value: string) {
				this.noteContent = value
				let title = this.noteTitle.trim()
				if (title == '') {
					title = '无标题'
				}
				if (this.noteContent.trim() == '') {
					uni.showToast({ position: 'bottom', title: '请输入内容', icon: 'none' })
					return
				}
				const payload: UTSJSONObject = {
					id: this.noteId,
					title: title,
					content: this.noteContent,
					agentId: this.getSelectedAgentId(),
					agentName: this.getSelectedAgentName(),
				} as UTSJSONObject
				setRuntimeState('note_editor_result', JSON.stringify(payload))
				this.clearEditorPayload()
				this.dirty = false
				uni.navigateBack()
			},

			clearEditorPayload() {
				deleteRuntimeState('note_editor_id')
				deleteRuntimeState('note_editor_title')
				deleteRuntimeState('note_editor_content')
				deleteRuntimeState('note_editor_agent_id')
			},
		}
	}
</script>

<style>
	.note-title-field {
		width: 100%;
		padding: 1px 0 9px 0;
		margin-bottom: 9px;
		border-bottom-width: 1px;
		border-bottom-style: solid;
		border-bottom-color: #F3F4F6;
	}

	.title-input {
		width: 100%;
		align-self: stretch;
		font-size: 19px;
		font-weight: bold;
		color: #111827;
		padding: 0;
		background-color: transparent;
	}

</style>
