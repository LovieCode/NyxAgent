<template>
	<view class="page-shell rice-theme-light">
		<NavBar title="群聊设置" showBack @back="goBack" />
		<scroll-view class="settings-scroll" :scroll-y="true">

			<view class="card">
				<text class="card-title">群名</text>
				<input class="text-input" v-model="groupName" placeholder="输入群聊名称" placeholder-style="color:var(--rice-text-color-3)" />
			</view>

			<view class="card">
				<text class="card-title">成员</text>
				<text class="card-desc">直接复用私聊联系人；踢出只影响之后发言，历史保留。</text>
				<view v-for="(agent, index) in agentList" :key="agent['id']" class="member-row">
					<view class="member-avatar" :class="'avatar-' + ((index % 5) + 1)">
						<image v-if="getAgentAvatar(agent) != ''" :src="getAgentAvatar(agent)" class="member-avatar-img" mode="aspectFill" />
						<oui-icon-unix v-else :name="agent['icon']" size="19px" color="#FFFFFF" />
					</view>
					<view class="member-info">
						<text class="member-name">{{agent['name']}}</text>
						<text class="member-desc">{{agent['desc']}}</text>
					</view>
					<view class="member-action" :class="isMember(agent) ? 'member-action-on' : ''" @click="toggleMember(agent)">
						<text class="member-action-text" :class="isMember(agent) ? 'member-action-text-on' : ''">{{isMember(agent) ? '踢出' : '添加'}}</text>
					</view>
				</view>
			</view>

			<view class="card">
				<view class="prompt-header">
					<view class="prompt-header-left">
						<text class="card-title" style="margin-bottom:0">眠汐全局调度提示词</text>
						<text class="card-desc" style="margin-top:3px;margin-bottom:0">对所有群聊生效，决定谁发言、顺序和续轮逻辑。</text>
					</view>
					<text class="reset-btn" @click="resetSchedulerPrompt">恢复默认</text>
				</view>
				<textarea class="prompt-input" v-model="schedulerPrompt" placeholder="眠汐全局调度提示词" placeholder-style="color:var(--rice-text-color-3)" />
			</view>

			<view class="card">
				<view class="prompt-header">
					<view class="prompt-header-left">
						<text class="card-title" style="margin-bottom:0">共享提示词</text>
						<text class="card-desc" style="margin-top:3px;margin-bottom:0">注入每个成员的上下文，规定公开发言的风格和约束。</text>
					</view>
					<text class="reset-btn" @click="resetSharedPrompt">恢复默认</text>
				</view>
				<textarea class="prompt-input" v-model="sharedPrompt" placeholder="所有成员公开发言共同遵守的提示词" placeholder-style="color:var(--rice-text-color-3)" />
			</view>

			<view class="card save-card">
				<rice-button type="primary" text="保存" size="large" shape="round" @click="saveSettings" style="flex:1" />
			</view>

		</scroll-view>
	</view>
</template>

<script lang="uts">
	import { getAgents } from '@/utils/agent.uts'
	import {
		type GroupChat,
		GLOBAL_SCHEDULER_AGENT_ID,
		addGroupMember,
		buildDefaultSchedulerPrompt,
		buildDefaultSharedPrompt,
		getActiveGroupMembers,
		getActiveGroupChatId,
		getGlobalSchedulerPrompt,
		getGroupChatById,
		isAgentInGroup,
		removeGroupMember,
		saveGroupChat,
		saveGlobalSchedulerPrompt,
	} from '@/utils/group-chat-service.uts'

	export default {
		data() {
			return {
				group: null as GroupChat | null,
				agentList: [] as UTSJSONObject[],
				groupName: '' as string,
				schedulerPrompt: '' as string,
				sharedPrompt: '' as string,
				savedGroupName: '' as string,
				savedSchedulerPrompt: '' as string,
				savedSharedPrompt: '' as string,
				isConfirmingLeave: false as boolean,
				refreshToken: 0 as number,
			}
		},
		onLoad() { this.loadData() },
		onShow() { this.loadData() },
		onBackPress(): boolean {
			if (this.hasUnsavedChanges() == false) {
				return false
			}
			this.confirmLeave()
			return true
		},
		methods: {
			loadData(): void {
				this.agentList = getAgents()
				const groupId = getActiveGroupChatId()
				if (groupId == '') { return }
				const group = getGroupChatById(groupId)
				if (group == null) { return }
				this.group = group
				this.groupName = group.name
				this.schedulerPrompt = getGlobalSchedulerPrompt()
				this.sharedPrompt = group.sharedPrompt != '' ? group.sharedPrompt : buildDefaultSharedPrompt()
				this.captureSavedState()
			},
			captureSavedState(): void {
				this.savedGroupName = this.groupName.trim()
				this.savedSchedulerPrompt = this.schedulerPrompt.trim()
				this.savedSharedPrompt = this.sharedPrompt.trim()
			},
			hasUnsavedChanges(): boolean {
				if (this.groupName.trim() != this.savedGroupName) { return true }
				if (this.schedulerPrompt.trim() != this.savedSchedulerPrompt) { return true }
				if (this.sharedPrompt.trim() != this.savedSharedPrompt) { return true }
				return false
			},
			goBack(): void {
				if (this.hasUnsavedChanges() == false) {
					uni.navigateBack()
					return
				}
				this.confirmLeave()
			},
			confirmLeave(): void {
				if (this.isConfirmingLeave == true) { return }
				this.isConfirmingLeave = true
				uni.showModal({
					title: '有未保存修改',
					content: '要保存后退出吗？',
					cancelText: '不保存',
					confirmText: '保存',
					success: (res) => {
						this.isConfirmingLeave = false
						if (res.confirm == true) {
							if (this.saveSettings() == true) {
								uni.navigateBack()
							}
							return
						}
						uni.navigateBack()
					},
					fail: () => {
						this.isConfirmingLeave = false
					}
				})
			},
			getAgentAvatar(agent: UTSJSONObject): string {
				const avatar = agent['avatar'] as string | null
				return avatar != null ? avatar : ''
			},
			isMember(agent: UTSJSONObject): boolean {
				const group = this.group
				if (group == null) { return false }
				const id = agent['id'] as string | null
				if (id == null) { return false }
				const _refresh = this.refreshToken
				return isAgentInGroup(group.id, id)
			},
			toggleMember(agent: UTSJSONObject): void {
				const group = this.group
				if (group == null) { return }
				const id = agent['id'] as string | null
				if (id == null || id == '') { return }
				if (this.isMember(agent) == true) {
					const members = getActiveGroupMembers(group.id)
					if (members.length <= 1) {
						uni.showToast({ position: 'bottom', title: '至少保留一个成员', icon: 'none' })
						return
					}
					removeGroupMember(group.id, id)
				} else {
					addGroupMember(group.id, id)
				}
				this.refreshToken++
			},
			resetSchedulerPrompt(): void {
				this.schedulerPrompt = buildDefaultSchedulerPrompt()
			},
			resetSharedPrompt(): void {
				this.sharedPrompt = buildDefaultSharedPrompt()
			},
			saveSettings(): boolean {
				const group = this.group
				if (group == null) { return false }
				const name = this.groupName.trim()
				if (name == '') {
					uni.showToast({ position: 'bottom', title: '群名不能为空', icon: 'none' })
					return false
				}
				group.name = name
				group.schedulerAgentId = GLOBAL_SCHEDULER_AGENT_ID
				// LEGACY_COMPAT: 旧版群级 schedulerPrompt 字段不再参与调度，保存为空避免继续分叉。
				group.schedulerPrompt = ''
				group.sharedPrompt = this.sharedPrompt.trim() != '' ? this.sharedPrompt.trim() : buildDefaultSharedPrompt()
				group.updatedAt = Date.now()
				saveGlobalSchedulerPrompt(this.schedulerPrompt)
				saveGroupChat(group)
				this.group = group
				this.groupName = group.name
				this.schedulerPrompt = getGlobalSchedulerPrompt()
				this.sharedPrompt = group.sharedPrompt
				this.captureSavedState()
				uni.showToast({ position: 'bottom', title: '已保存', icon: 'success' })
				return true
			}
		}
	}
</script>

<style>
	.settings-scroll { flex: 1; }
	.card { margin: 10px 12px 0; padding: 14px; border-radius: 16px; background-color: var(--rice-background-2); flex-direction: column; }
	.save-card { margin-bottom: 20px; }
	.card-title { font-size: 16px; font-weight: bold; color: var(--rice-text-color); margin-bottom: 9px; }
	.card-desc { font-size: 12px; color: var(--rice-text-color-3); margin-bottom: 9px; }
	.text-input { height: 39px; border-radius: 12px; background-color: var(--rice-background); padding: 0 11px; font-size: 14px; color: var(--rice-text-color); }
	.prompt-header { flex-direction: row; align-items: flex-start; margin-bottom: 9px; }
	.prompt-header-left { flex: 1; flex-direction: column; }
	.reset-btn { font-size: 12px; color: var(--rice-primary-color); padding-left: 10px; padding-top: 2px; }
	.member-row { flex-direction: row; align-items: center; padding: 9px 0; border-bottom-width: 1px; border-bottom-color: var(--rice-border-color); border-bottom-style: solid; }
	.member-avatar { width: 38px; height: 38px; border-radius: 12px; justify-content: center; align-items: center; margin-right: 9px; overflow: hidden; }
	.member-avatar-img { width: 38px; height: 38px; border-radius: 12px; }
	.avatar-1 { background-color: var(--rice-primary-color); }
	.avatar-2 { background-color: #60A5FA; }
	.avatar-3 { background-color: #34D399; }
	.avatar-4 { background-color: #FBBF24; }
	.avatar-5 { background-color: #A78BFA; }
	.member-info { flex: 1; flex-direction: column; }
	.member-name { font-size: 14px; color: var(--rice-text-color); font-weight: bold; }
	.member-desc { margin-top: 3px; font-size: 11px; color: var(--rice-text-color-3); lines: 1; text-overflow: ellipsis; }
	.member-action { padding: 6px 11px; border-radius: 500px; background-color: var(--rice-primary-color); }
	.member-action-on { background-color: #FEF2F2; }
	.member-action-text { color: #FFFFFF; font-size: 12px; font-weight: bold; }
	.member-action-text-on { color: #EF4444; }
	.prompt-input { min-height: 120px; border-radius: 12px; background-color: var(--rice-background); padding: 10px; font-size: 13px; color: var(--rice-text-color); line-height: 19px; }
</style>
