<template>
	<view class="page-shell rice-theme-light">
		<NavBar title="群聊设置" showBack @back="goBack" />
		<scroll-view class="settings-scroll" :scroll-y="true">
			<view class="card">
				<text class="card-title">基础信息</text>
				<input class="text-input" v-model="groupName" placeholder="群聊名称" placeholder-style="color:var(--rice-text-color-3)" />
				<text class="field-label">调度 Agent</text>
				<view class="agent-select-list">
					<view v-for="(agent, index) in agentList" :key="agent['id']" class="agent-pill" :class="schedulerAgentId == (agent['id'] as string) ? 'agent-pill-active' : ''" @click="selectScheduler(agent)">
						<text class="agent-pill-text" :class="schedulerAgentId == (agent['id'] as string) ? 'agent-pill-text-active' : ''">{{agent['name']}}</text>
					</view>
				</view>
			</view>

			<view class="card">
				<text class="card-title">成员</text>
				<text class="card-desc">直接复用私聊 Agent；踢出只影响之后发言，历史会保留。</text>
				<view v-for="(agent, index) in agentList" :key="agent['id']" class="member-row">
					<view class="member-avatar" :class="'avatar-' + ((index % 5) + 1)">
						<image v-if="getAgentAvatar(agent) != ''" :src="getAgentAvatar(agent)" class="member-avatar-img" mode="aspectFill" />
						<oui-icon-unix v-else :name="agent['icon']" size="38rpx" color="#FFFFFF" />
					</view>
					<view class="member-info">
						<text class="member-name">{{agent['name']}}</text>
						<text class="member-desc">{{agent['desc']}}</text>
					</view>
					<view class="member-action" :class="isMember(agent) ? 'member-action-on' : ''" @click="toggleMember(agent)">
						<text class="member-action-text" :class="isMember(agent) ? 'member-action-text-on' : ''">{{isMember(agent) ? '踢出' : '添加'}}</text>
					</view>
				</view>
			</view>

			<view class="card">
				<text class="card-title">调度提示词</text>
				<textarea class="prompt-input" v-model="schedulerPrompt" placeholder="隐藏调度 Agent 的系统提示词" placeholder-style="color:var(--rice-text-color-3)" />
			</view>

			<view class="card bottom-card">
				<text class="card-title">群聊共享提示词</text>
				<textarea class="prompt-input" v-model="sharedPrompt" placeholder="所有成员公开发言共同遵守的提示词" placeholder-style="color:var(--rice-text-color-3)" />
			</view>
		</scroll-view>

		<view class="footer-bar">
			<rice-button type="primary" text="保存" size="large" shape="round" @click="saveSettings" style="flex:1" />
		</view>
	</view>
</template>

<script lang="uts">
	import { getAgents } from '@/utils/agent.uts'
	import {
		ACTIVE_GROUP_CHAT_ID_KEY,
		GroupChat,
		addGroupMember,
		buildDefaultSchedulerPrompt,
		buildDefaultSharedPrompt,
		getActiveGroupMembers,
		getGroupChatById,
		isAgentInGroup,
		removeGroupMember,
		saveGroupChat,
	} from '@/utils/group-chat-service.uts'

	export default {
		data() {
			return {
				group: null as GroupChat | null,
				agentList: [] as UTSJSONObject[],
				groupName: '' as string,
				schedulerAgentId: '' as string,
				schedulerPrompt: '' as string,
				sharedPrompt: '' as string,
				refreshToken: 0 as number,
			}
		},
		onLoad() { this.loadData() },
		onShow() { this.loadData() },
		methods: {
			loadData(): void {
				this.agentList = getAgents()
				const groupId = uni.getStorageSync(ACTIVE_GROUP_CHAT_ID_KEY) as string | null
				if (groupId == null || groupId == '') { return }
				const group = getGroupChatById(groupId)
				if (group == null) { return }
				this.group = group
				this.groupName = group.name
				this.schedulerAgentId = group.schedulerAgentId
				this.schedulerPrompt = group.schedulerPrompt != '' ? group.schedulerPrompt : buildDefaultSchedulerPrompt()
				this.sharedPrompt = group.sharedPrompt != '' ? group.sharedPrompt : buildDefaultSharedPrompt()
			},
			goBack(): void { uni.navigateBack() },
			getAgentAvatar(agent: UTSJSONObject): string {
				const avatar = agent['avatar'] as string | null
				return avatar != null ? avatar : ''
			},
			selectScheduler(agent: UTSJSONObject): void {
				const id = agent['id'] as string | null
				if (id != null) { this.schedulerAgentId = id }
			},
			isMember(agent: UTSJSONObject): boolean {
				const group = this.group
				if (group == null) { return false }
				const id = agent['id'] as string | null
				if (id == null) { return false }
				const _refresh = this.refreshToken
				return isAgentInGroup(group.id, id)
			},
			toggleMember(agent: UTSJSONObject): void {
				const group = this.group
				if (group == null) { return }
				const id = agent['id'] as string | null
				if (id == null || id == '') { return }
				if (this.isMember(agent) == true) {
					const members = getActiveGroupMembers(group.id)
					if (members.length <= 1) {
						uni.showToast({ position: 'bottom', title: '至少保留一个成员', icon: 'none' })
						return
					}
					removeGroupMember(group.id, id)
				} else {
					addGroupMember(group.id, id)
				}
				this.refreshToken++
			},
			saveSettings(): void {
				const group = this.group
				if (group == null) { return }
				const name = this.groupName.trim()
				if (name == '') {
					uni.showToast({ position: 'bottom', title: '群名不能为空', icon: 'none' })
					return
				}
				group.name = name
				group.schedulerAgentId = this.schedulerAgentId
				group.schedulerPrompt = this.schedulerPrompt.trim() != '' ? this.schedulerPrompt.trim() : buildDefaultSchedulerPrompt()
				group.sharedPrompt = this.sharedPrompt.trim() != '' ? this.sharedPrompt.trim() : buildDefaultSharedPrompt()
				group.updatedAt = Date.now()
				saveGroupChat(group)
				uni.showToast({ position: 'bottom', title: '已保存', icon: 'success' })
			}
		}
	}
</script>

<style>
	.settings-scroll { flex: 1; }
	.card { margin: 20rpx 24rpx 0; padding: 28rpx; border-radius: 32rpx; background-color: var(--rice-background-2); flex-direction: column; }
	.bottom-card { margin-bottom: 160rpx; }
	.card-title { font-size: 32rpx; font-weight: bold; color: var(--rice-text-color); margin-bottom: 18rpx; }
	.card-desc { font-size: 24rpx; color: var(--rice-text-color-3); margin-bottom: 18rpx; }
	.text-input { height: 78rpx; border-radius: 24rpx; background-color: var(--rice-background); padding: 0 22rpx; font-size: 28rpx; color: var(--rice-text-color); }
	.field-label { font-size: 24rpx; color: var(--rice-text-color-3); margin-top: 24rpx; margin-bottom: 14rpx; }
	.agent-select-list { flex-direction: row; flex-wrap: wrap; }
	.agent-pill { padding: 14rpx 22rpx; border-radius: 999rpx; background-color: var(--rice-background); margin-right: 14rpx; margin-bottom: 14rpx; }
	.agent-pill-active { background-color: var(--rice-primary-color); }
	.agent-pill-text { font-size: 24rpx; color: var(--rice-text-color-2); }
	.agent-pill-text-active { color: #FFFFFF; font-weight: bold; }
	.member-row { flex-direction: row; align-items: center; padding: 18rpx 0; border-bottom-width: 0.10rpx; border-bottom-color: var(--rice-border-color); border-bottom-style: solid; }
	.member-avatar { width: 76rpx; height: 76rpx; border-radius: 24rpx; justify-content: center; align-items: center; margin-right: 18rpx; overflow: hidden; }
	.member-avatar-img { width: 76rpx; height: 76rpx; border-radius: 24rpx; }
	.avatar-1 { background-color: var(--rice-primary-color); }
	.avatar-2 { background-color: #60A5FA; }
	.avatar-3 { background-color: #34D399; }
	.avatar-4 { background-color: #FBBF24; }
	.avatar-5 { background-color: #A78BFA; }
	.member-info { flex: 1; flex-direction: column; }
	.member-name { font-size: 28rpx; color: var(--rice-text-color); font-weight: bold; }
	.member-desc { margin-top: 6rpx; font-size: 22rpx; color: var(--rice-text-color-3); lines: 1; text-overflow: ellipsis; }
	.member-action { padding: 12rpx 22rpx; border-radius: 999rpx; background-color: var(--rice-primary-color); }
	.member-action-on { background-color: #FEF2F2; }
	.member-action-text { color: #FFFFFF; font-size: 24rpx; font-weight: bold; }
	.member-action-text-on { color: #EF4444; }
	.prompt-input { min-height: 240rpx; border-radius: 24rpx; background-color: var(--rice-background); padding: 20rpx; font-size: 26rpx; color: var(--rice-text-color); line-height: 38rpx; }
	.footer-bar { position: fixed; left: 0; right: 0; bottom: 0; padding: 20rpx 28rpx 34rpx; background-color: var(--rice-background-2); }
</style>
