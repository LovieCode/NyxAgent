<template>
	<view class="page-shell rice-theme-light">
		<NyxPageHeader title="文件管理">
			<template #right>
				<view class="header-action" @click="showSortMenu">
					<oui-icon-unix name="sort-ascending" size="21px" color="#242129" />
				</view>
				<view class="header-action header-action-gap" @click="showPageMenu">
					<oui-icon-unix name="ellipsis" size="22px" color="#242129" />
				</view>
			</template>
		</NyxPageHeader>
		<view class="container">
			<!-- 面包屑导航 -->
			<scroll-view class="breadcrumb-bar" :scroll-x="true" :show-scrollbar="false">
				<view class="breadcrumb-row">
					<view class="breadcrumb-item" @click="goToRoot">
						<oui-icon-unix name="folder" size="14px" color="#FB8FAB" />
						<text class="breadcrumb-text breadcrumb-text-active">根目录</text>
					</view>
					<view v-for="(seg, index) in pathSegments" :key="index" class="breadcrumb-segment">
						<text class="breadcrumb-separator">/</text>
						<view class="breadcrumb-item" @click="goToSegment(index)">
							<text :class="['breadcrumb-text', index == pathSegments.length - 1 ? 'breadcrumb-text-active' : '']">{{ seg.name }}</text>
						</view>
					</view>
				</view>
			</scroll-view>

			<view class="file-search">
				<oui-icon-unix name="search" size="18px" color="#A79DA4" />
				<input
					class="file-search-input"
					v-model="searchQuery"
					placeholder="搜索当前文件夹"
					placeholder-style="color:#B7AFB4"
				/>
				<view v-if="searchQuery != ''" class="search-clear" @click="searchQuery = ''">
					<oui-icon-unix name="close" size="14px" color="#8A7B84" />
				</view>
			</view>

			<!-- 文件列表 -->
			<scroll-view class="file-list" :scroll-y="true">
				<view v-if="visibleItems.length == 0" class="empty-state">
					<text class="empty-text">{{ searchQuery != '' ? '没有匹配文件' : '空目录' }}</text>
					<text class="empty-hint">{{ searchQuery != '' ? '换个关键词试试' : '点击右下角按钮创建文件或文件夹' }}</text>
				</view>
				<view v-else>
					<template v-for="(item, index) in visibleItems" :key="item.path">
						<!-- 分组标题：名称包含 [Agent] 时视为 Agent 分组 -->
						<view v-if="isGroupStart(index, item)" class="section-header">
							<view class="section-divider" />
							<text class="section-label">{{ getSectionLabel(item) }}</text>
							<view class="section-divider" />
						</view>
						<view
							class="file-item"
							@click="onItemClick(item)"
							@longpress="onItemLongPress(item)"
						>
							<view class="file-icon">
								<oui-icon-unix
									:name="getFileIconName(item)"
									size="22px"
									:color="getFileIconColor(item)"
								/>
							</view>
							<view class="file-info">
								<text class="file-name">{{ getDisplayItemName(item) }}</text>
							<view class="file-meta">
								<text v-if="item.isDirectory" class="file-meta-text">文件夹</text>
								<text v-else class="file-meta-text">{{ fmtFileSize(item.size) }}</text>
								<text class="file-meta-time">{{ fmtTime(item.lastModified) }}</text>
							</view>
							</view>
							<view class="file-more" @click.stop="onItemMore(item)">
								<oui-icon-unix name="ellipsis" size="18px" color="#8A7B84" />
							</view>
						</view>
					</template>
				</view>
				<view class="tabbar-list-spacer"></view>
			</scroll-view>

			<!-- FAB 新建按钮 -->
			<rice-float-fab icon="plus" bg-color="#FB8FAB" :gap-bottom="102" @click="showCreateMenu" />

			<!-- 新建弹窗 -->
			<rice-dialog
				v-model:show="showCreateDialog"
				:title="createMode == 'dir' ? '新建文件夹' : '新建文件'"
				:show-cancel-button="true"
				cancel-button-text="取消"
				confirm-button-text="创建"
				@confirm="doCreate"
				@cancel="cancelCreate"
			>
				<view class="dialog-content">
					<rice-input v-model="createName" :placeholder="createMode == 'dir' ? '输入文件夹名称' : '输入文件名（如 note.txt）'" border="none" />
				</view>
			</rice-dialog>

			<!-- 重命名弹窗 -->
			<rice-dialog
				v-model:show="showRenameDialog"
				title="重命名"
				:show-cancel-button="true"
				cancel-button-text="取消"
				confirm-button-text="确认"
				@confirm="doRename"
				@cancel="cancelRename"
			>
				<view class="dialog-content">
					<rice-input v-model="renameNewName" placeholder="输入新名称" border="none" />
				</view>
			</rice-dialog>

		</view>
		<NyxTabDock current="pages/files/files" />
	</view>
</template>

<script lang="uts">
	import { listDir, listRootContents, createDir, createFile, deleteItem, renameItem, parentPath, joinPath, getUserDir, getInternalFilesDir, getExternalFilesDir, getAgentsRoot, formatFileSize, formatTime, isTextFile, isImageFile, type FileItem, type FileOpResult, type PathSegment } from '@/utils/file-manager.uts'
	import { consumeFilesInitialPath } from '@/utils/runtime-state.uts'
	import {
		buildManagedFilePathSegments,
		buildGroupWorkspacesRootPath,
		consumeManagedEditorSavedState,
		getManagedFileDisplayName,
		getManagedFileIconColor,
		getManagedFileIconName,
		getManagedFileItemGroup,
		getManagedFileSectionLabel,
		prepareManagedTextEditorRuntimeState,
	} from '@/utils/files-page-helpers.uts'

	/** 虚拟根路径标记（合并视图用） */
	const VIRTUAL_ROOT = '__FILE_ROOT__'

	/**
	 * 文件管理页面
	 * 根视图合并沙盒文件 + Agent 目录两个来源。
	 */
	export default {
		data() {
			return {
				currentPath: '' as string,
				items: [] as FileItem[],
				searchQuery: '' as string,
				sortMode: 'name' as string,

				// 新建弹窗
				showCreateDialog: false as boolean,
				createMode: 'file' as string,
				createName: '' as string,

				// 重命名弹窗
				showRenameDialog: false as boolean,
				renameTargetPath: '' as string,
				renameNewName: '' as string,

				// 长按操作菜单锁
				actionSheetOpen: false as boolean
			}
		},
		computed: {
			/** 面包屑路径分段：从叶子向上收集，跳过系统技术前缀 */
			pathSegments() : PathSegment[] {
				return buildManagedFilePathSegments(this.currentPath, VIRTUAL_ROOT)
			},

			visibleItems() : FileItem[] {
				let result = [] as FileItem[]
				const keyword = this.searchQuery.trim().toLowerCase()
				for (let i = 0; i < this.items.length; i++) {
					const item = this.items[i]
					if (keyword == '' || this.getDisplayItemName(item).toLowerCase().indexOf(keyword) >= 0) {
						result.push(item)
					}
				}

				for (let i = 1; i < result.length; i++) {
					const current = result[i]
					let j = i - 1
					while (j >= 0 && this.shouldShiftFileItem(result[j], current)) {
						result[j + 1] = result[j]
						j--
					}
					result[j + 1] = current
				}
				return result
			}
		},
		onLoad() {
			const initialPath = consumeFilesInitialPath()
			if (initialPath != '') {
				this.currentPath = initialPath
			} else {
				this.currentPath = VIRTUAL_ROOT
			}
			this.refreshList()
		},
		onBackPress(): boolean {
			if (this.currentPath == VIRTUAL_ROOT) {
				return false // 根视图 → 正常返回
			}
			const parent = parentPath(this.currentPath)
			const isRootLevel = (
				parent == '' || parent == this.currentPath ||
				parent == getInternalFilesDir() ||
				parent == getExternalFilesDir() ||
				parent == getAgentsRoot() ||
				parent == buildGroupWorkspacesRootPath() ||
				parent == getUserDir()
			)
			if (isRootLevel) {
				this.currentPath = VIRTUAL_ROOT
			} else {
				this.currentPath = parent
			}
			this.searchQuery = ''
			this.refreshList()
			return true
		},
		onShow() {
			// 编辑器通过 SQLite runtime_state 回传保存结果。
			consumeManagedEditorSavedState()
			if (this.currentPath != '') {
				this.refreshList()
			}
		},
		methods: {
			shouldShiftFileItem(left : FileItem, right : FileItem) : boolean {
				if (this.sortMode == 'time') {
					return left.lastModified < right.lastModified
				}
				if (this.sortMode == 'folder') {
					if (left.isDirectory != right.isDirectory) {
						return left.isDirectory == false
					}
				}
				return this.getDisplayItemName(left).toLowerCase() > this.getDisplayItemName(right).toLowerCase()
			},

			showSortMenu() {
				if (this.actionSheetOpen == true) {
					return
				}
				this.actionSheetOpen = true
				uni.showActionSheet({
					itemList: ['按名称排序', '按修改时间排序', '文件夹优先'],
					success: (res) => {
						if (res.tapIndex == 0) {
							this.sortMode = 'name'
						} else if (res.tapIndex == 1) {
							this.sortMode = 'time'
						} else if (res.tapIndex == 2) {
							this.sortMode = 'folder'
						}
					},
					complete: () => {
						this.actionSheetOpen = false
					}
				})
			},

			showPageMenu() {
				if (this.actionSheetOpen == true) {
					return
				}
				this.actionSheetOpen = true
				uni.showActionSheet({
					itemList: ['刷新', '回到根目录', '新建文件夹'],
					success: (res) => {
						if (res.tapIndex == 0) {
							this.refreshList()
						} else if (res.tapIndex == 1) {
							this.goToRoot()
						} else if (res.tapIndex == 2) {
							this.startCreate('dir')
						}
					},
					complete: () => {
						this.actionSheetOpen = false
					}
				})
			},

			onItemMore(item : FileItem) {
				this.onItemLongPress(item)
			},

			/** 刷新当前目录文件列表 */
			refreshList() {
				if (this.currentPath == VIRTUAL_ROOT) {
					this.items = listRootContents()
					return
				}
				if (this.currentPath == '') {
					this.items = []
					return
				}
				this.items = listDir(this.currentPath)
			},

			/** 跳转到根目录（合并视图） */
			goToRoot() {
				if (this.currentPath == VIRTUAL_ROOT) {
					return
				}
				this.currentPath = VIRTUAL_ROOT
				this.searchQuery = ''
				this.refreshList()
			},

			/** 跳转到面包屑某个层级 */
			goToSegment(index : number) {
				if (index < 0 || index >= this.pathSegments.length) {
					return
				}
				const target = this.pathSegments[index]
				if (target.path == this.currentPath) {
					return
				}
				this.currentPath = target.path
				this.searchQuery = ''
				this.refreshList()
			},

			/** 点击文件项 */
			onItemClick(item : FileItem) {
				if (item.isDirectory == true) {
					// 进入子目录
					this.currentPath = item.path
					this.searchQuery = ''
					this.refreshList()
					return
				}
				// 文件：根据类型打开
				if (isTextFile(item.name)) {
					this.openTextEditor(item)
				} else if (isImageFile(item.name)) {
					// 图片预览
					uni.previewImage({
						urls: [item.path],
						current: item.path
					})
				} else {
					// 其他文件：显示信息
					uni.showModal({
						title: item.name,
						content: '大小：' + formatFileSize(item.size) + '\n修改时间：' + formatTime(item.lastModified) + '\n路径：' + item.path,
						showCancel: false,
						confirmText: '关闭'
					})
				}
			},

			/** 长按文件项 - 弹出操作菜单 */
			onItemLongPress(item : FileItem) {
				if (this.actionSheetOpen == true) {
					return
				}
				this.actionSheetOpen = true
				const itemName = item.name
				const itemList = ['重命名', '删除']
				uni.showActionSheet({
					itemList: itemList,
					success: (res) => {
						const tapIdx = res.tapIndex
						if (tapIdx == 0) {
							this.startRename(item)
						} else if (tapIdx == 1) {
							this.confirmDelete(item)
						}
					},
					complete: () => {
						this.actionSheetOpen = false
					}
				})
			},

			/** 打开文本编辑器 */
			openTextEditor(item : FileItem) {
				prepareManagedTextEditorRuntimeState(item)
				uni.navigateTo({
					url: '/pages/common/editor/editor'
				})
			},

			/** 显示新建菜单 */
			showCreateMenu() {
				if (this.actionSheetOpen == true) {
					return
				}
				this.actionSheetOpen = true
				uni.showActionSheet({
					itemList: ['新建文件', '新建文件夹'],
					success: (res) => {
						const tapIdx = res.tapIndex
						if (tapIdx == 0) {
							this.startCreate('file')
						} else if (tapIdx == 1) {
							this.startCreate('dir')
						}
					},
					complete: () => {
						this.actionSheetOpen = false
					}
				})
			},

			/** 开始新建 */
			startCreate(mode : string) {
				this.createMode = mode
				this.createName = ''
				this.showCreateDialog = true
			},

			/** 取消新建 */
			cancelCreate() {
				this.showCreateDialog = false
				this.createName = ''
			},

			/** 执行新建 */
			doCreate() {
				const name = this.createName.trim()
				if (name == '') {
					uni.showToast({ position: 'bottom', title: '请输入名称', icon: 'none' })
					return
				}
				// 简单校验：不允许包含路径分隔符
				if (name.indexOf('/') >= 0 || name.indexOf('\\') >= 0) {
					uni.showToast({ position: 'bottom', title: '名称不能包含斜杠', icon: 'none' })
					return
				}
				let basePath = this.currentPath
				const shouldEnterUserDir = basePath == VIRTUAL_ROOT
				if (basePath == VIRTUAL_ROOT) {
					basePath = getUserDir()
					if (basePath == '') {
						uni.showToast({ position: 'bottom', title: '用户目录不可用', icon: 'none' })
						return
					}
				}
				const fullPath = joinPath(basePath, name)
				let result: FileOpResult
				if (this.createMode == 'dir') {
					result = createDir(fullPath, true)
				} else {
					result = createFile(fullPath)
				}
				if (result.ok) {
					uni.showToast({ position: 'bottom', title: '已创建', icon: 'success' })
					this.showCreateDialog = false
					this.createName = ''
					if (shouldEnterUserDir) {
						this.currentPath = basePath
					}
					this.refreshList()
				} else {
					uni.showToast({ position: 'bottom', title: '创建失败: ' + result.error, icon: 'none' })
				}
			},

			/** 开始重命名 */
			startRename(item : FileItem) {
				this.renameTargetPath = item.path
				this.renameNewName = item.name
				this.showRenameDialog = true
			},

			/** 取消重命名 */
			cancelRename() {
				this.showRenameDialog = false
				this.renameTargetPath = ''
				this.renameNewName = ''
			},

			/** 执行重命名 */
			doRename() {
				const newName = this.renameNewName.trim()
				if (newName == '') {
					uni.showToast({ position: 'bottom', title: '请输入新名称', icon: 'none' })
					return
				}
				if (newName.indexOf('/') >= 0 || newName.indexOf('\\') >= 0) {
					uni.showToast({ position: 'bottom', title: '名称不能包含斜杠', icon: 'none' })
					return
				}
				const parent = parentPath(this.renameTargetPath)
				if (parent == '') {
					uni.showToast({ position: 'bottom', title: '无法重命名根目录', icon: 'none' })
					return
				}
				const newPath = joinPath(parent, newName)
				if (newPath == this.renameTargetPath) {
					// 名称没变
					this.showRenameDialog = false
					return
				}
				const result = renameItem(this.renameTargetPath, newPath)
				if (result.ok) {
					uni.showToast({ position: 'bottom', title: '已重命名', icon: 'success' })
					this.showRenameDialog = false
					this.renameTargetPath = ''
					this.renameNewName = ''
					this.refreshList()
				} else {
					uni.showToast({ position: 'bottom', title: '重命名失败: ' + result.error, icon: 'none' })
				}
			},

			/** 确认删除 */
			confirmDelete(item : FileItem) {
				const hint = item.isDirectory ? '文件夹及其所有内容' : '文件'
				uni.showModal({
					title: '确认删除',
					content: '确定要删除' + hint + '「' + item.name + '」吗？此操作不可恢复。',
					confirmText: '删除',
					confirmColor: '#EF4444',
					success: (res) => {
						if (res.confirm == true) {
							this.doDelete(item)
						}
					}
				})
			},

			/** 执行删除 */
			doDelete(item : FileItem) {
				const result = deleteItem(item.path, true)
				if (result.ok) {
					uni.showToast({ position: 'bottom', title: '已删除', icon: 'success' })
					this.refreshList()
				} else {
					uni.showToast({ position: 'bottom', title: '删除失败: ' + result.error, icon: 'none' })
				}
			},

			/** 获取文件图标名称 */
			getFileIconName(item : FileItem) : string {
				return getManagedFileIconName(item)
			},

			/** 获取文件图标颜色 */
			getFileIconColor(item : FileItem) : string {
				return getManagedFileIconColor(item)
			},

			/** 获取根视图分组类型 */
			getItemGroup(item : FileItem) : string {
				return getManagedFileItemGroup(item)
			},

			/** 检测是否分组起始 */
			isGroupStart(index : number, item : FileItem) : boolean {
				if (index == 0) {
					return true
				}
				const prevItem = this.visibleItems[index - 1]
				if (prevItem == null) {
					return true
				}
				return this.getItemGroup(item) != this.getItemGroup(prevItem)
			},

			/** 获取分组标签 */
			getSectionLabel(item : FileItem) : string {
				return getManagedFileSectionLabel(item)
			},

			getDisplayItemName(item : FileItem) : string {
				return getManagedFileDisplayName(item)
			},

			/** 格式化文件大小（模板调用包装） */
			fmtFileSize(bytes : number) : string {
				return formatFileSize(bytes)
			},

			/** 格式化时间（模板调用包装） */
			fmtTime(timestamp : number) : string {
				return formatTime(timestamp)
			}
		}
	}
</script>

<style>
	.page-shell {
		background-color: #FAF7F5;
	}

	.container {
		flex: 1;
		background-color: #FAF7F5;
	}

	/* 面包屑导航 */
	.breadcrumb-bar {
		margin-left: 24px;
		margin-right: 24px;
		margin-top: 0;
		margin-bottom: 12px;
	}

	.breadcrumb-row {
		flex-direction: row;
		align-items: center;
		padding: 6px 0;
	}

	.breadcrumb-item {
		flex-direction: row;
		align-items: center;
		padding: 3px 5px;
	}

	.breadcrumb-text {
		font-size: 13px;
		color: #8A7B84;
		margin-left: 3px;
	}

	.breadcrumb-text-active {
		color: #DB6F92;
		font-weight: bold;
	}

	.header-action {
		width: 34px;
		height: 34px;
		align-items: center;
		justify-content: center;
	}

	.header-action-gap {
		margin-left: 6px;
	}

	.file-search {
		height: 44px;
		margin-left: 24px;
		margin-right: 24px;
		margin-bottom: 14px;
		padding-left: 14px;
		padding-right: 10px;
		flex-direction: row;
		align-items: center;
		background-color: #F2EDEF;
		border-radius: 22px;
	}

	.file-search-input {
		flex: 1;
		height: 44px;
		margin-left: 9px;
		font-size: 14px;
		color: #2A2529;
	}

	.search-clear {
		width: 30px;
		height: 30px;
		align-items: center;
		justify-content: center;
	}

	.breadcrumb-segment {
		flex-direction: row;
		align-items: center;
	}

	.breadcrumb-separator {
		font-size: 13px;
		color: #D8CAD1;
		margin: 0 2px;
	}

	/* 文件列表 */
	.file-list {
		flex: 1;
		padding-left: 24px;
		padding-right: 24px;
	}

	.empty-state {
		flex: 1;
		justify-content: center;
		align-items: center;
		padding-top: 100px;
	}

	.empty-text {
		font-size: 16px;
		color: #8A7B84;
		margin-bottom: 6px;
		font-weight: bold;
	}

	.empty-hint {
		font-size: 12px;
		color: #A79DA4;
	}

	/* 分组标题 */
	.section-header {
		flex-direction: row;
		align-items: center;
		padding: 12px 0 6px 0;
	}

	.section-divider {
		flex: 1;
		height: 1px;
		background-color: #F1E5EA;
	}

	.section-label {
		font-size: 11px;
		color: #A79DA4;
		margin: 0 8px;
		flex-shrink: 0;
	}

	/* 文件项 */
	.file-item {
		flex-direction: row;
		align-items: center;
		padding: 13px 14px;
		margin-bottom: 10px;
