<template>
	<view class="page-shell rice-theme-light">
		<NavBar title="文件管理" />
		<view class="container">
			<!-- 面包屑导航 -->
			<scroll-view class="breadcrumb-bar" :scroll-x="true" :show-scrollbar="false">
				<view class="breadcrumb-row">
					<view class="breadcrumb-item" @click="goToRoot">
						<oui-icon-unix name="folder" size="28rpx" color="#FB8FAB" />
						<text class="breadcrumb-text breadcrumb-text-active">根目录</text>
					</view>
					<view v-for="(seg, index) in pathSegments" :key="index" class="breadcrumb-segment">
						<text class="breadcrumb-separator">/</text>
						<view class="breadcrumb-item" @click="goToSegment(index)">
							<text :class="['breadcrumb-text', index == pathSegments.length - 1 ? 'breadcrumb-text-active' : '']">{{ seg.name }}</text>
						</view>
					</view>
				</view>
			</scroll-view>

			<!-- 文件列表 -->
			<scroll-view class="file-list" :scroll-y="true">
				<view v-if="items.length == 0" class="empty-state">
					<text class="empty-text">空目录</text>
					<text class="empty-hint">点击右下角按钮创建文件或文件夹</text>
				</view>
				<view v-else>
					<template v-for="(item, index) in items" :key="item.path">
						<!-- 分组标题：名称包含 [Agent] 时视为 Agent 分组 -->
						<view v-if="isGroupStart(index, item)" class="section-header">
							<view class="section-divider" />
							<text class="section-label">{{ getSectionLabel(item) }}</text>
							<view class="section-divider" />
						</view>
						<view
							class="file-item"
							@click="onItemClick(item)"
							@longpress="onItemLongPress(item)"
						>
							<view class="file-icon">
								<oui-icon-unix
									:name="getFileIconName(item)"
									size="44rpx"
									:color="getFileIconColor(item)"
								/>
							</view>
							<view class="file-info">
								<text class="file-name">{{ item.name }}</text>
							<view class="file-meta">
								<text v-if="item.isDirectory" class="file-meta-text">文件夹</text>
								<text v-else class="file-meta-text">{{ fmtFileSize(item.size) }}</text>
								<text class="file-meta-time">{{ fmtTime(item.lastModified) }}</text>
							</view>
							</view>
							<view class="file-arrow" v-if="item.isDirectory == true">
								<oui-icon-unix name="right" size="32rpx" color="#D1D5DB" />
							</view>
						</view>
					</template>
				</view>
			</scroll-view>

			<!-- FAB 新建按钮 -->
			<rice-float-fab icon="plus" bg-color="#FB8FAB" :gap-bottom="80" @click="showCreateMenu" />

			<!-- 新建弹窗 -->
			<rice-dialog
				v-model:show="showCreateDialog"
				:title="createMode == 'dir' ? '新建文件夹' : '新建文件'"
				:show-cancel-button="true"
				cancel-button-text="取消"
				confirm-button-text="创建"
				@confirm="doCreate"
				@cancel="cancelCreate"
			>
				<view class="dialog-content">
					<rice-input v-model="createName" :placeholder="createMode == 'dir' ? '输入文件夹名称' : '输入文件名（如 note.txt）'" border="none" />
				</view>
			</rice-dialog>

			<!-- 重命名弹窗 -->
			<rice-dialog
				v-model:show="showRenameDialog"
				title="重命名"
				:show-cancel-button="true"
				cancel-button-text="取消"
				confirm-button-text="确认"
				@confirm="doRename"
				@cancel="cancelRename"
			>
				<view class="dialog-content">
					<rice-input v-model="renameNewName" placeholder="输入新名称" border="none" />
				</view>
			</rice-dialog>

		</view>
		<TabBar current="pages/files/files" />
	</view>
</template>

<script lang="uts">
	import { listDir, listRootContents, createDir, createFile, deleteItem, renameItem, parentPath, basename, joinPath, normalizePath, getUserDir, getInternalFilesDir, getExternalFilesDir, getAgentsRoot, formatFileSize, formatTime, isTextFile, isImageFile, getExtension, type FileItem, type FileOpResult, type PathSegment } from '@/utils/file-manager.uts'

	/** 虚拟根路径标记（合并视图用） */
	const VIRTUAL_ROOT = '__FILE_ROOT__'

	/**
	 * 文件管理页面
	 * 根视图合并沙盒文件 + Agent 目录两个来源。
	 */
	export default {
		data() {
			return {
				currentPath: '' as string,
				items: [] as FileItem[],

				// 新建弹窗
				showCreateDialog: false as boolean,
				createMode: 'file' as string,
				createName: '' as string,

				// 重命名弹窗
				showRenameDialog: false as boolean,
				renameTargetPath: '' as string,
				renameNewName: '' as string,

				// 长按操作菜单锁
				actionSheetOpen: false as boolean
			}
		},
		computed: {
			/** 面包屑路径分段：从叶子向上收集，跳过系统技术前缀 */
			pathSegments() : PathSegment[] {
				if (this.currentPath == '' || this.currentPath == VIRTUAL_ROOT) {
					return []
				}
				let p = this.currentPath
				// 去除末尾斜杠，统一处理
				while (p.length > 1 && p.endsWith('/')) {
					p = p.substring(0, p.length - 1)
				}
				const stack: PathSegment[] = []
				const userDir = getUserDir()
				// 从叶子向上收集所有层级
				while (p != '') {
					const name = basename(p)
					if (name == '') {
						break
					}
					stack.push({ name: name, path: p })
					const parent = parentPath(p)
					if (parent == '' || parent == p) {
						break
					}
					p = parent
				}
				// 找到 files/usr 作为技术前缀边界
				let startIndex = stack.length // 默认全部裁剪
				for (let j = stack.length - 1; j >= 0; j--) {
					const segName = stack[j].name
					if (segName == 'files' || segName == 'usr') {
						startIndex = j
						break
					}
				}
				// 从叶子向根收集时本身是根→叶子顺序，无需反转
				const parts: PathSegment[] = []
				for (let i = startIndex - 1; i >= 0; i--) {
					let displayName = stack[i].name
					// 跳过 agents 容器目录本身
					if (displayName == 'agents') {
						continue
					}
					// 用户目录固定显示中文名
					if (userDir != '' && stack[i].path == userDir) {
						displayName = '用户目录'
					}
					// 父级是 agents → 当前段是 agent ID，替换为显示名
					if (i + 1 < stack.length && stack[i + 1].name == 'agents') {
						const agentName = this.lookupAgentName(displayName)
						if (agentName != '') {
							displayName = agentName
						}
					}
					parts.push({ name: displayName, path: stack[i].path })
				}
				return parts
			}
		},
		onLoad() {
			const initialPath = uni.getStorageSync('files_initial_path') as string | null
			if (initialPath != null && initialPath != '') {
				this.currentPath = initialPath
				uni.removeStorageSync('files_initial_path')
			} else {
				this.currentPath = VIRTUAL_ROOT
			}
			this.refreshList()
		},
		onBackPress(): boolean {
			if (this.currentPath == VIRTUAL_ROOT) {
				return false // 根视图 → 正常返回
			}
			const parent = parentPath(this.currentPath)
			const isRootLevel = (
				parent == '' || parent == this.currentPath ||
				parent == getInternalFilesDir() ||
				parent == getExternalFilesDir() ||
				parent == getAgentsRoot() ||
				parent == getUserDir()
			)
			if (isRootLevel) {
				this.currentPath = VIRTUAL_ROOT
			} else {
				this.currentPath = parent
			}
			this.refreshList()
			return true
		},
		onShow() {
			const saved = uni.getStorageSync('editor_saved') as string | null
			if (saved == 'true') {
				uni.removeStorageSync('editor_saved')
				uni.removeStorageSync('editor_saved_path')
				uni.removeStorageSync('editor_mode')
				uni.removeStorageSync('editor_file_path')
				uni.removeStorageSync('editor_title')
				uni.removeStorageSync('editor_target')
				uni.removeStorageSync('editor_placeholder')
			}
			if (this.currentPath != '') {
				this.refreshList()
			}
		},
		methods: {
			/** 刷新当前目录文件列表 */
			refreshList() {
				if (this.currentPath == VIRTUAL_ROOT) {
					this.items = listRootContents()
					return
				}
				if (this.currentPath == '') {
					this.items = []
					return
				}
				this.items = listDir(this.currentPath)
			},

			/** 跳转到根目录（合并视图） */
			goToRoot() {
				if (this.currentPath == VIRTUAL_ROOT) {
					return
				}
				this.currentPath = VIRTUAL_ROOT
				this.refreshList()
			},

			/** 跳转到面包屑某个层级 */
			goToSegment(index : number) {
				if (index < 0 || index >= this.pathSegments.length) {
					return
				}
				const target = this.pathSegments[index]
				if (target.path == this.currentPath) {
					return
				}
				this.currentPath = target.path
				this.refreshList()
			},

			/** 点击文件项 */
			onItemClick(item : FileItem) {
				if (item.isDirectory == true) {
					// 进入子目录
					this.currentPath = item.path
					this.refreshList()
					return
				}
				// 文件：根据类型打开
				if (isTextFile(item.name)) {
					this.openTextEditor(item)
				} else if (isImageFile(item.name)) {
					// 图片预览
					uni.previewImage({
						urls: [item.path],
						current: item.path
					})
				} else {
					// 其他文件：显示信息
					uni.showModal({
						title: item.name,
						content: '大小：' + formatFileSize(item.size) + '\n修改时间：' + formatTime(item.lastModified) + '\n路径：' + item.path,
						showCancel: false,
						confirmText: '关闭'
					})
				}
			},

			/** 长按文件项 - 弹出操作菜单 */
			onItemLongPress(item : FileItem) {
				if (this.actionSheetOpen == true) {
					return
				}
				this.actionSheetOpen = true
				const itemName = item.name
				const itemList = ['重命名', '删除']
				uni.showActionSheet({
					itemList: itemList,
					success: (res) => {
						const tapIdx = res.tapIndex
						if (tapIdx == 0) {
							this.startRename(item)
						} else if (tapIdx == 1) {
							this.confirmDelete(item)
						}
					},
					complete: () => {
						this.actionSheetOpen = false
					}
				})
			},

			clearEditorStorage() {
				uni.removeStorageSync('editor_mode')
				uni.removeStorageSync('editor_title')
				uni.removeStorageSync('editor_content')
				uni.removeStorageSync('editor_result')
				uni.removeStorageSync('editor_result_ready')
				uni.removeStorageSync('editor_target')
				uni.removeStorageSync('editor_file_path')
				uni.removeStorageSync('editor_saved')
				uni.removeStorageSync('editor_saved_path')
				uni.removeStorageSync('editor_readonly')
				uni.removeStorageSync('editor_placeholder')
				uni.removeStorageSync('editor_draft')
			},

			/** 打开文本编辑器 */
			openTextEditor(item : FileItem) {
				this.clearEditorStorage()
				uni.setStorageSync('editor_mode', 'file')
				uni.setStorageSync('editor_file_path', item.path)
				uni.setStorageSync('editor_title', item.name)
				uni.setStorageSync('editor_target', 'file-manager')
				uni.setStorageSync('editor_placeholder', '文件内容为空')
				uni.navigateTo({
					url: '/pages/common/editor/editor'
				})
			},

			/** 显示新建菜单 */
			showCreateMenu() {
				if (this.actionSheetOpen == true) {
					return
				}
				this.actionSheetOpen = true
				uni.showActionSheet({
					itemList: ['新建文件', '新建文件夹'],
					success: (res) => {
						const tapIdx = res.tapIndex
						if (tapIdx == 0) {
							this.startCreate('file')
						} else if (tapIdx == 1) {
							this.startCreate('dir')
						}
					},
					complete: () => {
						this.actionSheetOpen = false
					}
				})
			},

			/** 开始新建 */
			startCreate(mode : string) {
				this.createMode = mode
				this.createName = ''
				this.showCreateDialog = true
			},

			/** 取消新建 */
			cancelCreate() {
				this.showCreateDialog = false
				this.createName = ''
			},

			/** 执行新建 */
			doCreate() {
				const name = this.createName.trim()
				if (name == '') {
					uni.showToast({ position: 'bottom', title: '请输入名称', icon: 'none' })
					return
				}
				// 简单校验：不允许包含路径分隔符
				if (name.indexOf('/') >= 0 || name.indexOf('\\') >= 0) {
					uni.showToast({ position: 'bottom', title: '名称不能包含斜杠', icon: 'none' })
					return
				}
				let basePath = this.currentPath
				const shouldEnterUserDir = basePath == VIRTUAL_ROOT
				if (basePath == VIRTUAL_ROOT) {
					basePath = getUserDir()
					if (basePath == '') {
						uni.showToast({ position: 'bottom', title: '用户目录不可用', icon: 'none' })
						return
					}
				}
				const fullPath = joinPath(basePath, name)
				let result: FileOpResult
				if (this.createMode == 'dir') {
					result = createDir(fullPath, true)
				} else {
					result = createFile(fullPath)
				}
				if (result.ok) {
					uni.showToast({ position: 'bottom', title: '已创建', icon: 'success' })
					this.showCreateDialog = false
					this.createName = ''
					if (shouldEnterUserDir) {
						this.currentPath = basePath
					}
					this.refreshList()
				} else {
					uni.showToast({ position: 'bottom', title: '创建失败: ' + result.error, icon: 'none' })
				}
			},

			/** 开始重命名 */
			startRename(item : FileItem) {
				this.renameTargetPath = item.path
				this.renameNewName = item.name
				this.showRenameDialog = true
			},

			/** 取消重命名 */
			cancelRename() {
				this.showRenameDialog = false
				this.renameTargetPath = ''
				this.renameNewName = ''
			},

			/** 执行重命名 */
			doRename() {
				const newName = this.renameNewName.trim()
				if (newName == '') {
					uni.showToast({ position: 'bottom', title: '请输入新名称', icon: 'none' })
					return
				}
				if (newName.indexOf('/') >= 0 || newName.indexOf('\\') >= 0) {
					uni.showToast({ position: 'bottom', title: '名称不能包含斜杠', icon: 'none' })
					return
				}
				const parent = parentPath(this.renameTargetPath)
				if (parent == '') {
					uni.showToast({ position: 'bottom', title: '无法重命名根目录', icon: 'none' })
					return
				}
				const newPath = joinPath(parent, newName)
				if (newPath == this.renameTargetPath) {
					// 名称没变
					this.showRenameDialog = false
					return
				}
				const result = renameItem(this.renameTargetPath, newPath)
				if (result.ok) {
					uni.showToast({ position: 'bottom', title: '已重命名', icon: 'success' })
					this.showRenameDialog = false
					this.renameTargetPath = ''
					this.renameNewName = ''
					this.refreshList()
				} else {
					uni.showToast({ position: 'bottom', title: '重命名失败: ' + result.error, icon: 'none' })
				}
			},

			/** 确认删除 */
			confirmDelete(item : FileItem) {
				const hint = item.isDirectory ? '文件夹及其所有内容' : '文件'
				uni.showModal({
					title: '确认删除',
					content: '确定要删除' + hint + '「' + item.name + '」吗？此操作不可恢复。',
					confirmText: '删除',
					confirmColor: '#EF4444',
					success: (res) => {
						if (res.confirm == true) {
							this.doDelete(item)
						}
					}
				})
			},

			/** 执行删除 */
			doDelete(item : FileItem) {
				const result = deleteItem(item.path, true)
				if (result.ok) {
					uni.showToast({ position: 'bottom', title: '已删除', icon: 'success' })
					this.refreshList()
				} else {
					uni.showToast({ position: 'bottom', title: '删除失败: ' + result.error, icon: 'none' })
				}
			},

			/** 获取文件图标名称 */
			getFileIconName(item : FileItem) : string {
				if (item.isDirectory == true) {
					return 'folder'
				}
				const ext = getExtension(item.name)
				if (isImageFile(item.name)) {
					return 'image'
				}
				if (ext == 'txt' || ext == 'md' || ext == 'log') {
					return 'file-text'
				}
				if (ext == 'json' || ext == 'xml' || ext == 'yaml' || ext == 'yml') {
					return 'file-text'
				}
				if (ext == 'zip' || ext == 'rar' || ext == '7z' || ext == 'tar' || ext == 'gz') {
					return 'file'
				}
				return 'file'
			},

			/** 获取文件图标颜色 */
			getFileIconColor(item : FileItem) : string {
				if (item.isDirectory == true) {
					return '#FB8FAB'
				}
				if (isImageFile(item.name)) {
					return '#10B981'
				}
				const ext = getExtension(item.name)
				if (ext == 'txt' || ext == 'md' || ext == 'log') {
					return '#6B7280'
				}
				return '#9CA3AF'
			},

			/** 获取根视图分组类型 */
			getItemGroup(item : FileItem) : string {
				if (item.name.startsWith('[User]')) {
					return 'user'
				}
				if (item.name.startsWith('[Agent]')) {
					return 'agent'
				}
				return 'file'
			},

			/** 检测是否分组起始 */
			isGroupStart(index : number, item : FileItem) : boolean {
				if (index == 0) {
					return true
				}
				const prevItem = this.items[index - 1]
				if (prevItem == null) {
					return true
				}
				return this.getItemGroup(item) != this.getItemGroup(prevItem)
			},

			/** 获取分组标签 */
			getSectionLabel(item : FileItem) : string {
				if (item.name.startsWith('[User]')) {
					return '用户目录'
				}
				if (item.name.startsWith('[Agent]')) {
					return 'Agent 目录'
				}
				return '文件目录'
			},

			/** 查智能体显示名（agentId → name），无匹配返回空 */
			lookupAgentName(agentId : string) : string {
				const stored = uni.getStorageSync('agent_list') as string
				if (stored == null || stored == '') {
					return ''
				}
				try {
					const list = JSON.parse(stored) as UTSJSONObject[]
					for (let i = 0; i < (list as any[]).length; i++) {
						const item = list[i] as UTSJSONObject
						if ((item['id'] as string) == agentId) {
							const name = item['name'] as string
							if (name != null && name != '') {
								return name
							}
							break
						}
					}
				} catch (_e: any) { /* 解析失败则返回空 */ }
				return ''
			},

			/** 格式化文件大小（模板调用包装） */
			fmtFileSize(bytes : number) : string {
				return formatFileSize(bytes)
			},

			/** 格式化时间（模板调用包装） */
			fmtTime(timestamp : number) : string {
				return formatTime(timestamp)
			}
		}
	}
</script>

<style>
	.container {
		flex: 1;
	}

	/* 面包屑导航 */
	.breadcrumb-bar {
		background-color: #FFFFFF;
		border-bottom-width: 0.10rpx;
		border-bottom-color: #F3F4F6;
		border-bottom-style: solid;
	}

	.breadcrumb-row {
		flex-direction: row;
		align-items: center;
		padding: 16rpx 30rpx;
	}

	.breadcrumb-item {
		flex-direction: row;
		align-items: center;
		padding: 4rpx 8rpx;
	}

	.breadcrumb-text {
		font-size: 26rpx;
		color: #6B7280;
		margin-left: 6rpx;
	}

	.breadcrumb-text-active {
		color: #DB2777;
		font-weight: bold;
	}

	.breadcrumb-segment {
		flex-direction: row;
		align-items: center;
	}

	.breadcrumb-separator {
		font-size: 26rpx;
		color: #D1D5DB;
		margin: 0 4rpx;
	}

	/* 文件列表 */
	.file-list {
		flex: 1;
		padding: 8rpx 30rpx;
	}

	.empty-state {
		flex: 1;
		justify-content: center;
		align-items: center;
		padding-top: 200rpx;
	}

	.empty-text {
		font-size: 32rpx;
		color: #9CA3AF;
		margin-bottom: 12rpx;
	}

	.empty-hint {
		font-size: 24rpx;
		color: #D1D5DB;
	}

	/* 分组标题 */
	.section-header {
		flex-direction: row;
		align-items: center;
		padding: 20rpx 0 8rpx 0;
	}

	.section-divider {
		flex: 1;
		height: 1rpx;
		background-color: #E5E7EB;
	}

	.section-label {
		font-size: 22rpx;
		color: #9CA3AF;
		margin: 0 16rpx;
		flex-shrink: 0;
	}

	/* 文件项 */
	.file-item {
		flex-direction: row;
		align-items: center;
		padding: 20rpx 0;
		border-bottom-width: 0.10rpx;
		border-bottom-color: #F3F4F6;
		border-bottom-style: solid;
	}

	.file-icon {
		width: 64rpx;
