<template>
	<view class="page-shell rice-theme-light">
		<NavBar title="原始上下文" showBack @back="goBack">
			<template #right>
				<text class="nav-btn" @click="copyAll">复制</text>
			</template>
		</NavBar>
		<view class="scroll-wrapper">
			<scroll-view id="context-scroll" class="container" :scroll-y="true" :scroll-with-animation="false" :show-scrollbar="false" :scroll-top="scrollTop" @scroll="onPageScroll">
			<view id="anchor-top" class="anchor-spacer"></view>
			<view class="hero-card">
				<text class="hero-title">上次真实请求上下文</text>
				<text class="hero-desc">这里展示上次发送瞬间真实写入 API request body 的上下文快照。不会显示 API Key，也不会重新模拟上下文。</text>
			</view>

			<view v-if="responsePreviewText != '' || thinkingPreviewText != ''" id="section-response" class="card response-card">
				<view class="section-row">
					<text class="section-title">上次响应</text>
				</view>
				<view v-if="responsePreviewText != ''" class="response-section">
					<text class="summary-section-title">正文</text>
					<text class="code-text">{{responsePreviewText}}</text>
				</view>
				<view v-if="thinkingPreviewText != ''" class="response-section response-section-last">
					<text class="summary-section-title">思考过程</text>
					<text class="code-text">{{thinkingPreviewText}}</text>
				</view>
			</view>

			<view id="section-summary" class="card summary-card">
				<text class="section-title">摘要</text>
				<view class="summary-section">
					<text class="summary-section-title">请求目标</text>
					<view class="summary-row">
						<text class="summary-label">模型</text>
						<text class="summary-value summary-value-strong">{{model != '' ? model : '未解析'}}</text>
					</view>
					<view class="summary-row">
						<text class="summary-label">请求 URL</text>
						<text class="summary-value summary-url">{{requestUrl != '' ? requestUrl : '未解析'}}</text>
					</view>
					<view class="summary-row">
						<text class="summary-label">Base URL</text>
						<text class="summary-value summary-url">{{baseUrl != '' ? baseUrl : '未解析'}}</text>
					</view>
					<view class="summary-row">
						<text class="summary-label">消息数</text>
						<text class="summary-value">{{messageCount}} 条</text>
					</view>
					<view class="summary-row">
						<text class="summary-label">工具定义</text>
						<text class="summary-value">{{toolCount}} 个</text>
					</view>
				</view>

				<view class="summary-section">
					<text class="summary-section-title">生成参数</text>
					<view class="summary-param-row">
						<view class="summary-param-pill">
							<text class="summary-param-label">temperature</text>
							<text class="summary-param-value">{{settingsTemperature}}</text>
						</view>
						<view class="summary-param-pill">
							<text class="summary-param-label">max_tokens</text>
							<text class="summary-param-value">{{settingsMaxTokens}}</text>
						</view>
						<view class="summary-param-pill">
							<text class="summary-param-label">max_iter</text>
							<text class="summary-param-value">{{settingsMaxIterations}}</text>
						</view>
						<view class="summary-param-pill summary-param-pill-last">
							<text class="summary-param-label">stream</text>
							<text class="summary-param-value">{{settingsStreamEnabled ? '开' : '关'}}</text>
						</view>
					</view>
				</view>

				<view class="summary-section">
					<text class="summary-section-title">Token 用量</text>
					<view class="summary-param-row usage-param-row">
						<view class="summary-param-pill">
							<text class="summary-param-label">prompt</text>
							<text class="summary-param-value">{{usagePromptTokens}}</text>
						</view>
						<view class="summary-param-pill">
							<text class="summary-param-label">completion</text>
							<text class="summary-param-value">{{usageCompletionTokens}}</text>
						</view>
						<view class="summary-param-pill">
							<text class="summary-param-label">total</text>
							<text class="summary-param-value">{{usageTotalTokens}}</text>
						</view>
						<view class="summary-param-pill summary-param-pill-last">
							<text class="summary-param-label">cache hit</text>
							<text class="summary-param-value">{{usageCacheHitTokens}}</text>
						</view>
					</view>
					<view class="summary-param-row">
						<view class="summary-param-pill">
							<text class="summary-param-label">calls</text>
							<text class="summary-param-value">{{usageCallCount}}</text>
						</view>
						<view class="summary-param-pill">
							<text class="summary-param-label">累计 prompt</text>
							<text class="summary-param-value">{{usageAccumPromptTokens}}</text>
						</view>
						<view class="summary-param-pill">
							<text class="summary-param-label">累计缓存</text>
							<text class="summary-param-value">{{usageAccumCacheHitTokens}}</text>
						</view>
						<view class="summary-param-pill summary-param-pill-last">
							<text class="summary-param-label">命中率</text>
							<text class="summary-param-value">{{usageCacheHitRatio}}</text>
						</view>
					</view>
					<view class="usage-note-row">
						<text class="usage-note-text">上下文粗估：{{contextCharCount}} 字符 · ≈ {{contextEstimatedTokens}} tokens</text>
					</view>
				</view>

				<view class="summary-section summary-section-last">
					<text class="summary-section-title">快照信息</text>
					<view class="last-call-panel">
						<view class="last-call-head">
							<text class="last-call-title">真实请求</text>
							<text class="last-call-badge" :class="lastCallBadgeClass">{{lastCallStatus}}</text>
						</view>
						<view class="summary-row">
							<text class="summary-label">时间</text>
							<text class="summary-value">{{lastCallTime}}</text>
						</view>
						<view class="summary-row">
							<text class="summary-label">模式</text>
							<text class="summary-value">{{lastCallMode}}</text>
						</view>
						<view class="summary-row">
							<text class="summary-label">模型</text>
							<text class="summary-value summary-url">{{lastCallModel}}</text>
						</view>
						<view class="summary-row">
							<text class="summary-label">缓存键</text>
							<text class="summary-value summary-url">{{snapshotCacheKey}}</text>
						</view>
						<view class="summary-row">
							<text class="summary-label">请求规模</text>
							<text class="summary-value">{{lastCallMessageCount}} 消息 · {{lastCallToolCount}} 工具</text>
						</view>
						<view v-if="lastCallError != ''" class="last-call-error">
							<text class="last-call-error-text">{{lastCallError}}</text>
						</view>
					</view>
				</view>
			</view>

			<view id="section-full-json" class="card">
				<view class="section-row">
					<text class="section-title">完整上下文</text>
					<text class="mini-btn" @click="copyAll">复制</text>
				</view>
				<text class="code-text">{{fullJsonText}}</text>
			</view>
			<view id="anchor-bottom" class="anchor-spacer"></view>
		</scroll-view>
		<view class="custom-scrollbar" v-if="scrollViewHeight > 0 && scrollContentHeight > scrollViewHeight" @touchstart="onScrollbarTrackTap" @touchend="onScrollbarTouchEnd">
			<view class="scrollbar-thumb" :style="scrollbarThumbStyle" @touchstart.stop="onScrollbarThumbStart" @touchmove.stop.prevent="onScrollbarThumbMove" />
		</view>
	</view>
	</view>
</template>

<script lang="uts">
	import { consumeContextPreviewPayload } from '@/utils/runtime-state.uts'
	import {
		buildContextScrollbarThumbStyle,
		buildContextSnapshotDisplayText,
		buildLastCallBadgeClass,
		decodeContextDisplayEscapes,
		estimateContextSize,
		formatContextNumberValue,
		readContextNumberField,
	} from '@/utils/context-preview-helpers.uts'

	export default {
		data() {
			return {
				previewText: '' as string,
				previewDisplayText: '' as string,
				scrollTop: 0 as number,
				scrollRequestSeq: 0 as number,
				layoutTopMap: {} as UTSJSONObject,
				baseUrl: '' as string,
				requestUrl: '' as string,
				model: '' as string,
				messageCount: 0 as number,
				lastCallStatus: '未知' as string,
				lastCallTime: '—' as string,
				lastCallMode: '—' as string,
				lastCallModel: '—' as string,
				lastCallMessageCount: '—' as string,
				lastCallToolCount: '—' as string,
				lastCallError: '' as string,
				snapshotCacheKey: '—' as string,
				toolCount: 0 as number,
				usagePromptTokens: '—' as string,
				usageCompletionTokens: '—' as string,
				usageTotalTokens: '—' as string,
				usageCacheHitTokens: '—' as string,
				usageCallCount: '—' as string,
				usageAccumPromptTokens: '—' as string,
				usageAccumCacheHitTokens: '—' as string,
				usageCacheHitRatio: '—' as string,
				contextCharCount: '—' as string,
				contextEstimatedTokens: '—' as string,
				settingsTemperature: '—' as string,
				settingsMaxTokens: '—' as string,
				settingsMaxIterations: '—' as string,
				settingsStreamEnabled: false as boolean,
				fullJsonText: '' as string,
				responsePreviewText: '' as string,
				thinkingPreviewText: '' as string,
				// 自定义滚动条
				scrollViewHeight: 0 as number,
				scrollContentHeight: 0 as number,
				scrollOffset: 0 as number,
				scrollbarDragging: false as boolean,
				scrollbarDragStartY: 0 as number,
				scrollbarDragStartTop: 0 as number,
				scrollbarTrackTop: 0 as number,
				scrollbarThrottleTimer: 0 as number,
				scrollbarPendingTarget: -1 as number,
			}
		},
		computed: {
			scrollbarThumbStyle(): string {
				return buildContextScrollbarThumbStyle(this.scrollContentHeight, this.scrollViewHeight, this.scrollOffset)
			},

			lastCallBadgeClass(): string {
				return buildLastCallBadgeClass(this.lastCallStatus)
			},
		},
		onLoad() {
			const raw = consumeContextPreviewPayload()
			if (raw == '') {
				this.previewText = '（没有可展示的上下文）'
				this.previewDisplayText = '（没有可展示的上下文）'
				return
			}
			this.previewText = raw
			this.previewDisplayText = decodeContextDisplayEscapes(raw)
			this.fullJsonText = this.previewDisplayText
			const trimmed = raw.trim()
			if (trimmed.startsWith('{') == false) {
				this.scheduleLayoutCache()
				setTimeout(() => { this.measureScrollSize() }, 300)
				setTimeout(() => { this.measureScrollSize() }, 800)
				return
			}
			try {
				const parsed = JSON.parse(raw) as UTSJSONObject
				const baseUrl = parsed['baseUrl'] as string | null
				const requestUrl = parsed['url'] as string | null
				const model = parsed['model'] as string | null
				const requestBody = parsed['requestBody'] as UTSJSONObject | null
				this.baseUrl = baseUrl != null ? baseUrl : ''
				this.requestUrl = requestUrl != null ? requestUrl : ''
				this.model = model != null ? model : ''
				const streamEnabled = parsed['stream'] as boolean | null
				if (streamEnabled == true) {
					this.lastCallMode = '流式'
				} else if (streamEnabled == false) {
					this.lastCallMode = '非流式'
				}
				const timeText = parsed['timeText'] as string | null
				this.lastCallTime = timeText != null && timeText != '' ? timeText : '—'
				const cacheKey = parsed['cacheKey'] as string | null
				this.snapshotCacheKey = cacheKey != null && cacheKey != '' ? cacheKey : '—'
				const rawMessageCount = parsed['messageCount'] as number | null
				this.messageCount = rawMessageCount != null ? rawMessageCount : 0
				const rawToolCount = parsed['toolCount'] as number | null
				this.toolCount = rawToolCount != null ? rawToolCount : 0
				this.lastCallStatus = '已捕获'
				const usage = parsed['usage'] as UTSJSONObject | null
				this.applyTokenUsage(usage)
				const usageStats = parsed['conversationTokenUsageStats'] as UTSJSONObject | null
				this.applyConversationUsageStats(usageStats)
				if (requestBody != null) {
					const bodyText = JSON.stringify(requestBody, null, 2)
					this.applyContextSize(bodyText)
					const responseText = parsed['responseText'] as string | null
					const thinkingText = parsed['thinkingText'] as string | null
					this.responsePreviewText = responseText != null ? decodeContextDisplayEscapes(responseText) : ''
					this.thinkingPreviewText = thinkingText != null ? decodeContextDisplayEscapes(thinkingText) : ''
					const combined = buildContextSnapshotDisplayText(bodyText, responseText, thinkingText)
					this.fullJsonText = decodeContextDisplayEscapes(combined)
					this.previewText = combined
					const bodyMessages = requestBody['messages'] as UTSJSONObject[] | null
					if (bodyMessages != null) {
						this.messageCount = bodyMessages.length
					}
					const bodyTools = requestBody['tools'] as UTSJSONObject[] | null
					if (bodyTools != null) {
						this.toolCount = bodyTools.length
					}
					const temp = requestBody['temperature'] as number | null
					const mt = requestBody['max_tokens'] as number | null
					const se = requestBody['stream'] as boolean | null
					const bodyModel = requestBody['model'] as string | null
					if (bodyModel != null && bodyModel != '') { this.model = bodyModel }
					if (temp != null) { this.settingsTemperature = '' + temp }
					if (mt != null) { this.settingsMaxTokens = '' + mt }
					if (se != null) { this.settingsStreamEnabled = se }
				}
				this.settingsMaxIterations = '—'
				this.lastCallModel = this.model != '' ? this.model : '—'
				this.lastCallMessageCount = '' + this.messageCount
				this.lastCallToolCount = '' + this.toolCount
			} catch (_e: any) {
			}
			this.scheduleLayoutCache()
			setTimeout(() => { this.measureScrollSize() }, 300)
			setTimeout(() => { this.measureScrollSize() }, 800)
		},
		methods: {
			applyContextSize(bodyText: string): void {
				const size = estimateContextSize(bodyText)
				this.contextCharCount = size.charCount
				// TOKEN_ESTIMATE: 未引入 tokenizer，原始上下文页只给粗估值；实际 billing 仍以 provider usage 为准。
				this.contextEstimatedTokens = size.estimatedTokens
			},

			applyTokenUsage(usage: UTSJSONObject | null): void {
				if (usage == null) { return }
				const promptTokens = readContextNumberField(usage, 'prompt_tokens')
				const completionTokens = readContextNumberField(usage, 'completion_tokens')
				let totalTokens = readContextNumberField(usage, 'total_tokens')
				const cacheHitTokens = readContextNumberField(usage, 'prompt_cache_hit_tokens')
				if (totalTokens == null && promptTokens != null && completionTokens != null) {
					totalTokens = promptTokens + completionTokens
				}
				this.usagePromptTokens = formatContextNumberValue(promptTokens)
				this.usageCompletionTokens = formatContextNumberValue(completionTokens)
				this.usageTotalTokens = formatContextNumberValue(totalTokens)
				this.usageCacheHitTokens = formatContextNumberValue(cacheHitTokens)
			},

			applyConversationUsageStats(stats: UTSJSONObject | null): void {
				if (stats == null) { return }
				const promptTokens = readContextNumberField(stats, 'prompt_tokens')
				const cacheHitTokens = readContextNumberField(stats, 'prompt_cache_hit_tokens')
				const callCount = readContextNumberField(stats, 'call_count')
				this.usageAccumPromptTokens = formatContextNumberValue(promptTokens)
				this.usageAccumCacheHitTokens = formatContextNumberValue(cacheHitTokens)
				this.usageCallCount = formatContextNumberValue(callCount)
				if (promptTokens != null && cacheHitTokens != null && promptTokens > 0) {
					const ratio = Math.round((cacheHitTokens / promptTokens) * 1000) / 10
					this.usageCacheHitRatio = ratio + '%'
				}
			},

			scheduleLayoutCache(): void {
				setTimeout(() => {
					this.cacheLayoutMetrics()
				}, 80)
				setTimeout(() => {
					this.cacheLayoutMetrics()
				}, 240)
			},

			cacheLayoutMetrics(): void {
				const ids: string[] = ['context-scroll', 'anchor-top', 'anchor-bottom', 'section-response', 'section-summary', 'section-full-json']
				const query = uni.createSelectorQuery().in(this)
				for (let i = 0; i < ids.length; i++) {
					const id = ids[i]
					if (id != '') {
						query.select('#' + id).boundingClientRect()
					}
				}
				query.exec((res: any) => {
					const rows = res as UTSArray<any> | null
					if (rows == null || rows.length == 0) {
						return
					}
					const map: UTSJSONObject = {}
					const scrollRect = rows[0] as NodeInfo | null
					const baseTop = scrollRect?.top ?? 0
					const limit = rows.length < ids.length ? rows.length : ids.length
					for (let i = 1; i < limit; i++) {
						const id = ids[i]
						if (id == '') {
							continue
						}
						const row = rows[i] as NodeInfo | null
						if (row == null) {
							continue
						}
						const top = row.top
						if (top == null) {
							continue
						}
						map[id] = top - baseTop
					}
					this.layoutTopMap = map
				})
			},

			/** 页面滚动时同步偏移量给自定义滚动条 */
			onPageScroll(e: UniScrollEvent): void {
				this.scrollOffset = e.detail.scrollTop
			},

			// ====== 自定义滚动条方法 ======

			/** 点滚动条轨道直接跳转 */
			onScrollbarTrackTap(e: UniTouchEvent) {
				const y = this.getTouchRelativeY(e)
				if (y == null || this.scrollContentHeight <= 0 || this.scrollViewHeight <= 0) return
				const trackH = this.scrollViewHeight - 4
				if (trackH <= 0) return
				const maxScroll = this.scrollContentHeight - this.scrollViewHeight
				const ratio = y / trackH
				let target = ratio * maxScroll
				if (target < 0) target = 0
				if (target > maxScroll) target = maxScroll
				this.scrollTop = target
				this.scrollOffset = target
				this.scrollRequestSeq++
			},

			/** 开始拖拽滚动条滑块 */
			onScrollbarThumbStart(e: UniTouchEvent) {
				const y = this.getTouchRelativeY(e)
				if (y == null) return
				this.scrollbarDragStartTop = this.scrollTop
				this.scrollbarDragStartY = y
				this.scrollbarDragging = true
			},

			/** 拖拽滚动条滑块中 */
			onScrollbarThumbMove(e: UniTouchEvent) {
				if (this.scrollbarDragging == false) return
				const y = this.getTouchRelativeY(e)
				if (y == null || this.scrollContentHeight <= 0 || this.scrollViewHeight <= 0) return
				const dy = y - this.scrollbarDragStartY
				const trackH = this.scrollViewHeight - 4
				if (trackH <= 0) return
				const maxScroll = this.scrollContentHeight - this.scrollViewHeight
				const ratio = this.scrollViewHeight / this.scrollContentHeight
				const thumbH = Math.max(trackH * ratio, 36)
				const maxTop = trackH - thumbH
				const scale = maxTop > 0 ? maxScroll / maxTop : 0
				let target = this.scrollbarDragStartTop + dy * scale
				if (target < 0) target = 0
				if (target > maxScroll) target = maxScroll
				this.scrollTop = target
				this.scrollOffset = target
				this.scrollRequestSeq++
			},

			/** 拖拽结束 */
			onScrollbarTouchEnd(_e: UniTouchEvent) {
				this.scrollbarDragging = false
			},

			/** 从触摸事件提取 Y 坐标（相对于轨道顶部） */
			getTouchRelativeY(e: UniTouchEvent): number | null {
				if (e.touches.length == 0) return null
				const pageY = e.touches[0].pageY
				if (this.scrollbarTrackTop <= 0) return null
				return pageY - this.scrollbarTrackTop
			},

			/** 测量滚动尺寸 */
			measureScrollSize() {
				const query = uni.createSelectorQuery().in(this)
				query.select('#context-scroll').boundingClientRect()
				query.select('#anchor-bottom').boundingClientRect()
				query.exec((res: any) => {
					const rows = res as UTSArray<any> | null
					if (rows == null || rows.length < 2) return
					const viewRect = rows[0] as NodeInfo | null
					const anchorRect = rows[1] as NodeInfo | null
					if (viewRect != null) {
						if (viewRect.height != null) {
							this.scrollViewHeight = viewRect.height as number
						}
						if (viewRect.top != null) {
							this.scrollbarTrackTop = viewRect.top as number
						}
					}
					if (anchorRect != null && viewRect != null) {
						const anchorTop = anchorRect.top as number | null
						const viewTop = viewRect.top as number | null
						const anchorH = anchorRect.height as number | null
						if (anchorTop != null && viewTop != null && anchorH != null) {
							this.scrollContentHeight = anchorTop - viewTop + anchorH
						}
					}
				})
			},


			commitScrollTop(targetTop: number): void {
				let safeTop = targetTop
				if (safeTop < 0) {
					safeTop = 0
				}
				this.scrollRequestSeq = this.scrollRequestSeq + 1
				const requestId = this.scrollRequestSeq
				setTimeout(() => {
					if (requestId != this.scrollRequestSeq) {
						return
					}
					this.scrollTop = safeTop
				}, 16)
			},

			scrollToSectionWithOffset(id: string, offsetTop: number): void {
				const cachedTop = this.layoutTopMap[id] as number | null
				if (cachedTop != null) {
					this.commitScrollTop(cachedTop + offsetTop - 24)
					return
				}
				if (id == 'anchor-top') {
					this.commitScrollTop(0)
					return
				}
				if (id == 'anchor-bottom') {
					this.commitScrollTop(this.scrollContentHeight > 0 ? this.scrollContentHeight : 99999)
					return
				}
				this.scheduleLayoutCache()
				setTimeout(() => {
					const retryTop = this.layoutTopMap[id] as number | null
					if (retryTop != null) {
						this.commitScrollTop(retryTop + offsetTop - 24)
					}
				}, 320)
			},

			scrollToSection(id: string): void {
				this.scrollToSectionWithOffset(id, 0)
			},

			scrollToTop() {
				this.scrollToSection('anchor-top')
			},

			scrollToBottom() {
				const query = uni.createSelectorQuery().in(this)
				query.select('#anchor-bottom').boundingClientRect()
				query.select('#context-scroll').boundingClientRect()
				query.exec((res: any) => {
					const rows = res as UTSArray<any> | null
					if (rows == null || rows.length < 2) {
						this.commitScrollTop(99999)
						return
					}
					const anchorRect = rows[0] as NodeInfo | null
					const scrollRect = rows[1] as NodeInfo | null
					if (anchorRect == null || scrollRect == null) {
						this.commitScrollTop(99999)
						return
					}
					const anchorTop = anchorRect.top as number | null
					const scrollTop = scrollRect.top as number | null
					if (anchorTop != null && scrollTop != null) {
						this.commitScrollTop(anchorTop - scrollTop + 20)
					} else {
						this.commitScrollTop(99999)
					}
				})
			},


			copyAll() {
				if (this.previewText == '') {
					uni.showToast({ position: 'bottom',
						title: '没有可复制内容',
						icon: 'none'
					})
					return
				}
				uni.setClipboardData({
					data: this.previewText,
					success: () => {
						uni.showToast({ position: 'bottom',
							title: '已复制',
							icon: 'none'
						})
					}
				})
			},

			goBack() {
				uni.navigateBack()
			},
		}
	}
</script>

<style>
	.container {
		flex: 1;
		padding: 12px;
