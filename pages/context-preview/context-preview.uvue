<template>
	<view class="page-shell rice-theme-light">
		<NavBar title="原始上下文" showBack @back="goBack">
			<template #right>
				<text class="nav-btn" @click="copyAll">复制</text>
			</template>
		</NavBar>
		<view class="scroll-wrapper">
			<scroll-view id="context-scroll" class="container" :scroll-y="true" :scroll-with-animation="false" :show-scrollbar="false" :scroll-top="scrollTop" @scroll="onPageScroll">
			<view id="anchor-top" class="anchor-spacer"></view>
			<view class="hero-card">
				<text class="hero-title">发送前完整上下文</text>
				<text class="hero-desc">这里展示本轮真正会发给 agent 的首轮原始上下文，包含系统提示词、记忆动态注入、消息重写结果、工具定义与请求体。不会显示 API Key。</text>
			</view>

			<view id="section-summary" class="card summary-card">
				<text class="section-title">摘要</text>
				<view class="summary-section">
					<text class="summary-section-title">请求目标</text>
					<view class="summary-row">
						<text class="summary-label">模型</text>
						<text class="summary-value summary-value-strong">{{model != '' ? model : '未解析'}}</text>
					</view>
					<view class="summary-row">
						<text class="summary-label">Provider</text>
						<text class="summary-value">{{providerId != '' ? providerId : '未解析'}}</text>
					</view>
					<view class="summary-row">
						<text class="summary-label">Base URL</text>
						<text class="summary-value summary-url">{{baseUrl != '' ? baseUrl : '未解析'}}</text>
					</view>
					<view class="summary-row">
						<text class="summary-label">工具定义</text>
						<text class="summary-value">{{toolCount}} 个</text>
					</view>
				</view>

				<view class="summary-section">
					<text class="summary-section-title">生成参数</text>
					<view class="summary-param-row">
						<view class="summary-param-pill">
							<text class="summary-param-label">temperature</text>
							<text class="summary-param-value">{{settingsTemperature}}</text>
						</view>
						<view class="summary-param-pill">
							<text class="summary-param-label">max_tokens</text>
							<text class="summary-param-value">{{settingsMaxTokens}}</text>
						</view>
						<view class="summary-param-pill">
							<text class="summary-param-label">max_iter</text>
							<text class="summary-param-value">{{settingsMaxIterations}}</text>
						</view>
						<view class="summary-param-pill summary-param-pill-last">
							<text class="summary-param-label">stream</text>
							<text class="summary-param-value">{{settingsStreamEnabled ? '开' : '关'}}</text>
						</view>
					</view>
				</view>

				<view class="summary-section">
					<text class="summary-section-title">上下文规模（Token 估算）</text>
					<view class="summary-main-metrics">
						<view class="summary-metric">
							<text class="summary-metric-value">{{totalMessages}}</text>
							<text class="summary-metric-label">原始消息</text>
						</view>
						<view class="summary-metric">
							<text class="summary-metric-value">{{messageCount}}</text>
							<text class="summary-metric-label">发送消息</text>
						</view>
						<view class="summary-metric">
							<text class="summary-metric-value">{{droppedCount}}</text>
							<text class="summary-metric-label">已截断</text>
						</view>
						<view class="summary-metric summary-metric-last">
							<text class="summary-metric-value">≈ {{totalTokens}}</text>
							<text class="summary-metric-label">Token 估算</text>
						</view>
					</view>
					<view class="summary-role-list">
						<text class="summary-role-text">user：{{userMsgCount}} 条 / {{userCharCount}} 字</text>
						<text class="summary-role-text">assistant：{{assistantMsgCount}} 条 / {{assistantCharCount}} 字</text>
						<text class="summary-role-text">system：{{systemMsgCount}} 条 / {{systemCharCount}} 字</text>
						<text class="summary-role-text">tool：{{toolMsgCount}} 条 / {{toolCharCount}} 字</text>
					</view>
				</view>

				<view class="summary-section summary-section-last">
					<text class="summary-section-title">上次调用</text>
					<view class="last-call-panel">
						<view class="last-call-head">
							<text class="last-call-title">调用结果</text>
							<text class="last-call-badge" :class="lastCallBadgeClass">{{lastCallStatus}}</text>
						</view>
						<view class="summary-row">
							<text class="summary-label">时间</text>
							<text class="summary-value">{{lastCallTime}}</text>
						</view>
						<view class="summary-row">
							<text class="summary-label">模式 / 状态码</text>
							<text class="summary-value">{{lastCallMode}} · {{lastCallStatusCode}}</text>
						</view>
						<view class="summary-row">
							<text class="summary-label">模型</text>
							<text class="summary-value summary-url">{{lastCallModel}}</text>
						</view>
						<view class="summary-row">
							<text class="summary-label">地址</text>
							<text class="summary-value summary-url">{{lastCallBaseUrl}}</text>
						</view>
						<view class="summary-row">
							<text class="summary-label">请求规模</text>
							<text class="summary-value">{{lastCallMessageCount}} 消息 · {{lastCallToolCount}} 工具</text>
						</view>
						<view class="summary-row">
							<text class="summary-label">输出</text>
							<text class="summary-value">{{lastCallTextLength}} 字 · 工具调用 {{lastCallHasToolCalls}}</text>
						</view>
						<view class="last-usage-panel">
							<text class="last-usage-title">用量</text>
							<view class="last-usage-line">
								<text class="last-usage-label">Token</text>
								<text class="last-usage-value">输入 {{lastPromptTokensText}} · 输出 {{lastCompletionTokensText}} · 合计 {{lastTotalTokensText}}</text>
							</view>
							<view class="last-usage-line">
								<text class="last-usage-label">缓存</text>
								<text class="last-usage-value">命中 {{lastPromptCacheHitTokensText}} · 上次 {{lastPromptCacheHitRateText}} · 会话 {{conversationPromptCacheHitRateText}}</text>
							</view>
							<view class="last-usage-line last-usage-line-last">
								<text class="last-usage-label">累计</text>
								<text class="last-usage-value">{{conversationPromptCacheHitTokensText}} / {{conversationPromptTokensText}} · {{conversationUsageCallCountText}} 次</text>
							</view>
						</view>
						<view v-if="lastCallError != ''" class="last-call-error">
							<text class="last-call-error-text">{{lastCallError}}</text>
						</view>
					</view>
				</view>
			</view>

			<view id="section-full-json" class="card">
				<view class="section-row">
					<text class="section-title">完整 JSON</text>
					<text class="mini-btn" @click="copyAll">复制</text>
				</view>
				<text class="code-text">{{fullJsonText}}</text>
			</view>
			<view id="anchor-bottom" class="anchor-spacer"></view>
		</scroll-view>
		<view class="custom-scrollbar" v-if="scrollViewHeight > 0 && scrollContentHeight > scrollViewHeight" @touchstart="onScrollbarTrackTap" @touchend="onScrollbarTouchEnd">
			<view class="scrollbar-thumb" :style="scrollbarThumbStyle" @touchstart.stop="onScrollbarThumbStart" @touchmove.stop.prevent="onScrollbarThumbMove" />
		</view>
	</view>
	</view>
</template>

<script lang="uts">
	export default {
		data() {
			return {
				previewText: '' as string,
				previewDisplayText: '' as string,
				scrollTop: 0 as number,
				scrollRequestSeq: 0 as number,
				layoutTopMap: {} as UTSJSONObject,
				providerId: '' as string,
				baseUrl: '' as string,
				model: '' as string,
				messageCount: 0 as number,
				totalMessages: 0 as number,
				droppedCount: 0 as number,
				userMsgCount: 0 as number,
				userCharCount: 0 as number,
				assistantMsgCount: 0 as number,
				assistantCharCount: 0 as number,
				systemMsgCount: 0 as number,
				systemCharCount: 0 as number,
				toolMsgCount: 0 as number,
				toolCharCount: 0 as number,
				totalCharCount: 0 as number,
				totalTokens: 0 as number,
				lastPromptTokens: 0 as number,
				lastCompletionTokens: 0 as number,
				lastTotalTokens: 0 as number,
				lastPromptTokensText: '—' as string,
				lastCompletionTokensText: '—' as string,
				lastTotalTokensText: '—' as string,
				lastPromptCacheHitTokensText: '—' as string,
				lastPromptCacheHitRateText: '—' as string,
				conversationPromptCacheHitRateText: '—' as string,
				conversationPromptCacheHitTokensText: '—' as string,
				conversationPromptTokensText: '—' as string,
				conversationUsageCallCountText: '—' as string,
				lastCallStatus: '未知' as string,
				lastCallTime: '—' as string,
				lastCallMode: '—' as string,
				lastCallStatusCode: '—' as string,
				lastCallModel: '—' as string,
				lastCallBaseUrl: '—' as string,
				lastCallMessageCount: '—' as string,
				lastCallToolCount: '—' as string,
				lastCallTextLength: '—' as string,
				lastCallHasToolCalls: '—' as string,
				lastCallError: '' as string,
				toolCount: 0 as number,
				settingsTemperature: '—' as string,
				settingsMaxTokens: '—' as string,
				settingsMaxIterations: '—' as string,
				settingsStreamEnabled: false as boolean,
				fullJsonText: '' as string,
				// 自定义滚动条
				scrollViewHeight: 0 as number,
				scrollContentHeight: 0 as number,
				scrollOffset: 0 as number,
				scrollbarDragging: false as boolean,
				scrollbarDragStartY: 0 as number,
				scrollbarDragStartTop: 0 as number,
				scrollbarTrackTop: 0 as number,
				scrollbarThrottleTimer: 0 as number,
				scrollbarPendingTarget: -1 as number,
			}
		},
		computed: {
			scrollbarThumbStyle(): string {
				if (this.scrollContentHeight <= 0 || this.scrollViewHeight <= 0) {
					return 'top:0;height:0;'
				}
				const trackH = this.scrollViewHeight - 4
				const ratio = this.scrollViewHeight / this.scrollContentHeight
				const thumbH = Math.max(trackH * ratio, 36)
				const maxTop = trackH - thumbH
				const maxScroll = this.scrollContentHeight - this.scrollViewHeight
				const currentOffset = this.scrollOffset
				const rawTop = maxScroll > 0 ? (currentOffset / maxScroll) * maxTop : 0
				let top = rawTop
				if (top < 0) top = 0
				if (top > maxTop) top = maxTop
				return 'top:' + top + 'px;height:' + thumbH + 'px;'
			},

			lastCallBadgeClass(): string {
				if (this.lastCallStatus == '成功') return 'last-call-badge-ok'
				if (this.lastCallStatus == '失败') return 'last-call-badge-error'
				return 'last-call-badge-unknown'
			},
		},
		onLoad() {
			const raw = uni.getStorageSync('context_preview_payload') as string | null
			if (raw == null || raw == '') {
				this.previewText = '（没有可展示的上下文）'
				this.previewDisplayText = '（没有可展示的上下文）'
				return
			}
			this.previewText = raw
			this.previewDisplayText = this.decodeDisplayEscapes(raw)
			this.fullJsonText = this.previewDisplayText
			try {
				const parsed = JSON.parse(raw) as UTSJSONObject
				const providerId = parsed['providerId'] as string | null
				const baseUrl = parsed['baseUrl'] as string | null
				const model = parsed['model'] as string | null
				const settings = parsed['settings'] as UTSJSONObject | null
				const openaiMessages = parsed['openaiMessages'] as UTSJSONObject[] | null
				const openaiTools = parsed['openaiTools'] as UTSJSONObject[] | null
				const requestBody = parsed['requestBody'] as UTSJSONObject | null
				const lastCallInfo = parsed['lastCallInfo'] as UTSJSONObject | null
				const conversationTokenUsageStats = parsed['conversationTokenUsageStats'] as UTSJSONObject | null
				this.providerId = providerId != null ? providerId : ''
				this.baseUrl = baseUrl != null ? baseUrl : ''
				this.model = model != null ? model : ''
				this.messageCount = openaiMessages != null ? openaiMessages.length : 0
				const rawTotal = parsed['totalMessages'] as number | null
				this.totalMessages = rawTotal != null ? rawTotal : this.messageCount
				const rawDropped = parsed['droppedCount'] as number | null
				this.droppedCount = rawDropped != null ? rawDropped : 0
				// 按角色统计消息数和字数
				if (openaiMessages != null) {
					let uc = 0; let ucc = 0; let ac = 0; let acc = 0
					let sc = 0; let scc = 0; let tc = 0; let tcc = 0
					let allChars = 0
					for (let i = 0; i < openaiMessages.length; i++) {
						const msg = openaiMessages[i]
						const role = msg['role'] as string | null
						const content = msg['content'] as string | null
						const clen = content != null ? content.length : 0
						allChars += clen
						if (role == 'user') { uc++; ucc += clen }
						else if (role == 'assistant') { ac++; acc += clen }
						else if (role == 'system') { sc++; scc += clen }
						else if (role == 'tool') { tc++; tcc += clen }
					}
					this.userMsgCount = uc; this.userCharCount = ucc
					this.assistantMsgCount = ac; this.assistantCharCount = acc
					this.systemMsgCount = sc; this.systemCharCount = scc
					this.toolMsgCount = tc; this.toolCharCount = tcc
					this.totalCharCount = allChars
					this.totalTokens = Math.round(allChars / 2)
				}
				this.toolCount = openaiTools != null ? openaiTools.length : 0
				// 上次调用信息
				const ltu = parsed['lastTokenUsage'] as UTSJSONObject | null
				if (ltu != null) {
					this.applyLastTokenUsage(ltu)
				}
				if (lastCallInfo != null) {
					this.applyLastCallInfo(lastCallInfo)
				}
				if (conversationTokenUsageStats != null) {
					this.applyConversationTokenUsageStats(conversationTokenUsageStats)
				}
				if (settings != null) {
					const temp = settings['temperature'] as number | null
					const mt = settings['maxTokens'] as number | null
					const mi = settings['maxIterations'] as number | null
					const se = settings['streamEnabled'] as boolean | null
					if (temp != null) { this.settingsTemperature = '' + temp }
					if (mt != null) { this.settingsMaxTokens = '' + mt }
					if (mi != null) { this.settingsMaxIterations = '' + mi }
					if (se != null) { this.settingsStreamEnabled = se }
				}
			} catch (_e: any) {
			}
			this.scheduleLayoutCache()
			setTimeout(() => { this.measureScrollSize() }, 300)
			setTimeout(() => { this.measureScrollSize() }, 800)
		},
		methods: {
			formatPercentText(hitTokens: number, promptTokens: number): string {
				if (promptTokens <= 0) {
					return '—'
				}
				const basis = Math.round(hitTokens * 10000 / promptTokens)
				const whole = Math.floor(basis / 100)
				const fraction = basis - whole * 100
				if (fraction <= 0) {
					return '' + whole + '%'
				}
				if (fraction < 10) {
					return '' + whole + '.0' + fraction + '%'
				}
				if (fraction % 10 == 0) {
					return '' + whole + '.' + (fraction / 10) + '%'
				}
				return '' + whole + '.' + fraction + '%'
			},

			applyLastTokenUsage(usage: UTSJSONObject): void {
				const pt = usage['prompt_tokens'] as number | null
				const ct = usage['completion_tokens'] as number | null
				const tt = usage['total_tokens'] as number | null
				const cacheHit = usage['prompt_cache_hit_tokens'] as number | null
				const cacheReported = usage['prompt_cache_hit_tokens_reported'] as boolean | null
				if (pt != null) {
					this.lastPromptTokens = pt
					this.lastPromptTokensText = '' + pt
				}
				if (ct != null) {
					this.lastCompletionTokens = ct
					this.lastCompletionTokensText = '' + ct
				}
				if (tt != null) {
					this.lastTotalTokens = tt
					this.lastTotalTokensText = '' + tt
				}
				if (cacheReported == true && cacheHit != null) {
					this.lastPromptCacheHitTokensText = '' + cacheHit
					this.lastPromptCacheHitRateText = this.formatPercentText(cacheHit, pt != null ? pt : 0)
				}
			},

			applyConversationTokenUsageStats(stats: UTSJSONObject): void {
				const promptTokens = stats['prompt_tokens'] as number | null
				const cacheHitTokens = stats['prompt_cache_hit_tokens'] as number | null
				const callCount = stats['call_count'] as number | null
				const pt = promptTokens != null ? promptTokens : 0
				const hit = cacheHitTokens != null ? cacheHitTokens : 0
				this.conversationPromptTokensText = pt > 0 ? ('' + pt) : '—'
				this.conversationPromptCacheHitTokensText = pt > 0 ? ('' + hit) : '—'
				const calls = callCount != null ? callCount : 0
				this.conversationUsageCallCountText = calls > 0 ? ('' + calls) : '—'
				this.conversationPromptCacheHitRateText = this.formatPercentText(hit, pt)
			},

			applyLastCallInfo(info: UTSJSONObject): void {
				const success = info['success'] as boolean | null
				if (success == true) {
					this.lastCallStatus = '成功'
				} else if (success == false) {
					this.lastCallStatus = '失败'
				} else {
					this.lastCallStatus = '未知'
				}
				const timeText = info['timeText'] as string | null
				this.lastCallTime = timeText != null && timeText != '' ? timeText : '—'
				const streamEnabled = info['stream'] as boolean | null
				if (streamEnabled == true) {
					this.lastCallMode = '流式'
				} else if (streamEnabled == false) {
					this.lastCallMode = '非流式'
				} else {
					this.lastCallMode = '—'
				}
				const statusCode = info['statusCode'] as number | null
				this.lastCallStatusCode = statusCode != null ? ('' + statusCode) : '—'
				const model = info['model'] as string | null
				this.lastCallModel = model != null && model != '' ? model : '—'
				const baseUrl = info['baseUrl'] as string | null
				this.lastCallBaseUrl = baseUrl != null && baseUrl != '' ? baseUrl : '—'
				const messageCount = info['messageCount'] as number | null
				this.lastCallMessageCount = messageCount != null ? ('' + messageCount) : '—'
				const toolCount = info['toolCount'] as number | null
				this.lastCallToolCount = toolCount != null ? ('' + toolCount) : '—'
				const textLength = info['textLength'] as number | null
				this.lastCallTextLength = textLength != null ? ('' + textLength) : '—'
				const hasToolCalls = info['hasToolCalls'] as boolean | null
				if (hasToolCalls == true) {
					this.lastCallHasToolCalls = '有'
				} else if (hasToolCalls == false) {
					this.lastCallHasToolCalls = '无'
				} else {
					this.lastCallHasToolCalls = '—'
				}
				const errorMessage = info['errorMessage'] as string | null
				this.lastCallError = errorMessage != null ? errorMessage : ''
				const usage = info['usage'] as UTSJSONObject | null
				if (usage != null) {
					this.applyLastTokenUsage(usage)
				}
			},

			scheduleLayoutCache(): void {
				setTimeout(() => {
					this.cacheLayoutMetrics()
				}, 80)
				setTimeout(() => {
					this.cacheLayoutMetrics()
				}, 240)
			},

			cacheLayoutMetrics(): void {
				const ids: string[] = ['context-scroll', 'anchor-top', 'anchor-bottom', 'section-summary', 'section-full-json']
				const query = uni.createSelectorQuery().in(this)
				for (let i = 0; i < ids.length; i++) {
					const id = ids[i]
					if (id != '') {
						query.select('#' + id).boundingClientRect()
					}
				}
				query.exec((res: any) => {
					const rows = res as UTSArray<any> | null
					if (rows == null || rows.length == 0) {
						return
					}
					const map: UTSJSONObject = {}
					const scrollRect = rows[0] as NodeInfo | null
					const baseTop = scrollRect?.top ?? 0
					const limit = rows.length < ids.length ? rows.length : ids.length
					for (let i = 1; i < limit; i++) {
						const id = ids[i]
						if (id == '') {
							continue
						}
						const row = rows[i] as NodeInfo | null
						if (row == null) {
							continue
						}
						const top = row.top
						if (top == null) {
							continue
						}
						map[id] = top - baseTop
					}
					this.layoutTopMap = map
				})
			},

			/** 页面滚动时同步偏移量给自定义滚动条 */
			onPageScroll(e: UniScrollEvent): void {
				this.scrollOffset = e.detail.scrollTop
			},

			// ====== 自定义滚动条方法 ======

			/** 点滚动条轨道直接跳转 */
			onScrollbarTrackTap(e: UniTouchEvent) {
				const y = this.getTouchRelativeY(e)
				if (y == null || this.scrollContentHeight <= 0 || this.scrollViewHeight <= 0) return
				const trackH = this.scrollViewHeight - 4
				if (trackH <= 0) return
				const maxScroll = this.scrollContentHeight - this.scrollViewHeight
				const ratio = y / trackH
				let target = ratio * maxScroll
				if (target < 0) target = 0
				if (target > maxScroll) target = maxScroll
				this.scrollTop = target
				this.scrollOffset = target
				this.scrollRequestSeq++
			},

			/** 开始拖拽滚动条滑块 */
			onScrollbarThumbStart(e: UniTouchEvent) {
				const y = this.getTouchRelativeY(e)
				if (y == null) return
				this.scrollbarDragStartTop = this.scrollTop
				this.scrollbarDragStartY = y
				this.scrollbarDragging = true
			},

			/** 拖拽滚动条滑块中 */
			onScrollbarThumbMove(e: UniTouchEvent) {
				if (this.scrollbarDragging == false) return
				const y = this.getTouchRelativeY(e)
				if (y == null || this.scrollContentHeight <= 0 || this.scrollViewHeight <= 0) return
				const dy = y - this.scrollbarDragStartY
				const trackH = this.scrollViewHeight - 4
				if (trackH <= 0) return
				const maxScroll = this.scrollContentHeight - this.scrollViewHeight
				const ratio = this.scrollViewHeight / this.scrollContentHeight
				const thumbH = Math.max(trackH * ratio, 36)
				const maxTop = trackH - thumbH
				const scale = maxTop > 0 ? maxScroll / maxTop : 0
				let target = this.scrollbarDragStartTop + dy * scale
				if (target < 0) target = 0
				if (target > maxScroll) target = maxScroll
				this.scrollTop = target
				this.scrollOffset = target
				this.scrollRequestSeq++
			},

			/** 拖拽结束 */
			onScrollbarTouchEnd(_e: UniTouchEvent) {
				this.scrollbarDragging = false
			},

			/** 从触摸事件提取 Y 坐标（相对于轨道顶部） */
			getTouchRelativeY(e: UniTouchEvent): number | null {
				if (e.touches.length == 0) return null
				const pageY = e.touches[0].pageY
				if (this.scrollbarTrackTop <= 0) return null
				return pageY - this.scrollbarTrackTop
			},

			/** 测量滚动尺寸 */
			measureScrollSize() {
				const query = uni.createSelectorQuery().in(this)
				query.select('#context-scroll').boundingClientRect()
				query.select('#anchor-bottom').boundingClientRect()
				query.exec((res: any) => {
					const rows = res as UTSArray<any> | null
					if (rows == null || rows.length < 2) return
					const viewRect = rows[0] as NodeInfo | null
					const anchorRect = rows[1] as NodeInfo | null
					if (viewRect != null) {
						if (viewRect.height != null) {
							this.scrollViewHeight = viewRect.height as number
						}
						if (viewRect.top != null) {
							this.scrollbarTrackTop = viewRect.top as number
						}
					}
					if (anchorRect != null && viewRect != null) {
						const anchorTop = anchorRect.top as number | null
						const viewTop = viewRect.top as number | null
						const anchorH = anchorRect.height as number | null
						if (anchorTop != null && viewTop != null && anchorH != null) {
							this.scrollContentHeight = anchorTop - viewTop + anchorH
						}
					}
				})
			},

			decodeDisplayEscapes(text: string): string {
				let result = text
				result = result.replace(/\\r\\n/g, '\n')
				result = result.replace(/\\n/g, '\n')
				result = result.replace(/\\t/g, '  ')
				return result
			},

			buildPreviewBlock(text: string, limit: number): string {
				if (text.length <= limit) {
					return text
				}
				return text.substring(0, limit) + '\n\n…… 已截断显示，复制可查看完整内容 ……'
			},

			commitScrollTop(targetTop: number): void {
				let safeTop = targetTop
				if (safeTop < 0) {
					safeTop = 0
				}
				this.scrollRequestSeq = this.scrollRequestSeq + 1
				const requestId = this.scrollRequestSeq
				setTimeout(() => {
					if (requestId != this.scrollRequestSeq) {
						return
					}
					this.scrollTop = safeTop
				}, 16)
			},

			scrollToSectionWithOffset(id: string, offsetTop: number): void {
				const cachedTop = this.layoutTopMap[id] as number | null
				if (cachedTop != null) {
					this.commitScrollTop(cachedTop + offsetTop - 24)
					return
				}
				if (id == 'anchor-top') {
					this.commitScrollTop(0)
					return
				}
				if (id == 'anchor-bottom') {
					this.commitScrollTop(this.scrollContentHeight > 0 ? this.scrollContentHeight : 99999)
					return
				}
				this.scheduleLayoutCache()
				setTimeout(() => {
					const retryTop = this.layoutTopMap[id] as number | null
					if (retryTop != null) {
						this.commitScrollTop(retryTop + offsetTop - 24)
					}
				}, 320)
			},

			scrollToSection(id: string): void {
				this.scrollToSectionWithOffset(id, 0)
			},

			scrollToTop() {
				this.scrollToSection('anchor-top')
			},

			scrollToBottom() {
				const query = uni.createSelectorQuery().in(this)
				query.select('#anchor-bottom').boundingClientRect()
				query.select('#context-scroll').boundingClientRect()
				query.exec((res: any) => {
					const rows = res as UTSArray<any> | null
					if (rows == null || rows.length < 2) {
						this.commitScrollTop(99999)
						return
					}
					const anchorRect = rows[0] as NodeInfo | null
					const scrollRect = rows[1] as NodeInfo | null
					if (anchorRect == null || scrollRect == null) {
						this.commitScrollTop(99999)
						return
					}
					const anchorTop = anchorRect.top as number | null
					const scrollTop = scrollRect.top as number | null
					if (anchorTop != null && scrollTop != null) {
						this.commitScrollTop(anchorTop - scrollTop + 20)
					} else {
						this.commitScrollTop(99999)
					}
				})
			},

			formatJsonObjectSegment(value: UTSJSONObject, fallback: string): string {
				try {
					return JSON.stringify(value, null, 2)
				} catch (_e: any) {
					try {
						return JSON.stringify(value)
					} catch (_e2: any) {
						return fallback
					}
				}
			},

			formatJsonArraySegment(value: UTSJSONObject[], fallback: string): string {
				try {
					return JSON.stringify(value, null, 2)
				} catch (_e: any) {
					try {
						return JSON.stringify(value)
					} catch (_e2: any) {
						return fallback
					}
				}
			},

			copyAll() {
				if (this.previewText == '') {
					uni.showToast({ position: 'bottom', 
						title: '没有可复制内容',
						icon: 'none'
					})
					return
				}
				uni.setClipboardData({
					data: this.previewText,
					success: () => {
						uni.showToast({ position: 'bottom', 
							title: '已复制',
							icon: 'none'
						})
					}
				})
			},

			goBack() {
				uni.navigateBack()
			},
		}
	}
</script>

