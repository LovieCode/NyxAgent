<template>
	<view class="page-shell rice-theme-light">
		<NavBar title="原始上下文" showBack @back="goBack">
			<template #right>
				<text class="nav-btn" @click="copyAll">复制</text>
			</template>
		</NavBar>
		<view class="scroll-wrapper">
			<scroll-view id="context-scroll" class="container" :scroll-y="true" :scroll-with-animation="false" :show-scrollbar="false" :scroll-top="scrollTop" @scroll="onPageScroll">
			<view id="anchor-top" class="anchor-spacer"></view>
			<view class="hero-card">
				<text class="hero-title">发送前完整上下文</text>
				<text class="hero-desc">这里展示本轮真正会发给 agent 的首轮原始上下文，包含系统提示词、记忆动态注入、消息重写结果、工具定义与请求体。不会显示 API Key。</text>
			</view>

			<view class="card">
				<text class="section-title">搜索定位</text>
				<view class="search-row">
					<input
						class="search-input"
						type="text"
						v-model="searchText"
						placeholder="搜索内容、记忆、工具、JSON 字段..."
						placeholder-style="color:#9CA3AF"
						@confirm="applySearch"
					/>
					<text class="search-btn" @click="applySearch">搜索</text>
				</view>
				<text class="search-meta">{{searchMetaText}}</text>
	
			</view>

			<view id="section-summary" class="card" :class="activeSectionId == 'section-summary' ? 'card-active' : ''">
				<text class="section-title">摘要</text>
				<view class="summary-grid">
					<view class="summary-item">
						<text class="summary-label">模型</text>
						<text class="summary-value">{{model != '' ? model : '未解析'}}</text>
					</view>
					<view class="summary-item">
						<text class="summary-label">接口</text>
						<text class="summary-value">{{providerId != '' ? providerId : '未解析'}}</text>
					</view>
					<view class="summary-item">
						<text class="summary-label">地址</text>
						<text class="summary-value">{{baseUrl != '' ? baseUrl : '未解析'}}</text>
					</view>
					<view class="summary-item">
						<text class="summary-label">温度</text>
						<text class="summary-value">{{settingsTemperature}}</text>
					</view>
					<view class="summary-item">
						<text class="summary-label">最大 Token</text>
						<text class="summary-value">{{settingsMaxTokens}}</text>
					</view>
					<view class="summary-item">
						<text class="summary-label">最大轮次</text>
						<text class="summary-value">{{settingsMaxIterations}}</text>
					</view>
					<view class="summary-item">
						<text class="summary-label">流式</text>
						<text class="summary-value">{{settingsStreamEnabled ? '开' : '关'}}</text>
					</view>
					<view class="summary-item">
						<text class="summary-label">原始消息</text>
						<text class="summary-value">{{totalMessages}} 条</text>
					</view>
					<view class="summary-item">
						<text class="summary-label">保留消息</text>
						<text class="summary-value">{{messageCount}} 条</text>
					</view>
					<view class="summary-item">
						<text class="summary-label">上下文总 Token</text>
						<text class="summary-value">≈ {{totalTokens}}</text>
					</view>
					<view class="summary-item">
						<text class="summary-label">用户消息</text>
						<text class="summary-value">{{userMsgCount}} 条 · {{userCharCount}} 字</text>
					</view>
					<view class="summary-item">
						<text class="summary-label">AI 消息</text>
						<text class="summary-value">{{assistantMsgCount}} 条 · {{assistantCharCount}} 字</text>
					</view>
					<view class="summary-item">
						<text class="summary-label">系统消息</text>
						<text class="summary-value">{{systemMsgCount}} 条 · {{systemCharCount}} 字</text>
					</view>
					<view class="summary-item">
						<text class="summary-label">工具消息</text>
						<text class="summary-value">{{toolMsgCount}} 条 · {{toolCharCount}} 字</text>
					</view>
					<view class="summary-item">
						<text class="summary-label">工具定义</text>
						<text class="summary-value">{{toolCount}} 个</text>
					</view>
					<view class="summary-item">
						<text class="summary-label">重要记忆</text>
						<text class="summary-value">{{importantMemory != '' ? '有' : '无'}}</text>
					</view>
					<view class="summary-item">
						<text class="summary-label">短缓存</text>
						<text class="summary-value">{{bufferInjection != '' ? '有' : '无'}}</text>
					</view>
					<view v-if="lastTotalTokens > 0" class="summary-item" style="background-color:#F0FFF4;border-radius:16rpx;padding:8rpx 16rpx;">
						<text class="summary-label" style="color:#059669;">上次调用</text>
						<text class="summary-value" style="color:#059669;">{{lastPromptTokens}} → {{lastCompletionTokens}}（共 {{lastTotalTokens}}）</text>
					</view>
				</view>
			</view>

			<view id="section-important-memory" class="card" :class="activeSectionId == 'section-important-memory' ? 'card-active' : ''" v-if="importantMemory != ''">
				<text class="section-title">重要记忆注入</text>
				<text class="block-text" :class="activeSectionId == 'section-important-memory' ? 'block-text-active' : ''">{{importantMemory}}</text>
			</view>

			<view id="section-buffer-memory" class="card" :class="activeSectionId == 'section-buffer-memory' ? 'card-active' : ''" v-if="bufferInjection != ''">
				<text class="section-title">短缓存注入</text>
				<text class="block-text" :class="activeSectionId == 'section-buffer-memory' ? 'block-text-active' : ''">{{bufferInjection}}</text>
			</view>

			<view id="section-full-json" class="card" :class="activeSectionId == 'section-full-json' ? 'card-active' : ''">
				<view class="section-row">
					<text class="section-title">完整 JSON</text>
					<text class="mini-btn" @click="copyAll">复制</text>
				</view>
				<text class="code-text">{{fullJsonText}}</text>
			</view>
			<view id="anchor-bottom" class="anchor-spacer"></view>
		</scroll-view>
		<view class="custom-scrollbar" v-if="scrollViewHeight > 0 && scrollContentHeight > scrollViewHeight" @touchstart="onScrollbarTrackTap" @touchend="onScrollbarTouchEnd">
			<view class="scrollbar-thumb" :style="scrollbarThumbStyle" @touchstart.stop="onScrollbarThumbStart" @touchmove.stop.prevent="onScrollbarThumbMove" />
		</view>
	</view>
		<view v-if="showFloatingSearchBar" class="floating-search-bar">
			<text class="floating-search-meta">{{floatingMetaText}}</text>
			<view class="floating-search-actions">
				<text class="floating-btn" @click="focusPrevResult">上一个</text>
				<text class="floating-btn" @click="focusNextResult">下一个</text>
				<text class="floating-btn" @click="scrollToTop">顶部</text>
				<text class="floating-btn" @click="scrollToBottom">底部</text>
				<text class="floating-btn floating-btn-danger" @click="clearSearch">清空</text>
			</view>
		</view>
	</view>
</template>

<script lang="uts">
	export default {
		data() {
			return {
				previewText: '' as string,
				previewDisplayText: '' as string,
				scrollTop: 0 as number,
				scrollRequestSeq: 0 as number,
				layoutTopMap: {} as UTSJSONObject,
				searchText: '' as string,
				searchResults: [] as UTSJSONObject[],
				searchIndex: -1 as number,
				searchMetaText: '输入关键词后可在各段内容之间跳转定位。' as string,
	
				activeSectionId: '' as string,

				searchJumpBusy: false as boolean,
				queuedSearchIndex: -1 as number,
				showFloatingSearchBar: false as boolean,
				floatingMetaText: '' as string,
				providerId: '' as string,
				baseUrl: '' as string,
				model: '' as string,
				importantMemory: '' as string,
				bufferInjection: '' as string,
				messageCount: 0 as number,
				totalMessages: 0 as number,
				userMsgCount: 0 as number,
				userCharCount: 0 as number,
				assistantMsgCount: 0 as number,
				assistantCharCount: 0 as number,
				systemMsgCount: 0 as number,
				systemCharCount: 0 as number,
				toolMsgCount: 0 as number,
				toolCharCount: 0 as number,
				totalCharCount: 0 as number,
				totalTokens: 0 as number,
				lastPromptTokens: 0 as number,
				lastCompletionTokens: 0 as number,
				lastTotalTokens: 0 as number,
				toolCount: 0 as number,
				settingsTemperature: '—' as string,
				settingsMaxTokens: '—' as string,
				settingsMaxIterations: '—' as string,
				settingsStreamEnabled: false as boolean,
				fullJsonText: '' as string,
				// 自定义滚动条
				scrollViewHeight: 0 as number,
				scrollContentHeight: 0 as number,
				scrollOffset: 0 as number,
				scrollbarDragging: false as boolean,
				scrollbarDragStartY: 0 as number,
				scrollbarDragStartTop: 0 as number,
				scrollbarTrackTop: 0 as number,
				scrollbarThrottleTimer: 0 as number,
				scrollbarPendingTarget: -1 as number,
			}
		},
		computed: {
			scrollbarThumbStyle(): string {
				if (this.scrollContentHeight <= 0 || this.scrollViewHeight <= 0) {
					return 'top:0;height:0;'
				}
				const trackH = this.scrollViewHeight - 4
				const ratio = this.scrollViewHeight / this.scrollContentHeight
				const thumbH = Math.max(trackH * ratio, 36)
				const maxTop = trackH - thumbH
				const maxScroll = this.scrollContentHeight - this.scrollViewHeight
				const currentOffset = this.scrollOffset
				const rawTop = maxScroll > 0 ? (currentOffset / maxScroll) * maxTop : 0
				let top = rawTop
				if (top < 0) top = 0
				if (top > maxTop) top = maxTop
				return 'top:' + top + 'px;height:' + thumbH + 'px;'
			},
		},
		onLoad() {
			const raw = uni.getStorageSync('context_preview_payload') as string | null
			if (raw == null || raw == '') {
				this.previewText = '（没有可展示的上下文）'
				this.previewDisplayText = '（没有可展示的上下文）'
				return
			}
			this.previewText = raw
			this.previewDisplayText = this.decodeDisplayEscapes(raw)
			this.fullJsonText = this.previewDisplayText
			try {
				const parsed = JSON.parse(raw) as UTSJSONObject
				const providerId = parsed['providerId'] as string | null
				const baseUrl = parsed['baseUrl'] as string | null
				const model = parsed['model'] as string | null
				const importantMemory = parsed['importantMemory'] as string | null
				const bufferInjection = parsed['bufferInjection'] as string | null
				const settings = parsed['settings'] as UTSJSONObject | null
				const openaiMessages = parsed['openaiMessages'] as UTSJSONObject[] | null
				const openaiTools = parsed['openaiTools'] as UTSJSONObject[] | null
				const requestBody = parsed['requestBody'] as UTSJSONObject | null
				this.providerId = providerId != null ? providerId : ''
				this.baseUrl = baseUrl != null ? baseUrl : ''
				this.model = model != null ? model : ''
				this.importantMemory = importantMemory != null ? importantMemory : ''
				this.bufferInjection = bufferInjection != null ? bufferInjection : ''
				this.messageCount = openaiMessages != null ? openaiMessages.length : 0
				const rawTotal = parsed['totalMessages'] as number | null
				this.totalMessages = rawTotal != null ? rawTotal : this.messageCount
				// 按角色统计消息数和字数
				if (openaiMessages != null) {
					let uc = 0; let ucc = 0; let ac = 0; let acc = 0
					let sc = 0; let scc = 0; let tc = 0; let tcc = 0
					let allChars = 0
					for (let i = 0; i < openaiMessages.length; i++) {
						const msg = openaiMessages[i]
						const role = msg['role'] as string | null
						const content = msg['content'] as string | null
						const clen = content != null ? content.length : 0
						allChars += clen
						if (role == 'user') { uc++; ucc += clen }
						else if (role == 'assistant') { ac++; acc += clen }
						else if (role == 'system') { sc++; scc += clen }
						else if (role == 'tool') { tc++; tcc += clen }
					}
					this.userMsgCount = uc; this.userCharCount = ucc
					this.assistantMsgCount = ac; this.assistantCharCount = acc
					this.systemMsgCount = sc; this.systemCharCount = scc
					this.toolMsgCount = tc; this.toolCharCount = tcc
					this.totalCharCount = allChars
					this.totalTokens = Math.round(allChars / 2)
				}
				this.toolCount = openaiTools != null ? openaiTools.length : 0
				// 上次调用的真实 Token 用量
				const ltu = parsed['lastTokenUsage'] as UTSJSONObject | null
				if (ltu != null) {
					const pt = ltu['prompt_tokens'] as number | null
					const ct = ltu['completion_tokens'] as number | null
					const tt = ltu['total_tokens'] as number | null
					if (pt != null) this.lastPromptTokens = pt
					if (ct != null) this.lastCompletionTokens = ct
					if (tt != null) this.lastTotalTokens = tt
				}
				if (settings != null) {
					const temp = settings['temperature'] as number | null
					const mt = settings['maxTokens'] as number | null
					const mi = settings['maxIterations'] as number | null
					const se = settings['streamEnabled'] as boolean | null
					if (temp != null) { this.settingsTemperature = '' + temp }
					if (mt != null) { this.settingsMaxTokens = '' + mt }
					if (mi != null) { this.settingsMaxIterations = '' + mi }
					if (se != null) { this.settingsStreamEnabled = se }
				}
			} catch (_e: any) {
			}
			this.scheduleLayoutCache()
			setTimeout(() => { this.measureScrollSize() }, 300)
			setTimeout(() => { this.measureScrollSize() }, 800)
	},
		methods: {
			scheduleLayoutCache(): void {
				setTimeout(() => {
					this.cacheLayoutMetrics()
				}, 80)
				setTimeout(() => {
					this.cacheLayoutMetrics()
				}, 240)
			},

			cacheLayoutMetrics(): void {
				const ids: string[] = ['context-scroll', 'anchor-top', 'anchor-bottom', 'section-summary']
				if (this.importantMemory != '') {
					ids.push('section-important-memory')
				}
				if (this.bufferInjection != '') {
					ids.push('section-buffer-memory')
				}
				ids.push('section-messages')
				ids.push('section-tools')
				ids.push('section-request')
				ids.push('section-full-json')
				const query = uni.createSelectorQuery().in(this)
				for (let i = 0; i < ids.length; i++) {
					const id = ids[i]
					if (id != '') {
						query.select('#' + id).boundingClientRect()
					}
				}
				query.exec((res: any) => {
					const rows = res as UTSArray<any> | null
					if (rows == null || rows.length == 0) {
						return
					}
					const map: UTSJSONObject = {}
					const scrollRect = rows[0] as NodeInfo | null
					const baseTop = scrollRect?.top ?? 0
					const limit = rows.length < ids.length ? rows.length : ids.length
					for (let i = 1; i < limit; i++) {
						const id = ids[i]
						if (id == '') {
							continue
						}
						const row = rows[i] as NodeInfo | null
						if (row == null) {
							continue
						}
						const top = row.top
						if (top == null) {
							continue
						}
						map[id] = top - baseTop
					}
					this.layoutTopMap = map
				})
			},

			/** 页面滚动时同步偏移量给自定义滚动条 */
			onPageScroll(e: UniScrollEvent): void {
				this.scrollOffset = e.detail.scrollTop
			},

			// ====== 自定义滚动条方法 ======

			/** 点滚动条轨道直接跳转 */
			onScrollbarTrackTap(e: UniTouchEvent) {
				const y = this.getTouchRelativeY(e)
				if (y == null || this.scrollContentHeight <= 0 || this.scrollViewHeight <= 0) return
				const trackH = this.scrollViewHeight - 4
				if (trackH <= 0) return
				const maxScroll = this.scrollContentHeight - this.scrollViewHeight
				const ratio = y / trackH
				let target = ratio * maxScroll
				if (target < 0) target = 0
				if (target > maxScroll) target = maxScroll
				this.scrollTop = target
				this.scrollOffset = target
				this.scrollRequestSeq++
			},

			/** 开始拖拽滚动条滑块 */
			onScrollbarThumbStart(e: UniTouchEvent) {
				const y = this.getTouchRelativeY(e)
				if (y == null) return
				this.scrollbarDragStartTop = this.scrollTop
				this.scrollbarDragStartY = y
				this.scrollbarDragging = true
			},

			/** 拖拽滚动条滑块中 */
			onScrollbarThumbMove(e: UniTouchEvent) {
				if (this.scrollbarDragging == false) return
				const y = this.getTouchRelativeY(e)
				if (y == null || this.scrollContentHeight <= 0 || this.scrollViewHeight <= 0) return
				const dy = y - this.scrollbarDragStartY
				const trackH = this.scrollViewHeight - 4
				if (trackH <= 0) return
				const maxScroll = this.scrollContentHeight - this.scrollViewHeight
				const ratio = this.scrollViewHeight / this.scrollContentHeight
				const thumbH = Math.max(trackH * ratio, 36)
				const maxTop = trackH - thumbH
				const scale = maxTop > 0 ? maxScroll / maxTop : 0
				let target = this.scrollbarDragStartTop + dy * scale
				if (target < 0) target = 0
				if (target > maxScroll) target = maxScroll
				this.scrollTop = target
				this.scrollOffset = target
				this.scrollRequestSeq++
			},

			/** 拖拽结束 */
			onScrollbarTouchEnd(_e: UniTouchEvent) {
				this.scrollbarDragging = false
			},

			/** 从触摸事件提取 Y 坐标（相对于轨道顶部） */
			getTouchRelativeY(e: UniTouchEvent): number | null {
				if (e.touches.length == 0) return null
				const pageY = e.touches[0].pageY
				if (this.scrollbarTrackTop <= 0) return null
				return pageY - this.scrollbarTrackTop
			},

			/** 测量滚动尺寸 */
			measureScrollSize() {
				const query = uni.createSelectorQuery().in(this)
				query.select('#context-scroll').boundingClientRect()
				query.select('#anchor-bottom').boundingClientRect()
				query.exec((res: any) => {
					const rows = res as UTSArray<any> | null
					if (rows == null || rows.length < 2) return
					const viewRect = rows[0] as NodeInfo | null
					const anchorRect = rows[1] as NodeInfo | null
					if (viewRect != null) {
						if (viewRect.height != null) {
							this.scrollViewHeight = viewRect.height as number
						}
						if (viewRect.top != null) {
							this.scrollbarTrackTop = viewRect.top as number
						}
					}
					if (anchorRect != null && viewRect != null) {
						const anchorTop = anchorRect.top as number | null
						const viewTop = viewRect.top as number | null
						const anchorH = anchorRect.height as number | null
						if (anchorTop != null && viewTop != null && anchorH != null) {
							this.scrollContentHeight = anchorTop - viewTop + anchorH
						}
					}
				})
			},

			decodeDisplayEscapes(text: string): string {
				let result = text
				result = result.replace(/\\r\\n/g, '\n')
				result = result.replace(/\\n/g, '\n')
				result = result.replace(/\\t/g, '  ')
				return result
			},

			buildPreviewBlock(text: string, limit: number): string {
				if (text.length <= limit) {
					return text
				}
				return text.substring(0, limit) + '\n\n…… 已截断显示，使用搜索定位或复制查看完整内容 ……'
			},

			/** 在全文中搜索匹配并构建搜索结果 */

			buildSearchResult(sectionId: string, title: string, content: string, query: string): UTSJSONObject | null {
				if (content == '' || query == '') {
					return null
				}
				const source = content.toLowerCase()
				const needle = query.toLowerCase()
				const firstIndex = source.indexOf(needle)
				if (firstIndex < 0) {
					return null
				}
				let count = 0
				let fromIndex = 0
				while (fromIndex < source.length) {
					const hit = source.indexOf(needle, fromIndex)
					if (hit < 0) {
						break
					}
					count++
					fromIndex = hit + needle.length
				}
				let start = firstIndex - 48
				if (start < 0) {
					start = 0
				}
				let end = firstIndex + needle.length + 96
				if (end > content.length) {
					end = content.length
				}
				let excerpt = content.substring(start, end)
				if (start > 0) {
					excerpt = '…' + excerpt
				}
				if (end < content.length) {
					excerpt = excerpt + '…'
				}
				return {
					sectionId: sectionId,
					title: title,
					excerpt: excerpt,
					count: count,
				} as UTSJSONObject
			},

			/** 构建摘要搜索文本（含生成参数） */
			buildSummarySearchText(): string {
				return '接口 ' + this.providerId + '\n' +
					'模型 ' + this.model + '\n' +
					'温度 ' + this.settingsTemperature + '\n' +
					'最大Token ' + this.settingsMaxTokens + '\n' +
					'最大轮次 ' + this.settingsMaxIterations + '\n' +
					'保留消息 ' + this.messageCount + ' 条\n' +
					'原始消息 ' + this.totalMessages + ' 条\n' +
					'上下文总 Token ≈ ' + this.totalTokens + '\n' +
					'用户 ' + this.userMsgCount + ' 条 · ' + this.userCharCount + ' 字\n' +
					'AI ' + this.assistantMsgCount + ' 条 · ' + this.assistantCharCount + ' 字\n' +
					'系统 ' + this.systemMsgCount + ' 条 · ' + this.systemCharCount + ' 字\n' +
					'工具 ' + this.toolMsgCount + ' 条 · ' + this.toolCharCount + ' 字\n' +
					'工具定义 ' + this.toolCount + ' 个\n' +
					'流式 ' + (this.settingsStreamEnabled ? '开' : '关') + '\n' +
					'记忆 ' + (this.importantMemory != '' ? '有' : '无') + '\n' +
					'地址 ' + this.baseUrl
			},

			pushSearchResult(list: UTSJSONObject[], sectionId: string, title: string, content: string, query: string): void {
				const result = this.buildSearchResult(sectionId, title, content, query)
				if (result != null) {
					list.push(result)
				}
			},

			/** 在完整 JSON 文本中搜索所有匹配并构建搜索结果 */
			pushFullTextMatches(list: UTSJSONObject[], sectionId: string, title: string, content: string, query: string): void {
				if (query == '' || content == '') {
					return
				}
				const needle = query.toLowerCase()
				const source = content.toLowerCase()
				let hits: number[] = []
				let fromIndex = 0
				while (fromIndex < source.length) {
					const hit = source.indexOf(needle, fromIndex)
					if (hit < 0) {
						break
					}
					hits.push(hit)
					fromIndex = hit + needle.length
				}
				if (hits.length == 0) {
					return
				}
				const total = hits.length
				for (let j = 0; j < hits.length; j++) {
					const hit = hits[j]
					let start = hit - 48
					if (start < 0) {
						start = 0
					}
					let end = hit + needle.length + 96
					if (end > content.length) {
						end = content.length
					}
					let excerpt = content.substring(start, end)
					if (start > 0) {
						excerpt = '…' + excerpt
					}
					if (end < content.length) {
						excerpt = excerpt + '…'
					}
					list.push({
						sectionId: sectionId,
						title: title,
						excerpt: excerpt,
						count: total,
						occurrence: j + 1,
						matchStart: hit,
					} as UTSJSONObject)
				}
			},

			applySearch() {
				const query = this.searchText.trim()
				if (query == '') {
					this.clearSearch()
					return
				}
				const results: UTSJSONObject[] = []
				this.pushSearchResult(results, 'section-summary', '摘要', this.buildSummarySearchText(), query)
				this.pushSearchResult(results, 'section-important-memory', '重要记忆注入', this.importantMemory, query)
				this.pushFullTextMatches(results, 'section-full-json', '完整 JSON', this.fullJsonText, query)
				this.searchResults = results
				if (results.length == 0) {
					this.searchIndex = -1
					this.searchMetaText = '没有找到匹配项。'
					this.activeSectionId = ''
					this.searchJumpBusy = false
					this.queuedSearchIndex = -1
					this.scrollRequestSeq = this.scrollRequestSeq + 1
					this.showFloatingSearchBar = false
					this.floatingMetaText = ''
					uni.showToast({ position: 'bottom', 
						title: '没有匹配内容',
						icon: 'none'
					})
					return
				}
				this.searchIndex = 0
				this.searchMetaText = '找到 ' + results.length + ' 处命中。点击下一个 / 上一个开始跳转。'
				this.activeSectionId = ''
				this.searchJumpBusy = false
				this.queuedSearchIndex = -1
				this.showFloatingSearchBar = true
				this.floatingMetaText = '1 / ' + results.length
				this.queueFocusSearchIndex(0)
			},

			focusSearchIndex(index: number): void {
				if (index < 0 || index >= this.searchResults.length) {
					return
				}
				this.searchIndex = index
				const item = this.searchResults[index]
				const sectionId = item['sectionId'] as string | null
				const count = item['count'] as number | null
				const occurrence = item['occurrence'] as number | null
				const matchStart = item['matchStart'] as number | null
				this.searchMetaText = '命中 ' + this.searchResults.length + ' 处，当前第 ' + (index + 1) + ' 处' + (count != null && occurrence != null ? '（本段 ' + occurrence + '/' + count + '）' : '')
				this.activeSectionId = sectionId != null ? sectionId : ''
				this.showFloatingSearchBar = true
				this.floatingMetaText = (index + 1) + ' / ' + this.searchResults.length + (count != null && occurrence != null ? '（本段 ' + occurrence + '/' + count + '）' : '')
				if (sectionId != null && sectionId != '') {
					this.scrollToSectionMatch(sectionId, matchStart != null ? matchStart : 0)
				}
			},

			queueFocusSearchIndex(index: number): void {
				if (index < 0 || index >= this.searchResults.length) {
					return
				}
				if (this.searchJumpBusy == true) {
					this.queuedSearchIndex = index
					return
				}
				this.searchJumpBusy = true
				this.queuedSearchIndex = -1
				this.focusSearchIndex(index)
				setTimeout(() => {
					this.searchJumpBusy = false
					const pending = this.queuedSearchIndex
					this.queuedSearchIndex = -1
					if (pending >= 0 && pending != this.searchIndex) {
						this.queueFocusSearchIndex(pending)
					}
				}, 96)
			},

			focusPrevResult() {
				if (this.searchResults.length == 0) {
					this.applySearch()
					return
				}
				let nextIndex = this.searchIndex - 1
				if (nextIndex < 0) {
					nextIndex = this.searchResults.length - 1
				}
				this.queueFocusSearchIndex(nextIndex)
			},

			focusNextResult() {
				if (this.searchResults.length == 0) {
					this.applySearch()
					return
				}
				let nextIndex = this.searchIndex + 1
				if (nextIndex >= this.searchResults.length) {
					nextIndex = 0
				}
				this.queueFocusSearchIndex(nextIndex)
			},

			clearSearch() {
				this.searchResults = [] as UTSJSONObject[]
				this.searchIndex = -1
				this.searchMetaText = '输入关键词后可在各段内容之间跳转定位。'
				this.activeSectionId = ''
				this.searchJumpBusy = false
				this.queuedSearchIndex = -1
				this.scrollRequestSeq = this.scrollRequestSeq + 1
				this.showFloatingSearchBar = false
				this.floatingMetaText = ''
			},

			commitScrollTop(targetTop: number): void {
				let safeTop = targetTop
				if (safeTop < 0) {
					safeTop = 0
				}
				this.scrollRequestSeq = this.scrollRequestSeq + 1
				const requestId = this.scrollRequestSeq
				setTimeout(() => {
					if (requestId != this.scrollRequestSeq) {
						return
					}
					this.scrollTop = safeTop
				}, 16)
			},

			scrollToSectionWithOffset(id: string, offsetTop: number): void {
				const cachedTop = this.layoutTopMap[id] as number | null
				if (cachedTop != null) {
					this.commitScrollTop(cachedTop + offsetTop - 24)
					return
				}
				if (id == 'anchor-top') {
					this.commitScrollTop(0)
					return
				}
				if (id == 'anchor-bottom') {
					this.commitScrollTop(this.scrollContentHeight > 0 ? this.scrollContentHeight : 99999)
					return
				}
				this.scheduleLayoutCache()
			},

			scrollToSection(id: string): void {
				this.scrollToSectionWithOffset(id, 0)
			},

			/** 估算等宽字体每行字符数 */
			estimateCodeCharsPerLine(): number {
				const info = uni.getSystemInfoSync()
				const windowWidth = info.windowWidth
				const usableWidth = windowWidth - 116
				const charWidth = 7.2
				let value = Math.floor(usableWidth / charWidth)
				if (value < 18) {
					value = 18
				}
				return value
			},

			/** 计算文本到 endExclusive 位置的行/列 */
			measureTextGrid(content: string, endExclusive: number, charsPerLine: number): number[] {
				let line = 0
				let column = 0
				if (content == '' || endExclusive <= 0) {
					return [line, column]
				}
				let limit = endExclusive
				if (limit > content.length) {
					limit = content.length
				}
				for (let i = 0; i < limit; i++) {
					const ch = content.charAt(i)
					if (ch == '\n') {
						line++
						column = 0
						continue
					}
					column++
					if (column >= charsPerLine) {
						line++
						column = 0
					}
				}
				return [line, column]
			},

			/** 估算匹配位置在文本中的像素偏移 */
			estimateTextMatchOffset(content: string, matchStart: number): number {
				if (content == '' || matchStart < 0) {
					return 0
				}
				const charsPerLine = this.estimateCodeCharsPerLine()
				const grid = this.measureTextGrid(content, matchStart, charsPerLine)
				const line = grid.length > 0 ? grid[0] : 0
				let offsetTop = 6 + line * 18
				if (offsetTop < 0) {
					offsetTop = 0
				}
				return offsetTop
			},

			/** 滚动到区块内匹配位置 */
			scrollToSectionMatch(sectionId: string, matchStart: number): void {
				const offsetTop = this.estimateTextMatchOffset(this.fullJsonText, matchStart)
				this.scrollToSectionWithOffset(sectionId, offsetTop)
			},

			scrollToTop() {
				this.activeSectionId = ''
				this.scrollToSection('anchor-top')
			},

			scrollToBottom() {
				this.activeSectionId = ''
				// 用真实锚点坐标定位
				const query = uni.createSelectorQuery().in(this)
				query.select('#anchor-bottom').boundingClientRect()
				query.select('#context-scroll').boundingClientRect()
				query.exec((res: any) => {
					const rows = res as UTSArray<any> | null
					if (rows == null || rows.length < 2) {
						this.commitScrollTop(99999)
						return
					}
					const anchorRect = rows[0] as NodeInfo | null
					const scrollRect = rows[1] as NodeInfo | null
					if (anchorRect == null || scrollRect == null) {
						this.commitScrollTop(99999)
						return
					}
					const anchorTop = anchorRect.top as number | null
					const scrollTop = scrollRect.top as number | null
					if (anchorTop != null && scrollTop != null) {
						this.commitScrollTop(anchorTop - scrollTop + 20)
					} else {
						this.commitScrollTop(99999)
					}
				})
			},

			formatJsonObjectSegment(value: UTSJSONObject, fallback: string): string {
				try {
					return JSON.stringify(value, null, 2)
				} catch (_e: any) {
					try {
						return JSON.stringify(value)
					} catch (_e2: any) {
						return fallback
					}
				}
			},

			formatJsonArraySegment(value: UTSJSONObject[], fallback: string): string {
				try {
					return JSON.stringify(value, null, 2)
				} catch (_e: any) {
					try {
						return JSON.stringify(value)
					} catch (_e2: any) {
						return fallback
					}
				}
			},

			copyAll() {
				if (this.previewText == '') {
					uni.showToast({ position: 'bottom', 
						title: '没有可复制内容',
						icon: 'none'
					})
					return
				}
				uni.setClipboardData({
					data: this.previewText,
					success: () => {
						uni.showToast({ position: 'bottom', 
							title: '已复制',
							icon: 'none'
						})
					}
				})
			},

			goBack() {
				uni.navigateBack()
			},
		}
	}
</script>

<style>
	.container {
		flex: 1;
		padding: 24rpx;
		padding-bottom: 192rpx;
	}

	.hero-card,
	.card {
		background-color: #FFFFFF;
		border-radius: 32rpx;
		padding: 32rpx;
		margin-bottom: 24rpx;
	}

	.card-active {
	}

	.hero-title {
		font-size: 36rpx;
		color: var(--rice-text-color);
		font-weight: bold;
		margin-bottom: 16rpx;
	}

	.hero-desc {
		font-size: 26rpx;
		line-height: 40rpx;
		color: var(--rice-text-color-2);
	}

	.section-title {
		font-size: 30rpx;
		font-weight: bold;
		color: var(--rice-text-color);
		margin-bottom: 20rpx;
	}

	.section-row {
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 20rpx;
	}

	.meta-line {
		font-size: 26rpx;
		line-height: 44rpx;
		color: var(--rice-text-color-2);
	}

	.summary-grid {
		flex-direction: row;
		flex-wrap: wrap;
		align-items: flex-start;
	}

	.summary-item {
		flex-direction: row;
		align-items: center;
		padding: 12rpx 32rpx 12rpx 0;
	}

	.summary-label {
		font-size: 24rpx;
		color: #9CA3AF;
		margin-right: 12rpx;
		flex-shrink: 0;
	}

	.summary-value {
		font-size: 26rpx;
		color: var(--rice-text-color);
	}

	.search-row {
		flex-direction: row;
		align-items: center;
	}

	.search-input {
		flex: 1;
		height: 76rpx;
		background-color: #F9FAFB;
		border-radius: 20rpx;
		padding-left: 24rpx;
		padding-right: 24rpx;
		font-size: 26rpx;
		color: var(--rice-text-color);
	}

	.search-btn {
		margin-left: 20rpx;
		padding: 18rpx 28rpx;
		border-radius: 20rpx;
		background-color: var(--rice-primary-color);
		color: #FFFFFF;
		font-size: 26rpx;
		font-weight: bold;
	}

	.search-meta {
		font-size: 24rpx;
		line-height: 40rpx;
		color: #6B7280;
	}

	.floating-search-bar {
		position: absolute;
		left: 24rpx;
		right: 24rpx;
		bottom: 24rpx;
		background-color: #FFFFFF;
		border-radius: 32rpx;
		padding: 24rpx;
		box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.10);
	}

	.floating-search-meta {
		font-size: 24rpx;
		line-height: 36rpx;
		color: #6B7280;
		margin-bottom: 20rpx;
	}

	.floating-search-actions {
		flex-direction: row;
		flex-wrap: wrap;
	}

	.floating-btn {
		padding: 14rpx 22rpx;
		margin-right: 16rpx;
		margin-bottom: 16rpx;
		border-radius: 1998rpx;
		background-color: #F3F4F6;
		color: #374151;
		font-size: 24rpx;
	}

	.floating-btn-danger {
		background-color: #FEE2E2;
		color: #DC2626;
	}

	.block-text {
		font-size: 26rpx;
		line-height: 42rpx;
		color: var(--rice-text-color);
		white-space: normal;
	}

	.block-text-active {
		background-color: #FFF7FA;
		border-radius: 24rpx;
		padding: 20rpx 24rpx;
		box-shadow: inset 0 0 0 2rpx rgba(251, 143, 171, 0.38);
	}

	.code-text {
		font-size: 24rpx;
		line-height: 36rpx;
		color: #E5E7EB;
		white-space: pre-wrap;
		background-color: #111827;
		border-radius: 24rpx;
		padding: 24rpx;
		font-family: monospace;
	}

	.nav-btn,
	.mini-btn {
		font-size: 28rpx;
		color: #FFFFFF;
		font-weight: bold;
	}

	.mini-btn {
		color: var(--rice-primary-color);
	}

	.anchor-spacer {
		height: 4rpx;
	}

	/* 自定义滚动条 */
	.scroll-wrapper {
		flex: 1;
		position: relative;
		overflow: hidden;
	}

	.custom-scrollbar {
		position: absolute;
		right: 4rpx;
		top: 4rpx;
		bottom: 4rpx;
		width: 28rpx;
		border-radius: 14rpx;
		background-color: rgba(0, 0, 0, 0.04);
	}

	.scrollbar-thumb {
		position: absolute;
		left: 6rpx;
		right: 6rpx;
		border-radius: 8rpx;
		background-color: rgba(0, 0, 0, 0.18);
	}
</style>
