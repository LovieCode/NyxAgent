<template>
	<view class="page-shell rice-theme-light">
		<NavBar title="原始上下文" showBack @back="goBack">
			<template #right>
				<text class="nav-btn" @click="copyAll">复制</text>
			</template>
		</NavBar>
		<scroll-view id="context-scroll" class="container" :scroll-y="true" :scroll-with-animation="false" :scroll-top="scrollTop">
			<view id="anchor-top" class="anchor-spacer"></view>
			<view class="hero-card">
				<text class="hero-title">发送前完整上下文</text>
				<text class="hero-desc">这里展示本轮真正会发给 agent 的首轮原始上下文，包含系统提示词、记忆动态注入、消息重写结果、工具定义与请求体。不会显示 API Key。</text>
			</view>

			<view class="card">
				<text class="section-title">搜索定位</text>
				<view class="search-row">
					<input
						class="search-input"
						type="text"
						v-model="searchText"
						placeholder="搜索内容、记忆、工具、JSON 字段..."
						placeholder-style="color:#9CA3AF"
						@confirm="applySearch"
					/>
					<text class="search-btn" @click="applySearch">搜索</text>
				</view>
				<text class="search-meta">{{searchMetaText}}</text>
				<view v-if="currentSearchTitle != ''" class="search-hit-card">
					<text class="search-hit-title">{{currentSearchTitle}}</text>
					<text class="search-hit-excerpt">
						<text>{{currentSearchExcerptBefore}}</text>
						<text v-if="currentSearchExcerptMatch != ''" class="search-mark">{{currentSearchExcerptMatch}}</text>
						<text>{{currentSearchExcerptAfter}}</text>
					</text>
				</view>
			</view>

			<view id="section-summary" class="card" :class="activeSectionId == 'section-summary' ? 'card-active' : ''">
				<text class="section-title">摘要</text>
				<text class="meta-line">Provider：{{providerId != '' ? providerId : '未解析'}}</text>
				<text class="meta-line">Base URL：{{baseUrl != '' ? baseUrl : '未解析'}}</text>
				<text class="meta-line">Model：{{model != '' ? model : '未解析'}}</text>
				<text class="meta-line">消息数：{{messageCount}}</text>
				<text class="meta-line">工具数：{{toolCount}}</text>
				<text class="meta-line">重要记忆：{{importantMemory != '' ? '已注入' : '无'}}</text>
				<text class="meta-line">短缓存：{{bufferInjection != '' ? '已注入' : '无'}}</text>
			</view>

			<view id="section-system" class="card" :class="activeSectionId == 'section-system' ? 'card-active' : ''">
				<text class="section-title">系统提示词</text>
				<text class="block-text" :class="activeSectionId == 'section-system' ? 'block-text-active' : ''">{{systemPrompt != '' ? systemPrompt : '（空）'}}</text>
			</view>

			<view id="section-settings" class="card" :class="activeSectionId == 'section-settings' ? 'card-active' : ''">
				<text class="section-title">生成参数</text>
				<text class="code-text" :class="activeSectionId == 'section-settings' ? 'code-text-active' : ''">{{settingsText}}</text>
			</view>

			<view id="section-important-memory" class="card" :class="activeSectionId == 'section-important-memory' ? 'card-active' : ''" v-if="importantMemory != ''">
				<text class="section-title">重要记忆注入</text>
				<text class="block-text" :class="activeSectionId == 'section-important-memory' ? 'block-text-active' : ''">{{importantMemory}}</text>
			</view>

			<view id="section-buffer-memory" class="card" :class="activeSectionId == 'section-buffer-memory' ? 'card-active' : ''" v-if="bufferInjection != ''">
				<text class="section-title">短缓存注入</text>
				<text class="block-text" :class="activeSectionId == 'section-buffer-memory' ? 'block-text-active' : ''">{{bufferInjection}}</text>
			</view>

			<view id="section-messages" class="card" :class="activeSectionId == 'section-messages' ? 'card-active' : ''">
				<text class="section-title">发送 messages（OpenAI 格式）</text>
				<view v-for="(chunk, index) in messagesChunks" :key="'msg-' + index" :id="chunkAnchorId(chunk)" class="chunk-wrap" :class="isChunkActive(chunk) ? 'chunk-wrap-active' : ''">
					<view v-if="isChunkActive(chunk) && hasActiveChunkMatch(chunk)" class="code-panel code-text-active">
						<view class="code-hit-overlay" :style="activeChunkOverlayStyle(chunk)"></view>
						<text class="code-text code-text-panel">
							<text>{{activeChunkPrefix(chunk)}}</text>
							<text class="code-inline-hit">{{activeChunkMatch(chunk)}}</text>
							<text>{{activeChunkSuffix(chunk)}}</text>
						</text>
					</view>
					<text v-else class="code-text">{{chunkText(chunk)}}</text>
				</view>
			</view>

			<view id="section-tools" class="card" :class="activeSectionId == 'section-tools' ? 'card-active' : ''">
				<text class="section-title">工具定义</text>
				<view v-for="(chunk, index) in toolsChunks" :key="'tool-' + index" :id="chunkAnchorId(chunk)" class="chunk-wrap" :class="isChunkActive(chunk) ? 'chunk-wrap-active' : ''">
					<view v-if="isChunkActive(chunk) && hasActiveChunkMatch(chunk)" class="code-panel code-text-active">
						<view class="code-hit-overlay" :style="activeChunkOverlayStyle(chunk)"></view>
						<text class="code-text code-text-panel">
							<text>{{activeChunkPrefix(chunk)}}</text>
							<text class="code-inline-hit">{{activeChunkMatch(chunk)}}</text>
							<text>{{activeChunkSuffix(chunk)}}</text>
						</text>
					</view>
					<text v-else class="code-text">{{chunkText(chunk)}}</text>
				</view>
			</view>

			<view id="section-request" class="card" :class="activeSectionId == 'section-request' ? 'card-active' : ''">
				<text class="section-title">最终 request body</text>
				<view v-for="(chunk, index) in requestBodyChunks" :key="'req-' + index" :id="chunkAnchorId(chunk)" class="chunk-wrap" :class="isChunkActive(chunk) ? 'chunk-wrap-active' : ''">
					<view v-if="isChunkActive(chunk) && hasActiveChunkMatch(chunk)" class="code-panel code-text-active">
						<view class="code-hit-overlay" :style="activeChunkOverlayStyle(chunk)"></view>
						<text class="code-text code-text-panel">
							<text>{{activeChunkPrefix(chunk)}}</text>
							<text class="code-inline-hit">{{activeChunkMatch(chunk)}}</text>
							<text>{{activeChunkSuffix(chunk)}}</text>
						</text>
					</view>
					<text v-else class="code-text">{{chunkText(chunk)}}</text>
				</view>
			</view>

			<view id="section-full-json" class="card" :class="activeSectionId == 'section-full-json' ? 'card-active' : ''">
				<view class="section-row">
					<text class="section-title">完整 JSON</text>
					<text class="mini-btn" @click="copyAll">复制</text>
				</view>
				<view v-for="(chunk, index) in fullJsonChunks" :key="'json-' + index" :id="chunkAnchorId(chunk)" class="chunk-wrap" :class="isChunkActive(chunk) ? 'chunk-wrap-active' : ''">
					<view v-if="isChunkActive(chunk) && hasActiveChunkMatch(chunk)" class="code-panel code-text-active">
						<view class="code-hit-overlay" :style="activeChunkOverlayStyle(chunk)"></view>
						<text class="code-text code-text-panel">
							<text>{{activeChunkPrefix(chunk)}}</text>
							<text class="code-inline-hit">{{activeChunkMatch(chunk)}}</text>
							<text>{{activeChunkSuffix(chunk)}}</text>
						</text>
					</view>
					<text v-else class="code-text">{{chunkText(chunk)}}</text>
				</view>
			</view>
			<view id="anchor-bottom" class="anchor-spacer"></view>
		</scroll-view>
		<view v-if="showFloatingSearchBar" class="floating-search-bar">
			<text class="floating-search-meta">{{floatingMetaText}}</text>
			<view class="floating-search-actions">
				<text class="floating-btn" @click="focusPrevResult">上一个</text>
				<text class="floating-btn" @click="focusNextResult">下一个</text>
				<text class="floating-btn" @click="scrollToTop">顶部</text>
				<text class="floating-btn" @click="scrollToBottom">底部</text>
				<text class="floating-btn floating-btn-danger" @click="clearSearch">清空</text>
			</view>
		</view>
	</view>
</template>

<script lang="uts">
	export default {
		data() {
			return {
				previewText: '' as string,
				previewDisplayText: '' as string,
				scrollTop: 0 as number,
				scrollRequestSeq: 0 as number,
				layoutTopMap: {} as UTSJSONObject,
				searchText: '' as string,
				searchResults: [] as UTSJSONObject[],
				searchIndex: -1 as number,
				searchMetaText: '输入关键词后可在各段内容之间跳转定位。' as string,
				currentSearchTitle: '' as string,
				currentSearchExcerpt: '' as string,
				currentSearchExcerptBefore: '' as string,
				currentSearchExcerptMatch: '' as string,
				currentSearchExcerptAfter: '' as string,
				activeSectionId: '' as string,
				activeChunkId: '' as string,
				activeMatchStart: -1 as number,
				activeMatchLength: 0 as number,
				showFloatingSearchBar: false as boolean,
				floatingMetaText: '' as string,
				providerId: '' as string,
				baseUrl: '' as string,
				model: '' as string,
				systemPrompt: '' as string,
				importantMemory: '' as string,
				bufferInjection: '' as string,
				messageCount: 0 as number,
				toolCount: 0 as number,
				settingsText: '（空）' as string,
				messagesText: '[]' as string,
				toolsText: '[]' as string,
				requestBodyText: '{}' as string,
				messagesPreviewText: '[]' as string,
				toolsPreviewText: '[]' as string,
				requestBodyPreviewText: '{}' as string,
				previewJsonShortText: '（没有可展示的上下文）' as string,
				messagesChunks: [] as UTSJSONObject[],
				toolsChunks: [] as UTSJSONObject[],
				requestBodyChunks: [] as UTSJSONObject[],
				fullJsonChunks: [] as UTSJSONObject[],
			}
		},
		onLoad() {
			const raw = uni.getStorageSync('context_preview_payload') as string | null
			if (raw == null || raw == '') {
				this.previewText = '（没有可展示的上下文）'
				this.previewDisplayText = '（没有可展示的上下文）'
				return
			}
			this.previewText = raw
			this.previewDisplayText = this.decodeDisplayEscapes(raw)
			this.previewJsonShortText = this.buildPreviewBlock(this.previewDisplayText, 12000)
			this.fullJsonChunks = this.buildChunks('section-full-json', '完整 JSON', this.previewDisplayText, 640)
			try {
				const parsed = JSON.parse(raw) as UTSJSONObject
				const providerId = parsed['providerId'] as string | null
				const baseUrl = parsed['baseUrl'] as string | null
				const model = parsed['model'] as string | null
				const systemPrompt = parsed['systemPrompt'] as string | null
				const importantMemory = parsed['importantMemory'] as string | null
				const bufferInjection = parsed['bufferInjection'] as string | null
				const settings = parsed['settings'] as UTSJSONObject | null
				const openaiMessages = parsed['openaiMessages'] as UTSJSONObject[] | null
				const openaiTools = parsed['openaiTools'] as UTSJSONObject[] | null
				const requestBody = parsed['requestBody'] as UTSJSONObject | null
				this.providerId = providerId != null ? providerId : ''
				this.baseUrl = baseUrl != null ? baseUrl : ''
				this.model = model != null ? model : ''
				this.systemPrompt = systemPrompt != null ? systemPrompt : ''
				this.importantMemory = importantMemory != null ? importantMemory : ''
				this.bufferInjection = bufferInjection != null ? bufferInjection : ''
				this.messageCount = openaiMessages != null ? openaiMessages.length : 0
				this.toolCount = openaiTools != null ? openaiTools.length : 0
				if (settings != null) {
					this.settingsText = this.decodeDisplayEscapes(this.formatJsonObjectSegment(settings, '（空）'))
				}
				if (openaiMessages != null) {
					this.messagesText = this.decodeDisplayEscapes(this.formatJsonArraySegment(openaiMessages, '[]'))
					this.messagesPreviewText = this.buildPreviewBlock(this.messagesText, 12000)
					this.messagesChunks = this.buildChunks('section-messages', '发送 messages', this.messagesText, 520)
				}
				if (openaiTools != null) {
					this.toolsText = this.decodeDisplayEscapes(this.formatJsonArraySegment(openaiTools, '[]'))
					this.toolsPreviewText = this.buildPreviewBlock(this.toolsText, 8000)
					this.toolsChunks = this.buildChunks('section-tools', '工具定义', this.toolsText, 520)
				}
				if (requestBody != null) {
					this.requestBodyText = this.decodeDisplayEscapes(this.formatJsonObjectSegment(requestBody, '{}'))
					this.requestBodyPreviewText = this.buildPreviewBlock(this.requestBodyText, 12000)
					this.requestBodyChunks = this.buildChunks('section-request', '最终 request body', this.requestBodyText, 520)
				}
			} catch (_e: any) {
			}
			this.scheduleLayoutCache()
		},
		methods: {
			scheduleLayoutCache(): void {
				setTimeout(() => {
					this.cacheLayoutMetrics()
				}, 80)
				setTimeout(() => {
					this.cacheLayoutMetrics()
				}, 240)
			},

			cacheLayoutMetrics(): void {
				const ids: string[] = ['context-scroll', 'anchor-top', 'anchor-bottom', 'section-summary', 'section-system', 'section-settings']
				if (this.importantMemory != '') {
					ids.push('section-important-memory')
				}
				if (this.bufferInjection != '') {
					ids.push('section-buffer-memory')
				}
				ids.push('section-messages')
				ids.push('section-tools')
				ids.push('section-request')
				ids.push('section-full-json')
				for (let i = 0; i < this.messagesChunks.length; i++) {
					ids.push(this.chunkAnchorId(this.messagesChunks[i]))
				}
				for (let i = 0; i < this.toolsChunks.length; i++) {
					ids.push(this.chunkAnchorId(this.toolsChunks[i]))
				}
				for (let i = 0; i < this.requestBodyChunks.length; i++) {
					ids.push(this.chunkAnchorId(this.requestBodyChunks[i]))
				}
				for (let i = 0; i < this.fullJsonChunks.length; i++) {
					ids.push(this.chunkAnchorId(this.fullJsonChunks[i]))
				}
				const query = uni.createSelectorQuery().in(this)
				for (let i = 0; i < ids.length; i++) {
					const id = ids[i]
					if (id != '') {
						query.select('#' + id).boundingClientRect()
					}
				}
				query.exec((res: any) => {
					const rows = res as UTSArray<any> | null
					if (rows == null || rows.length == 0) {
						return
					}
					const map: UTSJSONObject = {}
					const scrollRect = rows[0] as NodeInfo | null
					const baseTop = scrollRect?.top ?? 0
					const limit = rows.length < ids.length ? rows.length : ids.length
					for (let i = 1; i < limit; i++) {
						const id = ids[i]
						if (id == '') {
							continue
						}
						const row = rows[i] as NodeInfo | null
						if (row == null) {
							continue
						}
						const top = row.top
						if (top == null) {
							continue
						}
						map[id] = top - baseTop
					}
					this.layoutTopMap = map
				})
			},

			decodeDisplayEscapes(text: string): string {
				let result = text
				result = result.replace(/\\r\\n/g, '\n')
				result = result.replace(/\\n/g, '\n')
				result = result.replace(/\\t/g, '  ')
				return result
			},

			buildPreviewBlock(text: string, limit: number): string {
				if (text.length <= limit) {
					return text
				}
				return text.substring(0, limit) + '\n\n…… 已截断显示，使用搜索定位或复制查看完整内容 ……'
			},

			buildChunks(sectionId: string, title: string, text: string, chunkSize: number): UTSJSONObject[] {
				const list: UTSJSONObject[] = []
				if (text == '') {
					return list
				}
				let start = 0
				let index = 0
				while (start < text.length) {
					let end = start + chunkSize
					if (end > text.length) {
						end = text.length
					}
					list.push({
						id: sectionId + '-chunk-' + index,
						sectionId: sectionId,
						title: title,
						text: text.substring(start, end),
						start: start,
						end: end,
					} as UTSJSONObject)
					start = end
					index++
				}
				return list
			},

			chunkAnchorId(chunk: UTSJSONObject): string {
				const value = chunk['id'] as string | null
				return value != null ? value : ''
			},

			pushChunkMatches(list: UTSJSONObject[], chunks: UTSJSONObject[], query: string): void {
				if (query == '') {
					return
				}
				const needle = query.toLowerCase()
				for (let i = 0; i < chunks.length; i++) {
					const chunk = chunks[i]
					const content = chunk['text'] as string | null
					if (content == null || content == '') {
						continue
					}
					const source = content.toLowerCase()
					const firstIndex = source.indexOf(needle)
					if (firstIndex < 0) {
						continue
					}
					let hits: number[] = []
					let fromIndex = 0
					while (fromIndex < source.length) {
						const hit = source.indexOf(needle, fromIndex)
						if (hit < 0) {
							break
						}
						hits.push(hit)
						fromIndex = hit + needle.length
					}
					const total = hits.length
					for (let j = 0; j < hits.length; j++) {
						const hit = hits[j]
						let start = hit - 48
						if (start < 0) {
							start = 0
						}
						let end = hit + needle.length + 96
						if (end > content.length) {
							end = content.length
						}
						let excerpt = content.substring(start, end)
						if (start > 0) {
							excerpt = '…' + excerpt
						}
						if (end < content.length) {
							excerpt = excerpt + '…'
						}
						list.push({
							sectionId: chunk['sectionId'] as string,
							anchorId: chunk['id'] as string,
							title: chunk['title'] as string,
							excerpt: excerpt,
							count: total,
							occurrence: j + 1,
							matchStart: hit,
							matchLength: needle.length,
						} as UTSJSONObject)
					}
				}
			},

			buildSearchResult(sectionId: string, title: string, content: string, query: string): UTSJSONObject | null {
				if (content == '' || query == '') {
					return null
				}
				const source = content.toLowerCase()
				const needle = query.toLowerCase()
				const firstIndex = source.indexOf(needle)
				if (firstIndex < 0) {
					return null
				}
				let count = 0
				let fromIndex = 0
				while (fromIndex < source.length) {
					const hit = source.indexOf(needle, fromIndex)
					if (hit < 0) {
						break
					}
					count++
					fromIndex = hit + needle.length
				}
				let start = firstIndex - 48
				if (start < 0) {
					start = 0
				}
				let end = firstIndex + needle.length + 96
				if (end > content.length) {
					end = content.length
				}
				let excerpt = content.substring(start, end)
				if (start > 0) {
					excerpt = '…' + excerpt
				}
				if (end < content.length) {
					excerpt = excerpt + '…'
				}
				return {
					sectionId: sectionId,
					title: title,
					excerpt: excerpt,
					count: count,
				} as UTSJSONObject
			},

			pushSearchResult(list: UTSJSONObject[], sectionId: string, title: string, content: string, query: string): void {
				const result = this.buildSearchResult(sectionId, title, content, query)
				if (result != null) {
					list.push(result)
				}
			},

			setCurrentSearchExcerpt(text: string): void {
				this.currentSearchExcerpt = text
				const query = this.searchText.trim()
				if (query == '' || text == '') {
					this.currentSearchExcerptBefore = text
					this.currentSearchExcerptMatch = ''
					this.currentSearchExcerptAfter = ''
					return
				}
				const source = text.toLowerCase()
				const needle = query.toLowerCase()
				const firstIndex = source.indexOf(needle)
				if (firstIndex < 0) {
					this.currentSearchExcerptBefore = text
					this.currentSearchExcerptMatch = ''
					this.currentSearchExcerptAfter = ''
					return
				}
				this.currentSearchExcerptBefore = text.substring(0, firstIndex)
				this.currentSearchExcerptMatch = text.substring(firstIndex, firstIndex + query.length)
				this.currentSearchExcerptAfter = text.substring(firstIndex + query.length)
			},

			applySearch() {
				const query = this.searchText.trim()
				if (query == '') {
					this.clearSearch()
					return
				}
				const results: UTSJSONObject[] = []
				this.pushSearchResult(results, 'section-summary', '摘要', 'Provider: ' + this.providerId + '\nBase URL: ' + this.baseUrl + '\nModel: ' + this.model, query)
				this.pushSearchResult(results, 'section-system', '系统提示词', this.systemPrompt, query)
				this.pushSearchResult(results, 'section-settings', '生成参数', this.settingsText, query)
				this.pushSearchResult(results, 'section-important-memory', '重要记忆注入', this.importantMemory, query)
				this.pushSearchResult(results, 'section-buffer-memory', '短缓存注入', this.bufferInjection, query)
				this.pushChunkMatches(results, this.messagesChunks, query)
				this.pushChunkMatches(results, this.toolsChunks, query)
				this.pushChunkMatches(results, this.requestBodyChunks, query)
				this.pushChunkMatches(results, this.fullJsonChunks, query)
				this.searchResults = results
				if (results.length == 0) {
					this.searchIndex = -1
					this.searchMetaText = '没有找到匹配项。'
					this.currentSearchTitle = ''
					this.setCurrentSearchExcerpt('')
					this.activeSectionId = ''
					this.activeChunkId = ''
					this.activeMatchStart = -1
					this.activeMatchLength = 0
					this.showFloatingSearchBar = false
					this.floatingMetaText = ''
					uni.showToast({
						title: '没有匹配内容',
						icon: 'none'
					})
					return
				}
				this.searchIndex = 0
				const first = results[0]
				const title = first['title'] as string | null
				const excerpt = first['excerpt'] as string | null
				const count = first['count'] as number | null
				const occurrence = first['occurrence'] as number | null
				this.searchMetaText = '找到 ' + results.length + ' 处命中。点击下一个 / 上一个开始跳转。'
				this.currentSearchTitle = title != null ? title : ''
				this.setCurrentSearchExcerpt(excerpt != null ? excerpt : '')
				this.activeSectionId = ''
				this.activeChunkId = ''
				this.activeMatchStart = -1
				this.activeMatchLength = 0
				this.showFloatingSearchBar = true
				this.floatingMetaText = '1 / ' + results.length + (count != null && occurrence != null ? '（本段 ' + occurrence + '/' + count + '）' : '')
			},

			focusSearchIndex(index: number): void {
				if (index < 0 || index >= this.searchResults.length) {
					return
				}
				this.searchIndex = index
				const item = this.searchResults[index]
				const sectionId = item['sectionId'] as string | null
				const anchorId = item['anchorId'] as string | null
				const title = item['title'] as string | null
				const excerpt = item['excerpt'] as string | null
				const count = item['count'] as number | null
				const occurrence = item['occurrence'] as number | null
				const matchStart = item['matchStart'] as number | null
				const matchLength = item['matchLength'] as number | null
				this.searchMetaText = '命中 ' + this.searchResults.length + ' 处，当前第 ' + (index + 1) + ' 处' + (count != null && occurrence != null ? '（本段 ' + occurrence + '/' + count + '）' : '')
				this.currentSearchTitle = title != null ? title : ''
				this.setCurrentSearchExcerpt(excerpt != null ? excerpt : '')
				this.activeSectionId = sectionId != null ? sectionId : ''
				this.activeChunkId = anchorId != null ? anchorId : ''
				this.activeMatchStart = matchStart != null ? matchStart : -1
				this.activeMatchLength = matchLength != null ? matchLength : 0
				this.showFloatingSearchBar = true
				this.floatingMetaText = (index + 1) + ' / ' + this.searchResults.length + (count != null && occurrence != null ? '（本段 ' + occurrence + '/' + count + '）' : '')
				if (anchorId != null && anchorId != '') {
					this.scrollToSection(anchorId)
				} else if (sectionId != null && sectionId != '') {
					this.scrollToSection(sectionId)
				}
			},

			focusPrevResult() {
				if (this.searchResults.length == 0) {
					this.applySearch()
					return
				}
				let nextIndex = this.searchIndex - 1
				if (nextIndex < 0) {
					nextIndex = this.searchResults.length - 1
				}
				this.focusSearchIndex(nextIndex)
			},

			focusNextResult() {
				if (this.searchResults.length == 0) {
					this.applySearch()
					return
				}
				let nextIndex = this.searchIndex + 1
				if (nextIndex >= this.searchResults.length) {
					nextIndex = 0
				}
				this.focusSearchIndex(nextIndex)
			},

			clearSearch() {
				this.searchResults = [] as UTSJSONObject[]
				this.searchIndex = -1
				this.searchMetaText = '输入关键词后可在各段内容之间跳转定位。'
				this.currentSearchTitle = ''
				this.setCurrentSearchExcerpt('')
				this.activeSectionId = ''
				this.activeChunkId = ''
				this.activeMatchStart = -1
				this.activeMatchLength = 0
				this.showFloatingSearchBar = false
				this.floatingMetaText = ''
			},

			scrollToSection(id: string): void {
				this.scrollRequestSeq = this.scrollRequestSeq + 1
				const cachedTop = this.layoutTopMap[id] as number | null
				if (cachedTop != null) {
					const nextTop = cachedTop - 24
					this.scrollTop = nextTop > 0 ? nextTop : 0
					return
				}
				if (id == 'anchor-top') {
					this.scrollTop = 0
					return
				}
				if (id == 'anchor-bottom') {
					this.scrollTop = this.scrollTop + 99999
				}
			},

			scrollToTop() {
				this.activeSectionId = ''
				this.activeChunkId = ''
				this.activeMatchStart = -1
				this.activeMatchLength = 0
				this.scrollToSection('anchor-top')
			},

			scrollToBottom() {
				this.activeSectionId = ''
				this.activeChunkId = ''
				this.activeMatchStart = -1
				this.activeMatchLength = 0
				this.scrollToSection('anchor-bottom')
			},

			isChunkActive(chunk: UTSJSONObject): boolean {
				const id = chunk['id'] as string | null
				if (id == null || id == '') {
					return false
				}
				return this.activeChunkId == id
			},

			chunkText(chunk: UTSJSONObject): string {
				const content = chunk['text'] as string | null
				return content != null ? content : ''
			},

			estimateCodeCharsPerLine(): number {
				const info = uni.getSystemInfoSync()
				const windowWidth = info.windowWidth
				const usableWidth = windowWidth - 116
				const charWidth = 7.2
				let value = Math.floor(usableWidth / charWidth)
				if (value < 18) {
					value = 18
				}
				return value
			},

			hasActiveChunkMatch(chunk: UTSJSONObject): boolean {
				if (this.isChunkActive(chunk) == false) {
					return false
				}
				if (this.activeMatchStart < 0 || this.activeMatchLength <= 0) {
					return false
				}
				const content = this.chunkText(chunk)
				if (content == '') {
					return false
				}
				return this.activeMatchStart + this.activeMatchLength <= content.length
			},

			activeChunkPrefix(chunk: UTSJSONObject): string {
				if (this.hasActiveChunkMatch(chunk) == false) {
					return this.chunkText(chunk)
				}
				return this.chunkText(chunk).substring(0, this.activeMatchStart)
			},

			activeChunkMatch(chunk: UTSJSONObject): string {
				if (this.hasActiveChunkMatch(chunk) == false) {
					return ''
				}
				return this.chunkText(chunk).substring(this.activeMatchStart, this.activeMatchStart + this.activeMatchLength)
			},

			activeChunkSuffix(chunk: UTSJSONObject): string {
				if (this.hasActiveChunkMatch(chunk) == false) {
					return ''
				}
				return this.chunkText(chunk).substring(this.activeMatchStart + this.activeMatchLength)
			},

			activeChunkOverlayStyle(chunk: UTSJSONObject): Map<string, string> {
				const styles = new Map<string, string>()
				let top = 12
				let left = 12
				let width = 18
				const height = 18
				if (this.hasActiveChunkMatch(chunk) == true) {
					const content = this.chunkText(chunk)
					const charsPerLine = this.estimateCodeCharsPerLine()
					const charWidth = 7.2
					let line = 0
					let column = 0
					for (let i = 0; i < this.activeMatchStart; i++) {
						const ch = content.charAt(i)
						if (ch == '\n') {
							line++
							column = 0
							continue
						}
						column++
						if (column >= charsPerLine) {
							line++
							column = 0
						}
					}
					const remain = charsPerLine - column
					const matchChars = this.activeMatchLength < remain ? this.activeMatchLength : remain
					top = 12 + line * 18
					left = 12 + Math.floor(column * charWidth)
					width = Math.floor(matchChars * charWidth) + 8
				}
				styles.set('top', top + 'px')
				styles.set('left', left + 'px')
				styles.set('width', width + 'px')
				styles.set('height', height + 'px')
				return styles
			},

			formatJsonObjectSegment(value: UTSJSONObject, fallback: string): string {
				try {
					return JSON.stringify(value, null, 2)
				} catch (_e: any) {
					try {
						return JSON.stringify(value)
					} catch (_e2: any) {
						return fallback
					}
				}
			},

			formatJsonArraySegment(value: UTSJSONObject[], fallback: string): string {
				try {
					return JSON.stringify(value, null, 2)
				} catch (_e: any) {
					try {
						return JSON.stringify(value)
					} catch (_e2: any) {
						return fallback
					}
				}
			},

			copyAll() {
				if (this.previewText == '') {
					uni.showToast({
						title: '没有可复制内容',
						icon: 'none'
					})
					return
				}
				uni.setClipboardData({
					data: this.previewText,
					success: () => {
						uni.showToast({
							title: '已复制',
							icon: 'none'
						})
					}
				})
			},

			goBack() {
				uni.navigateBack()
			},
		}
	}
</script>

<style>
	.container {
		flex: 1;
		padding: 12px;
		padding-bottom: 96px;
	}

	.hero-card,
	.card {
		background-color: #FFFFFF;
		border-radius: 18px;
		padding: 16px;
		margin-bottom: 12px;
	}

	.card-active {
		border-width: 2px;
		border-style: solid;
		border-color: #FB8FAB;
		box-shadow: 0 10px 30px rgba(251, 143, 171, 0.22);
	}

	.hero-title {
		font-size: 18px;
		color: var(--rice-text-color);
		font-weight: bold;
		margin-bottom: 8px;
	}

	.hero-desc {
		font-size: 13px;
		line-height: 20px;
		color: var(--rice-text-color-2);
	}

	.section-title {
		font-size: 15px;
		font-weight: bold;
		color: var(--rice-text-color);
		margin-bottom: 10px;
	}

	.section-row {
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 10px;
	}

	.meta-line {
		font-size: 13px;
		line-height: 22px;
		color: var(--rice-text-color-2);
	}

	.search-row {
		flex-direction: row;
		align-items: center;
	}

	.search-input {
		flex: 1;
		height: 38px;
		background-color: #F9FAFB;
		border-radius: 10px;
		padding-left: 12px;
		padding-right: 12px;
		font-size: 13px;
		color: var(--rice-text-color);
	}

	.search-btn {
		margin-left: 10px;
		padding: 9px 14px;
		border-radius: 10px;
		background-color: var(--rice-primary-color);
		color: #FFFFFF;
		font-size: 13px;
		font-weight: bold;
	}

	.search-meta {
		font-size: 12px;
		line-height: 20px;
		color: #6B7280;
	}

	.floating-search-bar {
		position: absolute;
		left: 12px;
		right: 12px;
		bottom: 12px;
		background-color: rgba(17, 24, 39, 0.94);
		border-radius: 16px;
		padding: 12px;
		box-shadow: 0 10px 24px rgba(17, 24, 39, 0.18);
	}

	.floating-search-meta {
		font-size: 12px;
		line-height: 18px;
		color: #F3F4F6;
		margin-bottom: 10px;
	}

	.floating-search-actions {
		flex-direction: row;
		flex-wrap: wrap;
	}

	.floating-btn {
		padding: 7px 11px;
		margin-right: 8px;
		margin-bottom: 8px;
		border-radius: 999px;
		background-color: rgba(255, 255, 255, 0.12);
		color: #FFFFFF;
		font-size: 12px;
	}

	.floating-btn-danger {
		background-color: rgba(239, 68, 68, 0.22);
	}

	.search-hit-card {
		margin-top: 10px;
		padding: 12px;
		border-radius: 12px;
		background-color: #FFF7FA;
	}

	.search-hit-title {
		font-size: 13px;
		font-weight: bold;
		color: #DB2777;
		margin-bottom: 6px;
	}

	.search-hit-excerpt {
		font-size: 12px;
		line-height: 19px;
		color: #4B5563;
		white-space: pre-wrap;
	}

	.search-mark {
		background-color: #FDE68A;
		color: #7C2D12;
		border-radius: 6px;
		padding-left: 2px;
		padding-right: 2px;
		font-weight: bold;
	}

	.chunk-wrap {
		margin-top: 10px;
	}

	.chunk-wrap-active {
		border-radius: 12px;
		padding: 2px;
		background-color: rgba(251, 143, 171, 0.1);
		border-width: 1px;
		border-style: solid;
		border-color: rgba(251, 143, 171, 0.28);
	}

	.block-text {
		font-size: 13px;
		line-height: 21px;
		color: var(--rice-text-color);
		white-space: normal;
	}

	.block-text-active {
		background-color: #FFF7FA;
		border-radius: 12px;
		padding: 10px 12px;
		box-shadow: inset 0 0 0 1px rgba(251, 143, 171, 0.38);
	}

	.code-text {
		font-size: 12px;
		line-height: 18px;
		color: #E5E7EB;
		white-space: pre-wrap;
		background-color: #111827;
		border-radius: 12px;
		padding: 12px;
		font-family: monospace;
	}

	.code-panel {
		position: relative;
	}

	.code-text-panel {
		position: relative;
		z-index: 2;
	}

	.code-hit-overlay {
		position: absolute;
		z-index: 1;
		background-color: rgba(253, 230, 138, 0.35);
		border-radius: 4px;
	}

	.code-text-active {
		background-color: #18212F;
		border-width: 1px;
		border-style: solid;
		border-color: #FB8FAB;
	}

	.code-inline-hit {
		background-color: #FDE68A;
		color: #111827;
		border-radius: 4px;
		padding-left: 2px;
		padding-right: 2px;
		font-weight: bold;
	}

	.nav-btn,
	.mini-btn {
		font-size: 14px;
		color: #FFFFFF;
		font-weight: bold;
	}

	.mini-btn {
		color: var(--rice-primary-color);
	}

	.anchor-spacer {
		height: 2px;
