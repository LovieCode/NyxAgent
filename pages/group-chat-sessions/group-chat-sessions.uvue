<template>
	<view class="page-shell rice-theme-light">
		<NavBar title="群聊会话" showBack @back="goBack">
			<template #right>
				<view class="add-btn" @click="createSession">
					<oui-icon-unix name="plus" size="44rpx" color="#FFFFFF" />
				</view>
			</template>
		</NavBar>

		<scroll-view class="session-scroll" :scroll-y="true">
			<view class="hint-card">
				<text class="hint-title">会话工作区</text>
				<text class="hint-text">工作区在 group-workspaces 下按内部会话 ID 分目录；界面只显示会话名，不直接展示 sessionId。</text>
			</view>

			<view class="session-list">
				<view v-for="(session, index) in sessionList" :key="session.id" class="session-item" :class="activeSessionId == session.id ? 'session-item-active' : ''" @click="switchSession(session)">
					<view class="session-icon" :class="activeSessionId == session.id ? 'session-icon-active' : ''">
						<oui-icon-unix name="file-text" size="42rpx" :color="activeSessionId == session.id ? '#FFFFFF' : 'var(--rice-primary-color)'" />
					</view>
					<view class="session-info">
						<view class="session-top">
							<text class="session-title">{{displayTitle(session)}}</text>
							<text v-if="activeSessionId == session.id" class="active-badge">当前</text>
						</view>
						<text class="session-desc">{{session.forkedFromSessionId != '' ? '从旧会话 fork' : '独立会话'}} · {{formatTime(session.updatedAt)}}</text>
					</view>
					<view class="session-actions" @click.stop>
						<text class="session-action" @click="forkSession(session)">分支</text>
						<text class="session-action danger" @click="askDeleteSession(session)">删除</text>
					</view>
				</view>
			</view>
		</scroll-view>
	</view>
</template>

<script lang="uts">
	import {
		ACTIVE_GROUP_CHAT_ID_KEY,
		ACTIVE_GROUP_SESSION_ID_KEY,
		GroupChat,
		GroupChatSession,
		createGroupSession,
		deleteGroupSession,
		displaySessionTitle,
		ensureGroupActiveSession,
		forkGroupSession,
		getGroupChatById,
		getGroupSessions,
		setActiveGroupSession,
	} from '@/utils/group-chat-service.uts'

	export default {
		data() {
			return {
				groupId: '' as string,
				activeSessionId: '' as string,
				group: null as GroupChat | null,
				sessionList: [] as GroupChatSession[],
			}
		},
		onLoad() { this.loadData() },
		onShow() { this.loadData() },
		methods: {
			loadData(): void {
				const groupId = uni.getStorageSync(ACTIVE_GROUP_CHAT_ID_KEY) as string | null
				if (groupId == null || groupId == '') { return }
				const group = getGroupChatById(groupId)
				if (group == null) { return }
				const session = ensureGroupActiveSession(group)
				this.groupId = group.id
				this.group = group
				this.activeSessionId = session.id
				this.sessionList = getGroupSessions(group.id)
			},
			goBack(): void { uni.navigateBack() },
			displayTitle(session: GroupChatSession): string { return displaySessionTitle(session) },
			createSession(): void {
				if (this.groupId == '') { return }
				const session = createGroupSession(this.groupId, '新会话')
				setActiveGroupSession(this.groupId, session.id)
				uni.setStorageSync(ACTIVE_GROUP_SESSION_ID_KEY, session.id)
				this.loadData()
				uni.showToast({ position: 'bottom', title: '新会话已创建', icon: 'success' })
			},
			switchSession(session: GroupChatSession): void {
				setActiveGroupSession(this.groupId, session.id)
				uni.setStorageSync(ACTIVE_GROUP_SESSION_ID_KEY, session.id)
				this.loadData()
				uni.showToast({ position: 'bottom', title: '已切换：' + displaySessionTitle(session), icon: 'none' })
			},
			forkSession(session: GroupChatSession): void {
				const forked = forkGroupSession(this.groupId, session.id)
				if (forked != null) {
					setActiveGroupSession(this.groupId, forked.id)
					uni.setStorageSync(ACTIVE_GROUP_SESSION_ID_KEY, forked.id)
					this.loadData()
					uni.showToast({ position: 'bottom', title: '分支已创建', icon: 'success' })
				}
			},
			askDeleteSession(session: GroupChatSession): void {
				if (this.sessionList.length <= 1) {
					uni.showToast({ position: 'bottom', title: '至少保留一个会话', icon: 'none' })
					return
				}
				uni.showActionSheet({
					itemList: ['只删除记录', '删除记录并清空文件'],
					success: (res) => {
						const clearFiles = res.tapIndex == 1
						deleteGroupSession(this.groupId, session.id, clearFiles)
						this.loadData()
						uni.showToast({ position: 'bottom', title: clearFiles ? '会话和文件已删除' : '会话已删除', icon: 'none' })
					}
				})
			},
			formatTime(timestamp: number): string {
				if (timestamp <= 0) { return '' }
				const d = new Date(timestamp)
				const month = (d.getMonth() + 1).toString()
				const day = d.getDate().toString()
				const hour = d.getHours() < 10 ? '0' + d.getHours().toString() : d.getHours().toString()
				const minute = d.getMinutes() < 10 ? '0' + d.getMinutes().toString() : d.getMinutes().toString()
				return month + '/' + day + ' ' + hour + ':' + minute
			}
		}
	}
</script>

<style>
	.add-btn { width: 80rpx; height: 80rpx; justify-content: center; align-items: center; }
	.session-scroll { flex: 1; }
	.hint-card { margin: 20rpx 24rpx 0; padding: 28rpx; border-radius: 32rpx; background-color: var(--rice-primary-color); flex-direction: column; }
	.hint-title { color: #FFFFFF; font-size: 32rpx; font-weight: bold; }
	.hint-text { color: rgba(255,255,255,0.78); font-size: 24rpx; margin-top: 10rpx; line-height: 36rpx; }
	.session-list { margin: 16rpx 24rpx 32rpx; border-radius: 36rpx; background-color: var(--rice-background-2); overflow: hidden; }
	.session-item { flex-direction: row; align-items: center; padding: 26rpx; border-bottom-width: 0.10rpx; border-bottom-color: var(--rice-border-color); border-bottom-style: solid; }
	.session-item-active { background-color: #FFF7FA; }
	.session-icon { width: 76rpx; height: 76rpx; border-radius: 24rpx; background-color: var(--rice-background); justify-content: center; align-items: center; margin-right: 18rpx; }
	.session-icon-active { background-color: var(--rice-primary-color); }
	.session-info { flex: 1; flex-direction: column; }
	.session-top { flex-direction: row; align-items: center; }
	.session-title { font-size: 30rpx; color: var(--rice-text-color); font-weight: bold; max-width: 360rpx; lines: 1; text-overflow: ellipsis; }
	.active-badge { margin-left: 12rpx; color: var(--rice-primary-color); font-size: 22rpx; font-weight: bold; }
	.session-desc { margin-top: 8rpx; font-size: 22rpx; color: var(--rice-text-color-3); }
	.session-actions { flex-direction: row; align-items: center; margin-left: 10rpx; }
	.session-action { font-size: 24rpx; color: var(--rice-primary-color); padding: 10rpx; }
	.danger { color: #EF4444; }
</style>
