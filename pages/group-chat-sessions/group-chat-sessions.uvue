<template>
	<view class="page-shell rice-theme-light">
		<NavBar title="群聊会话" showBack @back="goBack">
			<template #right>
				<view class="add-btn" @click="createSession">
					<oui-icon-unix name="plus" size="22px" color="#FFFFFF" />
				</view>
			</template>
		</NavBar>

		<scroll-view class="session-scroll" :scroll-y="true">
			<view class="hint-card">
				<text class="hint-title">会话工作区</text>
				<text class="hint-text">工作区在 group-workspaces 下按内部会话 ID 分目录；界面只显示会话名，不直接展示 sessionId。</text>
			</view>

			<view class="session-list">
				<view v-for="(session, index) in sessionList" :key="session.id" class="session-item" :class="activeSessionId == session.id ? 'session-item-active' : ''" @click="switchSession(session)">
					<view class="session-icon" :class="activeSessionId == session.id ? 'session-icon-active' : ''">
						<oui-icon-unix name="file-text" size="21px" :color="activeSessionId == session.id ? '#FFFFFF' : 'var(--rice-primary-color)'" />
					</view>
					<view class="session-info">
						<view class="session-top">
							<text class="session-title">{{displayTitle(session)}}</text>
							<text v-if="activeSessionId == session.id" class="active-badge">当前</text>
						</view>
						<text class="session-desc">{{session.forkedFromSessionId != '' ? '从旧会话 fork' : '独立会话'}} · {{formatTime(session.updatedAt)}}</text>
					</view>
					<view class="session-actions" @click.stop>
						<text class="session-action" @click="showSessionJson(session)">查看</text>
						<text class="session-action" @click="forkSession(session)">分支</text>
						<text class="session-action danger" @click="askDeleteSession(session)">删除</text>
					</view>
				</view>
			</view>
		</scroll-view>

		<view v-if="previewVisible" class="preview-overlay">
			<view class="preview-card">
				<view class="preview-header">
					<view class="preview-title-wrap">
						<text class="preview-title">{{previewTitle}}</text>
						<text class="preview-subtitle">群聊完整原始 JSON，包含隐藏调度记录</text>
					</view>
					<view class="preview-close" @click="closePreview"><text class="preview-close-text">×</text></view>
				</view>
				<scroll-view class="preview-scroll" :scroll-y="true"><text class="preview-json-text">{{previewJson}}</text></scroll-view>
			</view>
		</view>
	</view>
</template>

<script lang="uts">
	import {
		GroupChat,
		GroupChatSession,
		createGroupSession,
		deleteGroupSession,
		displaySessionTitle,
		ensureGroupActiveSession,
		forkGroupSession,
		getActiveGroupChatId,
		getGroupChatById,
		getGroupMessages,
		getGroupSessions,
		setActiveGroupSession,
	} from '@/utils/group-chat-service.uts'

	export default {
		data() {
			return {
				groupId: '' as string,
				activeSessionId: '' as string,
				group: null as GroupChat | null,
				sessionList: [] as GroupChatSession[],
				previewVisible: false as boolean,
				previewTitle: '' as string,
				previewJson: '[]' as string,
			}
		},
		onLoad() { this.loadData() },
		onShow() { this.loadData() },
		methods: {
			loadData(): void {
				const groupId = getActiveGroupChatId()
				if (groupId == '') { return }
				const group = getGroupChatById(groupId)
				if (group == null) { return }
				const session = ensureGroupActiveSession(group)
				this.groupId = group.id
				this.group = group
				this.activeSessionId = session.id
				this.sessionList = getGroupSessions(group.id)
			},
			goBack(): void {
				if (this.previewVisible == true) {
					this.closePreview()
					return
				}
				uni.navigateBack()
			},
			displayTitle(session: GroupChatSession): string { return displaySessionTitle(session) },
			createSession(): void {
				if (this.groupId == '') { return }
				const session = createGroupSession(this.groupId, '新会话')
				setActiveGroupSession(this.groupId, session.id)
				this.loadData()
				uni.showToast({ position: 'bottom', title: '新会话已创建', icon: 'success' })
			},
			switchSession(session: GroupChatSession): void {
				setActiveGroupSession(this.groupId, session.id)
				this.loadData()
				uni.showToast({ position: 'bottom', title: '已切换：' + displaySessionTitle(session), icon: 'none' })
			},
			showSessionJson(session: GroupChatSession): void {
				const messages = getGroupMessages(this.groupId, session.id)
				this.previewTitle = displaySessionTitle(session)
				this.previewJson = JSON.stringify(messages, null, 2)
				this.previewVisible = true
			},
			closePreview(): void {
				this.previewVisible = false
			},
			forkSession(session: GroupChatSession): void {
				const forked = forkGroupSession(this.groupId, session.id)
				if (forked != null) {
					setActiveGroupSession(this.groupId, forked.id)
					this.loadData()
					uni.showToast({ position: 'bottom', title: '分支已创建', icon: 'success' })
				}
			},
			askDeleteSession(session: GroupChatSession): void {
				if (this.sessionList.length <= 1) {
					uni.showToast({ position: 'bottom', title: '至少保留一个会话', icon: 'none' })
					return
				}
				uni.showActionSheet({
					itemList: ['只删除记录', '删除记录并清空文件'],
					success: (res) => {
						const clearFiles = res.tapIndex == 1
						deleteGroupSession(this.groupId, session.id, clearFiles)
						this.loadData()
						uni.showToast({ position: 'bottom', title: clearFiles ? '会话和文件已删除' : '会话已删除', icon: 'none' })
					}
				})
			},
			formatTime(timestamp: number): string {
				if (timestamp <= 0) { return '' }
				const d = new Date(timestamp)
				const month = (d.getMonth() + 1).toString()
				const day = d.getDate().toString()
				const hour = d.getHours() < 10 ? '0' + d.getHours().toString() : d.getHours().toString()
				const minute = d.getMinutes() < 10 ? '0' + d.getMinutes().toString() : d.getMinutes().toString()
				return month + '/' + day + ' ' + hour + ':' + minute
			}
		}
	}
</script>

<style>
	.add-btn { width: 40px; height: 40px; justify-content: center; align-items: center; }
	.session-scroll { flex: 1; }
	.hint-card { margin: 10px 12px 0; padding: 14px; border-radius: 16px; background-color: var(--rice-primary-color); flex-direction: column; }
	.hint-title { color: #FFFFFF; font-size: 16px; font-weight: bold; }
	.hint-text { color: rgba(255,255,255,0.78); font-size: 12px; margin-top: 5px; line-height: 18px; }
	.session-list { margin: 8px 12px 16px; border-radius: 18px; background-color: var(--rice-background-2); overflow: hidden; }
	.session-item { flex-direction: row; align-items: center; padding: 13px; border-bottom-width: 1px; border-bottom-color: var(--rice-border-color); border-bottom-style: solid; }
	.session-item-active { background-color: #FFF7FA; }
	.session-icon { width: 38px; height: 38px; border-radius: 12px; background-color: var(--rice-background); justify-content: center; align-items: center; margin-right: 9px; }
	.session-icon-active { background-color: var(--rice-primary-color); }
	.session-info { flex: 1; flex-direction: column; }
	.session-top { flex-direction: row; align-items: center; }
	.session-title { font-size: 15px; color: var(--rice-text-color); font-weight: bold; max-width: 180px; lines: 1; text-overflow: ellipsis; }
	.active-badge { margin-left: 6px; color: var(--rice-primary-color); font-size: 11px; font-weight: bold; }
	.session-desc { margin-top: 4px; font-size: 11px; color: var(--rice-text-color-3); }
	.session-actions { flex-direction: row; align-items: center; margin-left: 5px; }
	.session-action { font-size: 12px; color: var(--rice-primary-color); padding: 5px; }
	.danger { color: #EF4444; }
	.preview-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(17,24,39,0.38); z-index: 1000; justify-content: flex-end; }
	.preview-card { width: 100%; flex: 1; background-color: #FFFFFF; padding: 14px 16px 18px; flex-direction: column; }
	.preview-header { flex-direction: row; align-items: center; justify-content: space-between; margin-bottom: 11px; flex-shrink: 0; }
	.preview-title-wrap { flex: 1; flex-direction: column; margin-right: 10px; }
	.preview-title { font-size: 17px; font-weight: bold; color: var(--rice-text-color); }
	.preview-subtitle { font-size: 12px; color: var(--rice-text-color-3); margin-top: 4px; }
	.preview-close { width: 32px; height: 32px; border-radius: 16px; background-color: var(--rice-background-2); align-items: center; justify-content: center; }
	.preview-close-text { font-size: 21px; line-height: 25px; color: var(--rice-text-color-2); }
	.preview-scroll { flex: 1; background-color: #111827; border-radius: 12px; padding: 12px; }
	.preview-json-text { font-size: 12px; line-height: 18px; color: #E5E7EB; }
</style>
