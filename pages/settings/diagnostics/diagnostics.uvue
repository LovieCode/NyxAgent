<template>
	<view class="page-shell rice-theme-light">
		<NavBar variant="light" title="运行诊断" showBack>
			<template #right>
				<view class="clear-action" :class="diagnostics.length == 0 ? 'clear-action-disabled' : ''" @click="confirmClear">
					<text class="clear-action-text" :class="diagnostics.length == 0 ? 'clear-action-text-disabled' : ''">清空</text>
				</view>
			</template>
		</NavBar>

		<view class="summary-band">
			<view class="summary-main">
				<text class="summary-title">{{diagnostics.length}} 条记录</text>
				<text class="summary-desc">仅保留本次运行，应用重启后自动清除</text>
			</view>
			<view v-if="diagnostics.length > 0" class="status-dot"></view>
		</view>

		<scroll-view class="diagnostics-scroll" :scroll-y="true">
			<view v-if="diagnostics.length == 0" class="empty-state">
				<view class="empty-icon">
					<oui-icon-unix name="info-circle" size="28px" color="#C8BBC1" />
				</view>
				<text class="empty-title">本次运行没有错误记录</text>
				<text class="empty-desc">发生可诊断错误后，会在这里显示错误编号和技术详情。</text>
			</view>

			<view
				v-for="entry in diagnostics"
				:key="entry.diagnosticId"
				class="diagnostic-item"
				@click="toggleDetail(entry.diagnosticId)"
			>
				<view class="item-head">
					<view class="item-title-wrap">
						<text class="item-message">{{entry.userMessage}}</text>
						<text class="item-time">{{formatDiagnosticTime(entry.createdAt)}}</text>
					</view>
					<oui-icon-unix
						:name="expandedDiagnosticId == entry.diagnosticId ? 'up' : 'down'"
						size="14px"
						color="#A79DA4"
					/>
				</view>

				<view class="identity-row">
					<text class="code-chip">{{entry.code}}</text>
					<text class="category-text">{{entry.category}}</text>
				</view>

				<view class="meta-row">
					<text class="meta-label">操作</text>
					<text class="meta-value">{{entry.operation}}</text>
				</view>
				<view class="meta-row">
					<text class="meta-label">诊断编号</text>
					<text class="meta-value diagnostic-id">{{entry.diagnosticId}}</text>
				</view>

				<view v-if="expandedDiagnosticId == entry.diagnosticId" class="detail-box">
					<text class="detail-label">技术详情</text>
					<text class="detail-text">{{entry.detail != '' ? entry.detail : '没有附加技术详情'}}</text>
					<text class="recoverable-text">{{entry.recoverable == true ? '可重试' : '需要检查配置或数据'}}</text>
				</view>
			</view>

			<view class="bottom-space"></view>
		</scroll-view>
	</view>
</template>

<script lang="uts">
	import { APP_ERROR_CATEGORY_RUNTIME, clearAppDiagnostics, formatAppErrorForUser, getRecentAppDiagnostics, reportAppErrorFromCause, type AppDiagnosticEntry } from '@/utils/app-error.uts'

	export default {
		data() {
			return {
				diagnostics: [] as AppDiagnosticEntry[],
				expandedDiagnosticId: '' as string,
			}
		},
		onLoad() {
			this.loadDiagnostics()
		},
		onShow() {
			this.loadDiagnostics()
		},
		methods: {
			showDiagnosticsFailure(code: string, operation: string, userMessage: string, cause: any | null): void {
				const error = reportAppErrorFromCause(
					code,
					APP_ERROR_CATEGORY_RUNTIME,
					operation,
					userMessage,
					cause,
					true,
				)
				this.loadDiagnostics()
				uni.showToast({ position: 'bottom', title: formatAppErrorForUser(error), icon: 'none' })
			},

			loadDiagnostics() {
				const recent = getRecentAppDiagnostics(80)
				const newestFirst: AppDiagnosticEntry[] = []
				for (let i = recent.length - 1; i >= 0; i--) {
					newestFirst.push(recent[i])
				}
				this.diagnostics = newestFirst
				if (this.expandedDiagnosticId != '' && this.containsDiagnosticId(this.expandedDiagnosticId) == false) {
					this.expandedDiagnosticId = ''
				}
			},

			containsDiagnosticId(diagnosticId: string): boolean {
				for (let i = 0; i < this.diagnostics.length; i++) {
					if (this.diagnostics[i].diagnosticId == diagnosticId) { return true }
				}
				return false
			},

			toggleDetail(diagnosticId: string) {
				this.expandedDiagnosticId = this.expandedDiagnosticId == diagnosticId ? '' : diagnosticId
			},

			confirmClear() {
				if (this.diagnostics.length == 0) { return }
				uni.showModal({
					title: '清空错误记录',
					content: '只会清空本次运行的诊断记录，不会影响聊天和设置。',
					success: (res) => {
						if (res.confirm == true) {
							clearAppDiagnostics()
							this.expandedDiagnosticId = ''
							this.loadDiagnostics()
								uni.showToast({ position: 'bottom', title: '已清空', icon: 'success' })
							}
						},
						fail: (err: any) => {
							this.showDiagnosticsFailure('DIAGNOSTICS_CLEAR_CONFIRM_FAILED', 'diagnostics_clear_confirm', '无法打开清空确认框', err)
						}
				})
			},

			formatDiagnosticTime(timestamp: number): string {
				const date = new Date(timestamp)
				const month = date.getMonth() + 1
				const day = date.getDate()
				const hour = date.getHours()
				const minute = date.getMinutes()
				const second = date.getSeconds()
				return date.getFullYear() + '-' + this.padTime(month) + '-' + this.padTime(day) + ' ' +
					this.padTime(hour) + ':' + this.padTime(minute) + ':' + this.padTime(second)
			},

			padTime(value: number): string {
				return value < 10 ? '0' + value : '' + value
			}
		}
	}
</script>

