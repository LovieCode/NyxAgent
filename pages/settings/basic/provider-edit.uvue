		font-size: 26rpx;
		color: #9CA3AF;
	}

	/* 模型卡片 */
	.model-card {
		background-color: #F9FAFB;
		border-radius: 14rpx;
		margin-bottom: 12rpx;
		overflow: hidden;
	}

	.model-row {
		flex-direction: row;
		align-items: center;
		padding: 16rpx 12rpx;
	}

	.model-row-left {
		flex-direction: row;
		align-items: center;
		flex: 1;
	}

	.model-index {
		font-size: 22rpx;
		color: #9CA3AF;
		width: 40rpx;
		text-align: center;
	}

	.model-summary {
		flex-direction: column;
		flex: 1;
	}

	.model-summary-id {
		font-size: 28rpx;
		font-weight: bold;
		color: #111827;
	}

	.model-summary-meta {
		font-size: 22rpx;
		color: #9CA3AF;
		margin-top: 4rpx;
	}

	.model-row-right {
		flex-direction: row;
		align-items: center;
	}

	.model-expand-icon {
		font-size: 28rpx;
		color: #9CA3AF;
		padding: 8rpx;
		width: 40rpx;
		text-align: center;
	}

	.model-del-btn {
		font-size: 32rpx;
		color: #EF4444;
		padding: 8rpx 12rpx;
	}

	/* 展开详情 */
	.model-detail {
		padding: 0 12rpx 16rpx 12rpx;
		border-top-width: 0.5px;
		border-top-style: solid;
		border-top-color: #E5E7EB;
	}

	.detail-field {
		margin-top: 14rpx;
	}

	.detail-field-label {
		font-size: 24rpx;
		color: #6B7280;
		margin-bottom: 6rpx;
	}

	.detail-field-input {
		background-color: #FFFFFF;
		border-radius: 10rpx;
		padding: 16rpx;
		font-size: 26rpx;
		color: #111827;
	}

	.detail-params-input {
		font-family: monospace;
		font-size: 24rpx;
	}

	.detail-field-hint {
		font-size: 20rpx;
		color: #9CA3AF;
		margin-top: 4rpx;
	}

	.detail-row {
		flex-direction: row;
		margin-top: 14rpx;
	}

	.add-model-btn {
		background-color: #F9FAFB;
		border-radius: 12rpx;
		border-width: 1px;
		border-style: dashed;
		border-color: #D1D5DB;
		padding: 18rpx;
		align-items: center;
		margin-top: 8rpx;
	}

	.add-model-text {
		font-size: 26rpx;
