<template>
	<view class="page-shell rice-theme-light">
		<NavBar :title="providerEditTitle" showBack @back="goBack" />
		<scroll-view class="container" :scroll-y="true">
			<view v-if="fromFirstRunGuide" class="guide-card">
				<text class="guide-title">先把聊天模型接上</text>
				<text class="guide-desc">填 API Key 后可以直接「获取模型列表」，勾选要用的模型。保存后会自动把第一个模型设为默认对话模型。</text>
			</view>

			<view class="card">
				<!-- 标识 -->
				<text class="field-label">标识 (ID)</text>
				<input
					class="field-input"
					type="text"
					v-model="editId"
					:disabled="!isNew"
					placeholder="例如 deepseek"
					placeholder-class="ph"
				/>

				<!-- 显示名称 -->
				<text class="field-label">显示名称</text>
				<input
					class="field-input"
					type="text"
					v-model="editName"
					placeholder="例如 DeepSeek"
					placeholder-class="ph"
					@input="autoSaveProvider"
					@blur="autoSaveProvider"
				/>

				<!-- API Key -->
				<text class="field-label">API Key</text>
				<input
					class="field-input"
					type="text"
					v-model="editApiKey"
					placeholder="输入 API Key"
					placeholder-class="ph"
					@input="autoSaveProvider"
					@blur="autoSaveProvider"
				/>

				<!-- 接口地址 -->
				<text class="field-label">接口地址</text>
				<input
					class="field-input"
					type="text"
					v-model="editApiBase"
					placeholder="留空使用默认地址"
					placeholder-class="ph"
					@input="autoSaveProvider"
					@blur="autoSaveProvider"
				/>
			</view>

			<!-- 模型管理卡片 -->
			<view class="card">
				<view class="model-card-header">
					<text class="model-card-title">模型列表</text>
					<view class="fetch-btn" @click="fetchModels">
						<text class="fetch-btn-text">获取模型列表</text>
					</view>
				</view>

				<!-- 加载中 -->
				<view v-if="fetchingModels" class="fetching-row">
					<text class="fetching-text">正在获取模型列表...</text>
				</view>

				<!-- 模型选择器（获取成功后显示） -->
				<view v-if="showModelPicker" class="model-picker">
					<view class="picker-header">
						<text class="picker-title">获取到 {{fetchedModelIds.length}} 个模型</text>
						<text class="picker-select-all" @click="toggleSelectAllModels">{{allModelsSelected ? '取消全选' : '全选'}}</text>
					</view>
					<input
						class="picker-search"
						type="text"
						v-model="pickerSearchText"
						placeholder="搜索模型..."
						placeholder-style="color:#9CA3AF"
					/>
					<scroll-view class="picker-list" :scroll-y="true" style="max-height:160px;">
						<view v-for="(mid, pidx) in fetchedModelIds" :key="pidx">
							<view v-if="modelMatchesSearch(mid)" class="picker-row" @click="toggleModelSelection(pidx)">
							<view class="picker-checkbox" :class="selectedModelIndexes[pidx] == true ? 'picker-checkbox-on' : ''">
								<text v-if="selectedModelIndexes[pidx] == true" class="picker-checkmark">✓</text>
							</view>
							<text class="picker-model-id">{{mid}}</text>
						</view>
						</view>
						<view v-if="filteredModelCount == 0 && pickerSearchText != ''" class="picker-empty">
							<text class="picker-empty-text">无匹配模型</text>
						</view>
					</scroll-view>
					<view class="picker-actions">
						<text class="picker-cancel" @click="cancelModelPicker">取消</text>
						<text class="picker-confirm" @click="confirmAddModels">添加选中 ({{selectedModelCount}})</text>
					</view>
				</view>

				<!-- 模型列表 -->
				<view v-for="(m, mi) in editModels" :key="mi" class="model-card">
					<!-- 折叠态概要 -->
					<view class="model-row" @click="toggleExpand(mi)">
						<view class="model-row-left">
							<text class="model-index">{{mi + 1}}</text>
							<view class="model-summary">
								<text class="model-summary-id">{{m.id != '' ? m.id : '新模型'}}</text>
								<text class="model-summary-meta">
									{{getModelSummary(m)}}
								</text>
							</view>
						</view>
						<view class="model-row-right">
							<text class="model-expand-icon">{{(m.expanded == true) ? '▾' : '▸'}}</text>
							<text class="model-del-btn" @click.stop="removeModel(mi)">✕</text>
						</view>
					</view>

					<!-- 展开详情 -->
					<view v-if="m.expanded" class="model-detail">
						<view class="detail-field">
							<text class="detail-field-label">模型 ID</text>
							<input class="detail-field-input" type="text" v-model="m.id" placeholder="deepseek-v4-flash" placeholder-class="ph" @blur="autoSaveProvider" />
						</view>
						<view class="detail-field">
							<text class="detail-field-label">显示名称</text>
							<input class="detail-field-input" type="text" v-model="m.name" placeholder="DeepSeek V4 Flash" placeholder-class="ph" @blur="autoSaveProvider" />
						</view>
						<view class="detail-row">
							<view class="detail-field" style="flex:1;margin-right:6px;">
								<text class="detail-field-label">上下文窗口 (tokens)</text>
								<input class="detail-field-input" type="number" v-model="m.ctxStr" placeholder="128000" placeholder-class="ph" @blur="autoSaveProvider" />
							</view>
							<view class="detail-field" style="flex:1;">
								<text class="detail-field-label">最大输出 (tokens)</text>
								<input class="detail-field-input" type="number" v-model="m.maxTokensStr" placeholder="4096" placeholder-class="ph" @blur="autoSaveProvider" />
							</view>
						</view>
						<view class="detail-field">
							<text class="detail-field-label">自定义参数 (JSON)</text>
							<input class="detail-field-input detail-params-input" type="text" v-model="m.params" placeholder='{"key": "value"}' placeholder-class="ph" @blur="autoSaveProvider" />
							<text class="detail-field-hint">额外的 API 参数，例如温度、top_p 等</text>
						</view>
					<view class="detail-field model-vision-row">
						<text class="detail-field-label">支持识图</text>
						<rice-switch v-model="m.supportsVision" @change="autoSaveProvider" />
					</view>
					<view class="detail-field model-vision-row">
						<text class="detail-field-label">支持工具调用</text>
						<rice-switch v-model="m.supportsToolCall" @change="autoSaveProvider" />
					</view>
					<view class="detail-field model-vision-row">
						<text class="detail-field-label">支持思维链</text>
						<rice-switch v-model="m.supportsReasoning" @change="autoSaveProvider" />
					</view>
				</view>
				</view>

				<!-- 添加模型 -->
				<view class="add-model-btn" @click="addModel">
					<text class="add-model-text">+ 添加模型</text>
				</view>
			</view>

			<!-- 保存 -->
			<view v-if="showSaveButton" class="save-wrap">
				<rice-button type="primary" :text="saveButtonText" size="large" shape="round" @click="saveProviderAndBack" />
			</view>
		</scroll-view>
	</view>
</template>

<script lang="uts">
	import { saveProvider, fetchProviderModels, parseModels, ModelInfo, getDefaultTaskModel, getProviderById, getDefaultProviderApiBase, setActiveProvider, setDefaultTaskModel } from '@/uni_modules/agent-core/utssdk/provider.uts'
	import { getModelCapabilities, refreshMetadataCache, isMetadataCacheStale, ensureMetadataCache } from '@/uni_modules/agent-core/utssdk/llm-metadata.uts'
	import { consumeRuntimeState, setAppSetting } from '@/utils/database.uts'

	const PROVIDER_EDIT_RUNTIME_ID_KEY = 'provider_edit_id'
	const PROVIDER_EDIT_SOURCE_KEY = 'provider_edit_source'
	const PROVIDER_EDIT_SOURCE_FIRST_RUN = 'first_run_guide'
	const PROVIDER_EDIT_PRESET_KEY = 'provider_edit_preset'
	const FIRST_RUN_GUIDE_DONE_KEY = 'first_run_model_guide_done'

	export default {
			data() {
			return {
				isNew: true as boolean,
				editId: '' as string,
				editName: '' as string,
				editApiKey: '' as string,
				editApiBase: '' as string,
				editModels: [] as ModelInfo[],
				fromFirstRunGuide: false as boolean,
				fetchingModels: false as boolean,
				showModelPicker: false as boolean,
				fetchedModelIds: [] as string[],
				selectedModelIndexes: [] as boolean[],
				pickerSearchText: '' as string,
			}
		},
		onLoad() {
			// 预加载元数据缓存到内存，保证后续 getModelCapabilities 直接命中
			ensureMetadataCache()
			const source = consumeRuntimeState(PROVIDER_EDIT_SOURCE_KEY)
			this.fromFirstRunGuide = source == PROVIDER_EDIT_SOURCE_FIRST_RUN
			const preset = consumeRuntimeState(PROVIDER_EDIT_PRESET_KEY)
			const editId = consumeRuntimeState(PROVIDER_EDIT_RUNTIME_ID_KEY)
			if (editId != '') {
				this.loadProviderForEdit(editId)
			}
			if (preset != '') {
				this.applyProviderPreset(preset, editId == '')
			}
		},
		computed: {
			providerEditTitle(): string {
				if (this.fromFirstRunGuide == true) { return '配置聊天模型' }
				return this.isNew ? '添加提供商' : '编辑提供商'
			},
			showSaveButton(): boolean {
				return this.isNew == true || this.fromFirstRunGuide == true
			},
			saveButtonText(): string {
				return this.fromFirstRunGuide == true ? '保存并开始聊天' : '保存创建'
			},
			selectedModelCount(): number {
				let count = 0
				for (let i = 0; i < this.selectedModelIndexes.length; i++) {
					if (this.selectedModelIndexes[i] == true) {
						count++
					}
				}
				return count
			},
			allModelsSelected(): boolean {
				if (this.fetchedModelIds.length == 0) return false
				return this.selectedModelCount >= this.fetchedModelIds.length
			},
			filteredModelCount(): number {
				if (this.pickerSearchText == '') return this.fetchedModelIds.length
				const needle = this.pickerSearchText.toLowerCase()
				let count = 0
				for (let i = 0; i < this.fetchedModelIds.length; i++) {
					if (this.fetchedModelIds[i].toLowerCase().indexOf(needle) >= 0) {
						count++
					}
				}
				return count
			},
		},
		methods: {
			goBack() {
				uni.navigateBack()
			},

			appendModelIfMissing(modelId: string): void {
				if (modelId == '') { return }
				for (let i = 0; i < this.editModels.length; i++) {
					if (this.editModels[i].id == modelId) { return }
				}
				const caps = getModelCapabilities(modelId)
				this.editModels.push({
					id: modelId,
					ctxStr: '',
					maxTokensStr: '',
					expanded: false,
					supportsVision: caps.supportsVision,
					supportsToolCall: caps.supportsToolCall,
					supportsReasoning: caps.supportsReasoning,
				} as ModelInfo)
			},

			applyProviderPreset(presetJson: string, overrideIdentity: boolean): void {
				try {
					const preset = JSON.parse(presetJson) as UTSJSONObject
					const rawId = preset['id'] as string | null
					const rawName = preset['name'] as string | null
					const rawApiBase = preset['apiBase'] as string | null
					const rawModel = preset['model'] as string | null
					const id = rawId != null ? rawId : ''
					const name = rawName != null ? rawName : ''
					const apiBase = rawApiBase != null ? rawApiBase : ''
					const model = rawModel != null ? rawModel : ''
					if (overrideIdentity == true) {
						this.isNew = true
						this.editId = id
						this.editName = name
					} else if (this.editName == '' && name != '') {
						this.editName = name
					}
					if (this.editApiBase == '' && apiBase != '') {
						this.editApiBase = apiBase
					}
					this.appendModelIfMissing(model)
				} catch (_e: any) {
				}
			},

			loadProviderForEdit(id: string) {
				const data = getProviderById(id)
				if (data == null) {
					uni.showToast({ position: 'bottom', title: '提供商不存在', icon: 'none' })
					return
				}
				this.isNew = false
				this.editId = id
				const rawName = data['name'] as string | null
				const rawApiKey = data['api_key'] as string | null
				const rawApiBase = data['api_base'] as string | null
				this.editName = rawName != null ? rawName : ''
				this.editApiKey = rawApiKey != null ? rawApiKey : ''
				this.editApiBase = rawApiBase != null ? rawApiBase : ''
				if (this.editApiBase == '') {
					this.editApiBase = getDefaultProviderApiBase(id)
				}
				const modelsStr = data['models'] as string | null
				if (modelsStr != null) {
					this.editModels = parseModels(modelsStr)
				}
			},

			getModelSummary(m: ModelInfo): string {
				const parts: string[] = []
				if (m.name != null && m.name != '') {
					parts.push(m.name)
				}
				if (m.context != null && m.context > 0) {
					parts.push(m.context + 'k ctx')
				}
				return parts.join(' · ')
			},

			toggleExpand(index: number) {
				const m = this.editModels[index]
				if (m != null) {
					m.expanded = !(m.expanded == true)
				}
			},

			addModel() {
				const m: ModelInfo = { id: '', ctxStr: '', maxTokensStr: '', expanded: true, supportsVision: false, supportsToolCall: false, supportsReasoning: false } as ModelInfo
				this.editModels.push(m)
				this.autoSaveProvider()
			},

			removeModel(index: number) {
				const newList: ModelInfo[] = []
				for (let i = 0; i < this.editModels.length; i++) {
					if (i != index) {
						newList.push(this.editModels[i])
					}
				}
				this.editModels = newList
				this.autoSaveProvider()
			},

			async fetchModels() {
				if (this.editApiBase == '') {
					this.editApiBase = getDefaultProviderApiBase(this.editId)
					if (this.editApiBase == '') {
						uni.showToast({ position: 'bottom',  title: '请先输入接口地址', icon: 'none' })
						return
					}
				}
				if (this.editApiKey == '') {
					uni.showToast({ position: 'bottom',  title: '请先输入 API Key', icon: 'none' })
					return
				}
				this.fetchingModels = true
				const ids = await fetchProviderModels(this.editApiBase, this.editApiKey)
				// 过期才刷新元数据缓存，避免每次拉取 130KB
				if (isMetadataCacheStale()) {
					await refreshMetadataCache()
				}
				this.fetchingModels = false
				if (ids.length == 0) {
					uni.showToast({ position: 'bottom',  title: '获取失败，请检查地址和 Key', icon: 'none' })
					return
				}
				// 过滤已有模型，只展示新增的
				const existingMap: UTSJSONObject = {} as UTSJSONObject
				for (let i = 0; i < this.editModels.length; i++) {
					const mid = this.editModels[i].id
					if (mid != '') {
						existingMap[mid] = true
					}
				}
				const newIds: string[] = []
				for (let i = 0; i < ids.length; i++) {
					if (existingMap[ids[i]] == null) {
						newIds.push(ids[i])
					}
				}
				if (newIds.length == 0) {
					uni.showToast({ position: 'bottom',  title: '所有模型已存在', icon: 'none' })
					return
				}
				this.fetchedModelIds = newIds
				this.selectedModelIndexes = []
				for (let i = 0; i < newIds.length; i++) {
					this.selectedModelIndexes.push(false)
				}
				this.showModelPicker = true
			},

			toggleSelectAllModels() {
				const select = this.allModelsSelected ? false : true
				for (let i = 0; i < this.selectedModelIndexes.length; i++) {
					this.selectedModelIndexes[i] = select
				}
			},

			toggleModelSelection(index: number) {
				if (index >= 0 && index < this.selectedModelIndexes.length) {
					this.selectedModelIndexes[index] = !this.selectedModelIndexes[index]
				}
			},

			modelMatchesSearch(id: string): boolean {
				if (this.pickerSearchText == '') return true
				return id.toLowerCase().indexOf(this.pickerSearchText.toLowerCase()) >= 0
			},

			cancelModelPicker() {
				this.showModelPicker = false
				this.fetchedModelIds = []
				this.selectedModelIndexes = []
				this.pickerSearchText = ''
			},

			confirmAddModels() {
				let addedCount = 0
				for (let i = 0; i < this.fetchedModelIds.length; i++) {
					if (this.selectedModelIndexes[i] == true) {
						const modelId = this.fetchedModelIds[i]
						const caps = getModelCapabilities(modelId)
						this.editModels.push({
							id: modelId,
							ctxStr: '',
							supportsVision: caps.supportsVision,
							supportsToolCall: caps.supportsToolCall,
							supportsReasoning: caps.supportsReasoning,
						} as ModelInfo)
						addedCount++
					}
				}
				this.showModelPicker = false
				this.fetchedModelIds = []
				this.selectedModelIndexes = []
				this.pickerSearchText = ''
				this.autoSaveProvider()
				uni.showToast({ position: 'bottom',  title: '已添加 ' + addedCount + ' 个模型', icon: 'success' })
			},

			autoSaveProvider() {
				if (this.isNew == true) { return }
				this.saveProvider(false)
			},

			saveProviderAndBack() {
				this.saveProvider(true)
			},

			saveProvider(navigateAfterSave: boolean) {
				if (this.editId == '') {
					uni.showToast({ position: 'bottom',  title: '请输入标识', icon: 'none' })
					return
				}
				if (this.editName == '') {
					this.editName = this.editId
				}
				if (this.editApiBase == '') {
					this.editApiBase = getDefaultProviderApiBase(this.editId)
				}
				if (this.fromFirstRunGuide == true && navigateAfterSave == true) {
					this.editApiKey = this.editApiKey.trim()
					this.editApiBase = this.editApiBase.trim()
					if (this.editApiKey == '') {
						uni.showToast({ position: 'bottom',  title: '先填写 API Key', icon: 'none' })
						return
					}
					if (this.editApiBase == '') {
						uni.showToast({ position: 'bottom',  title: '先填写接口地址', icon: 'none' })
						return
					}
				}
				// 同步字符串 → 数字，清理空模型
				const validModels: ModelInfo[] = []
				for (let i = 0; i < this.editModels.length; i++) {
					const m = this.editModels[i]
					if (m.id == '') {
						continue
					}
					// ctxStr → context
					const ctxVal = m.ctxStr
					if (ctxVal != null && ctxVal != '') {
						const parsed = Number.parseInt(ctxVal)
						if (!isNaN(parsed) && parsed > 0) {
							m.context = parsed
						}
					}
					// maxTokensStr → maxTokens
					const mtVal = m.maxTokensStr
					if (mtVal != null && mtVal != '') {
						const parsed = Number.parseInt(mtVal)
						if (!isNaN(parsed) && parsed > 0) {
							m.maxTokens = parsed
						}
					}
					validModels.push(m)
				}
				if (this.fromFirstRunGuide == true && navigateAfterSave == true && validModels.length == 0) {
					uni.showToast({ position: 'bottom',  title: '先添加或获取一个模型', icon: 'none' })
					return
				}
				saveProvider(this.editId, this.editName, this.editApiBase, this.editApiKey, validModels, true)
				if (navigateAfterSave == false) {
					return
				}
				if (this.fromFirstRunGuide == true) {
					const defaultModel = validModels[0].id
					setActiveProvider(this.editId)
					setDefaultTaskModel('chat', this.editId, defaultModel)
					// COMPAT_LEGACY_MODEL_SETTINGS: 旧聊天创建逻辑还读 settings_*；默认模型页统一后可清空。
					setAppSetting('settings_provider_id', this.editId)
					setAppSetting('settings_model', defaultModel)
					setAppSetting(FIRST_RUN_GUIDE_DONE_KEY, 'true')
					uni.showToast({ position: 'bottom',  title: '已接入，可以开始聊天', icon: 'success' })
					setTimeout(() => {
						uni.navigateBack()
					}, 500)
					return
				}
				uni.showToast({ position: 'bottom',  title: '已保存', icon: 'success' })

				// 检查是否已设置默认聊天模型，没有则引导
				const defaultChat = getDefaultTaskModel('chat')
				if (defaultChat == null && validModels.length > 0) {
					setTimeout(() => {
						uni.showModal({
							title: '设置默认模型',
							content: '还没有设置默认聊天模型，是否现在去设置？',
							success: (res) => {
								if (res.confirm == true) {
									uni.navigateTo({ url: '/pages/settings/default-models/default-models' })
								} else {
									uni.navigateBack()
								}
							}
						})
					}, 600)
				} else {
					setTimeout(() => {
						uni.navigateBack()
					}, 500)
				}
			}
		}
	}
</script>

<style>
	.container {
		flex: 1;
		padding: 16px;
	}

	.guide-card {
		background-color: #FFF7FA;
		border-radius: 12px;
		padding: 14px;
		margin-bottom: 12px;
		border-width: 1px;
		border-style: solid;
		border-color: rgba(251, 143, 171, 0.22);
	}

	.guide-title {
		font-size: 15px;
		font-weight: bold;
		color: #111827;
		margin-bottom: 5px;
	}

	.guide-desc {
		font-size: 13px;
		line-height: 19px;
		color: #6B7280;
	}

	.card {
		background-color: #FFFFFF;
		border-radius: 10px;
		padding: 16px;
		margin-bottom: 12px;
	}

	/* 字段 */
	.field-label {
		font-size: 13px;
		color: #6B7280;
		margin-top: 10px;
		margin-bottom: 4px;
	}

	.field-label:first-child {
		margin-top: 0;
	}

	.field-input {
		background-color: #F9FAFB;
		border-radius: 7px;
		padding: 10px;
		font-size: 14px;
		color: #111827;
	}

	.ph {
		color: #D1D5DB;
	}

	/* 模型卡片头 */
	.model-card-header {
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 10px;
	}

	.model-card-title {
		font-size: 15px;
		font-weight: bold;
		color: #111827;
	}

