<template>
	<view class="page-shell rice-theme-light">
		<NavBar variant="light" :title="providerEditTitle" showBack @back="goBack" />
		<scroll-view class="container" :scroll-y="true">
			<view v-if="fromFirstRunGuide" class="guide-card">
				<text class="guide-title">先把聊天模型接上</text>
				<text class="guide-desc">填 API Key 后可以直接「获取模型列表」，勾选要用的模型。保存后会自动把第一个模型设为默认对话模型。</text>
			</view>

			<view class="card">
				<!-- 标识 -->
				<text class="field-label">标识 (ID)</text>
				<input
					class="field-input"
					type="text"
					v-model="editId"
					:disabled="!isNew"
					placeholder="例如 deepseek"
					placeholder-class="ph"
				/>

				<!-- 显示名称 -->
				<text class="field-label">显示名称</text>
				<input
					class="field-input"
					type="text"
					v-model="editName"
					placeholder="例如 DeepSeek"
					placeholder-class="ph"
					@input="autoSaveProvider"
					@blur="autoSaveProvider"
				/>

				<!-- API Key -->
				<text class="field-label">API Key</text>
				<view class="api-key-row">
					<input
						class="field-input api-key-input"
						type="text"
						:password="showApiKey == false"
						v-model="editApiKey"
						placeholder="输入 API Key"
						placeholder-class="ph"
						@input="autoSaveProvider"
						@blur="autoSaveProvider"
					/>
					<view class="api-key-toggle" @click="toggleApiKeyVisibility">
						<oui-icon-unix name="eye" size="20px" :color="showApiKey == true ? '#E05A87' : '#9CA3AF'" />
					</view>
				</view>

				<!-- 接口地址 -->
				<text class="field-label">接口地址</text>
				<input
					class="field-input"
					type="text"
					v-model="editApiBase"
					placeholder="留空使用默认地址"
					placeholder-class="ph"
					@input="autoSaveProvider"
					@blur="autoSaveProvider"
				/>
			</view>

			<!-- 模型管理卡片 -->
			<view class="card">
				<view class="model-card-header">
					<text class="model-card-title">模型列表</text>
					<view class="fetch-btn" @click="fetchModels">
						<text class="fetch-btn-text">获取模型列表</text>
					</view>
				</view>

				<!-- 加载中 -->
				<view v-if="fetchingModels" class="fetching-row">
					<text class="fetching-text">正在获取模型列表...</text>
				</view>

				<!-- 模型选择器（获取成功后显示） -->
				<view v-if="showModelPicker" class="model-picker">
					<view class="picker-header">
						<text class="picker-title">获取到 {{fetchedModelIds.length}} 个模型</text>
						<text class="picker-select-all" @click="toggleSelectAllModels">{{allModelsSelected ? '取消全选' : '全选'}}</text>
					</view>
					<input
						class="picker-search"
						type="text"
						v-model="pickerSearchText"
						placeholder="搜索模型..."
						placeholder-style="color:#9CA3AF"
					/>
					<scroll-view class="picker-list" :scroll-y="true" style="max-height:160px;">
						<view v-for="(mid, pidx) in fetchedModelIds" :key="pidx">
							<view v-if="modelMatchesSearch(mid)" class="picker-row" @click="toggleModelSelection(pidx)">
							<view class="picker-checkbox" :class="selectedModelIndexes[pidx] == true ? 'picker-checkbox-on' : ''">
								<text v-if="selectedModelIndexes[pidx] == true" class="picker-checkmark">✓</text>
							</view>
							<text class="picker-model-id">{{mid}}</text>
						</view>
						</view>
						<view v-if="filteredModelCount == 0 && pickerSearchText != ''" class="picker-empty">
							<text class="picker-empty-text">无匹配模型</text>
						</view>
					</scroll-view>
					<view class="picker-actions">
						<text class="picker-cancel" @click="cancelModelPicker">取消</text>
						<text class="picker-confirm" @click="confirmAddModels">添加选中 ({{selectedModelCount}})</text>
					</view>
				</view>

				<!-- 模型列表 -->
				<view v-for="(m, mi) in editModels" :key="mi" class="model-card">
					<!-- 折叠态概要 -->
					<view class="model-row" @click="toggleExpand(mi)">
						<view class="model-row-left">
							<text class="model-index">{{mi + 1}}</text>
							<view class="model-summary">
								<text class="model-summary-id">{{m.id != '' ? m.id : '新模型'}}</text>
								<text class="model-summary-meta">
									{{getModelSummary(m)}}
								</text>
							</view>
						</view>
						<view class="model-row-right">
							<text
								v-if="fromFirstRunGuide == true && m.id != ''"
								class="model-default-btn"
								:class="firstRunDefaultModelId == m.id ? 'model-default-btn-active' : ''"
								@click.stop="selectFirstRunDefaultModel(m.id)"
							>{{firstRunDefaultModelId == m.id ? '默认模型' : '设为默认'}}</text>
							<text class="model-expand-icon">{{(m.expanded == true) ? '▾' : '▸'}}</text>
							<text class="model-del-btn" @click.stop="removeModel(mi)">✕</text>
						</view>
					</view>

					<!-- 展开详情 -->
					<view v-if="m.expanded" class="model-detail">
						<view class="detail-field">
							<text class="detail-field-label">模型 ID</text>
							<input class="detail-field-input" type="text" v-model="m.id" placeholder="输入 Provider 返回的模型 ID" placeholder-class="ph" @blur="autoSaveProvider" />
						</view>
						<view class="detail-field">
							<text class="detail-field-label">显示名称</text>
							<input class="detail-field-input" type="text" v-model="m.name" placeholder="DeepSeek V4 Flash" placeholder-class="ph" @blur="autoSaveProvider" />
						</view>
						<view class="detail-row">
							<view class="detail-field" style="flex:1;margin-right:6px;">
								<text class="detail-field-label">上下文窗口 (tokens)</text>
								<input class="detail-field-input" type="number" v-model="m.ctxStr" placeholder="128000" placeholder-class="ph" @blur="autoSaveProvider" />
							</view>
							<view class="detail-field" style="flex:1;">
								<text class="detail-field-label">最大输出 (tokens)</text>
								<input class="detail-field-input" type="number" v-model="m.maxTokensStr" placeholder="4096" placeholder-class="ph" @blur="autoSaveProvider" />
							</view>
						</view>
						<view class="detail-field">
							<text class="detail-field-label">自定义参数 (JSON)</text>
							<input class="detail-field-input detail-params-input" type="text" v-model="m.params" placeholder='{"key": "value"}' placeholder-class="ph" @blur="autoSaveProvider" />
							<text class="detail-field-hint">额外的 API 参数，例如温度、top_p 等</text>
						</view>
						<view class="detail-field model-vision-row">
							<text class="detail-field-label">支持识图</text>
							<rice-switch v-model="m.supportsVision" @change="onModelCapabilityChange(mi)" />
						</view>
						<view class="detail-field model-vision-row">
							<text class="detail-field-label">支持工具调用</text>
							<rice-switch v-model="m.supportsToolCall" @change="onModelCapabilityChange(mi)" />
						</view>
						<view class="detail-field model-vision-row">
							<text class="detail-field-label">支持思维链</text>
							<rice-switch v-model="m.supportsReasoning" @change="onModelCapabilityChange(mi)" />
						</view>
				</view>
				</view>

				<!-- 添加模型 -->
				<view class="add-model-btn" @click="addModel">
					<text class="add-model-text">+ 添加模型</text>
				</view>
			</view>

			<!-- 保存 -->
			<view v-if="showSaveButton" class="save-wrap">
				<rice-button type="primary" :text="saveButtonText" size="large" shape="round" @click="saveProviderAndBack" />
			</view>
		</scroll-view>
	</view>
</template>

<script lang="uts">
	import { saveProvider, saveFirstRunProviderConfiguration, fetchProviderModelsDetailedForProvider, parseModels, ModelInfo, getDefaultTaskModel, getProviderById, getDefaultProviderApiBase } from '@/uni_modules/agent-core/utssdk/provider.uts'
	import { refreshMetadataCacheInBackground, ensureMetadataCache } from '@/uni_modules/agent-core/utssdk/llm-metadata.uts'
	import { consumeRuntimeState } from '@/utils/database.uts'
	import { APP_ERROR_CATEGORY_NETWORK, formatAppErrorForUser, reportAppErrorFromCause } from '@/utils/app-error.uts'
	import {
		appendSelectedProviderModels,
		areAllProviderModelsSelected,
		buildProviderModelSelectionFlags,
		buildProviderModelSummary,
		countFilteredProviderModels,
		countSelectedProviderModels,
		createProviderEditModelInfo,
		filterNewProviderModelIds,
		hasProviderEditModel,
		normalizeProviderModelsForSave,
		parseProviderEditPreset,
		providerModelMatchesSearch,
		removeProviderEditModelAt,
	} from '@/utils/provider-edit-page-helpers.uts'

	const PROVIDER_EDIT_RUNTIME_ID_KEY = 'provider_edit_id'
	const PROVIDER_EDIT_SOURCE_KEY = 'provider_edit_source'
	const PROVIDER_EDIT_SOURCE_FIRST_RUN = 'first_run_guide'
	const PROVIDER_EDIT_PRESET_KEY = 'provider_edit_preset'

	function cloneProviderEditModels(models: ModelInfo[]): ModelInfo[] {
		return JSON.parse(JSON.stringify(models)) as ModelInfo[]
	}

	export default {
		data() {
			return {
				isNew: true as boolean,
				editEnabled: true as boolean,
				editId: '' as string,
				editName: '' as string,
				editApiKey: '' as string,
				showApiKey: false as boolean,
				editApiBase: '' as string,
				editModels: [] as ModelInfo[],
				fromFirstRunGuide: false as boolean,
				fetchingModels: false as boolean,
				showModelPicker: false as boolean,
				fetchedModelIds: [] as string[],
				selectedModelIndexes: [] as boolean[],
				pickerSearchText: '' as string,
				firstRunDefaultModelId: '' as string,
				savedEditName: '' as string,
				savedEditApiKey: '' as string,
				savedEditApiBase: '' as string,
				savedEditEnabled: true as boolean,
				savedEditModels: [] as ModelInfo[],
				savedFirstRunDefaultModelId: '' as string,
				pageActive: false as boolean,
				navigationTimer: -1 as number,
			}
		},
		onLoad() {
			this.pageActive = true
			// 预加载模型能力元数据缓存，保证后续模型构造直接命中
			ensureMetadataCache()
			const source = consumeRuntimeState(PROVIDER_EDIT_SOURCE_KEY)
			this.fromFirstRunGuide = source == PROVIDER_EDIT_SOURCE_FIRST_RUN
			const preset = consumeRuntimeState(PROVIDER_EDIT_PRESET_KEY)
			const editId = consumeRuntimeState(PROVIDER_EDIT_RUNTIME_ID_KEY)
			if (editId != '') {
				this.loadProviderForEdit(editId)
			}
			if (preset != '') {
				this.applyProviderPreset(preset, editId == '')
			}
		},
		onUnload() {
			this.pageActive = false
			if (this.navigationTimer != -1) {
				clearTimeout(this.navigationTimer)
				this.navigationTimer = -1
			}
		},
		computed: {
			providerEditTitle(): string {
				if (this.fromFirstRunGuide == true) { return '配置聊天模型' }
				return this.isNew ? '添加提供商' : '编辑提供商'
			},
			showSaveButton(): boolean {
				return this.isNew == true || this.fromFirstRunGuide == true
			},
			saveButtonText(): string {
				return this.fromFirstRunGuide == true ? '保存并开始聊天' : '保存创建'
			},
			selectedModelCount(): number {
				return countSelectedProviderModels(this.selectedModelIndexes)
			},
			allModelsSelected(): boolean {
				return areAllProviderModelsSelected(this.fetchedModelIds, this.selectedModelIndexes)
			},
			filteredModelCount(): number {
				return countFilteredProviderModels(this.fetchedModelIds, this.pickerSearchText)
			},
		},
		methods: {
			captureSavedProviderState(): void {
				this.savedEditName = this.editName
				this.savedEditApiKey = this.editApiKey
				this.savedEditApiBase = this.editApiBase
				this.savedEditEnabled = this.editEnabled
				this.savedEditModels = cloneProviderEditModels(this.editModels)
				this.savedFirstRunDefaultModelId = this.firstRunDefaultModelId
			},

			restoreSavedProviderState(): void {
				if (this.isNew == true) { return }
				this.editName = this.savedEditName
				this.editApiKey = this.savedEditApiKey
				this.editApiBase = this.savedEditApiBase
				this.editEnabled = this.savedEditEnabled
				this.editModels = cloneProviderEditModels(this.savedEditModels)
				this.firstRunDefaultModelId = this.savedFirstRunDefaultModelId
			},
			goBack() {
				uni.navigateBack()
			},

			toggleApiKeyVisibility() {
				this.showApiKey = !this.showApiKey
			},

			appendModelIfMissing(modelId: string): void {
				if (hasProviderEditModel(this.editModels, modelId) == true) { return }
				this.editModels.push(createProviderEditModelInfo(modelId, false, this.editId))
			},

			applyProviderPreset(presetJson: string, overrideIdentity: boolean): void {
				const preset = parseProviderEditPreset(presetJson)
				if (preset.valid == false) { return }
				if (this.fromFirstRunGuide == true) {
					this.editEnabled = true
				}
				if (overrideIdentity == true) {
					this.isNew = true
					this.editEnabled = true
					this.editId = preset.id
					this.editName = preset.name
				} else if (this.editName == '' && preset.name != '') {
					this.editName = preset.name
				}
				if (this.editApiBase == '' && preset.apiBase != '') {
					this.editApiBase = preset.apiBase
				}
				this.appendModelIfMissing(preset.model)
			},

			loadProviderForEdit(id: string) {
				const data = getProviderById(id)
				if (data == null) {
					uni.showToast({ position: 'bottom', title: '提供商不存在', icon: 'none' })
					return
				}
				this.isNew = false
				this.editId = id
				const rawName = data['name'] as string | null
				const rawApiKey = data['api_key'] as string | null
				const rawApiBase = data['api_base'] as string | null
				const rawEnabled = data['enabled'] as number | null
					this.editName = rawName != null ? rawName : ''
					this.editApiKey = rawApiKey != null ? rawApiKey : ''
					this.editApiBase = rawApiBase != null ? rawApiBase : ''
					this.editEnabled = rawEnabled == 1
					if (this.editApiBase == '') {
						this.editApiBase = getDefaultProviderApiBase(id)
					}
					const modelsStr = data['models'] as string | null
					if (modelsStr != null) {
						this.editModels = parseModels(modelsStr)
					}
					this.captureSavedProviderState()
				},

			getModelSummary(m: ModelInfo): string {
				return buildProviderModelSummary(m)
			},

			toggleExpand(index: number) {
				const m = this.editModels[index]
				if (m != null) {
					m.expanded = !(m.expanded == true)
				}
			},

			addModel() {
				this.editModels.push(createProviderEditModelInfo('', true, this.editId))
				this.autoSaveProvider()
			},

			removeModel(index: number) {
				if (index >= 0 && index < this.editModels.length && this.editModels[index].id == this.firstRunDefaultModelId) {
					this.firstRunDefaultModelId = ''
				}
				this.editModels = removeProviderEditModelAt(this.editModels, index)
				this.autoSaveProvider()
			},

			selectFirstRunDefaultModel(modelId: string) {
				if (modelId == '') { return }
				this.firstRunDefaultModelId = modelId
			},

			async fetchModels() {
				if (this.fetchingModels == true) { return }
				if (this.editApiBase == '') {
					this.editApiBase = getDefaultProviderApiBase(this.editId)
					if (this.editApiBase == '') {
						uni.showToast({ position: 'bottom',  title: '请先输入接口地址', icon: 'none' })
						return
					}
				}
				if (this.editApiKey == '') {
					uni.showToast({ position: 'bottom',  title: '请先输入 API Key', icon: 'none' })
					return
				}
				this.fetchingModels = true
				const result = await fetchProviderModelsDetailedForProvider(this.editApiBase, this.editApiKey, this.editId)
				this.fetchingModels = false
				if (this.pageActive == false) { return }
				if (result.ok == false) {
					const error = reportAppErrorFromCause(result.errorCode, APP_ERROR_CATEGORY_NETWORK, 'provider_fetch_models', result.errorMessage, result.detail, true)
					uni.showToast({ position: 'bottom', title: formatAppErrorForUser(error), icon: 'none' })
					return
				}
				const ids = result.ids
				if (ids.length == 0) {
					uni.showToast({ position: 'bottom', title: '接口连接成功，但没有返回可用模型', icon: 'none' })
					return
				}
				// 元数据只补充能力标签，后台刷新不应阻塞已获取的模型列表。
				refreshMetadataCacheInBackground()
				// 过滤已有模型，只展示新增的
				const newIds = filterNewProviderModelIds(ids, this.editModels)
				if (newIds.length == 0) {
					uni.showToast({ position: 'bottom',  title: '所有模型已存在', icon: 'none' })
					return
				}
				this.fetchedModelIds = newIds
				this.selectedModelIndexes = buildProviderModelSelectionFlags(newIds.length, false)
				this.showModelPicker = true
			},

			toggleSelectAllModels() {
				const select = this.allModelsSelected ? false : true
				this.selectedModelIndexes = buildProviderModelSelectionFlags(this.selectedModelIndexes.length, select)
			},

			onModelCapabilityChange(index: number): void {
				if (index < 0 || index >= this.editModels.length) { return }
				// 手工开关即代表用户明确声明能力，不能继续按旧模型的未知状态序列化。
				this.editModels[index].capabilitiesKnown = true
				this.autoSaveProvider()
			},

			toggleModelSelection(index: number) {
				if (index >= 0 && index < this.selectedModelIndexes.length) {
					this.selectedModelIndexes[index] = !this.selectedModelIndexes[index]
				}
			},

			modelMatchesSearch(id: string): boolean {
				return providerModelMatchesSearch(id, this.pickerSearchText)
			},

			cancelModelPicker() {
				this.showModelPicker = false
				this.fetchedModelIds = []
				this.selectedModelIndexes = []
				this.pickerSearchText = ''
			},

			confirmAddModels() {
				const addedCount = appendSelectedProviderModels(this.editModels, this.fetchedModelIds, this.selectedModelIndexes, this.editId)
				this.showModelPicker = false
				this.fetchedModelIds = []
				this.selectedModelIndexes = []
				this.pickerSearchText = ''
				const saved = this.autoSaveProvider()
				if (saved == false) { return }
				uni.showToast({ position: 'bottom',  title: '已添加 ' + addedCount + ' 个模型', icon: 'success' })
			},

			autoSaveProvider(): boolean {
				if (this.isNew == true) { return true }
				return this.saveProvider(false)
			},

			saveProviderAndBack() {
				this.saveProvider(true)
			},

			saveProvider(navigateAfterSave: boolean): boolean {
				if (this.editId == '') {
					uni.showToast({ position: 'bottom',  title: '请输入标识', icon: 'none' })
					return false
				}
				if (this.editName == '') {
					this.editName = this.editId
				}
				if (this.editApiBase == '') {
					this.editApiBase = getDefaultProviderApiBase(this.editId)
				}
				if (this.fromFirstRunGuide == true && navigateAfterSave == true) {
					this.editApiKey = this.editApiKey.trim()
					this.editApiBase = this.editApiBase.trim()
					if (this.editApiKey == '') {
						uni.showToast({ position: 'bottom',  title: '先填写 API Key', icon: 'none' })
						return false
					}
					if (this.editApiBase == '') {
						uni.showToast({ position: 'bottom',  title: '先填写接口地址', icon: 'none' })
						return false
					}
				}
				// 同步字符串 → 数字，清理空模型
				const validModels = normalizeProviderModelsForSave(this.editModels)
				if (this.fromFirstRunGuide == true && navigateAfterSave == true && validModels.length == 0) {
					uni.showToast({ position: 'bottom',  title: '先添加或获取一个模型', icon: 'none' })
					return false
				}
				let firstRunDefaultModel = ''
				if (this.fromFirstRunGuide == true && navigateAfterSave == true) {
					if (validModels.length == 1) {
						firstRunDefaultModel = validModels[0].id
					} else {
						for (let i = 0; i < validModels.length; i++) {
							if (validModels[i].id == this.firstRunDefaultModelId) {
								firstRunDefaultModel = validModels[i].id
								break
							}
						}
						if (firstRunDefaultModel == '') {
							uni.showToast({ position: 'bottom', title: '多个模型中请选择一个默认对话模型', icon: 'none' })
							return false
						}
					}
				}
				let providerSaved = false
				if (this.fromFirstRunGuide == true && navigateAfterSave == true) {
					providerSaved = saveFirstRunProviderConfiguration(this.editId, this.editName, this.editApiBase, this.editApiKey, validModels, firstRunDefaultModel)
				} else {
					providerSaved = saveProvider(this.editId, this.editName, this.editApiBase, this.editApiKey, validModels, this.editEnabled)
				}
					if (providerSaved == false) {
						this.restoreSavedProviderState()
						uni.showToast({ position: 'bottom', title: '保存提供商失败，请重试', icon: 'none' })
						return false
					}
					this.captureSavedProviderState()
				if (navigateAfterSave == false) {
					return true
				}
				if (this.fromFirstRunGuide == true) {
					uni.showToast({ position: 'bottom',  title: '已接入，可以开始聊天', icon: 'success' })
					if (this.navigationTimer != -1) {
						clearTimeout(this.navigationTimer)
					}
					this.navigationTimer = setTimeout(() => {
						this.navigationTimer = -1
						uni.navigateBack()
					}, 500)
					return true
				}
				uni.showToast({ position: 'bottom',  title: '已保存', icon: 'success' })

				// 检查是否已设置默认聊天模型，没有则引导
				const defaultChat = getDefaultTaskModel('chat')
				if (defaultChat == null && validModels.length > 0) {
					if (this.navigationTimer != -1) {
						clearTimeout(this.navigationTimer)
					}
					this.navigationTimer = setTimeout(() => {
						this.navigationTimer = -1
						uni.showModal({
							title: '设置默认模型',
							content: '还没有设置默认聊天模型，是否现在去设置？',
							success: (res) => {
								if (res.confirm == true) {
									uni.navigateTo({ url: '/pages/settings/default-models/default-models' })
								} else {
									uni.navigateBack()
								}
							}
						})
					}, 600)
				} else {
					if (this.navigationTimer != -1) {
						clearTimeout(this.navigationTimer)
					}
					this.navigationTimer = setTimeout(() => {
						this.navigationTimer = -1
						uni.navigateBack()
					}, 500)
				}
				return true
			}
		}
	}
</script>

