<template>
	<view class="page-shell rice-theme-light">
		<NavBar title="提供商管理" showBack>
			<template #right>
				<view class="nav-add-btn" @click="addProvider">
					<text class="nav-add-text">+ 添加</text>
				</view>
			</template>
		</NavBar>
		<scroll-view class="container" :scroll-y="true">

			<!-- 提供商列表 -->
			<view class="card" v-for="(item, index) in providerList" :key="index">
				<view class="provider-header">
					<view class="provider-left">
						<text class="provider-name">{{item['name']}}</text>
						<text class="provider-id">{{item['id']}}</text>
					</view>
					<view class="provider-right">
						<rice-switch
							v-model="switchStates[index]"
							@change="toggleEnabled(index)"
						/>
					</view>
				</view>
				<view class="provider-detail">
					<text class="detail-label">API Key</text>
					<text class="detail-value">{{maskString(item['api_key'] as string)}}</text>
				</view>
				<view class="provider-detail">
					<text class="detail-label">接口地址</text>
					<text class="detail-value">{{(item['api_base'] as string) != '' ? item['api_base'] : '默认'}}</text>
				</view>
				<view class="provider-detail" style="flex-direction:column;align-items:flex-start;">
					<view style="flex-direction:row;align-items:center;width:100%;">
						<text class="detail-label">模型</text>
						<text class="detail-value">{{getModelsPreview(item['models'] as string)}}</text>
					</view>
				</view>
				<view class="provider-actions">
					<text class="action-btn action-edit" @click="editProvider(index)">编辑</text>
					<text class="action-btn action-delete" @click="deleteProvider(index)">删除</text>
				</view>
			</view>

			<!-- 空状态 -->
			<view v-if="providerList.length == 0" class="empty-state">
				<text class="empty-text">暂无提供商，点击右上角添加</text>
			</view>

		</scroll-view>
	</view>
</template>

<script lang="uts">
	import { getAllProviders, deleteProvider, setProviderEnabled, parseModels } from '@/uni_modules/agent-core/utssdk/provider.uts'

	export default {
		data() {
			return {
				providerList: [] as UTSJSONObject[],
				switchStates: [] as boolean[],
			}
		},
		onShow() {
			this.loadProviders()
		},
		methods: {
			loadProviders() {
				this.providerList = getAllProviders()
				// 同步 switch 状态
				this.switchStates = []
				for (let i = 0; i < this.providerList.length; i++) {
					const enabled = this.providerList[i]['enabled'] as number
					this.switchStates.push(enabled == 1)
				}
			},

			maskString(s: string): string {
				if (s == null || s == '') {
					return '未设置'
				}
				if (s.length <= 8) {
					return s.substring(0, 4) + '****'
				}
				return s.substring(0, 8) + '****'
			},

			getModelsPreview(modelsStr: string): string {
				const models = parseModels(modelsStr)
				if (models.length == 0) {
					return '未设置'
				}
				const names: string[] = []
				for (let i = 0; i < models.length && i < 3; i++) {
					names.push(models[i].id)
				}
				if (models.length <= 3) {
					return names.join(', ')
				}
				return names.join(', ') + ` 等${models.length}个`
			},

			toggleEnabled(index: number) {
				const item = this.providerList[index]
				if (item == null) {
					return
				}
				const id = item['id'] as string
				const newEnabled = this.switchStates[index]
				setProviderEnabled(id, newEnabled)
				item['enabled'] = newEnabled ? 1 : 0
			},

			addProvider() {
				uni.setStorageSync('provider_edit_data', '')
				uni.navigateTo({
					url: '/pages/settings/basic/provider-edit'
				})
			},

			editProvider(index: number) {
				const item = this.providerList[index]
				if (item == null) {
					return
				}
				const data: UTSJSONObject = {
					id: item['id'],
					name: item['name'],
					apiKey: item['api_key'],
					apiBase: item['api_base'],
					models: item['models'],
				} as UTSJSONObject
				uni.setStorageSync('provider_edit_data', JSON.stringify(data))
				uni.navigateTo({
					url: '/pages/settings/basic/provider-edit'
				})
			},

			deleteProvider(index: number) {
				const item = this.providerList[index]
				if (item == null) {
					return
				}
				const id = item['id'] as string
				uni.showModal({
					title: '确认删除',
					content: `确定删除提供商「${item['name']}」吗？`,
					success: (res) => {
						if (res.confirm == true) {
							deleteProvider(id)
							this.loadProviders()
							uni.showToast({
								title: '已删除',
								icon: 'success'
							})
						}
					}
				})
			},

		}
	}
</script>

<style>
	.container {
		flex: 1;
		padding: 32rpx;
	}

	/* 添加按钮 */
	.nav-add-btn {
		padding: 8rpx 16rpx;
	}

	.nav-add-text {
		font-size: 32rpx;
		color: #FFFFFF;
		font-weight: bold;
	}

	/* 提供商卡片 */
	.card {
		background-color: #FFFFFF;
		border-radius: 20rpx;
		padding: 32rpx;
		margin-bottom: 24rpx;
	}

	.provider-header {
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 16rpx;
	}

	.provider-left {
		flex-direction: column;
		flex: 1;
	}

	.provider-name {
		font-size: 32rpx;
		font-weight: bold;
		color: #111827;
	}

	.provider-id {
		font-size: 22rpx;
		color: #9CA3AF;
		margin-top: 4rpx;
	}

	.provider-right {
		padding-left: 16rpx;
	}

	/* 详情行 */
	.provider-detail {
		flex-direction: row;
		align-items: center;
		padding: 6rpx 0;
	}

	.detail-label {
		font-size: 24rpx;
		color: #9CA3AF;
		width: 120rpx;
		flex-shrink: 0;
	}

	.detail-value {
		font-size: 24rpx;
		color: #374151;
		flex: 1;
	}

	/* 操作按钮 */
	.provider-actions {
		flex-direction: row;
		justify-content: flex-end;
		margin-top: 16rpx;
		padding-top: 16rpx;
		border-top-width: 0.10rpx;
		border-top-style: solid;
		border-top-color: #F3F4F6;
	}

	.action-btn {
		padding: 10rpx 24rpx;
		border-radius: 10rpx;
		font-size: 26rpx;
		margin-left: 16rpx;
	}

	.action-edit {
		background-color: #FDE8EF;
		color: #FB8FAB;
	}

	.action-delete {
		background-color: #FEE2E2;
		color: #EF4444;
	}

	/* 空状态 */
	.empty-state {
		align-items: center;
		padding: 80rpx 0;
	}

	.empty-text {
		font-size: 28rpx;
		color: #9CA3AF;
	}
</style>
