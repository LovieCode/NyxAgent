<template>
	<view class="page-shell rice-theme-light">
		<NavBar variant="light" title="数据与备份" showBack />
		<scroll-view class="container" :scroll-y="true">
			<view class="hero-card">
				<text class="hero-title">数据与备份</text>
				<text class="hero-desc">备份就是存档点。安全备份会移除已知 API Key；完整迁移备份适合换机，但别乱分享。</text>
			</view>

			<view class="card">
				<view class="card-header">
					<oui-icon-unix name="download" size="14px" color="#6B7280" style="margin-right:6px" />
					<text class="card-title">备份当前数据</text>
				</view>
				<view class="action-row" @click="confirmExportSafe">
					<view class="action-main">
						<text class="action-title">安全备份</text>
						<text class="action-desc">不导出已知 API Key，也不会附带原始 SQLite 数据库文件。</text>
					</view>
					<text class="action-badge">推荐</text>
				</view>
				<view class="inner-divider"></view>
				<view class="action-row" @click="confirmExportFull">
					<view class="action-main">
						<text class="action-title danger-title">完整迁移备份</text>
						<text class="action-desc">包含 API Key、聊天记录、文件和原始数据库，只建议自己换机使用。</text>
					</view>
					<text class="action-arrow">›</text>
				</view>
			</view>

			<view class="card">
				<view class="card-header">
					<oui-icon-unix name="upload" size="14px" color="#6B7280" style="margin-right:6px" />
					<text class="card-title">从备份恢复</text>
				</view>
				<view class="action-row" @click="chooseImportZip">
					<view class="action-main">
						<text class="action-title">选择备份 ZIP</text>
						<text class="action-desc">选择后先预览内容，不会立刻写入数据。</text>
					</view>
					<text class="action-arrow">›</text>
				</view>
				<view class="preview-box">
					<view class="preview-head">
						<text class="preview-title">导入预览</text>
						<text v-if="selectedBackupHasApiKeys == true" class="danger-chip">含密钥</text>
					</view>
					<text class="preview-text">{{previewText}}</text>
				</view>
				<view v-if="selectedImportPath != ''" class="button-row">
					<view class="secondary-button" @click="confirmImportSettingsOnly">
						<text class="secondary-button-text">仅恢复设置</text>
					</view>
					<view class="danger-button" @click="confirmImportOverwrite">
						<text class="danger-button-text">覆盖恢复全部</text>
					</view>
				</view>
			</view>

			<view class="card">
				<view class="card-header">
					<oui-icon-unix name="setting" size="14px" color="#6B7280" style="margin-right:6px" />
					<text class="card-title">数据维护</text>
				</view>
				<view class="action-row" @click="confirmMigrateLegacyStorage">
					<view class="action-main">
						<text class="action-title">迁移旧 Storage 数据</text>
						<text class="action-desc">把旧版缓存迁移到 SQLite / 文件位置，并清理兼容遗留数据。</text>
					</view>
					<text class="action-arrow">›</text>
				</view>
			</view>

			<view class="bottom-space"></view>
		</scroll-view>
	</view>
</template>

<script lang="uts">
	import { buildDataExportOptions, exportAllDataToFileWithOptions, exportAllDataToJsonWithOptions, shareExportedDataFile, getLastShareExportErrorMessage } from '@/utils/data-export.uts'
	import { previewImportBackup, importAllDataFromZip, importSettingsOnlyFromZip } from '@/utils/data-import.uts'
	import { migrateAllLegacyStorageToNewLocation } from '@/utils/storage.uts'
	import { isChooseCancelError, parsePickedFileInfo } from '@/utils/attachment-reader.uts'
	import { APP_ERROR_CATEGORY_STORAGE, formatAppErrorForUser, reportAppErrorFromCause } from '@/utils/app-error.uts'

	export default {
		data() {
			return {
				selectedImportPath: '' as string,
				previewText: '还没选择备份包。点上面的「选择备份 ZIP」先看内容，别盲导。' as string,
				selectedBackupHasApiKeys: false as boolean,
				isBusy: false as boolean,
				isMigratingStorage: false as boolean,
			}
		},
		methods: {
			showDataFailure(code: string, operation: string, userMessage: string, cause: any | null) {
				const error = reportAppErrorFromCause(
					code,
					APP_ERROR_CATEGORY_STORAGE,
					operation,
					userMessage,
					cause,
					true,
				)
				uni.showToast({ position: 'bottom', title: formatAppErrorForUser(error), icon: 'none' })
			},

			confirmExportSafe() {
				if (this.isBusy == true) { return }
				uni.showModal({
					title: '导出安全备份',
					content: '会导出配置、聊天记录、头像和工作区文件，但会移除已知 API Key，并跳过原始 SQLite 数据库文件。继续？',
					success: (res) => {
						if (res.confirm == true) {
							this.exportData(false)
						}
					}
				})
			},

			confirmExportFull() {
				if (this.isBusy == true) { return }
				uni.showModal({
					title: '导出完整迁移备份',
					content: '完整备份包含 API Key、聊天记录、文件和原始数据库。只建议自己换机使用，不要发给别人。继续？',
					success: (res) => {
						if (res.confirm == true) {
							this.exportData(true)
						}
					}
				})
			},

			exportData(includeApiKeys: boolean) {
				this.isBusy = true
				try {
					const options = buildDataExportOptions(includeApiKeys)
					const path = exportAllDataToFileWithOptions(options)
					if (path != '') {
						this.isBusy = false
						this.shareOrCopyExportPath(path)
						return
					}
					// #ifdef APP-ANDROID
					reportAppErrorFromCause(
						'DATA_EXPORT_ZIP_FAILED',
						APP_ERROR_CATEGORY_STORAGE,
						'data_export_zip',
						'ZIP 备份生成失败，已改为复制备份内容',
						'writeExportZipFile 返回空路径',
						true,
					)
					// #endif
					const json = exportAllDataToJsonWithOptions(options)
					this.isBusy = false
					this.copyExportJson(json)
				} catch (e: any) {
					this.isBusy = false
					this.showDataFailure('DATA_EXPORT_FAILED', 'data_export', '导出失败', e)
				}
			},

			shareOrCopyExportPath(path: string) {
				const shared = shareExportedDataFile(path)
				if (shared == true) {
					return
				}
				const shareError = getLastShareExportErrorMessage()
				const diagnostic = reportAppErrorFromCause(
					'DATA_EXPORT_SHARE_FAILED',
					APP_ERROR_CATEGORY_STORAGE,
					'data_export_share',
					'系统分享失败',
					shareError != '' ? shareError : '系统分享面板没有打开',
					true,
				)
				const diagnosticText = '\n诊断编号：' + diagnostic.diagnosticId
				const shareFailTip = shareError != '' ? ('系统分享失败：' + shareError + '\nZIP 路径已复制：\n' + path + diagnosticText) : ('系统分享面板没有打开，ZIP 路径已复制：\n' + path + diagnosticText)
				uni.setClipboardData({
					data: path,
					success: () => {
						uni.showModal({
							title: '分享失败',
							content: shareFailTip,
							showCancel: false
						})
					},
					fail: (err: any) => {
						const clipboardError = reportAppErrorFromCause(
							'DATA_EXPORT_PATH_COPY_FAILED',
							APP_ERROR_CATEGORY_STORAGE,
							'data_export_copy_path',
							'导出路径复制失败',
							err,
							true,
						)
						uni.showModal({
							title: '分享失败',
							content: (shareError != '' ? ('系统分享失败：' + shareError + '\nZIP 已导出：\n' + path) : ('系统分享面板没有打开，ZIP 已导出：\n' + path)) + '\n诊断编号：' + clipboardError.diagnosticId,
							showCancel: false
						})
					}
				})
			},

			copyExportJson(json: string) {
				uni.setClipboardData({
					data: json,
					success: () => {
						uni.showToast({ position: 'bottom', title: '已复制导出清单', icon: 'success' })
					},
					fail: (err: any) => {
						this.showDataFailure('DATA_EXPORT_CLIPBOARD_FAILED', 'data_export_copy_json', '备份内容复制失败', err)
					}
				})
			},

			chooseImportZip() {
				if (this.isBusy == true) { return }
				uni.chooseFile({
					count: 1,
					success: (res: any) => {
						const path = parsePickedFileInfo(res).path
						if (path == '') {
							this.showDataFailure('DATA_IMPORT_PICK_EMPTY', 'data_import_pick_file', '没有读取到所选备份文件', res)
							return
						}
						this.loadImportPreview(path)
					},
					fail: (err: any) => {
						if (isChooseCancelError(err) == true) { return }
						this.showDataFailure('DATA_IMPORT_PICK_FAILED', 'data_import_pick_file', '选择备份文件失败', err)
					}
				})
			},

			loadImportPreview(path: string) {
				const result = previewImportBackup(path)
				if (result.ok != true) {
					this.selectedImportPath = ''
					this.selectedBackupHasApiKeys = false
					this.previewText = '预览失败：' + result.error
					uni.showToast({ position: 'bottom', title: '预览失败：' + result.error, icon: 'none' })
					return
				}
				this.selectedImportPath = path
				this.selectedBackupHasApiKeys = result.apiKeys
				this.previewText = result.summary
			},

			confirmImportSettingsOnly() {
				if (this.isBusy == true) { return }
				if (this.selectedImportPath == '') {
					uni.showToast({ position: 'bottom', title: '先选择备份包', icon: 'none' })
					return
				}
				uni.showModal({
					title: '仅恢复设置',
					content: '会覆盖提供商、默认模型、用户资料、Agent 和 Skills，不会覆盖聊天记录或工作区文件。建议先备份当前数据。继续？',
					success: (res) => {
						if (res.confirm == true) {
							this.importSettingsOnly()
						}
					}
				})
			},

			confirmImportOverwrite() {
				if (this.isBusy == true) { return }
				if (this.selectedImportPath == '') {
					uni.showToast({ position: 'bottom', title: '先选择备份包', icon: 'none' })
					return
				}
				uni.showModal({
					title: '覆盖恢复全部数据',
					content: '这会覆盖当前提供商、设置、对话、记忆、群聊、Agent、Skills 和工作区文件。建议先导出当前数据。继续？',
					success: (res) => {
						if (res.confirm == true) {
							this.importAllData()
						}
					}
				})
			},

			importSettingsOnly() {
				this.isBusy = true
				try {
					const summary = importSettingsOnlyFromZip(this.selectedImportPath)
					this.isBusy = false
					if (summary == '') {
						uni.showToast({ position: 'bottom', title: '导入失败，可在运行诊断查看详情', icon: 'none' })
						return
					}
					uni.showModal({
						title: '恢复完成',
						content: summary,
						showCancel: false
					})
				} catch (e: any) {
					this.isBusy = false
					this.showDataFailure('DATA_IMPORT_SETTINGS_FAILED', 'data_import_settings', '恢复设置失败', e)
				}
			},

			importAllData() {
				this.isBusy = true
				try {
					const summary = importAllDataFromZip(this.selectedImportPath)
					this.isBusy = false
					if (summary == '') {
						uni.showToast({ position: 'bottom', title: '导入失败，可在运行诊断查看详情', icon: 'none' })
						return
					}
					uni.showModal({
						title: '导入完成',
						content: summary,
						showCancel: false
					})
				} catch (e: any) {
					this.isBusy = false
					this.showDataFailure('DATA_IMPORT_ALL_FAILED', 'data_import_all', '导入备份失败', e)
				}
			},

			confirmMigrateLegacyStorage() {
				if (this.isMigratingStorage == true) { return }
				uni.showModal({
					title: '迁移旧 Storage 数据',
					content: '会把旧版本遗留的 uni.storage 数据迁移到 SQLite / 结构化表，成功后清理旧缓存。建议先做一次安全备份。继续？',
					success: (res) => {
						if (res.confirm == true) {
							this.migrateLegacyStorage()
						}
					}
				})
			},

			migrateLegacyStorage() {
				this.isMigratingStorage = true
				try {
					const result = migrateAllLegacyStorageToNewLocation()
					this.isMigratingStorage = false
					let diagnosticSuffix = ''
					if (result.failed > 0) {
						const diagnostic = reportAppErrorFromCause(
							'DATA_MIGRATION_PARTIAL_FAILED',
							APP_ERROR_CATEGORY_STORAGE,
							'data_migration_legacy_storage',
							'旧数据迁移未完全完成',
							result.message,
							true,
						)
						diagnosticSuffix = '\n诊断编号：' + diagnostic.diagnosticId
					}
					uni.showModal({
						title: result.failed == 0 ? '迁移完成' : '迁移未完全完成',
						content: result.message + diagnosticSuffix,
						showCancel: false
					})
				} catch (e: any) {
					this.isMigratingStorage = false
					this.showDataFailure('DATA_MIGRATION_FAILED', 'data_migration_legacy_storage', '迁移失败', e)
				}
			}
		}
	}
</script>

<style>
