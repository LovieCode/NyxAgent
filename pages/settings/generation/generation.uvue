<template>
	<view class="page-shell rice-theme-light">
		<NavBar variant="light" title="生成参数" showBack />
		<scroll-view class="container" :scroll-y="true">
			<view class="hero-card">
				<text class="hero-title">全局默认生成参数</text>
				<text class="hero-desc">这里是普通对话和记忆整理的默认生成参数。修改后自动保存，记忆整理参数独立保存，不会被某个联系人的聊天配置带偏。</text>
			</view>

			<view class="card">
				<view class="card-header">
					<oui-icon-unix name="experiment" size="14px" color="#6B7280" style="margin-right:6px" />
					<text class="card-title">普通聊天参数</text>
				</view>
				<text class="field-label">温度 temperature</text>
				<input
					class="flat-input"
					type="text"
					v-model="temperatureStr"
					placeholder="0 - 2，默认 1"
					placeholder-style="color: #D1D5DB; font-size: 13px;"
					@input="autoSaveSettings"
					@blur="normalizeAndSaveSettings"
				/>
				<text class="field-tip">越低越稳，越高越发散。默认 1 更通用，写代码可手动调低。</text>

				<text class="field-label" style="margin-top:12px;">输出上限 max_tokens</text>
				<input
					class="flat-input"
					type="text"
					v-model="maxTokensStr"
					placeholder="256 - 65536，默认 4096"
					placeholder-style="color: #D1D5DB; font-size: 13px;"
					@input="autoSaveSettings"
					@blur="normalizeAndSaveSettings"
				/>
				<text class="field-tip">限制单次回复长度，太低会被截断，太高会更吃额度。</text>

				<text class="field-label" style="margin-top:12px;">连续思考轮数</text>
				<input
					class="flat-input"
					type="text"
					v-model="maxIterationsStr"
					placeholder="0 - 100，默认 20"
					placeholder-style="color: #D1D5DB; font-size: 13px;"
					@input="autoSaveSettings"
					@blur="normalizeAndSaveSettings"
				/>
				<text class="field-tip">每次「思考 → 工具 → 继续」算一轮。填 0 表示不限制，遇到“达到最大迭代次数”就调这里。</text>
			</view>

			<view class="card">
				<view class="card-header">
					<oui-icon-unix name="robot" size="14px" color="#6B7280" style="margin-right:6px" />
					<text class="card-title">记忆整理</text>
				</view>
				<text class="field-label">温度 temperature</text>
				<input
					class="flat-input"
					type="text"
					v-model="memoryTemperatureStr"
					placeholder="0 - 2，默认 0.7"
					placeholder-style="color: #D1D5DB; font-size: 13px;"
					@input="autoSaveSettings"
					@blur="normalizeAndSaveSettings"
				/>
				<text class="field-tip">默认保持通用温度，避免部分模型温度过低时异常；需要更稳再手动调低。</text>

				<text class="field-label" style="margin-top:12px;">输出上限 max_tokens</text>
				<input
					class="flat-input"
					type="text"
					v-model="memoryMaxTokensStr"
					placeholder="256 - 2048，默认 2048"
					placeholder-style="color: #D1D5DB; font-size: 13px;"
					@input="autoSaveSettings"
					@blur="normalizeAndSaveSettings"
				/>
				<text class="field-tip">记忆整理只需要简短总结，最高限制为 2048。</text>

				<text class="field-label" style="margin-top:12px;">最大迭代次数</text>
				<input
					class="flat-input"
					type="text"
					v-model="memoryMaxIterationsStr"
					placeholder="1 - 100，默认 20"
					placeholder-style="color: #D1D5DB; font-size: 13px;"
					@input="autoSaveSettings"
					@blur="normalizeAndSaveSettings"
				/>
				<text class="field-tip">记忆整理会查历史、查记忆、写短缓存/长期记忆。默认 20，系统提示也会同步标注。</text>
				<text class="field-tip">记忆整理固定非流式运行，避免后台维护过程刷屏。</text>
			</view>

			<view class="card">
				<view class="setting-row">
					<view class="setting-text">
						<text class="setting-title">普通聊天流式显示</text>
						<text class="setting-desc">开启后边生成边显示；记忆整理固定非流式，不受这里影响。</text>
					</view>
					<rice-switch v-model="streamEnabled" @change="saveStreamSetting" />
				</view>
			</view>
		</scroll-view>
	</view>
</template>

<script lang="uts">
	import { getGlobalGenerationSettings, getMemoryOrganizerGenerationSettings, saveGenerationSettings, type GenerationSettings } from '@/utils/generation-settings.uts'

	export default {
		data() {
			return {
				temperatureStr: '' as string,
				maxTokensStr: '' as string,
				maxIterationsStr: '' as string,
				streamEnabled: true as boolean,
				memoryTemperatureStr: '' as string,
				memoryMaxTokensStr: '' as string,
				memoryMaxIterationsStr: '' as string,
			}
		},
		onLoad() {
			this.loadSettings()
		},
		methods: {
			clampNumber(value: number, min: number, max: number): number {
				if (value < min) return min
				if (value > max) return max
				return value
			},

			parseFloatSetting(value: string, fallback: number, min: number, max: number): number {
				const parsed = parseFloat(value)
				if (isNaN(parsed)) {
					return fallback
				}
				return this.clampNumber(parsed, min, max)
			},

			parseIntSetting(value: string, fallback: number, min: number, max: number): number {
				const parsed = parseInt(value)
				if (isNaN(parsed)) {
					return fallback
				}
				return this.clampNumber(parsed, min, max)
			},

			loadSettings() {
				const settings = getGlobalGenerationSettings()
				this.temperatureStr = settings.temperature + ''
				this.maxTokensStr = settings.maxTokens + ''
				this.maxIterationsStr = settings.maxIterations + ''
				this.streamEnabled = settings.streamEnabled
				const memorySettings = getMemoryOrganizerGenerationSettings()
				this.memoryTemperatureStr = memorySettings.temperature + ''
				this.memoryMaxTokensStr = memorySettings.maxTokens + ''
				this.memoryMaxIterationsStr = memorySettings.maxIterations + ''
			},

			buildCurrentSettings(): UTSJSONObject {
				const oldSettings = getGlobalGenerationSettings()
				const oldMemorySettings = getMemoryOrganizerGenerationSettings()
				const settings: GenerationSettings = {
					temperature: this.parseFloatSetting(this.temperatureStr, oldSettings.temperature, 0, 2),
					maxTokens: this.parseIntSetting(this.maxTokensStr, oldSettings.maxTokens, 256, 65536),
					maxIterations: this.parseIntSetting(this.maxIterationsStr, oldSettings.maxIterations, 0, 100),
					streamEnabled: this.streamEnabled,
				}
				const memorySettings: GenerationSettings = {
					temperature: this.parseFloatSetting(this.memoryTemperatureStr, oldMemorySettings.temperature, 0, 2),
					maxTokens: this.parseIntSetting(this.memoryMaxTokensStr, oldMemorySettings.maxTokens, 256, 2048),
					maxIterations: this.parseIntSetting(this.memoryMaxIterationsStr, oldMemorySettings.maxIterations, 1, 100),
					streamEnabled: false,
				}
				return {
					settings: settings,
					memorySettings: memorySettings,
				} as UTSJSONObject
			},

			autoSaveSettings(): boolean {
				const built = this.buildCurrentSettings()
				const settings = built['settings'] as GenerationSettings
				const memorySettings = built['memorySettings'] as GenerationSettings
				const saved = saveGenerationSettings(settings, memorySettings)
				if (saved == false) {
					uni.showToast({ title: '保存生成参数失败，请重试', icon: 'none' })
					return false
				}
				return true
			},

			normalizeAndSaveSettings() {
				const built = this.buildCurrentSettings()
				const settings = built['settings'] as GenerationSettings
				const memorySettings = built['memorySettings'] as GenerationSettings
				const saved = saveGenerationSettings(settings, memorySettings)
				if (saved == false) {
					uni.showToast({ title: '保存生成参数失败，请重试', icon: 'none' })
					return
				}
				this.temperatureStr = settings.temperature + ''
				this.maxTokensStr = settings.maxTokens + ''
				this.maxIterationsStr = settings.maxIterations + ''
				this.memoryTemperatureStr = memorySettings.temperature + ''
				this.memoryMaxTokensStr = memorySettings.maxTokens + ''
				this.memoryMaxIterationsStr = memorySettings.maxIterations + ''
			},

			saveStreamSetting() {
				const oldValue = !this.streamEnabled
				if (this.autoSaveSettings() == false) {
					this.streamEnabled = oldValue
				}
			},
		}
	}
</script>

