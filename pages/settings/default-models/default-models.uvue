<template>
	<view class="page-shell rice-theme-light">
		<NavBar variant="light" title="默认模型" showBack @back="goBack" />
		<scroll-view class="container" :scroll-y="true">

			<view class="card" v-for="(task, index) in taskList" :key="index">
				<view class="task-header">
					<text class="task-type-icon">{{taskIcon(task['type'] as string)}}</text>
					<text class="task-type-name">{{task['typeName']}}</text>
				</view>
				<text v-if="isMemoryTask(task)" class="task-desc">不设置时默认使用对话模型；设置后记忆整理会单独使用该模型。</text>
				<text v-if="isVisionTask(task)" class="task-desc">参考 AstrBot：图片会先用该模型转述为文字，再交给对话模型继续回答。</text>
				<text v-if="isSpeechTask(task)" class="task-desc">{{speechTaskDesc(task)}}</text>

				<!-- 选择提供商 -->
				<text class="field-label">提供商</text>
				<scroll-view class="chip-scroll" :scroll-x="true" :show-scrollbar="false">
					<view class="chip-row">
						<view
							v-if="isMemoryTask(task)"
							class="chip"
							:class="isFollowChatModel(task) ? 'chip-active' : ''"
							@click="selectFollowChat(index)"
						>
							<text
								class="chip-text"
								:class="isFollowChatModel(task) ? 'chip-text-active' : ''"
							>跟随对话模型</text>
						</view>
						<view
							v-if="isVisionTask(task)"
							class="chip"
							:class="isVisionDisabled(task) ? 'chip-active' : ''"
							@click="selectDisableVision(index)"
						>
							<text
								class="chip-text"
								:class="isVisionDisabled(task) ? 'chip-text-active' : ''"
							>不转述</text>
						</view>
						<view
							v-if="isSpeechTask(task)"
							class="chip"
							:class="isSpeechDisabled(task) ? 'chip-active' : ''"
							@click="selectDisableSpeech(index)"
						>
							<text
								class="chip-text"
								:class="isSpeechDisabled(task) ? 'chip-text-active' : ''"
							>不启用</text>
						</view>
						<view
							v-for="(p, pi) in enabledProviders"
							:key="pi"
							class="chip"
							:class="(task['providerId'] as string) == (p['id'] as string) ? 'chip-active' : ''"
							@click="selectProvider(index, p['id'] as string)"
						>
							<text
								class="chip-text"
								:class="(task['providerId'] as string) == (p['id'] as string) ? 'chip-text-active' : ''"
							>{{p['name']}}</text>
						</view>
					</view>
				</scroll-view>

				<!-- 选择模型 -->
				<text class="field-label" style="margin-top:8px;">模型</text>
				<scroll-view class="chip-scroll" :scroll-x="true" :show-scrollbar="false">
					<view class="chip-row">
						<view
							v-for="(m, mi) in getTaskModels(task)"
							:key="mi"
							class="chip"
							:class="(task['model'] as string) == m ? 'chip-active' : ''"
							@click="selectModel(index, m)"
						>
							<text
								class="chip-text"
								:class="(task['model'] as string) == m ? 'chip-text-active' : ''"
							>{{m}}</text>
						</view>
						<!-- 没有模型时提示 -->
						<text v-if="isFollowChatModel(task)" class="no-models-hint">当前跟随对话模型</text>
						<text v-if="isVisionDisabled(task)" class="no-models-hint">当前不转述图片</text>
						<text v-if="isSpeechDisabled(task)" class="no-models-hint">{{speechDisabledHint(task)}}</text>
						<text v-if="getTaskModels(task).length == 0 && isFollowChatModel(task) == false && isVisionDisabled(task) == false && isSpeechDisabled(task) == false" class="no-models-hint">该提供商未配置模型</text>
					</view>
				</scroll-view>

				<view v-if="isTtsTask(task)" class="tts-box">
					<view class="prompt-header-row">
						<text class="field-label">TTS 参数</text>
						<text class="prompt-save-text" @click="saveTtsSettings">保存 TTS 参数</text>
					</view>
					<text class="tts-hint">参考 AstrBot：不同 TTS 服务必须配置音色。OpenAI 兼容接口常用 voice/response_format/speed；火山引擎需要 appid、cluster、voice_type，并支持音量/音高。</text>

					<text class="field-label tts-field-label">接口类型</text>
					<view class="chip-row tts-adapter-row">
						<view class="chip" :class="ttsAdapter == 'openai_compatible' ? 'chip-active' : ''" @click="selectTtsAdapter('openai_compatible')">
							<text class="chip-text" :class="ttsAdapter == 'openai_compatible' ? 'chip-text-active' : ''">OpenAI 兼容</text>
						</view>
						<view class="chip" :class="ttsAdapter == 'volcengine' ? 'chip-active' : ''" @click="selectTtsAdapter('volcengine')">
							<text class="chip-text" :class="ttsAdapter == 'volcengine' ? 'chip-text-active' : ''">火山引擎</text>
						</view>
					</view>

					<text class="field-label tts-field-label">音色 / Voice</text>
					<input class="tts-input" type="text" v-model="ttsVoice" placeholder="OpenAI: alloy / 千问: Cherry / 火山: voice_type" placeholder-class="ph" />

					<view class="tts-two-col">
						<view class="tts-col-left">
							<text class="field-label tts-field-label">格式</text>
							<input class="tts-input" type="text" v-model="ttsResponseFormat" placeholder="wav / mp3 / opus / aac / flac" placeholder-class="ph" />
						</view>
						<view class="tts-col-right">
							<text class="field-label tts-field-label">语速</text>
							<input class="tts-input" type="text" v-model="ttsSpeed" placeholder="1.0" placeholder-class="ph" />
						</view>
					</view>

					<view class="tts-two-col">
						<view class="tts-col-left">
							<text class="field-label tts-field-label">音量</text>
							<input class="tts-input" type="text" v-model="ttsVolume" placeholder="1.0（火山等支持）" placeholder-class="ph" />
						</view>
						<view class="tts-col-right">
							<text class="field-label tts-field-label">音高</text>
							<input class="tts-input" type="text" v-model="ttsPitch" placeholder="1.0（火山等支持）" placeholder-class="ph" />
						</view>
					</view>

					<text class="field-label tts-field-label">高级参数 JSON</text>
					<textarea class="prompt-input tts-extra-input" v-model="ttsExtraParams" auto-height placeholder='{"appid":"...","volcengine_cluster":"volcano_tts"}' placeholder-class="ph" />

					<view class="tts-temp-row">
						<view class="tts-temp-info">
							<text class="tts-temp-title">临时目录</text>
							<text class="tts-temp-path">{{ttsTempDir != '' ? ttsTempDir : '不可用'}}</text>
						</view>
						<view class="tts-clear-btn" @click="clearTtsTempFiles">
							<text class="tts-clear-text">清理缓存</text>
						</view>
					</view>
				</view>

				<view v-if="isVisionTask(task)" class="prompt-box">
					<view class="prompt-header-row">
						<text class="field-label">图片转述提示词</text>
						<text class="prompt-save-text" @click="saveImageCaptionPrompt">保存提示词</text>
					</view>
					<textarea class="prompt-input" v-model="imageCaptionPrompt" auto-height @input="hasUnsavedPrompt = true" />
				</view>
			</view>

		</scroll-view>
	</view>
</template>

<script lang="uts">
	import { getAllProviders, setDefaultTaskModel, getAllDefaultTaskModels, getImageCaptionPrompt, setImageCaptionPrompt, getDefaultTTSSettings, setDefaultTTSSettings, TTS_ADAPTER_OPENAI_COMPAT } from '@/uni_modules/agent-core/utssdk/provider.uts'
	import { getSpeechTempDir, clearSpeechTempFiles } from '@/utils/speech-service.uts'
	import {
		defaultSpeechDisabledHint,
		defaultSpeechTaskDesc,
		defaultTaskIcon,
		filterEnabledDefaultModelProviders,
		getDefaultTaskModelIds,
		getFirstDefaultProviderModelId,
		isDefaultFollowChatModel,
		isDefaultMemoryTask,
		isDefaultSpeechDisabled,
		isDefaultSpeechTask,
		isDefaultTtsTask,
		isDefaultVisionDisabled,
		isDefaultVisionTask,
		readDefaultModelsTtsForm,
		readDefaultTaskModel,
		readDefaultTaskProviderId,
		readDefaultTaskType,
		validateTtsExtraParamsText,
	} from '@/utils/default-models-page-helpers.uts'

	export default {
		data() {
			return {
				allProviders: [] as UTSJSONObject[],
				taskList: [] as UTSJSONObject[],
				imageCaptionPrompt: '',
				ttsAdapter: TTS_ADAPTER_OPENAI_COMPAT as string,
				ttsVoice: '' as string,
				ttsResponseFormat: '' as string,
				ttsSpeed: '' as string,
				ttsVolume: '' as string,
				ttsPitch: '' as string,
				ttsExtraParams: '' as string,
				ttsTempDir: '' as string,
				savedImageCaptionPrompt: '' as string,
				hasUnsavedPrompt: false as boolean,
				isConfirmingLeave: false as boolean,
			}
		},
		onShow() {
			this.loadData()
		},
		onBackPress(): boolean {
			if (this.hasUnsavedPrompt == false) {
				return false
			}
			this.confirmLeave()
			return true
		},
		computed: {
			/** 只展示已启用提供商，避免默认任务指向未启用的 Provider。 */
			enabledProviders(): UTSJSONObject[] {
				return filterEnabledDefaultModelProviders(this.allProviders)
			}
		},
		methods: {
			loadData() {
				this.allProviders = getAllProviders()
				this.taskList = getAllDefaultTaskModels()
				this.imageCaptionPrompt = getImageCaptionPrompt()
				this.loadTtsSettings()
				this.savedImageCaptionPrompt = this.imageCaptionPrompt
				this.hasUnsavedPrompt = false
			},

			loadTtsSettings() {
				this.ttsTempDir = getSpeechTempDir()
				const form = readDefaultModelsTtsForm(getDefaultTTSSettings())
				this.ttsAdapter = form.adapter
				this.ttsVoice = form.voice
				this.ttsResponseFormat = form.responseFormat
				this.ttsSpeed = form.speed
				this.ttsVolume = form.volume
				this.ttsPitch = form.pitch
				this.ttsExtraParams = form.extraParams
			},

			taskIcon(type: string): string {
				return defaultTaskIcon(type)
			},

			isMemoryTask(task: UTSJSONObject): boolean {
				return isDefaultMemoryTask(task)
			},

			isFollowChatModel(task: UTSJSONObject): boolean {
				return isDefaultFollowChatModel(task)
			},

			isVisionTask(task: UTSJSONObject): boolean {
				return isDefaultVisionTask(task)
			},

			isVisionDisabled(task: UTSJSONObject): boolean {
				return isDefaultVisionDisabled(task)
			},

			isSpeechTask(task: UTSJSONObject): boolean {
				return isDefaultSpeechTask(task)
			},

			isTtsTask(task: UTSJSONObject): boolean {
				return isDefaultTtsTask(task)
			},

			isSpeechDisabled(task: UTSJSONObject): boolean {
				return isDefaultSpeechDisabled(task)
			},

			speechTaskDesc(task: UTSJSONObject): string {
				return defaultSpeechTaskDesc(task)
			},

			speechDisabledHint(task: UTSJSONObject): string {
				return defaultSpeechDisabledHint(task)
			},

			/** 获取某个任务当前选择的提供商下可用的模型 ID 列表 */
			getTaskModels(task: UTSJSONObject): string[] {
				return getDefaultTaskModelIds(task, this.allProviders)
			},

			/** 选择提供商后自动选第一个模型 */
			selectProvider(taskIndex: number, providerId: string) {
				const task = this.taskList[taskIndex]
				if (task == null) return
				task['providerId'] = providerId
				const firstModel = getFirstDefaultProviderModelId(providerId)
				if (firstModel != '') {
					task['model'] = firstModel
					this.saveTaskModel(taskIndex)
					return
				}
				task['model'] = ''
				uni.showToast({ title: '该提供商未配置模型', icon: 'none' })
			},

			selectFollowChat(taskIndex: number) {
				const task = this.taskList[taskIndex]
				if (task == null) return
				task['providerId'] = ''
				task['model'] = ''
				this.saveTaskModel(taskIndex)
			},

			selectDisableVision(taskIndex: number) {
				const task = this.taskList[taskIndex]
				if (task == null) return
				task['providerId'] = ''
				task['model'] = ''
				this.saveTaskModel(taskIndex)
			},

			selectDisableSpeech(taskIndex: number) {
				const task = this.taskList[taskIndex]
				if (task == null) return
				task['providerId'] = ''
				task['model'] = ''
				this.saveTaskModel(taskIndex)
			},

			selectModel(taskIndex: number, model: string) {
				const task = this.taskList[taskIndex]
				if (task == null) return
				task['model'] = model
				this.saveTaskModel(taskIndex)
			},

			selectTtsAdapter(adapter: string) {
				this.ttsAdapter = adapter
				this.saveTtsSettings()
			},

			validateTtsExtraParams(): boolean {
				const error = validateTtsExtraParamsText(this.ttsExtraParams)
				if (error != '') {
					uni.showToast({ title: error, icon: 'none' })
					return false
				}
				return true
			},

			saveTtsSettingsQuiet(): boolean {
				if (this.validateTtsExtraParams() == false) { return false }
				setDefaultTTSSettings(this.ttsAdapter, this.ttsVoice, this.ttsResponseFormat, this.ttsSpeed, this.ttsVolume, this.ttsPitch, this.ttsExtraParams)
				return true
			},

			saveTtsSettings() {
				if (this.saveTtsSettingsQuiet() == false) { return }
				uni.showToast({ title: '已保存 TTS 参数', icon: 'success' })
			},

			clearTtsTempFiles() {
				const ok = clearSpeechTempFiles()
				if (ok == true) {
					uni.showToast({ title: '已清理语音缓存', icon: 'success' })
					this.ttsTempDir = getSpeechTempDir()
					return
				}
				uni.showToast({ title: '清理语音缓存失败', icon: 'none' })
			},

			saveTaskModel(taskIndex: number) {
				const task = this.taskList[taskIndex]
				if (task == null) return
				const type = readDefaultTaskType(task)
				const providerId = readDefaultTaskProviderId(task)
				const model = readDefaultTaskModel(task)
				if (type == 'chat' && (providerId == '' || model == '')) {
					uni.showToast({ title: '对话模型不能为空', icon: 'none' })
					return
				}
				if (type == 'tts' && this.validateTtsExtraParams() == false) {
					return
				}
				if (providerId == '' || model == '') {
					setDefaultTaskModel(type, providerId, model)
					if (type == 'tts') {
						this.saveTtsSettingsQuiet()
					}
					uni.showToast({ title: '已停用默认任务模型', icon: 'none' })
					return
				}
				setDefaultTaskModel(type, providerId, model)
				if (type == 'tts') {
					this.saveTtsSettingsQuiet()
				}
				uni.showToast({ title: '已保存', icon: 'success' })
			},

			saveImageCaptionPrompt() {
				setImageCaptionPrompt(this.imageCaptionPrompt.trim())
				this.savedImageCaptionPrompt = this.imageCaptionPrompt.trim()
				this.imageCaptionPrompt = this.savedImageCaptionPrompt
				this.hasUnsavedPrompt = false
				uni.showToast({
					title: '已保存',
					icon: 'success'
				})
			},

			confirmLeave() {
				if (this.isConfirmingLeave == true) { return }
				this.isConfirmingLeave = true
				uni.showModal({
					title: '有未保存提示词',
					content: '图片转述提示词已修改，要保存后退出吗？',
					cancelText: '不保存',
					confirmText: '保存',
					success: (res) => {
						this.isConfirmingLeave = false
						if (res.confirm == true) {
							this.saveImageCaptionPrompt()
						} else {
							this.imageCaptionPrompt = this.savedImageCaptionPrompt
							this.hasUnsavedPrompt = false
						}
						uni.navigateBack()
					},
					fail: () => {
						this.isConfirmingLeave = false
					}
				})
			},

			goBack() {
				if (this.hasUnsavedPrompt == false) {
					uni.navigateBack()
					return
				}
				this.confirmLeave()
			},
		}
	}
</script>

<style>
	.container {
		flex: 1;
		padding: 16px;
	}

	/* 任务卡片 */
	.card {
		background-color: #FFFFFF;
		border-radius: 10px;
		padding: 16px;
		margin-bottom: 12px;
	}

	.task-header {
		flex-direction: row;
		align-items: center;
		margin-bottom: 10px;
	}

	.task-type-icon {
		font-size: 16px;
		margin-right: 6px;
	}

	.task-type-name {
		font-size: 16px;
		font-weight: bold;
		color: #111827;
	}

	.task-desc {
		font-size: 12px;
		color: #6B7280;
		line-height: 17px;
		margin-bottom: 9px;
	}

	.unimplemented-badge {
		font-size: 10px;
		color: #FFFFFF;
		background-color: #9CA3AF;
		border-radius: 4px;
		padding: 1px 6px;
		margin-left: 6px;
	}

	.unimplemented-notice {
		background-color: #F3F4F6;
		border-radius: 6px;
		padding: 10px;
		margin-bottom: 9px;
	}

	.unimplemented-notice-text {
		font-size: 13px;
		color: #9CA3AF;
		text-align: center;
	}

	/* 字段标签 */
	.field-label {
		font-size: 13px;
		color: #6B7280;
		margin-bottom: 6px;
	}

	/* 选项 chips */
	.chip-scroll {
		flex-direction: row;
	}

	.chip-row {
		flex-direction: row;
	}

	.chip {
		background-color: #F3F4F6;
		border-radius: 6px;
		padding: 7px 14px;
		margin: 2px;
		border-width: 1px;
		border-style: solid;
		border-color: #E5E7EB;
	}

	.chip-active {
		background-color: #FDE8EF;
		border-color: #FB8FAB;
	}

	.chip-text {
		font-size: 13px;
		color: #374151;
		white-space: nowrap;
	}

	.chip-text-active {
		color: #DB2777;
		font-weight: bold;
	}

	.no-models-hint {
		font-size: 12px;
		color: #9CA3AF;
		padding: 7px 0;
	}

	.prompt-box {
		margin-top: 9px;
	}

	.prompt-header-row {
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 6px;
	}

	.prompt-save-text {
		font-size: 12px;
		color: var(--rice-primary-color);
		font-weight: bold;
		padding-left: 10px;
	}

	.prompt-input {
		width: 100%;
		min-height: 60px;
		background-color: #F9FAFB;
		border-radius: 7px;
		padding: 9px;
		font-size: 13px;
		color: #374151;
		line-height: 19px;
	}


	.tts-box {
		margin-top: 10px;
		background-color: #FFF7FB;
		border-radius: 8px;
		padding: 10px;
	}

	.tts-hint {
		font-size: 12px;
		color: #6B7280;
		line-height: 17px;
		margin-bottom: 8px;
	}

	.tts-field-label {
		margin-top: 8px;
	}

	.tts-adapter-row {
		flex-direction: row;
		flex-wrap: wrap;
	}

	.tts-input {
		width: 100%;
		min-height: 38px;
		background-color: #FFFFFF;
		border-radius: 7px;
		padding: 8px;
		font-size: 13px;
		color: #374151;
	}

	.tts-two-col {
		flex-direction: row;
	}

	.tts-col-left {
		flex: 1;
		margin-right: 6px;
	}

	.tts-col-right {
		flex: 1;
	}

	.tts-extra-input {
		min-height: 68px;
		background-color: #FFFFFF;
	}

	.tts-temp-row {
		margin-top: 10px;
		padding: 9px;
		border-radius: 8px;
		background-color: #FFFFFF;
		flex-direction: row;
