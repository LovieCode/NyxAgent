<template>
	<view class="page-shell rice-theme-light">
		<NavBar variant="light" title="关于" showBack />
		<scroll-view class="container" :scroll-y="true">

			<!-- Logo 和 App 名称 -->
			<view class="about-hero">
				<view class="logo-circle">
					<text class="logo-text">N</text>
				</view>
				<text class="app-name">{{appName}}</text>
				<text class="app-version">版本 {{appVersion}}</text>
			</view>

			<!-- 应用说明卡片 -->
			<view class="info-card">
				<text class="info-title">应用简介</text>
				<text class="info-desc">
					NyxAI 是一款智能对话应用，基于先进大语言模型，支持私聊 / 群聊、插件扩展、图片理解等能力，为你提供高效、自然的聊天体验。
				</text>
			</view>

			<!-- 详细信息列表 -->
			<view class="details-card">
				<view class="detail-row">
					<text class="detail-label">应用名称</text>
					<text class="detail-value">{{appName}}</text>
				</view>
				<view class="detail-divider"></view>
				<view class="detail-row">
					<text class="detail-label">版本号</text>
					<text class="detail-value">{{appVersion}}</text>
				</view>
				<view class="detail-divider"></view>
				<view class="detail-row">
					<text class="detail-label">构建版本</text>
					<text class="detail-value">{{appVersionCode}}</text>
				</view>
				<view class="detail-divider"></view>
				<view class="detail-row">
					<text class="detail-label">开发者</text>
					<text class="detail-value link-value" @click="openGitHub">洛薇</text>
				</view>
			</view>

			<!-- 版权信息 -->
			<view class="footer">
				<text class="copyright">© 2026 OhMyOpenCode. All rights reserved.</text>
			</view>
		</scroll-view>
	</view>
</template>

<script lang="uts">
	/**
	 * 关于页面 - 显示应用版本和版权信息
	 */
	import { openSchema } from '@/uni_modules/uts-openSchema'

	export default {
		data() {
			return {
				appName: 'NyxAI 眠汐AI',
				appVersion: '',
				appVersionCode: '',
			}
		},
		onLoad() {
			try {
				const baseInfo = uni.getAppBaseInfo()
				if (baseInfo != null) {
					const rawAppName = baseInfo['appName'] as string | null
					if (rawAppName != null && rawAppName != '') { this.appName = rawAppName }
					const rawVersion = baseInfo['appVersion'] as string | null
					if (rawVersion != null) { this.appVersion = rawVersion }
					const rawVersionCode = baseInfo['appVersionCode'] as string | null
					if (rawVersionCode != null) { this.appVersionCode = rawVersionCode }
				}
			} catch (_e: any) {}
			if (this.appVersion == '') { this.appVersion = '1.1.0' }
			if (this.appVersionCode == '') { this.appVersionCode = '110' }
		},
		methods: {
			goBack() {
				uni.navigateBack()
			},
			openGitHub() {
				openSchema('https://github.com/LovieCode')
			}
		}
	}
</script>

