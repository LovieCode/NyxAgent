<template>
	<view class="page-shell rice-theme-light">
		<NavBar title="插件设置" showBack />
		<scroll-view class="container" :scroll-y="true">

			<!-- GitHub 代理开关 -->
			<view class="card">
				<view class="card-header">
					<oui-icon-unix name="appstore" size="28rpx" color="#6B7280" style="margin-right:12rpx" />
					<text class="card-title">GitHub 代理</text>
				</view>
				<view class="setting-row">
					<text class="setting-label">启用代理</text>
					<rice-switch v-model="ghProxyEnabled" @change="toggleGhProxy" />
				</view>
				<view v-if="ghProxyEnabled" class="input-wrap" style="margin-top: 20rpx;">
					<text class="input-label">代理域名</text>
					<input
						class="flat-input"
						v-model="ghProxyDomain"
						placeholder="https://ghproxy.example.com"
						placeholder-style="color: #D1D5DB; font-size: 28rpx;"
					/>
				</view>
			</view>

			<!-- 保存按钮 -->
			<view class="save-wrap">
				<view class="save-btn" @click="saveSettings">
					<text class="save-btn-text">保存设置</text>
				</view>
			</view>
		</scroll-view>
		<TabBar current="pages/settings/settings" />
	</view>
</template>

<script lang="uts">
	/**
	 * 插件设置子页面 - GitHub 代理配置
	 */

	export default {
		data() {
			return {
				ghProxyEnabled: false as boolean,
				ghProxyDomain: '' as string
			}
		},
		onLoad() {
			this.loadSettings()
		},
		methods: {
			loadSettings() {
				let proxyEnabled = uni.getStorageSync('settings_gh_proxy_enabled') as string
				this.ghProxyEnabled = (proxyEnabled != null && proxyEnabled == 'true')
				let proxyDomain = uni.getStorageSync('settings_gh_proxy_domain') as string
				this.ghProxyDomain = (proxyDomain != null) ? proxyDomain : ''
			},

			saveSettings() {
				uni.setStorageSync('settings_gh_proxy_enabled', this.ghProxyEnabled ? 'true' : 'false')
				uni.setStorageSync('settings_gh_proxy_domain', this.ghProxyDomain)
				uni.showToast({
					title: '已保存',
					icon: 'success'
				})
			},

			toggleGhProxy() {
				// rice-switch 的 v-model 已自动同步值
				// 此方法保留以备扩展
			}
		}
	}
</script>

