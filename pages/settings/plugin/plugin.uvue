<template>
	<view class="page-shell rice-theme-light">
		<NavBar variant="light" title="插件设置" showBack />
		<scroll-view class="container" :scroll-y="true">

			<!-- 网络搜索 -->
			<view class="card">
				<view class="card-header">
					<oui-icon-unix name="search" size="14px" color="#6B7280" style="margin-right:6px" />
					<text class="card-title">网络搜索</text>
				</view>
				<text class="plugin-desc">为聊天提供联网搜索能力。可选择免费 SearXNG 或调用 AI 提供商内置搜索（Grok / 豆包 等）。</text>
				<view class="setting-row" style="margin-top: 10px;">
					<text class="setting-label">启用网络搜索</text>
					<rice-switch v-model="webSearchEnabled" @change="toggleWebSearch" />
				</view>
				<view v-if="webSearchEnabled">
					<text class="input-label" style="margin-top: 10px;">搜索引擎</text>
					<view class="chip-row">
						<view class="chip" :class="webSearchProvider == 'searxng' ? 'chip-active' : ''" @click="selectProvider('searxng')">
							<text class="chip-text" :class="webSearchProvider == 'searxng' ? 'chip-text-active' : ''">SearXNG</text>
						</view>
						<view class="chip" :class="webSearchProvider == 'grok' ? 'chip-active' : ''" @click="selectProvider('grok')">
							<text class="chip-text" :class="webSearchProvider == 'grok' ? 'chip-text-active' : ''">AI 模型</text>
						</view>
					</view>
					<view v-if="webSearchProvider == 'searxng'" class="input-wrap" style="margin-top: 8px;">
						<text class="input-label">自定义实例地址（选填）</text>
						<input
							class="flat-input"
							v-model="webSearchInstance"
							placeholder="留空使用默认公共实例，或填入自建地址"
							placeholder-style="color: #D1D5DB; font-size: 13px;"
							@input="saveSettings"
							@blur="saveSettings"
						/>
						<text class="input-hint">自建实例可避免查询日志泄露：docker run -d -p 8080:8080 searxng/searxng</text>
					</view>
					<view v-if="webSearchProvider == 'grok'">
						<text class="input-label" style="margin-top: 8px;">选择提供商</text>
						<scroll-view class="chip-scroll" :scroll-x="true" :show-scrollbar="false">
							<view class="chip-row">
								<view v-for="(p, pi) in providers" :key="pi" class="chip" :class="webSearchProviderId == readProviderId(p) ? 'chip-active' : ''" @click="selectSearchProvider(p)">
									<text class="chip-text" :class="webSearchProviderId == readProviderId(p) ? 'chip-text-active' : ''">{{readProviderName(p)}}</text>
								</view>
							</view>
						</scroll-view>
						<text class="input-hint">使用已配置的 API 提供商。Grok 选 xAI，豆包选火山引擎，第三方兼容 API 选对应提供商。火山引擎自动走 Responses API 注册 web_search 工具。</text>
						<text class="input-label" style="margin-top: 6px;">选择模型</text>
						<scroll-view class="chip-scroll" :scroll-x="true" :show-scrollbar="false">
							<view class="chip-row">
								<view v-for="(m, mi) in searchProviderModels" :key="mi" class="chip" :class="webSearchModel == readModelId(m) ? 'chip-active' : ''" @click="selectSearchModel(m)">
									<text class="chip-text" :class="webSearchModel == readModelId(m) ? 'chip-text-active' : ''">{{readModelName(m)}}</text>
								</view>
							</view>
						</scroll-view>
						<text class="input-hint">留空默认使用该提供商配置的第一个模型。</text>
					</view>
				</view>
			</view>

			<!-- AstrBot 重型工具 -->
			<view class="card">
				<view class="card-header">
					<oui-icon-unix name="robot" size="14px" color="#6B7280" style="margin-right:6px" />
					<text class="card-title">AstrBot 重型工具</text>
				</view>
				<text class="plugin-desc">把 AstrBot 当成远程执行器：App 里的 Agent 可以把复杂任务交给 AstrBot，拿到结果后再验收并回复用户。</text>
				<view class="setting-row" style="margin-top: 10px;">
					<text class="setting-label">启用 AstrBot 工具</text>
					<rice-switch v-model="astrBotEnabled" @change="toggleAstrBot" />
				</view>
				<view v-if="astrBotEnabled">
					<view class="input-wrap" style="margin-top: 10px;">
						<text class="input-label">AstrBot 地址</text>
						<input
							class="flat-input"
							v-model="astrBotBaseUrl"
							placeholder="例如 http://192.168.1.8:6185"
							placeholder-style="color: #D1D5DB; font-size: 13px;"
							@input="saveSettings"
							@blur="saveSettings"
						/>
						<text class="input-hint">填 AstrBot Dashboard/API 地址，不要带 /api/v1。</text>
					</view>
					<view class="input-wrap" style="margin-top: 8px;">
						<text class="input-label">API Key</text>
						<input
							class="flat-input"
							type="password"
							v-model="astrBotApiKey"
							placeholder="需要 chat scope"
							placeholder-style="color: #D1D5DB; font-size: 13px;"
							@input="saveSettings"
							@blur="saveSettings"
						/>
						<text class="input-hint">建议只给 chat scope。config/plugin/mcp/provider 这类高权限以后走眠汐审核链。</text>
					</view>
					<view class="input-wrap" style="margin-top: 8px;">
						<text class="input-label">用户名</text>
						<input
							class="flat-input"
							v-model="astrBotUsername"
							placeholder="nyx-agent"
							placeholder-style="color: #D1D5DB; font-size: 13px;"
							@input="saveSettings"
							@blur="saveSettings"
						/>
						<text class="input-hint">固定身份会参与 AstrBot 命令权限判断，不会暴露给模型随便改。</text>
					</view>
					<view class="input-wrap" style="margin-top: 8px;">
						<text class="input-label">默认 Session ID（选填）</text>
						<input
							class="flat-input"
							v-model="astrBotSessionId"
							placeholder="留空则首次调用自动创建并保存"
							placeholder-style="color: #D1D5DB; font-size: 13px;"
							@input="saveSettings"
							@blur="saveSettings"
						/>
					</view>
					<view class="input-wrap" style="margin-top: 8px;">
						<text class="input-label">默认 Config ID（选填）</text>
						<input
							class="flat-input"
							v-model="astrBotConfigId"
							placeholder="指定 AstrBot 配置档；留空使用默认路由"
							placeholder-style="color: #D1D5DB; font-size: 13px;"
							@input="saveSettings"
							@blur="saveSettings"
						/>
					</view>
					<view class="test-btn" :class="astrBotTesting == true ? 'test-btn-disabled' : ''" @click="testAstrBot">
						<text class="test-btn-text">{{astrBotTesting == true ? '测试中...' : '测试连接'}}</text>
					</view>
				</view>
			</view>

			<!-- GitHub 代理开关 -->
			<view class="card">
				<view class="card-header">
					<oui-icon-unix name="appstore" size="14px" color="#6B7280" style="margin-right:6px" />
					<text class="card-title">GitHub 代理</text>
				</view>
				<view class="setting-row">
					<text class="setting-label">启用代理</text>
					<rice-switch v-model="ghProxyEnabled" @change="toggleGhProxy" />
				</view>
				<view v-if="ghProxyEnabled" class="input-wrap" style="margin-top: 10px;">
					<text class="input-label">代理域名</text>
						<input
							class="flat-input"
							v-model="ghProxyDomain"
							placeholder="https://ghproxy.example.com"
							placeholder-style="color: #D1D5DB; font-size: 14px;"
							@input="saveSettings"
							@blur="saveSettings"
						/>
				</view>
			</view>
		</scroll-view>
	</view>
</template>

<script lang="uts">
	/**
	 * 插件设置子页面 - GitHub 代理 / 网络搜索配置
	 */
	import { getAllProviders, getProviderModels } from '@/uni_modules/agent-core/utssdk/provider.uts'
	import { APP_ERROR_CATEGORY_NETWORK, formatAppErrorForUser, reportAppErrorFromCause } from '@/utils/app-error.uts'
	import { getAppSetting, setAppSettings } from '@/utils/database.uts'
	import { ASTRBOT_API_KEY_KEY, ASTRBOT_BASE_URL_KEY, ASTRBOT_CONFIG_ID_KEY, ASTRBOT_ENABLED_KEY, ASTRBOT_SESSION_ID_KEY, ASTRBOT_USERNAME_KEY, getAstrBotConfig, normalizeAstrBotBaseUrl, testAstrBotConnection } from '@/utils/astrbot-service.uts'

	export default {
		data() {
			return {
				ghProxyEnabled: false as boolean,
				ghProxyDomain: '' as string,
				webSearchEnabled: false as boolean,
				webSearchProvider: 'searxng' as string,
				webSearchProviderId: '' as string,
				webSearchModel: '' as string,
				webSearchInstance: '' as string,
				astrBotEnabled: false as boolean,
				astrBotBaseUrl: '' as string,
				astrBotApiKey: '' as string,
				astrBotUsername: 'nyx-agent' as string,
				astrBotSessionId: '' as string,
				astrBotConfigId: '' as string,
				astrBotTesting: false as boolean,
				providers: [] as UTSJSONObject[],
				searchProviderModels: [] as UTSJSONObject[],
				pageActive: false as boolean,
			}
		},
		onLoad() {
			this.pageActive = true
			this.loadSettings()
		},
		onUnload() {
			this.pageActive = false
		},
		methods: {
			loadSettings() {
				let proxyEnabled = getAppSetting('settings_gh_proxy_enabled')
				this.ghProxyEnabled = (proxyEnabled != null && proxyEnabled == 'true')
				let proxyDomain = getAppSetting('settings_gh_proxy_domain')
				this.ghProxyDomain = (proxyDomain != null) ? proxyDomain : ''
				let wsEnabled = getAppSetting('settings_web_search_enabled')
				this.webSearchEnabled = (wsEnabled != null && wsEnabled == 'true')
				let wsProvider = getAppSetting('settings_web_search_provider')
				this.webSearchProvider = (wsProvider != null && wsProvider != '') ? wsProvider : 'searxng'
				let wsProviderId = getAppSetting('settings_web_search_provider_id')
				this.webSearchProviderId = (wsProviderId != null) ? wsProviderId : ''
				let wsModel = getAppSetting('settings_web_search_model')
				this.webSearchModel = (wsModel != null) ? wsModel : ''
				let wsInstance = getAppSetting('settings_web_search_instance')
				this.webSearchInstance = (wsInstance != null) ? wsInstance : ''
				const astrBot = getAstrBotConfig()
				this.astrBotEnabled = astrBot.enabled
				this.astrBotBaseUrl = astrBot.baseUrl
				this.astrBotApiKey = astrBot.apiKey
				this.astrBotUsername = astrBot.username
				this.astrBotSessionId = astrBot.sessionId
				this.astrBotConfigId = astrBot.configId
				const allProviders = getAllProviders()
				this.providers = []
				let selectedProviderEnabled = false
				for (let i = 0; i < allProviders.length; i++) {
					const provider = allProviders[i]
					const enabled = provider['enabled'] as number | null
					if (enabled == 1) {
						this.providers.push(provider)
						const id = provider['id'] as string | null
						if (id != null && id == this.webSearchProviderId) {
							selectedProviderEnabled = true
						}
					}
				}
				if (this.webSearchProviderId != '' && selectedProviderEnabled == false) {
					this.webSearchProviderId = ''
					this.webSearchModel = ''
				}
				this.loadSearchProviderModels()
			},

			saveSettings(): boolean {
				const saved = setAppSettings(
					[
						'settings_gh_proxy_enabled', 'settings_gh_proxy_domain',
						'settings_web_search_enabled', 'settings_web_search_provider', 'settings_web_search_provider_id', 'settings_web_search_model', 'settings_web_search_instance',
						ASTRBOT_ENABLED_KEY, ASTRBOT_BASE_URL_KEY, ASTRBOT_API_KEY_KEY, ASTRBOT_USERNAME_KEY, ASTRBOT_SESSION_ID_KEY, ASTRBOT_CONFIG_ID_KEY,
					],
					[
						this.ghProxyEnabled ? 'true' : 'false', this.ghProxyDomain,
						this.webSearchEnabled ? 'true' : 'false', this.webSearchProvider, this.webSearchProviderId, this.webSearchModel, this.webSearchInstance,
						this.astrBotEnabled ? 'true' : 'false', normalizeAstrBotBaseUrl(this.astrBotBaseUrl), this.astrBotApiKey.trim(), this.astrBotUsername.trim() != '' ? this.astrBotUsername.trim() : 'nyx-agent', this.astrBotSessionId.trim(), this.astrBotConfigId.trim(),
					],
				)
				if (saved == false) {
					uni.showToast({ position: 'bottom', title: '保存插件设置失败，请重试', icon: 'none' })
					return false
				}
				return true
			},

			testAstrBot(): void {
				if (this.astrBotTesting == true) { return }
				if (this.saveSettings() == false) { return }
				this.astrBotTesting = true
				testAstrBotConnection().then((result) => {
					if (this.pageActive == false) { return }
					this.astrBotTesting = false
					if (result.ok == true) {
						uni.showToast({ position: 'bottom', title: 'AstrBot 连接成功', icon: 'success' })
						return
					}
					const error = reportAppErrorFromCause(
						'ASTRBOT_CONNECTION_TEST_FAILED',
						APP_ERROR_CATEGORY_NETWORK,
						'astrbot_connection_test',
						'AstrBot 连接测试失败',
						result.error,
						true,
					)
					uni.showToast({ position: 'bottom', title: formatAppErrorForUser(error), icon: 'none' })
				})
			},

			selectProvider(provider: string) {
				const oldProvider = this.webSearchProvider
				this.webSearchProvider = provider
				if (this.saveSettings() == false) {
					this.webSearchProvider = oldProvider
				}
			},

			selectSearchProvider(provider: UTSJSONObject) {
				const oldProviderId = this.webSearchProviderId
				const oldModel = this.webSearchModel
				const id = provider['id'] as string | null
				this.webSearchProviderId = (id != null) ? id : ''
				this.webSearchModel = ''
				this.loadSearchProviderModels()
				if (this.saveSettings() == false) {
					this.webSearchProviderId = oldProviderId
					this.webSearchModel = oldModel
					this.loadSearchProviderModels()
				}
			},

			selectSearchModel(model: UTSJSONObject) {
				const oldModel = this.webSearchModel
				const id = model['id'] as string | null
				this.webSearchModel = (id != null) ? id : ''
				if (this.saveSettings() == false) {
					this.webSearchModel = oldModel
				}
			},

			loadSearchProviderModels() {
				if (this.webSearchProviderId == '') {
					this.searchProviderModels = []
					return
				}
				const models = getProviderModels(this.webSearchProviderId)
				const list: UTSJSONObject[] = []
				for (let i = 0; i < models.length; i++) {
					list.push({
						id: models[i].id,
						name: models[i].name != null && models[i].name != '' ? models[i].name : models[i].id,
					} as UTSJSONObject)
				}
				this.searchProviderModels = list
			},

			readProviderId(provider: UTSJSONObject): string {
				const value = provider['id'] as string | null
				return value != null ? value : ''
			},

			readProviderName(provider: UTSJSONObject): string {
				const value = provider['name'] as string | null
				return value != null ? value : this.readProviderId(provider)
			},

			readModelId(model: UTSJSONObject): string {
				const value = model['id'] as string | null
				return value != null ? value : ''
			},

			readModelName(model: UTSJSONObject): string {
				const value = model['name'] as string | null
				return value != null ? value : this.readModelId(model)
			},

			toggleGhProxy() {
				// rice-switch 的 v-model 已自动同步值
				if (this.saveSettings() == false) {
					this.ghProxyEnabled = !this.ghProxyEnabled
				}
			},

			toggleWebSearch() {
				if (this.saveSettings() == false) {
					this.webSearchEnabled = !this.webSearchEnabled
				}
			},

			toggleAstrBot() {
				if (this.saveSettings() == false) {
					this.astrBotEnabled = !this.astrBotEnabled
				}
			}
		}
	}
</script>

<style>
	.container {
		flex: 1;
		padding: 16px;
	}


	/* 通用卡片容器 */
	.card {
		background-color: #FFFFFF;
		border-radius: 10px;
		padding: 16px;
		margin-bottom: 12px;
	}

	.card-header {
		flex-direction: row;
		align-items: center;
		margin-bottom: 10px;
	}

	.card-icon {
		font-size: 14px;
		margin-right: 6px;
	}

	.card-title {
		font-size: 15px;
		font-weight: bold;
		color: #111827;
	}

	/* 设置行（用于开关行） */
	.setting-row {
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		padding: 6px 0;
	}

	.setting-label {
		font-size: 14px;
		color: #374151;
	}

	.plugin-desc {
		font-size: 12px;
		color: #6B7280;
		line-height: 18px;
	}

	.input-hint {
		font-size: 11px;
		color: #9CA3AF;
		line-height: 16px;
		margin-top: 5px;
	}

	.chip-row {
		flex-direction: row;
		margin-top: 4px;
	}

	.chip {
		padding: 6px 11px;
		border-radius: 500px;
		background-color: #F3F4F6;
		margin-right: 7px;
	}

	.chip-active {
		background-color: #FFF0F5;
		border-color: rgba(251, 143, 171, 0.56);
	}

	.chip-text {
		font-size: 12px;
		color: #4B5563;
	}

	.chip-text-active {
		color: #DB6F92;
		font-weight: bold;
	}

	.chip-scroll {
		flex-direction: row;
	}

	/* 输入框标签 */
	.input-label {
		font-size: 13px;
		color: #6B7280;
		margin-bottom: 6px;
	}

	/* 扁平输入框 */
	.input-wrap {
		margin-top: 4px;
	}

	.flat-input {
		background-color: #F9FAFB;
		border-radius: 7px;
		padding: 12px;
		font-size: 14px;
		color: #111827;
	}

	.test-btn {
		margin-top: 12px;
		background-color: #111827;
		border-radius: 8px;
		padding: 12px 0;
		align-items: center;
		justify-content: center;
	}

	.test-btn-disabled {
		opacity: 0.6;
	}

	.test-btn-text {
		font-size: 14px;
		font-weight: bold;
		color: #FFFFFF;
	}

	/* 保存按钮容器 */
	.save-wrap {
		padding: 10px 0 30px 0;
	}

	.save-btn {
		background-color: #111827;
		border-radius: 8px;
		padding: 14px 0;
		align-items: center;
		justify-content: center;
	}

	.save-btn-text {
		font-size: 15px;
		font-weight: bold;
		color: #FFFFFF;
	}


/* ===== Nyx 子页面视觉重制 ===== */
	.page-shell { background-color: #FAF7F5; }
	.container, .settings-scroll, .session-scroll, .history-page { background-color: #FAF7F5; }
	.container, .settings-scroll, .session-scroll { padding-left: 24px; padding-right: 24px; padding-top: 14px; padding-bottom: 28px; }
	.card, .form-card, .info-card, .details-card, .guide-card, .model-card, .hint-card, .hero-card, .danger-card, .empty-card, .prompt-box, .unimplemented-notice, .fullscreen-edit-card, .import-panel, .last-call-panel, .summary-card, .response-card, .preview-box { background-color: #FFFFFF; border-radius: 20px; border-width: 1px; border-style: solid; border-color: rgba(241, 229, 234, 0.92); box-shadow: 0 8px 20px rgba(216, 140, 165, 0.045); margin-left: 0; margin-right: 0; margin-top: 0; margin-bottom: 12px; padding: 16px; }
	.hero-card, .hint-card, .guide-card, .unimplemented-notice { background-color: #FFF7FA; border-color: rgba(251, 143, 171, 0.20); }
	.card-title, .hero-title, .hint-title, .guide-title, .info-title, .setting-title, .card-label, .provider-name, .model-card-title, .task-type-name, .skill-name, .action-title, .app-name, .form-label { color: #2A2529; }
	.card-desc, .hero-desc, .hint-text, .guide-desc, .info-desc, .setting-desc, .plugin-desc, .action-desc, .field-tip, .input-hint, .desc, .detail-value, .app-version { color: #8A7B84; }
	.text-input, .prompt-input, .flat-input, .field-input, .detail-field-input, .detail-params-input, .tts-input, .tts-extra-input, .small-textarea, .search-input, .textarea, .form-input, .form-textarea, .param-input, .short-input { background-color: #F8F2F4; border-radius: 15px; border-width: 1px; border-style: solid; border-color: #F0E5EA; color: #2A2529; }
	.member-row, .setting-row, .action-row, .provider-detail, .detail-row, .form-item, .model-row, .param-row, .tool-row, .log-item, .summary-row, .response-section, .usage-note-row { border-color: #F4EAEE; }
	.member-avatar, .session-icon, .logo-circle, .avatar-circle, .agent-avatar-placeholder, .card-icon, .task-type-icon, .tool-card-check, .skill-card-check { background-color: #FFF0F5; }
	.chip, .model-pill, .provider-chip, .doc-tab, .filter-chip, .tts-box, .summary-param-pill, .log-badge { border-radius: 500px; background-color: #FFFFFF; border-width: 1px; border-style: solid; border-color: #F1E5EA; }
	.chip-active, .pill-active, .doc-tab-active, .model-card-active, .skill-item-active, .skill-card-active, .tool-card-active, .session-item-active, .card-selected { background-color: #FFF0F5; border-color: rgba(251, 143, 171, 0.56); }
	.chip-text-active, .pill-text-active, .doc-tab-text-active, .filter-chip-text-active { color: #DB6F92; font-weight: bold; }
