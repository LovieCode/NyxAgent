<template>
	<view class="page-shell rice-theme-light">
		<NavBar title="设置" />
		<scroll-view class="container" :scroll-y="true">
			<!-- 设置菜单列表 -->
			<view class="settings-menu">
				<view class="menu-item" @click="goSubPage('profile')">
					<view class="menu-item-left">
						<oui-icon-unix name="user" size="28rpx" color="#6B7280" style="margin-right:20rpx" />
						<view class="menu-text">
							<text class="menu-title">用户资料</text>
							<text class="menu-desc">昵称、头像、个人简介</text>
						</view>
					</view>
					<text class="menu-arrow">›</text>
				</view>
				<view class="menu-divider"></view>
				<view class="menu-item" @click="goSubPage('basic')">
					<view class="menu-item-left">
						<oui-icon-unix name="setting" size="28rpx" color="#6B7280" style="margin-right:20rpx" />
						<view class="menu-text">
							<text class="menu-title">提供商管理</text>
							<text class="menu-desc">管理多个 LLM 提供商、API 密钥</text>
						</view>
					</view>
					<text class="menu-arrow">›</text>
				</view>
				<view class="menu-divider"></view>
				<view class="menu-item" @click="goSubPage('default-models')">
					<view class="menu-item-left">
						<oui-icon-unix name="robot" size="28rpx" color="#6B7280" style="margin-right:20rpx" />
						<view class="menu-text">
							<text class="menu-title">默认模型</text>
							<text class="menu-desc">对话、识图、语音识别、语音合成模型分配</text>
						</view>
					</view>
					<text class="menu-arrow">›</text>
				</view>
				<view class="menu-divider"></view>
				<view class="menu-item" @click="goSubPage('plugin')">
					<view class="menu-item-left">
						<oui-icon-unix name="appstore" size="28rpx" color="#6B7280" style="margin-right:20rpx" />
						<view class="menu-text">
							<text class="menu-title">插件设置</text>
							<text class="menu-desc">GitHub 代理、下载配置</text>
						</view>
					</view>
					<text class="menu-arrow">›</text>
				</view>
				<view class="menu-divider"></view>
				<view class="menu-item" @click="confirmExportAllData">
					<view class="menu-item-left">
						<oui-icon-unix name="download" size="28rpx" color="#6B7280" style="margin-right:20rpx" />
						<view class="menu-text">
							<text class="menu-title">导出全部数据</text>
							<text class="menu-desc">ZIP 备份包：配置、对话、头像、Agent 工作区</text>
						</view>
					</view>
					<text class="menu-arrow">›</text>
				</view>
				<view class="menu-divider"></view>
				<view class="menu-item" @click="confirmImportAllData">
					<view class="menu-item-left">
						<oui-icon-unix name="upload" size="28rpx" color="#6B7280" style="margin-right:20rpx" />
						<view class="menu-text">
							<text class="menu-title">导入备份包</text>
							<text class="menu-desc">从 ZIP 恢复配置、对话与 Agent 工作区</text>
						</view>
					</view>
					<text class="menu-arrow">›</text>
				</view>
				<view class="menu-divider"></view>
				<view class="menu-item" @click="goSubPage('about')">
					<view class="menu-item-left">
						<oui-icon-unix name="infomation" size="28rpx" color="#6B7280" style="margin-right:20rpx" />
						<view class="menu-text">
							<text class="menu-title">关于</text>
							<text class="menu-desc">版本信息</text>
						</view>
					</view>
					<text class="menu-arrow">›</text>
				</view>
			</view>
		</scroll-view>
		<TabBar current="pages/settings/settings" />
	</view>
</template>

<script lang="uts">
	/**
	 * 设置页面 - 扁平化粉白渐变设计
	 * 参考 PI Agent models.generated.ts 模型列表
	 */

	import { exportAllDataToFile, exportAllDataToJson, shareExportedDataFile, getLastShareExportErrorMessage } from '@/utils/data-export.uts'
	import { importAllDataFromZip } from '@/utils/data-import.uts'

	export default {
		data() {
			return {
				selectedProviderId: 'deepseek' as string,
				apiKey: '' as string,
				baseUrl: '' as string,
				selectedModel: 'deepseek-v4-flash' as string,
				ghProxyEnabled: false as boolean,
				ghProxyDomain: '' as string,
				showApiKey: false as boolean,
				expandBasic: true as boolean,
				expandModel: true as boolean,
				expandPlugin: true as boolean,
				expandAbout: true as boolean
			}
		},
		computed: {
			pIds() : string[] {
				return [
					'anthropic', 'openai', 'deepseek', 'zai',
					'kimi-coding', 'minimax-cn', 'xiaomi', 'ant-ling', 'custom'
				]
			},
			pNames() : string[] {
				return [
					'Anthropic', 'OpenAI', 'DeepSeek', 'ZAI',
					'Kimi', 'MiniMax', 'MiMo', 'AntLing', 'Custom'
				]
			},
			pUrls() : string[] {
				return [
					'https://api.anthropic.com',
					'https://api.openai.com/v1',
					'https://api.deepseek.com',
					'https://api.z.ai/api/coding/paas/v4',
					'https://api.kimi.com/coding',
					'https://api.minimaxi.com/anthropic',
					'https://api.xiaomimimo.com/v1',
					'https://api.ant-ling.com/v1',
					''
				]
			},
			pHints() : string[] {
				return [
					'sk-ant-...', 'sk-...', 'sk-...', 'ZAI Coding Plan Key',
					'KIMI_API_KEY', 'MINIMAX_CN_API_KEY', 'XIAOMI_API_KEY', 'ANT_LING_API_KEY', 'Enter API Key'
				]
			},
			pModels() : string[][] {
				return [
					['claude-sonnet-4-20250514', 'claude-3-5-sonnet-20241022', 'claude-3-5-haiku-20241022'],
					['gpt-4o', 'gpt-4o-mini', 'gpt-4.1', 'gpt-4.1-mini', 'gpt-4.1-nano'],
					['deepseek-v4-flash', 'deepseek-v4-pro'],
					['glm-5.2', 'glm-5.1', 'glm-5-turbo', 'glm-4.7', 'glm-4.5-air'],
					['k2p7', 'kimi-for-coding', 'kimi-k2-thinking'],
					['MiniMax-M3', 'MiniMax-M2.7', 'MiniMax-M2.7-highspeed'],
					['mimo-v2.5-pro-ultraspeed', 'mimo-v2.5-pro', 'mimo-v2-pro', 'mimo-v2-omni', 'mimo-v2-flash'],
					['Ring-2.6-1T', 'Ling-2.6-1T', 'Ling-2.6-flash'],
					['custom-model']
				]
			},
			currentModels() : string[] {
				const idx = this.findProviderIndex(this.selectedProviderId)
				if (idx >= 0) {
					return this.pModels[idx]
				}
				return ['custom-model']
			},
			keyPlaceholder() : string {
				const idx = this.findProviderIndex(this.selectedProviderId)
				if (idx >= 0) {
					return this.pHints[idx]
				}
				return 'Enter API Key'
			}
		},
		onLoad() {
			this.loadSettings()
		},
		methods: {
			findProviderIndex(id : string) : number {
				for (let i = 0; i < this.pIds.length; i++) {
					if (this.pIds[i] == id) {
						return i
					}
				}
				return -1
			},

			loadSettings() {
				let providerId = uni.getStorageSync('settings_provider_id') as string
				this.selectedProviderId = (providerId != null && providerId != '') ? providerId : 'deepseek'
				let key = uni.getStorageSync('settings_api_key') as string
				this.apiKey = (key != null) ? key : ''
				let url = uni.getStorageSync('settings_base_url') as string
				this.baseUrl = (url != null) ? url : ''
				let model = uni.getStorageSync('settings_model') as string
				this.selectedModel = (model != null && model != '') ? model : 'deepseek-v4-flash'
				let proxyEnabled = uni.getStorageSync('settings_gh_proxy_enabled') as string
				this.ghProxyEnabled = (proxyEnabled != null && proxyEnabled == 'true')
				let proxyDomain = uni.getStorageSync('settings_gh_proxy_domain') as string
				this.ghProxyDomain = (proxyDomain != null) ? proxyDomain : ''
			},

			saveSettings() {
				uni.setStorageSync('settings_provider_id', this.selectedProviderId)
				uni.setStorageSync('settings_api_key', this.apiKey)
				uni.setStorageSync('settings_base_url', this.baseUrl)
				uni.setStorageSync('settings_model', this.selectedModel)
				uni.setStorageSync('settings_gh_proxy_enabled', this.ghProxyEnabled ? 'true' : 'false')
				uni.setStorageSync('settings_gh_proxy_domain', this.ghProxyDomain)
				uni.showToast({
					title: '已保存',
					icon: 'success'
				})
			},

			selectProvider(id : string) {
				this.selectedProviderId = id
				const idx = this.findProviderIndex(id)
				if (idx >= 0) {
					this.baseUrl = ''
					const models = this.pModels[idx]
					if (models != null && models.length > 0) {
						this.selectedModel = models[0]
					}
				}
			},

			selectModel(model : string) {
				this.selectedModel = model
			},

			toggleGhProxy() {
				this.ghProxyEnabled = !this.ghProxyEnabled
			},

			toggleShowApiKey() {
				this.showApiKey = !this.showApiKey
			},

			goSubPage(name : string) {
				uni.navigateTo({
					url: '/pages/settings/' + name + '/' + name
				})
			},

			confirmExportAllData() {
				uni.showModal({
					title: '导出并分享全部数据',
					content: '导出 ZIP 包包含 API Key、对话历史、头像、Agent 工作区和个人资料。导出完成后会打开系统分享面板，请只分享给可信目标。确定继续？',
					success: (res) => {
						if (res.confirm == true) {
							this.exportAllData()
						}
					}
				})
			},


			confirmImportAllData() {
				uni.showModal({
					title: '导入备份包',
					content: '导入会覆盖当前提供商、对话、智能体、设置、笔记、待办和 Agent 工作区。建议先导出当前数据。继续？',
					success: (res) => {
						if (res.confirm == true) {
							this.chooseImportZip()
						}
					}
				})
			},

			chooseImportZip() {
				uni.chooseFile({
					count: 1,
					success: (res: any) => {
						const path = this.parseChosenFilePath(res)
						if (path == '') {
							uni.showToast({ title: '未选择文件', icon: 'none' })
							return
						}
						this.importAllData(path)
					},
					fail: () => {
						uni.showToast({ title: '选择文件失败', icon: 'none' })
					}
				})
			},

			parseChosenFilePath(res: any): string {
				try {
					const raw = JSON.stringify(res)
					const parsed = JSON.parse(raw) as UTSJSONObject
					const tempFilePaths = parsed['tempFilePaths'] as string[] | null
					if (tempFilePaths != null && tempFilePaths.length > 0) {
						return tempFilePaths[0]
					}
					const tempFiles = parsed['tempFiles'] as UTSJSONObject[] | null
					if (tempFiles != null && tempFiles.length > 0) {
						const first = tempFiles[0]
						const path = first['path'] as string | null
						if (path != null) {
							return path
						}
					}
				} catch (_e: any) {
				}
				return ''
			},

			importAllData(path: string) {
				const summary = importAllDataFromZip(path)
				if (summary == '') {
					uni.showToast({ title: '导入失败', icon: 'none' })
					return
				}
				uni.showModal({
					title: '导入完成',
					content: summary,
					showCancel: false,
					success: () => {
						this.loadSettings()
					}
				})
			},

			exportAllData() {
				try {
					const path = exportAllDataToFile()
					if (path != '') {
						const shared = shareExportedDataFile(path)
						if (shared == true) {
							return
						}
						const shareError = getLastShareExportErrorMessage()
						const shareFailTip = shareError != '' ? ('系统分享失败：' + shareError + '\nZIP 路径已复制：\n' + path) : ('系统分享面板没有打开，ZIP 路径已复制：\n' + path)
						uni.setClipboardData({
							data: path,
							success: () => {
								uni.showModal({
									title: '分享失败',
									content: shareFailTip,
									showCancel: false
								})
							},
							fail: () => {
								uni.showModal({
									title: '分享失败',
									content: shareError != '' ? ('系统分享失败：' + shareError + '\nZIP 已导出：\n' + path) : ('系统分享面板没有打开，ZIP 已导出：\n' + path),
									showCancel: false
								})
							}
						})
						return
					}
					const json = exportAllDataToJson()
					uni.setClipboardData({
						data: json,
						success: () => {
							uni.showToast({
								title: '已复制导出清单',
								icon: 'success'
							})
						},
						fail: () => {
							uni.showToast({
								title: '导出失败',
								icon: 'none'
							})
						}
					})
				} catch (_e: any) {
					uni.showToast({
						title: '导出失败',
						icon: 'none'
					})
				}
			}
		}
	}
</script>

<style>
