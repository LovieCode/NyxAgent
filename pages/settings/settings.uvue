		font-size: 24px;
	}

	/* 扁平输入框 */
	.input-wrap {
		margin-top: 8rpx;
	}

	.flat-input {
		background-color: #F9FAFB;
		border-radius: 14rpx;
		padding: 24rpx;
		font-size: 28rpx;
		color: #111827;
	}

	/* 设置行（用于开关行） */
	.setting-row {
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		padding: 12rpx 0;
	}

	.setting-label {
		font-size: 28rpx;
		color: #374151;
	}

	.setting-value {
		font-size: 26rpx;
		color: #9CA3AF;
	}

	/* 设置菜单 */
	.settings-menu {
		background-color: #FFFFFF;
		border-radius: 20rpx;
		overflow: hidden;
	}

	.menu-item {
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		padding: 28rpx 32rpx;
	}

	.menu-item-left {
		flex-direction: row;
		align-items: center;
		flex: 1;
	}

	.menu-text {
		flex: 1;
	}

	.menu-title {
		font-size: 28rpx;
		font-weight: bold;
		color: #111827;
	}

	.menu-desc {
		font-size: 22rpx;
		color: #9CA3AF;
		margin-top: 4rpx;
	}

	.menu-arrow {
		font-size: 32rpx;
		color: #D1D5DB;
		padding-left: 16rpx;
	}

	.menu-divider {
		height: 0.5px;
		background-color: #F3F4F6;
		margin-left: 84rpx;
	}

	/* 提供商网格 */
	.provider-grid {
		flex-direction: row;
		flex-wrap: wrap;
	}

	.provider-chip {
		background-color: #F3F4F6;
		border-radius: 12rpx;
		padding: 14rpx 28rpx;
		margin: 8rpx;
		border-width: 1px;
		border-style: solid;
		border-color: #E5E7EB;
	}

	.chip-active {
		background-color: #FDE8EF;
		border-color: #FB8FAB;
	}

	.chip-label {
		font-size: 26rpx;
		color: #374151;
	}

	/* 模型 pills */
	.model-scroll {
		flex-direction: row;
		flex-wrap: wrap;
	}

	.model-pill {
		background-color: #F3F4F6;
		border-radius: 10rpx;
		padding: 14rpx 22rpx;
		margin: 6rpx;
	}

	.pill-active {
		background-color: #FDE8EF;
	}

	.pill-text {
		font-size: 24rpx;
		color: #6B7280;
	}

	.pill-text-active {
		color: #DB2777;
		font-weight: bold;
	}

	/* 保存按钮容器 */
	.save-wrap {
		padding: 20rpx 0 60rpx 0;
	}

	/* rice-cell-group 间距 */
	.rice-cell-group + .rice-cell-group {
		margin-top: 24rpx;
	}
</style>
