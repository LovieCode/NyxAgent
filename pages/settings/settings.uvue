		flex-direction: row;
		align-items: center;
		margin-bottom: 20rpx;
	}

	.card-icon {
		font-size: 28rpx;
		margin-right: 12rpx;
	}

	.card-title {
		font-size: 30rpx;
		font-weight: bold;
		color: #111827;
	}

	/* 输入行（带切换按钮） */
	.input-row {
		flex-direction: row;
		align-items: center;
	}

	.input-row-input {
		flex: 1;
	}

	.toggle-vis-btn {
		width: 44px;
		height: 44px;
		justify-content: center;
		align-items: center;
		margin-left: 8rpx;
	}

