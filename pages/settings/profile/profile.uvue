<template>
	<view class="page-shell rice-theme-light">
		<NavBar variant="light" title="用户资料" showBack @back="goBack" />
		<scroll-view class="container" :scroll-y="true">

			<!-- 头像区域 -->
			<view class="avatar-section" @click="pickAvatar">
				<image v-if="avatarPath != ''" :src="avatarPath" class="avatar-image" mode="aspectFill" />
				<view v-else class="avatar-circle">
					<text class="avatar-text">{{avatarText}}</text>
				</view>
				<text class="avatar-hint">点击更换头像</text>
			</view>

			<!-- 资料表单卡片 -->
			<view class="form-card">
				<view class="form-item">
					<text class="form-label">昵称</text>
					<input class="form-input" v-model="nickname" placeholder="输入昵称" placeholder-style="color:#9CA3AF" @input="hasUnsaved = true" />
				</view>
				<view class="form-divider"></view>
				<view class="form-item">
					<text class="form-label">简介</text>
					<input class="form-input" v-model="bio" placeholder="一句话介绍自己" placeholder-style="color:#9CA3AF" @input="hasUnsaved = true" />
				</view>
				<view class="form-divider"></view>
				<view class="form-item">
					<text class="form-label">邮箱</text>
					<input class="form-input" v-model="email" placeholder="邮箱地址" placeholder-style="color:#9CA3AF" inputmode="email" @input="hasUnsaved = true" />
				</view>
				<view class="form-divider"></view>
				<view class="form-item form-item-textarea">
					<text class="form-label">个人简介</text>
					<view class="textarea-wrap">
						<textarea class="form-textarea" v-model="description" placeholder="详细介绍一下自己…" placeholder-style="color:#9CA3AF" @input="hasUnsaved = true" />
						<view class="fullscreen-btn" @click="openFullEditor">
							<text class="fullscreen-btn-text">全屏编辑</text>
						</view>
					</view>
				</view>
			</view>

			<!-- 保存按钮 -->
			<view class="save-btn-wrap">
				<view class="save-btn" @click="saveProfile">
					<text class="save-btn-text">保存</text>
				</view>
			</view>
		</scroll-view>
	</view>
</template>

<script lang="uts">
	import { getAppSetting, setAppSettings } from '@/utils/database.uts'
	import { chooseAvatarImage, consumeAvatarCropResult, discardManagedAvatarFile, openAvatarCrop } from '@/utils/avatar-image-picker.uts'
	import { APP_ERROR_CATEGORY_RUNTIME, formatAppErrorForUser, reportAppErrorFromCause } from '@/utils/app-error.uts'
	import { clearEditorRuntimeStateFor, consumeTextEditorResult, prepareTextEditorRuntimeState } from '@/utils/editor-runtime-state.uts'

	const PROFILE_EDITOR_OWNER = 'profile'
	const PROFILE_DESCRIPTION_EDITOR_TARGET = 'profile-description'

	function showProfileFailure(code: string, operation: string, userMessage: string, cause: any | null): void {
		const error = reportAppErrorFromCause(
			code,
			APP_ERROR_CATEGORY_RUNTIME,
			operation,
			userMessage,
			cause,
			true,
		)
		uni.showToast({ position: 'bottom', title: formatAppErrorForUser(error), icon: 'none' })
	}

	function clearProfileEditorRuntimeState(): boolean {
		return clearEditorRuntimeStateFor(PROFILE_EDITOR_OWNER, PROFILE_DESCRIPTION_EDITOR_TARGET)
	}

	function navigateProfileBack(): void {
		uni.navigateBack({
			fail: (err: any) => {
				showProfileFailure('PROFILE_BACK_FAILED', 'profile_navigate_back', '无法返回上一页', err)
			}
		})
	}

	/**
	 * 用户资料页面 - 扁平化粉白主题
	 * 支持头像选择（拍照/相册）、资料编辑
	 */
	export default {
		data() {
			return {
				nickname: '' as string,
				bio: '' as string,
				email: '' as string,
				description: '' as string,
				/** 头像路径（空字符串表示使用默认文字头像） */
				avatarPath: '' as string,
				savedAvatarPath: '' as string,
				hasUnsaved: false as boolean,
				isConfirmingLeave: false as boolean,
			}
		},
		computed: {
			/** 头像占位文字：取昵称首字符或默认 */
			avatarText() : string {
				if (this.nickname != null && this.nickname != '') {
					return this.nickname.substring(0, 1)
				}
				return '我'
			}
		},
		onLoad() {
			this.loadProfile()
		},
		onBackPress(): boolean {
			if (this.hasUnsaved == false) {
				return false
			}
			this.confirmLeave()
			return true
		},
		onShow() {
			try {
				// 检查全屏编辑器是否有返回结果
				const result = consumeTextEditorResult(PROFILE_EDITOR_OWNER, PROFILE_DESCRIPTION_EDITOR_TARGET)
				if (result != null) {
					this.description = result as string
					this.hasUnsaved = true
				}
				// 检查裁剪页面是否有返回结果
				const cropResult = consumeAvatarCropResult('profile_avatar')
				if (cropResult != '') {
					if (this.avatarPath != this.savedAvatarPath) {
						discardManagedAvatarFile(this.avatarPath)
					}
					this.avatarPath = cropResult
					this.hasUnsaved = true
				}
			} catch (e: any) {
				showProfileFailure('PROFILE_RETURN_STATE_FAILED', 'profile_consume_page_result', '页面返回结果读取失败', e)
			}
		},
		methods: {
			loadProfile() {
				try {
					const v1 = getAppSetting('profile_nickname')
					this.nickname = (v1 != null) ? v1 : ''
					const v2 = getAppSetting('profile_bio')
					this.bio = (v2 != null && v2 != '') ? v2 : ''
					const v3 = getAppSetting('profile_email')
					this.email = (v3 != null && v3 != '') ? v3 : ''
					const v4 = getAppSetting('profile_description')
					this.description = (v4 != null && v4 != '') ? v4 : ''
					const avatar = getAppSetting('profile_avatar')
					this.avatarPath = (avatar != null) ? avatar : ''
					this.savedAvatarPath = this.avatarPath
					this.hasUnsaved = false
				} catch (e: any) {
					showProfileFailure('PROFILE_LOAD_FAILED', 'profile_load', '个人资料加载失败', e)
				}
			},
			saveProfile(): boolean {
				let saved = false
				try {
					saved = setAppSettings(
						['profile_nickname', 'profile_bio', 'profile_email', 'profile_description', 'profile_avatar'],
						[this.nickname, this.bio, this.email, this.description, this.avatarPath],
					)
				} catch (e: any) {
					showProfileFailure('PROFILE_SAVE_FAILED', 'profile_save', '保存个人资料失败', e)
					return false
				}
				if (saved == false) {
					showProfileFailure('PROFILE_SAVE_FAILED', 'profile_save', '保存个人资料失败', 'setAppSettings 返回 false')
					return false
				}
				if (this.savedAvatarPath != this.avatarPath) {
					discardManagedAvatarFile(this.savedAvatarPath)
					this.savedAvatarPath = this.avatarPath
				}
				this.hasUnsaved = false
				uni.showToast({ position: 'bottom', 
					title: '已保存',
					icon: 'success'
				})
				return true
			},
			confirmLeave() {
				if (this.isConfirmingLeave == true) { return }
				this.isConfirmingLeave = true
				uni.showModal({
					title: '有未保存资料',
					content: '个人资料已修改，要保存后退出吗？',
					cancelText: '不保存',
					confirmText: '保存',
					success: (res) => {
						this.isConfirmingLeave = false
						if (res.confirm == true) {
							if (this.saveProfile() == true) {
								navigateProfileBack()
							}
						} else {
							if (this.avatarPath != this.savedAvatarPath) {
								discardManagedAvatarFile(this.avatarPath)
								this.avatarPath = this.savedAvatarPath
							}
							this.hasUnsaved = false
							navigateProfileBack()
						}
					},
					fail: (err: any) => {
						this.isConfirmingLeave = false
						showProfileFailure('PROFILE_LEAVE_CONFIRM_FAILED', 'profile_leave_confirm', '无法打开退出确认框', err)
					}
				})
			},
			goBack() {
				if (this.hasUnsaved == false) {
					navigateProfileBack()
					return
				}
				this.confirmLeave()
			},
			/** 弹出选择头像（拍照或从相册选取）*/
			pickAvatar() {
				chooseAvatarImage((path: string) => {
					openAvatarCrop(path, 'profile_avatar')
				})
			},
			/** 打开全屏编辑器 */
			openFullEditor() {
				const prepared = prepareTextEditorRuntimeState(
					this.description,
					'编辑个人简介',
					PROFILE_EDITOR_OWNER,
					PROFILE_DESCRIPTION_EDITOR_TARGET,
					'详细介绍一下自己…',
				)
				if (prepared == false) {
					showProfileFailure('PROFILE_EDITOR_STATE_FAILED', 'profile_editor_prepare', '无法准备全屏编辑器', '编辑器临时状态保存失败')
					return
				}
				uni.navigateTo({
					url: '/pages/common/editor/editor',
					fail: (err: any) => {
						if (clearProfileEditorRuntimeState() == false) {
							showProfileFailure('PROFILE_EDITOR_CLEANUP_FAILED', 'profile_editor_cleanup', '编辑器临时状态清理失败', 'clearEditorRuntimeState 返回 false')
						}
						showProfileFailure('PROFILE_EDITOR_ROUTE_FAILED', 'profile_editor_navigate', '无法打开全屏编辑器', err)
					}
				})
			},
		}
	}
</script>

<style>
	.container {
		flex: 1;
		padding: 16px 12px 0;
	}

	/* 头像区域 */
	.avatar-section {
		align-items: center;
		padding: 24px 0 20px;
	}

	.avatar-circle {
		width: 80px;
		height: 80px;
		border-radius: 40px;
		background-image: linear-gradient(to bottom right, #FB8FAB, #E8729A);
		justify-content: center;
		align-items: center;
		margin-bottom: 8px;
	}

	.avatar-image {
		width: 80px;
		height: 80px;
		border-radius: 40px;
		margin-bottom: 8px;
	}

	.avatar-text {
		font-size: 32px;
		color: #FFFFFF;
		font-weight: bold;
	}

	.avatar-hint {
		font-size: 12px;
		color: #9CA3AF;
	}

	/* 表单卡片 */
	.form-card {
		background-color: #FFFFFF;
		border-radius: 16px;
		padding: 0 12px;
	}

	.form-item {
		flex-direction: row;
		align-items: center;
		padding: 6px 0;
		min-height: 40px;
	}

	.form-item-textarea {
		align-items: flex-start;
		padding: 6px 0;
	}

	.textarea-wrap {
		flex: 1;
		position: relative;
	}

	/* 全屏编辑按钮 - 浮动在输入框右上角 */
	.fullscreen-btn {
		position: absolute;
		top: 6px;
		right: 6px;
		padding: 4px 10px;
		border-radius: 8px;
		background-color: var(--rice-primary-color-1);
		justify-content: center;
		align-items: center;
	}

	.fullscreen-btn-text {
		font-size: 12px;
		color: var(--rice-primary-color);
		font-weight: bold;
	}

	.form-label {
		font-size: 15px;
		color: #374151;
		width: 70px;
		font-weight: bold;
		flex-shrink: 0;
	}

	.form-input {
		flex: 1;
		font-size: 15px;
		color: #111827;
		padding-left: 14px;
		padding-right: 14px;
		height: 36px;
	}

	.form-textarea {
		flex: 1;
		background-color: #F9FAFB;
		border-radius: 12px;
		padding: 8px 12px;
		font-size: 15px;
		color: #111827;
		min-height: 36px;
		line-height: 22px;
	}

	.form-divider {
		height: 1px;
		background-color: #F3F4F6;
		margin-left: 70px;
	}

	/* 保存按钮 */
	.save-btn-wrap {
		padding: 12px 0 40px;
		align-items: center;
	}

	.save-btn {
		background-image: linear-gradient(to bottom right, #FB8FAB, #E8729A);
		border-radius: 22px;
		height: 44px;
		width: 200px;
		justify-content: center;
		align-items: center;
	}

	.save-btn-text {
		font-size: 16px;
		color: #FFFFFF;
		font-weight: bold;
	}


/* ===== Nyx 子页面视觉重制 ===== */
	.page-shell { background-color: #FAF7F5; }
	.container, .settings-scroll, .session-scroll, .history-page { background-color: #FAF7F5; }
	.container, .settings-scroll, .session-scroll { padding-left: 24px; padding-right: 24px; padding-top: 14px; padding-bottom: 28px; }
	.card, .form-card, .info-card, .details-card, .guide-card, .model-card, .hint-card, .hero-card, .danger-card, .empty-card, .prompt-box, .unimplemented-notice, .fullscreen-edit-card, .import-panel, .last-call-panel, .summary-card, .response-card, .preview-box { background-color: #FFFFFF; border-radius: 20px; border-width: 1px; border-style: solid; border-color: rgba(241, 229, 234, 0.92); box-shadow: 0 8px 20px rgba(216, 140, 165, 0.045); margin-left: 0; margin-right: 0; margin-top: 0; margin-bottom: 12px; padding: 16px; }
	.hero-card, .hint-card, .guide-card, .unimplemented-notice { background-color: #FFF7FA; border-color: rgba(251, 143, 171, 0.20); }
	.card-title, .hero-title, .hint-title, .guide-title, .info-title, .setting-title, .card-label, .provider-name, .model-card-title, .task-type-name, .skill-name, .action-title, .app-name, .form-label { color: #2A2529; }
	.card-desc, .hero-desc, .hint-text, .guide-desc, .info-desc, .setting-desc, .plugin-desc, .action-desc, .field-tip, .input-hint, .desc, .detail-value, .app-version { color: #8A7B84; }
	.text-input, .prompt-input, .flat-input, .field-input, .detail-field-input, .detail-params-input, .tts-input, .tts-extra-input, .small-textarea, .search-input, .textarea, .form-input, .form-textarea, .param-input, .short-input { background-color: #F8F2F4; border-radius: 15px; border-width: 1px; border-style: solid; border-color: #F0E5EA; color: #2A2529; }
	.member-row, .setting-row, .action-row, .provider-detail, .detail-row, .form-item, .model-row, .param-row, .tool-row, .log-item, .summary-row, .response-section, .usage-note-row { border-color: #F4EAEE; }
	.member-avatar, .session-icon, .logo-circle, .avatar-circle, .agent-avatar-placeholder, .card-icon, .task-type-icon, .tool-card-check, .skill-card-check { background-color: #FFF0F5; }
	.chip, .model-pill, .provider-chip, .doc-tab, .filter-chip, .tts-box, .summary-param-pill, .log-badge { border-radius: 500px; background-color: #FFFFFF; border-width: 1px; border-style: solid; border-color: #F1E5EA; }
	.chip-active, .pill-active, .doc-tab-active, .model-card-active, .skill-item-active, .skill-card-active, .tool-card-active, .session-item-active, .card-selected { background-color: #FFF0F5; border-color: rgba(251, 143, 171, 0.56); }
	.chip-text-active, .pill-text-active, .doc-tab-text-active, .filter-chip-text-active { color: #DB6F92; font-weight: bold; }
	.save-btn, .primary-btn, .test-btn, .add-model-btn, .fetch-btn, .member-action, .preview-primary-btn { border-radius: 500px; background-color: #FB8FAB; box-shadow: 0 8px 18px rgba(251, 143, 171, 0.18); }
	.save-btn-text, .primary-btn-text, .fetch-btn-text, .add-model-text, .test-btn-text, .member-action-text, .preview-primary-text { color: #FFFFFF; font-weight: bold; }
	.nav-add-text, .done-btn, .nav-btn, .reset-btn, .text-btn, .mini-btn, .session-action, .link-value, .fullscreen-edit-action, .prompt-save-text, .tts-clear-text { color: #DB6F92; font-weight: bold; }
	.danger, .nav-btn-danger, .danger-btn-text, .danger-button-text, .action-delete, .delete-btn-text { color: #EF4444; }
	.preview-card { border-top-left-radius: 26px; border-top-right-radius: 26px; }
	.bottom-space { height: 28px; flex-shrink: 0; }


