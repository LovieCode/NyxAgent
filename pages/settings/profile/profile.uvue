<template>
	<view class="page-shell rice-theme-light">
		<NavBar variant="light" title="用户资料" showBack @back="goBack" />
		<scroll-view class="container" :scroll-y="true">

			<!-- 头像区域 -->
			<view class="avatar-section" @click="pickAvatar">
				<image v-if="avatarPath != ''" :src="avatarPath" class="avatar-image" mode="aspectFill" />
				<view v-else class="avatar-circle">
					<text class="avatar-text">{{avatarText}}</text>
				</view>
				<text class="avatar-hint">点击更换头像</text>
			</view>

			<!-- 资料表单卡片 -->
			<view class="form-card">
				<view class="form-item">
					<text class="form-label">昵称</text>
					<input class="form-input" v-model="nickname" placeholder="输入昵称" placeholder-style="color:#9CA3AF" @input="hasUnsaved = true" />
				</view>
				<view class="form-divider"></view>
				<view class="form-item">
					<text class="form-label">简介</text>
					<input class="form-input" v-model="bio" placeholder="一句话介绍自己" placeholder-style="color:#9CA3AF" @input="hasUnsaved = true" />
				</view>
				<view class="form-divider"></view>
				<view class="form-item">
					<text class="form-label">邮箱</text>
					<input class="form-input" v-model="email" placeholder="邮箱地址" placeholder-style="color:#9CA3AF" inputmode="email" @input="hasUnsaved = true" />
				</view>
				<view class="form-divider"></view>
				<view class="form-item form-item-textarea">
					<text class="form-label">个人简介</text>
					<view class="textarea-wrap">
						<textarea class="form-textarea" v-model="description" placeholder="详细介绍一下自己…" placeholder-style="color:#9CA3AF" @input="hasUnsaved = true" />
						<view class="fullscreen-btn" @click="openFullEditor">
							<text class="fullscreen-btn-text">全屏编辑</text>
						</view>
					</view>
				</view>
			</view>

			<!-- 保存按钮 -->
			<view class="save-btn-wrap">
				<view class="save-btn" @click="saveProfile">
					<text class="save-btn-text">保存</text>
				</view>
			</view>
		</scroll-view>
	</view>
</template>

<script lang="uts">
	import { deleteRuntimeState, getAppSetting, getRuntimeState, setAppSettings, setRuntimeState } from '@/utils/database.uts'
	import { chooseAvatarImage, consumeAvatarCropResult, openAvatarCrop } from '@/utils/avatar-image-picker.uts'

	/**
	 * 用户资料页面 - 扁平化粉白主题
	 * 支持头像选择（拍照/相册）、资料编辑
	 */
	export default {
		data() {
			return {
				nickname: '' as string,
				bio: '' as string,
				email: '' as string,
				description: '' as string,
				/** 头像路径（空字符串表示使用默认文字头像） */
				avatarPath: '' as string,
				hasUnsaved: false as boolean,
				isConfirmingLeave: false as boolean,
			}
		},
		computed: {
			/** 头像占位文字：取昵称首字符或默认 */
			avatarText() : string {
				if (this.nickname != null && this.nickname != '') {
					return this.nickname.substring(0, 1)
				}
				return '我'
			}
		},
		onLoad() {
			this.loadProfile()
		},
		onBackPress(): boolean {
			if (this.hasUnsaved == false) {
				return false
			}
			this.confirmLeave()
			return true
		},
		onShow() {
			// 检查全屏编辑器是否有返回结果
			const ready = getRuntimeState('editor_result_ready')
			const result = getRuntimeState('editor_result')
			if (ready == 'true' || (result != null && result != '')) {
				const target = getRuntimeState('editor_target')
				if (target == 'profile-description' || target == null || target == '') {
					this.description = result != null ? result : ''
					deleteRuntimeState('editor_result')
					deleteRuntimeState('editor_result_ready')
					deleteRuntimeState('editor_target')
					deleteRuntimeState('editor_mode')
					deleteRuntimeState('editor_content')
					deleteRuntimeState('editor_title')
					deleteRuntimeState('editor_placeholder')
					deleteRuntimeState('editor_readonly')
					this.hasUnsaved = true
				}
			}
			// 检查裁剪页面是否有返回结果
			const cropResult = consumeAvatarCropResult('profile_avatar')
			if (cropResult != '') {
				this.avatarPath = cropResult
				this.hasUnsaved = true
			}
		},
		methods: {
			loadProfile() {
				const v1 = getAppSetting('profile_nickname')
				this.nickname = (v1 != null) ? v1 : ''
				const v2 = getAppSetting('profile_bio')
				this.bio = (v2 != null && v2 != '') ? v2 : ''
				const v3 = getAppSetting('profile_email')
				this.email = (v3 != null && v3 != '') ? v3 : ''
				const v4 = getAppSetting('profile_description')
				this.description = (v4 != null && v4 != '') ? v4 : ''
				const avatar = getAppSetting('profile_avatar')
				this.avatarPath = (avatar != null) ? avatar : ''
				this.hasUnsaved = false
			},
			saveProfile(): boolean {
				const saved = setAppSettings(
					['profile_nickname', 'profile_bio', 'profile_email', 'profile_description', 'profile_avatar'],
					[this.nickname, this.bio, this.email, this.description, this.avatarPath],
				)
				if (saved == false) {
					uni.showToast({ position: 'bottom', title: '保存个人资料失败，请重试', icon: 'none' })
					return false
				}
				this.hasUnsaved = false
				uni.showToast({ position: 'bottom', 
					title: '已保存',
					icon: 'success'
				})
				return true
			},
			confirmLeave() {
				if (this.isConfirmingLeave == true) { return }
				this.isConfirmingLeave = true
				uni.showModal({
					title: '有未保存资料',
					content: '个人资料已修改，要保存后退出吗？',
					cancelText: '不保存',
					confirmText: '保存',
					success: (res) => {
						this.isConfirmingLeave = false
						if (res.confirm == true) {
							if (this.saveProfile() == true) {
								uni.navigateBack()
							}
						} else {
							this.hasUnsaved = false
							uni.navigateBack()
						}
					},
					fail: () => {
						this.isConfirmingLeave = false
					}
				})
			},
			goBack() {
				if (this.hasUnsaved == false) {
					uni.navigateBack()
					return
				}
				this.confirmLeave()
			},
			/** 弹出选择头像（拍照或从相册选取）*/
			pickAvatar() {
				chooseAvatarImage((path: string) => {
					openAvatarCrop(path, 'profile_avatar')
				})
			},
			/** 打开全屏编辑器 */
			openFullEditor() {
				deleteRuntimeState('editor_draft')
				deleteRuntimeState('editor_result')
				deleteRuntimeState('editor_result_ready')
				deleteRuntimeState('editor_file_path')
				deleteRuntimeState('editor_saved')
				deleteRuntimeState('editor_saved_path')
				setRuntimeState('editor_mode', 'text')
				setRuntimeState('editor_content', this.description)
				setRuntimeState('editor_title', '编辑个人简介')
				setRuntimeState('editor_target', 'profile-description')
				setRuntimeState('editor_placeholder', '详细介绍一下自己…')
				uni.navigateTo({
					url: '/pages/common/editor/editor'
				})
			},
		}
	}
</script>

<style>
