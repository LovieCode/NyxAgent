<template>
	<view class="page-shell rice-theme-light">
		<NavBar title="用户资料" showBack @back="goBack" />
		<scroll-view class="container" :scroll-y="true">

			<!-- 头像区域 -->
			<view class="avatar-section" @click="pickAvatar">
				<image v-if="avatarPath != ''" :src="avatarPath" class="avatar-image" mode="aspectFill" />
				<view v-else class="avatar-circle">
					<text class="avatar-text">{{avatarText}}</text>
				</view>
				<text class="avatar-hint">点击更换头像</text>
			</view>

			<!-- 资料表单卡片 -->
			<view class="form-card">
				<view class="form-item">
					<text class="form-label">昵称</text>
					<input class="form-input" v-model="nickname" placeholder="输入昵称" placeholder-style="color:#9CA3AF" @input="hasUnsaved = true" />
				</view>
				<view class="form-divider"></view>
				<view class="form-item">
					<text class="form-label">简介</text>
					<input class="form-input" v-model="bio" placeholder="一句话介绍自己" placeholder-style="color:#9CA3AF" @input="hasUnsaved = true" />
				</view>
				<view class="form-divider"></view>
				<view class="form-item">
					<text class="form-label">邮箱</text>
					<input class="form-input" v-model="email" placeholder="邮箱地址" placeholder-style="color:#9CA3AF" inputmode="email" @input="hasUnsaved = true" />
				</view>
				<view class="form-divider"></view>
				<view class="form-item form-item-textarea">
					<text class="form-label">个人简介</text>
					<view class="textarea-wrap">
						<textarea class="form-textarea" v-model="description" placeholder="详细介绍一下自己…" placeholder-style="color:#9CA3AF" @input="hasUnsaved = true" />
						<view class="fullscreen-btn" @click="openFullEditor">
							<text class="fullscreen-btn-text">全屏编辑</text>
						</view>
					</view>
				</view>
			</view>

			<!-- 保存按钮 -->
			<view class="save-btn-wrap">
				<view class="save-btn" @click="saveProfile">
					<text class="save-btn-text">保存</text>
				</view>
			</view>
		</scroll-view>
	</view>
</template>

<script lang="uts">
	import { deleteRuntimeState, getAppSetting, getRuntimeState, setAppSetting, setRuntimeState } from '@/utils/database.uts'

	/**
	 * 用户资料页面 - 扁平化粉白主题
	 * 支持头像选择（拍照/相册）、资料编辑
	 */
	export default {
		data() {
			return {
				nickname: '' as string,
				bio: '' as string,
				email: '' as string,
				description: '' as string,
				/** 头像路径（空字符串表示使用默认文字头像） */
				avatarPath: '' as string,
				hasUnsaved: false as boolean,
				isConfirmingLeave: false as boolean,
			}
		},
		computed: {
			/** 头像占位文字：取昵称首字符或默认 */
			avatarText() : string {
				if (this.nickname != null && this.nickname != '') {
					return this.nickname.substring(0, 1)
				}
				return 'U'
			}
		},
		onLoad() {
			this.loadProfile()
		},
		onBackPress(): boolean {
			if (this.hasUnsaved == false) {
				return false
			}
			this.confirmLeave()
			return true
		},
		onShow() {
			// 检查全屏编辑器是否有返回结果
			const ready = getRuntimeState('editor_result_ready')
			const result = getRuntimeState('editor_result')
			if (ready == 'true' || (result != null && result != '')) {
				const target = getRuntimeState('editor_target')
				if (target == 'profile-description' || target == null || target == '') {
					this.description = result != null ? result : ''
					deleteRuntimeState('editor_result')
					deleteRuntimeState('editor_result_ready')
					deleteRuntimeState('editor_target')
					deleteRuntimeState('editor_mode')
					deleteRuntimeState('editor_content')
					deleteRuntimeState('editor_title')
					deleteRuntimeState('editor_placeholder')
					deleteRuntimeState('editor_readonly')
					this.hasUnsaved = true
				}
			}
			// 检查裁剪页面是否有返回结果
			const cropTarget = getRuntimeState('crop_target')
			const cropResult = getRuntimeState('crop_result')
			if (cropTarget == 'profile_avatar' && cropResult != null && cropResult != '') {
				this.avatarPath = cropResult
				setAppSetting('profile_avatar', this.avatarPath)
				deleteRuntimeState('crop_result')
				deleteRuntimeState('crop_target')
				deleteRuntimeState('crop_image_path')
			}
		},
		methods: {
			loadProfile() {
				const v1 = getAppSetting('profile_nickname')
				this.nickname = (v1 != null && v1 != '') ? v1 : '用户'
				const v2 = getAppSetting('profile_bio')
				this.bio = (v2 != null && v2 != '') ? v2 : ''
				const v3 = getAppSetting('profile_email')
				this.email = (v3 != null && v3 != '') ? v3 : ''
				const v4 = getAppSetting('profile_description')
				this.description = (v4 != null && v4 != '') ? v4 : ''
				const avatar = getAppSetting('profile_avatar')
				this.avatarPath = (avatar != null) ? avatar : ''
				this.hasUnsaved = false
			},
			saveProfile() {
				setAppSetting('profile_nickname', this.nickname)
				setAppSetting('profile_bio', this.bio)
				setAppSetting('profile_email', this.email)
				setAppSetting('profile_description', this.description)
				this.hasUnsaved = false
				uni.showToast({ position: 'bottom', 
					title: '已保存',
					icon: 'success'
				})
			},
			confirmLeave() {
				if (this.isConfirmingLeave == true) { return }
				this.isConfirmingLeave = true
				uni.showModal({
					title: '有未保存资料',
					content: '个人资料已修改，要保存后退出吗？',
					cancelText: '不保存',
					confirmText: '保存',
					success: (res) => {
						this.isConfirmingLeave = false
						if (res.confirm == true) {
							this.saveProfile()
						} else {
							this.hasUnsaved = false
						}
						uni.navigateBack()
					},
					fail: () => {
						this.isConfirmingLeave = false
					}
				})
			},
			goBack() {
				if (this.hasUnsaved == false) {
					uni.navigateBack()
					return
				}
				this.confirmLeave()
			},
			/** 弹出选择头像（拍照或从相册选取）*/
			pickAvatar() {
				uni.chooseImage({
					count: 1,
					sourceType: ['album', 'camera'],
					sizeType: ['compressed'],
					success: (res: any) => {
						const raw = JSON.stringify(res)
						if (raw == null || raw == '') { return }
						const parsed = JSON.parse(raw) as UTSJSONObject
						const paths = parsed['tempFilePaths'] as string[]
						if (paths != null && paths.length > 0) {
							deleteRuntimeState('crop_result')
							setRuntimeState('crop_target', 'profile_avatar')
							setRuntimeState('crop_image_path', paths[0])
							uni.navigateTo({
								url: '/pages/common/crop/crop'
							})
						}
					}
				})
			},
			/** 打开全屏编辑器 */
			openFullEditor() {
				deleteRuntimeState('editor_draft')
				deleteRuntimeState('editor_result')
				deleteRuntimeState('editor_result_ready')
				deleteRuntimeState('editor_file_path')
				deleteRuntimeState('editor_saved')
				deleteRuntimeState('editor_saved_path')
				setRuntimeState('editor_mode', 'text')
				setRuntimeState('editor_content', this.description)
				setRuntimeState('editor_title', '编辑个人简介')
				setRuntimeState('editor_target', 'profile-description')
				setRuntimeState('editor_placeholder', '详细介绍一下自己…')
				uni.navigateTo({
					url: '/pages/common/editor/editor'
				})
			},
		}
	}
</script>

<style>
	.container {
		flex: 1;
		padding: 32rpx 24rpx 0;
	}

	/* 头像区域 */
	.avatar-section {
		align-items: center;
		padding: 48rpx 0 40rpx;
	}

	.avatar-circle {
		width: 160rpx;
		height: 160rpx;
		border-radius: 80rpx;
		background-image: linear-gradient(to bottom right, #FB8FAB, #E8729A);
		justify-content: center;
		align-items: center;
		margin-bottom: 16rpx;
	}

	.avatar-image {
		width: 160rpx;
		height: 160rpx;
		border-radius: 80rpx;
		margin-bottom: 16rpx;
	}

	.avatar-text {
		font-size: 64rpx;
		color: #FFFFFF;
		font-weight: bold;
	}

	.avatar-hint {
		font-size: 24rpx;
		color: #9CA3AF;
	}

	/* 表单卡片 */
	.form-card {
		background-color: #FFFFFF;
		border-radius: 32rpx;
		padding: 0 24rpx;
	}

	.form-item {
		flex-direction: row;
		align-items: center;
		padding: 12rpx 0;
		min-height: 80rpx;
	}

	.form-item-textarea {
		align-items: flex-start;
		padding: 12rpx 0;
	}

	.textarea-wrap {
		flex: 1;
		position: relative;
	}

	/* 全屏编辑按钮 - 浮动在输入框右上角 */
	.fullscreen-btn {
		position: absolute;
		top: 12rpx;
		right: 12rpx;
		padding: 8rpx 20rpx;
		border-radius: 16rpx;
		background-color: var(--rice-primary-color-1);
		justify-content: center;
		align-items: center;
	}

	.fullscreen-btn-text {
		font-size: 24rpx;
		color: var(--rice-primary-color);
		font-weight: bold;
	}

	.form-label {
		font-size: 30rpx;
		color: #374151;
		width: 140rpx;
		font-weight: bold;
		flex-shrink: 0;
	}

	.form-input {
		flex: 1;
		font-size: 30rpx;
		color: #111827;
		padding: 0;
		height: 72rpx;
	}

	.form-textarea {
		flex: 1;
		background-color: #F9FAFB;
		border-radius: 24rpx;
		padding: 16rpx 24rpx;
		font-size: 30rpx;
		color: #111827;
		min-height: 72rpx;
		line-height: 44rpx;
	}

	.form-divider {
		height: 0.10rpx;
		background-color: #F3F4F6;
		margin-left: 140rpx;
	}

	/* 保存按钮 */
	.save-btn-wrap {
		padding: 24rpx 0 80rpx;
		align-items: center;
	}

	.save-btn {
		background-image: linear-gradient(to bottom right, #FB8FAB, #E8729A);
		border-radius: 44rpx;
		height: 88rpx;
		width: 400rpx;
		justify-content: center;
		align-items: center;
	}

	.save-btn-text {
		font-size: 32rpx;
		color: #FFFFFF;
		font-weight: bold;
	}
</style>
