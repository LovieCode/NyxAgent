<template>
	<view class="page-shell rice-theme-light">
		<NavBar variant="light" title="模型设置" showBack />
		<scroll-view class="container" :scroll-y="true">

			<!-- 选择提供商 -->
			<view class="card">
				<view class="section-header">
					<oui-icon-unix name="apartment" size="11px" color="#6B7280" style="margin-right:5px" />
					<text class="section-title">提供商</text>
				</view>
				<scroll-view class="chip-scroll" :scroll-x="true" :show-scrollbar="false">
					<view class="chip-row">
						<view
							v-for="(p, pi) in enabledProviders"
							:key="pi"
							class="chip"
							:class="selectedProvider == (p['id'] as string) ? 'chip-active' : ''"
							@click="selectProvider(p['id'] as string)"
						>
							<text class="chip-text" :class="selectedProvider == (p['id'] as string) ? 'chip-text-active' : ''">{{p['name']}}</text>
							<text v-if="(p['enabled'] as number) == 1" class="chip-badge">已启用</text>
						</view>
					</view>
				</scroll-view>
			</view>

			<!-- 选择模型 -->
			<view v-if="selectedProvider != ''" class="card">
				<view class="section-header">
					<oui-icon-unix name="robot" size="11px" color="#6B7280" style="margin-right:5px" />
					<text class="section-title">模型</text>
					<text class="section-count">{{currentModels.length}} 个</text>
				</view>
				<view v-if="currentModels.length == 0" class="empty-models">
					<text class="empty-models-text">该提供商没有配置模型，请先在提供商管理中设置</text>
				</view>
				<view v-else class="model-grid">
					<view
						v-for="(m, mi) in currentModels"
						:key="mi"
						class="model-pill"
						:class="selectedModel == m.id ? 'pill-active' : ''"
						@click="selectModel(m.id)"
					>
						<text class="pill-text" :class="selectedModel == m.id ? 'pill-text-active' : ''">{{m.id}}</text>
						<text v-if="m.context != null && m.context > 0" class="pill-ctx">{{formatModelContext(m.context)}}</text>
					</view>
				</view>
			</view>

		</scroll-view>
	</view>
</template>

<script lang="uts">
	import { getAgentById, updateAgentModel } from '@/utils/agent.uts'
	import { getAllProviders, getProviderModels, setDefaultChatTaskModel, getDefaultTaskModel, type ModelInfo } from '@/uni_modules/agent-core/utssdk/provider.uts'
	import { deleteRuntimeState, getRuntimeState } from '@/utils/database.uts'
	import { APP_ERROR_CATEGORY_RUNTIME, formatAppErrorForUser, reportAppErrorFromCause } from '@/utils/app-error.uts'
	import { getActiveAgentRuntimeId, getActiveConversationRuntimeId, setActiveChatRouteState } from '@/utils/runtime-state.uts'

	const PENDING_AGENT_MODEL_ID_KEY = 'pending_agent_model_id'

	function showModelRouteFailure(code: string, operation: string, userMessage: string, cause: any | null): void {
		const error = reportAppErrorFromCause(
			code,
			APP_ERROR_CATEGORY_RUNTIME,
			operation,
			userMessage,
			cause,
			true,
		)
		uni.showToast({ position: 'bottom', title: formatAppErrorForUser(error), icon: 'none' })
	}

	function clearPendingAgentModelId(): boolean {
		let cleared = false
		try {
			cleared = deleteRuntimeState(PENDING_AGENT_MODEL_ID_KEY)
		} catch (e: any) {
			showModelRouteFailure('MODEL_PENDING_STATE_CLEAR_FAILED', 'model_route_pending_clear', '模型设置跳转状态清理失败', e)
			return false
		}
		if (cleared == false) {
			showModelRouteFailure(
				'MODEL_PENDING_STATE_CLEAR_FAILED',
				'model_route_pending_clear',
				'模型设置跳转状态清理失败',
				'pending_agent_model_id 未能从运行状态数据库删除',
			)
		}
		return cleared
	}

	export default {
		data() {
			return {
				allProviders: [] as UTSJSONObject[],
				selectedProvider: '' as string,
				selectedModel: '' as string,
				pendingAgentId: '' as string,
			}
		},
		computed: {
			/** 只显示已启用的提供商 */
			enabledProviders(): UTSJSONObject[] {
				const list: UTSJSONObject[] = []
				for (let i = 0; i < this.allProviders.length; i++) {
					const p = this.allProviders[i]
					if ((p['enabled'] as number) == 1) {
						list.push(p)
					}
				}
				return list
			},
			/** 当前提供商的模型列表 */
			currentModels(): ModelInfo[] {
				if (this.selectedProvider == '') return []
				return getProviderModels(this.selectedProvider)
			}
		},
		onLoad() {
			let pid = ''
			try {
				pid = getRuntimeState(PENDING_AGENT_MODEL_ID_KEY)
			} catch (e: any) {
				showModelRouteFailure('MODEL_PENDING_STATE_READ_FAILED', 'model_route_pending_read', '模型设置跳转状态读取失败', e)
				return
			}
			// 旧入口只保留兼容跳转，实际配置统一由新的默认模型/智能体设置页处理。
			if (pid != '') {
				let agent: UTSJSONObject | null = null
				try {
					agent = getAgentById(pid)
				} catch (e: any) {
					showModelRouteFailure('MODEL_AGENT_READ_FAILED', 'model_route_agent_read', '智能体设置目标读取失败', e)
					return
				}
				if (agent != null) {
					let previousAgentId = ''
					let previousConversationId = ''
					try {
						previousAgentId = getActiveAgentRuntimeId()
						previousConversationId = getActiveConversationRuntimeId()
					} catch (e: any) {
						showModelRouteFailure('MODEL_ACTIVE_ROUTE_READ_FAILED', 'model_route_previous_state_read', '当前聊天状态读取失败', e)
						return
					}
					if (setActiveChatRouteState(pid, '') == false) {
						showModelRouteFailure(
							'MODEL_ACTIVE_ROUTE_SAVE_FAILED',
							'model_route_target_state_save',
							'无法准备智能体设置',
							'active_agent_id 与 active_conversation_id 原子写入失败',
						)
						return
					}
					uni.redirectTo({
						url: '/pages/agent-settings/agent-settings',
						success: () => {
							clearPendingAgentModelId()
						},
						fail: (err: any) => {
							if (setActiveChatRouteState(previousAgentId, previousConversationId) == false) {
								showModelRouteFailure(
									'MODEL_ACTIVE_ROUTE_ROLLBACK_FAILED',
									'model_route_target_state_rollback',
									'当前聊天状态恢复失败',
									'智能体设置导航失败后，原聊天路由未能原子恢复',
								)
							}
							showModelRouteFailure('MODEL_AGENT_SETTINGS_REDIRECT_FAILED', 'model_route_agent_settings_redirect', '无法打开智能体设置', err)
						}
					})
					return
				}
			}
			uni.redirectTo({
				url: '/pages/settings/default-models/default-models',
				success: () => {
					if (pid != '') {
						clearPendingAgentModelId()
					}
				},
				fail: (err: any) => {
					showModelRouteFailure('MODEL_DEFAULT_SETTINGS_REDIRECT_FAILED', 'model_route_default_settings_redirect', '无法打开默认模型设置', err)
				}
			})
		},
		methods: {
			loadData() {
				this.allProviders = getAllProviders()
				this.loadSelection()
			},
			/** 解析当前选中的提供商+模型 */
			loadSelection() {
				let providerId = ''
				let modelId = ''

				// 1. 智能体专用模式
				if (this.pendingAgentId != '') {
					const agent = getAgentById(this.pendingAgentId)
					if (agent != null) {
						const rawModel = agent['model'] as string | null
						if (rawModel != null) {
							const parsed = this.parseModelKey(rawModel)
							providerId = parsed['providerId'] as string
							modelId = parsed['modelId'] as string
						}
					}
				}

				// 2. 回退到全局默认
				if (providerId == '') {
					const defaultConfig = getDefaultTaskModel('chat')
					if (defaultConfig != null) {
						providerId = defaultConfig['providerId'] as string
						modelId = defaultConfig['model'] as string
					}
				}

				// 检查选中的提供商是否已启用，否则用第一个启用的
				if (providerId != '') {
					const enabled = this.enabledProviders
					let found = false
					for (let i = 0; i < enabled.length; i++) {
						if ((enabled[i]['id'] as string) == providerId) {
							found = true
							break
						}
					}
					if (found == false && enabled.length > 0) {
						providerId = enabled[0]['id'] as string
						modelId = ''
					}
				} else {
					if (this.enabledProviders.length > 0) {
						providerId = this.enabledProviders[0]['id'] as string
					}
				}

				if (providerId != '') {
					const models = getProviderModels(providerId)
					let modelFound = false
					for (let i = 0; i < models.length; i++) {
						if (models[i].id == modelId) {
							modelFound = true
							break
						}
					}
					if (modelFound == false) {
						modelId = ''
					}
				}

				this.selectedProvider = providerId
				this.selectedModel = modelId
			},

			/** 解析模型键 "providerId||modelId" 或旧格式 "modelId" */
			parseModelKey(key: string): UTSJSONObject {
				const sep = '||'
				const idx = key.indexOf(sep)
				if (idx >= 0) {
					return {
						providerId: key.substring(0, idx),
						modelId: key.substring(idx + sep.length),
					} as UTSJSONObject
				}
				return { providerId: '', modelId: key } as UTSJSONObject
			},

			selectProvider(id: string) {
				this.selectedProvider = id
				this.selectedModel = ''
			},

			selectModel(id: string) {
				const previousModel = this.selectedModel
				this.selectedModel = id
				const saved = this.saveSettings()
				if (saved == false) {
					this.selectedModel = previousModel
				}
			},

			formatModelContext(context: number | null): string {
				if (context == null || context <= 0) {
					return ''
				}
				return Math.floor(context / 1000).toString() + 'k'
			},

			saveSettings(): boolean {
				if (this.selectedProvider == '' || this.selectedModel == '') {
					uni.showToast({ title: '请选择提供商和模型', icon: 'none' })
					return false
				}
				if (this.pendingAgentId != '') {
					// 智能体专用：存 "providerId||modelId"
					const saved = updateAgentModel(this.pendingAgentId, this.selectedProvider + '||' + this.selectedModel)
					if (saved == false) {
						uni.showToast({ title: '保存智能体模型失败，请重试', icon: 'none' })
						return false
					}
				} else {
					const defaultSaved = setDefaultChatTaskModel(this.selectedProvider, this.selectedModel)
					if (defaultSaved == false) {
						uni.showToast({ title: '保存默认模型失败，请重试', icon: 'none' })
						return false
					}
				}
				return true
			}
		}
	}
</script>

<style>
	.container {
		flex: 1;
		padding: 16px;
	}

	.card {
		background-color: #FFFFFF;
		border-radius: 10px;
		padding: 16px;
		margin-bottom: 12px;
	}

	.section-header {
		flex-direction: row;
		align-items: center;
		margin-bottom: 10px;
	}

	.section-title {
		font-size: 15px;
		font-weight: bold;
		color: #111827;
		margin-right: 6px;
	}

	.section-count {
		font-size: 12px;
		color: #9CA3AF;
	}

	/* 提供商 chips */
	.chip-scroll {
		flex-direction: row;
	}

	.chip-row {
		flex-direction: row;
	}

	.chip {
		flex-direction: row;
		align-items: center;
		background-color: #F3F4F6;
		border-radius: 6px;
		padding: 7px 12px;
		margin: 2px;
		border-width: 1px;
		border-style: solid;
		border-color: #E5E7EB;
	}

	.chip-active {
		background-color: #FDE8EF;
		border-color: #FB8FAB;
	}

	.chip-text {
		font-size: 13px;
		color: #374151;
		white-space: nowrap;
	}

	.chip-badge {
		font-size: 10px;
		color: #FB8FAB;
		margin-left: 4px;
		background-color: #FDE8EF;
		padding: 1px 4px;
		border-radius: 3px;
	}

	/* 模型网格 */
	.model-grid {
		flex-direction: row;
		flex-wrap: wrap;
	}

	.model-pill {
		flex-direction: row;
		align-items: center;
		background-color: #F3F4F6;
		border-radius: 5px;
		padding: 7px 11px;
		margin: 3px;
		border-width: 1px;
		border-style: solid;
		border-color: #E5E7EB;
	}

	.pill-active {
		background-color: #FDE8EF;
		border-color: #FB8FAB;
	}

	.pill-text {
		font-size: 12px;
		color: #6B7280;
	}

	.pill-text-active {
		color: #DB6F92;
		font-weight: bold;
	}

	.pill-ctx {
		font-size: 10px;
		color: #9CA3AF;
		margin-left: 4px;
		background-color: #F3F4F6;
		padding: 1px 4px;
		border-radius: 3px;
	}

	.empty-models {
		padding: 20px 0;
		align-items: center;
	}

	.empty-models-text {
		font-size: 13px;
		color: #9CA3AF;
		text-align: center;
	}

	.save-wrap {
		padding: 10px 0 30px 0;
	}


/* ===== Nyx 子页面视觉重制 ===== */
	.page-shell { background-color: #FAF7F5; }
	.container { background-color: #FAF7F5; padding-left: 24px; padding-right: 24px; padding-top: 14px; padding-bottom: 28px; }
	.card { background-color: #FFFFFF; border-radius: 20px; border-width: 1px; border-style: solid; border-color: rgba(241, 229, 234, 0.92); box-shadow: 0 8px 20px rgba(216, 140, 165, 0.045); margin-bottom: 12px; padding: 16px; }
	.section-title { color: #2A2529; }
	.chip, .model-pill { border-radius: 500px; background-color: #FFFFFF; border-color: #F1E5EA; }
	.chip-active, .pill-active { background-color: #FFF0F5; border-color: rgba(251, 143, 171, 0.56); }
	.pill-text-active, .chip-text-active { color: #DB6F92; font-weight: bold; }
</style>
