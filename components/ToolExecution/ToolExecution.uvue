<template>
	<view class="tool-exec">
		<view class="tool-line">
			<view class="tool-dot" :class="dotClass"></view>
			<text class="tool-name">{{displayName}}</text>
			<text class="tool-status">{{statusText}}</text>
		</view>
		<text v-if="detailText != ''" class="tool-detail">{{detailText}}</text>
	</view>
</template>

<script lang="uts">
	/**
	 * ToolExecution 组件 - 工具执行状态展示
	 * 极简日志行风格，低视觉权重
	 */

	/** 工具名称友好映射 */
	function getDisplayName(name: string): string {
		if (name == 'file_read') return '读取文件'
		if (name == 'file_write') return '写入文件'
		if (name == 'file_delete') return '删除文件'
		if (name == 'file_list') return '列出文件'
		if (name == 'file_info') return '获取文件信息'
		if (name == 'directory_create') return '创建目录'
		return name
	}

	export default {
		props: {
			toolName: {
				type: String,
				default: ''
			},
			status: {
				type: String,
				default: 'running'
			},
			result: {
				type: String,
				default: ''
			},
			args: {
				type: String,
				default: ''
			}
		},
		computed: {
			dotClass() : string {
				if (this.status == 'running') return 'dot-running'
				if (this.status == 'completed') return 'dot-completed'
				if (this.status == 'error') return 'dot-error'
				return 'dot-running'
			},
			statusText() : string {
				if (this.status == 'running') return '执行中'
				if (this.status == 'completed') return '已完成'
				if (this.status == 'error') return '失败'
				return ''
			},
			displayName() : string {
				return getDisplayName(this.toolName)
			},
			detailText() : string {
				const source = this.status == 'running' ? this.args : this.result
				if (source.length == 0) return ''
				return source.length > 60 ? source.substring(0, 60) + '…' : source
			}
		},
	}
</script>

<style>
	.tool-exec {
		align-self: flex-start;
		margin-left: 48px;
		margin-right: 50px;
		margin-top: 2px;
		margin-bottom: 2px;
		padding-left: 8px;
		padding-right: 10px;
		padding-top: 4px;
		padding-bottom: 4px;
		border-radius: 10px;
		background-color: rgba(0, 0, 0, 0.04);
		flex-direction: column;
	}

	.tool-line {
		flex-direction: row;
		align-items: center;
	}

	.tool-dot {
		width: 5px;
		height: 5px;
		border-radius: 2.5px;
		margin-right: 5px;
	}

	.dot-running {
		background-color: #9CA3AF;
	}

	.dot-completed {
		background-color: #10B981;
	}

	.dot-error {
		background-color: #EF4444;
	}

	.tool-name {
		font-size: 12px;
		color: #6B7280;
		font-weight: 500;
	}

	.tool-status {
		font-size: 11px;
		color: #9CA3AF;
		margin-left: 5px;
	}

	.tool-detail {
		font-size: 11px;
		color: #9CA3AF;
		margin-top: 1px;
		margin-left: 10px;
		lines: 1;
		text-overflow: ellipsis;
	}
</style>
