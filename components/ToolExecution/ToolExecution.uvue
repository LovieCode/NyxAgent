<template>
	<view class="tool-exec" @click="toggleExpand">
		<view class="tool-line">
			<view class="tool-dot" :class="dotClass"></view>
			<text class="tool-name">{{displayName}}</text>
			<text class="tool-status">{{statusText}}</text>
			<text class="tool-toggle">{{expanded ? '▾' : '▸'}}</text>
		</view>
		<text v-if="!expanded && collapsedHint != ''" class="tool-detail">{{collapsedHint}}</text>
		<view v-if="expanded" class="tool-detail-expanded">
			<view v-if="argsDisplay != ''" class="detail-block">
				<text class="detail-label">参数</text>
				<text class="detail-mono">{{argsDisplay}}</text>
			</view>
			<view v-if="resultDisplay != ''" class="detail-block">
				<text class="detail-label">结果</text>
				<text class="detail-mono">{{resultDisplay}}</text>
			</view>
		</view>
	</view>
</template>

<script lang="uts">
	/**
	 * ToolExecution 组件 - 工具执行状态展示
	 * 点击展开/收起查看完整参数和结果
	 */

	/** 工具名称友好映射 */
	function getDisplayName(name: string): string {
		if (name == 'file_read') return '读取文件'
		if (name == 'file_write') return '写入文件'
		if (name == 'file_delete') return '删除文件'
		if (name == 'file_list') return '列出文件'
		if (name == 'file_info') return '获取文件信息'
		if (name == 'directory_create') return '创建目录'
		if (name == 'memory_search') return '搜索记忆'
		if (name == 'memory_buffer_write') return '写短缓存'
		if (name == 'memory_core_list') return '列出记忆'
		if (name == 'memory_core_save') return '保存记忆'
		if (name == 'memory_core_forget') return '遗忘记忆'
		if (name == 'web_search') return '网络搜索'
		return name
	}

	export default {
		props: {
			toolName: {
				type: String,
				default: ''
			},
			status: {
				type: String,
				default: 'running'
			},
			result: {
				type: String,
				default: ''
			},
			args: {
				type: String,
				default: ''
			}
		},
		data() {
			return {
				expanded: false as boolean,
			}
		},
		computed: {
			dotClass() : string {
				if (this.status == 'running') return 'dot-running'
				if (this.status == 'completed') return 'dot-completed'
				if (this.status == 'error') return 'dot-error'
				return 'dot-running'
			},
			statusText() : string {
				if (this.status == 'running') return '执行中'
				if (this.status == 'completed') return '已完成'
				if (this.status == 'error') return '失败'
				return ''
			},
			displayName() : string {
				return getDisplayName(this.toolName)
			},
			collapsedHint() : string {
				const source = this.status == 'running' ? this.args : this.result
				if (source.length == 0) return ''
				return source.length > 60 ? source.substring(0, 60) + '…' : source
			},
			argsDisplay() : string {
				if (this.args.length == 0) return ''
				return this.args
			},
			resultDisplay() : string {
				if (this.result.length == 0) return ''
				return this.result
			},
		},
		methods: {
			toggleExpand() {
				this.expanded = !this.expanded
			},
		},
	}
</script>

<style>
	.tool-exec {
		align-self: flex-start;
		margin-left: 48px;
		margin-right: 50px;
		margin-top: 2px;
		margin-bottom: 2px;
		padding-left: 10px;
		padding-right: 10px;
		padding-top: 6px;
		padding-bottom: 6px;
		border-radius: 10px;
		background-color: rgba(0, 0, 0, 0.04);
		flex-direction: column;
	}

	.tool-line {
		flex-direction: row;
		align-items: center;
	}

	.tool-dot {
		width: 5px;
		height: 5px;
		border-radius: 1px;
		margin-right: 5px;
	}

	.dot-running {
		background-color: #9CA3AF;
	}

	.dot-completed {
		background-color: #10B981;
	}

	.dot-error {
		background-color: #EF4444;
	}

	.tool-name {
		font-size: 12px;
		color: #6B7280;
		font-weight: 500;
	}

	.tool-status {
		font-size: 11px;
		color: #9CA3AF;
		margin-left: 5px;
		flex: 1;
	}

	.tool-toggle {
		font-size: 12px;
		color: #9CA3AF;
	}

	.tool-detail {
		font-size: 11px;
		color: #9CA3AF;
		margin-top: 1px;
		margin-left: 10px;
	}

	.tool-detail-expanded {
		margin-top: 6px;
		margin-left: 10px;
	}

	.detail-block {
		margin-bottom: 8px;
	}

	.detail-label {
		font-size: 11px;
		color: #6B7280;
		font-weight: 500;
		margin-bottom: 3px;
	}

	.detail-mono {
		font-size: 11px;
		line-height: 16px;
		color: #374151;
		font-family: monospace;
		white-space: pre-wrap;
		background-color: rgba(0, 0, 0, 0.03);
		border-radius: 6px;
		padding: 6px 8px;
	}
</style>
