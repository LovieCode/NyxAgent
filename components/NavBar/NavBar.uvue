		flex-direction: column;
		flex-shrink: 0;
		background-color: var(--rice-primary-color);
	}

	.nb-root-light {
		background-color: #FAF7F8;
	}

	.nb-status {
		flex-direction: column;
		flex-shrink: 0;
		background-color: var(--rice-primary-color);
	}

	.nb-root-light .nb-status {
		background-color: #F48FB1;
	}

	.nb-status-fill {
		flex-shrink: 0;
		background-color: var(--rice-primary-color);
	}

	.nb-root-light .nb-status-fill {
		background-color: #F48FB1;
	}

	.nb-wrap {
		background-color: var(--rice-primary-color);
	}

	.nb-root-light .nb-wrap {
		background-color: #FAF7F8;
	}

	.nb-header {
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		padding-left: 10px;
		padding-right: 10px;
		padding-top: 0px;
		padding-bottom: 0px;
		height: 48px;
		background-color: var(--rice-primary-color);
	}

	.nb-root-light .nb-header {
		background-color: #FAF7F8;
	}

	/* 阴影线 */
	.nb-shadow {
		height: 1px;
		background-color: rgba(0,0,0,0.06);
	}

	.nb-root-light .nb-shadow {
		background-color: rgba(241, 229, 234, 0.85);
	}

	.nb-left {
		width: 112px;
		height: 48px;
		flex-direction: row;
		align-items: center;
	}

	.nb-title {
		font-size: 18px;
		font-weight: bold;
		color: var(--rice-text-color-white);
	}

	.nb-root-light .nb-title {
		color: #25242A;
	}

	.nb-title-center {
		flex: 1;
		text-align: center;
	}

	.nb-right {
		width: 112px;
		height: 48px;
		flex-direction: row;
		align-items: center;
		justify-content: flex-end;
	}

	/* 返回按钮 */
	.back-btn {
		flex-direction: row;
		align-items: center;
	}

	.back-arrow {
		font-size: 22px;
		color: var(--rice-text-color-white);
	}

	.nb-root-light .back-arrow {
		color: #25242A;
	}

	.back-text {
		font-size: 16px;
		color: var(--rice-text-color-white);
		margin-left: 4px;
		padding-top: 3px;
	}

	.nb-root-light .back-text {
		color: #25242A;
	}
</style>
