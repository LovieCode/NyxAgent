<template>
	<view :class="variant == 'light' ? 'nb-root nb-root-light' : 'nb-root'">
		<NyxFloatingVoice v-if="showNyxFloat == true" />
		<view v-if="!noStatusBar" class="nb-status" :style="{ height: statusBarHeight + 'px' }">
			<share-element v-if="shareKey != ''" :share-key="shareKey">
				<view class="nb-status-fill" :style="{ height: statusBarHeight + 'px' }"></view>
			</share-element>
			<view v-else class="nb-status-fill" :style="{ height: statusBarHeight + 'px' }"></view>
		</view>
		<view class="nb-wrap">
			<view class="nb-header">
				<view class="nb-left">
					<slot name="left">
						<view v-if="showBack" class="back-btn" @click="onBack">
							<text class="back-arrow">‹</text>
							<text class="back-text">{{backText}}</text>
						</view>
					</slot>
				</view>
				<text :class="['nb-title', leftAligned ? '' : 'nb-title-center']">{{title}}</text>
				<view class="nb-right">
					<slot name="right"></slot>
				</view>
			</view>
			<view class="nb-shadow"></view>
		</view>
	</view>
</template>

<script lang="uts">
	export default {
		name: 'NavBar',
		props: {
			title: {
				type: String,
				default: ''
			},
			showBack: {
				type: Boolean,
				default: false
			},
			backText: {
				type: String,
				default: '返回'
			},
			leftAligned: {
				type: Boolean,
				default: false
			},
			noStatusBar: {
				type: Boolean,
				default: false
			},
			shareKey: {
				type: String,
				default: ''
			},
			showNyxFloat: {
				type: Boolean,
				default: true
			},
			variant: {
				type: String,
				default: 'primary'
			}
		},
		data() {
			return {
				statusBarHeight: 0
			}
		},
		created() {
			try {
				// #ifndef WEB
				const windowInfo = uni.getWindowInfo()
				let top = windowInfo.statusBarHeight
				if (windowInfo.safeAreaInsets.top > top) {
					top = windowInfo.safeAreaInsets.top
				}
				this.statusBarHeight = top > 0 ? top : 0
				// #endif
				// #ifdef WEB
				this.statusBarHeight = 0
				// #endif
			} catch (_e: any) {
				this.statusBarHeight = 0
			}
		},
		methods: {
			onBack() {
				// $attrs 不含 emits 声明的事件监听器
				// 有 onBack 说明父组件注册了 @back → 由页面自己处理返回
				// 没有 onBack → NavBar 默认执行返回
				const hasBackListener = this.$attrs != null && this.$attrs['onBack'] != null
				if (hasBackListener == true) {
					this.$emit('back')
				} else {
					uni.navigateBack()
				}
			}
		}
	}
</script>

<style>
