<template>
	<!-- 自定义底部导航栏 - 设计图同款白色浮层 -->
	<view class="tabbar">
		<view
			v-for="(tab, index) in tabs"
			:key="index"
			:class="'tab-item' + (current == tab['pagePath'] ? ' tab-item-active' : '')"
			@click="switchTab(tab['pagePath'] as string)"
		>
			<oui-icon-unix
				:name="current == tab['pagePath'] ? (tab['activeIcon'] as string) : (tab['icon'] as string)"
				:size="'22px'"
				:color="current == tab['pagePath'] ? 'var(--rice-primary-color)' : '#4B5563'"
			/>
			<text
				:class="'tab-label' + (current == tab['pagePath'] ? ' tab-label-active' : '')"
			>{{ tab['text'] }}</text>
		</view>
	</view>
</template>

<script lang="uts">
	/**
	 * 自定义底部导航栏组件
	 * 使用 oui-icon-unix 渲染图标
	 */
	export default {
		name: 'TabBar',
		props: {
			// 当前选中页面的路径，例如 "pages/chat/chat"
			current: {
				type: String,
				default: 'pages/chat/chat',
			},
		},
		data() {
			return {
				tabs: [
					{ pagePath: 'pages/agents/agents', text: '聊天', icon: 'message', activeIcon: 'message-fill' },
					{ pagePath: 'pages/todo/todo', text: '待办', icon: 'check-circle', activeIcon: 'check-circle-fill' },
					{ pagePath: 'pages/files/files', text: '文件', icon: 'folder', activeIcon: 'folder-fill' },
					{ pagePath: 'pages/settings/settings', text: '设置', icon: 'setting', activeIcon: 'setting-fill' },
				],
			};
		},
		methods: {
			switchTab(url: string) {
				if (url == this.current) {
					return;
				}
				uni.redirectTo({
					url: '/' + url,
				});
			},
		},
	};
</script>

<style>
	/* 底部导航栏 - 设计图里的白色浮动胶囊 */
	.tabbar {
		flex-direction: row;
		height: 66px;
		background-color: #FFFFFF;
		border-radius: 30px;
		padding-left: 7px;
		padding-right: 7px;
		justify-content: space-around;
		align-items: center;
		border-width: 1px;
		border-style: solid;
		border-color: rgba(241, 229, 234, 0.92);
		box-shadow: 0 14px 28px rgba(216, 140, 165, 0.12);
	}

	/* 单个标签项 */
	.tab-item {
		flex-direction: column;
		justify-content: center;
		align-items: center;
		flex: 1;
		height: 54px;
		border-radius: 22px;
	}

	.tab-item-active {
		background-color: rgba(255, 240, 245, 0.72);
	}

	/* 标签文字 */
	.tab-label {
		font-size: 11px;
		color: #8A7B84;
		margin-top: 4px;
	}

	/* 选中标签文字 - 粉色 */
	.tab-label-active {
		color: var(--rice-primary-color);
		font-weight: bold;
	}
</style>
