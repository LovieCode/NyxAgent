<template>
	<!-- 自定义底部导航栏 - 淡粉胶囊风格 -->
	<view class="tabbar-shell">
		<view class="tabbar">
			<view
				v-for="(tab, index) in tabs"
				:key="index"
				:class="'tab-item' + (current == tab['pagePath'] ? ' tab-item-active' : '')"
				@click="switchTab(tab['pagePath'] as string)"
			>
				<view :class="'tab-icon-shell' + (current == tab['pagePath'] ? ' tab-icon-shell-active' : '')">
					<oui-icon-unix
						:name="tab['icon'] as string"
						:size="'21px'"
						:color="current == tab['pagePath'] ? '#FFFFFF' : 'var(--rice-text-color-3)'"
					/>
				</view>
				<text
					:class="'tab-label' + (current == tab['pagePath'] ? ' tab-label-active' : '')"
				>{{ tab['text'] }}</text>
			</view>
		</view>
	</view>
</template>

<script lang="uts">
	/**
	 * 自定义底部导航栏组件
	 * 使用 oui-icon-unix 渲染图标
	 */
	export default {
		name: 'TabBar',
		props: {
			// 当前选中页面的路径，例如 "pages/chat/chat"
			current: {
				type: String,
				default: 'pages/chat/chat',
			},
		},
		data() {
			return {
				tabs: [
					{ pagePath: 'pages/agents/agents', text: '聊天', icon: 'message' },
					{ pagePath: 'pages/todo/todo', text: '待办', icon: 'check-circle' },
					{ pagePath: 'pages/files/files', text: '文件', icon: 'folder' },
					{ pagePath: 'pages/settings/settings', text: '设置', icon: 'setting' },
				],
			};
		},
		methods: {
			switchTab(url: string) {
				if (url == this.current) {
					return;
				}
				uni.redirectTo({
					url: '/' + url,
				});
			},
		},
	};
</script>

<style>
	.tabbar-shell {
		background-color: #FAF7F5;
		padding-left: 18px;
		padding-right: 18px;
		padding-top: 6px;
		padding-bottom: 12px;
	}

	/* 底部导航栏 - 白色胶囊 */
	.tabbar {
		flex-direction: row;
		height: 64px;
		background-color: var(--rice-background-2);
		border-radius: 26px;
		padding-left: 7px;
		padding-right: 7px;
		justify-content: space-around;
		align-items: center;
		border-width: 1px;
		border-style: solid;
		border-color: rgba(241, 229, 234, 0.96);
		box-shadow: 0 12px 28px rgba(216, 140, 165, 0.10);
	}

	/* 单个标签项 */
	.tab-item {
		flex-direction: column;
		justify-content: center;
		align-items: center;
		flex: 1;
		height: 52px;
		border-radius: 20px;
		margin-left: 2px;
		margin-right: 2px;
	}

	.tab-item-active {
		background-color: #FFF3F7;
	}

	.tab-icon-shell {
		width: 30px;
		height: 30px;
		border-radius: 15px;
		justify-content: center;
		align-items: center;
	}

	.tab-icon-shell-active {
		background-color: #F48FB1;
		box-shadow: 0 8px 16px rgba(244, 143, 177, 0.24);
	}

	/* 标签文字 */
	.tab-label {
		font-size: 11px;
		color: var(--rice-text-color-3);
		margin-top: 2px;
	}

	/* 选中标签文字 - 粉色 */
	.tab-label-active {
		color: var(--rice-primary-color);
		font-weight: bold;
	}
</style>
