<template>
	<view :class="bubbleClass">
		<!-- 工具名称标签（在内容上方） -->
		<view v-if="role == 'toolResult'" class="tool-badge">
			<text class="tool-badge-text">{{toolName}}</text>
		</view>

		<!-- 用户消息：气泡 + 右侧头像 -->
		<view v-if="role == 'user'" class="user-row">
			<view class="user-bubble" :class="isPressed ? 'bubble-pressed' : ''" @touchstart="onBubbleTouchStart($event as UniTouchEvent)" @touchmove="onBubbleTouchMove($event as UniTouchEvent)" @touchend="onBubbleTouchEnd">
				<!-- 图片消息 -->
				<image v-if="msgType == 'image' && imageUrl != ''" :src="imageUrl" class="bubble-image" mode="widthFix" />
				<!-- 文本消息 -->
				<text v-if="msgType != 'image' || content != ''" :class="textClass">{{content}}<text v-if="isStreaming" class="cursor">|</text></text>
			</view>
			<image v-if="userAvatar != ''" :src="userAvatar" class="chat-avatar user-avatar-image" mode="aspectFill" />
			<view v-else class="chat-avatar user-avatar">
				<text class="chat-avatar-text">{{userInitial}}</text>
			</view>
		</view>

		<!-- AI 消息：左侧头像 + 标签 + 气泡 -->
		<view v-if="role == 'assistant'" class="ai-row">
			<image v-if="agentAvatar != ''" :src="agentAvatar" class="chat-avatar ai-avatar-image" mode="aspectFill" />
			<view v-else class="chat-avatar ai-avatar">
				<text class="chat-avatar-text">AI</text>
			</view>
			<view class="ai-content" :class="isPressed ? 'bubble-pressed' : ''" @touchstart="onBubbleTouchStart($event as UniTouchEvent)" @touchmove="onBubbleTouchMove($event as UniTouchEvent)" @touchend="onBubbleTouchEnd">
				<!-- 思考内容——默认折叠，受 hideThinking 控制 -->
				<view v-if="thinking != '' && hideThinking == false" class="thinking-wrap" @click.stop="thinkingExpanded = !thinkingExpanded">
					<text class="thinking-toggle">{{thinkingExpanded ? '▾' : '▸'}} 思考过程</text>
					<text v-if="thinkingExpanded == true" class="thinking-text">{{thinking}}</text>
				</view>
				<image v-if="msgType == 'image' && imageUrl != ''" :src="imageUrl" class="bubble-image" mode="widthFix" />
				<text v-if="msgType != 'image' || content != ''" :class="textClass">{{content}}<text v-if="isStreaming" class="cursor">|</text></text>
			</view>
		</view>

		<!-- 工具消息：纯文本 -->
		<text v-if="role == 'toolResult'" :class="textClass">{{content}}<text v-if="isStreaming" class="cursor">|</text></text>
	</view>
</template>

<script lang="uts">
	/**
	 * ChatBubble 组件 - 聊天气泡
	 * 扁平化粉白主题
	 */
	export default {
		props: {
			role: {
				type: String,
				default: 'user'
			},
			content: {
				type: String,
				default: ''
			},
			msgType: {
				type: String,
				default: 'text'
			},
			imageUrl: {
				type: String,
				default: ''
			},
			toolName: {
				type: String,
				default: ''
			},
			thinking: {
				type: String,
				default: ''
			},
			hideThinking: {
				default: false
			},
			isError: {
				default: false
			},
			isStreaming: {
				default: false
			},
			userNickname: {
				type: String,
				default: ''
			},
			userAvatar: {
				type: String,
				default: ''
			},
			agentAvatar: {
				type: String,
				default: ''
			},
			cancelToken: {
				type: Number,
				default: 0
			}
		},
		data() {
			return {
				/** 长按检测 */
				touchStartX: 0 as number,
				touchStartY: 0 as number,
				longpressTick: 0 as number,
				longpressTimer: -1 as number,
				longpressTriggered: false as boolean,
				/** 长按按下态（视觉反馈） */
				isPressed: false as boolean,
				/** 思考内容折叠态 */
				thinkingExpanded: false as boolean,
			}
		},
		watch: {
			cancelToken(newVal: number, oldVal: number) {
				if (newVal != oldVal) {
					this.cancelLongpress()
				}
			}
		},
		computed: {
			/** 将 any 类型转 boolean */
			isErrorBool(): boolean {
				return this.isError == true || this.isError == 'true'
			},
			isStreamingBool(): boolean {
				return this.isStreaming == true || this.isStreaming == 'true'
			},

			/** 用户头像首字母 */
			userInitial(): string {
				const name = this.userNickname as string
				if (name != null && name != '') {
					return name.substring(0, 1)
				}
				return 'U'
			},

			bubbleClass() : string {
				if (this.role == 'user') {
					return 'bubble-user'
				}
				if (this.role == 'assistant') {
					return 'bubble-assistant'
				}
				if (this.role == 'toolResult') {
					if (this.isErrorBool) {
						return 'bubble-tool-error'
					}
					return 'bubble-tool'
				}
				return 'bubble-user'
			},
			textClass() : string {
				if (this.role == 'user') {
					return 'text-user'
				}
				if (this.role == 'assistant') {
					return 'text-assistant'
				}
				if (this.role == 'toolResult') {
					return 'text-tool'
				}
				return 'text-user'
			}
		},
		methods: {
			/** 取消长按状态 */
			cancelLongpress() {
				if (this.longpressTimer != -1) {
					clearInterval(this.longpressTimer)
					this.longpressTimer = -1
				}
				this.longpressTriggered = false
				this.isPressed = false
			},

			/** 触摸开始 — 启动长按计时 */
			onBubbleTouchStart(e: UniTouchEvent) {
				this.touchStartX = e.touches[0].screenX
				this.touchStartY = e.touches[0].screenY
				this.longpressTick = 0
				this.longpressTriggered = false
				this.isPressed = true
				if (this.longpressTimer != -1) {
					clearInterval(this.longpressTimer)
				}
				this.longpressTimer = setInterval(() => {
					this.longpressTick++
					if (this.longpressTick >= 5) {
						clearInterval(this.longpressTimer)
						this.longpressTimer = -1
						if (this.longpressTriggered == true) {
							return
						}
						this.longpressTriggered = true
						this.$emit('bubbleLongpress')
					}
				}, 100)
			},

			/** 触摸移动 — 距离过大取消长按 */
			onBubbleTouchMove(e: UniTouchEvent) {
				if (this.longpressTimer == -1) { return }
				const dx = e.touches[0].screenX - this.touchStartX
				const dy = e.touches[0].screenY - this.touchStartY
				if (Math.abs(dx) > 30 || Math.abs(dy) > 30) {
					this.cancelLongpress()
				}
			},

			/** 触摸结束 — 清理状态 */
			onBubbleTouchEnd() {
				this.cancelLongpress()
				this.longpressTriggered = false
				this.isPressed = false
			},
		}
	}
</script>

<style>
	/* 用户气泡 - 右对齐粉色 */
	.bubble-user {
		flex-direction: column;
		align-items: flex-end;
		margin-left: 50px;
		margin-right: 10px;
		margin-top: 8px;
		margin-bottom: 8px;
	}

	/* 用户行：气泡 + 头像，顶部对齐 */
	.user-row {
		flex-direction: row;
		align-items: flex-start;
		justify-content: flex-end;
		width: 100%;
	}

	/* 用户气泡 - 粉色渐变背景 */
	.user-bubble {
		background-image: linear-gradient(to bottom right, #FB8FAB, #E8729A);
		border-radius: 16px;
		padding: 6px 12px;
		max-width: 500px;
		flex-shrink: 1;
	}

	/* 用户气泡按压效果 */
	.user-bubble:active {
		opacity: 0.75;
	}

	/* AI 行：头像 + 内容，顶部对齐 */
	.ai-row {
		flex-direction: row;
		align-items: flex-start;
		width: 100%;
	}

	.ai-content {
		flex-shrink: 1;
		background-color: var(--rice-background-2);
		border-radius: 16px;
		padding: 10px;
		max-width: 500px;
	}

	/* AI 气泡按压效果 */
	.ai-content:active {
		background-color: #E5E7EB;
	}

	/* 通用头像 - 小圆形 */
	.chat-avatar {
		width: 28px;
		height: 28px;
		border-radius: 14px;
		flex-shrink: 0;
		margin-top: 2px;
	}

	.chat-avatar-text {
		font-size: 12px;
		color: var(--rice-background-2);
		font-weight: bold;
	}

	/* 用户头像 - 粉色渐变 */
	.user-avatar {
		background-image: linear-gradient(to bottom right, #FB8FAB, #E8729A);
		margin-left: 8px;
		justify-content: center;
		align-items: center;
	}

	/* 用户头像 - 自定义图片 */
	.user-avatar-image {
		margin-left: 8px;
	}

	/* AI 头像 - 灰色 */
	.ai-avatar {
		background-color: var(--rice-text-color-3);
		margin-right: 8px;
		justify-content: center;
		align-items: center;
	}

	/* AI 头像 - 自定义图片 */
	.ai-avatar-image {
		margin-right: 8px;
	}

	/* AI 气泡容器 - 只提供外边距 */
	.bubble-assistant {
		flex-direction: column;
		align-items: flex-start;
		margin-left: 10px;
		margin-right: 50px;
		margin-top: 8px;
		margin-bottom: 8px;
	}

	/* 工具气泡 - 浅灰背景 */
	.bubble-tool {
		flex-direction: column;
		align-items: flex-start;
		margin-left: 32px;
		margin-right: 32px;
		margin-top: 4px;
		margin-bottom: 4px;
		background-color: var(--rice-button-info-background);
		border-radius: 8px;
		padding: 10px;
	}

	/* 工具错误气泡 */
	.bubble-tool-error {
		flex-direction: column;
		align-items: flex-start;
		margin-left: 32px;
		margin-right: 32px;
		margin-top: 4px;
		margin-bottom: 4px;
		background-color: rgba(239,68,68,0.08);
		border-radius: 8px;
		padding: 10px;
		border-width: 1px;
		border-color: #EF4444;
	}

	/* 工具标签 */
	.tool-badge {
		background-color: #E5E7EB;
		border-radius: 4px;
		padding-left: 6px;
		padding-right: 6px;
		padding-top: 2px;
		padding-bottom: 2px;
		margin-bottom: 6px;
	}

	.tool-badge-text {
		font-size: 10px;
		color: var(--rice-text-color-2);
		font-weight: bold;
	}

	/* 气泡内的图片 */
	.bubble-image {
		width: 200px;
		max-height: 300px;
		border-radius: 10px;
		margin-bottom: 4px;
	}

	/* 用户文字 - 白色字，粉底由父容器提供 */
	.text-user {
		font-size: 15px;
		color: var(--rice-background-2);
		line-height: 22px;
		white-space: normal;
	}

	/* AI 文字 - 深色字，白底由父容器提供 */
	.text-assistant {
		font-size: 15px;
		color: var(--rice-text-color);
		line-height: 22px;
		white-space: normal;
	}

	/* 工具文字 */
	.text-tool {
		font-size: 13px;
		color: var(--rice-text-color-2);
		line-height: 20px;
	}

	/* 流式光标 - 粉色 */
	.cursor {
		color: #FB8FAB;
		font-weight: bold;
	}

	/* 长按按下态 */
	.bubble-pressed {
		opacity: 0.65;
	}

	/* 思考内容折叠区 */
	.thinking-wrap {
		margin-bottom: 6px;
		padding: 4px 0;
	}
	.thinking-toggle {
		font-size: 11px;
		color: #D1D5DB;
	}
	.thinking-text {
		font-size: 12px;
		color: #9CA3AF;
		line-height: 18px;
		margin-top: 2px;
		white-space: pre-wrap;
		padding-left: 8px;
		border-left-width: 1px;
		border-left-color: #E5E7EB;
		border-left-style: solid;
	}
</style>
