<template>
	<view :class="bubbleClass">
		<!-- 工具名称标签（在内容上方） -->
		<view v-if="role == 'toolResult'" class="tool-badge">
			<text class="tool-badge-text">{{toolName}}</text>
		</view>

		<!-- 用户消息：单气泡（保留换行符） -->
		<view v-if="role == 'user'" class="user-row">
			<view class="user-bubble" :class="isPressed ? 'bubble-pressed' : ''"
				@touchstart="onBubbleTouchStart($event as UniTouchEvent)"
				@touchmove="onBubbleTouchMove($event as UniTouchEvent)"
				@touchend="onBubbleTouchEnd">
				<!-- 图片消息 -->
				<image v-if="msgType == 'image' && imageUrl != ''" :src="imageUrl" class="bubble-image" mode="widthFix" />
				<!-- 文本消息（保留换行） -->
				<text v-if="msgType != 'image' && content != ''" class="text-user">{{content}}<text v-if="isStreaming" class="cursor">|</text></text>
			</view>
			<image v-if="userAvatar != ''" :src="userAvatar" class="chat-avatar user-avatar-image" mode="aspectFill" />
			<view v-else class="chat-avatar user-avatar">
				<text class="chat-avatar-text">{{userInitial}}</text>
			</view>
		</view>

		<!-- 交错思维链时间线（blocks 模式） -->
		<view v-if="role == 'assistant' && displayBlocks.length > 0" class="ai-row">
			<image v-if="agentAvatar != ''" :src="agentAvatar" class="chat-avatar ai-avatar-image" mode="aspectFill" />
			<view v-else class="chat-avatar ai-avatar">
				<text class="chat-avatar-text">AI</text>
			</view>
			<view class="ai-content timeline-content" :class="isPressed ? 'bubble-pressed' : ''"
				@touchstart="onBubbleTouchStart($event as UniTouchEvent)"
				@touchmove="onBubbleTouchMove($event as UniTouchEvent)"
				@touchend="onBubbleTouchEnd">
				<!-- 思考过程：thinking + toolCall 统一收进一个容器 -->
				<view v-if="reasoningBlocks.length > 0" class="reasoning-panel">
					<view class="reasoning-header" @click.stop="thinkingExpanded = !thinkingExpanded">
						<text class="thinking-step-icon">{{thinkingExpanded ? '▾' : '▸'}}</text>
						<text class="thinking-step-label">思考过程</text>
					</view>
					<view v-if="thinkingExpanded == true" class="reasoning-body">
						<view v-for="(block, bi) in reasoningBlocks" :key="'reasoning-' + bi" class="block-entry">
							<text v-if="block.type == 'thinking'" class="thinking-step-text">{{block.thinking}}</text>
							<view v-else-if="block.type == 'toolCall'" class="tool-call-step" @click.stop="toggleToolCallExpand(bi)">
								<view class="tool-call-card">
									<view class="tool-call-card-header">
										<view class="tool-call-card-left">
											<text class="tool-call-card-name">{{getToolDisplayName(block.name)}}</text>
										</view>
										<view class="tool-call-card-right">
											<text v-if="block.ts != null && block.ts > 0 && (_renderSwitch == true || _renderSwitch == false)" :key="'elapsed-' + bi + '-' + timerTick + '-' + _renderSwitch" class="tool-call-elapsed">{{getToolElapsed(block)}}</text>
											<text class="tool-call-chevron">{{getToolCallExpanded(bi) ? '▾' : '▸'}}</text>
										</view>
									</view>
									<view v-if="getToolCallExpanded(bi) == true" class="tool-call-card-detail">
										<view class="tool-detail-section">
											<text class="tool-detail-label">参数</text>
											<text class="tool-detail-value">{{block.args}}</text>
										</view>
										<view v-if="block.status == 'completed' && block.result != null && block.result != ''" class="tool-detail-section">
											<text class="tool-detail-label">结果</text>
											<text class="tool-detail-value">{{block.result}}</text>
										</view>
									</view>
								</view>
							</view>
						</view>
					</view>
				</view>
				<text v-if="timelineAnswerText != ''" class="text-assistant-pre">{{timelineAnswerText}}<text v-if="showTimelineCursor == true" class="cursor">|</text></text>
			</view>
		</view>

		<!-- AI 分段模式：每段独立一行带头像（无 blocks 时） -->
		<template v-for="(segment, si) in contentLines" v-if="role == 'assistant' && displayBlocks.length == 0 && msgSegmentation == true && msgType != 'image'">
			<view class="ai-row">
				<image v-if="agentAvatar != ''" :src="agentAvatar" class="chat-avatar ai-avatar-image" mode="aspectFill" />
				<view v-else class="chat-avatar ai-avatar">
					<text class="chat-avatar-text">AI</text>
				</view>
				<view class="ai-content" :class="isPressed ? 'bubble-pressed' : ''"
					@touchstart="onBubbleTouchStart($event as UniTouchEvent)"
					@touchmove="onBubbleTouchMove($event as UniTouchEvent)"
					@touchend="onBubbleTouchEnd">
					<!-- 思考内容——仅首段显示 -->
<view v-if="si == 0 && thinking != '' && hideThinking == false" class="thinking-wrap" @click.stop="thinkingExpanded = !thinkingExpanded">
						<text class="thinking-toggle">{{thinkingExpanded ? '▾' : '▸'}} 思考过程</text>
						<text v-if="thinkingExpanded == true" class="thinking-text">{{thinking}}</text>
					</view>
					<text class="text-assistant">{{segment.text}}<text v-if="isStreaming && segment.isLast" class="cursor">|</text></text>
				</view>
			</view>
		</template>

		<!-- AI 非分段模式：单行头像 + 气泡（含图片/思考，无 blocks 时） -->
		<view v-if="role == 'assistant' && displayBlocks.length == 0 && (msgSegmentation == false || msgType == 'image')" class="ai-row">
			<image v-if="agentAvatar != ''" :src="agentAvatar" class="chat-avatar ai-avatar-image" mode="aspectFill" />
			<view v-else class="chat-avatar ai-avatar">
				<text class="chat-avatar-text">AI</text>
			</view>
			<view class="ai-content" :class="isPressed ? 'bubble-pressed' : ''"
				@touchstart="onBubbleTouchStart($event as UniTouchEvent)"
				@touchmove="onBubbleTouchMove($event as UniTouchEvent)"
				@touchend="onBubbleTouchEnd">
				<!-- 思考内容——默认折叠 -->
				<view v-if="thinking != '' && hideThinking == false" class="thinking-wrap" @click.stop="thinkingExpanded = !thinkingExpanded">
					<text class="thinking-toggle">{{thinkingExpanded ? '▾' : '▸'}} 思考过程</text>
					<text v-if="thinkingExpanded == true" class="thinking-text">{{thinking}}</text>
				</view>
				<!-- 图片消息（独占一个气泡） -->
				<view v-if="msgType == 'image' && imageUrl != ''" class="ai-content-no-bg">
					<image :src="imageUrl" class="bubble-image" mode="widthFix" />
				</view>
				<!-- 非分段文本 -->
				<text v-if="msgType != 'image'" class="text-assistant-pre">{{content}}<text v-if="isStreaming" class="cursor">|</text></text>
			</view>
		</view>

		<!-- 工具消息：纯文本 -->
		<text v-if="role == 'toolResult'" :class="textClass">{{content}}<text v-if="isStreaming" class="cursor">|</text></text>
	</view>
</template>

<script lang="uts">
	/**
	 * ChatBubble 组件 - 聊天气泡
	 * 扁平化粉白主题
	 */
	type ContentSegment = {
		text: string
		isLast: boolean
	}
	type DisplayBlock = {
		type: string
		text: string
		thinking: string
		name: string
		args: string
		ts: number
		finished_ts: number
		status: string
		result: string
	}
	export default {
		props: {
			role: {
				type: String,
				default: 'user'
			},
			content: {
				type: String,
				default: ''
			},
			msgType: {
				type: String,
				default: 'text'
			},
			imageUrl: {
				type: String,
				default: ''
			},
			toolName: {
				type: String,
				default: ''
			},
			thinking: {
				type: String,
				default: ''
			},
			blocks: {
				type: Array,
				default: () => []
			},
			msgSegmentation: {
				type: Boolean,
				default: true
			},
			hideThinking: {
				type: Boolean,
				default: false
			},
			isError: {
				type: Boolean,
				default: false
			},
			isStreaming: {
				type: Boolean,
				default: false
			},
			userNickname: {
				type: String,
				default: ''
			},
			userAvatar: {
				type: String,
				default: ''
			},
			agentAvatar: {
				type: String,
				default: ''
			},
			cancelToken: {
				type: Number,
				default: 0
			}
		},
		data() {
			return {
				/** 长按检测 */
				touchStartX: 0 as number,
				touchStartY: 0 as number,
				longpressTick: 0 as number,
				longpressTimer: -1 as number,
				longpressTriggered: false as boolean,
				/** 长按按下态（视觉反馈） */
				isPressed: false as boolean,
				/** 思考内容折叠态 */
				thinkingExpanded: false as boolean,
				toolCallExpanded: [] as boolean[],
				/** 计时器是否在运行（递归 setTimeout 控制） */
				timerRunning: false as boolean,
				/** 渲染开关 — setInterval 里 toggle 触发 v-if 重渲染 */
				_renderSwitch: false as boolean,
				/** 计时器 tick 计数器，用于触发耗时重新渲染 */
				timerTick: 0 as number,
			}
		},
		watch: {
			cancelToken(newVal: number, oldVal: number) {
				if (newVal != oldVal) {
					this.cancelLongpress()
				}
			},
			thinking(newVal: string, oldVal: string) {
				// thinking 从空变为非空 + 正在流式 → 自动展开
				if (oldVal == '' && newVal != '' && this.isStreaming == true) {
					this.thinkingExpanded = true
				}
				// thinking 从非空变为空 → 自动折叠
				if (oldVal != '' && newVal == '') {
					this.thinkingExpanded = false
				}
			},
			blocks: {
				handler(newBlocks: UTSJSONObject[]) {
					if (this.isStreaming == true && newBlocks.length > 0) {
						// 流式阶段只要出现 thinking，就展开统一的思考过程容器
						const lastBlock = newBlocks[newBlocks.length - 1]
						if (lastBlock != null && (lastBlock['type'] as string) == 'thinking') {
							this.thinkingExpanded = true
						}
					}
					// 启动/停止工具调用耗时计时器
				let hasRunning = false
				for (let i = 0; i < this.displayBlocks.length; i++) {
					if (this.displayBlocks[i].status == 'running') {
						hasRunning = true
						break
					}
				}
				if (hasRunning == true && this.timerRunning == false) {
					this.timerRunning = true
					this.tick()
				}
				if (hasRunning == false && this.timerRunning == true) {
					this.timerRunning = false
				}
				},
				deep: true
			},
			isStreaming(newVal: boolean, oldVal: boolean) {
				// 开始流式 + thinking 不为空 → 自动展开
				if (newVal == true && oldVal == false && this.thinking != '') {
					this.thinkingExpanded = true
				}
				// 流式结束 → 自动折叠 + 停止计时
				if (newVal == false && oldVal == true) {
					this.thinkingExpanded = false
					this.timerRunning = false
				}
			}
		},
		unmounted() {
			this.timerRunning = false
		},
		computed: {
			/** 将 blocks (UTSJSONObject[]) 转为有类型的 DisplayBlock[]，避免模板中类型推断问题 */
			displayBlocks(): DisplayBlock[] {
				const _tick = this.timerTick  // 强制依赖 timerTick，每秒刷新 UI
				const now = Date.now()
				const result: DisplayBlock[] = []
				for (let i = 0; i < this.blocks.length; i++) {
					const b = this.blocks[i] as UTSJSONObject
					const bt = b['type'] as string
					const blockType = bt != null ? bt : ''
					let blockText = ''
					let blockThinking = ''
					let blockName = ''
					let blockArgs = ''
					let blockTs = 0
					let blockFt = 0
					let blockSt = ''
					let blockResult = ''
					if (blockType == 'text') {
						const txt = b['text'] as string
						blockText = txt != null ? txt : ''
					} else if (blockType == 'thinking') {
						const thk = b['thinking'] as string
						blockThinking = thk != null ? thk : ''
					} else if (blockType == 'toolCall') {
						const nm = b['name'] as string
						const ag = b['arguments'] as string
						const rawTs = b['ts']
						let tTs = 0
						if (rawTs != null) { tTs = rawTs as number }
						const rawFt = b['finished_ts']
						let tFt = 0
						if (rawFt != null) { tFt = rawFt as number }
						const rawSt = b['status']
						let tSt = ''
						if (rawSt != null) { tSt = rawSt as string }
						const rawResult = b['result']
						let tResult = ''
						if (rawResult != null) { tResult = rawResult as string }
						blockName = nm != null ? nm : ''
						blockArgs = ag != null ? ag : ''
						blockTs = tTs
						blockFt = tFt
						blockSt = tSt
						blockResult = tResult
					}
					// 过滤无名的 toolCall 块
					if (blockType == 'toolCall' && blockName == '') {
						continue
					}
					result.push({
						type: blockType,
						text: blockText,
						thinking: blockThinking,
						name: blockName,
						args: blockArgs,
						ts: blockTs != null ? blockTs : 0,
						finished_ts: blockFt != null ? blockFt : 0,
						status: blockSt != null ? blockSt : '',
						result: blockResult != null ? blockResult : '',
					} as DisplayBlock)
				}
				return result
			},
			/** 思考过程块：thinking 与 toolCall 都属于同一个推理容器 */
			reasoningBlocks(): DisplayBlock[] {
				const result: DisplayBlock[] = []
				for (let i = 0; i < this.displayBlocks.length; i++) {
					const block = this.displayBlocks[i]
					if (block.type == 'thinking' || block.type == 'toolCall') {
						result.push(block)
					}
				}
				return result
			},
			/** 正文块：只汇总 text，避免 thinking 被“思考1/2”割裂 */
			timelineAnswerText(): string {
				let text = ''
				for (let i = 0; i < this.displayBlocks.length; i++) {
					const block = this.displayBlocks[i]
					if (block.type == 'text' && block.text != '') {
						text += block.text
					}
				}
				return text
			},
			showTimelineCursor(): boolean {
				if (this.isStreaming != true) {
					return false
				}
				if (this.displayBlocks.length == 0) {
					return false
				}
				const last = this.displayBlocks[this.displayBlocks.length - 1]
				return last.type == 'text'
			},
			/** 按段落分段（连续空行分隔），单换行保留在段落内 */
			contentLines(): ContentSegment[] {
				const text = this.content as string
				if (text == '') {
					return []
				}
				const lines = text.split('\n')
				const result: ContentSegment[] = []
				let para = ''
				for (let i = 0; i < lines.length; i++) {
					const raw = lines[i]
					if (raw.trim() == '') {
						// 空行 = 段落分隔符
						if (para != '') {
							result.push({
								text: para.trim(),
								isLast: false
							} as ContentSegment)
							para = ''
						}
					} else {
						if (para != '') {
							para += '\n'
						}
						para += raw
					}
				}
				if (para != '') {
					result.push({
						text: para.trim(),
						isLast: false
					} as ContentSegment)
				}
				if (result.length > 0) {
					result[result.length - 1].isLast = true
				}
				return result
			},

			/** 将 any 类型转 boolean */
			isErrorBool(): boolean {
				return this.isError == true
			},
			isStreamingBool(): boolean {
				return this.isStreaming == true
			},

			/** 用户头像首字母 */
			userInitial(): string {
				const name = this.userNickname as string
				if (name != null && name != '') {
					return name.substring(0, 1)
				}
				return 'U'
			},

			bubbleClass() : string {
				if (this.role == 'user') {
					return 'bubble-user'
				}
				if (this.role == 'assistant') {
					return 'bubble-assistant'
				}
				if (this.role == 'toolResult') {
					if (this.isErrorBool) {
						return 'bubble-tool-error'
					}
					return 'bubble-tool'
				}
				return 'bubble-user'
			},
			textClass() : string {
				if (this.role == 'user') {
					return 'text-user'
				}
				if (this.role == 'assistant') {
					return 'text-assistant'
				}
				if (this.role == 'toolResult') {
					return 'text-tool'
				}
				return 'text-user'
			}
		},
		methods: {
			/** 递归计时 —— 每秒自检，running 停止则终止递归 */
			tick() {
				if (this.timerRunning == false) return
				this.timerTick = this.timerTick + 1
				this._renderSwitch = !this._renderSwitch
				// 自检：没有 running 状态的工具则停止
				let anyRunning = false
				for (let i = 0; i < this.displayBlocks.length; i++) {
					if (this.displayBlocks[i].status == 'running') {
						anyRunning = true
						break
					}
				}
				if (anyRunning == false) {
					this.timerRunning = false
					return
				}
				setTimeout(() => { this.tick() }, 1000)
			},
			/** 格式化工具调用耗时 */
			getToolElapsed(block: DisplayBlock): string {
				const _tick = this.timerTick  // bind reactivity for live timing
				const ts = block.ts
				const finished = block.finished_ts
				if (ts == null || ts == 0) return ''
				if (finished != null && finished > 0) {
					const elapsed = ((finished - ts) / 1000)
					return elapsed.toFixed(1) + 's'
				}
				const now = Date.now()
				const elapsed = ((now - ts) / 1000)
				return elapsed.toFixed(1) + 's'
			},
			/** 获取工具状态图标 */
			getToolStatus(block: DisplayBlock): string {
				const status = block.status
				if (status == 'running') return '⏳'
				if (status == 'completed') return '✅'
				if (status == 'error') return '❌'
				if (status == 'pending') return '🔧'
				return '🔧'
			},
			/** 获取时间线节点 dot 样式类 */
			getDotClass(block: DisplayBlock): string {
				if (block.type == 'thinking') return 'dot-thinking'
				if (block.type == 'text') return 'dot-text'
				if (block.type == 'toolCall') {
					if (block.status == 'running') return 'dot-running'
					if (block.status == 'completed') return 'dot-completed'
					if (block.status == 'error') return 'dot-error'
					return 'dot-pending'
				}
				return 'dot-default'
			},
			/** 工具图标 */
			getToolIcon(block: DisplayBlock): string {
				const name = block.name
				if (name == 'file_read' || name == 'file_write' || name == 'file_delete' || name == 'file_list' || name == 'file_info' || name == 'directory_create') return '📁'
				if (name == 'memory_search' || name == 'memory_buffer_write' || name == 'memory_core_list' || name == 'memory_core_save' || name == 'memory_core_forget') return '🧠'
				if (name == 'web_search') return '🌐'
				return '🔧'
			},
			/** 工具名友好显示 */
			getToolDisplayName(name: string): string {
				if (name == 'file_read') return '读取文件'
				if (name == 'file_write') return '写入文件'
				if (name == 'file_delete') return '删除文件'
				if (name == 'file_list') return '列出文件'
				if (name == 'file_info') return '文件信息'
				if (name == 'directory_create') return '创建目录'
				if (name == 'memory_search') return '搜索记忆'
				if (name == 'memory_buffer_write') return '写短缓存'
				if (name == 'memory_core_list') return '列出记忆'
				if (name == 'memory_core_save') return '保存记忆'
				if (name == 'memory_core_forget') return '遗忘记忆'
				if (name == 'web_search') return '网络搜索'
				return name
			},
			/** 切换工具调用的展开/折叠 */
			toggleToolCallExpand(index: number) {
				while (this.toolCallExpanded.length <= index) {
					this.toolCallExpanded.push(false)
				}
				this.toolCallExpanded[index] = !(this.toolCallExpanded[index] == true)
			},
			/** 获取工具调用展开状态 */
			getToolCallExpanded(index: number): boolean {
				if (index >= this.toolCallExpanded.length) return false
				return this.toolCallExpanded[index] == true
			},
			/** 取消长按状态 */
			cancelLongpress() {
				if (this.longpressTimer != -1) {
					clearInterval(this.longpressTimer)
					this.longpressTimer = -1
				}
				this.longpressTriggered = false
				this.isPressed = false
			},

			/** 触摸开始 — 启动长按计时 */
			onBubbleTouchStart(e: UniTouchEvent) {
				this.touchStartX = e.touches[0].screenX
				this.touchStartY = e.touches[0].screenY
				this.longpressTick = 0
				this.longpressTriggered = false
				this.isPressed = true
				if (this.longpressTimer != -1) {
					clearInterval(this.longpressTimer)
				}
				this.longpressTimer = setInterval(() => {
					this.longpressTick++
					if (this.longpressTick >= 5) {
						clearInterval(this.longpressTimer)
						this.longpressTimer = -1
						if (this.longpressTriggered == true) {
							return
						}
						this.longpressTriggered = true
						this.$emit('bubbleLongpress')
					}
				}, 100)
			},

			/** 触摸移动 — 距离过大取消长按 */
			onBubbleTouchMove(e: UniTouchEvent) {
				if (this.longpressTimer == -1) { return }
				const dx = e.touches[0].screenX - this.touchStartX
				const dy = e.touches[0].screenY - this.touchStartY
				if (Math.abs(dx) > 30 || Math.abs(dy) > 30) {
					this.cancelLongpress()
				}
			},

			/** 触摸结束 — 清理状态 */
			onBubbleTouchEnd() {
				this.cancelLongpress()
				this.longpressTriggered = false
				this.isPressed = false
			},
		}
	}
</script>

