<template>
	<view :class="bubbleClass">
		<view v-if="role == 'user'" class="user-row">
			<view class="user-stack">
				<text v-if="userDisplayName != ''" class="speaker-name user-speaker-name">{{userDisplayName}}</text>
				<view class="user-bubble" :class="isPressed ? 'bubble-pressed' : ''"
					@touchstart="onBubbleTouchStart($event as UniTouchEvent)"
					@touchmove="onBubbleTouchMove($event as UniTouchEvent)"
					@touchend="onBubbleTouchEnd">
					<view v-for="(part, pi) in contentParts" :key="'user-part-' + pi" class="part-wrap" :class="isLastContentPart(pi) == true ? '' : 'part-wrap-spaced'">
						<view v-if="part.type == 'image' && part.url != ''" class="image-part">
							<image :src="part.url" class="bubble-image" mode="widthFix" />
							<view v-if="part.caption != ''" class="caption-card user-caption-card">
								<text class="caption-label user-caption-label">图片转述</text>
								<text class="caption-text user-caption-text">{{part.caption}}</text>
							</view>
						</view>
						<text v-else-if="part.type == 'plain' || part.type == 'location'" class="text-user">{{part.text}}<text v-if="isStreaming == true && isLastContentPart(pi) == true" class="cursor">|</text></text>
						<view v-else class="media-chip user-media-chip">
							<text class="media-chip-text user-media-text">{{getPartLabel(part)}}</text>
						</view>
					</view>
					<text v-if="contentParts.length == 0 && content != ''" class="text-user">{{content}}<text v-if="isStreaming" class="cursor">|</text></text>
				</view>
			</view>
			<image v-if="userAvatar != ''" :src="userAvatar" class="chat-avatar user-avatar-image" mode="aspectFill" @click.stop="onAvatarClick" />
			<view v-else class="chat-avatar user-avatar" @click.stop="onAvatarClick">
				<text class="chat-avatar-text">{{userInitial}}</text>
			</view>
		</view>

		<view v-else-if="role == 'assistant' && msgSegmentation == true && renderContentParts.length > 1" class="assistant-segment-list">
			<view v-for="(part, pi) in renderContentParts" :key="'assistant-segment-' + pi" class="ai-row assistant-segment-row">
				<image v-if="agentAvatar != ''" :src="agentAvatar" class="chat-avatar ai-avatar-image" mode="aspectFill" @click.stop="onAvatarClick" />
				<view v-else class="chat-avatar ai-avatar" @click.stop="onAvatarClick">
					<text class="chat-avatar-text">AI</text>
				</view>
				<view class="ai-stack">
					<text v-if="assistantName != ''" class="speaker-name assistant-name">{{assistantName}}</text>
					<view class="ai-content timeline-content" :class="isPressed ? 'bubble-pressed' : ''"
						@touchstart="onBubbleTouchStart($event as UniTouchEvent)"
						@touchmove="onBubbleTouchMove($event as UniTouchEvent)"
						@touchend="onBubbleTouchEnd">
						<view v-if="pi == 0 && reasoningBlocks.length > 0 && hideThinking == false" class="reasoning-panel">
							<view class="reasoning-header" @click.stop="thinkingExpanded = !thinkingExpanded">
								<oui-icon-unix :name="thinkingExpanded ? 'down' : 'right'" size="9px" color="var(--rice-text-color-3)" />
								<text class="thinking-step-label">思考过程</text>
							</view>
							<view v-if="thinkingExpanded == true" class="reasoning-body">
								<view v-for="(block, bi) in reasoningBlocks" :key="'reasoning-segment-' + bi" class="block-entry">
									<text v-if="block.type == 'thinking'" class="thinking-step-text">{{block.thinking}}</text>
									<view v-else-if="block.type == 'toolCall'" class="tool-call-step" @click.stop="toggleToolCallExpand(bi)">
										<view class="tool-call-card">
											<view class="tool-call-card-header">
												<view class="tool-call-card-left">
													<text class="tool-call-status">{{getToolStatusText(block)}}</text>
													<text class="tool-call-card-name">{{getToolDisplayName(block.name)}}</text>
												</view>
												<view class="tool-call-card-right">
													<text v-if="block.ts > 0 && (_renderSwitch == true || _renderSwitch == false)" :key="'elapsed-segment-' + bi + '-' + timerTick + '-' + _renderSwitch" class="tool-call-elapsed">{{getToolElapsed(block)}}</text>
													<text class="tool-call-chevron">{{getToolCallExpanded(bi) ? '收起' : '详情'}}</text>
												</view>
											</view>
											<view v-if="getToolCallExpanded(bi) == true" class="tool-call-card-detail">
												<view class="tool-detail-section">
													<text class="tool-detail-label">参数</text>
													<text class="tool-detail-value">{{block.args}}</text>
												</view>
												<view v-if="block.result != ''" class="tool-detail-section">
													<text class="tool-detail-label">结果</text>
													<text class="tool-detail-value">{{block.result}}</text>
												</view>
											</view>
										</view>
									</view>
								</view>
							</view>
						</view>
						<view v-if="part.type == 'image' && part.url != ''" class="image-part">
							<image :src="part.url" class="bubble-image" mode="widthFix" />
							<view v-if="part.caption != ''" class="caption-card">
								<text class="caption-label">图片转述</text>
								<text class="caption-text">{{part.caption}}</text>
							</view>
						</view>
						<text v-else-if="part.type == 'plain' || part.type == 'location'" class="text-assistant-pre">{{part.text}}<text v-if="isStreaming == true && isLastContentPart(pi) == true" class="cursor">|</text></text>
						<view v-else class="media-chip">
							<text class="media-chip-text">{{getPartLabel(part)}}</text>
						</view>
					</view>
				</view>
			</view>
		</view>

		<view v-else-if="role == 'assistant'" class="ai-row">
			<image v-if="agentAvatar != ''" :src="agentAvatar" class="chat-avatar ai-avatar-image" mode="aspectFill" @click.stop="onAvatarClick" />
			<view v-else class="chat-avatar ai-avatar" @click.stop="onAvatarClick">
				<text class="chat-avatar-text">AI</text>
			</view>
			<view class="ai-stack">
				<text v-if="assistantName != ''" class="speaker-name assistant-name">{{assistantName}}</text>
				<view class="ai-content timeline-content" :class="isPressed ? 'bubble-pressed' : ''"
					@touchstart="onBubbleTouchStart($event as UniTouchEvent)"
					@touchmove="onBubbleTouchMove($event as UniTouchEvent)"
					@touchend="onBubbleTouchEnd">
					<view v-if="reasoningBlocks.length > 0 && hideThinking == false" class="reasoning-panel">
						<view class="reasoning-header" @click.stop="thinkingExpanded = !thinkingExpanded">
							<text class="thinking-step-icon">{{thinkingExpanded ? '⌄' : '›'}}</text>
							<text class="thinking-step-label">思考过程</text>
						</view>
						<view v-if="thinkingExpanded == true" class="reasoning-body">
							<view v-for="(block, bi) in reasoningBlocks" :key="'reasoning-' + bi" class="block-entry">
								<text v-if="block.type == 'thinking'" class="thinking-step-text">{{block.thinking}}</text>
								<view v-else-if="block.type == 'toolCall'" class="tool-call-step" @click.stop="toggleToolCallExpand(bi)">
									<view class="tool-call-card">
										<view class="tool-call-card-header">
											<view class="tool-call-card-left">
												<text class="tool-call-status">{{getToolStatusText(block)}}</text>
												<text class="tool-call-card-name">{{getToolDisplayName(block.name)}}</text>
											</view>
											<view class="tool-call-card-right">
												<text v-if="block.ts > 0 && (_renderSwitch == true || _renderSwitch == false)" :key="'elapsed-' + bi + '-' + timerTick + '-' + _renderSwitch" class="tool-call-elapsed">{{getToolElapsed(block)}}</text>
												<text class="tool-call-chevron">{{getToolCallExpanded(bi) ? '收起' : '详情'}}</text>
											</view>
										</view>
										<view v-if="getToolCallExpanded(bi) == true" class="tool-call-card-detail">
											<view class="tool-detail-section">
												<text class="tool-detail-label">参数</text>
												<text class="tool-detail-value">{{block.args}}</text>
											</view>
											<view v-if="block.result != ''" class="tool-detail-section">
												<text class="tool-detail-label">结果</text>
												<text class="tool-detail-value">{{block.result}}</text>
											</view>
										</view>
									</view>
								</view>
							</view>
						</view>
					</view>

					<view v-for="(part, pi) in renderContentParts" :key="'assistant-part-' + pi" class="part-wrap" :class="isLastContentPart(pi) == true ? '' : 'part-wrap-spaced'">
						<view v-if="part.type == 'image' && part.url != ''" class="image-part">
							<image :src="part.url" class="bubble-image" mode="widthFix" />
							<view v-if="part.caption != ''" class="caption-card">
								<text class="caption-label">图片转述</text>
								<text class="caption-text">{{part.caption}}</text>
							</view>
						</view>
						<text v-else-if="part.type == 'plain' || part.type == 'location'" class="text-assistant-pre">{{part.text}}<text v-if="isStreaming == true && isLastContentPart(pi) == true" class="cursor">|</text></text>
						<view v-else class="media-chip">
							<text class="media-chip-text">{{getPartLabel(part)}}</text>
						</view>
					</view>
					<text v-if="renderContentParts.length == 0 && content != ''" class="text-assistant-pre">{{content}}<text v-if="isStreaming" class="cursor">|</text></text>
					<text v-if="renderContentParts.length == 0 && content == '' && isStreaming == true" class="text-assistant-pre"><text class="cursor">|</text></text>
				</view>
			</view>
		</view>

		<view v-else-if="role == 'toolResult'" class="tool-fallback">
			<view v-if="toolName != ''" class="tool-badge">
				<text class="tool-badge-text">{{toolName}}</text>
			</view>
			<text :class="textClass">{{content}}<text v-if="isStreaming" class="cursor">|</text></text>
		</view>
	</view>
</template>

<script lang="uts">
	import {
		type ChatContentPartView,
		type ChatDisplayBlock,
		buildChatContentParts,
		buildChatDisplayBlocks,
		buildChatFallbackMessageParts,
		buildChatRenderContentParts,
		formatChatToolElapsed,
		getChatPartLabel,
		getChatToolDisplayName,
		getChatToolStatusText,
		hasRunningChatToolBlock,
	} from '@/utils/chat-bubble-render.uts'

	export default {
		props: {
			role: {
				type: String,
				default: 'user'
			},
			content: {
				type: String,
				default: ''
			},
			parts: {
				type: Array,
				default: () => []
			},
			msgType: {
				type: String,
				default: 'text'
			},
			imageUrl: {
				type: String,
				default: ''
			},
			toolName: {
				type: String,
				default: ''
			},
			thinking: {
				type: String,
				default: ''
			},
			msgSegmentation: {
				type: Boolean,
				default: true
			},
			hideThinking: {
				type: Boolean,
				default: false
			},
			isError: {
				type: Boolean,
				default: false
			},
			isStreaming: {
				type: Boolean,
				default: false
			},
			userNickname: {
				type: String,
				default: ''
			},
			userDisplayName: {
				type: String,
				default: ''
			},
			userAvatar: {
				type: String,
				default: ''
			},
			agentAvatar: {
				type: String,
				default: ''
			},
			assistantName: {
				type: String,
				default: ''
			},
			cancelToken: {
				type: Number,
				default: 0
			}
		},
		data() {
			return {
				touchStartX: 0 as number,
				touchStartY: 0 as number,
				longpressTick: 0 as number,
				longpressTimer: -1 as number,
				longpressTriggered: false as boolean,
				isPressed: false as boolean,
				thinkingExpanded: false as boolean,
				toolCallExpanded: [] as boolean[],
				timerRunning: false as boolean,
				_renderSwitch: false as boolean,
				timerTick: 0 as number,
			}
		},
		watch: {
			cancelToken(newVal: number, oldVal: number) {
				if (newVal != oldVal) {
					this.cancelLongpress()
				}
			},
			parts: {
				handler(_newParts: UTSJSONObject[]) {
					if (this.isStreaming == true && this.reasoningBlocks.length > 0) {
						this.thinkingExpanded = true
					}
					this.syncToolTimer()
				},
				deep: true
			},
			isStreaming(newVal: boolean, oldVal: boolean) {
				if (newVal == true && oldVal == false && this.reasoningBlocks.length > 0) {
					this.thinkingExpanded = true
				}
				if (newVal == false && oldVal == true) {
					this.thinkingExpanded = false
					this.timerRunning = false
				}
			}
		},
		unmounted() {
			this.timerRunning = false
		},
		computed: {
			messageParts(): UTSJSONObject[] {
				const raw = this.parts as UTSJSONObject[]
				if (raw != null && raw.length > 0) {
					return raw
				}
				return buildChatFallbackMessageParts(this.thinking, this.msgType, this.imageUrl, this.content)
			},
			displayBlocks(): ChatDisplayBlock[] {
				const _tick = this.timerTick
				return buildChatDisplayBlocks(this.messageParts)
			},
			reasoningBlocks(): ChatDisplayBlock[] {
				const result: ChatDisplayBlock[] = []
				for (let i = 0; i < this.displayBlocks.length; i++) {
					const block = this.displayBlocks[i]
					if (block.type == 'thinking' || block.type == 'toolCall') {
						result.push(block)
					}
				}
				return result
			},
			contentParts(): ChatContentPartView[] {
				return buildChatContentParts(this.messageParts)
			},
			renderContentParts(): ChatContentPartView[] {
				return buildChatRenderContentParts(this.contentParts, this.role, this.msgSegmentation)
			},
			isErrorBool(): boolean {
				return this.isError == true
			},
			userInitial(): string {
				const name = this.userNickname as string
				if (name != null && name != '') {
					return name.substring(0, 1)
				}
				return '我'
			},
			bubbleClass(): string {
				if (this.role == 'user') {
					return 'bubble-user'
				}
				if (this.role == 'assistant') {
					return 'bubble-assistant'
				}
				if (this.role == 'toolResult') {
					if (this.isErrorBool) {
						return 'bubble-tool-error'
					}
					return 'bubble-tool'
				}
				return 'bubble-user'
			},
			textClass(): string {
				if (this.role == 'toolResult') {
					return 'text-tool'
				}
				if (this.role == 'assistant') {
					return 'text-assistant'
				}
				return 'text-user'
			}
		},
		methods: {
			onAvatarClick() {
				this.$emit('avatarClick')
			},
			isLastContentPart(index: number): boolean {
				if (this.role == 'assistant') {
					return index == this.renderContentParts.length - 1
				}
				return index == this.contentParts.length - 1
			},
			syncToolTimer() {
				const hasRunning = hasRunningChatToolBlock(this.displayBlocks)
				if (hasRunning == true && this.timerRunning == false) {
					this.timerRunning = true
					this.tick()
				}
				if (hasRunning == false && this.timerRunning == true) {
					this.timerRunning = false
				}
			},
			tick() {
				if (this.timerRunning == false) { return }
				this.timerTick = this.timerTick + 1
				this._renderSwitch = !this._renderSwitch
				const anyRunning = hasRunningChatToolBlock(this.displayBlocks)
				if (anyRunning == false) {
					this.timerRunning = false
					return
				}
				setTimeout(() => { this.tick() }, 1000)
			},
			getToolElapsed(block: ChatDisplayBlock): string {
				const _tick = this.timerTick
				return formatChatToolElapsed(block)
			},
			getToolStatusText(block: ChatDisplayBlock): string {
				return getChatToolStatusText(block)
			},
			getToolDisplayName(name: string): string {
				return getChatToolDisplayName(name)
			},
			getPartLabel(part: ChatContentPartView): string {
				return getChatPartLabel(part)
			},
			toggleToolCallExpand(index: number) {
				while (this.toolCallExpanded.length <= index) {
					this.toolCallExpanded.push(false)
				}
				this.toolCallExpanded[index] = !(this.toolCallExpanded[index] == true)
			},
			getToolCallExpanded(index: number): boolean {
				if (index >= this.toolCallExpanded.length) return false
				return this.toolCallExpanded[index] == true
			},
			cancelLongpress() {
				if (this.longpressTimer != -1) {
					clearInterval(this.longpressTimer)
					this.longpressTimer = -1
				}
				this.longpressTriggered = false
				this.isPressed = false
			},
			onBubbleTouchStart(e: UniTouchEvent) {
				this.touchStartX = e.touches[0].screenX
				this.touchStartY = e.touches[0].screenY
				this.longpressTick = 0
				this.longpressTriggered = false
				this.isPressed = true
				if (this.longpressTimer != -1) {
					clearInterval(this.longpressTimer)
				}
				this.longpressTimer = setInterval(() => {
					this.longpressTick++
					if (this.longpressTick >= 5) {
						clearInterval(this.longpressTimer)
						this.longpressTimer = -1
						if (this.longpressTriggered == true) {
							return
						}
						this.longpressTriggered = true
						this.$emit('bubbleLongpress')
					}
				}, 100)
			},
			onBubbleTouchMove(e: UniTouchEvent) {
				if (this.longpressTimer == -1) { return }
				const dx = e.touches[0].screenX - this.touchStartX
				const dy = e.touches[0].screenY - this.touchStartY
				if (Math.abs(dx) > 30 || Math.abs(dy) > 30) {
					this.cancelLongpress()
				}
			},
			onBubbleTouchEnd() {
				this.cancelLongpress()
				this.longpressTriggered = false
				this.isPressed = false
			},
		}
	}
</script>

<style>
	.bubble-user {
		flex-direction: column;
		align-items: flex-end;
		margin-left: 58px;
		margin-right: 12px;
		margin-top: 9px;
		margin-bottom: 9px;
	}
	.user-row {
		flex-direction: row;
		align-items: flex-start;
		justify-content: flex-end;
		width: 100%;
	}
	.user-stack {
		flex-direction: column;
		align-items: flex-end;
		flex: 1;
		flex-shrink: 1;
		width: 0;
	}
	.user-bubble {
		background-color: #FFE7EF;
		border-radius: 18px;
		padding-left: 13px;
		padding-right: 13px;
		padding-top: 8px;
		padding-bottom: 7px;
		flex-shrink: 1;
		border-width: 1px;
		border-style: solid;
		border-color: rgba(251, 143, 171, 0.20);
	}
	.user-bubble:active {
		opacity: 0.75;
	}
	.ai-row {
		flex-direction: row;
		align-items: flex-start;
		width: 100%;
	}
	.ai-content {
		flex-shrink: 1;
		background-color: #FFFFFF;
		border-radius: 18px;
		padding-left: 12px;
		padding-right: 12px;
		padding-top: 10px;
		padding-bottom: 9px;
		border-width: 1px;
		border-style: solid;
		border-color: rgba(241, 229, 234, 0.92);
		box-shadow: 0 8px 20px rgba(216, 140, 165, 0.05);
	}
	.ai-content:active {
		background-color: #FFF7FA;
	}
	.ai-stack {
		flex-direction: column;
		align-items: flex-start;
		flex: 1;
		flex-shrink: 1;
		width: 0;
	}
	.speaker-name {
		font-size: 13px;
		color: rgba(17, 24, 39, 0.68);
		margin-top: 2px;
		margin-bottom: 4px;
		line-height: 16px;
	}
	.assistant-name {
		margin-left: 4px;
	}
	.user-speaker-name {
		margin-right: 4px;
	}
	.chat-avatar {
		width: 34px;
		height: 34px;
		border-radius: 17px;
		flex-shrink: 0;
		margin-top: 2px;
	}
	.chat-avatar-text {
		font-size: 12px;
		color: var(--rice-background-2);
		font-weight: bold;
	}
	.user-avatar {
		background-color: #F59AB7;
		margin-left: 9px;
		justify-content: center;
		align-items: center;
	}
	.user-avatar-image {
		margin-left: 9px;
	}
	.ai-avatar {
		background-color: #BDA8F5;
		margin-right: 9px;
		justify-content: center;
		align-items: center;
	}
	.ai-avatar-image {
		margin-right: 9px;
	}
	.assistant-segment-list {
		flex-direction: column;
		align-items: flex-start;
		width: 100%;
	}
	.assistant-segment-row {
		margin-bottom: 8px;
	}
	.bubble-assistant {
		flex-direction: column;
		align-items: flex-start;
		margin-left: 12px;
		margin-right: 58px;
		margin-top: 9px;
		margin-bottom: 9px;
	}
	.bubble-tool {
		flex-direction: column;
		align-items: flex-start;
		margin-left: 32px;
		margin-right: 32px;
		margin-top: 4px;
		margin-bottom: 4px;
		background-color: var(--rice-button-info-background);
		border-radius: 8px;
		padding: 10px;
	}
	.bubble-tool-error {
		flex-direction: column;
		align-items: flex-start;
		margin-left: 32px;
		margin-right: 32px;
		margin-top: 4px;
		margin-bottom: 4px;
		background-color: rgba(239,68,68,0.08);
		border-radius: 8px;
		padding: 10px;
		border-width: 1px;
		border-color: #EF4444;
	}
	.tool-fallback {
		flex-direction: column;
	}
	.tool-badge {
		background-color: #E5E7EB;
		border-radius: 4px;
		padding-left: 6px;
		padding-right: 6px;
		padding-top: 2px;
		padding-bottom: 2px;
		margin-bottom: 6px;
	}
	.tool-badge-text {
		font-size: 10px;
		color: var(--rice-text-color-2);
		font-weight: bold;
	}
	.part-wrap {
