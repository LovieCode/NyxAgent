<template>
	<view :class="bubbleClass">
		<!-- 工具名称标签（在内容上方） -->
		<view v-if="role == 'toolResult'" class="tool-badge">
			<text class="tool-badge-text">{{toolName}}</text>
		</view>

		<!-- 用户消息：单气泡（保留换行符） -->
		<view v-if="role == 'user'" class="user-row">
			<view class="user-bubble" :class="isPressed ? 'bubble-pressed' : ''"
				@touchstart="onBubbleTouchStart($event as UniTouchEvent)"
				@touchmove="onBubbleTouchMove($event as UniTouchEvent)"
				@touchend="onBubbleTouchEnd">
				<!-- 图片消息 -->
				<image v-if="msgType == 'image' && imageUrl != ''" :src="imageUrl" class="bubble-image" mode="widthFix" />
				<!-- 文本消息（保留换行） -->
				<text v-if="msgType != 'image' && content != ''" class="text-user">{{content}}<text v-if="isStreaming" class="cursor">|</text></text>
			</view>
			<image v-if="userAvatar != ''" :src="userAvatar" class="chat-avatar user-avatar-image" mode="aspectFill" />
			<view v-else class="chat-avatar user-avatar">
				<text class="chat-avatar-text">{{userInitial}}</text>
			</view>
		</view>

		<!-- 交错思维链时间线（blocks 模式） -->
		<view v-if="role == 'assistant' && displayBlocks.length > 0" class="ai-row">
			<image v-if="agentAvatar != ''" :src="agentAvatar" class="chat-avatar ai-avatar-image" mode="aspectFill" />
			<view v-else class="chat-avatar ai-avatar">
				<text class="chat-avatar-text">AI</text>
			</view>
			<view class="ai-content" :class="isPressed ? 'bubble-pressed' : ''"
				@touchstart="onBubbleTouchStart($event as UniTouchEvent)"
				@touchmove="onBubbleTouchMove($event as UniTouchEvent)"
				@touchend="onBubbleTouchEnd">
				<view v-for="(block, bi) in displayBlocks" :key="bi" class="block-entry">
					<!-- 思考块 -->
					<view v-if="block.type == 'thinking'" class="thinking-wrap" @click.stop="toggleBlockExpand(bi)">
						<text class="thinking-toggle">{{getBlockExpanded(bi) ? '▾' : '▸'}} {{thinkingCount > 1 ? ('思考 ' + (bi + 1)) : '思考过程'}}</text>
						<text v-if="getBlockExpanded(bi) == true" class="thinking-text">{{block.thinking}}</text>
					</view>
					<!-- 文本块 -->
					<text v-else-if="block.type == 'text'" class="text-assistant-pre">{{block.text}}<text v-if="isStreaming && bi == displayBlocks.length - 1 && displayBlocks[displayBlocks.length - 1].type == 'text'" class="cursor">|</text></text>
					<!-- 工具调用块 -->
					<view v-else-if="block.type == 'toolCall'" class="tool-call-block">
						<text class="tool-call-name">🔧 {{block.name}}</text>
						<text class="tool-call-args">{{block.args}}</text>
					</view>
				</view>
			</view>
		</view>

		<!-- AI 分段模式：每段独立一行带头像（无 blocks 时） -->
		<template v-for="(segment, si) in contentLines" v-if="role == 'assistant' && displayBlocks.length == 0 && msgSegmentation == true && msgType != 'image'">
			<view class="ai-row">
				<image v-if="agentAvatar != ''" :src="agentAvatar" class="chat-avatar ai-avatar-image" mode="aspectFill" />
				<view v-else class="chat-avatar ai-avatar">
					<text class="chat-avatar-text">AI</text>
				</view>
				<view class="ai-content" :class="isPressed ? 'bubble-pressed' : ''"
					@touchstart="onBubbleTouchStart($event as UniTouchEvent)"
					@touchmove="onBubbleTouchMove($event as UniTouchEvent)"
					@touchend="onBubbleTouchEnd">
					<!-- 思考内容——仅首段显示 -->
<view v-if="si == 0 && thinking != '' && hideThinking == false" class="thinking-wrap" @click.stop="thinkingExpanded = !thinkingExpanded">
						<text class="thinking-toggle">{{thinkingExpanded ? '▾' : '▸'}} 思考过程</text>
						<text v-if="thinkingExpanded == true" class="thinking-text">{{thinking}}</text>
					</view>
					<text class="text-assistant">{{segment.text}}<text v-if="isStreaming && segment.isLast" class="cursor">|</text></text>
				</view>
			</view>
		</template>

		<!-- AI 非分段模式：单行头像 + 气泡（含图片/思考，无 blocks 时） -->
		<view v-if="role == 'assistant' && displayBlocks.length == 0 && (msgSegmentation == false || msgType == 'image')" class="ai-row">
			<image v-if="agentAvatar != ''" :src="agentAvatar" class="chat-avatar ai-avatar-image" mode="aspectFill" />
			<view v-else class="chat-avatar ai-avatar">
				<text class="chat-avatar-text">AI</text>
			</view>
			<view class="ai-content" :class="isPressed ? 'bubble-pressed' : ''"
				@touchstart="onBubbleTouchStart($event as UniTouchEvent)"
				@touchmove="onBubbleTouchMove($event as UniTouchEvent)"
				@touchend="onBubbleTouchEnd">
				<!-- 思考内容——默认折叠 -->
				<view v-if="thinking != '' && hideThinking == false" class="thinking-wrap" @click.stop="thinkingExpanded = !thinkingExpanded">
					<text class="thinking-toggle">{{thinkingExpanded ? '▾' : '▸'}} 思考过程</text>
					<text v-if="thinkingExpanded == true" class="thinking-text">{{thinking}}</text>
				</view>
				<!-- 图片消息（独占一个气泡） -->
				<view v-if="msgType == 'image' && imageUrl != ''" class="ai-content-no-bg">
					<image :src="imageUrl" class="bubble-image" mode="widthFix" />
				</view>
				<!-- 非分段文本 -->
				<text v-if="msgType != 'image'" class="text-assistant-pre">{{content}}<text v-if="isStreaming" class="cursor">|</text></text>
			</view>
		</view>

		<!-- 工具消息：纯文本 -->
		<text v-if="role == 'toolResult'" :class="textClass">{{content}}<text v-if="isStreaming" class="cursor">|</text></text>
	</view>
</template>

<script lang="uts">
	/**
	 * ChatBubble 组件 - 聊天气泡
	 * 扁平化粉白主题
	 */
	type ContentSegment = {
		text: string
		isLast: boolean
	}
	type DisplayBlock = {
		type: string
		text: string
		thinking: string
		name: string
		args: string
	}
	export default {
		props: {
			role: {
				type: String,
				default: 'user'
			},
			content: {
				type: String,
				default: ''
			},
			msgType: {
				type: String,
				default: 'text'
			},
			imageUrl: {
				type: String,
				default: ''
			},
			toolName: {
				type: String,
				default: ''
			},
			thinking: {
				type: String,
				default: ''
			},
			blocks: {
				type: Array,
				default: () => []
			},
			msgSegmentation: {
				type: Boolean,
				default: true
			},
			hideThinking: {
				type: Boolean,
				default: false
			},
			isError: {
				type: Boolean,
				default: false
			},
			isStreaming: {
				type: Boolean,
				default: false
			},
			userNickname: {
				type: String,
				default: ''
			},
			userAvatar: {
				type: String,
				default: ''
			},
			agentAvatar: {
				type: String,
				default: ''
			},
			cancelToken: {
				type: Number,
				default: 0
			}
		},
		data() {
			return {
				/** 长按检测 */
				touchStartX: 0 as number,
				touchStartY: 0 as number,
				longpressTick: 0 as number,
				longpressTimer: -1 as number,
				longpressTriggered: false as boolean,
				/** 长按按下态（视觉反馈） */
				isPressed: false as boolean,
				/** 思考内容折叠态 */
				thinkingExpanded: false as boolean,
				/** 每个 thinking block 的展开状态（按块索引） */
				blocksExpanded: [] as boolean[],
			}
		},
		watch: {
			cancelToken(newVal: number, oldVal: number) {
				if (newVal != oldVal) {
					this.cancelLongpress()
				}
			},
			thinking(newVal: string, oldVal: string) {
				// thinking 从空变为非空 + 正在流式 → 自动展开
				if (oldVal == '' && newVal != '' && this.isStreaming == true) {
					this.thinkingExpanded = true
				}
				// thinking 从非空变为空 → 自动折叠
				if (oldVal != '' && newVal == '') {
					this.thinkingExpanded = false
				}
			},
			blocks: {
				handler(newBlocks: UTSJSONObject[]) {
					if (this.isStreaming == true && newBlocks.length > 0) {
						// Auto-expand new thinking blocks during streaming
						const lastBlock = newBlocks[newBlocks.length - 1]
						if (lastBlock != null && (lastBlock['type'] as string) == 'thinking') {
							while (this.blocksExpanded.length < newBlocks.length) {
								this.blocksExpanded.push(false)
							}
							this.blocksExpanded[newBlocks.length - 1] = true
						}
					}
				},
				deep: true
			},
			isStreaming(newVal: boolean, oldVal: boolean) {
				// 开始流式 + thinking 不为空 → 自动展开
				if (newVal == true && oldVal == false && this.thinking != '') {
					this.thinkingExpanded = true
				}
				// 流式结束 → 自动折叠
				if (newVal == false && oldVal == true) {
					this.thinkingExpanded = false
					this.blocksExpanded = []
				}
			}
		},
		computed: {
			/** 将 blocks (UTSJSONObject[]) 转为有类型的 DisplayBlock[]，避免模板中类型推断问题 */
			displayBlocks(): DisplayBlock[] {
				const result: DisplayBlock[] = []
				for (let i = 0; i < this.blocks.length; i++) {
					const b = this.blocks[i] as UTSJSONObject
					const bt = b['type'] as string
					const blockType = bt != null ? bt : ''
					let blockText = ''
					let blockThinking = ''
					let blockName = ''
					let blockArgs = ''
					if (blockType == 'text') {
						const txt = b['text'] as string
						blockText = txt != null ? txt : ''
					} else if (blockType == 'thinking') {
						const thk = b['thinking'] as string
						blockThinking = thk != null ? thk : ''
					} else if (blockType == 'toolCall') {
						const nm = b['name'] as string
						const ag = b['arguments'] as string
						blockName = nm != null ? nm : ''
						blockArgs = ag != null ? ag : ''
					}
					result.push({
						type: blockType,
						text: blockText,
						thinking: blockThinking,
						name: blockName,
						args: blockArgs,
					} as DisplayBlock)
				}
				return result
			},
			/** 统计 thinking 块数量，用于单块/多块标签切换 */
			thinkingCount(): number {
				let count = 0
				for (let i = 0; i < this.displayBlocks.length; i++) {
					if (this.displayBlocks[i].type == 'thinking') {
						count++
					}
				}
				return count
			},
			/** 按段落分段（连续空行分隔），单换行保留在段落内 */
			contentLines(): ContentSegment[] {
				const text = this.content as string
				if (text == '') {
					return []
				}
				const lines = text.split('\n')
				const result: ContentSegment[] = []
				let para = ''
				for (let i = 0; i < lines.length; i++) {
					const raw = lines[i]
					if (raw.trim() == '') {
						// 空行 = 段落分隔符
						if (para != '') {
							result.push({
								text: para.trim(),
								isLast: false
							} as ContentSegment)
							para = ''
						}
					} else {
						if (para != '') {
							para += '\n'
						}
						para += raw
					}
				}
				if (para != '') {
					result.push({
						text: para.trim(),
						isLast: false
					} as ContentSegment)
				}
				if (result.length > 0) {
					result[result.length - 1].isLast = true
				}
				return result
			},

			/** 将 any 类型转 boolean */
			isErrorBool(): boolean {
				return this.isError == true
			},
			isStreamingBool(): boolean {
				return this.isStreaming == true
			},

			/** 用户头像首字母 */
			userInitial(): string {
				const name = this.userNickname as string
				if (name != null && name != '') {
					return name.substring(0, 1)
				}
				return 'U'
			},

			bubbleClass() : string {
				if (this.role == 'user') {
					return 'bubble-user'
				}
				if (this.role == 'assistant') {
					return 'bubble-assistant'
				}
				if (this.role == 'toolResult') {
					if (this.isErrorBool) {
						return 'bubble-tool-error'
					}
					return 'bubble-tool'
				}
				return 'bubble-user'
			},
			textClass() : string {
				if (this.role == 'user') {
					return 'text-user'
				}
				if (this.role == 'assistant') {
					return 'text-assistant'
				}
				if (this.role == 'toolResult') {
					return 'text-tool'
				}
				return 'text-user'
			}
		},
		methods: {
			/** 切换 block 展开/折叠 */
			toggleBlockExpand(index: number) {
				while (this.blocksExpanded.length <= index) {
					this.blocksExpanded.push(false)
				}
				this.blocksExpanded[index] = !(this.blocksExpanded[index] == true)
			},
			/** 获取 block 展开状态 */
			getBlockExpanded(index: number): boolean {
				if (index >= this.blocksExpanded.length) return false
				return this.blocksExpanded[index] == true
			},
			/** 获取 block 的类型字符串 */
			getBlockType(block: UTSJSONObject | null): string {
				if (block == null) return ''

				const t = block['type'] as string
				return t != null ? t : ''
			},
			/** 获取 block 的文本内容 */
			getBlockText(block: UTSJSONObject | null): string {
				if (block == null) return ''
				const t = block['text'] as string
				return t != null ? t : ''
			},
			/** 获取 block 的思考内容 */
			getBlockThinking(block: UTSJSONObject | null): string {
				if (block == null) return ''
				const t = block['thinking'] as string
				return t != null ? t : ''
			},
			/** 获取 block 的工具名 */
			getBlockName(block: UTSJSONObject | null): string {
				if (block == null) return ''
				const t = block['name'] as string
				return t != null ? t : ''
			},
			/** 获取 block 的工具参数 */
			getBlockArgs(block: UTSJSONObject | null): string {
				if (block == null) return ''
				const t = block['arguments'] as string
				return t != null ? t : ''
			},
			/** 取消长按状态 */
			cancelLongpress() {
				if (this.longpressTimer != -1) {
					clearInterval(this.longpressTimer)
					this.longpressTimer = -1
				}
				this.longpressTriggered = false
				this.isPressed = false
			},

			/** 触摸开始 — 启动长按计时 */
			onBubbleTouchStart(e: UniTouchEvent) {
				this.touchStartX = e.touches[0].screenX
				this.touchStartY = e.touches[0].screenY
				this.longpressTick = 0
				this.longpressTriggered = false
				this.isPressed = true
				if (this.longpressTimer != -1) {
					clearInterval(this.longpressTimer)
				}
				this.longpressTimer = setInterval(() => {
					this.longpressTick++
					if (this.longpressTick >= 5) {
						clearInterval(this.longpressTimer)
						this.longpressTimer = -1
						if (this.longpressTriggered == true) {
							return
						}
						this.longpressTriggered = true
						this.$emit('bubbleLongpress')
					}
				}, 100)
			},

			/** 触摸移动 — 距离过大取消长按 */
			onBubbleTouchMove(e: UniTouchEvent) {
				if (this.longpressTimer == -1) { return }
				const dx = e.touches[0].screenX - this.touchStartX
				const dy = e.touches[0].screenY - this.touchStartY
				if (Math.abs(dx) > 30 || Math.abs(dy) > 30) {
					this.cancelLongpress()
				}
			},

			/** 触摸结束 — 清理状态 */
			onBubbleTouchEnd() {
				this.cancelLongpress()
				this.longpressTriggered = false
				this.isPressed = false
			},
		}
	}
</script>

<style>
	/* 用户气泡 - 右对齐粉色 */
	.bubble-user {
		flex-direction: column;
		align-items: flex-end;
		margin-left: 100rpx;
		margin-right: 20rpx;
		margin-top: 16rpx;
		margin-bottom: 16rpx;
	}

	/* 用户行：气泡 + 头像，顶部对齐 */
	.user-row {
		flex-direction: row;
		align-items: flex-start;
		justify-content: flex-end;
		width: 100%;
	}

	/* 用户气泡 - 粉色渐变背景 */
	.user-bubble {
		background-color: var(--rice-primary-color);
		border-radius: 32rpx;
		padding: 12rpx 24rpx;
		max-width: 1000rpx;
		flex-shrink: 1;
	}

	/* 用户气泡按压效果 */
	.user-bubble:active {
		opacity: 0.75;
	}

	/* AI 行：头像 + 内容，顶部对齐 */
	.ai-row {
		flex-direction: row;
		align-items: flex-start;
		width: 100%;
	}

	/* AI 气泡容器（分段气泡纵向排列） */
	.ai-bubbles {
		flex-direction: column;
		align-items: flex-start;
	}

	.ai-content {
		flex-shrink: 1;
		background-color: var(--rice-background-2);
		border-radius: 32rpx;
		padding: 20rpx;
		max-width: 1000rpx;
		margin-bottom: 20rpx;
	}

	/* AI 气泡按压效果 */
	.ai-content:active {
		background-color: #E5E7EB;
	}

	/* 通用头像 - 小圆形 */
	.chat-avatar {
		width: 56rpx;
		height: 56rpx;
		border-radius: 28rpx;
		flex-shrink: 0;
		margin-top: 4rpx;
	}

	.chat-avatar-text {
		font-size: 24rpx;
		color: var(--rice-background-2);
		font-weight: bold;
	}

	/* 用户头像 - 粉色渐变 */
	.user-avatar {
		background-color: var(--rice-primary-color);
		margin-left: 16rpx;
		justify-content: center;
		align-items: center;
	}

	/* 用户头像 - 自定义图片 */
	.user-avatar-image {
		margin-left: 16rpx;
	}

	/* AI 头像 - 灰色 */
	.ai-avatar {
		background-color: var(--rice-text-color-3);
		margin-right: 16rpx;
		justify-content: center;
		align-items: center;
	}

	/* AI 头像 - 自定义图片 */
	.ai-avatar-image {
		margin-right: 16rpx;
	}

	/* AI 气泡容器 - 只提供外边距 */
	.bubble-assistant {
		flex-direction: column;
		align-items: flex-start;
		margin-left: 20rpx;
		margin-right: 100rpx;
		margin-top: 16rpx;
		margin-bottom: 16rpx;
	}

	/* 工具气泡 - 浅灰背景 */
	.bubble-tool {
		flex-direction: column;
		align-items: flex-start;
		margin-left: 64rpx;
		margin-right: 64rpx;
		margin-top: 8rpx;
		margin-bottom: 8rpx;
		background-color: var(--rice-button-info-background);
		border-radius: 16rpx;
		padding: 20rpx;
	}

	/* 工具错误气泡 */
	.bubble-tool-error {
		flex-direction: column;
		align-items: flex-start;
		margin-left: 64rpx;
		margin-right: 64rpx;
		margin-top: 8rpx;
		margin-bottom: 8rpx;
		background-color: rgba(239,68,68,0.08);
		border-radius: 16rpx;
		padding: 20rpx;
		border-width: 2rpx;
		border-color: #EF4444;
	}

	/* 工具标签 */
	.tool-badge {
		background-color: #E5E7EB;
		border-radius: 8rpx;
		padding-left: 12rpx;
		padding-right: 12rpx;
		padding-top: 4rpx;
		padding-bottom: 4rpx;
		margin-bottom: 12rpx;
	}

	.tool-badge-text {
		font-size: 20rpx;
		color: var(--rice-text-color-2);
		font-weight: bold;
	}

	/* 气泡内的图片 */
	.bubble-image {
		width: 400rpx;
		max-height: 600rpx;
		border-radius: 20rpx;
		margin-bottom: 8rpx;
	}

	/* 用户文字 - 白色字，粉底由父容器提供 */
	.text-user {
		font-size: 30rpx;
		color: var(--rice-background-2);
		line-height: 44rpx;
		white-space: pre-wrap;
	}

	/* AI 文字 - 深色字，白底由父容器提供 */
	.text-assistant {
		font-size: 30rpx;
		color: var(--rice-text-color);
		line-height: 44rpx;
		white-space: pre-wrap;
	}

	/* AI 文字（非分段模式，保留换行符） */
	.text-assistant-pre {
		font-size: 30rpx;
		color: var(--rice-text-color);
		line-height: 44rpx;
		white-space: pre-wrap;
	}

	/* 工具文字 */
	.text-tool {
		font-size: 26rpx;
		color: var(--rice-text-color-2);
		line-height: 40rpx;
	}

	/* 流式光标 - 粉色 */
	.cursor {
		color: #FB8FAB;
		font-weight: bold;
	}

	/* 长按按下态 */
	.bubble-pressed {
		opacity: 0.65;
	}

	/* 思考内容折叠区 */
	.thinking-wrap {
	}
	.thinking-toggle {
		font-size: 22rpx;
		color: #D1D5DB;
	}
	.thinking-text {
