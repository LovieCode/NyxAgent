<template>
	<view :class="bubbleClass">
		<view v-if="role == 'user'" class="user-row">
			<view class="user-bubble" :class="isPressed ? 'bubble-pressed' : ''"
				@touchstart="onBubbleTouchStart($event as UniTouchEvent)"
				@touchmove="onBubbleTouchMove($event as UniTouchEvent)"
				@touchend="onBubbleTouchEnd">
				<view v-for="(part, pi) in contentParts" :key="'user-part-' + pi" class="part-wrap">
					<view v-if="part.type == 'image' && part.url != ''" class="image-part">
						<image :src="part.url" class="bubble-image" mode="widthFix" />
						<view v-if="part.caption != ''" class="caption-card user-caption-card">
							<text class="caption-label user-caption-label">图片转述</text>
							<text class="caption-text user-caption-text">{{part.caption}}</text>
						</view>
					</view>
					<text v-else-if="part.type == 'plain' || part.type == 'location'" class="text-user">{{part.text}}<text v-if="isStreaming == true && isLastContentPart(pi) == true" class="cursor">|</text></text>
					<view v-else class="media-chip user-media-chip">
						<text class="media-chip-text user-media-text">{{getPartLabel(part)}}</text>
					</view>
				</view>
				<text v-if="contentParts.length == 0 && content != ''" class="text-user">{{content}}<text v-if="isStreaming" class="cursor">|</text></text>
			</view>
			<image v-if="userAvatar != ''" :src="userAvatar" class="chat-avatar user-avatar-image" mode="aspectFill" />
			<view v-else class="chat-avatar user-avatar">
				<text class="chat-avatar-text">{{userInitial}}</text>
			</view>
		</view>

		<view v-else-if="role == 'assistant'" class="ai-row">
			<image v-if="agentAvatar != ''" :src="agentAvatar" class="chat-avatar ai-avatar-image" mode="aspectFill" />
			<view v-else class="chat-avatar ai-avatar">
				<text class="chat-avatar-text">AI</text>
			</view>
			<view class="ai-content timeline-content" :class="isPressed ? 'bubble-pressed' : ''"
				@touchstart="onBubbleTouchStart($event as UniTouchEvent)"
				@touchmove="onBubbleTouchMove($event as UniTouchEvent)"
				@touchend="onBubbleTouchEnd">
				<view v-if="reasoningBlocks.length > 0 && hideThinking == false" class="reasoning-panel">
					<view class="reasoning-header" @click.stop="thinkingExpanded = !thinkingExpanded">
						<text class="thinking-step-icon">{{thinkingExpanded ? '↑' : '↓'}}</text>
						<text class="thinking-step-label">思考过程</text>
					</view>
					<view v-if="thinkingExpanded == true" class="reasoning-body">
						<view v-for="(block, bi) in reasoningBlocks" :key="'reasoning-' + bi" class="block-entry">
							<text v-if="block.type == 'thinking'" class="thinking-step-text">{{block.thinking}}</text>
							<view v-else-if="block.type == 'toolCall'" class="tool-call-step" @click.stop="toggleToolCallExpand(bi)">
								<view class="tool-call-card">
									<view class="tool-call-card-header">
										<view class="tool-call-card-left">
											<text class="tool-call-status">{{getToolStatusText(block)}}</text>
											<text class="tool-call-card-name">{{getToolDisplayName(block.name)}}</text>
										</view>
										<view class="tool-call-card-right">
											<text v-if="block.ts > 0 && (_renderSwitch == true || _renderSwitch == false)" :key="'elapsed-' + bi + '-' + timerTick + '-' + _renderSwitch" class="tool-call-elapsed">{{getToolElapsed(block)}}</text>
											<text class="tool-call-chevron">{{getToolCallExpanded(bi) ? '收起' : '详情'}}</text>
										</view>
									</view>
									<view v-if="getToolCallExpanded(bi) == true" class="tool-call-card-detail">
										<view class="tool-detail-section">
											<text class="tool-detail-label">参数</text>
											<text class="tool-detail-value">{{block.args}}</text>
										</view>
										<view v-if="block.result != ''" class="tool-detail-section">
											<text class="tool-detail-label">结果</text>
											<text class="tool-detail-value">{{block.result}}</text>
										</view>
									</view>
								</view>
							</view>
						</view>
					</view>
				</view>

				<view v-for="(part, pi) in contentParts" :key="'assistant-part-' + pi" class="part-wrap">
					<view v-if="part.type == 'image' && part.url != ''" class="image-part">
						<image :src="part.url" class="bubble-image" mode="widthFix" />
						<view v-if="part.caption != ''" class="caption-card">
							<text class="caption-label">图片转述</text>
							<text class="caption-text">{{part.caption}}</text>
						</view>
					</view>
					<text v-else-if="part.type == 'plain' || part.type == 'location'" class="text-assistant-pre">{{part.text}}<text v-if="isStreaming == true && isLastContentPart(pi) == true" class="cursor">|</text></text>
					<view v-else class="media-chip">
						<text class="media-chip-text">{{getPartLabel(part)}}</text>
					</view>
				</view>
				<text v-if="contentParts.length == 0 && content != ''" class="text-assistant-pre">{{content}}<text v-if="isStreaming" class="cursor">|</text></text>
				<text v-if="contentParts.length == 0 && content == '' && isStreaming == true" class="text-assistant-pre"><text class="cursor">|</text></text>
			</view>
		</view>

		<view v-else-if="role == 'toolResult'" class="tool-fallback">
			<view v-if="toolName != ''" class="tool-badge">
				<text class="tool-badge-text">{{toolName}}</text>
			</view>
			<text :class="textClass">{{content}}<text v-if="isStreaming" class="cursor">|</text></text>
		</view>
	</view>
</template>

<script lang="uts">
	type ContentPartView = {
		type: string
		text: string
		url: string
		path: string
		filename: string
		caption: string
	}
	type DisplayBlock = {
		type: string
		text: string
		thinking: string
		name: string
		args: string
		ts: number
		finished_ts: number
		status: string
		result: string
	}
	export default {
		props: {
			role: {
				type: String,
				default: 'user'
			},
			content: {
				type: String,
				default: ''
			},
			parts: {
				type: Array,
				default: () => []
			},
			msgType: {
				type: String,
				default: 'text'
			},
			imageUrl: {
				type: String,
				default: ''
			},
			toolName: {
				type: String,
				default: ''
			},
			thinking: {
				type: String,
				default: ''
			},
			msgSegmentation: {
				type: Boolean,
				default: true
			},
			hideThinking: {
				type: Boolean,
				default: false
			},
			isError: {
				type: Boolean,
				default: false
			},
			isStreaming: {
				type: Boolean,
				default: false
			},
			userNickname: {
				type: String,
				default: ''
			},
			userAvatar: {
				type: String,
				default: ''
			},
			agentAvatar: {
				type: String,
				default: ''
			},
			cancelToken: {
				type: Number,
				default: 0
			}
		},
		data() {
			return {
				touchStartX: 0 as number,
				touchStartY: 0 as number,
				longpressTick: 0 as number,
				longpressTimer: -1 as number,
				longpressTriggered: false as boolean,
				isPressed: false as boolean,
				thinkingExpanded: false as boolean,
				toolCallExpanded: [] as boolean[],
				timerRunning: false as boolean,
				_renderSwitch: false as boolean,
				timerTick: 0 as number,
			}
		},
		watch: {
			cancelToken(newVal: number, oldVal: number) {
				if (newVal != oldVal) {
					this.cancelLongpress()
				}
			},
			parts: {
				handler(_newParts: UTSJSONObject[]) {
					if (this.isStreaming == true && this.reasoningBlocks.length > 0) {
						this.thinkingExpanded = true
					}
					this.syncToolTimer()
				},
				deep: true
			},
			isStreaming(newVal: boolean, oldVal: boolean) {
				if (newVal == true && oldVal == false && this.reasoningBlocks.length > 0) {
					this.thinkingExpanded = true
				}
				if (newVal == false && oldVal == true) {
					this.thinkingExpanded = false
					this.timerRunning = false
				}
			}
		},
		unmounted() {
			this.timerRunning = false
		},
		computed: {
			messageParts(): UTSJSONObject[] {
				const raw = this.parts as UTSJSONObject[]
				if (raw != null && raw.length > 0) {
					return raw
				}
				const fallback: UTSJSONObject[] = []
				if (this.thinking != '') {
					fallback.push({ type: 'think', think: this.thinking } as UTSJSONObject)
				}
				if (this.msgType == 'image' && this.imageUrl != '') {
					fallback.push({ type: 'image', url: this.imageUrl, path: this.imageUrl } as UTSJSONObject)
				} else if (this.content != '') {
					fallback.push({ type: 'plain', text: this.content } as UTSJSONObject)
				}
				return fallback
			},
			displayBlocks(): DisplayBlock[] {
				const _tick = this.timerTick
				const result: DisplayBlock[] = []
				const source = this.messageParts
				for (let i = 0; i < source.length; i++) {
					const part = source[i]
					const typeRaw = part['type'] as string | null
					const partType = typeRaw != null ? typeRaw : ''
					if (partType == 'plain' || partType == 'text') {
						const txt = part['text'] as string | null
						result.push({ type: 'text', text: txt != null ? txt : '', thinking: '', name: '', args: '', ts: 0, finished_ts: 0, status: '', result: '' } as DisplayBlock)
					} else if (partType == 'think' || partType == 'thinking') {
						const thk = part['think'] as string | null
						const oldThk = part['thinking'] as string | null
						result.push({ type: 'thinking', text: '', thinking: thk != null ? thk : (oldThk != null ? oldThk : ''), name: '', args: '', ts: 0, finished_ts: 0, status: '', result: '' } as DisplayBlock)
					} else if (partType == 'tool_call' || partType == 'toolCall') {
						const calls = part['tool_calls'] as UTSJSONObject[] | null
						if (calls != null) {
							for (let j = 0; j < calls.length; j++) {
								result.push(this.buildToolBlock(calls[j]))
							}
						} else {
							result.push(this.buildToolBlock(part))
						}
					}
				}
				return result
			},
			reasoningBlocks(): DisplayBlock[] {
				const result: DisplayBlock[] = []
				for (let i = 0; i < this.displayBlocks.length; i++) {
					const block = this.displayBlocks[i]
					if (block.type == 'thinking' || block.type == 'toolCall') {
						result.push(block)
					}
				}
				return result
			},
			contentParts(): ContentPartView[] {
				const result: ContentPartView[] = []
				const source = this.messageParts
				for (let i = 0; i < source.length; i++) {
					const part = source[i]
					const typeRaw = part['type'] as string | null
					const partType = typeRaw != null ? typeRaw : ''
					if (partType == 'think' || partType == 'thinking' || partType == 'tool_call' || partType == 'toolCall') {
						continue
					}
					let text = ''
					let url = ''
					let path = ''
					let filename = ''
					let caption = ''
					const rawText = part['text'] as string | null
					if (rawText != null) { text = rawText }
					const rawUrl = part['url'] as string | null
					if (rawUrl != null) { url = rawUrl }
					const rawPath = part['path'] as string | null
					if (rawPath != null) { path = rawPath }
					const rawCaption = part['caption'] as string | null
					if (rawCaption != null) { caption = rawCaption }
					if (url == '' && path != '') { url = path }
					const rawFile = part['filename'] as string | null
					const rawName = part['name'] as string | null
					if (rawFile != null && rawFile != '') {
						filename = rawFile
					} else if (rawName != null) {
						filename = rawName
					}
					result.push({ type: partType == 'text' ? 'plain' : partType, text: text, url: url, path: path, filename: filename, caption: caption } as ContentPartView)
				}
				return result
			},
			isErrorBool(): boolean {
				return this.isError == true
			},
			userInitial(): string {
				const name = this.userNickname as string
				if (name != null && name != '') {
					return name.substring(0, 1)
				}
				return 'U'
			},
			bubbleClass(): string {
				if (this.role == 'user') {
					return 'bubble-user'
				}
				if (this.role == 'assistant') {
					return 'bubble-assistant'
				}
				if (this.role == 'toolResult') {
					if (this.isErrorBool) {
						return 'bubble-tool-error'
					}
					return 'bubble-tool'
				}
				return 'bubble-user'
			},
			textClass(): string {
				if (this.role == 'toolResult') {
					return 'text-tool'
				}
				if (this.role == 'assistant') {
					return 'text-assistant'
				}
				return 'text-user'
			}
		},
		methods: {
			buildToolBlock(item: UTSJSONObject): DisplayBlock {
				const name = item['name'] as string | null
				const args1 = item['arguments'] as string | null
				const args2 = item['args'] as string | null
				const rawTs = item['ts'] as number | null
				const rawFt = item['finished_ts'] as number | null
				const status = item['status'] as string | null
				const result = item['result'] as string | null
				return {
					type: 'toolCall',
					text: '',
					thinking: '',
					name: name != null ? name : '',
					args: args1 != null ? args1 : (args2 != null ? args2 : ''),
					ts: rawTs != null ? rawTs : 0,
					finished_ts: rawFt != null ? rawFt : 0,
					status: status != null ? status : '',
					result: result != null ? result : '',
				} as DisplayBlock
			},
			isLastContentPart(index: number): boolean {
				return index == this.contentParts.length - 1
			},
			syncToolTimer() {
				let hasRunning = false
				for (let i = 0; i < this.displayBlocks.length; i++) {
					if (this.displayBlocks[i].status == 'running') {
						hasRunning = true
						break
					}
				}
				if (hasRunning == true && this.timerRunning == false) {
					this.timerRunning = true
					this.tick()
				}
				if (hasRunning == false && this.timerRunning == true) {
					this.timerRunning = false
				}
			},
			tick() {
				if (this.timerRunning == false) return
				this.timerTick = this.timerTick + 1
				this._renderSwitch = !this._renderSwitch
				let anyRunning = false
				for (let i = 0; i < this.displayBlocks.length; i++) {
					if (this.displayBlocks[i].status == 'running') {
						anyRunning = true
						break
					}
				}
				if (anyRunning == false) {
					this.timerRunning = false
					return
				}
				setTimeout(() => { this.tick() }, 1000)
			},
			getToolElapsed(block: DisplayBlock): string {
				const _tick = this.timerTick
				const ts = block.ts
				const finished = block.finished_ts
				if (ts == 0) return ''
				if (finished > 0) {
					const elapsed = ((finished - ts) / 1000)
					return elapsed.toFixed(1) + 's'
				}
				const now = Date.now()
				const elapsed = ((now - ts) / 1000)
				return elapsed.toFixed(1) + 's'
			},
			getToolStatusText(block: DisplayBlock): string {
				if (block.status == 'running') return '运行中'
				if (block.status == 'completed') return '完成'
				if (block.status == 'error') return '失败'
				if (block.status == 'pending') return '等待'
				return '工具'
			},
			getToolDisplayName(name: string): string {
				if (name == 'file_read') return '读取文件'
				if (name == 'file_write') return '写入文件'
				if (name == 'file_delete') return '删除文件'
				if (name == 'file_list') return '列出文件'
				if (name == 'file_info') return '文件信息'
				if (name == 'directory_create') return '创建目录'
				if (name == 'memory_search') return '搜索记忆'
				if (name == 'memory_buffer_write') return '写短缓存'
				if (name == 'memory_core_list') return '列出记忆'
				if (name == 'memory_core_save') return '保存记忆'
				if (name == 'memory_core_forget') return '遗忘记忆'
				if (name == 'web_search') return '网络搜索'
				return name
			},
			getPartLabel(part: ContentPartView): string {
				if (part.type == 'file') {
					return '[文件] ' + (part.filename != '' ? part.filename : (part.path != '' ? part.path : '未命名文件'))
				}
				if (part.type == 'record' || part.type == 'voice') {
					return '[语音] ' + (part.path != '' ? part.path : part.url)
				}
				if (part.type == 'audio') {
					return '[音频] ' + (part.filename != '' ? part.filename : (part.path != '' ? part.path : part.url))
				}
				if (part.type == 'video') {
					return '[视频] ' + (part.filename != '' ? part.filename : (part.path != '' ? part.path : part.url))
				}
				return '[' + part.type + '] ' + (part.text != '' ? part.text : part.path)
			},
			toggleToolCallExpand(index: number) {
				while (this.toolCallExpanded.length <= index) {
					this.toolCallExpanded.push(false)
				}
				this.toolCallExpanded[index] = !(this.toolCallExpanded[index] == true)
			},
			getToolCallExpanded(index: number): boolean {
				if (index >= this.toolCallExpanded.length) return false
				return this.toolCallExpanded[index] == true
			},
			cancelLongpress() {
				if (this.longpressTimer != -1) {
					clearInterval(this.longpressTimer)
					this.longpressTimer = -1
				}
				this.longpressTriggered = false
				this.isPressed = false
			},
			onBubbleTouchStart(e: UniTouchEvent) {
				this.touchStartX = e.touches[0].screenX
				this.touchStartY = e.touches[0].screenY
				this.longpressTick = 0
				this.longpressTriggered = false
				this.isPressed = true
				if (this.longpressTimer != -1) {
					clearInterval(this.longpressTimer)
				}
				this.longpressTimer = setInterval(() => {
					this.longpressTick++
					if (this.longpressTick >= 5) {
						clearInterval(this.longpressTimer)
						this.longpressTimer = -1
						if (this.longpressTriggered == true) {
							return
						}
						this.longpressTriggered = true
						this.$emit('bubbleLongpress')
					}
				}, 100)
			},
			onBubbleTouchMove(e: UniTouchEvent) {
				if (this.longpressTimer == -1) { return }
				const dx = e.touches[0].screenX - this.touchStartX
				const dy = e.touches[0].screenY - this.touchStartY
				if (Math.abs(dx) > 30 || Math.abs(dy) > 30) {
					this.cancelLongpress()
				}
			},
			onBubbleTouchEnd() {
				this.cancelLongpress()
				this.longpressTriggered = false
				this.isPressed = false
			},
		}
	}
</script>

<style>
	.bubble-user {
		flex-direction: column;
		align-items: flex-end;
		margin-left: 100rpx;
		margin-right: 20rpx;
		margin-top: 16rpx;
		margin-bottom: 16rpx;
	}
	.user-row {
		flex-direction: row;
		align-items: flex-start;
		justify-content: flex-end;
		width: 100%;
	}
	.user-bubble {
		background-color: var(--rice-primary-color);
		border-radius: 32rpx;
		padding: 12rpx 24rpx;
		max-width: 1000rpx;
		flex-shrink: 1;
	}
	.user-bubble:active {
		opacity: 0.75;
	}
	.ai-row {
		flex-direction: row;
		align-items: flex-start;
		width: 100%;
	}
	.ai-content {
		flex-shrink: 1;
		background-color: var(--rice-background-2);
		border-radius: 32rpx;
		padding: 20rpx;
		max-width: 1000rpx;
		margin-bottom: 20rpx;
	}
	.ai-content:active {
		background-color: #E5E7EB;
	}
	.chat-avatar {
		width: 56rpx;
		height: 56rpx;
		border-radius: 28rpx;
		flex-shrink: 0;
		margin-top: 4rpx;
	}
	.chat-avatar-text {
		font-size: 24rpx;
		color: var(--rice-background-2);
		font-weight: bold;
	}
	.user-avatar {
		background-color: var(--rice-primary-color);
		margin-left: 16rpx;
		justify-content: center;
		align-items: center;
	}
	.user-avatar-image {
		margin-left: 16rpx;
	}
	.ai-avatar {
		background-color: var(--rice-text-color-3);
		margin-right: 16rpx;
		justify-content: center;
		align-items: center;
	}
	.ai-avatar-image {
		margin-right: 16rpx;
	}
	.bubble-assistant {
		flex-direction: column;
		align-items: flex-start;
		margin-left: 20rpx;
		margin-right: 100rpx;
		margin-top: 16rpx;
		margin-bottom: 16rpx;
	}
	.bubble-tool {
		flex-direction: column;
		align-items: flex-start;
		margin-left: 64rpx;
		margin-right: 64rpx;
		margin-top: 8rpx;
		margin-bottom: 8rpx;
		background-color: var(--rice-button-info-background);
		border-radius: 16rpx;
		padding: 20rpx;
	}
	.bubble-tool-error {
		flex-direction: column;
		align-items: flex-start;
		margin-left: 64rpx;
		margin-right: 64rpx;
		margin-top: 8rpx;
		margin-bottom: 8rpx;
		background-color: rgba(239,68,68,0.08);
		border-radius: 16rpx;
		padding: 20rpx;
		border-width: 2rpx;
		border-color: #EF4444;
	}
	.tool-fallback {
		flex-direction: column;
	}
	.tool-badge {
		background-color: #E5E7EB;
		border-radius: 8rpx;
		padding-left: 12rpx;
		padding-right: 12rpx;
		padding-top: 4rpx;
		padding-bottom: 4rpx;
		margin-bottom: 12rpx;
	}
	.tool-badge-text {
		font-size: 20rpx;
		color: var(--rice-text-color-2);
		font-weight: bold;
	}
	.part-wrap {
		margin-bottom: 8rpx;
	}
