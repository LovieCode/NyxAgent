<template>
	<view :class="bubbleClass">
		<!-- 工具名称标签（在内容上方） -->
		<view v-if="role == 'toolResult'" class="tool-badge">
			<text class="tool-badge-text">{{toolName}}</text>
		</view>

		<!-- 用户消息：气泡 + 右侧头像 -->
		<view v-if="role == 'user'" class="user-row">
			<view class="user-bubble">
				<!-- 图片消息 -->
				<image v-if="msgType == 'image' && imageUrl != ''" :src="imageUrl" class="bubble-image" mode="widthFix" />
				<!-- 文本消息 -->
				<text v-if="msgType != 'image' || content != ''" :class="textClass">{{content}}<text v-if="isStreaming" class="cursor">|</text></text>
			</view>
			<view class="chat-avatar user-avatar">
				<text class="chat-avatar-text">{{userInitial}}</text>
			</view>
		</view>

		<!-- AI 消息：左侧头像 + 标签 + 气泡 -->
		<view v-if="role == 'assistant'" class="ai-row">
			<image v-if="agentAvatar != ''" :src="agentAvatar" class="chat-avatar ai-avatar-image" mode="aspectFill" />
			<view v-else class="chat-avatar ai-avatar">
				<text class="chat-avatar-text">AI</text>
			</view>
			<view class="ai-content">
				<view class="ai-label">
					<text class="ai-label-text">AI 助手</text>
				</view>
				<image v-if="msgType == 'image' && imageUrl != ''" :src="imageUrl" class="bubble-image" mode="widthFix" />
				<text v-if="msgType != 'image' || content != ''" :class="textClass">{{content}}<text v-if="isStreaming" class="cursor">|</text></text>
			</view>
		</view>

		<!-- 工具消息：纯文本 -->
		<text v-if="role == 'toolResult'" :class="textClass">{{content}}<text v-if="isStreaming" class="cursor">|</text></text>
	</view>
</template>

<script lang="uts">
	/**
	 * ChatBubble 组件 - 聊天气泡
	 * 扁平化粉白主题
	 */
	export default {
		props: {
			role: {
				type: String,
				default: 'user'
			},
			content: {
				type: String,
				default: ''
			},
			msgType: {
				type: String,
				default: 'text'
			},
			imageUrl: {
				type: String,
				default: ''
			},
			toolName: {
				type: String,
				default: ''
			},
			isError: {
				default: false
			},
			isStreaming: {
				default: false
			},
			userNickname: {
				type: String,
				default: ''
			},
			agentAvatar: {
				type: String,
				default: ''
			}
		},
		computed: {
			/** 将 any 类型转 boolean */
			isErrorBool(): boolean {
				return this.isError == true || this.isError == 'true'
			},
			isStreamingBool(): boolean {
				return this.isStreaming == true || this.isStreaming == 'true'
			},

			/** 用户头像首字母 */
			userInitial(): string {
				const name = this.userNickname as string
				if (name != null && name != '') {
					return name.substring(0, 1)
				}
				return 'U'
			},

			bubbleClass() : string {
				if (this.role == 'user') {
					return 'bubble-user'
				}
				if (this.role == 'assistant') {
					return 'bubble-assistant'
				}
				if (this.role == 'toolResult') {
					if (this.isErrorBool) {
						return 'bubble-tool-error'
					}
					return 'bubble-tool'
				}
				return 'bubble-user'
			},
			textClass() : string {
				if (this.role == 'user') {
					return 'text-user'
				}
				if (this.role == 'assistant') {
					return 'text-assistant'
				}
				if (this.role == 'toolResult') {
					return 'text-tool'
				}
				return 'text-user'
			}
		},
	}
</script>

<style>
	/* 用户气泡 - 右对齐粉色 */
	.bubble-user {
		flex-direction: column;
		align-items: flex-end;
		margin-left: 50px;
		margin-right: 10px;
		margin-top: 8px;
		margin-bottom: 8px;
	}

	/* 用户行：气泡 + 头像，顶部对齐 */
	.user-row {
		flex-direction: row;
		align-items: flex-start;
		justify-content: flex-end;
	}

	/* 用户气泡 - 粉色渐变背景 */
	.user-bubble {
		background-image: linear-gradient(to bottom right, #FB8FAB, #E8729A);
		border-radius: 16px;
		padding: 6px 12px;
		max-width: 500px;
	}

	/* AI 行：头像 + 内容，顶部对齐 */
	.ai-row {
		flex-direction: row;
		align-items: flex-start;
		width: 100%;
	}

	.ai-content {
		flex: 1;
		flex-shrink: 1;
		background-color: var(--rice-background-2);
		border-radius: 16px;
		padding: 10px;
	}

	/* 通用头像 - 小圆形 */
	.chat-avatar {
		width: 28px;
		height: 28px;
		border-radius: 14px;
		justify-content: center;
		align-items: center;
		flex-shrink: 0;
		margin-top: 2px;
	}

	.chat-avatar-text {
		font-size: 12px;
		color: var(--rice-background-2);
		font-weight: bold;
	}

	/* 用户头像 - 粉色渐变 */
	.user-avatar {
		background-image: linear-gradient(to bottom right, #FB8FAB, #E8729A);
		margin-left: 8px;
	}

	/* AI 头像 - 灰色 */
	.ai-avatar {
		background-color: var(--rice-text-color-3);
		margin-right: 8px;
	}

	/* AI 头像 - 自定义图片 */
	.ai-avatar-image {
		margin-right: 8px;
	}

	/* AI 气泡容器 - 只提供外边距 */
	.bubble-assistant {
		flex-direction: column;
		align-items: flex-start;
		margin-left: 10px;
		margin-right: 50px;
		margin-top: 8px;
		margin-bottom: 8px;
	}

	/* 工具气泡 - 浅灰背景 */
	.bubble-tool {
		flex-direction: column;
		align-items: flex-start;
		margin-left: 32px;
		margin-right: 32px;
		margin-top: 4px;
		margin-bottom: 4px;
		background-color: var(--rice-button-info-background);
		border-radius: 8px;
		padding: 10px;
	}

	/* 工具错误气泡 */
	.bubble-tool-error {
		flex-direction: column;
		align-items: flex-start;
		margin-left: 32px;
		margin-right: 32px;
		margin-top: 4px;
		margin-bottom: 4px;
		background-color: rgba(239,68,68,0.08);
		border-radius: 8px;
		padding: 10px;
		border-width: 1px;
		border-color: #EF4444;
	}

	/* AI 标签 - 淡粉强调 */
	.ai-label {
		background-color: var(--rice-primary-color-1);
		border-radius: 4px;
		padding-left: 6px;
		padding-right: 6px;
		padding-top: 2px;
		padding-bottom: 2px;
		margin-bottom: 4px;
		align-self: flex-start;
	}

	.ai-label-text {
		font-size: 10px;
		color: var(--rice-primary-color-7);
		font-weight: bold;
	}

	/* 工具标签 */
	.tool-badge {
		background-color: #E5E7EB;
		border-radius: 4px;
		padding-left: 6px;
		padding-right: 6px;
		padding-top: 2px;
		padding-bottom: 2px;
		margin-bottom: 6px;
	}

	.tool-badge-text {
		font-size: 10px;
		color: var(--rice-text-color-2);
		font-weight: bold;
	}

	/* 气泡内的图片 */
	.bubble-image {
		width: 200px;
		max-height: 300px;
		border-radius: 10px;
		margin-bottom: 4px;
	}

	/* 用户文字 - 白色字，粉底由父容器提供 */
	.text-user {
		font-size: 15px;
		color: var(--rice-background-2);
		line-height: 22px;
	}

	/* AI 文字 - 深色字，白底由父容器提供 */
	.text-assistant {
		font-size: 15px;
		color: var(--rice-text-color);
		line-height: 22px;
	}

	/* 工具文字 */
	.text-tool {
		font-size: 13px;
		color: var(--rice-text-color-2);
		line-height: 20px;
	}

	/* 流式光标 - 粉色 */
	.cursor {
		color: #FB8FAB;
		font-weight: bold;
	}
</style>
