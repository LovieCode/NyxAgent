<template>
	<view class="page-shell rice-theme-light">
		<NavBar variant="light" :title="title" showBack @back="handleBack">
			<template #right>
				<text v-if="readOnly == false" class="done-btn" @click="handleSave">{{ saveText }}</text>
			</template>
		</NavBar>
		<view class="editor-wrap" :style="{ marginBottom: keyboardInset + 'px' }">
			<slot name="header"></slot>
			<view class="editor-meta" v-if="subtitle != ''">
				<text class="editor-meta-text">{{ subtitle }}</text>
			</view>
			<textarea
				class="editor-input"
				v-model="localText"
				:disabled="readOnly"
				:placeholder="placeholder"
				placeholder-style="color:#D1D5DB;font-size:15px;"
				:auto-height="false"
				:adjust-position="false"
				@input="handleInput"
			/>
			<view class="editor-footer">
				<text class="footer-text">{{ dirty ? '未保存' : '已同步' }}</text>
				<text class="footer-text">{{ localText.length }} 字</text>
			</view>
		</view>
	</view>
</template>

<script lang="uts">
	import { resolveKeyboardInset } from '@/utils/keyboard-inset.uts'

	/**
	 * 通用全屏文本编辑组件。
	 * 只负责编辑体验，不碰 storage / 文件系统 / 业务保存。
	 */
	export default {
		name: 'FullscreenTextEditor',
		props: {
			title: {
				type: String,
				default: '编辑'
			},
			subtitle: {
				type: String,
				default: ''
			},
			value: {
				type: String,
				default: ''
			},
			placeholder: {
				type: String,
				default: '输入内容...'
			},
			readOnly: {
				type: Boolean,
				default: false
			},
			dirty: {
				type: Boolean,
				default: false
			},
			saveText: {
				type: String,
				default: '保存'
			}
		},
		emits: ['change', 'save', 'back'],
		data() {
			return {
				localText: '' as string,
				keyboardInset: 0 as number,
				keyboardBaseWindowHeight: 0 as number,
				keyboardHeightListenerId: -1 as number,
			}
		},
		watch: {
			value(newVal: string, oldVal: string) {
				if (newVal != this.localText) {
					this.localText = newVal
				}
			}
		},
		created() {
			this.localText = this.value
		},
		mounted() {
			try {
				const windowInfo = uni.getWindowInfo()
				this.keyboardBaseWindowHeight = windowInfo.windowHeight
			} catch (error) {
				this.keyboardBaseWindowHeight = 0
			}
			this.keyboardHeightListenerId = uni.onKeyboardHeightChange((res: OnKeyboardHeightChangeCallbackResult) => {
				let currentWindowHeight = this.keyboardBaseWindowHeight
				try {
					const windowInfo = uni.getWindowInfo()
					currentWindowHeight = windowInfo.windowHeight
				} catch (error) {
					currentWindowHeight = this.keyboardBaseWindowHeight
				}
				if (res.height == 0 && currentWindowHeight > 0) {
					this.keyboardBaseWindowHeight = currentWindowHeight
				}
				this.keyboardInset = resolveKeyboardInset(res.height, this.keyboardBaseWindowHeight, currentWindowHeight)
			})
		},
		unmounted() {
			if (this.keyboardHeightListenerId != -1) {
				uni.offKeyboardHeightChange(this.keyboardHeightListenerId)
				this.keyboardHeightListenerId = -1
			}
		},
		methods: {
			handleInput() {
				this.$emit('change', this.localText)
			},
			handleSave() {
				this.$emit('save', this.localText)
			},
			handleBack() {
				this.$emit('back')
			},
		}
	}
</script>

<style>
	.page-shell {
		flex: 1;
		width: 100%;
		flex-direction: column;
		background-color: #FFFFFF;
	}

	.editor-wrap {
		flex: 1;
		width: 100%;
		flex-direction: column;
		background-color: #FFFFFF;
		padding: 12px 14px 9px;
	}

	.editor-meta {
		width: 100%;
		padding: 0 0 9px 0;
	}

	.editor-meta-text {
		font-size: 11px;
		color: #9CA3AF;
		lines: 1;
		text-overflow: ellipsis;
	}

	.editor-input {
		flex: 1;
		width: 100%;
		align-self: stretch;
		font-size: 15px;
		color: #111827;
		line-height: 24px;
		padding: 0;
		background-color: transparent;
	}

	.editor-footer {
		width: 100%;
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		padding-top: 8px;
	}

	.footer-text {
		font-size: 11px;
		color: #9CA3AF;
	}

	.done-btn {
		font-size: 15px;
		color: #FFFFFF;
		font-weight: bold;
		padding: 8px 4px;
	}


/* ===== Nyx 子页面视觉重制 ===== */
	.page-shell { background-color: #FAF7F5; }
	.editor-wrap { background-color: #FAF7F5; padding: 14px 24px 12px; }
	.editor-meta { background-color: #FFFFFF; border-radius: 16px; padding: 10px 12px; margin-bottom: 10px; border-width: 1px; border-style: solid; border-color: #F1E5EA; }
	.editor-input { background-color: #FFFFFF; border-radius: 20px; border-width: 1px; border-style: solid; border-color: rgba(241, 229, 234, 0.92); padding: 14px; box-shadow: 0 8px 20px rgba(216, 140, 165, 0.045); }
	.done-btn { color: #DB6F92; font-weight: bold; }
</style>
