<template>
	<view class="nyx-float-wrap" :style="floatStyle">
		<view
			class="nyx-float"
			:class="isRecording == true ? 'nyx-float-active' : ''"
			@touchstart.stop="onFloatTouchStart"
			@touchmove.stop.prevent="onFloatTouchMove"
			@touchend.stop="onFloatTouchEnd"
			@touchcancel.stop="onFloatTouchEnd"
		>
			<text class="nyx-face">眠</text>
		</view>
		<text v-if="isRecording == true" class="nyx-dot">松开</text>
		<text v-if="isTranscribing == true" class="nyx-dot">识别中</text>
	</view>
</template>

<script lang="uts">
	import { getDefaultTaskModel } from '@/uni_modules/agent-core/utssdk/provider.uts'
	import { transcribeAudio } from '@/utils/speech-service.uts'
	import { ensureNyxAdminAgent, NYX_ADMIN_AGENT_ID } from '@/utils/agent.uts'
	import { getActiveAgentRuntimeId, getActiveConversationRuntimeId, getNyxFloatPosition, setActiveChatRouteState, setNyxFloatPosition } from '@/utils/runtime-state.uts'
	import { publishNyxFloatVoiceText, readNyxFloatVoiceContext } from '@/utils/nyx-float-voice.uts'
	import { APP_ERROR_CATEGORY_RUNTIME, formatAppErrorForUser, reportAppErrorFromCause } from '@/utils/app-error.uts'

	function showNyxRuntimeStateFailure(operation: string, userMessage: string): void {
		const error = reportAppErrorFromCause(
			'NYX_FLOAT_RUNTIME_STATE_SAVE_FAILED',
			APP_ERROR_CATEGORY_RUNTIME,
			operation,
			userMessage,
			'跨页运行状态写入 SQLite 失败',
			true,
		)
		uni.showToast({ position: 'bottom', title: formatAppErrorForUser(error), icon: 'none' })
	}

	function showNyxNavigationFailure(operation: string, userMessage: string, cause: any | null): void {
		const error = reportAppErrorFromCause(
			'NYX_FLOAT_NAVIGATION_FAILED',
			APP_ERROR_CATEGORY_RUNTIME,
			operation,
			userMessage,
			cause,
			true,
		)
		uni.showToast({ position: 'bottom', title: formatAppErrorForUser(error), icon: 'none' })
	}

	export default {
		name: 'NyxFloatingVoice',
		data() {
			return {
				isRecording: false as boolean,
				isTranscribing: false as boolean,
				voiceSessionId: 0 as number,
				floatX: 305 as number,
				floatY: 440 as number,
				floatSize: 54 as number,
				floatGap: 16 as number,
				floatReady: false as boolean,
				windowWidth: 375 as number,
				windowHeight: 667 as number,
				dragStartX: 0 as number,
				dragStartY: 0 as number,
				dragBaseX: 0 as number,
				dragBaseY: 0 as number,
				floatTouching: false as boolean,
				floatMoved: false as boolean,
				floatLongPressHandled: false as boolean,
				recordStartTimer: 0 as number,
				recordStartDelay: 360 as number,
				isOpeningChat: false as boolean,
				lastOpenChatAt: 0 as number,
			}
		},
		computed: {
			floatStyle(): string {
				const opacity = this.floatReady == true ? '1' : '0'
				return 'left:' + this.floatX + 'px;top:' + this.floatY + 'px;opacity:' + opacity + ';'
			},
		},
		mounted() {
			this.initFloatPosition()
		},
		unmounted() {
			this.clearPendingVoiceStart()
		},
		methods: {
			navigateToChatOnce(previousAgentId: string, previousConversationId: string, rollbackRouteState: boolean): boolean {
				const now = Date.now()
				if (this.isOpeningChat == true || now - this.lastOpenChatAt < 1200) {
					return false
				}
				this.isOpeningChat = true
				this.lastOpenChatAt = now
				uni.navigateTo({
					url: '/pages/chat/chat',
					fail: (err: any) => {
						this.isOpeningChat = false
						if (rollbackRouteState == true && setActiveChatRouteState(previousAgentId, previousConversationId) == false) {
							reportAppErrorFromCause('NYX_FLOAT_RUNTIME_STATE_ROLLBACK_FAILED', APP_ERROR_CATEGORY_RUNTIME, 'nyx_float_navigation_rollback', '眠汐私聊状态恢复失败', '跨页运行状态回滚 SQLite 失败', true)
						}
						showNyxNavigationFailure('nyx_float_navigate_chat', '无法打开眠汐私聊', err)
					}
				})
				setTimeout(() => {
					this.isOpeningChat = false
				}, 1200)
				return true
			},

			handleFloatTap(): void {
				if (this.isTranscribing == true) {
					uni.showToast({ position: 'bottom', title: '正在识别，稍等', icon: 'none' })
					return
				}
				if (ensureNyxAdminAgent() == false) {
					showNyxRuntimeStateFailure('nyx_float_ensure_agent', '眠汐初始化失败')
					return
				}
				let previousAgentId = ''
				let previousConversationId = ''
				try {
					previousAgentId = getActiveAgentRuntimeId()
					previousConversationId = getActiveConversationRuntimeId()
				} catch (_e: any) {
					showNyxRuntimeStateFailure('nyx_float_open_chat', '无法打开眠汐私聊')
					return
				}
				if (setActiveChatRouteState(NYX_ADMIN_AGENT_ID, '') == false) {
					showNyxRuntimeStateFailure('nyx_float_open_chat', '无法打开眠汐私聊')
					return
				}
				if (this.navigateToChatOnce(previousAgentId, previousConversationId, true) == false) {
					if (setActiveChatRouteState(previousAgentId, previousConversationId) == false) {
						reportAppErrorFromCause('NYX_FLOAT_RUNTIME_STATE_ROLLBACK_FAILED', APP_ERROR_CATEGORY_RUNTIME, 'nyx_float_navigation_throttled_rollback', '眠汐私聊状态恢复失败', '跨页运行状态回滚 SQLite 失败', true)
					}
				}
			},

			clearPendingVoiceStart(): void {
				if (this.recordStartTimer <= 0) { return }
				clearTimeout(this.recordStartTimer)
				this.recordStartTimer = 0
			},

			scheduleVoiceStart(): void {
				this.clearPendingVoiceStart()
				if (this.isRecording == true || this.isTranscribing == true) { return }
				this.recordStartTimer = setTimeout(() => {
					this.recordStartTimer = 0
					if (this.floatTouching == true && this.floatMoved == false) {
						if (this.hasValidDefaultTaskModel('stt') == false) {
							this.floatLongPressHandled = true
							uni.showToast({ position: 'bottom', title: '请先配置语音识别模型', icon: 'none' })
							return
						}
						this.floatLongPressHandled = true
						this.startVoice()
					}
				}, this.recordStartDelay)
			},

			clampNumber(value: number, minValue: number, maxValue: number): number {
				let max = maxValue
				if (max < minValue) { max = minValue }
				if (value < minValue) { return minValue }
				if (value > max) { return max }
				return value
			},

			refreshWindowSize(): void {
				const info = uni.getWindowInfo()
				this.windowWidth = info.windowWidth
				this.windowHeight = info.windowHeight
			},

			initFloatPosition(): void {
				this.refreshWindowSize()
				if (this.restoreFloatPosition() == true) {
					this.floatReady = true
					return
				}
				const defaultBottom = 168
				const x = this.windowWidth - this.floatSize - this.floatGap
				const y = this.windowHeight - this.floatSize - defaultBottom
				this.floatX = this.clampNumber(x, this.floatGap, this.windowWidth - this.floatSize - this.floatGap)
				this.floatY = this.clampNumber(y, this.floatGap, this.windowHeight - this.floatSize - this.floatGap)
				this.floatReady = true
			},

			restoreFloatPosition(): boolean {
				const raw = getNyxFloatPosition()
				if (raw == '') { return false }
				try {
					const parsed = JSON.parse(raw) as UTSJSONObject
					const xRaw = parsed['x'] as number | null
					const yRaw = parsed['y'] as number | null
					if (xRaw == null || yRaw == null) { return false }
					this.floatX = this.clampNumber(xRaw, this.floatGap, this.windowWidth - this.floatSize - this.floatGap)
					this.floatY = this.clampNumber(yRaw, this.floatGap, this.windowHeight - this.floatSize - this.floatGap)
					return true
				} catch (_e: any) {
				}
				return false
			},

			saveFloatPosition(): void {
				if (setNyxFloatPosition('{"x":' + Math.floor(this.floatX).toString() + ',"y":' + Math.floor(this.floatY).toString() + '}') == false) {
					showNyxRuntimeStateFailure('nyx_float_save_position', '悬浮球位置保存失败')
				}
			},

			onFloatTouchStart(e: UniTouchEvent): void {
				this.refreshWindowSize()
				this.floatTouching = true
				this.floatMoved = false
				this.floatLongPressHandled = false
				const touch = e.touches[0]
				this.dragStartX = touch.clientX
				this.dragStartY = touch.clientY
				this.dragBaseX = this.floatX
				this.dragBaseY = this.floatY
				this.scheduleVoiceStart()
			},

			onFloatTouchMove(e: UniTouchEvent): void {
				if (this.floatTouching == false) { return }
				if (this.isRecording == true) { return }
				const touch = e.touches[0]
				const deltaX = touch.clientX - this.dragStartX
				const deltaY = touch.clientY - this.dragStartY
				if (Math.abs(deltaX) > 5 || Math.abs(deltaY) > 5) {
					this.floatMoved = true
					this.clearPendingVoiceStart()
				}
				const maxX = this.windowWidth - this.floatSize - this.floatGap
				const maxY = this.windowHeight - this.floatSize - this.floatGap
				this.floatX = this.clampNumber(this.dragBaseX + deltaX, this.floatGap, maxX)
				this.floatY = this.clampNumber(this.dragBaseY + deltaY, this.floatGap, maxY)
				e.preventDefault()
			},

			onFloatTouchEnd(): void {
				if (this.floatTouching == false) { return }
				this.floatTouching = false
				this.clearPendingVoiceStart()
				if (this.isRecording == true) {
					this.stopVoice()
					return
				}
				if (this.floatLongPressHandled == true) {
					return
				}
				if (this.floatMoved == true) {
					this.saveFloatPosition()
					return
				}
				this.handleFloatTap()
			},

			hasValidDefaultTaskModel(type: string): boolean {
				const config = getDefaultTaskModel(type)
				if (config == null) { return false }
				const providerIdRaw = config['providerId'] as string | null
				const modelRaw = config['model'] as string | null
				const providerId = providerIdRaw != null ? providerIdRaw : ''
				const model = modelRaw != null ? modelRaw : ''
				return providerId != '' && model != ''
			},

			startVoice(): void {
				if (this.isTranscribing == true) { return }
				if (this.isRecording == true) { return }
				if (this.hasValidDefaultTaskModel('stt') == false) {
					uni.showToast({ position: 'bottom', title: '请先配置语音识别模型', icon: 'none' })
					return
				}
				this.isRecording = true
				this.voiceSessionId++
				const sessionId = this.voiceSessionId
				const recorder = uni.getRecorderManager()
				recorder.onStop((res: any): void => {
					if (sessionId != this.voiceSessionId) { return }
					this.isRecording = false
					const raw = JSON.stringify(res)
					if (raw == '') { return }
					const parsed = JSON.parse(raw) as UTSJSONObject
					const rawTempPath = parsed['tempFilePath'] as string | null
					const tempPath = rawTempPath != null ? rawTempPath : ''
					if (tempPath != '') {
						this.handleVoiceRecordStopped(tempPath)
					}
				})
				recorder.onError((err: any): void => {
					if (sessionId != this.voiceSessionId) { return }
					this.isRecording = false
					console.log('[NyxFloatVoice] 录音失败: ' + err)
					uni.showToast({ position: 'bottom', title: '录音失败', icon: 'none' })
				})
				const startOpts: RecorderManagerStartOptions = {
					format: 'wav',
				}
				recorder.start(startOpts)
			},

			stopVoice(): void {
				if (this.isRecording == false) { return }
				const recorder = uni.getRecorderManager()
				recorder.stop()
			},

			handleVoiceRecordStopped(tempPath: string): void {
				if (tempPath == '') { return }
				this.isTranscribing = true
				transcribeAudio(tempPath).then((result) => {
					this.isTranscribing = false
					if (result.ok == true) {
						this.dispatchRecognizedText(result.text)
						return
					}
					uni.showToast({ position: 'bottom', title: result.error, icon: 'none' })
				})
			},

			dispatchRecognizedText(text: string): void {
				const content = text.trim()
				if (content == '') {
					uni.showToast({ position: 'bottom', title: '没听清，再来一次', icon: 'none' })
					return
				}
				const context = readNyxFloatVoiceContext()
				if (context != '') {
					if (publishNyxFloatVoiceText(content) == false) {
						showNyxRuntimeStateFailure('nyx_float_publish_voice', '语音消息保存失败')
						return
					}
					uni.showToast({ position: 'bottom', title: '已发送', icon: 'success' })
					return
				}
				let activeAgentId = ''
				try {
					activeAgentId = getActiveAgentRuntimeId()
				} catch (_e: any) {
					showNyxRuntimeStateFailure('nyx_float_read_active_agent', '无法读取当前联系人')
					return
				}
				if (activeAgentId == '') {
					uni.showToast({ position: 'bottom', title: '先选择一个联系人', icon: 'none' })
					return
				}
				if (publishNyxFloatVoiceText(content) == false) {
					showNyxRuntimeStateFailure('nyx_float_publish_voice', '语音消息保存失败')
					return
				}
				uni.showToast({ position: 'bottom', title: '已发给当前私聊', icon: 'success' })
				this.navigateToChatOnce('', '', false)
			}
		}
	}
</script>

<style>
	.nyx-float-wrap {
		position: fixed;
		width: 54px;
		height: 54px;
		z-index: 999;
	}

	.nyx-float {
		width: 54px;
		height: 54px;
		border-radius: 27px;
		background-color: #FB8FAB;
		align-items: center;
		justify-content: center;
		border-width: 2px;
		border-color: #FFFFFF;
		border-style: solid;
		box-shadow: 0 10px 24px rgba(251, 143, 171, 0.28);
	}

	.nyx-float-active {
		background-color: #EF4444;
	}

	.nyx-face {
		font-size: 18px;
		font-weight: 800;
		color: #FFFFFF;
	}

	.nyx-dot {
		position: absolute;
		top: -18px;
		right: -4px;
		padding: 2px 6px;
		border-radius: 999px;
		background-color: #111827;
		color: #FFFFFF;
		font-size: 10px;
	}

</style>
