export type GroupSessionDeleteResult = {
	ok: boolean
	filesCleared: boolean
}

// LEGACY_COMPAT: 旧版曾把群调度提示词存成全局设置；未来清兼容时删除。
const LEGACY_GLOBAL_SCHEDULER_PROMPT_SETTING_KEY = 'global_scheduler_prompt'

function readLegacySchedulerPrompt(): string {
	const legacyPrompt = getAppSetting(LEGACY_GLOBAL_SCHEDULER_PROMPT_SETTING_KEY)
	return legacyPrompt != null ? legacyPrompt : ''
}

function legacyGetGroupChats(): GroupChat[] {
	const raw = uni.getStorageSync(GROUP_CHAT_LIST_KEY) as string | null
	return parseGroupChats(safeJsonText(raw), readLegacySchedulerPrompt())
}

function legacyGetGroupMembers(groupId: string): GroupChatMember[] {
	const raw = uni.getStorageSync(storageMembersKey(groupId)) as string | null
	return parseGroupMembers(safeJsonText(raw))
}

function legacyGetGroupSessions(groupId: string): GroupChatSession[] {
	const raw = uni.getStorageSync(storageSessionsKey(groupId)) as string | null
	return parseGroupSessions(safeJsonText(raw))
}

function legacyGetGroupMessages(groupId: string, sessionId: string): UTSJSONObject[] {
	const raw = uni.getStorageSync(storageMessagesKey(groupId, sessionId)) as string | null
	return parseGroupMessages(safeJsonText(raw))
}

function isSafeId(id: string): boolean {
	if (id == '') { return false }
	if (id.indexOf('/') >= 0 || id.indexOf('\\') >= 0) { return false }
	if (id == '..' || id.indexOf('..') >= 0) { return false }
	return true
}

function ensureDirectory(path: string): void {
	if (path == '') { return }
	if (exists(path) == false) {
		createDir(path, true)
	}
}

export function getGroupChats(): GroupChat[] {
	const rows = getGroupChatRows()
	const result: GroupChat[] = []
	const legacySchedulerPrompt = readLegacySchedulerPrompt()
	for (let i = 0; i < rows.length; i++) {
		result.push(dbRowToGroupChat(rows[i], legacySchedulerPrompt))
	}
	return result
}

export function saveGroupChats(groups: GroupChat[]): void {
	for (let i = 0; i < groups.length; i++) {
		saveGroupChatRow(groupChatToDbRow(groups[i]))
	}
}

export function getGroupChatById(groupId: string): GroupChat | null {
	const row = getGroupChatRowById(groupId)
	if (row != null) {
		return dbRowToGroupChat(row, readLegacySchedulerPrompt())
	}
	return null
}

export function saveGroupChat(group: GroupChat): void {
	saveGroupChatRow(groupChatToDbRow(group))
}

export function buildGroupWorkspaceRoot(): string {
	const filesDir = getInternalFilesDir()
	if (filesDir == '') { return '' }
	const root = joinPath(filesDir, 'group-workspaces')
	ensureDirectory(root)
	return root
}

export function buildGroupWorkspacePath(groupId: string, sessionId: string): string {
	if (isSafeId(groupId) == false || isSafeId(sessionId) == false) { return '' }
	const root = buildGroupWorkspaceRoot()
	if (root == '') { return '' }
	return joinPath(joinPath(root, groupId), sessionId)
}

export function getGroupSessionWorkspaceDir(groupId: string, sessionId: string): string {
	const dir = buildGroupWorkspacePath(groupId, sessionId)
	ensureDirectory(dir)
	return dir
}

function isInsideGroupWorkspace(path: string): boolean {
	const root = normalizePath(buildGroupWorkspaceRoot())
	const target = normalizePath(path)
	if (root == '' || target == '') { return false }
	return target == root || target.startsWith(root + '/')
}

export function getGroupMembers(groupId: string): GroupChatMember[] {
	const rows = getGroupMemberRows(groupId)
	const result: GroupChatMember[] = []
	for (let i = 0; i < rows.length; i++) {
		result.push(dbRowToGroupMember(rows[i]))
	}
	return result
}

export function saveGroupMembers(groupId: string, members: GroupChatMember[]): void {
	const rows: UTSJSONObject[] = []
	for (let i = 0; i < members.length; i++) {
		rows.push(memberToDbRow(members[i]))
	}
	saveGroupMemberRows(groupId, rows)
}

export function getActiveGroupMembers(groupId: string): GroupChatMember[] {
	const members = getGroupMembers(groupId)
	const result: GroupChatMember[] = []
	for (let i = 0; i < members.length; i++) {
		if (members[i].active == true && getAgentById(members[i].agentId) != null) {
			result.push(members[i])
		}
	}
	result.sort((a: GroupChatMember, b: GroupChatMember): number => {
		if (a.order < b.order) { return -1 }
		if (a.order > b.order) { return 1 }
		return 0
	})
	return result
}

export function isAgentInGroup(groupId: string, agentId: string): boolean {
	if (getAgentById(agentId) == null) {
		return false
	}
	const members = getGroupMembers(groupId)
	for (let i = 0; i < members.length; i++) {
		if (members[i].agentId == agentId && members[i].active == true) {
			return true
		}
	}
	return false
}

export function addGroupMember(groupId: string, agentId: string): void {
	if (groupId == '' || agentId == '') { return }
	const members = getGroupMembers(groupId)
	for (let i = 0; i < members.length; i++) {
		if (members[i].agentId == agentId) {
			members[i].active = true
			members[i].leftAt = 0
			saveGroupMembers(groupId, members)
			return
		}
	}
	members.push({
		id: createId('gmember'),
		groupId: groupId,
		agentId: agentId,
		active: true,
		joinedAt: Date.now(),
		leftAt: 0,
		order: members.length,
	} as GroupChatMember)
	saveGroupMembers(groupId, members)
}

export function removeGroupMember(groupId: string, agentId: string): void {
	const members = getGroupMembers(groupId)
	for (let i = 0; i < members.length; i++) {
		if (members[i].agentId == agentId && members[i].active == true) {
			members[i].active = false
			members[i].leftAt = Date.now()
			break
		}
	}
	saveGroupMembers(groupId, members)
}

export function getGroupSessions(groupId: string): GroupChatSession[] {
	const rows = getGroupSessionRows(groupId)
	const result: GroupChatSession[] = []
	for (let i = 0; i < rows.length; i++) {
		result.push(dbRowToGroupSession(rows[i]))
	}
	return result
}

export function saveGroupSessions(groupId: string, sessions: GroupChatSession[]): void {
	const rows: UTSJSONObject[] = []
	for (let i = 0; i < sessions.length; i++) {
		rows.push(sessionToDbRow(sessions[i]))
	}
	saveGroupSessionRows(groupId, rows)
}

export function getGroupSessionById(groupId: string, sessionId: string): GroupChatSession | null {
	const sessions = getGroupSessions(groupId)
	for (let i = 0; i < sessions.length; i++) {
		if (sessions[i].id == sessionId) {
			return sessions[i]
		}
	}
	return null
}

export function saveGroupSession(session: GroupChatSession): void {
	const sessions = getGroupSessions(session.groupId)
	let found = false
	for (let i = 0; i < sessions.length; i++) {
		if (sessions[i].id == session.id) {
			sessions.splice(i, 1, session)
			found = true
			break
		}
	}
	if (found == false) {
		sessions.push(session)
	}
	saveGroupSessions(session.groupId, sessions)
}

export function createGroupSession(groupId: string, title: string = ''): GroupChatSession {
	const sessionId = createId('gsession')
	const sessionTitle = title.trim() != '' ? title.trim() : '故事会话'
	const workspace = getGroupSessionWorkspaceDir(groupId, sessionId)
	const session: GroupChatSession = {
		id: sessionId,
		groupId: groupId,
		title: sessionTitle,
		workspacePath: workspace,
		forkedFromSessionId: '',
		titleLocked: false,
		createdAt: Date.now(),
		updatedAt: Date.now(),
	}
	const sessions = getGroupSessions(groupId)
	sessions.push(session)
	saveGroupSessions(groupId, sessions)
	return session
}

export function ensureGroupActiveSession(group: GroupChat): GroupChatSession {
	let session = getGroupSessionById(group.id, group.activeSessionId)
	if (session != null) {
		getGroupSessionWorkspaceDir(group.id, session.id)
		return session
	}
	const sessions = getGroupSessions(group.id)
	if (sessions.length > 0) {
		session = sessions[0]
		group.activeSessionId = session.id
		group.updatedAt = Date.now()
		saveGroupChat(group)
		getGroupSessionWorkspaceDir(group.id, session.id)
		return session
	}
	session = createGroupSession(group.id, '故事会话')
	group.activeSessionId = session.id
	group.updatedAt = Date.now()
	saveGroupChat(group)
	return session
}

export function setActiveGroupSession(groupId: string, sessionId: string): void {
	const group = getGroupChatById(groupId)
	if (group == null) { return }
	const session = getGroupSessionById(groupId, sessionId)
	if (session == null) { return }
	group.activeSessionId = sessionId
	group.updatedAt = Date.now()
	saveGroupChat(group)
	setActiveGroupChat(groupId)
	setActiveGroupSessionId(sessionId)
}

export function getActiveGroupChatId(): string {
	const dbValue = getGroupChatState(ACTIVE_GROUP_CHAT_ID_KEY)
	return dbValue
}

export function setActiveGroupChat(groupId: string): void {
	if (groupId == '') { return }
	setGroupChatState(ACTIVE_GROUP_CHAT_ID_KEY, groupId)
}

export function getActiveGroupSessionId(): string {
	const dbValue = getGroupChatState(ACTIVE_GROUP_SESSION_ID_KEY)
	return dbValue
}

export function setActiveGroupSessionId(sessionId: string): void {
	if (sessionId == '') { return }
	setGroupChatState(ACTIVE_GROUP_SESSION_ID_KEY, sessionId)
}

export function updateGroupSessionTitle(groupId: string, sessionId: string, title: string): void {
	const session = getGroupSessionById(groupId, sessionId)
	if (session == null) { return }
	const safeTitle = title.trim()
	if (safeTitle == '') { return }
	session.title = safeTitle
	session.titleLocked = true
	session.updatedAt = Date.now()
	saveGroupSession(session)
}

export function applyGroupSessionTitleSuggestion(groupId: string, sessionId: string, title: string): void {
	const session = getGroupSessionById(groupId, sessionId)
	if (session == null) { return }
	const safeTitle = title.trim()
	if (safeTitle == '') { return }
	if (session.titleLocked == true) { return }
	if (session.title != '' && session.title != '故事会话' && session.title != '新会话') { return }
	session.title = safeTitle
	session.updatedAt = Date.now()
	saveGroupSession(session)
}

export function getGroupMessages(groupId: string, sessionId: string): UTSJSONObject[] {
	const rows = getGroupMessageRows(groupId, sessionId)
	const result: UTSJSONObject[] = []
	for (let i = 0; i < rows.length; i++) {
		result.push(dbRowToGroupMessage(rows[i]))
	}
	return result
}

export function saveGroupMessages(groupId: string, sessionId: string, messages: UTSJSONObject[]): void {
	saveGroupMessageRows(groupId, sessionId, messages)
	const session = getGroupSessionById(groupId, sessionId)
	if (session != null) {
		session.updatedAt = Date.now()
		saveGroupSession(session)
	}
	const group = getGroupChatById(groupId)
	if (group != null) {
		group.updatedAt = Date.now()
		saveGroupChat(group)
	}
}

export function listGroupAgentContextRecords(agentId: string): UTSJSONObject[] {
	const rows = getGroupAgentContextRows(agentId)
	const records: UTSJSONObject[] = []
	for (let i = 0; i < rows.length; i++) {
		const payload = readStringField(rows[i], 'payload_json')
		try {
			const record = JSON.parse(payload) as UTSJSONObject
			records.push(record)
		} catch (_e: any) {
		}
	}
	records.sort((a: UTSJSONObject, b: UTSJSONObject): number => {
		const at = a['createdAt'] as number | null
		const bt = b['createdAt'] as number | null
		const av = at != null ? at : 0
		const bv = bt != null ? bt : 0
		if (av == bv) { return 0 }
		return av > bv ? -1 : 1
	})
	return records
}

export function getGroupAgentContextRecord(agentId: string, recordId: string): UTSJSONObject | null {
	const records = listGroupAgentContextRecords(agentId)
	for (let i = 0; i < records.length; i++) {
		const id = records[i]['id'] as string | null
		if (id == recordId) { return records[i] }
	}
	return null
}

export function deleteGroupAgentContextRecord(agentId: string, recordId: string): void {
	deleteGroupAgentContextRow(agentId, recordId)
}

export function saveGroupAgentContextRecord(record: UTSJSONObject): void {
	const agentId = record['agentId'] as string | null
	if (agentId == null || agentId == '') { return }
	saveGroupAgentContextRow(record)
}

export function migrateLegacyGroupChatStorage(storageKeys: string[]): number {
	let migrated = 0
	const canMigrateGroups = getGroupChatRows().length == 0
	const groups: GroupChat[] = canMigrateGroups == true ? legacyGetGroupChats() : []
	if (canMigrateGroups == true) {
		if (groups.length > 0) {
			saveGroupChats(groups)
			migrated += groups.length
		}

		for (let i = 0; i < groups.length; i++) {
			const groupId = groups[i].id
			const members = legacyGetGroupMembers(groupId)
			if (members.length > 0) {
				saveGroupMembers(groupId, members)
				migrated += members.length
			}
			const sessions = legacyGetGroupSessions(groupId)
			if (sessions.length > 0) {
				saveGroupSessions(groupId, sessions)
				migrated += sessions.length
			}
			for (let j = 0; j < sessions.length; j++) {
				const messages = legacyGetGroupMessages(groupId, sessions[j].id)
				if (messages.length > 0) {
					saveGroupMessages(groupId, sessions[j].id, messages)
					migrated += messages.length
				}
			}
		}
	}

	if (canMigrateGroups == true) {
		try {
			const activeGroupId = uni.getStorageSync(ACTIVE_GROUP_CHAT_ID_KEY) as string | null
			if (activeGroupId != null && activeGroupId != '' && getGroupChatState(ACTIVE_GROUP_CHAT_ID_KEY) == '') {
				setGroupChatState(ACTIVE_GROUP_CHAT_ID_KEY, activeGroupId)
				migrated++
			}
		} catch (_e: any) {
		}
		try {
			const activeSessionId = uni.getStorageSync(ACTIVE_GROUP_SESSION_ID_KEY) as string | null
			if (activeSessionId != null && activeSessionId != '' && getGroupChatState(ACTIVE_GROUP_SESSION_ID_KEY) == '') {
				setGroupChatState(ACTIVE_GROUP_SESSION_ID_KEY, activeSessionId)
				migrated++
			}
		} catch (_e2: any) {
		}
	}

	const agentContextPrefix = 'group_agent_context_records_'
	for (let k = 0; k < storageKeys.length; k++) {
		const key = storageKeys[k]
		if (key.startsWith(agentContextPrefix) == false) { continue }
		const agentId = key.substring(agentContextPrefix.length)
		if (agentId == '') { continue }
		if (getGroupAgentContextRows(agentId).length > 0) { continue }
		const raw = uni.getStorageSync(key) as string | null
		const records = parseAgentContextRecords(safeJsonText(raw))
		for (let r = 0; r < records.length; r++) {
			saveGroupAgentContextRecord(records[r])
			migrated++
		}
	}
	return migrated
}

export function createGroupAgentContextRecord(group: GroupChat, session: GroupChatSession, agentId: string, agentName: string, action: UTSJSONObject, runtimeMessages: UTSJSONObject[], systemPrompt: string): UTSJSONObject {
	return createGroupAgentContextRecordPayload(group, session, agentId, agentName, action, runtimeMessages, systemPrompt)
}

export function appendGroupMessage(groupId: string, sessionId: string, message: UTSJSONObject): void {
	const messages = getGroupMessages(groupId, sessionId)
	messages.push(message)
	saveGroupMessages(groupId, sessionId, messages)
}


export function createGroupUserMessage(groupId: string, sessionId: string, content: string, userName: string = ''): UTSJSONObject {
	const base = createTextMessage(CHAT_ROLE_USER, content)
	return decorateGroupMessage(base, groupId, sessionId, GROUP_MESSAGE_SENDER_USER, '', normalizeGroupUserDisplayName(userName), '', true, GROUP_MESSAGE_VISIBILITY_PUBLIC)
}

export function createGroupHiddenMessage(groupId: string, sessionId: string, senderType: string, content: string): UTSJSONObject {
	const base = createTextMessage('system', content)
	const group = senderType == GROUP_MESSAGE_SENDER_SCHEDULER || senderType == GROUP_MESSAGE_SENDER_REVIEWER ? getGroupChatById(groupId) : null
	const senderName = resolveGroupHiddenSenderName(group, senderType)
	const senderAgentId = resolveGroupHiddenSenderAgentId(group, senderType)
	return decorateGroupMessage(base, groupId, sessionId, senderType, senderAgentId, senderName, '', false, GROUP_MESSAGE_VISIBILITY_INTERNAL, [] as string[])
}


export function createGroupAgentStreamingMessage(groupId: string, sessionId: string, agentId: string): UTSJSONObject {
	const agent = getAgentById(agentId)
	const name = readAgentName(agent)
	const avatar = readAgentAvatar(agent)
	const base = createAssistantStreamingMessage([] as UTSJSONObject[], Date.now())
	base['hideThinking'] = readAgentHideThinking(agent)
	base['msgSegmentation'] = readAgentMsgSegmentation(agent)
	return decorateGroupMessage(base, groupId, sessionId, GROUP_MESSAGE_SENDER_AGENT, agentId, name, avatar, true, GROUP_MESSAGE_VISIBILITY_PUBLIC)
}

export function createGroupAgentFinalMessage(groupId: string, sessionId: string, agentId: string, parts: UTSJSONObject[], content: string): UTSJSONObject {
	const agent = getAgentById(agentId)
	const name = readAgentName(agent)
	const avatar = readAgentAvatar(agent)
	const cleanParts = cloneParts(parts)
	stripGroupAgentSpeakerPrefixFromParts(cleanParts, name)
	const base = createAssistantFinalMessage(cleanParts, Date.now())
	const cleanContent = extractPlainText(cleanParts)
	base['content'] = cleanContent != '' ? cleanContent : stripGroupAgentSpeakerPrefix(content, name)
	base['hideThinking'] = readAgentHideThinking(agent)
	base['msgSegmentation'] = readAgentMsgSegmentation(agent)
	return decorateGroupMessage(base, groupId, sessionId, GROUP_MESSAGE_SENDER_AGENT, agentId, name, avatar, true, GROUP_MESSAGE_VISIBILITY_PUBLIC)
}

export function createGroupUserImageMessage(groupId: string, sessionId: string, imagePath: string, userName: string = ''): UTSJSONObject {
	const base = createImageMessage(imagePath)
	return decorateGroupMessage(base, groupId, sessionId, GROUP_MESSAGE_SENDER_USER, '', normalizeGroupUserDisplayName(userName), '', true, GROUP_MESSAGE_VISIBILITY_PUBLIC)
}

export function createGroupUserFileMessage(groupId: string, sessionId: string, fileName: string, filePath: string, userName: string = '', fileText: string = ''): UTSJSONObject {
	const base = createFileMessage(fileName, filePath, fileText)
	return decorateGroupMessage(base, groupId, sessionId, GROUP_MESSAGE_SENDER_USER, '', normalizeGroupUserDisplayName(userName), '', true, GROUP_MESSAGE_VISIBILITY_PUBLIC)
}

export function revokeGroupAgentMessage(groupId: string, sessionId: string, messageId: string): void {
	const messages = getGroupMessages(groupId, sessionId)
	for (let i = 0; i < messages.length; i++) {
		const id = messages[i]['id'] as string | null
		const senderType = messages[i]['senderType'] as string | null
		if (id == messageId && senderType == GROUP_MESSAGE_SENDER_AGENT) {
			markGroupMessageRevokedFields(messages[i])
			break
		}
	}
	saveGroupMessages(groupId, sessionId, messages)
}

export function markGroupAgentMessageRevoked(message: UTSJSONObject): void {
	markGroupMessageRevokedFields(message)
}

export function deleteGroupSession(groupId: string, sessionId: string, clearFiles: boolean): GroupSessionDeleteResult {
	const sessions = getGroupSessions(groupId)
	const next: GroupChatSession[] = []
	let targetWorkspace = ''
	let found = false
	for (let i = 0; i < sessions.length; i++) {
		if (sessions[i].id == sessionId) {
			targetWorkspace = sessions[i].workspacePath
			found = true
		} else {
			next.push(sessions[i])
		}
	}
	if (found == false) {
		return { ok: false, filesCleared: false } as GroupSessionDeleteResult
	}
	try {
		deleteGroupSessionDbRows(groupId, sessionId)
	} catch (_e: any) {
		return { ok: false, filesCleared: false } as GroupSessionDeleteResult
	}
	let filesCleared = true
	if (clearFiles == true && targetWorkspace != '' && isInsideGroupWorkspace(targetWorkspace) == true && exists(targetWorkspace) == true) {
		const deleteResult = deleteItem(targetWorkspace, true)
		filesCleared = deleteResult.ok
	}
	const group = getGroupChatById(groupId)
	if (group != null && group.activeSessionId == sessionId) {
		if (next.length > 0) {
			group.activeSessionId = next[0].id
		} else {
			const fresh = createGroupSession(groupId, '故事会话')
			group.activeSessionId = fresh.id
		}
		group.updatedAt = Date.now()
		saveGroupChat(group)
		setActiveGroupSessionId(group.activeSessionId)
	}
	return { ok: true, filesCleared: filesCleared } as GroupSessionDeleteResult
}

export function forkGroupSession(groupId: string, sessionId: string): GroupChatSession | null {
	const source = getGroupSessionById(groupId, sessionId)
	if (source == null) { return null }
	const forkId = createId('gsession')
	const sourceTitle = displaySessionTitle(source)
	const destWorkspace = buildGroupWorkspacePath(groupId, forkId)
	if (source.workspacePath != '' && destWorkspace != '' && exists(source.workspacePath) == true && isInsideGroupWorkspace(source.workspacePath) == true && isInsideGroupWorkspace(destWorkspace) == true) {
		copyItem(source.workspacePath, destWorkspace)
	} else {
		ensureDirectory(destWorkspace)
	}
	const forked: GroupChatSession = {
		id: forkId,
		groupId: groupId,
		title: sourceTitle + ' · 分支',
		workspacePath: destWorkspace,
		forkedFromSessionId: sessionId,
		titleLocked: false,
		createdAt: Date.now(),
		updatedAt: Date.now(),
	}
	const sessions = getGroupSessions(groupId)
	sessions.push(forked)
	saveGroupSessions(groupId, sessions)
	const oldMessages = getGroupMessages(groupId, sessionId)
	const copiedMessages = cloneGroupMessagesForFork(oldMessages, forkId)
	saveGroupMessages(groupId, forkId, copiedMessages)
	return forked
}

export function createDefaultWritingGroupChat(): GroupChat {
	const agents = getAgents()
	let firstMember = ''
	let secondMember = ''
	if (agents.length > 0) {
		const firstId = agents[0]['id'] as string | null
		firstMember = firstId != null ? firstId : ''
	}
	for (let i = 0; i < agents.length; i++) {
		const aid = agents[i]['id'] as string | null
		if (aid == 'writing-helper') { firstMember = aid }
		if (aid == 'idea-lab') { secondMember = aid }
	}
	if (secondMember == '' && agents.length > 1) {
		const fallbackId = agents[1]['id'] as string | null
		secondMember = fallbackId != null ? fallbackId : ''
	}
	const groupId = createId('gchat')
	const group: GroupChat = {
		id: groupId,
		name: '故事工坊',
		avatar: '',
		schedulerAgentId: buildGroupSchedulerAgentId(groupId),
		schedulerPrompt: buildDefaultSchedulerPrompt(),
		sharedPrompt: buildDefaultSharedPrompt(),
		activeSessionId: '',
		createdAt: Date.now(),
		updatedAt: Date.now(),
	}
	saveGroupChat(group)
	if (firstMember != '') { addGroupMember(groupId, firstMember) }
	if (secondMember != '' && secondMember != firstMember) { addGroupMember(groupId, secondMember) }
	const session = createGroupSession(groupId, '故事会话')
	group.activeSessionId = session.id
	saveGroupChat(group)
	return group
}
