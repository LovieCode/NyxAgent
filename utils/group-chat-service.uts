/**
 * 群聊数据模型与服务
 *
 * AstrBot 风格：持久化记录和 UI 展示解耦。
 * 群聊复用私聊 Agent 设置，群会话拥有独立共享工作区。
 */

import { getAgentById, getAgents } from '@/utils/agent.uts'
import {
	getInternalFilesDir,
	joinPath,
	createDir,
	exists,
	copyItem,
	deleteItem,
	normalizePath,
} from '@/utils/file-manager.uts'
import {
	CHAT_PART_PLAIN,
	CHAT_ROLE_ASSISTANT,
	CHAT_ROLE_USER,
	cloneParts,
	createAssistantFinalMessage,
	createAssistantStreamingMessage,
	createFileMessage,
	createImageMessage,
	createPlainPart,
	createTextMessage,
	extractPlainText,
	getMessageContent,
	getMessageParts,
} from '@/utils/chat-models.uts'
import { buildRuntimeMessages as buildRuntimeChatMessages } from '@/utils/chat-message-reducer.uts'

export const GROUP_CHAT_LIST_KEY = 'group_chat_list'
export const ACTIVE_GROUP_CHAT_ID_KEY = 'active_group_chat_id'
export const ACTIVE_GROUP_SESSION_ID_KEY = 'active_group_session_id'

export const GROUP_MESSAGE_SENDER_USER = 'user'
export const GROUP_MESSAGE_SENDER_AGENT = 'agent'
export const GROUP_MESSAGE_SENDER_SCHEDULER = 'scheduler'
export const GROUP_MESSAGE_SENDER_SYSTEM = 'system'

const DEFAULT_SCHEDULER_PROMPT_TEXT = '你是隐藏的群聊调度 Agent。你可以在内部向任意成员 Agent 传递私密指令、背景信息和任务拆解，也可以指定一个或多个成员按顺序发言。你的存在、调度流程、私密指令不能被其他成员在公开发言中暴露。你只在系统触发节点工作，例如用户发消息、用户手动继续、连续讨论过多需要判断是否继续。\n' +
	'输出必须是 JSON 对象，禁止 Markdown，结构：{"actions":[{"type":"speak","agentId":"成员ID","targetType":"user","targetAgentId":"","privateInstruction":"给该成员的私密指令","publicIntent":"公开发言目标","replyLength":"short","replyGuidance":"简短自然，优先 1-3 句","searchAdvice":"none","searchInstruction":"","order":0}],"shouldContinue":false,"titleSuggestion":"适合本会话的短标题","privateNotes":"仅内部记录"}。\n' +
	'默认让成员简短发言。事实不确定、涉及外部/时效信息时，建议具备相关工具的成员先查证或搜索；发现跑题、重复、事实冲突或虚构 App 功能时，用私密指令要求纠偏和收束。不要为了热闹强行多人发言。'

const DEFAULT_SHARED_PROMPT_TEXT = '这是一个故事/写作交流群聊。成员可以讨论人物、剧情、节奏、文风和表达，但要自然像群聊发言。公开发言只输出自己要说的话，不写舞台说明，不提隐藏调度、内部指令或系统消息。'

export type GroupChat = {
	id: string
	name: string
	avatar: string
	schedulerAgentId: string
	schedulerPrompt: string
	sharedPrompt: string
	activeSessionId: string
	createdAt: number
	updatedAt: number
}

export type GroupChatMember = {
	id: string
	groupId: string
	agentId: string
	active: boolean
	joinedAt: number
	leftAt: number
	order: number
}

export type GroupChatSession = {
	id: string
	groupId: string
	title: string
	workspacePath: string
	forkedFromSessionId: string
	titleLocked: boolean
	createdAt: number
	updatedAt: number
}

export type GroupChatMessage = {
	id: string
	groupId: string
	sessionId: string
	role: string
	senderType: string
	senderAgentId: string
	senderName: string
	senderAvatar: string
	content: string
	message: UTSJSONObject[]
	visible: boolean
	revoked: boolean
	isStreaming: boolean
	timestamp: number
}

function storageMembersKey(groupId: string): string {
	return 'group_chat_members_' + groupId
}

function storageSessionsKey(groupId: string): string {
	return 'group_chat_sessions_' + groupId
}

function storageMessagesKey(groupId: string, sessionId: string): string {
	return 'group_chat_messages_' + groupId + '_' + sessionId
}

function storageAgentContextKey(agentId: string): string {
	return 'group_agent_context_records_' + agentId
}

function safeJsonText(raw: string | null): string {
	return raw != null ? raw : ''
}

function createId(prefix: string): string {
	return prefix + '-' + Date.now() + '-' + Math.floor(Math.random() * 100000)
}

function readStringField(item: UTSJSONObject, key: string): string {
	const value = item[key] as string | null
	return value != null ? value : ''
}

function readNumberField(item: UTSJSONObject, key: string): number {
	const value = item[key] as number | null
	return value != null ? value : 0
}

function readBooleanField(item: UTSJSONObject, key: string): boolean {
	const value = item[key] as boolean | null
	return value != null ? value : false
}

function normalizeGroupChat(item: UTSJSONObject): GroupChat {
	const now = Date.now()
	let name = readStringField(item, 'name')
	if (name == '') { name = '故事工坊' }
	let schedulerPrompt = readStringField(item, 'schedulerPrompt')
	if (schedulerPrompt == '') { schedulerPrompt = DEFAULT_SCHEDULER_PROMPT_TEXT }
	let sharedPrompt = readStringField(item, 'sharedPrompt')
	if (sharedPrompt == '') { sharedPrompt = DEFAULT_SHARED_PROMPT_TEXT }
	let createdAt = readNumberField(item, 'createdAt')
	if (createdAt <= 0) { createdAt = now }
	let updatedAt = readNumberField(item, 'updatedAt')
	if (updatedAt <= 0) { updatedAt = createdAt }
	return {
		id: readStringField(item, 'id'),
		name: name,
		avatar: readStringField(item, 'avatar'),
		schedulerAgentId: readStringField(item, 'schedulerAgentId'),
		schedulerPrompt: schedulerPrompt,
		sharedPrompt: sharedPrompt,
		activeSessionId: readStringField(item, 'activeSessionId'),
		createdAt: createdAt,
		updatedAt: updatedAt,
	} as GroupChat
}

function normalizeGroupMember(item: UTSJSONObject): GroupChatMember {
	let id = readStringField(item, 'id')
	if (id == '') { id = createId('gmember') }
	let joinedAt = readNumberField(item, 'joinedAt')
	if (joinedAt <= 0) { joinedAt = Date.now() }
	return {
		id: id,
		groupId: readStringField(item, 'groupId'),
		agentId: readStringField(item, 'agentId'),
		active: readBooleanField(item, 'active'),
		joinedAt: joinedAt,
		leftAt: readNumberField(item, 'leftAt'),
		order: readNumberField(item, 'order'),
	} as GroupChatMember
}

function normalizeGroupSession(item: UTSJSONObject): GroupChatSession {
	let id = readStringField(item, 'id')
	if (id == '') { id = createId('gsession') }
	let title = readStringField(item, 'title')
	if (title == '') { title = '故事会话' }
	let createdAt = readNumberField(item, 'createdAt')
	if (createdAt <= 0) { createdAt = Date.now() }
	let updatedAt = readNumberField(item, 'updatedAt')
	if (updatedAt <= 0) { updatedAt = createdAt }
	return {
		id: id,
		groupId: readStringField(item, 'groupId'),
		title: title,
		workspacePath: readStringField(item, 'workspacePath'),
		forkedFromSessionId: readStringField(item, 'forkedFromSessionId'),
		titleLocked: readBooleanField(item, 'titleLocked'),
		createdAt: createdAt,
		updatedAt: updatedAt,
	} as GroupChatSession
}

function parseGroupChats(raw: string): GroupChat[] {
	if (raw == '') { return [] as GroupChat[] }
	try {
		const list = JSON.parse(raw) as UTSJSONObject[]
		const result: GroupChat[] = []
		if (list != null) {
			for (let i = 0; i < list.length; i++) {
				const group = normalizeGroupChat(list[i])
				if (group.id != '') {
					result.push(group)
				}
			}
		}
		return result
	} catch (_e: any) {
	}
	return [] as GroupChat[]
}

function parseGroupMembers(raw: string): GroupChatMember[] {
	if (raw == '') { return [] as GroupChatMember[] }
	try {
		const list = JSON.parse(raw) as UTSJSONObject[]
		const result: GroupChatMember[] = []
		if (list != null) {
			for (let i = 0; i < list.length; i++) {
				const member = normalizeGroupMember(list[i])
				if (member.groupId != '' && member.agentId != '') {
					result.push(member)
				}
			}
		}
		return result
	} catch (_e: any) {
	}
	return [] as GroupChatMember[]
}

function parseGroupSessions(raw: string): GroupChatSession[] {
	if (raw == '') { return [] as GroupChatSession[] }
	try {
		const list = JSON.parse(raw) as UTSJSONObject[]
		const result: GroupChatSession[] = []
		if (list != null) {
			for (let i = 0; i < list.length; i++) {
				const session = normalizeGroupSession(list[i])
				if (session.id != '' && session.groupId != '') {
					result.push(session)
				}
			}
		}
		return result
	} catch (_e: any) {
	}
	return [] as GroupChatSession[]
}

function parseGroupMessages(raw: string): UTSJSONObject[] {
	if (raw == '') { return [] as UTSJSONObject[] }
	try {
		const list = JSON.parse(raw) as UTSJSONObject[]
		if (list != null) { return list }
	} catch (_e: any) {
	}
	return [] as UTSJSONObject[]
}

function parseAgentContextRecords(raw: string): UTSJSONObject[] {
	if (raw == '') { return [] as UTSJSONObject[] }
	try {
		const list = JSON.parse(raw) as UTSJSONObject[]
		if (list != null) { return list }
	} catch (_e: any) {
	}
	return [] as UTSJSONObject[]
}

function isSafeId(id: string): boolean {
	if (id == '') { return false }
	if (id.indexOf('/') >= 0 || id.indexOf('\\') >= 0) { return false }
	if (id == '..' || id.indexOf('..') >= 0) { return false }
	return true
}

function ensureDirectory(path: string): void {
	if (path == '') { return }
	if (exists(path) == false) {
		createDir(path, true)
	}
}

export function getGroupChats(): GroupChat[] {
	const raw = uni.getStorageSync(GROUP_CHAT_LIST_KEY) as string | null
	return parseGroupChats(safeJsonText(raw))
}

export function saveGroupChats(groups: GroupChat[]): void {
	uni.setStorageSync(GROUP_CHAT_LIST_KEY, JSON.stringify(groups))
}

export function getGroupChatById(groupId: string): GroupChat | null {
	const groups = getGroupChats()
	for (let i = 0; i < groups.length; i++) {
		if (groups[i].id == groupId) {
			return groups[i]
		}
	}
	return null
}

export function saveGroupChat(group: GroupChat): void {
	const groups = getGroupChats()
	let found = false
	for (let i = 0; i < groups.length; i++) {
		if (groups[i].id == group.id) {
			groups.splice(i, 1, group)
			found = true
			break
		}
	}
	if (found == false) {
		groups.push(group)
	}
	saveGroupChats(groups)
}

export function buildDefaultSchedulerPrompt(): string {
	return DEFAULT_SCHEDULER_PROMPT_TEXT
}

export function buildDefaultSharedPrompt(): string {
	return DEFAULT_SHARED_PROMPT_TEXT
}

export function buildGroupWorkspaceRoot(): string {
	const filesDir = getInternalFilesDir()
	if (filesDir == '') { return '' }
	const root = joinPath(filesDir, 'group-workspaces')
	ensureDirectory(root)
	return root
}

export function buildGroupWorkspacePath(groupId: string, sessionId: string): string {
	if (isSafeId(groupId) == false || isSafeId(sessionId) == false) { return '' }
	const root = buildGroupWorkspaceRoot()
	if (root == '') { return '' }
	return joinPath(joinPath(root, groupId), sessionId)
}

export function getGroupSessionWorkspaceDir(groupId: string, sessionId: string): string {
	const dir = buildGroupWorkspacePath(groupId, sessionId)
	ensureDirectory(dir)
	return dir
}

function isInsideGroupWorkspace(path: string): boolean {
	const root = normalizePath(buildGroupWorkspaceRoot())
	const target = normalizePath(path)
	if (root == '' || target == '') { return false }
	return target == root || target.startsWith(root + '/')
}

export function getGroupMembers(groupId: string): GroupChatMember[] {
	const raw = uni.getStorageSync(storageMembersKey(groupId)) as string | null
	return parseGroupMembers(safeJsonText(raw))
}

export function saveGroupMembers(groupId: string, members: GroupChatMember[]): void {
	uni.setStorageSync(storageMembersKey(groupId), JSON.stringify(members))
}

export function getActiveGroupMembers(groupId: string): GroupChatMember[] {
	const members = getGroupMembers(groupId)
	const result: GroupChatMember[] = []
	for (let i = 0; i < members.length; i++) {
		if (members[i].active == true && getAgentById(members[i].agentId) != null) {
			result.push(members[i])
		}
	}
	result.sort((a: GroupChatMember, b: GroupChatMember): number => {
		if (a.order < b.order) { return -1 }
		if (a.order > b.order) { return 1 }
		return 0
	})
	return result
}

export function isAgentInGroup(groupId: string, agentId: string): boolean {
	if (getAgentById(agentId) == null) {
		return false
	}
	const members = getGroupMembers(groupId)
	for (let i = 0; i < members.length; i++) {
		if (members[i].agentId == agentId && members[i].active == true) {
			return true
		}
	}
	return false
}

export function addGroupMember(groupId: string, agentId: string): void {
	if (groupId == '' || agentId == '') { return }
	const members = getGroupMembers(groupId)
	for (let i = 0; i < members.length; i++) {
		if (members[i].agentId == agentId) {
			members[i].active = true
			members[i].leftAt = 0
			saveGroupMembers(groupId, members)
			return
		}
	}
	members.push({
		id: createId('gmember'),
		groupId: groupId,
		agentId: agentId,
		active: true,
		joinedAt: Date.now(),
		leftAt: 0,
		order: members.length,
	} as GroupChatMember)
	saveGroupMembers(groupId, members)
}

export function removeGroupMember(groupId: string, agentId: string): void {
	const members = getGroupMembers(groupId)
	for (let i = 0; i < members.length; i++) {
		if (members[i].agentId == agentId && members[i].active == true) {
			members[i].active = false
			members[i].leftAt = Date.now()
			break
		}
	}
	saveGroupMembers(groupId, members)
}

export function getGroupSessions(groupId: string): GroupChatSession[] {
	const raw = uni.getStorageSync(storageSessionsKey(groupId)) as string | null
	return parseGroupSessions(safeJsonText(raw))
}

export function saveGroupSessions(groupId: string, sessions: GroupChatSession[]): void {
	uni.setStorageSync(storageSessionsKey(groupId), JSON.stringify(sessions))
}

export function displaySessionTitle(session: GroupChatSession | null): string {
	if (session == null) { return '未命名会话' }
	const title = session.title.trim()
	if (title != '') { return title }
	return '未命名会话'
}

export function getGroupSessionById(groupId: string, sessionId: string): GroupChatSession | null {
	const sessions = getGroupSessions(groupId)
	for (let i = 0; i < sessions.length; i++) {
		if (sessions[i].id == sessionId) {
			return sessions[i]
		}
	}
	return null
}

export function saveGroupSession(session: GroupChatSession): void {
	const sessions = getGroupSessions(session.groupId)
	let found = false
	for (let i = 0; i < sessions.length; i++) {
		if (sessions[i].id == session.id) {
			sessions.splice(i, 1, session)
			found = true
			break
		}
	}
	if (found == false) {
		sessions.push(session)
	}
	saveGroupSessions(session.groupId, sessions)
}

export function createGroupSession(groupId: string, title: string = ''): GroupChatSession {
	const sessionId = createId('gsession')
	const sessionTitle = title.trim() != '' ? title.trim() : '故事会话'
	const workspace = getGroupSessionWorkspaceDir(groupId, sessionId)
	const session: GroupChatSession = {
		id: sessionId,
		groupId: groupId,
		title: sessionTitle,
		workspacePath: workspace,
		forkedFromSessionId: '',
		titleLocked: false,
		createdAt: Date.now(),
		updatedAt: Date.now(),
	}
	const sessions = getGroupSessions(groupId)
	sessions.push(session)
	saveGroupSessions(groupId, sessions)
	return session
}

export function ensureGroupActiveSession(group: GroupChat): GroupChatSession {
	let session = getGroupSessionById(group.id, group.activeSessionId)
	if (session != null) {
		getGroupSessionWorkspaceDir(group.id, session.id)
		return session
	}
	const sessions = getGroupSessions(group.id)
	if (sessions.length > 0) {
		session = sessions[0]
		group.activeSessionId = session.id
		group.updatedAt = Date.now()
		saveGroupChat(group)
		getGroupSessionWorkspaceDir(group.id, session.id)
		return session
	}
	session = createGroupSession(group.id, '故事会话')
	group.activeSessionId = session.id
	group.updatedAt = Date.now()
	saveGroupChat(group)
	return session
}

export function setActiveGroupSession(groupId: string, sessionId: string): void {
	const group = getGroupChatById(groupId)
	if (group == null) { return }
	const session = getGroupSessionById(groupId, sessionId)
	if (session == null) { return }
	group.activeSessionId = sessionId
	group.updatedAt = Date.now()
	saveGroupChat(group)
	uni.setStorageSync(ACTIVE_GROUP_CHAT_ID_KEY, groupId)
	uni.setStorageSync(ACTIVE_GROUP_SESSION_ID_KEY, sessionId)
}

export function updateGroupSessionTitle(groupId: string, sessionId: string, title: string): void {
	const session = getGroupSessionById(groupId, sessionId)
	if (session == null) { return }
	const safeTitle = title.trim()
	if (safeTitle == '') { return }
	session.title = safeTitle
	session.titleLocked = true
	session.updatedAt = Date.now()
	saveGroupSession(session)
}

export function applyGroupSessionTitleSuggestion(groupId: string, sessionId: string, title: string): void {
	const session = getGroupSessionById(groupId, sessionId)
	if (session == null) { return }
	const safeTitle = title.trim()
	if (safeTitle == '') { return }
	if (session.titleLocked == true) { return }
	if (session.title != '' && session.title != '故事会话' && session.title != '新会话') { return }
	session.title = safeTitle
	session.updatedAt = Date.now()
	saveGroupSession(session)
}

export function getGroupMessages(groupId: string, sessionId: string): UTSJSONObject[] {
	const raw = uni.getStorageSync(storageMessagesKey(groupId, sessionId)) as string | null
	return parseGroupMessages(safeJsonText(raw))
}

export function saveGroupMessages(groupId: string, sessionId: string, messages: UTSJSONObject[]): void {
	uni.setStorageSync(storageMessagesKey(groupId, sessionId), JSON.stringify(messages))
	const session = getGroupSessionById(groupId, sessionId)
	if (session != null) {
		session.updatedAt = Date.now()
		saveGroupSession(session)
	}
	const group = getGroupChatById(groupId)
	if (group != null) {
		group.updatedAt = Date.now()
		saveGroupChat(group)
	}
}

export function listGroupAgentContextRecords(agentId: string): UTSJSONObject[] {
	const raw = uni.getStorageSync(storageAgentContextKey(agentId)) as string | null
	const records = parseAgentContextRecords(safeJsonText(raw))
	records.sort((a: UTSJSONObject, b: UTSJSONObject): number => {
		const at = a['createdAt'] as number | null
		const bt = b['createdAt'] as number | null
		const av = at != null ? at : 0
		const bv = bt != null ? bt : 0
		if (av == bv) { return 0 }
		return av > bv ? -1 : 1
	})
	return records
}

export function getGroupAgentContextRecord(agentId: string, recordId: string): UTSJSONObject | null {
	const records = listGroupAgentContextRecords(agentId)
	for (let i = 0; i < records.length; i++) {
		const id = records[i]['id'] as string | null
		if (id == recordId) { return records[i] }
	}
	return null
}

export function deleteGroupAgentContextRecord(agentId: string, recordId: string): void {
	const records = listGroupAgentContextRecords(agentId)
	const next: UTSJSONObject[] = []
	for (let i = 0; i < records.length; i++) {
		const id = records[i]['id'] as string | null
		if (id != recordId) { next.push(records[i]) }
	}
	uni.setStorageSync(storageAgentContextKey(agentId), JSON.stringify(next))
}

export function saveGroupAgentContextRecord(record: UTSJSONObject): void {
	const agentId = record['agentId'] as string | null
	if (agentId == null || agentId == '') { return }
	const records = listGroupAgentContextRecords(agentId)
	const id = record['id'] as string | null
	let replaced = false
	for (let i = 0; i < records.length; i++) {
		const oldId = records[i]['id'] as string | null
		if (id != null && id != '' && oldId == id) {
			records.splice(i, 1, record)
			replaced = true
			break
		}
	}
	if (replaced == false) { records.push(record) }
	records.sort((a: UTSJSONObject, b: UTSJSONObject): number => {
		const at = a['createdAt'] as number | null
		const bt = b['createdAt'] as number | null
		const av = at != null ? at : 0
		const bv = bt != null ? bt : 0
		if (av == bv) { return 0 }
		return av > bv ? -1 : 1
	})
	uni.setStorageSync(storageAgentContextKey(agentId), JSON.stringify(records))
}

function readActionText(action: UTSJSONObject, key: string): string {
	const raw = action[key] as string | null
	return raw != null ? raw : ''
}

export function createGroupAgentContextRecord(group: GroupChat, session: GroupChatSession, agentId: string, agentName: string, action: UTSJSONObject, runtimeMessages: UTSJSONObject[], systemPrompt: string): UTSJSONObject {
	const privateInstruction = readActionText(action, 'privateInstruction')
	const publicIntent = readActionText(action, 'publicIntent')
	const targetType = readActionText(action, 'targetType')
	const targetAgentId = readActionText(action, 'targetAgentId')
	const replyLength = readActionText(action, 'replyLength')
	const replyGuidance = readActionText(action, 'replyGuidance')
	const searchAdvice = readActionText(action, 'searchAdvice')
	const searchInstruction = readActionText(action, 'searchInstruction')
	const now = Date.now()
	return {
		id: createId('gctx'),
		agentId: agentId,
		agentName: agentName,
		groupId: group.id,
		groupName: group.name,
		sessionId: session.id,
		sessionTitle: displaySessionTitle(session),
		privateInstruction: privateInstruction,
		publicIntent: publicIntent,
		targetType: targetType,
		targetAgentId: targetAgentId,
		replyLength: replyLength,
		replyGuidance: replyGuidance,
		searchAdvice: searchAdvice,
		searchInstruction: searchInstruction,
		systemPrompt: systemPrompt,
		runtimeMessages: JSON.parse(JSON.stringify(runtimeMessages)) as UTSJSONObject[],
		createdAt: now,
	} as UTSJSONObject
}

export function appendGroupMessage(groupId: string, sessionId: string, message: UTSJSONObject): void {
	const messages = getGroupMessages(groupId, sessionId)
	messages.push(message)
	saveGroupMessages(groupId, sessionId, messages)
}

function decorateGroupMessage(base: UTSJSONObject, groupId: string, sessionId: string, senderType: string, agentId: string, agentName: string, agentAvatar: string, visible: boolean): UTSJSONObject {
	base['id'] = createId('gmsg')
	base['groupId'] = groupId
	base['sessionId'] = sessionId
	base['senderType'] = senderType
	base['senderAgentId'] = agentId
	base['senderName'] = agentName
	base['senderAvatar'] = agentAvatar
	base['visible'] = visible
	base['revoked'] = false
	base['timestamp'] = Date.now()
	return base
}

function normalizeUserDisplayName(userName: string): string {
	const name = userName.trim()
	return name != '' ? name : '用户'
}

export function createGroupUserMessage(groupId: string, sessionId: string, content: string, userName: string = ''): UTSJSONObject {
	const base = createTextMessage(CHAT_ROLE_USER, content)
	return decorateGroupMessage(base, groupId, sessionId, GROUP_MESSAGE_SENDER_USER, '', normalizeUserDisplayName(userName), '', true)
}

export function createGroupHiddenMessage(groupId: string, sessionId: string, senderType: string, content: string): UTSJSONObject {
	const base = createTextMessage('system', content)
	return decorateGroupMessage(base, groupId, sessionId, senderType, '', senderType, '', false)
}


export function readAgentName(agent: UTSJSONObject | null): string {
	if (agent == null) { return 'Agent' }
	const raw = agent['name'] as string | null
	return raw != null && raw != '' ? raw : 'Agent'
}

export function readAgentAvatar(agent: UTSJSONObject | null): string {
	if (agent == null) { return '' }
	const raw = agent['avatar'] as string | null
	return raw != null ? raw : ''
}

export function readAgentModel(agent: UTSJSONObject | null): string {
	if (agent == null) { return '' }
	const raw = agent['model'] as string | null
	return raw != null ? raw : ''
}

export function readAgentSystemPrompt(agent: UTSJSONObject | null): string {
	if (agent == null) { return '' }
	const raw = agent['systemPrompt'] as string | null
	return raw != null ? raw : ''
}

export function readAgentHideThinking(agent: UTSJSONObject | null): boolean {
	if (agent == null) { return false }
	const raw = agent['hideThinking'] as boolean | null
	return raw == true
}

export function readAgentInjectDatetime(agent: UTSJSONObject | null): boolean {
	if (agent == null) { return true }
	const raw = agent['injectDatetime'] as boolean | null
	return raw != null ? raw : true
}

export function readAgentMsgSegmentation(agent: UTSJSONObject | null): boolean {
	if (agent == null) { return true }
	const raw = agent['msgSegmentation'] as boolean | null
	return raw != null ? raw : true
}

function stripLeadingSpaces(text: string): string {
	let index = 0
	while (index < text.length) {
		const ch = text.charAt(index)
		if (ch == ' ' || ch == '\n' || ch == '\r' || ch == '\t') {
			index++
		} else {
			break
		}
	}
	return index > 0 ? text.substring(index) : text
}

function stripGroupAgentSpeakerPrefix(text: string, agentName: string): string {
	const name = agentName.trim()
	if (name == '' || text == '') { return text }
	const body = stripLeadingSpaces(text)
	const cnPrefix = name + '：'
	const enPrefix = name + ':'
	let stripped = body
	if (body.startsWith(cnPrefix)) {
		stripped = body.substring(cnPrefix.length)
	} else if (body.startsWith(enPrefix)) {
		stripped = body.substring(enPrefix.length)
	} else {
		return text
	}
	return stripLeadingSpaces(stripped)
}

function stripGroupAgentSpeakerPrefixFromParts(parts: UTSJSONObject[], agentName: string): void {
	for (let i = 0; i < parts.length; i++) {
		const part = parts[i]
		const type = part['type'] as string | null
		if (type == CHAT_PART_PLAIN) {
			const raw = part['text'] as string | null
			if (raw != null && raw != '') {
				part['text'] = stripGroupAgentSpeakerPrefix(raw, agentName)
			}
			return
		}
	}
}

export function createGroupAgentStreamingMessage(groupId: string, sessionId: string, agentId: string): UTSJSONObject {
	const agent = getAgentById(agentId)
	const name = readAgentName(agent)
	const avatar = readAgentAvatar(agent)
	const base = createAssistantStreamingMessage([] as UTSJSONObject[], Date.now())
	base['hideThinking'] = readAgentHideThinking(agent)
	base['msgSegmentation'] = readAgentMsgSegmentation(agent)
	return decorateGroupMessage(base, groupId, sessionId, GROUP_MESSAGE_SENDER_AGENT, agentId, name, avatar, true)
}

export function createGroupAgentFinalMessage(groupId: string, sessionId: string, agentId: string, parts: UTSJSONObject[], content: string): UTSJSONObject {
	const agent = getAgentById(agentId)
	const name = readAgentName(agent)
	const avatar = readAgentAvatar(agent)
	const cleanParts = cloneParts(parts)
	stripGroupAgentSpeakerPrefixFromParts(cleanParts, name)
	const base = createAssistantFinalMessage(cleanParts, Date.now())
	const cleanContent = extractPlainText(cleanParts)
	base['content'] = cleanContent != '' ? cleanContent : stripGroupAgentSpeakerPrefix(content, name)
	base['hideThinking'] = readAgentHideThinking(agent)
	base['msgSegmentation'] = readAgentMsgSegmentation(agent)
	return decorateGroupMessage(base, groupId, sessionId, GROUP_MESSAGE_SENDER_AGENT, agentId, name, avatar, true)
}

export function createGroupUserImageMessage(groupId: string, sessionId: string, imagePath: string, userName: string = ''): UTSJSONObject {
	const base = createImageMessage(imagePath)
	return decorateGroupMessage(base, groupId, sessionId, GROUP_MESSAGE_SENDER_USER, '', normalizeUserDisplayName(userName), '', true)
}

export function createGroupUserFileMessage(groupId: string, sessionId: string, fileName: string, filePath: string, userName: string = ''): UTSJSONObject {
	const base = createFileMessage(fileName, filePath)
	return decorateGroupMessage(base, groupId, sessionId, GROUP_MESSAGE_SENDER_USER, '', normalizeUserDisplayName(userName), '', true)
}

export function revokeGroupAgentMessage(groupId: string, sessionId: string, messageId: string): void {
	const messages = getGroupMessages(groupId, sessionId)
	for (let i = 0; i < messages.length; i++) {
		const id = messages[i]['id'] as string | null
		const senderType = messages[i]['senderType'] as string | null
		if (id == messageId && senderType == GROUP_MESSAGE_SENDER_AGENT) {
			const senderName = messages[i]['senderName'] as string | null
			const name = senderName != null && senderName.trim() != '' ? senderName.trim() : '成员'
			const text = name + '撤回了一条消息'
			messages[i]['revoked'] = true
			messages[i]['content'] = text
			messages[i]['message'] = [createPlainPart(text)]
			messages[i]['isStreaming'] = false
			break
		}
	}
	saveGroupMessages(groupId, sessionId, messages)
}

export function markGroupAgentMessageRevoked(message: UTSJSONObject): void {
	const senderName = message['senderName'] as string | null
	const name = senderName != null && senderName.trim() != '' ? senderName.trim() : '成员'
	const text = name + '撤回了一条消息'
	message['revoked'] = true
	message['content'] = text
	message['message'] = [createPlainPart(text)]
	message['isStreaming'] = false
}

export function getVisibleGroupMessages(messages: UTSJSONObject[]): UTSJSONObject[] {
	const result: UTSJSONObject[] = []
	for (let i = 0; i < messages.length; i++) {
		const visible = messages[i]['visible'] as boolean | null
		if (visible != false) {
			result.push(messages[i])
		}
	}
	return result
}

export function deleteGroupSession(groupId: string, sessionId: string, clearFiles: boolean): void {
	const sessions = getGroupSessions(groupId)
	const next: GroupChatSession[] = []
	let targetWorkspace = ''
	for (let i = 0; i < sessions.length; i++) {
		if (sessions[i].id == sessionId) {
			targetWorkspace = sessions[i].workspacePath
		} else {
			next.push(sessions[i])
		}
	}
	uni.removeStorageSync(storageMessagesKey(groupId, sessionId))
	if (clearFiles == true && targetWorkspace != '' && isInsideGroupWorkspace(targetWorkspace) == true && exists(targetWorkspace) == true) {
		deleteItem(targetWorkspace, true)
	}
	saveGroupSessions(groupId, next)
	const group = getGroupChatById(groupId)
	if (group != null && group.activeSessionId == sessionId) {
		if (next.length > 0) {
			group.activeSessionId = next[0].id
		} else {
			const fresh = createGroupSession(groupId, '故事会话')
			group.activeSessionId = fresh.id
		}
		group.updatedAt = Date.now()
		saveGroupChat(group)
		uni.setStorageSync(ACTIVE_GROUP_SESSION_ID_KEY, group.activeSessionId)
	}
}

export function forkGroupSession(groupId: string, sessionId: string): GroupChatSession | null {
	const source = getGroupSessionById(groupId, sessionId)
	if (source == null) { return null }
	const forkId = createId('gsession')
	const sourceTitle = displaySessionTitle(source)
	const destWorkspace = buildGroupWorkspacePath(groupId, forkId)
	if (source.workspacePath != '' && destWorkspace != '' && exists(source.workspacePath) == true && isInsideGroupWorkspace(source.workspacePath) == true && isInsideGroupWorkspace(destWorkspace) == true) {
		copyItem(source.workspacePath, destWorkspace)
	} else {
		ensureDirectory(destWorkspace)
	}
	const forked: GroupChatSession = {
		id: forkId,
		groupId: groupId,
		title: sourceTitle + ' · 分支',
		workspacePath: destWorkspace,
		forkedFromSessionId: sessionId,
		titleLocked: false,
		createdAt: Date.now(),
		updatedAt: Date.now(),
	}
	const sessions = getGroupSessions(groupId)
	sessions.push(forked)
	saveGroupSessions(groupId, sessions)
	const oldMessages = getGroupMessages(groupId, sessionId)
	const copiedMessages: UTSJSONObject[] = []
	for (let i = 0; i < oldMessages.length; i++) {
		const copied = JSON.parse(JSON.stringify(oldMessages[i])) as UTSJSONObject
		copied['id'] = createId('gmsg')
		copied['sessionId'] = forkId
		copied['isStreaming'] = false
		copiedMessages.push(copied)
	}
	saveGroupMessages(groupId, forkId, copiedMessages)
	return forked
}

export function createDefaultWritingGroupChat(): GroupChat {
	const agents = getAgents()
	let firstMember = ''
	let secondMember = ''
	if (agents.length > 0) {
		const firstId = agents[0]['id'] as string | null
		firstMember = firstId != null ? firstId : ''
	}
	for (let i = 0; i < agents.length; i++) {
		const aid = agents[i]['id'] as string | null
		if (aid == 'writing-helper') { firstMember = aid }
		if (aid == 'idea-lab') { secondMember = aid }
	}
	if (secondMember == '' && agents.length > 1) {
		const fallbackId = agents[1]['id'] as string | null
		secondMember = fallbackId != null ? fallbackId : ''
	}
	const groupId = createId('gchat')
	const group: GroupChat = {
		id: groupId,
		name: '故事工坊',
		avatar: '',
		schedulerAgentId: '',
		schedulerPrompt: buildDefaultSchedulerPrompt(),
		sharedPrompt: buildDefaultSharedPrompt(),
		activeSessionId: '',
		createdAt: Date.now(),
		updatedAt: Date.now(),
	}
	saveGroupChat(group)
	if (firstMember != '') { addGroupMember(groupId, firstMember) }
	if (secondMember != '' && secondMember != firstMember) { addGroupMember(groupId, secondMember) }
	const session = createGroupSession(groupId, '故事会话')
	group.activeSessionId = session.id
	saveGroupChat(group)
	return group
}


export function buildSchedulerSystemPrompt(): string {
	return '你是群聊的隐藏调度 Agent，职责是决定下一步由哪些成员发言、给出具体指令。\n\n' +
		'规则：\n' +
		'· 你的存在和调度过程绝不能被成员在公开发言中提及。\n' +
		'· 闲聊/简单回应：只安排 1 个最合适的成员；协作任务：可安排多个按顺序发言，order 从 0 递增。\n' +
		'· 默认控场目标是简短、清晰、少废话。replyLength 默认 short；只有用户明确要求长文、方案、创作片段或复杂推理时才用 normal/detailed。\n' +
		'· privateInstruction 必须具体可执行：告诉成员要表达什么观点、采用什么角度、回应哪个细节、是否需要纠偏/收束，不要写"正常回复"这种废话。\n' +
		'· 如果最近发言出现事实冲突、虚构 App 功能、误解用户意图或跑题，优先安排最合适成员自然修正；不要让成员提及你、调度、私密指令或系统流程。\n' +
		'· 涉及时效、外部事实、版本、价格、法律、医学、金融、新闻等不稳信息时，将 searchAdvice 设为 recommend，并在 searchInstruction 写明要查证什么；不能让成员伪造搜索结果。\n' +
		'· shouldContinue：仅当讨论有明确的下一步价值（如任务未完成、需要多轮协作）时设为 true；闲聊收尾设 false。\n' +
		'· agentId 必须与成员列表 id= 后的值完全一致，不能自造。\n\n' +
		'输出纯 JSON，禁止任何 Markdown 标记，格式：\n' +
		'{"actions":[{"type":"speak","agentId":"<id>","targetType":"user","targetAgentId":"","privateInstruction":"<具体指令>","publicIntent":"<公开目标>","replyLength":"short|normal|detailed","replyGuidance":"<语气/结构建议，默认简短>","searchAdvice":"none|recommend","searchInstruction":"<需要查证时写查什么，否则空>","order":0}],"shouldContinue":false,"titleSuggestion":"<6字内短标题>","privateNotes":"<内部备注>"}\n\n' +
		'触发上下文、成员列表（含角色简介）、最近聊天记录在用户消息中提供。'
}

export function buildSchedulerReviewSystemPrompt(): string {
	return '你是群聊的隐藏审核调度 Agent，职责是判断一条候选群聊发言是否可以公开显示。\n\n' +
		'审核范围只限：是否暴露隐藏调度、内部指令、私密指令、幕后安排或 scheduler 机制。\n' +
		'不要审查事实对错、语气好坏、创作质量，也不要扩大判断范围。\n\n' +
		'输出纯 JSON，禁止 Markdown，格式：\n' +
		'{"decision":"allow|revise|revoke","reason":"<简短原因>","revisionInstruction":"<需要重写时给成员的要求，否则为空>"}\n\n' +
		'allow：误触发或没有真正暴露调度；revise：保留原意但必须移除调度/内部指令表述；revoke：严重暴露且不适合公开。'
}

function formatMemberList(groupId: string): string {
	const members = getActiveGroupMembers(groupId)
	const lines: string[] = []
	for (let i = 0; i < members.length; i++) {
		const agent = getAgentById(members[i].agentId)
		const agentDesc = agent != null ? (agent['desc'] as string | null) : null
		const desc = agentDesc != null && agentDesc != '' ? agentDesc : ''
		let line = '- id=' + members[i].agentId + '  name=' + readAgentName(agent)
		if (desc != '') { line += '\n  介绍：' + desc }
		lines.push(line)
	}
	return lines.join('\n')
}

function readCurrentUserDisplayName(): string {
	const raw = uni.getStorageSync('profile_nickname') as string | null
	const name = raw != null ? raw.trim() : ''
	return name != '' ? name : '用户'
}

function resolveGroupSenderDisplayName(senderName: string | null, senderType: string | null, role: string | null): string {
	const name = senderName != null ? senderName.trim() : ''
	if (senderType == GROUP_MESSAGE_SENDER_USER || role == CHAT_ROLE_USER) {
		if (name != '' && name != '用户') { return name }
		return readCurrentUserDisplayName()
	}
	return name != '' ? name : '成员'
}

function truncateTranscriptContent(content: string, maxLength: number): string {
	if (content.length <= maxLength) {
		return content
	}
	return content.substring(0, maxLength) + '...[已截断]'
}

export function buildGroupTranscript(messages: UTSJSONObject[], limit: number = 30): string {
	const visible = getVisibleGroupMessages(messages)
	const start = visible.length > limit ? visible.length - limit : 0
	const lines: string[] = []
	const keepFullCount = 5
	const truncateLength = 30
	for (let i = start; i < visible.length; i++) {
		const msg = visible[i]
		const role = msg['role'] as string | null
		const senderType = msg['senderType'] as string | null
		const senderName = msg['senderName'] as string | null
		const messageId = msg['id'] as string | null
		const name = resolveGroupSenderDisplayName(senderName, senderType, role)
		const content = getMessageContent(msg)
		if (content.trim() != '') {
			const fromLatest = visible.length - i
			let displayContent = content
			if (fromLatest > keepFullCount) {
				displayContent = truncateTranscriptContent(content, truncateLength)
			}
			lines.push('--- message #' + (i - start + 1).toString() + ' ---')
			lines.push('messageId: ' + (messageId != null ? messageId : ''))
			lines.push('sender: ' + name)
			lines.push('senderType: ' + (senderType != null ? senderType : '未标记'))
			lines.push('role: ' + (role != null ? role : '未标记'))
			lines.push('content:')
			lines.push(displayContent)
			lines.push('')
		}
	}
	if (lines.length == 0) { return '(暂无公开发言)' }
	return lines.join('\n')
}

export function buildSchedulerRuntimeMessages(group: GroupChat, session: GroupChatSession, messages: UTSJSONObject[], reason: string, loopTurns: number): UTSJSONObject[] {
	let schedulerPrompt = group.schedulerPrompt.trim()
	if (schedulerPrompt == '') {
		schedulerPrompt = buildDefaultSchedulerPrompt()
	}
	const content = '【动态调度上下文】\n' +
		'群聊调度提示词：\n' + schedulerPrompt + '\n\n' +
		'调度字段补充：即使上方提示词没有列出，也必须在每个 speak action 中返回 replyLength、replyGuidance、searchAdvice、searchInstruction。默认 replyLength=short、searchAdvice=none；需要查证外部/时效事实时才用 searchAdvice=recommend。\n\n' +
		'群聊共享规则：\n' + group.sharedPrompt + '\n\n' +
		'触发原因：' + reason + '\n' +
		'当前会话名：' + displaySessionTitle(session) + '\n' +
		'连续讨论轮数：' + loopTurns + '\n\n' +
		'可调度成员：\n' + formatMemberList(group.id) + '\n\n' +
		'最近公开群聊记录：\n' + buildGroupTranscript(messages, 20) + '\n\n' +
		'请根据以上上下文决定下一步由谁发言。严格输出 JSON，不加任何解释。'
	return [createTextMessage(CHAT_ROLE_USER, content)]
}

export function parseSchedulerDecision(raw: string, groupId: string): UTSJSONObject {
	let jsonText = raw.trim()
	const first = jsonText.indexOf('{')
	const last = jsonText.lastIndexOf('}')
	if (first >= 0 && last > first) {
		jsonText = jsonText.substring(first, last + 1)
	}
	try {
		const parsed = JSON.parse(jsonText) as UTSJSONObject
		const actions = parsed['actions'] as UTSJSONObject[] | null
		if (actions != null) {
			actions.sort((a: UTSJSONObject, b: UTSJSONObject): number => {
				const ao = a['order'] as number | null
				const bo = b['order'] as number | null
				const av = ao != null ? ao : 0
				const bv = bo != null ? bo : 0
				if (av < bv) { return -1 }
				if (av > bv) { return 1 }
				return 0
			})
			parsed['actions'] = actions
			return parsed
		}
	} catch (_e: any) {
	}
	return buildFallbackSchedulerDecision(groupId)
}

export function buildFallbackSchedulerDecision(groupId: string): UTSJSONObject {
	const members = getActiveGroupMembers(groupId)
	let agentId = ''
	if (members.length > 0) {
		agentId = members[0].agentId
	}
	const actions: UTSJSONObject[] = []
	if (agentId != '') {
		actions.push({
			type: 'speak',
			agentId: agentId,
			targetType: 'user',
			targetAgentId: '',
			privateInstruction: '调度结果解析失败，请根据最近公开群聊记录自然回应用户。',
			publicIntent: '自然回应用户',
			replyLength: 'short',
			replyGuidance: '简短自然，优先 1-3 句。',
			searchAdvice: 'none',
			searchInstruction: '',
			order: 0,
		} as UTSJSONObject)
	}
	return {
		actions: actions,
		shouldContinue: false,
		titleSuggestion: '',
		privateNotes: 'fallback',
	} as UTSJSONObject
}

export function buildSchedulerReviewMessages(group: GroupChat, session: GroupChatSession, messages: UTSJSONObject[], agentId: string, agentName: string, keyword: string, candidateText: string): UTSJSONObject[] {
	const content = '【调度审核任务】\n' +
		'你是隐藏的群聊调度 Agent。现在需要审核一条尚未完整公开的成员发言是否暴露了调度机制。\n\n' +
		'审核目标：只判断是否暴露隐藏调度、内部指令或私密调度过程；不要评价事实对错、文风、内容质量。\n' +
		'触发关键词：' + keyword + '\n' +
		'发言成员 ID：' + agentId + '\n' +
		'发言成员名：' + agentName + '\n' +
		'当前会话名：' + displaySessionTitle(session) + '\n\n' +
		'最近公开群聊记录：\n' + buildGroupTranscript(messages, 12) + '\n\n' +
		'候选完整发言：\n' + candidateText + '\n\n' +
		'请严格输出 JSON，不加 Markdown，不加解释。\n' +
		'格式：{"decision":"allow|revise|revoke","reason":"简短原因","revisionInstruction":"如果 decision=revise，给原成员的重写要求；否则为空"}\n' +
		'allow：误触发或没有真正暴露调度；revise：能保留原意但必须删掉调度/内部指令表述；revoke：严重暴露且不适合公开。'
	return [createTextMessage(CHAT_ROLE_USER, content)]
}

export function parseSchedulerReviewDecision(raw: string): UTSJSONObject {
	let jsonText = raw.trim()
	const first = jsonText.indexOf('{')
	const last = jsonText.lastIndexOf('}')
	if (first >= 0 && last > first) {
		jsonText = jsonText.substring(first, last + 1)
	}
	try {
		const parsed = JSON.parse(jsonText) as UTSJSONObject
		const decisionRaw = parsed['decision'] as string | null
		let decision = decisionRaw != null ? decisionRaw.trim() : ''
		if (decision != 'allow' && decision != 'revise' && decision != 'revoke') {
			decision = 'revise'
		}
		const reasonRaw = parsed['reason'] as string | null
		const instructionRaw = parsed['revisionInstruction'] as string | null
		return {
			decision: decision,
			reason: reasonRaw != null ? reasonRaw : '',
			revisionInstruction: instructionRaw != null ? instructionRaw : '',
		} as UTSJSONObject
	} catch (_e: any) {
	}
	return {
		decision: 'revise',
		reason: '审核结果解析失败',
		revisionInstruction: '保留原意，删除任何关于调度、内部指令、私密指令或幕后安排的表述。',
	} as UTSJSONObject
}

export function buildMemberSystemPrompt(agent: UTSJSONObject, sharedPrompt: string = ''): string {
	const basePrompt = readAgentSystemPrompt(agent)
	const sharedText = sharedPrompt.trim()
	const sharedBlock = sharedText != '' ? '\n\n群聊共享提示词：\n' + sharedText : ''
	return basePrompt + '\n\n' +
		'你正在一个群聊中发言。\n' +
		'群聊规则：你可以使用工具处理当前群会话共享工作区；公开回复只输出你要发到群里的正文，不要在开头附加自己的名字或“成员名：”。不要提及幕后安排、内部任务描述或系统流程。\n' +
		'成员名、动态会话名、公开发言目标、目标对象、本轮发言要点、推荐回复长度和查证建议会在最后一条用户消息中提供。' +
		sharedBlock
}

export function buildMemberRuntimeMessages(group: GroupChat, session: GroupChatSession, messages: UTSJSONObject[], action: UTSJSONObject, agentName: string, injectDatetime: boolean, datetimePrefix: string): UTSJSONObject[] {
	const runtime: UTSJSONObject[] = []
	const visible = getVisibleGroupMessages(messages)
	const start = visible.length > 40 ? visible.length - 40 : 0
	for (let i = start; i < visible.length; i++) {
		const msg = visible[i]
		const senderType = msg['senderType'] as string | null
		const senderName = msg['senderName'] as string | null
		const role = msg['role'] as string | null
		const label = resolveGroupSenderDisplayName(senderName, senderType, role)
		const content = getMessageContent(msg)
		if (content.trim() == '') { continue }
		if (role == CHAT_ROLE_ASSISTANT) {
			runtime.push(createTextMessage(CHAT_ROLE_ASSISTANT, label + '：' + content))
		} else {
			runtime.push(createTextMessage(CHAT_ROLE_USER, label + '：' + content))
		}
	}
	const privateInstruction = readActionText(action, 'privateInstruction')
	const publicIntent = readActionText(action, 'publicIntent')
	const targetType = readActionText(action, 'targetType')
	const targetAgentId = readActionText(action, 'targetAgentId')
	const replyLengthRaw = readActionText(action, 'replyLength')
	const replyLength = replyLengthRaw != '' ? replyLengthRaw : 'short'
	const replyGuidanceRaw = readActionText(action, 'replyGuidance')
	const replyGuidance = replyGuidanceRaw != '' ? replyGuidanceRaw : '简短自然，优先 1-3 句。'
	const searchAdviceRaw = readActionText(action, 'searchAdvice')
	const searchAdvice = searchAdviceRaw != '' ? searchAdviceRaw : 'none'
	const searchInstruction = readActionText(action, 'searchInstruction')
	const taskText = '【当前发言任务】\n' +
		'现在轮到你发言。\n' +
		'成员名：' + agentName + '\n' +
		'群聊名：' + group.name + '\n' +
		'会话名：' + displaySessionTitle(session) + '\n' +
		'公开发言目标：' + publicIntent + '\n' +
		'目标类型：' + targetType + '\n' +
		'目标 Agent ID：' + targetAgentId + '\n' +
		'推荐回复长度：' + replyLength + '\n' +
		'回复组织建议：' + replyGuidance + '\n' +
		'查证/搜索建议：' + searchAdvice + '\n' +
		'查证/搜索任务：' + searchInstruction + '\n' +
		'本轮发言要点：' + privateInstruction + '\n' +
		'如果建议查证但你没有可用工具，不要伪造搜索结果；可以基于已知信息简短回应并说明未查证。只输出要发到群聊里的正文，不要加自己的名字前缀，不要描述幕后流程。'
	runtime.push(createTextMessage(CHAT_ROLE_USER, taskText))
	return buildRuntimeChatMessages(runtime, {
		injectDatetime: injectDatetime,
		datetimePrefix: datetimePrefix,
	})
}

export function syncGroupStreamingMessage(target: UTSJSONObject, source: UTSJSONObject): void {
	const senderName = target['senderName'] as string | null
	const name = senderName != null ? senderName : ''
	const cleanParts = cloneParts(getMessageParts(source))
	stripGroupAgentSpeakerPrefixFromParts(cleanParts, name)
	const cleanContent = extractPlainText(cleanParts)
	target['content'] = cleanContent != '' ? cleanContent : stripGroupAgentSpeakerPrefix(getMessageContent(source), name)
	target['message'] = cleanParts
	target['isStreaming'] = source['isStreaming'] as boolean | null
	const toolCalls = source['tool_calls'] as UTSJSONObject[] | null
	if (toolCalls != null) {
		target['tool_calls'] = toolCalls
	}
}
