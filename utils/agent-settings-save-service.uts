/**
 * 联系人设置保存事务。
 *
 * 页面只负责表单交互；这里集中处理 Agent 基础资料、模型、TTS、生成参数和工具开关的持久化。
 */

import {
	filterAllowedAgentToolIdsForAgent,
	getAgents,
	saveAgents,
} from '@/utils/agent.uts'
import { updateSystemPromptForAgent } from '@/utils/database.uts'
import { type GenerationSettings } from '@/utils/generation-settings.uts'
import { filterExistingSkillIds } from '@/utils/skills.uts'
import { buildAgentGenerationSaveState, type AgentSettingsGenerationSaveState } from '@/utils/agent-settings-models.uts'

export type AgentSettingsSaveInput = {
	agentId: string
	name: string
	desc: string
	avatar: string
	systemPrompt: string
	interactionRules: string
	model: string
	ttsVoice: string
	ttsVolume: string
	ttsPitch: string
	useGlobalGeneration: boolean
	temperatureStr: string
	maxTokensStr: string
	maxIterationsStr: string
	streamEnabled: boolean
	truncateThresholdStr: string
	truncateDropCountStr: string
	cacheEnabled: boolean
	hideThinking: boolean
	injectDatetime: boolean
	msgSegmentation: boolean
	selectedSkillIds: string[]
	selectedToolIds: string[]
}

export type AgentSettingsSaveResult = {
	ok: boolean
	error: string
	generation: AgentSettingsGenerationSaveState | null
}

function failSave(error: string): AgentSettingsSaveResult {
	return {
		ok: false,
		error: error,
		generation: null,
	} as AgentSettingsSaveResult
}

function okSave(generation: AgentSettingsGenerationSaveState): AgentSettingsSaveResult {
	return {
		ok: true,
		error: '',
		generation: generation,
	} as AgentSettingsSaveResult
}

function restoreAgentSettingsSnapshot(snapshot: string): boolean {
	try {
		const agents = JSON.parse(snapshot) as UTSJSONObject[]
		return saveAgents(agents)
	} catch (_e: any) {
		return false
	}
}

export function saveAgentSettings(input: AgentSettingsSaveInput, global: GenerationSettings): AgentSettingsSaveResult {
	const agentId = input.agentId.trim()
	if (agentId == '') { return failSave('未选择联系人') }
	const name = input.name.trim()
	if (name == '') { return failSave('昵称不能为空') }
	const desc = input.desc.trim()
	const generation = buildAgentGenerationSaveState(
		input.useGlobalGeneration,
		input.temperatureStr,
		input.maxTokensStr,
		input.maxIterationsStr,
		input.streamEnabled,
		input.truncateThresholdStr,
		input.truncateDropCountStr,
		global
	)
	const agents = getAgents()
	const previousAgentsSnapshot = JSON.stringify(agents)
	let target: UTSJSONObject | null = null
	for (let i = 0; i < agents.length; i++) {
		const id = agents[i]['id'] as string | null
		if (id != null && id == agentId) {
			target = agents[i]
			break
		}
	}
	if (target == null) { return failSave('联系人不存在，无法保存') }
	target['name'] = name
	target['desc'] = desc
	target['systemPrompt'] = input.systemPrompt
	target['interactionRules'] = input.interactionRules.trim()
	target['model'] = input.model
	target['time'] = '刚刚'
	if (input.avatar != '') {
		target['avatar'] = input.avatar
	}
	target['ttsVoice'] = input.ttsVoice.trim()
	target['ttsVolume'] = input.ttsVolume.trim()
	target['ttsPitch'] = input.ttsPitch.trim()
	target['temperature'] = generation.temperature
	target['maxTokens'] = generation.maxTokens
	target['maxIterations'] = generation.maxIterations
	target['streamEnabled'] = generation.streamEnabled
	target['truncateThreshold'] = generation.truncateThreshold
	target['truncateDropCount'] = generation.truncateDropCount
	target['cacheEnabled'] = input.cacheEnabled
	target['hideThinking'] = input.hideThinking
	target['injectDatetime'] = input.injectDatetime
	target['msgSegmentation'] = input.msgSegmentation
	target['skillIds'] = filterExistingSkillIds(input.selectedSkillIds)
	target['enabledToolIds'] = filterAllowedAgentToolIdsForAgent(input.selectedToolIds, target, false)
	if (saveAgents(agents) == false) {
		return failSave('保存联系人设置失败，请重试')
	}
	if (updateSystemPromptForAgent(agentId, input.systemPrompt) == false) {
		if (restoreAgentSettingsSnapshot(previousAgentsSnapshot) == false) {
			return failSave('历史对话提示词同步失败，且联系人设置回滚失败，请立即重试')
		}
		return failSave('历史对话提示词同步失败，本次修改已回滚，请重试')
	}
	return okSave(generation)
}
