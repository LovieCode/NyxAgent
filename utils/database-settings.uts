/**
 * Provider / AppSettings 配置 DAO。
 *
 * database.uts 只保留数据库初始化、全量导入导出和总出口；配置类表的读写在这里。
 */

import {
	assertSqlSuccess,
	ensureAppSettingsTable,
	ensureProvidersTable,
	getDb,
	readNumberField,
	readStringField,
	runSqlOrThrow,
	rowsToObjects,
} from '@/utils/database-core.uts'
import { xSqlite } from '@/uni_modules/laoqianjunzi-sqlite'

function findProviderApiKeyInRows(rows: UTSJSONObject[], id: string): string {
	if (id == '') {
		return ''
	}
	for (let i = 0; i < rows.length; i++) {
		const rowId = rows[i]['id'] as string | null
		if (rowId == id) {
			const apiKey = rows[i]['api_key'] as string | null
			if (apiKey != null) {
				return apiKey
			}
		}
	}
	return ''
}

function findSettingValueInRows(rows: UTSJSONObject[], key: string): string {
	if (key == '') {
		return ''
	}
	for (let i = 0; i < rows.length; i++) {
		const rowKey = rows[i]['key'] as string | null
		if (rowKey == key) {
			const value = rows[i]['value'] as string | null
			if (value != null) {
				return value
			}
		}
	}
	return ''
}

function parseSettingObject(value: string): UTSJSONObject | null {
	try {
		return JSON.parse(value) as UTSJSONObject
	} catch (_e: any) {
		return null
	}
}

function parseSettingObjectArray(value: string): UTSJSONObject[] | null {
	try {
		return JSON.parse(value) as UTSJSONObject[]
	} catch (_e: any) {
		return null
	}
}

function parseProviderModelIds(value: string): string[] {
	const result: string[] = []
	if (value == '') { return result }
	try {
		const raw = JSON.parse(value) as any[]
		for (let i = 0; i < raw.length; i++) {
			const item = raw[i]
			if (typeof item == 'string') {
				result.push(item as string)
				continue
			}
			if (typeof item == 'object' && item != null) {
				const obj = item as UTSJSONObject
				const id = obj['id'] as string | null
				if (id != null && id != '') { result.push(id) }
			}
		}
	} catch (_e: any) {
	}
	return result
}

function stringListContains(list: string[], value: string): boolean {
	for (let i = 0; i < list.length; i++) {
		if (list[i] == value) { return true }
	}
	return false
}

function providerModelReferenceMatches(rawModel: string, providerId: string, modelIds: string[] | null, clearAll: boolean, defaultProviderId: string): boolean {
	if (rawModel == '') { return false }
	let referencedProvider = ''
	let referencedModel = rawModel
	const separator = '||'
	const separatorIndex = rawModel.indexOf(separator)
	if (separatorIndex >= 0) {
		referencedProvider = rawModel.substring(0, separatorIndex)
		referencedModel = rawModel.substring(separatorIndex + separator.length)
	} else {
		// 旧裸模型只在它仍由该 Provider 作为默认聊天 Provider 解释时清理。
		referencedProvider = defaultProviderId
	}
	if (referencedProvider != providerId) { return false }
	if (clearAll == true || modelIds == null) { return true }
	return stringListContains(modelIds, referencedModel)
}

function readDefaultProviderIdFromDb(db: xSqlite): string {
	const result = db.query('SELECT value FROM app_settings WHERE key = ? LIMIT 1', ['default_task_chat'])
	assertSqlSuccess(result, '读取默认聊天提供商')
	const rows = rowsToObjects(result)
	if (rows.length == 0) { return '' }
	const value = rows[0]['value'] as string | null
	if (value == null || value == '') { return '' }
	const config = parseSettingObject(value)
	if (config == null) { return '' }
	const providerId = config['providerId'] as string | null
	return providerId != null ? providerId : ''
}

/** 在当前事务内清除 Provider/模型被删除后的默认任务和 Agent 引用。 */
function clearProviderReferencesInTransaction(db: xSqlite, providerId: string, modelIds: string[] | null, clearAll: boolean): void {
	const defaultProviderId = readDefaultProviderIdFromDb(db)
	const taskKeys = [
		'default_task_chat',
		'default_task_memory_organize',
		'default_task_vision',
		'default_task_stt',
		'default_task_tts',
	]
	for (let i = 0; i < taskKeys.length; i++) {
		const key = taskKeys[i]
		const result = db.query('SELECT value FROM app_settings WHERE key = ? LIMIT 1', [key])
		assertSqlSuccess(result, '读取默认任务模型引用')
		const rows = rowsToObjects(result)
		if (rows.length == 0) { continue }
		const value = rows[0]['value'] as string | null
		if (value == null || value == '') { continue }
		const config = parseSettingObject(value)
		if (config == null) { continue }
		const refProvider = config['providerId'] as string | null
		const refModel = config['model'] as string | null
		if (refProvider == null || refModel == null || refProvider != providerId) { continue }
		if (clearAll == false && modelIds != null && stringListContains(modelIds, refModel) == false) { continue }
		if (key == 'default_task_tts') {
			config['providerId'] = ''
			config['model'] = ''
			runSqlOrThrow(db, 'UPDATE app_settings SET value = ? WHERE key = ?', [JSON.stringify(config), key])
		} else {
			runSqlOrThrow(db, 'UPDATE app_settings SET value = ? WHERE key = ?', ['', key])
		}
	}

	const searchResult = db.query('SELECT value FROM app_settings WHERE key = ? LIMIT 1', ['settings_web_search_provider_id'])
	assertSqlSuccess(searchResult, '读取联网搜索模型提供商引用')
	const searchRows = rowsToObjects(searchResult)
	if (searchRows.length > 0) {
		const searchProvider = searchRows[0]['value'] as string | null
		if (searchProvider == providerId) {
			const searchModelResult = db.query('SELECT value FROM app_settings WHERE key = ? LIMIT 1', ['settings_web_search_model'])
			assertSqlSuccess(searchModelResult, '读取联网搜索模型引用')
			const searchModelRows = rowsToObjects(searchModelResult)
			const searchModel = searchModelRows.length > 0 ? searchModelRows[0]['value'] as string | null : null
			if (clearAll == true || modelIds == null || (searchModel != null && stringListContains(modelIds, searchModel))) {
				runSqlOrThrow(db, 'UPDATE app_settings SET value = ? WHERE key IN (?, ?)', ['', 'settings_web_search_provider_id', 'settings_web_search_model'])
			}
		}
	}

	const agentResult = db.query('SELECT value FROM app_settings WHERE key = ? LIMIT 1', ['agent_list'])
	assertSqlSuccess(agentResult, '读取智能体模型引用')
	const agentRows = rowsToObjects(agentResult)
	if (agentRows.length > 0) {
		const agentValue = agentRows[0]['value'] as string | null
		if (agentValue != null && agentValue != '') {
			const agents = parseSettingObjectArray(agentValue)
			if (agents != null) {
				let changed = false
				for (let i = 0; i < agents.length; i++) {
					const rawModel = agents[i]['model'] as string | null
					if (rawModel != null && providerModelReferenceMatches(rawModel, providerId, modelIds, clearAll, defaultProviderId) == true) {
						agents[i]['model'] = ''
						changed = true
					}
				}
				if (changed == true) {
					runSqlOrThrow(db, 'UPDATE app_settings SET value = ? WHERE key = ?', [JSON.stringify(agents), 'agent_list'])
				}
			}
		}
	}
}

function clearDeletedProviderTaskSettings(db: xSqlite, providerId: string): void {
	const taskKeys = [
		'default_task_chat',
		'default_task_memory_organize',
		'default_task_vision',
		'default_task_stt',
		'default_task_tts',
	]
	for (let i = 0; i < taskKeys.length; i++) {
		const key = taskKeys[i]
		const queryResult = db.query('SELECT value FROM app_settings WHERE key = ? LIMIT 1', [key])
		assertSqlSuccess(queryResult, '读取默认任务模型')
		const rows = rowsToObjects(queryResult)
		if (rows.length == 0) { continue }
		const value = rows[0]['value'] as string | null
		if (value == null || value == '') { continue }
		const config = parseSettingObject(value)
		if (config == null) {
			// 无法解析的脏设置不应阻止删除；仅在明确引用当前 Provider 时清理。
			continue
		}
		const currentProviderId = config['providerId'] as string | null
		if (currentProviderId != providerId) { continue }
		if (key == 'default_task_tts') {
			// TTS 的音色、格式等参数仍然有效，只清除失效的模型引用。
			config['providerId'] = ''
			config['model'] = ''
			runSqlOrThrow(db, 'UPDATE app_settings SET value = ? WHERE key = ?', [JSON.stringify(config), key])
		} else {
			runSqlOrThrow(db, 'UPDATE app_settings SET value = ? WHERE key = ?', ['', key])
		}
	}
}

/** 仅覆盖导入配置类表，不触碰对话、消息、记忆和群聊数据。 */
export function importSettingsTables(providers: UTSJSONObject[], appSettings: UTSJSONObject[], preserveEmptyApiKeys: boolean): void {
	const db = getDb()
	ensureProvidersTable(db)
	ensureAppSettingsTable(db)
	let oldProviderKeys: UTSJSONObject[] = []
	let oldApiSettings: UTSJSONObject[] = []
	if (preserveEmptyApiKeys == true) {
		const providerKeysResult = db.query('SELECT id, api_key FROM providers')
		const apiSettingsResult = db.query('SELECT key, value FROM app_settings WHERE key = ?', ['settings_astrbot_api_key'])
		try {
			assertSqlSuccess(providerKeysResult, '读取现有提供商密钥')
			assertSqlSuccess(apiSettingsResult, '读取现有兼容密钥')
		} catch (e: any) {
			db.close()
			throw e
		}
		oldProviderKeys = rowsToObjects(providerKeysResult)
		oldApiSettings = rowsToObjects(apiSettingsResult)
	}
	try {
		assertSqlSuccess(db.beginTransaction(), '无法开始设置导入事务')
		runSqlOrThrow(db, 'DELETE FROM providers')
		runSqlOrThrow(db, 'DELETE FROM app_settings')

		for (let i = 0; i < providers.length; i++) {
			const item = providers[i]
			const providerId = readStringField(item, 'id')
			let apiKey = readStringField(item, 'api_key')
			if (preserveEmptyApiKeys == true && apiKey == '') {
				apiKey = findProviderApiKeyInRows(oldProviderKeys, providerId)
			}
			runSqlOrThrow(db,
			'INSERT OR REPLACE INTO providers (id, name, api_base, api_key, models, enabled, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?)',
			[
				providerId,
				readStringField(item, 'name'),
				readStringField(item, 'api_base'),
				apiKey,
				readStringField(item, 'models'),
				readNumberField(item, 'enabled'),
				readNumberField(item, 'created_at'),
				readNumberField(item, 'updated_at'),
			]
			)
		}

		for (let i = 0; i < appSettings.length; i++) {
			const item = appSettings[i]
			const key = readStringField(item, 'key')
			let value = readStringField(item, 'value')
			if (preserveEmptyApiKeys == true && key == 'settings_astrbot_api_key' && value == '') {
				value = findSettingValueInRows(oldApiSettings, key)
			}
			runSqlOrThrow(db,
			'INSERT OR REPLACE INTO app_settings (key, value) VALUES (?, ?)',
			[key, value]
			)
		}

		assertSqlSuccess(db.commit(), '无法提交设置导入事务')
	} catch (e: any) {
		db.rollback()
		db.close()
		throw e
	}

	db.close()
}

/**
 * 获取所有提供商
 */
export function getAllProviders(): UTSJSONObject[] {
	const db = getDb()
	const result = db.query('SELECT * FROM providers ORDER BY enabled DESC, created_at ASC, id ASC')
	db.close()
	assertSqlSuccess(result, '读取模型提供商失败')
	return rowsToObjects(result)
}

/**
 * 根据 id 获取单个提供商
 * 用 getAllProviders 替代直接 SQL 查询，避免 Android SingletonList 问题
 */
export function getProviderById(id: string): UTSJSONObject | null {
	const all = getAllProviders()
	for (let i = 0; i < all.length; i++) {
		if ((all[i]['id'] as string) == id) {
			return all[i]
		}
	}
	return null
}

/**
 * 初始化默认提供商（首次使用时填充）
 */
export function initDefaultProviders(): void {
	// 用 getAllProviders 检查，避免 SingletonList 问题
	const existing = getAllProviders()
	if (existing.length > 0) {
		return
	}

	const defaults: UTSJSONObject[] = [
		{ id: 'deepseek', name: 'DeepSeek', api_base: 'https://api.deepseek.com', api_key: '', models: '[]', enabled: 0 },
		{ id: 'openai', name: 'OpenAI', api_base: 'https://api.openai.com', api_key: '', models: '[]', enabled: 0 },
		{ id: 'anthropic', name: 'Anthropic', api_base: 'https://api.anthropic.com', api_key: '', models: '[]', enabled: 0 },
		{ id: 'volcengine', name: '豆包(火山引擎)', api_base: 'https://ark.cn-beijing.volces.com/api/v3', api_key: '', models: '[]', enabled: 0 },
		{ id: 'xai', name: 'xAI(Grok)', api_base: 'https://api.x.ai', api_key: '', models: '[]', enabled: 0 },
		{ id: 'zai', name: '智谱 GLM', api_base: 'https://api.z.ai/api/coding/paas/v4', api_key: '', models: '[]', enabled: 0 },
		{ id: 'kimi-coding', name: 'Kimi', api_base: 'https://api.kimi.com/coding', api_key: '', models: '[]', enabled: 0 },
		{ id: 'minimax-cn', name: 'MiniMax', api_base: 'https://api.minimaxi.com/anthropic', api_key: '', models: '[]', enabled: 0 },
		{ id: 'xiaomi', name: '小米', api_base: 'https://api.xiaomimimo.com/v1', api_key: '', models: '[]', enabled: 0 },
		{ id: 'ant-ling', name: '蚂蚁 Ling', api_base: 'https://api.ant-ling.com/v1', api_key: '', models: '[]', enabled: 0 },
		{ id: 'siliconflow', name: '硅基流动', api_base: 'https://api.siliconflow.cn/v1', api_key: '', models: '[]', enabled: 0 },
	]

	const db = getDb()
	const now = Date.now()
	try {
		assertSqlSuccess(db.beginTransaction(), '无法开始默认模型提供商初始化事务')
		for (let i = 0; i < defaults.length; i++) {
			const p = defaults[i]
			const id: string = p['id'] as string
			const name: string = p['name'] as string
			const apiBase: string = p['api_base'] as string
			const apiKey: string = p['api_key'] as string
			const models: string = p['models'] as string
			const enabled: number = p['enabled'] as number
			assertSqlSuccess(db.run(
				'INSERT INTO providers (id, name, api_base, api_key, models, enabled, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?)',
				[id, name, apiBase, apiKey, models, enabled, now, now]
			), '初始化默认模型提供商失败')
		}
		assertSqlSuccess(db.commit(), '无法提交默认模型提供商初始化事务')
	} catch (e: any) {
		db.rollback()
		db.close()
		throw e
	}
	db.close()
}

/**
 * 保存提供商（插入或替换）
 */
export function saveProvider(
	id: string,
	name: string,
	apiBase: string,
	apiKey: string,
	models: string,
	enabled: boolean
): boolean {
	const db = getDb()
	ensureProvidersTable(db)
	ensureAppSettingsTable(db)
	const now = Date.now()
	let success = true
	try {
		assertSqlSuccess(db.beginTransaction(), '开始保存模型提供商')
		const previousResult = db.query('SELECT models FROM providers WHERE id = ? LIMIT 1', [id])
		assertSqlSuccess(previousResult, '读取旧模型列表')
		const previousRows = rowsToObjects(previousResult)
		let previousModels = ''
		if (previousRows.length > 0) {
			const rawPrevious = previousRows[0]['models'] as string | null
			previousModels = rawPrevious != null ? rawPrevious : ''
		}
		assertSqlSuccess(
			db.run(
			'INSERT OR REPLACE INTO providers (id, name, api_base, api_key, models, enabled, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?)',
			[id, name, apiBase, apiKey, models, enabled ? 1 : 0, now, now]
			),
			'保存提供商',
		)
		const oldIds = parseProviderModelIds(previousModels)
		const nextIds = parseProviderModelIds(models)
		const removedIds: string[] = []
		for (let i = 0; i < oldIds.length; i++) {
			if (stringListContains(nextIds, oldIds[i]) == false) {
				removedIds.push(oldIds[i])
			}
		}
		if (removedIds.length > 0) {
			clearProviderReferencesInTransaction(db, id, removedIds, false)
		}
		assertSqlSuccess(db.commit(), '提交模型提供商')
	} catch (_e: any) {
		db.rollback()
		success = false
	}
	db.close()
	return success
}

/** 首次引导专用原子配置：Provider、启用态、默认聊天模型和完成标记必须同事务提交。 */
export function saveFirstRunProviderConfiguration(id: string, name: string, apiBase: string, apiKey: string, models: string, defaultModel: string): boolean {
	if (id == '' || apiKey == '' || models == '' || defaultModel == '') { return false }
	const db = getDb()
	ensureProvidersTable(db)
	ensureAppSettingsTable(db)
	let success = true
	try {
		assertSqlSuccess(db.beginTransaction(), '开始首次引导配置事务')
		const now = Date.now()
		assertSqlSuccess(db.run(
			'INSERT OR REPLACE INTO providers (id, name, api_base, api_key, models, enabled, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?)',
			[id, name, apiBase, apiKey, models, 1, now, now],
		), '保存首次引导提供商')
		assertSqlSuccess(db.run(
			'UPDATE providers SET enabled=CASE WHEN id=? THEN 1 ELSE 0 END, updated_at=?',
			[id, now],
		), '启用首次引导提供商')
		const defaultConfig = JSON.stringify({ providerId: id, model: defaultModel })
		const keys = ['default_task_chat', 'first_run_model_guide_done']
		const values = [defaultConfig, 'true']
		for (let i = 0; i < keys.length; i++) {
			assertSqlSuccess(db.run('INSERT OR REPLACE INTO app_settings (key, value) VALUES (?, ?)', [keys[i], values[i]]), '保存首次引导状态')
		}
		assertSqlSuccess(db.commit(), '提交首次引导配置事务')
	} catch (_e: any) {
		db.rollback()
		success = false
	}
	db.close()
	return success
}

/**
 * 删除提供商
 */
export function deleteProvider(id: string): boolean {
	if (id == '') { return false }
	const db = getDb()
	ensureProvidersTable(db)
	ensureAppSettingsTable(db)
	let success = true
	try {
		assertSqlSuccess(db.beginTransaction(), '开始删除提供商')
		const result = db.run('DELETE FROM providers WHERE id = ? AND ? = ?', [id, 1, 1])
		assertSqlSuccess(result, '删除提供商')
		const changes = result.changes
		if (changes == null || changes <= 0) {
			throw new Error('提供商不存在')
		}
		clearProviderReferencesInTransaction(db, id, null, true)
		assertSqlSuccess(db.commit(), '提交删除提供商事务')
	} catch (_e: any) {
		db.rollback()
		success = false
	}
	db.close()
	return success
}

/**
 * 切换提供商启用状态
 */
export function toggleProvider(id: string, enabled: boolean): boolean {
	if (id == '') { return false }
	const db = getDb()
	ensureProvidersTable(db)
	ensureAppSettingsTable(db)
	let success = true
	try {
		assertSqlSuccess(db.beginTransaction(), '开始更新提供商状态')
		const result = db.run('UPDATE providers SET enabled=?, updated_at=? WHERE id=?', [enabled ? 1 : 0, Date.now(), id])
		assertSqlSuccess(result, '更新提供商状态')
		const changes = result.changes
		if (changes == null || changes <= 0) { throw new Error('提供商不存在') }
		if (enabled == false) {
			clearProviderReferencesInTransaction(db, id, null, true)
		}
		assertSqlSuccess(db.commit(), '提交提供商状态事务')
	} catch (_e: any) {
		db.rollback()
		success = false
	}
	db.close()
	return success
}

/** 启用指定提供商并禁用其他提供商。 */
export function activateProvider(id: string): boolean {
	if (id == '') { return false }
	const db = getDb()
	ensureProvidersTable(db)
	let success = true
	try {
		const result = db.run(
			'UPDATE providers SET enabled=CASE WHEN id=? THEN 1 ELSE 0 END, updated_at=?',
			[id, Date.now()],
		)
		assertSqlSuccess(result, '切换当前提供商')
		const changes = result.changes
		success = changes != null && changes > 0
	} catch (_e: any) {
		success = false
	}
	db.close()
	return success
}

// ==================== 应用设置（SQLite app_settings） ====================

/**
 * 获取应用设置值
 */
export function getAppSetting(key: string): string | null {
	if (key == '') { return null }
	const db = getDb()
	ensureAppSettingsTable(db)
	const result = db.query('SELECT value FROM app_settings WHERE key = ? AND ? = ? LIMIT 1', [key, 1, 1])
	db.close()
	assertSqlSuccess(result, '读取应用设置失败')
	const rows = rowsToObjects(result)
	if (rows.length > 0) {
		const value = rows[0]['value'] as string | null
		if (value != null && value != '') {
			return value
		}
		return null
	}
	return null
}

/**
 * 保存应用设置
 */
export function setAppSetting(key: string, value: string): boolean {
	if (key == '') { return false }
	const db = getDb()
	ensureAppSettingsTable(db)
	let success = true
	try {
		assertSqlSuccess(
			db.run('INSERT OR REPLACE INTO app_settings (key, value) VALUES (?, ?)', [key, value]),
			'保存应用设置',
		)
	} catch (_e: any) {
		success = false
	}
	db.close()
	return success
}

/** 在一个事务内批量保存应用设置，避免页面出现部分保存。 */
export function setAppSettings(keys: string[], values: string[]): boolean {
	if (keys.length == 0 || keys.length != values.length) { return false }
	for (let i = 0; i < keys.length; i++) {
		if (keys[i] == '') { return false }
	}
	const db = getDb()
	ensureAppSettingsTable(db)
	let success = true
	try {
		assertSqlSuccess(db.beginTransaction(), '开始保存应用设置')
		for (let i = 0; i < keys.length; i++) {
			assertSqlSuccess(
				db.run('INSERT OR REPLACE INTO app_settings (key, value) VALUES (?, ?)', [keys[i], values[i]]),
				'保存应用设置',
			)
		}
		assertSqlSuccess(db.commit(), '提交应用设置')
	} catch (_e: any) {
		db.rollback()
		success = false
	}
	db.close()
	return success
}

export function removeAppSetting(key: string): boolean {
	if (key == '') { return false }
	const db = getDb()
	ensureAppSettingsTable(db)
	let success = true
	try {
		assertSqlSuccess(db.run('DELETE FROM app_settings WHERE key = ?', [key]), '删除应用设置')
	} catch (_e: any) {
		success = false
	}
	db.close()
	return success
}

/**
 * 导出 SQLite app_settings 表中的原始设置。
 */
export function getAllAppSettings(): UTSJSONObject[] {
	const db = getDb()
	ensureAppSettingsTable(db)
	const result = db.query('SELECT key, value FROM app_settings ORDER BY key ASC')
	db.close()
	assertSqlSuccess(result, '导出应用设置失败')
	return rowsToObjects(result)
}
