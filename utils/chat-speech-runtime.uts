/**
 * Chat 页面语音运行时辅助。
 *
 * 页面保留状态机，路径解析、录音回调解析和播放器销毁放这里，避免 UI 文件继续膨胀。
 */

import { exists } from '@/utils/file-manager.uts'

export type ChatSpeechCacheState = {
	path: string
	playable: boolean
	stale: boolean
}

export function parseRecorderTempPath(res: any): string {
	try {
		const raw = JSON.stringify(res)
		if (raw == null || raw == '') { return '' }
		const parsed = JSON.parse(raw) as UTSJSONObject
		const rawTempPath = parsed['tempFilePath'] as string | null
		return rawTempPath != null ? rawTempPath : ''
	} catch (_e: any) {
	}
	return ''
}

export function buildPlayableSpeechPath(path: string): string {
	if (path == '') { return '' }
	if (path.startsWith('file://') || path.startsWith('http://') || path.startsWith('https://') || path.startsWith('unifile://')) {
		return path
	}
	if (path.startsWith('/')) {
		return 'file://' + path
	}
	return path
}

export function isPlayableSpeechCachePath(path: string): boolean {
	if (path == '') { return false }
	if (path.startsWith('http://') || path.startsWith('https://') || path.startsWith('unifile://')) { return true }
	if (path.startsWith('file://')) {
		const rawPath = path.substring(7)
		return exists(rawPath)
	}
	if (path.startsWith('/')) { return exists(path) }
	return true
}

export function createSpeechPlayer(path: string): InnerAudioContext | null {
	if (path == '') { return null }
	const audio = uni.createInnerAudioContext()
	audio.src = buildPlayableSpeechPath(path)
	return audio
}

export function destroySpeechPlayer(player: InnerAudioContext | null): void {
	if (player == null) { return }
	try {
		player.stop()
	} catch (_e: any) {
	}
	try {
		player.destroy()
	} catch (_e2: any) {
	}
}

export function readChatSpeechCacheState(msg: UTSJSONObject): ChatSpeechCacheState {
	const rawPath = msg['ttsAudioPath'] as string | null
	const path = rawPath != null ? rawPath : ''
	const playable = isPlayableSpeechCachePath(path)
	return {
		path: path,
		playable: playable,
		stale: path != '' && playable == false,
	} as ChatSpeechCacheState
}

export function clearChatSpeechCachePath(msg: UTSJSONObject): void {
	msg['ttsAudioPath'] = ''
}
