import {
	CHAT_ROLE_ASSISTANT,
	cloneMessage,
	extractPlainText,
	getMessageParts,
} from '@/utils/chat-models.uts'

export const CHAT_MESSAGE_WINDOW_BASE_SIZE = 80
export const CHAT_MESSAGE_WINDOW_STEP_SIZE = 40
export const CHAT_MESSAGE_WINDOW_EDGE_THRESHOLD_PX = 160
const CHAT_MESSAGE_WINDOW_TEXT_CHUNK_SIZE = 1600

export type ChatMessageWindowItem = {
	sourceIndex: number
	sourceMessage: UTSJSONObject
	renderMessage: UTSJSONObject
}

function readWindowStringField(obj: UTSJSONObject, key: string): string {
	const raw = obj[key] as string | null
	return raw != null ? raw : ''
}

function countTextChunkUnits(textLength: number): number {
	if (textLength <= 0) { return 0 }
	let units = 0
	let remain = textLength
	while (remain > 0) {
		units = units + 1
		remain = remain - CHAT_MESSAGE_WINDOW_TEXT_CHUNK_SIZE
	}
	return units
}

function countTextParagraphSegments(text: string): number {
	if (text == '') { return 0 }
	let count = 0
	let paragraphActive = false
	let lineHasText = false
	let paragraphLength = 0
	let lineLength = 0
	for (let i = 0; i <= text.length; i++) {
		const isEnd = i == text.length
		const ch = isEnd == true ? '\n' : text.charAt(i)
		if (ch == '\r') {
			continue
		}
		if (ch == '\n') {
			if (lineHasText == true) {
				if (paragraphActive == true) {
					paragraphLength = paragraphLength + 1
				}
				paragraphLength = paragraphLength + lineLength
				paragraphActive = true
			} else if (paragraphActive == true) {
				count = count + countTextChunkUnits(paragraphLength)
				paragraphActive = false
				paragraphLength = 0
			}
			lineHasText = false
			lineLength = 0
		} else if (ch != ' ' && ch != '\t') {
			lineHasText = true
			lineLength = lineLength + 1
		} else {
			lineLength = lineLength + 1
		}
	}
	if (paragraphActive == true) {
		count = count + countTextChunkUnits(paragraphLength)
	}
	if (count == 0 && text.trim() != '') {
		return 1
	}
	return count
}

function pushTextUnitChunks(result: string[], text: string): void {
	if (text == '') { return }
	let start = 0
	while (start < text.length) {
		let end = start + CHAT_MESSAGE_WINDOW_TEXT_CHUNK_SIZE
		if (end > text.length) { end = text.length }
		result.push(text.substring(start, end))
		start = end
	}
}

function buildTextUnitChunks(text: string, useParagraphSegments: boolean): string[] {
	const result: string[] = []
	if (text == '') { return result }
	if (useParagraphSegments == false) {
		pushTextUnitChunks(result, text)
		return result
	}
	let paragraph = ''
	let lineHasText = false
	let line = ''
	const normalized = text.replace(/\r/g, '\n')
	for (let i = 0; i <= normalized.length; i++) {
		const isEnd = i == normalized.length
		const ch = isEnd == true ? '\n' : normalized.charAt(i)
		if (ch == '\n') {
			if (lineHasText == true) {
				if (paragraph != '') { paragraph = paragraph + '\n' }
				paragraph = paragraph + line
			} else if (paragraph != '') {
				pushTextUnitChunks(result, paragraph.trim())
				paragraph = ''
			}
			line = ''
			lineHasText = false
		} else {
			line = line + ch
			if (ch != ' ' && ch != '\t') {
				lineHasText = true
			}
		}
	}
	if (paragraph != '') {
		pushTextUnitChunks(result, paragraph.trim())
	}
	if (result.length == 0 && text.trim() != '') {
		pushTextUnitChunks(result, text.trim())
	}
	return result
}

function countTextRenderUnits(text: string, useParagraphSegments: boolean): number {
	if (text == '') { return 0 }
	if (useParagraphSegments == true) {
		return countTextParagraphSegments(text)
	}
	return countTextChunkUnits(text.length)
}

export function countChatMessageRenderUnits(msg: UTSJSONObject, msgSegmentation: boolean): number {
	const role = readWindowStringField(msg, 'role')
	const parts = getMessageParts(msg)
	let count = 0
	for (let i = 0; i < parts.length; i++) {
		const part = parts[i]
		const partType = readWindowStringField(part, 'type')
		if (partType == 'think' || partType == 'thinking' || partType == 'tool_call' || partType == 'toolCall') {
			continue
		}
		if (partType == 'plain' || partType == 'text' || partType == 'location') {
			const textCount = countTextRenderUnits(readWindowStringField(part, 'text'), role == CHAT_ROLE_ASSISTANT && msgSegmentation == true)
			count = count + (textCount > 0 ? textCount : 1)
		} else {
			count = count + 1
		}
	}
	if (count <= 0) { return 1 }
	return count
}

export function countChatMessageRenderUnitsForList(source: UTSJSONObject[], msgSegmentation: boolean): number {
	let count = 0
	for (let i = 0; i < source.length; i++) {
		count = count + countChatMessageRenderUnits(source[i], msgSegmentation)
	}
	return count
}

export function countChatMessageRenderUnitsBefore(source: UTSJSONObject[], endIndex: number, msgSegmentation: boolean): number {
	let limit = endIndex
	if (limit < 0) { limit = 0 }
	if (limit > source.length) { limit = source.length }
	let count = 0
	for (let i = 0; i < limit; i++) {
		count = count + countChatMessageRenderUnits(source[i], msgSegmentation)
	}
	return count
}

export function resolveChatMessageWindowStartByUnits(source: UTSJSONObject[], windowUnits: number, msgSegmentation: boolean): number {
	if (source.length == 0) { return 0 }
	if (windowUnits <= 0) { return source.length }
	let remaining = windowUnits
	let start = source.length
	for (let i = source.length - 1; i >= 0; i--) {
		const units = countChatMessageRenderUnits(source[i], msgSegmentation)
		if (start < source.length && remaining - units < 0) {
			break
		}
		remaining = remaining - units
		start = i
		if (remaining <= 0) {
			break
		}
	}
	return start
}

export function resolveChatMessageWindowStart(total: number, windowCount: number): number {
	if (total <= 0) { return 0 }
	if (windowCount <= 0) { return total }
	if (total <= windowCount) { return 0 }
	return total - windowCount
}

export function buildChatMessageWindow(source: UTSJSONObject[], windowCount: number): UTSJSONObject[] {
	const result: UTSJSONObject[] = []
	const start = resolveChatMessageWindowStart(source.length, windowCount)
	for (let i = start; i < source.length; i++) {
		result.push(source[i])
	}
	return result
}

export function buildChatMessageWindowFromStart(source: UTSJSONObject[], startIndex: number): UTSJSONObject[] {
	const result: UTSJSONObject[] = []
	let start = startIndex
	if (start < 0) { start = 0 }
	if (start > source.length) { start = source.length }
	for (let i = start; i < source.length; i++) {
		result.push(source[i])
	}
	return result
}

function clonePartWithText(part: UTSJSONObject, text: string): UTSJSONObject {
	const copied = JSON.parse(JSON.stringify(part)) as UTSJSONObject
	copied['text'] = text
	return copied
}

function sliceChatMessageByUnits(message: UTSJSONObject, startUnit: number, endUnit: number, msgSegmentation: boolean): UTSJSONObject {
	const role = readWindowStringField(message, 'role')
	const parts = getMessageParts(message)
	const nextParts: UTSJSONObject[] = []
	let cursor = 0
	for (let i = 0; i < parts.length; i++) {
		const part = parts[i]
		const partType = readWindowStringField(part, 'type')
		if (partType == 'think' || partType == 'thinking' || partType == 'tool_call' || partType == 'toolCall') {
			if (startUnit <= 0) {
				nextParts.push(JSON.parse(JSON.stringify(part)) as UTSJSONObject)
			}
			continue
		}
		if (partType == 'plain' || partType == 'text' || partType == 'location') {
			const chunks = buildTextUnitChunks(readWindowStringField(part, 'text'), role == CHAT_ROLE_ASSISTANT && msgSegmentation == true)
			const unitCount = chunks.length > 0 ? chunks.length : 1
			for (let j = 0; j < chunks.length; j++) {
				const unitIndex = cursor + j
				if (unitIndex >= startUnit && unitIndex < endUnit) {
					nextParts.push(clonePartWithText(part, chunks[j]))
				}
			}
			cursor = cursor + unitCount
		} else {
			if (cursor >= startUnit && cursor < endUnit) {
				nextParts.push(JSON.parse(JSON.stringify(part)) as UTSJSONObject)
			}
			cursor = cursor + 1
		}
	}
	const copied = cloneMessage(message)
	copied['message'] = nextParts
	copied['content'] = extractPlainText(nextParts)
	copied['windowed'] = true
	return copied
}

export function buildChatMessageWindowByUnits(source: UTSJSONObject[], windowUnits: number, msgSegmentation: boolean): UTSJSONObject[] {
	const result: UTSJSONObject[] = []
	const totalUnits = countChatMessageRenderUnitsForList(source, msgSegmentation)
	let startUnit = totalUnits - windowUnits
	if (startUnit < 0) { startUnit = 0 }
	let cursor = 0
	for (let i = 0; i < source.length; i++) {
		const message = source[i]
		const units = countChatMessageRenderUnits(message, msgSegmentation)
		const messageStart = cursor
		const messageEnd = cursor + units
		cursor = messageEnd
		if (messageEnd <= startUnit) { continue }
		if (messageStart >= totalUnits) { continue }
		if (startUnit <= messageStart) {
			result.push(message)
		} else {
			result.push(sliceChatMessageByUnits(message, startUnit - messageStart, units, msgSegmentation))
		}
	}
	return result
}

export function buildChatMessageWindowRange(source: UTSJSONObject[], startIndex: number, endIndex: number): ChatMessageWindowItem[] {
	const result: ChatMessageWindowItem[] = []
	let start = startIndex
	let end = endIndex
	if (start < 0) { start = 0 }
	if (end < start) { end = start }
	if (end > source.length) { end = source.length }
	for (let i = start; i < end; i++) {
		result.push({
			sourceIndex: i,
			sourceMessage: source[i],
			renderMessage: source[i],
		} as ChatMessageWindowItem)
	}
	return result
}

export function resolveRecentChatMessageWindowStart(totalCount: number): number {
	if (totalCount <= CHAT_MESSAGE_WINDOW_BASE_SIZE) { return 0 }
	return totalCount - CHAT_MESSAGE_WINDOW_BASE_SIZE
}

export function resolveShiftedChatMessageWindowStart(totalCount: number, currentStart: number, direction: number): number {
	if (totalCount <= CHAT_MESSAGE_WINDOW_BASE_SIZE) { return 0 }
	let nextStart = currentStart
	if (direction < 0) {
		nextStart = currentStart - CHAT_MESSAGE_WINDOW_STEP_SIZE
	} else if (direction > 0) {
		nextStart = currentStart + CHAT_MESSAGE_WINDOW_STEP_SIZE
	}
	if (nextStart < 0) { nextStart = 0 }
	const maxStart = totalCount - CHAT_MESSAGE_WINDOW_BASE_SIZE
	if (nextStart > maxStart) { nextStart = maxStart }
	return nextStart
}

export function resolveChatMessageWindowEnd(totalCount: number, startIndex: number): number {
	let endIndex = startIndex + CHAT_MESSAGE_WINDOW_BASE_SIZE
	if (endIndex > totalCount) { endIndex = totalCount }
	if (endIndex < 0) { return 0 }
	return endIndex
}

export function isChatMessageWindowAtRecentEnd(totalCount: number, endIndex: number): boolean {
	return endIndex >= totalCount
}

export function countRemainingChatMessageWindowUnits(totalUnits: number, windowUnits: number): number {
	const remain = totalUnits - windowUnits
	return remain > 0 ? remain : 0
}

export function resolveNextChatMessageWindowCount(currentCount: number, total: number): number {
	let nextCount = currentCount + CHAT_MESSAGE_WINDOW_STEP_SIZE
	if (nextCount < CHAT_MESSAGE_WINDOW_BASE_SIZE) {
		nextCount = CHAT_MESSAGE_WINDOW_BASE_SIZE
	}
	if (nextCount > total) {
		nextCount = total
	}
	return nextCount
}
