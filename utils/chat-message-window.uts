import {
	CHAT_ROLE_ASSISTANT,
	cloneMessage,
	extractPlainText,
	getMessageParts,
} from '@/utils/chat-models.uts'

export const CHAT_MESSAGE_WINDOW_BASE_SIZE = 80
export const CHAT_MESSAGE_WINDOW_STEP_SIZE = 40
export const CHAT_MESSAGE_WINDOW_BASE_UNITS = CHAT_MESSAGE_WINDOW_BASE_SIZE
export const CHAT_MESSAGE_WINDOW_STEP_UNITS = CHAT_MESSAGE_WINDOW_STEP_SIZE
export const CHAT_MESSAGE_WINDOW_EDGE_THRESHOLD_PX = 160
const CHAT_MESSAGE_WINDOW_TEXT_CHUNK_SIZE = 1600
const CHAT_MESSAGE_WINDOW_STREAM_TEXT_LIMIT = 5000

export type ChatMessageWindowItem = {
	sourceIndex: number
	sourceMessage: UTSJSONObject
	renderMessage: UTSJSONObject
	messageStartUnit: number
	renderStartUnit: number
	renderEndUnit: number
}

export type ChatMessageWindowAnchor = {
	sourceIndex: number
	localUnit: number
}

function readWindowStringField(obj: UTSJSONObject, key: string): string {
	const raw = obj[key] as string | null
	return raw != null ? raw : ''
}

function pushTextUnitChunks(result: string[], text: string): void {
	if (text == '') { return }
	let start = 0
	while (start < text.length) {
		let end = start + CHAT_MESSAGE_WINDOW_TEXT_CHUNK_SIZE
		if (end > text.length) { end = text.length }
		result.push(text.substring(start, end))
		start = end
	}
}

function buildTextUnitChunks(text: string, useParagraphSegments: boolean): string[] {
	const result: string[] = []
	if (text == '') { return result }
	if (useParagraphSegments == false) {
		pushTextUnitChunks(result, text)
		return result
	}
	const normalized = text.replace(/\r/g, '')
	const lines = normalized.split('\n')
	let paragraphLines: string[] = []
	for (let i = 0; i < lines.length; i++) {
		const line = lines[i]
		if (line.trim() == '') {
			if (paragraphLines.length > 0) {
				pushTextUnitChunks(result, paragraphLines.join('\n').trim())
				paragraphLines = [] as string[]
			}
		} else {
			paragraphLines.push(line)
		}
	}
	if (paragraphLines.length > 0) {
		pushTextUnitChunks(result, paragraphLines.join('\n').trim())
	}
	if (result.length == 0 && text.trim() != '') {
		pushTextUnitChunks(result, text.trim())
	}
	return result
}

function countTextRenderUnits(text: string, useParagraphSegments: boolean): number {
	return buildTextUnitChunks(text, useParagraphSegments).length
}

function countNonTextPartRenderUnits(partType: string): number {
	return 1
}

function resolveMessageSegmentation(msg: UTSJSONObject, fallback: boolean): boolean {
	const raw = msg['msgSegmentation'] as boolean | null
	return raw != null ? raw : fallback
}

function readWindowText(msg: UTSJSONObject, part: UTSJSONObject): string {
	const text = readWindowStringField(part, 'text')
	if ((msg['isStreaming'] as boolean | null) != true || text.length <= CHAT_MESSAGE_WINDOW_STREAM_TEXT_LIMIT) {
		return text
	}
	return '…\n' + text.substring(text.length - CHAT_MESSAGE_WINDOW_STREAM_TEXT_LIMIT)
}

export function countChatMessageRenderUnits(msg: UTSJSONObject, msgSegmentation: boolean): number {
	const role = readWindowStringField(msg, 'role')
	const effectiveSegmentation = resolveMessageSegmentation(msg, msgSegmentation)
	const parts = getMessageParts(msg)
	let count = 0
	for (let i = 0; i < parts.length; i++) {
		const part = parts[i]
		const partType = readWindowStringField(part, 'type')
		if (partType == 'think' || partType == 'thinking' || partType == 'tool_call' || partType == 'toolCall') {
			continue
		}
		if (partType == 'plain' || partType == 'text') {
			const textCount = countTextRenderUnits(readWindowText(msg, part), role == CHAT_ROLE_ASSISTANT && effectiveSegmentation == true)
			count = count + (textCount > 0 ? textCount : 1)
		} else {
			count = count + countNonTextPartRenderUnits(partType)
		}
	}
	if (count <= 0) { return 1 }
	return count
}

export function countChatMessageRenderUnitsForList(source: UTSJSONObject[], msgSegmentation: boolean): number {
	let count = 0
	for (let i = 0; i < source.length; i++) {
		count = count + countChatMessageRenderUnits(source[i], msgSegmentation)
	}
	return count
}

/**
 * 增量维护每条消息的渲染 unit 数与累计前缀。
 * 常规流式刷新只重算尾消息；追加消息只从旧尾部继续，避免反复扫描完整历史。
 */
export function refreshChatMessageWindowMetrics(source: UTSJSONObject[], unitCounts: number[], unitPrefix: number[], msgSegmentation: boolean, forceFull: boolean): number {
	let start = 0
	if (forceFull == false && unitCounts.length <= source.length && unitPrefix.length == unitCounts.length) {
		if (unitCounts.length > 0) {
			start = unitCounts.length - 1
		}
	}
	if (start > source.length) { start = 0 }
	if (start < unitCounts.length) {
		unitCounts.splice(start, unitCounts.length - start)
	}
	if (start < unitPrefix.length) {
		unitPrefix.splice(start, unitPrefix.length - start)
	}
	let total = start > 0 ? unitPrefix[start - 1] : 0
	for (let i = start; i < source.length; i++) {
		const units = countChatMessageRenderUnits(source[i], msgSegmentation)
		total = total + units
		unitCounts.push(units)
		unitPrefix.push(total)
	}
	return total
}

export function countChatMessageRenderUnitsBefore(source: UTSJSONObject[], endIndex: number, msgSegmentation: boolean): number {
	let limit = endIndex
	if (limit < 0) { limit = 0 }
	if (limit > source.length) { limit = source.length }
	let count = 0
	for (let i = 0; i < limit; i++) {
		count = count + countChatMessageRenderUnits(source[i], msgSegmentation)
	}
	return count
}

export function resolveChatMessageWindowStartByUnits(source: UTSJSONObject[], windowUnits: number, msgSegmentation: boolean): number {
	if (source.length == 0) { return 0 }
	if (windowUnits <= 0) { return source.length }
	let remaining = windowUnits
	let start = source.length
	for (let i = source.length - 1; i >= 0; i--) {
		const units = countChatMessageRenderUnits(source[i], msgSegmentation)
		if (start < source.length && remaining - units < 0) {
			break
		}
		remaining = remaining - units
		start = i
		if (remaining <= 0) {
			break
		}
	}
	return start
}

export function resolveChatMessageWindowStart(total: number, windowCount: number): number {
	if (total <= 0) { return 0 }
	if (windowCount <= 0) { return total }
	if (total <= windowCount) { return 0 }
	return total - windowCount
}

export function buildChatMessageWindow(source: UTSJSONObject[], windowCount: number): UTSJSONObject[] {
	const result: UTSJSONObject[] = []
	const start = resolveChatMessageWindowStart(source.length, windowCount)
	for (let i = start; i < source.length; i++) {
		result.push(source[i])
	}
	return result
}

export function buildChatMessageWindowFromStart(source: UTSJSONObject[], startIndex: number): UTSJSONObject[] {
	const result: UTSJSONObject[] = []
	let start = startIndex
	if (start < 0) { start = 0 }
	if (start > source.length) { start = source.length }
	for (let i = start; i < source.length; i++) {
		result.push(source[i])
	}
	return result
}

function clonePartWithText(part: UTSJSONObject, text: string, windowUnit: number): UTSJSONObject {
	const copied = JSON.parse(JSON.stringify(part)) as UTSJSONObject
	copied['text'] = text
	copied['windowUnit'] = windowUnit
	return copied
}

function clonePartWithWindowUnit(part: UTSJSONObject, windowUnit: number): UTSJSONObject {
	const copied = JSON.parse(JSON.stringify(part)) as UTSJSONObject
	copied['windowUnit'] = windowUnit
	return copied
}

function sliceChatMessageByUnits(message: UTSJSONObject, startUnit: number, endUnit: number, msgSegmentation: boolean): UTSJSONObject {
	const role = readWindowStringField(message, 'role')
	const effectiveSegmentation = resolveMessageSegmentation(message, msgSegmentation)
	const parts = getMessageParts(message)
	const nextParts: UTSJSONObject[] = []
	let cursor = 0
	for (let i = 0; i < parts.length; i++) {
		const part = parts[i]
		const partType = readWindowStringField(part, 'type')
		if (partType == 'think' || partType == 'thinking' || partType == 'tool_call' || partType == 'toolCall') {
			if (startUnit <= 0) {
				nextParts.push(JSON.parse(JSON.stringify(part)) as UTSJSONObject)
			}
			continue
		}
		if (partType == 'plain' || partType == 'text') {
			const chunks = buildTextUnitChunks(readWindowText(message, part), role == CHAT_ROLE_ASSISTANT && effectiveSegmentation == true)
			const unitCount = chunks.length > 0 ? chunks.length : 1
			if (chunks.length == 0 && cursor < endUnit && cursor + unitCount > startUnit) {
				nextParts.push(clonePartWithWindowUnit(part, cursor))
			}
			for (let j = 0; j < chunks.length; j++) {
				const unitIndex = cursor + j
				if (unitIndex >= startUnit && unitIndex < endUnit) {
					nextParts.push(clonePartWithText(part, chunks[j], unitIndex))
				}
			}
			cursor = cursor + unitCount
		} else {
			const unitCount = countNonTextPartRenderUnits(partType)
			if (cursor < endUnit && cursor + unitCount > startUnit) {
				nextParts.push(clonePartWithWindowUnit(part, cursor))
			}
			cursor = cursor + unitCount
		}
	}
	const copied = cloneMessage(message)
	copied['message'] = nextParts
	copied['content'] = extractPlainText(nextParts)
	copied['windowed'] = true
	return copied
}

export function buildChatMessageWindowByUnits(source: UTSJSONObject[], windowUnits: number, msgSegmentation: boolean): UTSJSONObject[] {
	const result: UTSJSONObject[] = []
	const totalUnits = countChatMessageRenderUnitsForList(source, msgSegmentation)
	let startUnit = totalUnits - windowUnits
	if (startUnit < 0) { startUnit = 0 }
	let cursor = 0
	for (let i = 0; i < source.length; i++) {
		const message = source[i]
		const units = countChatMessageRenderUnits(message, msgSegmentation)
		const messageStart = cursor
		const messageEnd = cursor + units
		cursor = messageEnd
		if (messageEnd <= startUnit) { continue }
		if (messageStart >= totalUnits) { continue }
		if (startUnit <= messageStart) {
			result.push(message)
		} else {
			result.push(sliceChatMessageByUnits(message, startUnit - messageStart, units, msgSegmentation))
		}
	}
	return result
}

export function buildChatMessageWindowRange(source: UTSJSONObject[], startIndex: number, endIndex: number): ChatMessageWindowItem[] {
	const result: ChatMessageWindowItem[] = []
	let start = startIndex
	let end = endIndex
	if (start < 0) { start = 0 }
	if (end < start) { end = start }
	if (end > source.length) { end = source.length }
	for (let i = start; i < end; i++) {
		result.push({
			sourceIndex: i,
			sourceMessage: source[i],
				renderMessage: source[i],
				messageStartUnit: 0,
				renderStartUnit: 0,
			renderEndUnit: 0,
		} as ChatMessageWindowItem)
	}
	return result
}

export function buildChatMessageWindowRangeByUnits(source: UTSJSONObject[], startUnit: number, endUnit: number, msgSegmentation: boolean): ChatMessageWindowItem[] {
	const unitCounts: number[] = []
	const unitPrefix: number[] = []
	refreshChatMessageWindowMetrics(source, unitCounts, unitPrefix, msgSegmentation, true)
	return buildChatMessageWindowRangeFromMetrics(source, unitCounts, unitPrefix, startUnit, endUnit, msgSegmentation)
}

function findFirstWindowMessageIndex(unitPrefix: number[], startUnit: number): number {
	let low = 0
	let high = unitPrefix.length
	while (low < high) {
		const middle = Math.floor((low + high) / 2)
		if (unitPrefix[middle] <= startUnit) {
			low = middle + 1
		} else {
			high = middle
		}
	}
	return low
}

export function buildChatMessageWindowRangeFromMetrics(source: UTSJSONObject[], unitCounts: number[], unitPrefix: number[], startUnit: number, endUnit: number, msgSegmentation: boolean): ChatMessageWindowItem[] {
	const result: ChatMessageWindowItem[] = []
	let safeStart = startUnit
	let safeEnd = endUnit
	if (safeStart < 0) { safeStart = 0 }
	if (safeEnd < safeStart) { safeEnd = safeStart }
	if (unitCounts.length != source.length || unitPrefix.length != source.length) { return result }
	const firstIndex = findFirstWindowMessageIndex(unitPrefix, safeStart)
	for (let i = firstIndex; i < source.length; i++) {
		const message = source[i]
		const units = unitCounts[i]
		const messageStart = i > 0 ? unitPrefix[i - 1] : 0
		const messageEnd = unitPrefix[i]
		if (messageEnd <= safeStart) { continue }
		if (messageStart >= safeEnd) { break }
		let localStart = safeStart - messageStart
		let localEnd = safeEnd - messageStart
		if (localStart < 0) { localStart = 0 }
		if (localEnd > units) { localEnd = units }
		let renderMessage = message
		const parts = getMessageParts(message)
		if (parts.length > 0 || localStart > 0 || localEnd < units) {
			renderMessage = sliceChatMessageByUnits(message, localStart, localEnd, msgSegmentation)
		}
		result.push({
			sourceIndex: i,
			sourceMessage: message,
			renderMessage: renderMessage,
			messageStartUnit: messageStart,
			renderStartUnit: localStart,
			renderEndUnit: localEnd,
		} as ChatMessageWindowItem)
	}
	return result
}

export function resolveChatMessageWindowAnchor(items: ChatMessageWindowItem[], globalUnit: number): ChatMessageWindowAnchor | null {
	for (let i = 0; i < items.length; i++) {
		const item = items[i]
		const visibleStart = item.messageStartUnit + item.renderStartUnit
		const visibleEnd = item.messageStartUnit + item.renderEndUnit
		if (globalUnit >= visibleStart && globalUnit < visibleEnd) {
			return {
				sourceIndex: item.sourceIndex,
				localUnit: globalUnit - item.messageStartUnit,
			} as ChatMessageWindowAnchor
		}
	}
	return null
}

export function resolveRecentChatMessageWindowUnitStart(totalUnits: number): number {
	if (totalUnits <= CHAT_MESSAGE_WINDOW_BASE_UNITS) { return 0 }
	return totalUnits - CHAT_MESSAGE_WINDOW_BASE_UNITS
}

export function resolveShiftedChatMessageWindowUnitStart(totalUnits: number, currentStart: number, direction: number): number {
	if (totalUnits <= CHAT_MESSAGE_WINDOW_BASE_UNITS) { return 0 }
	let nextStart = currentStart
	if (direction < 0) {
		nextStart = currentStart - CHAT_MESSAGE_WINDOW_STEP_UNITS
	} else if (direction > 0) {
		nextStart = currentStart + CHAT_MESSAGE_WINDOW_STEP_UNITS
	}
	if (nextStart < 0) { nextStart = 0 }
	const maxStart = totalUnits - CHAT_MESSAGE_WINDOW_BASE_UNITS
	if (nextStart > maxStart) { nextStart = maxStart }
	return nextStart
}

export function resolveChatMessageWindowUnitEnd(totalUnits: number, startUnit: number): number {
	let endUnit = startUnit + CHAT_MESSAGE_WINDOW_BASE_UNITS
	if (endUnit > totalUnits) { endUnit = totalUnits }
	if (endUnit < 0) { return 0 }
	return endUnit
}

export function resolveRecentChatMessageWindowStart(totalCount: number): number {
	if (totalCount <= CHAT_MESSAGE_WINDOW_BASE_SIZE) { return 0 }
	return totalCount - CHAT_MESSAGE_WINDOW_BASE_SIZE
}

export function resolveShiftedChatMessageWindowStart(totalCount: number, currentStart: number, direction: number): number {
	if (totalCount <= CHAT_MESSAGE_WINDOW_BASE_SIZE) { return 0 }
	let nextStart = currentStart
	if (direction < 0) {
		nextStart = currentStart - CHAT_MESSAGE_WINDOW_STEP_SIZE
	} else if (direction > 0) {
		nextStart = currentStart + CHAT_MESSAGE_WINDOW_STEP_SIZE
	}
	if (nextStart < 0) { nextStart = 0 }
	const maxStart = totalCount - CHAT_MESSAGE_WINDOW_BASE_SIZE
	if (nextStart > maxStart) { nextStart = maxStart }
	return nextStart
}

export function resolveChatMessageWindowEnd(totalCount: number, startIndex: number): number {
	let endIndex = startIndex + CHAT_MESSAGE_WINDOW_BASE_SIZE
	if (endIndex > totalCount) { endIndex = totalCount }
	if (endIndex < 0) { return 0 }
	return endIndex
}

export function isChatMessageWindowAtRecentEnd(totalCount: number, endIndex: number): boolean {
	return endIndex >= totalCount
}

export function countRemainingChatMessageWindowUnits(totalUnits: number, windowUnits: number): number {
	const remain = totalUnits - windowUnits
	return remain > 0 ? remain : 0
}

export function resolveNextChatMessageWindowCount(currentCount: number, total: number): number {
	let nextCount = currentCount + CHAT_MESSAGE_WINDOW_STEP_SIZE
	if (nextCount < CHAT_MESSAGE_WINDOW_BASE_SIZE) {
		nextCount = CHAT_MESSAGE_WINDOW_BASE_SIZE
	}
	if (nextCount > total) {
		nextCount = total
	}
	return nextCount
}
