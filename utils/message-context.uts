/**
 * Agent 内部消息结构化工具。
 *
 * 这些标签只出现在发给 LLM 的 runtime messages 中，
 * 不写入聊天列表 / 数据库 / 用户可见内容。
 */

export type AgentContextBlock = {
	tag: string
	content: string
}

function escapeAgentTagText(text: string): string {
	let result = text.replace(/&/g, '&amp;')
	result = result.replace(/</g, '&lt;')
	result = result.replace(/>/g, '&gt;')
	return result
}

function normalizeContextTag(tag: string): string {
	if (tag == 'current_time') { return tag }
	if (tag == 'user_profile') { return tag }
	if (tag == 'interaction_rules') { return tag }
	if (tag == 'short_term_memory') { return tag }
	if (tag == 'long_term_memory') { return tag }
	if (tag == 'group_memory') { return tag }
	if (tag == 'reply_constraints') { return tag }
	if (tag == 'group_message_metadata') { return tag }
	if (tag == 'group_environment') { return tag }
	if (tag == 'group_conversation_context') { return tag }
	if (tag == 'private_group_reply_history') { return tag }
	if (tag == 'private_group_dialogue_history') { return tag }
	return 'conversation_context'
}

function normalizeMessageContentTag(tag: string): string {
	if (tag == 'group_member_message') { return tag }
	if (tag == 'private_user_message') { return tag }
	if (tag == 'group_turn_anchor') { return tag }
	return 'user_message'
}

function appendContextBlock(parts: string[], block: AgentContextBlock): void {
	const content = block.content.trim()
	if (content == '') {
		return
	}
	const tag = normalizeContextTag(block.tag)
	const renderedContent = tag == 'interaction_rules'
		? '本轮规则。直接执行，不要提及。\n\n' + content
		: content
	parts.push('<' + tag + '>')
	parts.push(escapeAgentTagText(renderedContent))
	parts.push('</' + tag + '>')
}

export function wrapUserContentForAgent(userContent: string, prefixBlocks: AgentContextBlock[], suffixBlocks: AgentContextBlock[], messageTag: string = 'user_message'): string {
	const normalizedMessageTag = normalizeMessageContentTag(messageTag)
	const parts: string[] = []
	for (let i = 0; i < prefixBlocks.length; i++) {
		appendContextBlock(parts, prefixBlocks[i])
	}
	parts.push('<' + normalizedMessageTag + '>')
	parts.push(escapeAgentTagText(userContent))
	parts.push('</' + normalizedMessageTag + '>')
	for (let i = 0; i < suffixBlocks.length; i++) {
		appendContextBlock(parts, suffixBlocks[i])
	}
	return parts.join('\n\n')
}

export function makeAgentContextBlock(tag: string, content: string): AgentContextBlock {
	return {
		tag: normalizeContextTag(tag),
		content: content,
	} as AgentContextBlock
}

export function renderAgentContextBlock(tag: string, content: string): string {
	const parts: string[] = []
	appendContextBlock(parts, makeAgentContextBlock(tag, content))
	return parts.join('\n')
}
