/**
 * Agent 内部消息结构化工具。
 *
 * 这些标签只出现在发给 LLM 的 runtime messages 中，
 * 不写入聊天列表 / 数据库 / 用户可见内容。
 */

export type AgentContextBlock = {
	tag: string
	content: string
}

function escapeAgentTagText(text: string): string {
	let result = text.replace(/<\/user_message>/g, '</ user_message>')
	result = result.replace(/<user_message>/g, '< user_message>')
	result = result.replace(/<\/agent_context>/g, '</ agent_context>')
	result = result.replace(/<agent_context/g, '< agent_context')
	result = result.replace(/<\/current_time>/g, '</ current_time>')
	result = result.replace(/<current_time>/g, '< current_time>')
	result = result.replace(/<\/user_profile>/g, '</ user_profile>')
	result = result.replace(/<user_profile>/g, '< user_profile>')
	result = result.replace(/<\/short_term_memory>/g, '</ short_term_memory>')
	result = result.replace(/<short_term_memory>/g, '< short_term_memory>')
	result = result.replace(/<\/long_term_memory>/g, '</ long_term_memory>')
	result = result.replace(/<long_term_memory>/g, '< long_term_memory>')
	result = result.replace(/<\/group_memory>/g, '</ group_memory>')
	result = result.replace(/<group_memory>/g, '< group_memory>')
	result = result.replace(/<\/reply_constraints>/g, '</ reply_constraints>')
	result = result.replace(/<reply_constraints>/g, '< reply_constraints>')
	result = result.replace(/<\/group_message_metadata>/g, '</ group_message_metadata>')
	result = result.replace(/<group_message_metadata>/g, '< group_message_metadata>')
	result = result.replace(/<\/group_environment>/g, '</ group_environment>')
	result = result.replace(/<group_environment>/g, '< group_environment>')
	result = result.replace(/<\/conversation_context>/g, '</ conversation_context>')
	result = result.replace(/<conversation_context>/g, '< conversation_context>')
	result = result.replace(/<\/group_conversation_context>/g, '</ group_conversation_context>')
	result = result.replace(/<group_conversation_context>/g, '< group_conversation_context>')
	return result
}

function normalizeContextTag(tag: string): string {
	if (tag == 'current_time') { return tag }
	if (tag == 'user_profile') { return tag }
	if (tag == 'short_term_memory') { return tag }
	if (tag == 'long_term_memory') { return tag }
	if (tag == 'group_memory') { return tag }
	if (tag == 'reply_constraints') { return tag }
	if (tag == 'group_message_metadata') { return tag }
	if (tag == 'group_environment') { return tag }
	if (tag == 'group_conversation_context') { return tag }
	return 'conversation_context'
}

function appendContextBlock(parts: string[], block: AgentContextBlock): void {
	const content = block.content.trim()
	if (content == '') {
		return
	}
	const tag = normalizeContextTag(block.tag)
	parts.push('<' + tag + '>')
	parts.push(escapeAgentTagText(content))
	parts.push('</' + tag + '>')
}

export function wrapUserContentForAgent(userContent: string, prefixBlocks: AgentContextBlock[], suffixBlocks: AgentContextBlock[]): string {
	const hasPrefix = prefixBlocks.length > 0
	const hasSuffix = suffixBlocks.length > 0
	if (hasPrefix == false && hasSuffix == false) {
		return userContent
	}
	const parts: string[] = []
	for (let i = 0; i < prefixBlocks.length; i++) {
		appendContextBlock(parts, prefixBlocks[i])
	}
	parts.push('<user_message>')
	parts.push(escapeAgentTagText(userContent))
	parts.push('</user_message>')
	for (let i = 0; i < suffixBlocks.length; i++) {
		appendContextBlock(parts, suffixBlocks[i])
	}
	return parts.join('\n\n')
}

export function makeAgentContextBlock(tag: string, content: string): AgentContextBlock {
	return {
		tag: normalizeContextTag(tag),
		content: content,
	} as AgentContextBlock
}

export function renderAgentContextBlock(tag: string, content: string): string {
	const parts: string[] = []
	appendContextBlock(parts, makeAgentContextBlock(tag, content))
	return parts.join('\n')
}
