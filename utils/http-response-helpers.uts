/**
 * HTTP 响应文本与 SSE 容错解析工具。
 *
 * 参考 AstrBot 的分层方式：协议噪音放底层，业务 service 只处理语义。
 */

export function responseDataToText(data: any | null): string {
	if (data == null) { return '' }
	try {
		const json = JSON.stringify(data)
		if (json.startsWith('"') == true && json.endsWith('"') == true) {
			return JSON.parse(json) as string
		}
		return json
	} catch (_e: any) {
		return ''
	}
}

export function readJsonString(obj: UTSJSONObject, key: string): string {
	const value = obj[key] as string | null
	return value != null ? value : ''
}

export function truncateResponseText(text: string, limit: number): string {
	if (text.length <= limit) { return text }
	return text.substring(0, limit) + '\n...[已截断]'
}

export function encodeQueryText(text: string): string {
	let result = ''
	for (let i = 0; i < text.length; i++) {
		const ch = text.substring(i, i + 1)
		if (ch == ' ') {
			result += '%20'
		} else if (ch == '+') {
			result += '%2B'
		} else if (ch == '&') {
			result += '%26'
		} else if (ch == '=') {
			result += '%3D'
		} else if (ch == '?') {
			result += '%3F'
		} else if (ch == '#') {
			result += '%23'
		} else if (ch == '@') {
			result += '%40'
		} else if (ch == '%') {
			result += '%25'
		} else {
			result += ch
		}
	}
	return result
}

function appendSseDataEvent(events: UTSJSONObject[], line: string): void {
	const trimmed = line.trim()
	if (trimmed.startsWith('data:') == false) { return }
	const payload = trimmed.substring(5).trim()
	if (payload == '' || payload == '[DONE]') { return }
	try {
		const item = JSON.parse(payload) as UTSJSONObject
		events.push(item)
	} catch (_e: any) {
		events.push({
			type: 'raw',
			data: payload,
		} as UTSJSONObject)
	}
}

export function parseSseDataEvents(raw: string): UTSJSONObject[] {
	const events: UTSJSONObject[] = []
	const lines = raw.split('\r\n').join('\n').split('\r').join('\n').split('\n')
	for (let i = 0; i < lines.length; i++) {
		appendSseDataEvent(events, lines[i])
	}
	return events
}
