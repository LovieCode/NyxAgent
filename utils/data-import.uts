/**
 * 全量数据导入工具
 * 从导出的 ZIP 备份包中恢复结构化数据与 Agent 工作区。
 */

import { importDatabaseTables, importSettingsTables, setAppSetting, setRuntimeState } from '@/utils/database.uts'
import { saveAgents } from '@/utils/agent.uts'
import { getAgentDir, getInternalFilesDir, joinPath, exists, createDir, writeContent } from '@/utils/file-manager.uts'
import { readImportManifest, importAgentWorkspaceFiles, importBackupAssets, importGroupWorkspaceFiles, importUserWorkspaceFiles } from '@/utssdk/app-data-export/index.uts'
import { APP_ERROR_CATEGORY_STORAGE, reportAppErrorFromCause } from '@/utils/app-error.uts'
import { disposeAllChatTurns } from '@/utils/chat-turn-runtime.uts'

const IMPORT_SCHEMA_VERSION = 1

function recordDataImportFailure(code: string, operation: string, userMessage: string, cause: any | null): void {
	reportAppErrorFromCause(
		code,
		APP_ERROR_CATEGORY_STORAGE,
		operation,
		userMessage,
		cause,
		true,
	)
}

export type ImportBackupSummary = {
	ok: boolean
	path: string
	app: string
	exportedAt: string
	version: string
	agents: number
	skills: number
	providers: number
	conversations: number
	messages: number
	groups: number
	assets: number
	apiKeys: boolean
	summary: string
	error: string
}

function readObjectArray(obj: UTSJSONObject, key: string): UTSJSONObject[] {
	const value = obj[key] as UTSJSONObject[] | null
	if (value == null) {
		return []
	}
	return value
}

function isSafeImportWorkspaceId(value: string): boolean {
	if (value == '' || value.length > 120) { return false }
	for (let i = 0; i < value.length; i++) {
		const codeValue = value.charCodeAt(i)
		if (codeValue == null) { return false }
		const code = codeValue
		const isDigit = code >= 48 && code <= 57
		const isUpper = code >= 65 && code <= 90
		const isLower = code >= 97 && code <= 122
		if (isDigit == false && isUpper == false && isLower == false && code != 45 && code != 95) {
			return false
		}
	}
	return true
}

/** 导入时不信任备份内的绝对路径，只按 group/session ID 重建应用私有路径。 */
function rewriteImportedGroupSessionWorkspacePaths(groupChatData: UTSJSONObject): string {
	const workspaceRoot = joinPath(getInternalFilesDir(), 'group-workspaces')
	if (workspaceRoot == '') { return '群聊工作区根目录不可用' }
	const sessions = readObjectArray(groupChatData, 'groupSessions')
	for (let i = 0; i < sessions.length; i++) {
		const item = sessions[i]
		const groupIdValue = item['group_id'] as string | null
		const sessionIdValue = item['id'] as string | null
		const groupId = groupIdValue != null ? groupIdValue : ''
		const sessionId = sessionIdValue != null ? sessionIdValue : ''
		if (isSafeImportWorkspaceId(groupId) == false || isSafeImportWorkspaceId(sessionId) == false) {
			return '群聊会话 ID 不合法'
		}
		item['workspace_path'] = joinPath(joinPath(workspaceRoot, groupId), sessionId)
	}
	return ''
}

function validateRequiredObjectArray(data: UTSJSONObject, key: string): string {
	const value = data[key] as UTSJSONObject[] | null
	return value == null ? '备份包缺少 ' + key + ' 数组' : ''
}

function validateBackupData(data: UTSJSONObject): string {
	const arrayKeys: string[] = [
		'providers',
		'appSettings',
		'agents',
		'skills',
		'assets',
		'conversations',
		'messages',
		'memoryBuffers',
		'memoryCore',
		'conversationTokenUsageStats',
		'memoryCompactionStates',
		'notes',
		'todos',
	]
	for (let i = 0; i < arrayKeys.length; i++) {
		const error = validateRequiredObjectArray(data, arrayKeys[i])
		if (error != '') { return error }
	}
	const storageKeys = data['storageKeys'] as string[] | null
	if (storageKeys == null) { return '备份包缺少 storageKeys 数组' }
	const storage = data['storage'] as UTSJSONObject | null
	if (storage == null) { return '备份包缺少 storage 对象' }
	const groupChatData = data['groupChatData'] as UTSJSONObject | null
	if (groupChatData == null) { return '备份包缺少 groupChatData 对象' }
	return ''
}

