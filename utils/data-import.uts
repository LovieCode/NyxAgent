/**
 * 全量数据导入工具
 * 从导出的 ZIP 备份包中恢复结构化数据与 Agent 工作区。
 */

import { importDatabaseTables, importSettingsTables, setAppSetting, setRuntimeState } from '@/utils/database.uts'
import { saveAgents } from '@/utils/agent.uts'
import { getAgentDir, joinPath, exists, createDir, writeContent } from '@/utils/file-manager.uts'
import { readImportManifest, importAgentWorkspaceFiles, importBackupAssets, importGroupWorkspaceFiles, importUserWorkspaceFiles } from '@/utssdk/app-data-export/index.uts'

export type ImportBackupSummary = {
	ok: boolean
	path: string
	app: string
	exportedAt: string
	version: string
	agents: number
	skills: number
	providers: number
	conversations: number
	messages: number
	groups: number
	assets: number
	apiKeys: boolean
	summary: string
	error: string
}

function readObjectArray(obj: UTSJSONObject, key: string): UTSJSONObject[] {
	const value = obj[key] as UTSJSONObject[] | null
	if (value == null) {
		return []
	}
	return value
}

function buildFallbackStorageKeys(): string[] {
	return [
		'agent_list',
		'active_agent_id',
		'active_conversation_id',
		'settings_provider_id',
		'settings_api_key',
		'settings_base_url',
		'settings_model',
		'settings_gh_proxy_enabled',
		'settings_gh_proxy_domain',
		'settings_web_search_enabled',
		'settings_web_search_provider',
		'settings_web_search_provider_id',
		'settings_web_search_model',
		'settings_web_search_instance',
		'settings_astrbot_enabled',
		'settings_astrbot_base_url',
		'settings_astrbot_api_key',
		'settings_astrbot_username',
		'settings_astrbot_session_id',
		'settings_astrbot_config_id',
		'settings_generation_temperature',
		'settings_generation_max_tokens',
		'settings_generation_max_iterations',
		'settings_generation_stream_enabled',
		'skills_list',
		'settings_memory_enabled',
		'memory_agent_id',
		'memory_conversation_id',
		'app_setting_default_task_chat',
		'app_setting_default_task_vision',
		'app_setting_image_caption_prompt',
		'app_setting_default_task_stt',
		'app_setting_default_task_tts',
		'profile_nickname',
		'profile_bio',
		'profile_email',
		'profile_description',
		'profile_avatar',
		'notes_list',
		'todo_list',
		'provider_edit_data',
		'pending_agent_model_id',
		'editor_title',
		'editor_content',
		'editor_draft',
		'editor_target',
		'editor_result',
		'editor_mode',
		'editor_file_path',
		'editor_saved',
		'editor_saved_path',
		'editor_result_ready',
		'editor_readonly',
		'editor_placeholder',
		'crop_image_path',
		'crop_result',
	]
}

function readStringArray(obj: UTSJSONObject, key: string): string[] {
	const value = obj[key] as string[] | null
	if (value == null) {
		return []
	}
	return value
}

function buildImportBackupError(path: string, error: string): ImportBackupSummary {
	return {
		ok: false,
		path: path,
		app: '',
		exportedAt: '',
		version: '',
		agents: 0,
		skills: 0,
		providers: 0,
		conversations: 0,
		messages: 0,
		groups: 0,
		assets: 0,
		apiKeys: false,
		summary: '',
		error: error,
	} as ImportBackupSummary
}

function hasProviderApiKeys(providers: UTSJSONObject[]): boolean {
	for (let i = 0; i < providers.length; i++) {
		const value = providers[i]['api_key'] as string | null
		if (value != null && value != '') {
			return true
		}
	}
	return false
}

function hasAppSettingsApiKey(appSettings: UTSJSONObject[]): boolean {
	for (let i = 0; i < appSettings.length; i++) {
		const key = appSettings[i]['key'] as string | null
		const value = appSettings[i]['value'] as string | null
		if ((key == 'settings_api_key' || key == 'settings_astrbot_api_key') && value != null && value != '') {
			return true
		}
	}
	return false
}

function hasStorageApiKey(storage: UTSJSONObject | null): boolean {
	if (storage == null) {
		return false
	}
	const value = storage['settings_api_key'] as string | null
	if (value != null && value != '') {
		return true
	}
	const astrBotValue = storage['settings_astrbot_api_key'] as string | null
	if (astrBotValue != null && astrBotValue != '') {
		return true
	}
	return false
}

function countBackupGroups(groupChatData: UTSJSONObject | null): number {
	if (groupChatData == null) {
		return 0
	}
	return readObjectArray(groupChatData, 'groupChats').length
}

function backupContainsApiKeys(root: UTSJSONObject, providers: UTSJSONObject[], appSettings: UTSJSONObject[], storage: UTSJSONObject | null): boolean {
	const flag = root['containsApiKeys'] as boolean | null
	if (flag == true) {
		return true
	}
	if (hasProviderApiKeys(providers) == true) {
		return true
	}
	if (hasAppSettingsApiKey(appSettings) == true) {
		return true
	}
	return hasStorageApiKey(storage)
}

function buildPreviewText(exportedAt: string, version: string, providers: number, agents: number, skills: number, conversations: number, messages: number, groups: number, assets: number, apiKeys: boolean): string {
	const keyText = apiKeys == true ? '完整备份（含 API Key）' : '安全备份（不含 API Key）'
	return '备份类型：' + keyText +
		'\n导出时间：' + (exportedAt != '' ? exportedAt : '未知') +
		'\nSchema：' + (version != '' ? version : '未知') +
		'\n提供商：' + providers + ' 个' +
		'\nAgent：' + agents + ' 个，Skills：' + skills + ' 个' +
		'\n私聊：' + conversations + ' 条对话 / ' + messages + ' 条消息' +
		'\n群聊：' + groups + ' 个' +
		'\n资源文件：' + assets + ' 个'
}

function isSettingsOnlyStorageKey(key: string): boolean {
	if (key.startsWith('settings_')) {
		return true
	}
	if (key.startsWith('app_setting_')) {
		return true
	}
	if (key.startsWith('profile_')) {
		return true
	}
	if (key == 'agent_list' || key == 'active_agent_id' || key == 'skills_list') {
		return true
	}
	return false
}

function buildSettingsOnlyStorageKeys(sourceKeys: string[]): string[] {
	let keys = sourceKeys
	if (keys.length == 0) {
		keys = buildFallbackStorageKeys()
	}
	const result: string[] = []
	for (let i = 0; i < keys.length; i++) {
		const key = keys[i]
		if (isSettingsOnlyStorageKey(key) == true) {
			result.push(key)
		}
	}
	return result
}

function filterEmptySensitiveStorageKeys(keys: string[], storage: UTSJSONObject): string[] {
	const result: string[] = []
	for (let i = 0; i < keys.length; i++) {
		const key = keys[i]
		if (key == 'settings_api_key' || key == 'settings_astrbot_api_key') {
			const value = storage[key] as string | null
			if (value == null || value == '') {
				continue
			}
		}
		result.push(key)
	}
	return result
}

function filterSettingsAssets(assets: UTSJSONObject[]): UTSJSONObject[] {
	const result: UTSJSONObject[] = []
	for (let i = 0; i < assets.length; i++) {
		const kind = assets[i]['kind'] as string | null
		if (kind == 'profileAvatar' || kind == 'cropSource' || kind == 'cropResult' || kind == 'agentAvatar') {
			result.push(assets[i])
		}
	}
	return result
}

function updateMappedStorageAssets(storage: UTSJSONObject, assetMap: UTSJSONObject): void {
	const profileAvatar = assetMap['storage.profile_avatar'] as string | null
	if (profileAvatar != null && profileAvatar != '') {
		storage['profile_avatar'] = profileAvatar
	}
	const cropSource = assetMap['storage.crop_image_path'] as string | null
	if (cropSource != null && cropSource != '') {
		storage['crop_image_path'] = cropSource
	}
	const cropResult = assetMap['storage.crop_result'] as string | null
	if (cropResult != null && cropResult != '') {
		storage['crop_result'] = cropResult
	}
}

function updateMappedAgentAssets(agents: UTSJSONObject[], assetMap: UTSJSONObject): void {
	for (let i = 0; i < agents.length; i++) {
		const id = agents[i]['id'] as string | null
		if (id != null && id != '') {
			const avatar = assetMap['agents.' + id + '.avatar'] as string | null
			if (avatar != null && avatar != '') {
				agents[i]['avatar'] = avatar
			}
		}
	}
}


function updatePartAssetPath(part: UTSJSONObject, mappedPath: string): void {
	part['path'] = mappedPath
	part['url'] = mappedPath
}

function updateMappedMessageAssets(messages: UTSJSONObject[], assetMap: UTSJSONObject): void {
	for (let i = 0; i < messages.length; i++) {
		const id = messages[i]['id'] as number | null
		const idText = id != null ? (id + '') : (i + '')
		const extraText = messages[i]['extra'] as string | null
		let extra: UTSJSONObject = {}
		if (extraText != null && extraText != '') {
			try {
				extra = JSON.parse(extraText) as UTSJSONObject
			} catch (_e: any) {
				extra = {}
			}
		}
		const parts = extra['message'] as UTSJSONObject[] | null
		if (parts != null) {
			let changed = false
			for (let pi = 0; pi < parts.length; pi++) {
				const mapped = assetMap['messages.' + idText + '.message.' + pi + '.path'] as string | null
				if (mapped != null && mapped != '') {
					updatePartAssetPath(parts[pi], mapped)
					changed = true
				}
			}
			if (changed == true) {
				extra['message'] = parts
				messages[i]['extra'] = JSON.stringify(extra)
			}
		}
		const imagePath = assetMap['messages.' + idText + '.imageUrl'] as string | null
		if (imagePath != null && imagePath != '') {
			extra['imageUrl'] = imagePath
			if (parts != null) {
				for (let pi = 0; pi < parts.length; pi++) {
					const partType = parts[pi]['type'] as string | null
					if (partType == 'image') {
						updatePartAssetPath(parts[pi], imagePath)
						break
					}
				}
				extra['message'] = parts
			}
			messages[i]['extra'] = JSON.stringify(extra)
		}
	}
}

function writeStorageObject(storage: UTSJSONObject, storageKeys: string[]): void {
	let keys = storageKeys
	if (keys.length == 0) {
		keys = buildFallbackStorageKeys()
	}
	for (let i = 0; i < keys.length; i++) {
		const key = keys[i]
		const value = storage[key]
		if (value != null) {
			const text = value as string
			if (key.startsWith('app_setting_')) {
				setAppSetting(key.substring(12), text)
			} else if (
				key == 'active_agent_id' ||
				key == 'active_conversation_id' ||
				key == 'memory_agent_id' ||
				key == 'memory_conversation_id' ||
				key == 'provider_edit_data' ||
				key == 'pending_agent_model_id' ||
				key.startsWith('editor_') ||
				key.startsWith('crop_')
			) {
				setRuntimeState(key, text)
			} else {
				setAppSetting(key, text)
			}
		}
	}
}

function restoreListStorage(key: string, list: UTSJSONObject[]): void {
	setAppSetting(key, JSON.stringify(list))
}

/** 只读取备份包信息，不写入任何数据。 */
export function previewImportBackup(zipPath: string): ImportBackupSummary {
	const manifestJson = readImportManifest(zipPath)
	if (manifestJson == '') {
		return buildImportBackupError(zipPath, '无法读取备份清单')
	}
	try {
		const root = JSON.parse(manifestJson) as UTSJSONObject
		const data = root['data'] as UTSJSONObject | null
		if (data == null) {
			return buildImportBackupError(zipPath, '备份包缺少 data 字段')
		}
		const providers = readObjectArray(data, 'providers')
		const conversations = readObjectArray(data, 'conversations')
		const messages = readObjectArray(data, 'messages')
		const appSettings = readObjectArray(data, 'appSettings')
		const agents = readObjectArray(data, 'agents')
		const skills = readObjectArray(data, 'skills')
		const assets = readObjectArray(data, 'assets')
		const storage = data['storage'] as UTSJSONObject | null
		const groupChatData = data['groupChatData'] as UTSJSONObject | null
		const exportedAt = root['exportedAt'] as string | null
		const schemaVersion = root['schemaVersion'] as number | null
		const app = root['app'] as string | null
		const apiKeys = backupContainsApiKeys(root, providers, appSettings, storage)
		const versionText = schemaVersion != null ? (schemaVersion + '') : ''
		const exportedAtText = exportedAt != null ? exportedAt : ''
		const groups = countBackupGroups(groupChatData)
		const summary = buildPreviewText(exportedAtText, versionText, providers.length, agents.length, skills.length, conversations.length, messages.length, groups, assets.length, apiKeys)
		return {
			ok: true,
			path: zipPath,
			app: app != null ? app : '',
			exportedAt: exportedAtText,
			version: versionText,
			agents: agents.length,
			skills: skills.length,
			providers: providers.length,
			conversations: conversations.length,
			messages: messages.length,
			groups: groups,
			assets: assets.length,
			apiKeys: apiKeys,
			summary: summary,
			error: '',
		} as ImportBackupSummary
	} catch (_e: any) {
		return buildImportBackupError(zipPath, '备份清单解析失败')
	}
}

/** 仅恢复设置、提供商、个人资料、Agent 和 Skills，不覆盖聊天记录或工作区文件。 */
export function importSettingsOnlyFromZip(zipPath: string): string {
	const manifestJson = readImportManifest(zipPath)
	if (manifestJson == '') {
		return ''
	}
	try {
		const root = JSON.parse(manifestJson) as UTSJSONObject
		const data = root['data'] as UTSJSONObject | null
		if (data == null) {
			return ''
		}
		const providers = readObjectArray(data, 'providers')
		const appSettings = readObjectArray(data, 'appSettings')
		const agents = readObjectArray(data, 'agents')
		const skills = readObjectArray(data, 'skills')
		const storage = data['storage'] as UTSJSONObject | null
		let storageKeys = buildSettingsOnlyStorageKeys(readStringArray(data, 'storageKeys'))
		const assets = filterSettingsAssets(readObjectArray(data, 'assets'))
		const assetMap = importBackupAssets(zipPath, assets)

		if (storage != null) {
			storageKeys = filterEmptySensitiveStorageKeys(storageKeys, storage)
			updateMappedStorageAssets(storage, assetMap)
		}
		updateMappedAgentAssets(agents, assetMap)
		if (storage != null) {
			storage['agent_list'] = JSON.stringify(agents)
			if (skills.length > 0) {
				storage['skills_list'] = JSON.stringify(skills)
			}
		}

		if (providers.length > 0 || appSettings.length > 0) {
			importSettingsTables(providers, appSettings, true)
		}
		if (agents.length > 0) {
			saveAgents(agents)
		}
		if (storage != null) {
			writeStorageObject(storage, storageKeys)
		}
		return '已恢复设置：提供商 ' + providers.length + ' 个，Agent ' + agents.length + ' 个，Skills ' + skills.length + ' 个，资源 ' + assets.length + ' 个。聊天记录和工作区文件未覆盖。'
	} catch (_e: any) {
		return ''
	}
}

/** 导入 ZIP 备份包，成功返回摘要，失败返回空字符串。 */
export function importAllDataFromZip(zipPath: string): string {
	const manifestJson = readImportManifest(zipPath)
	if (manifestJson == '') {
		return ''
	}
	try {
		const root = JSON.parse(manifestJson) as UTSJSONObject
		const data = root['data'] as UTSJSONObject | null
		if (data == null) {
			return ''
		}

		const providers = readObjectArray(data, 'providers')
		const conversations = readObjectArray(data, 'conversations')
		const messages = readObjectArray(data, 'messages')
		const appSettings = readObjectArray(data, 'appSettings')
		const memoryBuffers = readObjectArray(data, 'memoryBuffers')
		const memoryCore = readObjectArray(data, 'memoryCore')
		const conversationTokenUsageStats = readObjectArray(data, 'conversationTokenUsageStats')
		const memoryCompactionStates = readObjectArray(data, 'memoryCompactionStates')
		const groupChatData = data['groupChatData'] as UTSJSONObject | null
		const agents = readObjectArray(data, 'agents')
		const skills = readObjectArray(data, 'skills')
		const notes = readObjectArray(data, 'notes')
		const todos = readObjectArray(data, 'todos')
		const storage = data['storage'] as UTSJSONObject | null
		const storageKeys = readStringArray(data, 'storageKeys')
		const assets = readObjectArray(data, 'assets')
		const assetMap = importBackupAssets(zipPath, assets)

		if (storage != null) {
			updateMappedStorageAssets(storage, assetMap)
		}
		updateMappedAgentAssets(agents, assetMap)
		updateMappedMessageAssets(messages, assetMap)
		if (storage != null) {
			storage['agent_list'] = JSON.stringify(agents)
			if (skills.length > 0) {
				storage['skills_list'] = JSON.stringify(skills)
			}
			storage['notes_list'] = JSON.stringify(notes)
			storage['todo_list'] = JSON.stringify(todos)
		}

		importDatabaseTables(providers, conversations, messages, appSettings, memoryBuffers, memoryCore, conversationTokenUsageStats, memoryCompactionStates, groupChatData != null ? groupChatData : ({} as UTSJSONObject))
		if (agents.length > 0) {
			saveAgents(agents)
		}
		restoreListStorage('notes_list', notes)
		restoreListStorage('todo_list', todos)
		if (storage != null) {
			writeStorageObject(storage, storageKeys)
		}
		const workspaceCount = importAgentWorkspaceFiles(zipPath)
		const groupWorkspaceCount = importGroupWorkspaceFiles(zipPath)
		const userWorkspaceCount = importUserWorkspaceFiles(zipPath)
		return '已导入：提供商 ' + providers.length + ' 个，对话 ' + conversations.length + ' 条，消息 ' + messages.length + ' 条，记忆 ' + memoryCore.length + ' 条，Skills ' + skills.length + ' 个，资源 ' + assets.length + ' 个，用户文件 ' + userWorkspaceCount + ' 个，Agent 文件 ' + workspaceCount + ' 个，群聊文件 ' + groupWorkspaceCount + ' 个。'
	} catch (_e: any) {
		return ''
	}
}
