		'settings_web_search_instance',
		'settings_astrbot_enabled',
		'settings_astrbot_base_url',
		'settings_astrbot_api_key',
		'settings_astrbot_username',
		'settings_astrbot_session_id',
		'settings_astrbot_config_id',
		'settings_generation_temperature',
		'settings_generation_max_tokens',
		'settings_generation_max_iterations',
		'settings_generation_stream_enabled',
		'skills_list',
		'settings_memory_enabled',
		'memory_agent_id',
		'memory_conversation_id',
		'app_setting_default_task_chat',
		'app_setting_default_task_vision',
		'app_setting_image_caption_prompt',
		'app_setting_default_task_stt',
		'app_setting_default_task_tts',
		'profile_nickname',
		'profile_bio',
		'profile_email',
		'profile_description',
		'profile_avatar',
		'notes_list',
		'todo_list',
		'provider_edit_data',
		'pending_agent_model_id',
		'editor_title',
