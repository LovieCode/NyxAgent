function isRuntimeStorageKey(key: string): boolean {
	return key == 'active_agent_id' ||
		key == 'active_conversation_id' ||
		key == 'memory_agent_id' ||
		key == 'memory_conversation_id' ||
		key == 'provider_edit_data' ||
		key == 'pending_agent_model_id' ||
		key.startsWith('editor_') ||
		key.startsWith('crop_')
}

function containsRuntimeSnapshotKey(items: RuntimeStateSnapshot[], key: string): boolean {
	for (let i = 0; i < items.length; i++) {
		if (items[i].key == key) { return true }
	}
	return false
}

function captureRuntimeStateSnapshot(storageKeys: string[]): RuntimeStateSnapshot[] {
	let keys = storageKeys
	if (keys.length == 0) { keys = buildFallbackStorageKeys() }
	const result: RuntimeStateSnapshot[] = []
	for (let i = 0; i < keys.length; i++) {
		const key = keys[i]
		if (isRuntimeStorageKey(key) == true && containsRuntimeSnapshotKey(result, key) == false) {
			result.push({ key: key, value: getRuntimeState(key) } as RuntimeStateSnapshot)
		}
	}
	return result
}

function restoreRuntimeStateSnapshot(items: RuntimeStateSnapshot[]): boolean {
	let ok = true
	for (let i = 0; i < items.length; i++) {
		const item = items[i]
		const saved = item.value == '' ? deleteRuntimeState(item.key) : setRuntimeState(item.key, item.value)
		if (saved == false) { ok = false }
	}
	return ok
}

function captureSettingsImportSnapshot(storageKeys: string[]): SettingsImportSnapshot {
	return {
		providers: getAllProviders(),
		appSettings: getAllAppSettings(),
		agents: getAgents(),
		runtimeStates: captureRuntimeStateSnapshot(storageKeys),
	} as SettingsImportSnapshot
}

function restoreSettingsImportSnapshot(snapshot: SettingsImportSnapshot): boolean {
	try {
		importSettingsTables(snapshot.providers, snapshot.appSettings, false)
		if (saveAgents(snapshot.agents) == false) { return false }
		return restoreRuntimeStateSnapshot(snapshot.runtimeStates)
	} catch (e: any) {
		recordDataImportFailure('IMPORT_SETTINGS_ROLLBACK_FAILED', 'data_import_settings_rollback', '设置导入回滚失败', e)
		return false
	}
}

function captureFullImportSnapshot(): FullImportSnapshot {
	return {
		providers: getAllProviders(),
		conversations: getAllConversationsForExport(),
		messages: getAllMessagesForExport(),
		appSettings: getAllAppSettings(),
		memoryBuffers: getAllMemoryBuffersForExport(),
		memoryCore: getAllMemoryCoreForExport(),
		conversationTokenUsageStats: getAllConversationTokenUsageStatsForExport(),
		memoryCompactionStates: getAllMemoryCompactionStatesForExport(),
		groupChatData: getAllGroupChatDataForExport(),
		agents: getAgents(),
		runtimeStates: getAllRuntimeStatesForExport(),
	} as FullImportSnapshot
}

function restoreFullImportSnapshot(snapshot: FullImportSnapshot): boolean {
	try {
		importDatabaseTables(
			snapshot.providers,
			snapshot.conversations,
			snapshot.messages,
			snapshot.appSettings,
			snapshot.memoryBuffers,
			snapshot.memoryCore,
			snapshot.conversationTokenUsageStats,
			snapshot.memoryCompactionStates,
			snapshot.groupChatData,
		)
		if (replaceAllRuntimeStates(snapshot.runtimeStates) == false) { return false }
		if (saveAgents(snapshot.agents) == false) { return false }
		return true
	} catch (e: any) {
		recordDataImportFailure('IMPORT_ALL_ROLLBACK_FAILED', 'data_import_all_rollback', '全量导入回滚失败', e)
		return false
	}
}

function readPreparedFileImport(raw: UTSJSONObject): PreparedFileImport {
	const okValue = raw['ok'] as boolean | null
	const tokenValue = raw['token'] as string | null
	const assetMapValue = raw['assetMap'] as UTSJSONObject | null
	const agentCountValue = raw['agentWorkspaceCount'] as number | null
	const groupCountValue = raw['groupWorkspaceCount'] as number | null
	const userCountValue = raw['userWorkspaceCount'] as number | null
	const errorValue = raw['error'] as string | null
	return {
		ok: okValue == true,
		token: tokenValue != null ? tokenValue : '',
		assetMap: assetMapValue != null ? assetMapValue : ({} as UTSJSONObject),
		agentWorkspaceCount: agentCountValue != null ? agentCountValue : 0,
		groupWorkspaceCount: groupCountValue != null ? groupCountValue : 0,
		userWorkspaceCount: userCountValue != null ? userCountValue : 0,
		error: errorValue != null ? errorValue : '',
	} as PreparedFileImport
}

const IMPORT_TRANSACTION_JOURNAL_FILE = 'database-snapshot.json'
const IMPORT_TRANSACTION_COMMITTED_FILE = 'committed.marker'

function getImportTransactionRootPath(): string {
	const filesDir = getInternalFilesDir()
	if (filesDir == '') { return '' }
	return joinPath(joinPath(filesDir, 'imports'), 'data-import-transaction')
}

function getImportTransactionJournalPath(token: string): string {
	if (token == '') { return '' }
	return joinPath(token, IMPORT_TRANSACTION_JOURNAL_FILE)
}

function getImportTransactionCommittedPath(token: string): string {
	if (token == '') { return '' }
	return joinPath(token, IMPORT_TRANSACTION_COMMITTED_FILE)
}

function runtimeSnapshotsToObjects(items: RuntimeStateSnapshot[]): UTSJSONObject[] {
	const result: UTSJSONObject[] = []
	for (let i = 0; i < items.length; i++) {
		result.push({ key: items[i].key, value: items[i].value } as UTSJSONObject)
	}
	return result
}

function readRuntimeSnapshots(root: UTSJSONObject): RuntimeStateSnapshot[] {
	const raw = readObjectArray(root, 'runtimeStates')
	const result: RuntimeStateSnapshot[] = []
	for (let i = 0; i < raw.length; i++) {
		const keyValue = raw[i]['key'] as string | null
		const valueValue = raw[i]['value'] as string | null
		if (keyValue != null && keyValue != '') {
			result.push({ key: keyValue, value: valueValue != null ? valueValue : '' } as RuntimeStateSnapshot)
		}
	}
	return result
}

function persistSettingsImportSnapshot(token: string, snapshot: SettingsImportSnapshot): boolean {
	const journalPath = getImportTransactionJournalPath(token)
	if (journalPath == '') { return false }
	const journal: UTSJSONObject = {
		journalVersion: 1,
		kind: 'settings',
		phase: 'prepared',
		providers: snapshot.providers,
		appSettings: snapshot.appSettings,
		agents: snapshot.agents,
		runtimeStates: snapshot.runtimeStates,
	}
	return writeContent(journalPath, JSON.stringify(journal)).ok
}

function persistFullImportSnapshot(token: string, snapshot: FullImportSnapshot): boolean {
	const journalPath = getImportTransactionJournalPath(token)
	if (journalPath == '') { return false }
	const journal: UTSJSONObject = {
		journalVersion: 1,
		kind: 'full',
		phase: 'prepared',
		providers: snapshot.providers,
		conversations: snapshot.conversations,
		messages: snapshot.messages,
		appSettings: snapshot.appSettings,
		memoryBuffers: snapshot.memoryBuffers,
		memoryCore: snapshot.memoryCore,
		conversationTokenUsageStats: snapshot.conversationTokenUsageStats,
		memoryCompactionStates: snapshot.memoryCompactionStates,
		groupChatData: snapshot.groupChatData,
		agents: snapshot.agents,
		runtimeStates: snapshot.runtimeStates,
	}
	return writeContent(journalPath, JSON.stringify(journal)).ok
}

function readSettingsSnapshotFromJournal(journal: UTSJSONObject): SettingsImportSnapshot {
	return {
		providers: readObjectArray(journal, 'providers'),
		appSettings: readObjectArray(journal, 'appSettings'),
		agents: readObjectArray(journal, 'agents'),
		runtimeStates: readRuntimeSnapshots(journal),
	} as SettingsImportSnapshot
}

function readFullSnapshotFromJournal(journal: UTSJSONObject): FullImportSnapshot | null {
	const groupChatData = journal['groupChatData'] as UTSJSONObject | null
	if (groupChatData == null) { return null }
	return {
		providers: readObjectArray(journal, 'providers'),
		conversations: readObjectArray(journal, 'conversations'),
		messages: readObjectArray(journal, 'messages'),
		appSettings: readObjectArray(journal, 'appSettings'),
		memoryBuffers: readObjectArray(journal, 'memoryBuffers'),
		memoryCore: readObjectArray(journal, 'memoryCore'),
		conversationTokenUsageStats: readObjectArray(journal, 'conversationTokenUsageStats'),
		memoryCompactionStates: readObjectArray(journal, 'memoryCompactionStates'),
		groupChatData: groupChatData,
		agents: readObjectArray(journal, 'agents'),
		runtimeStates: readObjectArray(journal, 'runtimeStates'),
	} as FullImportSnapshot
}

function hasJournalObjectArray(journal: UTSJSONObject, key: string): boolean {
	return (journal[key] as UTSJSONObject[] | null) != null
}

function validateImportJournal(journal: UTSJSONObject, kind: string): boolean {
	const version = journal['journalVersion'] as number | null
	if (version == null || version != 1) { return false }
	const phase = journal['phase'] as string | null
	if (phase != 'prepared' && phase != 'committed') { return false }
	if (hasJournalObjectArray(journal, 'providers') == false ||
		hasJournalObjectArray(journal, 'appSettings') == false ||
		hasJournalObjectArray(journal, 'agents') == false ||
		hasJournalObjectArray(journal, 'runtimeStates') == false) {
		return false
	}
	if (kind == 'settings') { return true }
	if (kind != 'full') { return false }
	if (hasJournalObjectArray(journal, 'conversations') == false ||
		hasJournalObjectArray(journal, 'messages') == false ||
		hasJournalObjectArray(journal, 'memoryBuffers') == false ||
		hasJournalObjectArray(journal, 'memoryCore') == false ||
		hasJournalObjectArray(journal, 'conversationTokenUsageStats') == false ||
		hasJournalObjectArray(journal, 'memoryCompactionStates') == false) {
		return false
	}
	return (journal['groupChatData'] as UTSJSONObject | null) != null
}

function markImportTransactionCommitted(token: string): boolean {
	const markerPath = getImportTransactionCommittedPath(token)
	if (markerPath == '') { return false }
	return writeContent(markerPath, 'committed').ok
}

/** 启动时恢复被进程中断的跨介质导入；成功导入在删除 journal 后才算完成。 */
export function recoverInterruptedDataImport(): boolean {
	const token = getImportTransactionRootPath()
	if (token == '' || exists(token) == false) {
		dataImportRecoveryBlocked = false
		return true
	}
	const journalPath = getImportTransactionJournalPath(token)
	if (journalPath == '' || exists(journalPath) == false) {
		if (finalizeImportFileTransaction(token) == false) {
			recordDataImportFailure('IMPORT_RECOVERY_CLEANUP_FAILED', 'data_import_recovery_cleanup', '上次导入临时文件清理失败', token)
		}
		dataImportRecoveryBlocked = false
		return true
	}
	const journalText = readContent(journalPath)
	if (journalText == null || journalText == '') {
		recordDataImportFailure('IMPORT_RECOVERY_JOURNAL_READ_FAILED', 'data_import_recovery_journal', '上次导入恢复信息损坏，请重试启动', journalPath)
		dataImportRecoveryBlocked = true
		return false
	}
	try {
		const journal = JSON.parse(journalText) as UTSJSONObject
		const kind = journal['kind'] as string | null
		if (kind == null || validateImportJournal(journal, kind) == false) {
			recordDataImportFailure('IMPORT_RECOVERY_JOURNAL_INVALID', 'data_import_recovery_validate', '上次导入恢复信息不完整，请重试启动', journalPath)
			dataImportRecoveryBlocked = true
			return false
		}
		const phase = journal['phase'] as string | null
		const committedPath = getImportTransactionCommittedPath(token)
		if (phase == 'committed' || (committedPath != '' && exists(committedPath) == true)) {
			if (finalizeImportFileTransaction(token) == false) {
				recordDataImportFailure('IMPORT_COMMITTED_CLEANUP_FAILED', 'data_import_committed_cleanup', '已完成导入，旧快照清理失败', token)
			}
			dataImportRecoveryBlocked = false
			return true
		}
		let databaseRestored = false
		if (kind == 'settings') {
			databaseRestored = restoreSettingsImportSnapshot(readSettingsSnapshotFromJournal(journal))
		} else if (kind == 'full') {
			const snapshot = readFullSnapshotFromJournal(journal)
			if (snapshot != null) {
				databaseRestored = restoreFullImportSnapshot(snapshot)
			}
		}
		if (databaseRestored == false) {
			recordDataImportFailure('IMPORT_RECOVERY_DATABASE_FAILED', 'data_import_recovery_database', '上次导入数据库回滚失败，请重试启动', kind)
			dataImportRecoveryBlocked = true
			return false
		}
		if (rollbackImportFileTransaction(token) == false) {
			recordDataImportFailure('IMPORT_RECOVERY_FILES_FAILED', 'data_import_recovery_files', '上次导入文件回滚失败，请重试启动', token)
			dataImportRecoveryBlocked = true
			return false
		}
		dataImportRecoveryBlocked = false
		return true
	} catch (e: any) {
		recordDataImportFailure('IMPORT_RECOVERY_FAILED', 'data_import_recovery', '上次导入恢复失败，请重试启动', e)
		dataImportRecoveryBlocked = true
		return false
	}
}

function recoverDataImportBeforeNewWork(): boolean {
	const token = getImportTransactionRootPath()
	if (token != '' && exists(token) == true) {
		if (quiesceChatRuntimesForDataImport() == false) { return false }
	}
	return recoverInterruptedDataImport()
}

function readStringArray(obj: UTSJSONObject, key: string): string[] {
	const value = obj[key] as string[] | null
	if (value == null) {
		return []
	}
	return value
}

function buildImportBackupError(path: string, error: string): ImportBackupSummary {
	return {
		ok: false,
		path: path,
		app: '',
		exportedAt: '',
		version: '',
		agents: 0,
		skills: 0,
		providers: 0,
		conversations: 0,
		messages: 0,
		groups: 0,
		assets: 0,
		apiKeys: false,
		summary: '',
		error: error,
	} as ImportBackupSummary
}

function validateBackupRoot(root: UTSJSONObject): string {
	const app = root['app'] as string | null
	if (app != 'agent') {
		return '不是 NyxAgent 备份包'
	}
	const schemaVersion = root['schemaVersion'] as number | null
	if (schemaVersion == null || schemaVersion != IMPORT_SCHEMA_VERSION) {
		return '不支持的备份 Schema'
	}
	const data = root['data'] as UTSJSONObject | null
	if (data == null) {
		return '备份包缺少 data 字段'
	}
	return validateBackupData(data)
}

function validateImportedAssets(assets: UTSJSONObject[], assetMap: UTSJSONObject): string {
	for (let i = 0; i < assets.length; i++) {
		const ref = assets[i]['ref'] as string | null
		const zipPath = assets[i]['zipPath'] as string | null
		if (ref == null || ref == '' || zipPath == null || zipPath == '') {
			return '备份资源清单不完整'
		}
		const mapped = assetMap[ref] as string | null
		if (mapped == null || mapped == '') {
			return '备份资源缺失：' + zipPath
		}
	}
	return ''
}

function hasProviderApiKeys(providers: UTSJSONObject[]): boolean {
	for (let i = 0; i < providers.length; i++) {
		const value = providers[i]['api_key'] as string | null
		if (value != null && value != '') {
			return true
		}
	}
	return false
}

function hasAppSettingsApiKey(appSettings: UTSJSONObject[]): boolean {
	for (let i = 0; i < appSettings.length; i++) {
		const key = appSettings[i]['key'] as string | null
		const value = appSettings[i]['value'] as string | null
		if (key == 'settings_astrbot_api_key' && value != null && value != '') {
			return true
		}
	}
	return false
}

function hasStorageApiKey(storage: UTSJSONObject | null): boolean {
	if (storage == null) {
		return false
	}
	const astrBotValue = storage['settings_astrbot_api_key'] as string | null
	if (astrBotValue != null && astrBotValue != '') {
		return true
	}
	return false
}

function countBackupGroups(groupChatData: UTSJSONObject | null): number {
	if (groupChatData == null) {
		return 0
	}
	return readObjectArray(groupChatData, 'groupChats').length
}

function backupContainsApiKeys(root: UTSJSONObject, providers: UTSJSONObject[], appSettings: UTSJSONObject[], storage: UTSJSONObject | null): boolean {
	const flag = root['containsApiKeys'] as boolean | null
	if (flag == true) {
		return true
	}
	if (hasProviderApiKeys(providers) == true) {
		return true
	}
	if (hasAppSettingsApiKey(appSettings) == true) {
		return true
	}
	return hasStorageApiKey(storage)
}

function buildPreviewText(exportedAt: string, version: string, providers: number, agents: number, skills: number, conversations: number, messages: number, groups: number, assets: number, apiKeys: boolean): string {
	const keyText = apiKeys == true ? '完整备份（含 API Key）' : '安全备份（不含 API Key）'
	return '备份类型：' + keyText +
		'\n导出时间：' + (exportedAt != '' ? exportedAt : '未知') +
		'\nSchema：' + (version != '' ? version : '未知') +
		'\n提供商：' + providers + ' 个' +
		'\nAgent：' + agents + ' 个，Skills：' + skills + ' 个' +
		'\n私聊：' + conversations + ' 条对话 / ' + messages + ' 条消息' +
		'\n群聊：' + groups + ' 个' +
		'\n资源文件：' + assets + ' 个'
}

function isSettingsOnlyStorageKey(key: string): boolean {
	if (key.startsWith('settings_')) {
		return true
	}
	if (key.startsWith('app_setting_')) {
		return true
	}
	if (key.startsWith('profile_')) {
		return true
	}
	if (key == 'agent_list' || key == 'active_agent_id' || key == 'skills_list') {
		return true
	}
	return false
}

function buildSettingsOnlyStorageKeys(sourceKeys: string[]): string[] {
	let keys = sourceKeys
	if (keys.length == 0) {
		keys = buildFallbackStorageKeys()
	}
	const result: string[] = []
	for (let i = 0; i < keys.length; i++) {
		const key = keys[i]
		if (isSettingsOnlyStorageKey(key) == true) {
			result.push(key)
		}
	}
	return result
}

function filterEmptySensitiveStorageKeys(keys: string[], storage: UTSJSONObject): string[] {
	const result: string[] = []
	for (let i = 0; i < keys.length; i++) {
		const key = keys[i]
		if (key == 'settings_astrbot_api_key') {
			const value = storage[key] as string | null
			if (value == null || value == '') {
				continue
			}
		}
		result.push(key)
	}
	return result
}

function filterSettingsAssets(assets: UTSJSONObject[]): UTSJSONObject[] {
	const result: UTSJSONObject[] = []
	for (let i = 0; i < assets.length; i++) {
		const kind = assets[i]['kind'] as string | null
		if (kind == 'profileAvatar' || kind == 'cropSource' || kind == 'cropResult' || kind == 'agentAvatar') {
			result.push(assets[i])
		}
	}
	return result
}

function updateMappedStorageAssets(storage: UTSJSONObject, assetMap: UTSJSONObject): void {
	const profileAvatar = assetMap['storage.profile_avatar'] as string | null
	if (profileAvatar != null && profileAvatar != '') {
		storage['profile_avatar'] = profileAvatar
	}
	const cropSource = assetMap['storage.crop_image_path'] as string | null
	if (cropSource != null && cropSource != '') {
		storage['crop_image_path'] = cropSource
	}
	const cropResult = assetMap['storage.crop_result'] as string | null
	if (cropResult != null && cropResult != '') {
		storage['crop_result'] = cropResult
	}
}

function updateMappedAgentAssets(agents: UTSJSONObject[], assetMap: UTSJSONObject): void {
	for (let i = 0; i < agents.length; i++) {
		const id = agents[i]['id'] as string | null
		if (id != null && id != '') {
			const avatar = assetMap['agents.' + id + '.avatar'] as string | null
			if (avatar != null && avatar != '') {
				agents[i]['avatar'] = avatar
			}
		}
	}
}


function updatePartAssetPath(part: UTSJSONObject, mappedPath: string): void {
	part['path'] = mappedPath
	part['url'] = mappedPath
}

function updateMappedMessageAssets(messages: UTSJSONObject[], assetMap: UTSJSONObject): void {
	for (let i = 0; i < messages.length; i++) {
		const id = messages[i]['id'] as number | null
		const idText = id != null ? (id + '') : (i + '')
		const extraText = messages[i]['extra'] as string | null
		let extra: UTSJSONObject = {}
		if (extraText != null && extraText != '') {
			try {
				extra = JSON.parse(extraText) as UTSJSONObject
			} catch (e: any) {
				extra = {}
				recordDataImportFailure(
					'IMPORT_MESSAGE_ASSET_INVALID',
					'data_import_message_asset_' + idText,
					'部分消息附件路径无法恢复',
					e,
				)
			}
		}
		const parts = extra['message'] as UTSJSONObject[] | null
		if (parts != null) {
			let changed = false
			for (let pi = 0; pi < parts.length; pi++) {
				const mapped = assetMap['messages.' + idText + '.message.' + pi + '.path'] as string | null
				if (mapped != null && mapped != '') {
					updatePartAssetPath(parts[pi], mapped)
					changed = true
				}
			}
			if (changed == true) {
				extra['message'] = parts
				messages[i]['extra'] = JSON.stringify(extra)
			}
		}
		const imagePath = assetMap['messages.' + idText + '.imageUrl'] as string | null
		if (imagePath != null && imagePath != '') {
			extra['imageUrl'] = imagePath
			if (parts != null) {
				for (let pi = 0; pi < parts.length; pi++) {
					const partType = parts[pi]['type'] as string | null
					if (partType == 'image') {
						updatePartAssetPath(parts[pi], imagePath)
						break
					}
				}
				extra['message'] = parts
			}
			messages[i]['extra'] = JSON.stringify(extra)
		}
	}
}

function writeStorageObject(storage: UTSJSONObject, storageKeys: string[], includeRuntimeStates: boolean = true): boolean {
	let keys = storageKeys
	if (keys.length == 0) {
		keys = buildFallbackStorageKeys()
	}
	for (let i = 0; i < keys.length; i++) {
		const key = keys[i]
		if (includeRuntimeStates == false && isRuntimeStorageKey(key) == true) { continue }
		const value = storage[key]
		if (value != null) {
			const text = value as string
			let saved = false
			if (key.startsWith('app_setting_')) {
				saved = setAppSetting(key.substring(12), text)
			} else if (
				key == 'active_agent_id' ||
				key == 'active_conversation_id' ||
				key == 'memory_agent_id' ||
				key == 'memory_conversation_id' ||
				key == 'provider_edit_data' ||
				key == 'pending_agent_model_id' ||
				key.startsWith('editor_') ||
				key.startsWith('crop_')
			) {
				saved = setRuntimeState(key, text)
			} else {
				saved = setAppSetting(key, text)
			}
			if (saved == false) {
				return false
			}
		}
	}
	return true
}

function restoreListStorage(key: string, list: UTSJSONObject[]): boolean {
	return setAppSetting(key, JSON.stringify(list))
}

/** 只读取备份包信息，不写入任何数据。 */
export function previewImportBackup(zipPath: string): ImportBackupSummary {
	const manifestJson = readImportManifest(zipPath)
	if (manifestJson == '') {
		const archiveError = getLastDataArchiveError()
		recordDataImportFailure('IMPORT_MANIFEST_READ_FAILED', 'data_import_preview_manifest', '无法读取备份清单', archiveError != '' ? archiveError : 'readImportManifest 返回空内容')
		return buildImportBackupError(zipPath, '无法读取备份清单')
	}
	try {
		const root = JSON.parse(manifestJson) as UTSJSONObject
		const validationError = validateBackupRoot(root)
		if (validationError != '') {
			recordDataImportFailure('IMPORT_BACKUP_INVALID', 'data_import_preview_validate', validationError, validationError)
			return buildImportBackupError(zipPath, validationError)
		}
		const data = root['data'] as UTSJSONObject | null
		if (data == null) {
			recordDataImportFailure('IMPORT_BACKUP_DATA_MISSING', 'data_import_preview_data', '备份包缺少 data 字段', 'data 字段为空')
			return buildImportBackupError(zipPath, '备份包缺少 data 字段')
		}
		const providers = readObjectArray(data, 'providers')
		const conversations = readObjectArray(data, 'conversations')
		const messages = readObjectArray(data, 'messages')
		const appSettings = readObjectArray(data, 'appSettings')
		const agents = readObjectArray(data, 'agents')
		const skills = readObjectArray(data, 'skills')
		const assets = readObjectArray(data, 'assets')
		const storage = data['storage'] as UTSJSONObject | null
		const groupChatData = data['groupChatData'] as UTSJSONObject | null
		const exportedAt = root['exportedAt'] as string | null
		const schemaVersion = root['schemaVersion'] as number | null
		const app = root['app'] as string | null
		const apiKeys = backupContainsApiKeys(root, providers, appSettings, storage)
		const versionText = schemaVersion != null ? (schemaVersion + '') : ''
		const exportedAtText = exportedAt != null ? exportedAt : ''
		const groups = countBackupGroups(groupChatData)
		const summary = buildPreviewText(exportedAtText, versionText, providers.length, agents.length, skills.length, conversations.length, messages.length, groups, assets.length, apiKeys)
		return {
			ok: true,
			path: zipPath,
			app: app != null ? app : '',
			exportedAt: exportedAtText,
			version: versionText,
			agents: agents.length,
			skills: skills.length,
			providers: providers.length,
			conversations: conversations.length,
			messages: messages.length,
			groups: groups,
			assets: assets.length,
			apiKeys: apiKeys,
			summary: summary,
			error: '',
		} as ImportBackupSummary
	} catch (e: any) {
		recordDataImportFailure('IMPORT_MANIFEST_PARSE_FAILED', 'data_import_preview_parse', '备份清单解析失败', e)
		return buildImportBackupError(zipPath, '备份清单解析失败')
	}
}

/** 仅恢复设置、提供商、个人资料、Agent 和 Skills，不覆盖聊天记录或工作区文件。 */
export function importSettingsOnlyFromZip(zipPath: string): string {
	if (recoverDataImportBeforeNewWork() == false) {
		return ''
	}
	const manifestJson = readImportManifest(zipPath)
	if (manifestJson == '') {
		const archiveError = getLastDataArchiveError()
		recordDataImportFailure('IMPORT_SETTINGS_MANIFEST_READ_FAILED', 'data_import_settings_manifest', '无法读取备份清单', archiveError != '' ? archiveError : 'readImportManifest 返回空内容')
		return ''
	}
	let fileTransactionToken = ''
	let fileCommitStarted = false
	let databaseApplyStarted = false
	let transactionMarkedCommitted = false
	let snapshot: SettingsImportSnapshot | null = null
	try {
		const root = JSON.parse(manifestJson) as UTSJSONObject
		const validationError = validateBackupRoot(root)
		if (validationError != '') {
			recordDataImportFailure('IMPORT_SETTINGS_BACKUP_INVALID', 'data_import_settings_validate', validationError, validationError)
			return ''
		}
		const data = root['data'] as UTSJSONObject | null
		if (data == null) {
			recordDataImportFailure('IMPORT_SETTINGS_DATA_MISSING', 'data_import_settings_data', '备份包缺少 data 字段', 'data 字段为空')
			return ''
		}
		const providers = readObjectArray(data, 'providers')
		const appSettings = readObjectArray(data, 'appSettings')
		const agents = readObjectArray(data, 'agents')
		const skills = readObjectArray(data, 'skills')
		const storage = data['storage'] as UTSJSONObject | null
		let storageKeys = buildSettingsOnlyStorageKeys(readStringArray(data, 'storageKeys'))
		const assets = filterSettingsAssets(readObjectArray(data, 'assets'))
		const prepared = readPreparedFileImport(prepareImportFileTransaction(zipPath, assets, false))
		if (prepared.ok == false) {
			throw new Error(prepared.error != '' ? prepared.error : '资源暂存失败')
		}
		fileTransactionToken = prepared.token
		const assetMap = prepared.assetMap
		const assetError = validateImportedAssets(assets, assetMap)
		if (assetError != '') { throw new Error(assetError) }

		if (storage != null) {
			storageKeys = filterEmptySensitiveStorageKeys(storageKeys, storage)
			updateMappedStorageAssets(storage, assetMap)
		}
		updateMappedAgentAssets(agents, assetMap)
		if (storage != null) {
			storage['agent_list'] = JSON.stringify(agents)
			storage['skills_list'] = JSON.stringify(skills)
		}

		if (quiesceChatRuntimesForDataImport() == false) {
			throw new Error('仍有聊天进度无法保存，已取消导入')
		}
		snapshot = captureSettingsImportSnapshot(storageKeys)
		if (persistSettingsImportSnapshot(fileTransactionToken, snapshot) == false) {
			throw new Error('设置回滚快照写入失败')
		}
		fileCommitStarted = true
		if (commitImportFileTransaction(fileTransactionToken) == false) {
			throw new Error('资源目录提交失败')
		}
		databaseApplyStarted = true
		importSettingsTables(providers, appSettings, true)
		if (saveAgents(agents) == false) {
			throw new Error('Agent 设置恢复失败')
		}
		if (restoreListStorage('skills_list', skills) == false) {
			throw new Error('Skill 设置恢复失败')
		}
		if (storage != null) {
			if (writeStorageObject(storage, storageKeys) == false) {
				throw new Error('应用设置恢复失败')
			}
		}
		if (markImportTransactionCommitted(fileTransactionToken) == false) {
			throw new Error('设置导入提交标记写入失败')
		}
		transactionMarkedCommitted = true
		if (finalizeImportFileTransaction(fileTransactionToken) == false) {
			recordDataImportFailure('IMPORT_SETTINGS_FINALIZE_FAILED', 'data_import_settings_finalize', '设置已恢复，但旧资源快照清理失败', fileTransactionToken)
		}
		const backgroundResumed = resumeGroupBackgroundWorkAfterImport()
		return '已恢复设置：提供商 ' + providers.length + ' 个，Agent ' + agents.length + ' 个，Skills ' + skills.length + ' 个，资源 ' + assets.length + ' 个。聊天记录和工作区文件未覆盖。' + (backgroundResumed == true ? '' : ' 部分群聊后台发言将在重启后继续恢复。')
	} catch (e: any) {
		let databaseRestored = true
		let rollbackSafe = true
		if (databaseApplyStarted == true && snapshot != null) {
			databaseRestored = restoreSettingsImportSnapshot(snapshot)
			if (databaseRestored == false) { rollbackSafe = false }
		}
		if (transactionMarkedCommitted == true) {
			if (finalizeImportFileTransaction(fileTransactionToken) == false) {
				rollbackSafe = false
				recordDataImportFailure('IMPORT_SETTINGS_FINALIZE_AFTER_ERROR_FAILED', 'data_import_settings_finalize_after_error', '设置导入异常后事务目录清理失败', fileTransactionToken)
			}
		} else if (fileCommitStarted == true && databaseRestored == true) {
			if (rollbackImportFileTransaction(fileTransactionToken) == false) {
				rollbackSafe = false
				recordDataImportFailure('IMPORT_SETTINGS_FILE_ROLLBACK_FAILED', 'data_import_settings_file_rollback', '设置导入失败，资源目录回滚失败', fileTransactionToken)
			}
		} else if (fileCommitStarted == false && fileTransactionToken != '') {
			if (finalizeImportFileTransaction(fileTransactionToken) == false) {
				rollbackSafe = false
				recordDataImportFailure('IMPORT_SETTINGS_STAGING_CLEANUP_FAILED', 'data_import_settings_staging_cleanup', '设置导入暂存目录清理失败', fileTransactionToken)
			}
		}
		if (rollbackSafe == false) {
			dataImportRecoveryBlocked = true
		} else {
			resumeGroupBackgroundWorkAfterImport()
		}
		recordDataImportFailure('IMPORT_SETTINGS_FAILED', 'data_import_settings_apply', '恢复设置失败', e)
		return ''
	}
}

/** 导入 ZIP 备份包，成功返回摘要，失败返回空字符串。 */
export function importAllDataFromZip(zipPath: string): string {
	if (recoverDataImportBeforeNewWork() == false) {
		return ''
	}
	const manifestJson = readImportManifest(zipPath)
	if (manifestJson == '') {
		const archiveError = getLastDataArchiveError()
		recordDataImportFailure('IMPORT_ALL_MANIFEST_READ_FAILED', 'data_import_all_manifest', '无法读取备份清单', archiveError != '' ? archiveError : 'readImportManifest 返回空内容')
		return ''
	}
	let fileTransactionToken = ''
	let fileCommitStarted = false
	let databaseApplyStarted = false
	let transactionMarkedCommitted = false
	let snapshot: FullImportSnapshot | null = null
	try {
		const root = JSON.parse(manifestJson) as UTSJSONObject
		const validationError = validateBackupRoot(root)
		if (validationError != '') {
			recordDataImportFailure('IMPORT_ALL_BACKUP_INVALID', 'data_import_all_validate', validationError, validationError)
			return ''
		}
		const data = root['data'] as UTSJSONObject | null
		if (data == null) {
			recordDataImportFailure('IMPORT_ALL_DATA_MISSING', 'data_import_all_data', '备份包缺少 data 字段', 'data 字段为空')
			return ''
		}

		const providers = readObjectArray(data, 'providers')
		const conversations = readObjectArray(data, 'conversations')
		const messages = readObjectArray(data, 'messages')
		const appSettings = readObjectArray(data, 'appSettings')
		const memoryBuffers = readObjectArray(data, 'memoryBuffers')
		const memoryCore = readObjectArray(data, 'memoryCore')
		const conversationTokenUsageStats = readObjectArray(data, 'conversationTokenUsageStats')
		const memoryCompactionStates = readObjectArray(data, 'memoryCompactionStates')
		const runtimeStates = readObjectArray(data, 'runtimeStates')
		const groupChatData = data['groupChatData'] as UTSJSONObject | null
		if (groupChatData == null) {
			throw new Error('备份包缺少 groupChatData 对象')
		}
		const groupWorkspacePathError = rewriteImportedGroupSessionWorkspacePaths(groupChatData)
		if (groupWorkspacePathError != '') {
			throw new Error(groupWorkspacePathError)
		}
		const agents = readObjectArray(data, 'agents')
		const skills = readObjectArray(data, 'skills')
		const notes = readObjectArray(data, 'notes')
		const todos = readObjectArray(data, 'todos')
		const storage = data['storage'] as UTSJSONObject | null
		const storageKeys = readStringArray(data, 'storageKeys')
		const assets = readObjectArray(data, 'assets')
		const prepared = readPreparedFileImport(prepareImportFileTransaction(zipPath, assets, true))
		if (prepared.ok == false) {
			throw new Error(prepared.error != '' ? prepared.error : '资源与工作区暂存失败')
		}
		fileTransactionToken = prepared.token
		const assetMap = prepared.assetMap
		const assetError = validateImportedAssets(assets, assetMap)
		if (assetError != '') { throw new Error(assetError) }

		if (storage != null) {
			updateMappedStorageAssets(storage, assetMap)
		}
		updateMappedAgentAssets(agents, assetMap)
		updateMappedMessageAssets(messages, assetMap)
		if (storage != null) {
			storage['agent_list'] = JSON.stringify(agents)
			storage['skills_list'] = JSON.stringify(skills)
			storage['notes_list'] = JSON.stringify(notes)
			storage['todo_list'] = JSON.stringify(todos)
		}

		if (quiesceChatRuntimesForDataImport() == false) {
			throw new Error('仍有聊天进度无法保存，已取消导入')
		}
		snapshot = captureFullImportSnapshot()
		if (persistFullImportSnapshot(fileTransactionToken, snapshot) == false) {
			throw new Error('全量回滚快照写入失败')
		}
		fileCommitStarted = true
		if (commitImportFileTransaction(fileTransactionToken) == false) {
			throw new Error('资源与工作区目录提交失败')
		}
		databaseApplyStarted = true
		importDatabaseTables(providers, conversations, messages, appSettings, memoryBuffers, memoryCore, conversationTokenUsageStats, memoryCompactionStates, groupChatData)
		if (replaceAllRuntimeStates(runtimeStates) == false) {
			throw new Error('页面运行状态恢复失败')
		}
		if (saveAgents(agents) == false) {
			throw new Error('Agent 数据恢复失败')
		}
		if (restoreListStorage('skills_list', skills) == false) {
			throw new Error('Skill 数据恢复失败')
		}
		if (restoreListStorage('notes_list', notes) == false) {
			throw new Error('笔记数据恢复失败')
		}
		if (restoreListStorage('todo_list', todos) == false) {
			throw new Error('待办数据恢复失败')
		}
		if (storage != null) {
			if (writeStorageObject(storage, storageKeys, false) == false) {
				throw new Error('应用设置恢复失败')
			}
		}
		if (markImportTransactionCommitted(fileTransactionToken) == false) {
			throw new Error('全量导入提交标记写入失败')
		}
		transactionMarkedCommitted = true
		if (finalizeImportFileTransaction(fileTransactionToken) == false) {
			recordDataImportFailure('IMPORT_ALL_FINALIZE_FAILED', 'data_import_all_finalize', '数据已导入，但旧目录快照清理失败', fileTransactionToken)
		}
		const backgroundResumed = resumeGroupBackgroundWorkAfterImport()
		return '已导入：提供商 ' + providers.length + ' 个，对话 ' + conversations.length + ' 条，消息 ' + messages.length + ' 条，记忆 ' + memoryCore.length + ' 条，Skills ' + skills.length + ' 个，资源 ' + assets.length + ' 个，用户文件 ' + prepared.userWorkspaceCount + ' 个，Agent 文件 ' + prepared.agentWorkspaceCount + ' 个，群聊文件 ' + prepared.groupWorkspaceCount + ' 个。' + (backgroundResumed == true ? '' : ' 部分群聊后台发言将在重启后继续恢复。')
	} catch (e: any) {
		let databaseRestored = true
		let rollbackSafe = true
		if (databaseApplyStarted == true && snapshot != null) {
			databaseRestored = restoreFullImportSnapshot(snapshot)
			if (databaseRestored == false) { rollbackSafe = false }
		}
		if (transactionMarkedCommitted == true) {
			if (finalizeImportFileTransaction(fileTransactionToken) == false) {
				rollbackSafe = false
				recordDataImportFailure('IMPORT_ALL_FINALIZE_AFTER_ERROR_FAILED', 'data_import_all_finalize_after_error', '全量导入异常后事务目录清理失败', fileTransactionToken)
			}
		} else if (fileCommitStarted == true && databaseRestored == true) {
			if (rollbackImportFileTransaction(fileTransactionToken) == false) {
				rollbackSafe = false
				recordDataImportFailure('IMPORT_ALL_FILE_ROLLBACK_FAILED', 'data_import_all_file_rollback', '全量导入失败，工作区回滚失败', fileTransactionToken)
			}
		} else if (fileCommitStarted == false && fileTransactionToken != '') {
			if (finalizeImportFileTransaction(fileTransactionToken) == false) {
				rollbackSafe = false
				recordDataImportFailure('IMPORT_ALL_STAGING_CLEANUP_FAILED', 'data_import_all_staging_cleanup', '全量导入暂存目录清理失败', fileTransactionToken)
			}
		}
		if (rollbackSafe == false) {
			dataImportRecoveryBlocked = true
		} else {
			resumeGroupBackgroundWorkAfterImport()
		}
		recordDataImportFailure('IMPORT_ALL_FAILED', 'data_import_all_apply', '导入备份失败', e)
		return ''
	}
}
