/**
 * Agent 沙箱文件工具
 * 将 agent-fs 的沙箱操作包装为 AgentTool 实现
 * 每个工具绑定到特定 agentId，防止越权
 */

import {
	readAgentFile,
	writeAgentFile,
	deleteAgentFile,
	listAgentFiles,
	createAgentDirectory,
	getAgentFileInfo,
	type AgentFileInfo,
} from '@/utils/agent-fs.uts'
import {
	searchCoreMemory,
	searchConversationHistory,
	updateMemoryBuffer,
	saveCoreMemory,
	listCoreMemory,
	archiveCoreMemory,
	formatCoreMemoryList,
	buildMemoryTargetPersonId,
	type MemoryCoreInput,
} from '@/utils/memory.uts'

/** ToolResult 匹配 agent-core types */
export type ToolResult = {
	content: string
	isError: boolean
}

/** 给 LLM 的工具定义描述 */
type ToolDefinition = {
	name: string
	description: string
	parameters: UTSJSONObject
}

/** AgentTool 接口（匹配 agent-core types） */
export interface AgentTool {
	name: string
	description: string
	parameters: UTSJSONObject
	execute(args: UTSJSONObject): Promise<ToolResult>
}

/**
 * 创建绑定到指定 agent 的沙箱文件工具列表
 * @param agentId 智能体 ID
 * @returns AgentTool 数组
 */
export function createAgentTools(agentId: string, conversationId: string = '', personId: string = '', allowCoreMemoryWrite: boolean = false): AgentTool[] {
	const tools: AgentTool[] = [
		new SandboxFileReadTool(agentId) as AgentTool,
		new SandboxFileWriteTool(agentId) as AgentTool,
		new SandboxFileDeleteTool(agentId) as AgentTool,
		new SandboxFileListTool(agentId) as AgentTool,
		new MemorySearchTool(agentId, conversationId, personId) as AgentTool,
		new MemoryBufferWriteTool(agentId, conversationId, personId) as AgentTool,
		new MemoryCoreListTool(agentId, conversationId, personId) as AgentTool,
	]
	if (allowCoreMemoryWrite == true) {
		tools.push(new MemoryCoreSaveTool(agentId, conversationId, personId) as AgentTool)
		tools.push(new MemoryCoreForgetTool() as AgentTool)
	}
	return tools
}

// ========== 工具定义 ==========

/**
 * 文件读取工具
 */
class SandboxFileReadTool implements AgentTool {
	name: string = 'file_read'
	description: string = '读取指定文件的内容。path 相对于智能体的私有存储目录，不允许使用绝对路径或 ".." 穿越。'
	parameters: UTSJSONObject = {
		'type': 'object',
		'properties': {
			'path': {
				'type': 'string',
				'description': '要读取的文件路径（相对于智能体私有目录）'
			}
		},
		'required': ['path']
	} as UTSJSONObject

	private agentId: string

	constructor(agentId: string) {
		this.agentId = agentId
	}

	execute(args: UTSJSONObject): Promise<ToolResult> {
		return new Promise<ToolResult>((resolve) => {
			const path = args['path'] as string | null
			if (path == null || path!.length == 0) {
				resolve({ content: '缺少必要参数: path', isError: true } as ToolResult)
				return
			}
			const content = readAgentFile(this.agentId, path!)
			if (content == null) {
				resolve({ content: '文件不存在或读取失败: ' + path!, isError: true } as ToolResult)
				return
			}
			resolve({ content: content!, isError: false } as ToolResult)
		})
	}
}

/**
 * 文件/目录写入工具
 * 合并创建文件和创建目录的能力
 */
class SandboxFileWriteTool implements AgentTool {
	name: string = 'file_write'
	description: string = '创建文件或目录。如果 is_directory 为 true，则创建目录；否则将 content 写入文件（父目录不存在自动创建）。'
	parameters: UTSJSONObject = {
		'type': 'object',
		'properties': {
			'path': {
				'type': 'string',
				'description': '要创建的文件或目录路径（相对于智能体私有目录）'
			},
			'is_directory': {
				'type': 'boolean',
				'description': 'true 表示创建目录，false 表示写入文件（默认 false）'
			},
			'content': {
				'type': 'string',
				'description': '要写入的文件内容（is_directory 为 false 时必填）'
			}
		},
		'required': ['path']
	} as UTSJSONObject

	private agentId: string

	constructor(agentId: string) {
		this.agentId = agentId
	}

	execute(args: UTSJSONObject): Promise<ToolResult> {
		return new Promise<ToolResult>((resolve) => {
			const path = args['path'] as string | null
			const isDirectory = args['is_directory'] as boolean | null
			const content = args['content'] as string | null
			if (path == null || path!.length == 0) {
				resolve({ content: '缺少必要参数: path', isError: true } as ToolResult)
				return
			}
			if (isDirectory == true) {
				const ok = createAgentDirectory(this.agentId, path!)
				resolve({
					content: ok ? '目录创建成功: ' + path! : '目录创建失败（可能已存在同名文件）: ' + path!,
					isError: !ok
				} as ToolResult)
				return
			}
			if (content == null) {
				resolve({ content: '缺少必要参数: content', isError: true } as ToolResult)
				return
			}
			const ok = writeAgentFile(this.agentId, path!, content!)
			resolve({
				content: ok ? '文件写入成功: ' + path! : '文件写入失败: ' + path!,
				isError: !ok
			} as ToolResult)
		})
	}
}

/**
 * 文件删除工具
 */
class SandboxFileDeleteTool implements AgentTool {
	name: string = 'file_delete'
	description: string = '删除指定文件。'
	parameters: UTSJSONObject = {
		'type': 'object',
		'properties': {
			'path': {
				'type': 'string',
				'description': '要删除的文件路径（相对于智能体私有目录）'
			}
		},
		'required': ['path']
	} as UTSJSONObject

	private agentId: string

	constructor(agentId: string) {
		this.agentId = agentId
	}

	execute(args: UTSJSONObject): Promise<ToolResult> {
		return new Promise<ToolResult>((resolve) => {
			const path = args['path'] as string | null
			if (path == null || path!.length == 0) {
				resolve({ content: '缺少必要参数: path', isError: true } as ToolResult)
				return
			}
			const ok = deleteAgentFile(this.agentId, path!)
			resolve({
				content: ok ? '文件删除成功: ' + path! : '文件删除失败: ' + path!,
				isError: !ok
			} as ToolResult)
		})
	}
}

/**
 * 目录列表工具
 */
function formatAgentFileTime(lastModified: number): string {
	const date = new Date(lastModified)
	return date.getFullYear() + '-' + (date.getMonth() + 1) + '-' + date.getDate() + ' ' + date.getHours() + ':' + date.getMinutes()
}

function formatAgentFileInfo(path: string, info: AgentFileInfo): string {
	const typeStr = info.isDirectory ? '目录' : '文件'
	const finalPath = path != '' ? path : info.name
	return '路径: ' + finalPath + '\n名称: ' + info.name + '\n类型: ' + typeStr + '\n大小: ' + info.size + ' bytes\n修改时间: ' + formatAgentFileTime(info.lastModified)
}

function formatAgentFileListLine(info: AgentFileInfo, detail: boolean): string {
	const prefix = info.isDirectory ? '[DIR]  ' : '[FILE] '
	if (detail == true) {
		const typeStr = info.isDirectory ? '目录' : '文件'
		return prefix + info.name + ' | 类型: ' + typeStr + ' | 大小: ' + info.size + ' bytes | 修改时间: ' + formatAgentFileTime(info.lastModified)
	}
	if (info.isDirectory) {
		return prefix + info.name
	}
	return prefix + info.name + ' (' + info.size + ' bytes)'
}

class SandboxFileListTool implements AgentTool {
	name: string = 'file_list'
	description: string = '列出指定目录下的文件和子目录；当 path 指向文件时返回该文件信息。path 为空则列出根目录，detail 为 true 时显示详细信息。'
	parameters: UTSJSONObject = {
		'type': 'object',
		'properties': {
			'path': {
				'type': 'string',
				'description': '要列出的目录或文件路径（相对于智能体私有目录，为空则列出根目录）'
			},
			'detail': {
				'type': 'boolean',
				'description': '是否显示详细信息（类型、大小、修改时间），默认 false'
			}
		},
		'required': [] as string[]
	} as UTSJSONObject

	private agentId: string

	constructor(agentId: string) {
		this.agentId = agentId
	}

	execute(args: UTSJSONObject): Promise<ToolResult> {
		return new Promise<ToolResult>((resolve) => {
			const path = args['path'] as string | null
			const rawDetail = args['detail'] as boolean | null
			const dirPath = (path != null && path!.length > 0) ? path! : ''
			if (dirPath != '') {
				const info = getAgentFileInfo(this.agentId, dirPath)
				if (info == null) {
					resolve({ content: '路径不存在: ' + dirPath, isError: true } as ToolResult)
					return
				}
				if (info!.isDirectory == false) {
					resolve({ content: formatAgentFileInfo(dirPath, info!), isError: false } as ToolResult)
					return
				}
			}
			const detail = rawDetail == true
			const files = listAgentFiles(this.agentId, dirPath)
			if (files.length == 0) {
				resolve({ content: '(目录为空)', isError: false } as ToolResult)
				return
			}
			const lines: string[] = []
			for (let i = 0; i < files.length; i++) {
				lines.push(formatAgentFileListLine(files[i], detail))
			}
			resolve({ content: lines.join('\n'), isError: false } as ToolResult)
		})
	}
}

/**
 * 文件信息工具
 */
class SandboxFileInfoTool implements AgentTool {
	name: string = 'file_info'
	description: string = '获取文件或目录的信息（大小、修改时间、类型）。'
	parameters: UTSJSONObject = {
		'type': 'object',
		'properties': {
			'path': {
				'type': 'string',
				'description': '文件或目录路径（相对于智能体私有目录）'
			}
		},
		'required': ['path']
	} as UTSJSONObject

	private agentId: string

	constructor(agentId: string) {
		this.agentId = agentId
	}

	execute(args: UTSJSONObject): Promise<ToolResult> {
		return new Promise<ToolResult>((resolve) => {
			const path = args['path'] as string | null
			if (path == null || path!.length == 0) {
				resolve({ content: '缺少必要参数: path', isError: true } as ToolResult)
				return
			}
			const info = getAgentFileInfo(this.agentId, path!)
			if (info == null) {
				resolve({ content: '文件不存在: ' + path!, isError: true } as ToolResult)
				return
			}
			resolve({
				content: formatAgentFileInfo(path!, info!),
				isError: false
			} as ToolResult)
		})
	}
}

/**
 * 获取工具定义列表（用于传给 LLM 的 tools 参数）
 * @param agentId 智能体 ID
 * @returns ToolDefinition 数组
 */
export function getToolDefinitions(agentId: string, allowCoreMemoryWrite: boolean = false): ToolDefinition[] {
	const tools = createAgentTools(agentId, '', '', allowCoreMemoryWrite)
	const defs: ToolDefinition[] = []
	for (let i = 0; i < tools.length; i++) {
		defs.push({
			name: tools[i].name,
			description: tools[i].description,
			parameters: tools[i].parameters
		} as ToolDefinition)
	}
	return defs
}

/**
 * 查询记忆与历史工具
 */
class MemorySearchTool implements AgentTool {
	name: string = 'memory_search'
	description: string = '查询 Agent 可见的记忆和历史对话。只返回 user/assistant 普通文本，不包含工具调用参数、工具结果或系统隐私信息。适合在不确定用户背景、偏好、历史要求时使用。'
	parameters: UTSJSONObject = {
		'type': 'object',
		'properties': {
			'query': {
				'type': 'string',
				'description': '要查询的关键词或问题，留空则返回最近相关记忆'
			},
			'limit': {
				'type': 'number',
				'description': '最多返回条数，1-10，默认 8'
			},
			'target_type': {
				'type': 'string',
				'description': '查询面对对象类型：user/agent/custom。默认 user'
			},
			'target_id': {
				'type': 'string',
				'description': '查询面对对象 ID 或名称。user 可留空表示当前用户；agent 填 Agent ID；custom 填对象名称'
			}
		},
		'required': ['query']
	} as UTSJSONObject

	private agentId: string
	private conversationId: string
	private personId: string

	constructor(agentId: string, conversationId: string, personId: string) {
		this.agentId = agentId
		this.conversationId = conversationId
		this.personId = personId
	}

	execute(args: UTSJSONObject): Promise<ToolResult> {
		return new Promise<ToolResult>((resolve) => {
			const rawQuery = args['query'] as string | null
			const rawLimit = args['limit'] as number | null
			const rawTargetType = args['target_type'] as string | null
			const rawTargetId = args['target_id'] as string | null
			const query = rawQuery != null ? rawQuery : ''
			const limit = rawLimit != null ? rawLimit : 8
			const targetPersonId = buildMemoryTargetPersonId(rawTargetType != null ? rawTargetType : 'user', rawTargetId != null ? rawTargetId : this.personId)
			const core = searchCoreMemory(this.agentId, targetPersonId, this.conversationId, query, limit)
			const history = searchConversationHistory(this.agentId, query, limit)
			resolve({ content: core + '\n\n' + history, isError: false } as ToolResult)
		})
	}
}

/**
 * 写入 128 字短记忆缓存工具
 */
class MemoryBufferWriteTool implements AgentTool {
	name: string = 'memory_buffer_write'
	description: string = '写入短记忆缓存。缓存最多 128 字，会临时拼到后续用户消息后，适合保存当前阶段目标/称呼/临时约束。不要写工具调用信息、密钥、完整日志。'
	parameters: UTSJSONObject = {
		'type': 'object',
		'properties': {
			'content': {
				'type': 'string',
				'description': '缓存内容，必须简短，最多 128 字'
			}
		},
		'required': ['content']
	} as UTSJSONObject

	private agentId: string
	private conversationId: string
	private personId: string

	constructor(agentId: string, conversationId: string, personId: string) {
		this.agentId = agentId
		this.conversationId = conversationId
		this.personId = personId
	}

	execute(args: UTSJSONObject): Promise<ToolResult> {
		return new Promise<ToolResult>((resolve) => {
			const rawContent = args['content'] as string | null
			if (rawContent == null || rawContent == '') {
				resolve({ content: '缺少必要参数: content', isError: true } as ToolResult)
				return
			}
			const finalContent = updateMemoryBuffer(this.agentId, this.personId, this.conversationId, rawContent)
			resolve({ content: '短记忆缓存已更新（' + finalContent.length + '/128）：' + finalContent, isError: false } as ToolResult)
		})
	}
}

/**
 * 保存重要信息工具
 */
class MemoryCoreSaveTool implements AgentTool {
	name: string = 'memory_core_save'
	description: string = '保存 Agent 重要信息。scope 只能是 always、person_only、conversation_only、manual_only、rule；category 只能是 impression、important、rule、preference、fact。用于长期偏好、重要事实、面对某人的规则，不要保存工具调用信息、密钥或流水账。'
	parameters: UTSJSONObject = {
		'type': 'object',
		'properties': {
			'content': {
				'type': 'string',
				'description': '记忆内容，建议一句话，最多约 240 字'
			},
			'scope': {
				'type': 'string',
				'description': '使用范围：always/person_only/conversation_only/manual_only/rule'
			},
			'category': {
				'type': 'string',
				'description': '分类：impression/important/rule/preference/fact'
			},
			'priority': {
				'type': 'number',
				'description': '优先级 1-5，越高越重要，默认 3'
			},
			'pinned': {
				'type': 'boolean',
				'description': '是否置顶，默认 false'
			},
			'target_type': {
				'type': 'string',
				'description': 'person_only 面对对象类型：user/agent/custom。默认 user'
			},
			'target_id': {
				'type': 'string',
				'description': 'person_only 面对对象 ID 或名称。user 可留空表示当前用户；agent 填 Agent ID；custom 填对象名称'
			}
		},
		'required': ['content', 'scope', 'category']
	} as UTSJSONObject

	private agentId: string
	private conversationId: string
	private personId: string

	constructor(agentId: string, conversationId: string, personId: string) {
		this.agentId = agentId
		this.conversationId = conversationId
		this.personId = personId
	}

	execute(args: UTSJSONObject): Promise<ToolResult> {
		return new Promise<ToolResult>((resolve) => {
			const rawContent = args['content'] as string | null
			if (rawContent == null || rawContent == '') {
				resolve({ content: '缺少必要参数: content', isError: true } as ToolResult)
				return
			}
			const rawScope = args['scope'] as string | null
			const rawCategory = args['category'] as string | null
			const rawPriority = args['priority'] as number | null
			const rawPinned = args['pinned'] as boolean | null
			const rawTargetType = args['target_type'] as string | null
			const rawTargetId = args['target_id'] as string | null
			const scope = rawScope != null ? rawScope : 'manual_only'
			let targetPersonId = this.personId
			if (scope == 'person_only' || scope == 'manual_only') {
				targetPersonId = buildMemoryTargetPersonId(rawTargetType != null ? rawTargetType : 'user', rawTargetId != null ? rawTargetId : this.personId)
			}
			const input: MemoryCoreInput = {
				scope: scope,
				category: rawCategory != null ? rawCategory : 'important',
				content: rawContent,
				priority: rawPriority != null ? rawPriority : 3,
				pinned: rawPinned == true,
			} as MemoryCoreInput
			const id = saveCoreMemory(this.agentId, targetPersonId, this.conversationId, input)
			if (id == '') {
				resolve({ content: '记忆为空，未保存。', isError: true } as ToolResult)
				return
			}
			resolve({ content: '重要记忆已保存：' + id, isError: false } as ToolResult)
		})
	}
}

/**
 * 列出重要信息工具
 */
class MemoryCoreListTool implements AgentTool {
	name: string = 'memory_core_list'
	description: string = '列出当前 Agent 可见的重要信息库条目，供确认和整理使用。长期写入或遗忘只由记忆管理 Agent 执行。'
	parameters: UTSJSONObject = {
		'type': 'object',
		'properties': {
			'include_manual': {
				'type': 'boolean',
				'description': '是否包含 manual_only，默认 true'
			},
			'target_type': {
				'type': 'string',
				'description': '面对对象类型：user/agent/custom。默认 user'
			},
			'target_id': {
				'type': 'string',
				'description': '面对对象 ID 或名称。user 可留空表示当前用户；agent 填 Agent ID；custom 填对象名称'
			}
		},
		'required': [] as string[]
	} as UTSJSONObject

	private agentId: string
	private conversationId: string
	private personId: string

	constructor(agentId: string, conversationId: string, personId: string) {
		this.agentId = agentId
		this.conversationId = conversationId
		this.personId = personId
	}

	execute(args: UTSJSONObject): Promise<ToolResult> {
		return new Promise<ToolResult>((resolve) => {
			const rawInclude = args['include_manual'] as boolean | null
			const rawTargetType = args['target_type'] as string | null
			const rawTargetId = args['target_id'] as string | null
			const includeManual = rawInclude != null ? rawInclude : true
			const targetPersonId = buildMemoryTargetPersonId(rawTargetType != null ? rawTargetType : 'user', rawTargetId != null ? rawTargetId : this.personId)
			const rows = listCoreMemory(this.agentId, targetPersonId, this.conversationId, includeManual)
			resolve({ content: formatCoreMemoryList(rows), isError: false } as ToolResult)
		})
	}
}

/**
 * 遗忘重要信息工具
 */
class MemoryCoreForgetTool implements AgentTool {
	name: string = 'memory_core_forget'
	description: string = '按 id 归档/遗忘一条重要记忆。只能遗忘 memory_core_list 或 memory_search 返回的记忆 id。'
	parameters: UTSJSONObject = {
		'type': 'object',
		'properties': {
			'id': {
				'type': 'string',
				'description': '要遗忘的记忆 id'
			}
		},
		'required': ['id']
	} as UTSJSONObject

	execute(args: UTSJSONObject): Promise<ToolResult> {
		return new Promise<ToolResult>((resolve) => {
			const id = args['id'] as string | null
			if (id == null || id == '') {
				resolve({ content: '缺少必要参数: id', isError: true } as ToolResult)
				return
			}
			const ok = archiveCoreMemory(id)
			resolve({ content: ok ? '已遗忘记忆：' + id : '遗忘失败：' + id, isError: !ok } as ToolResult)
		})
	}
}
