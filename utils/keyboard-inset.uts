/**
 * 计算页面需要手动补偿的键盘高度。
 * 部分设备会先缩小 windowHeight，部分设备完全不缩小，因此只补系统未处理的差额。
 */
export function resolveKeyboardInset(keyboardHeight: number, baselineWindowHeight: number, currentWindowHeight: number): number {
	let safeKeyboardHeight = keyboardHeight
	if (safeKeyboardHeight < 0) {
		safeKeyboardHeight = 0
	}
	if (safeKeyboardHeight == 0 || baselineWindowHeight <= 0 || currentWindowHeight <= 0) {
		return safeKeyboardHeight
	}
	let resizedHeight = baselineWindowHeight - currentWindowHeight
	if (resizedHeight <= 0) {
		return safeKeyboardHeight
	}
	if (resizedHeight >= safeKeyboardHeight) {
		return 0
	}
	return safeKeyboardHeight - resizedHeight
}

/**
 * 根据底部控件的真实布局位置计算遮挡量。
 * layoutBottomWithoutInset 需要把当前已应用的 inset 加回去，避免重复测量时振荡。
 */
export function resolveKeyboardInsetFromLayout(keyboardHeight: number, baselineWindowHeight: number, layoutBottomWithoutInset: number): number {
	let safeKeyboardHeight = keyboardHeight
	if (safeKeyboardHeight < 0) { safeKeyboardHeight = 0 }
	if (safeKeyboardHeight == 0) { return 0 }
	if (baselineWindowHeight <= 0 || layoutBottomWithoutInset <= 0) { return safeKeyboardHeight }
	const keyboardTop = baselineWindowHeight - safeKeyboardHeight
	let occludedHeight = layoutBottomWithoutInset - keyboardTop
	if (occludedHeight <= 0) { return 0 }
	if (occludedHeight > safeKeyboardHeight) { occludedHeight = safeKeyboardHeight }
	return occludedHeight
}
