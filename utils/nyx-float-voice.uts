/**
 * 眠汐全局悬浮入口。
 * 语音识别结果通过 App 内事件投递，位置走 runtime_state，不使用 uni.storage。
 */

import { eventBus } from '@/utils/event-bus.uts'
import { setNyxFloatVoiceText, consumeNyxFloatVoiceText, setNyxFloatVoiceContext, getNyxFloatVoiceContext, clearNyxFloatVoiceContext } from '@/utils/runtime-state.uts'

export const NYX_FLOAT_VOICE_EVENT = 'nyx_float_voice_ready'
export const NYX_FLOAT_CONTEXT_CHAT = 'chat'
export const NYX_FLOAT_CONTEXT_GROUP = 'group'

export function publishNyxFloatVoiceText(text: string): boolean {
	const content = text.trim()
	if (content == '') { return false }
	if (setNyxFloatVoiceText(content) == false) { return false }
	eventBus.emit(NYX_FLOAT_VOICE_EVENT)
	return true
}

export function consumePendingNyxFloatVoiceText(): string {
	return consumeNyxFloatVoiceText()
}

export function activateNyxFloatVoiceContext(context: string): boolean {
	return setNyxFloatVoiceContext(context)
}

export function readNyxFloatVoiceContext(): string {
	return getNyxFloatVoiceContext()
}

export function deactivateNyxFloatVoiceContext(context: string): boolean {
	return clearNyxFloatVoiceContext(context)
}
