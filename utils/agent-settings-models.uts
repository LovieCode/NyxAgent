/**
 * 私聊设置页模型与生成参数辅助。
 *
 * 页面只处理交互；模型标签、面板选择和参数格式化放这里，别把 uvue 写成配置计算器。
 */

import { getDefaultTaskModel, getProviderModels, type ModelInfo } from '@/uni_modules/agent-core/utssdk/provider.uts'
import { type GenerationSettings } from '@/utils/generation-settings.uts'

export type AgentSettingsModelSelection = {
	providerId: string
	modelId: string
}

export function buildEnabledAgentProviders(providers: UTSJSONObject[]): UTSJSONObject[] {
	const list: UTSJSONObject[] = []
	for (let i = 0; i < providers.length; i++) {
		const enabled = providers[i]['enabled'] as number | null
		if (enabled == 1) {
			list.push(providers[i])
		}
	}
	return list
}

export function buildAgentSettingsToolRows(tools: UTSJSONObject[], columns: number): UTSJSONObject[][] {
	const rows: UTSJSONObject[][] = []
	const safeColumns = columns > 0 ? columns : 2
	let current: UTSJSONObject[] = []
	for (let i = 0; i < tools.length; i++) {
		current.push(tools[i])
		if (current.length == safeColumns) {
			rows.push(current)
			current = []
		}
	}
	if (current.length > 0) {
		rows.push(current)
	}
	return rows
}

function readProviderId(provider: UTSJSONObject): string {
	const raw = provider['id'] as string | null
	return raw != null ? raw : ''
}

function readProviderName(provider: UTSJSONObject): string {
	const raw = provider['name'] as string | null
	return raw != null ? raw : ''
}

function readDefaultChatProviderId(): string {
	const config = getDefaultTaskModel('chat')
	if (config == null) { return '' }
	const raw = config['providerId'] as string | null
	return raw != null ? raw : ''
}

function providerContainsModel(providerId: string, modelId: string): boolean {
	if (providerId == '' || modelId == '') { return false }
	const models = getProviderModels(providerId)
	for (let i = 0; i < models.length; i++) {
		if (models[i].id == modelId) { return true }
	}
	return false
}

export function buildAgentCurrentModelLabel(currentModel: string, providers: UTSJSONObject[]): string {
	if (currentModel == '') { return '跟随默认对话模型' }
	const sep = '||'
	const idx = currentModel.indexOf(sep)
	if (idx >= 0) {
		const providerId = currentModel.substring(0, idx)
		const modelId = currentModel.substring(idx + sep.length)
		for (let i = 0; i < providers.length; i++) {
			if (readProviderId(providers[i]) == providerId) {
				return readProviderName(providers[i]) + ' / ' + modelId
			}
		}
		if (providerId == '') {
			return '（默认提供商） / ' + modelId
		}
		return providerId + ' / ' + modelId
	}
	const defaultProviderId = readDefaultChatProviderId()
	if (defaultProviderId != '') {
		for (let i = 0; i < providers.length; i++) {
			if (readProviderId(providers[i]) == defaultProviderId) {
				const configuredSuffix = providerContainsModel(defaultProviderId, currentModel) ? '' : '（未配置）'
				return readProviderName(providers[i]) + ' / ' + currentModel + configuredSuffix
			}
		}
		return defaultProviderId + ' / ' + currentModel + '（提供商不存在）'
	}
	return currentModel + '（未关联默认提供商）'
}

export function resolveAgentModelSelection(currentModel: string, enabledProviders: UTSJSONObject[]): AgentSettingsModelSelection {
	if (currentModel == '') {
		return {
			providerId: '',
			modelId: '',
		} as AgentSettingsModelSelection
	}
	const sep = '||'
	const idx = currentModel.indexOf(sep)
	if (idx >= 0) {
		return {
			providerId: currentModel.substring(0, idx),
			modelId: currentModel.substring(idx + sep.length),
		} as AgentSettingsModelSelection
	}
	const defaultProviderId = readDefaultChatProviderId()
	let providerId = ''
	for (let i = 0; i < enabledProviders.length; i++) {
		if (readProviderId(enabledProviders[i]) == defaultProviderId) {
			providerId = defaultProviderId
			break
		}
	}
	return {
		providerId: providerId,
		modelId: currentModel,
	} as AgentSettingsModelSelection
}

export function readAgentProviderModels(providerId: string): ModelInfo[] {
	if (providerId == '') { return [] }
	return getProviderModels(providerId)
}

export function clampAgentSettingNumber(value: number, min: number, max: number): number {
	if (value < min) { return min }
	if (value > max) { return max }
	return value
}

export function parseAgentFloatSetting(value: string, fallback: number, min: number, max: number): number {
	const parsed = parseFloat(value)
	if (isNaN(parsed)) {
		return fallback
	}
	return clampAgentSettingNumber(parsed, min, max)
}

export function parseAgentIntSetting(value: string, fallback: number, min: number, max: number): number {
	const parsed = parseInt(value)
	if (isNaN(parsed)) {
		return fallback
	}
	return clampAgentSettingNumber(parsed, min, max)
}

export function buildAgentGenerationHint(settings: GenerationSettings): string {
	const iterationText = settings.maxIterations == 0 ? '不限制' : (settings.maxIterations + '')
	const streamText = settings.streamEnabled == true ? '流式' : '非流式'
	return '温度 ' + settings.temperature + ' · 输出 ' + settings.maxTokens + ' · 迭代 ' + iterationText + ' · ' + streamText
}

export type AgentSettingsGenerationForm = {
	useGlobalGeneration: boolean
	temperatureStr: string
	maxTokensStr: string
	maxIterationsStr: string
	streamEnabled: boolean
	truncateThresholdStr: string
	truncateDropCountStr: string
	cacheEnabled: boolean
	hideThinking: boolean
	injectDatetime: boolean
	msgSegmentation: boolean
	globalGenerationHint: string
}

export type AgentSettingsGenerationSaveState = {
	temperature: number | null
	maxTokens: number | null
	maxIterations: number | null
	streamEnabled: boolean | null
	temperatureStr: string
	maxTokensStr: string
	maxIterationsStr: string
	truncateThreshold: number
	truncateDropCount: number
}

export function readAgentGenerationForm(agent: UTSJSONObject, global: GenerationSettings): AgentSettingsGenerationForm {
	const rawTemperature = agent['temperature'] as number | null
	const rawMaxTokens = agent['maxTokens'] as number | null
	const rawMaxIterations = agent['maxIterations'] as number | null
	const rawStreamEnabled = agent['streamEnabled'] as boolean | null
	const hasOverride = rawTemperature != null || rawMaxTokens != null || rawMaxIterations != null || rawStreamEnabled != null
	const rawThreshold = agent['truncateThreshold'] as number | null
	const rawDropCount = agent['truncateDropCount'] as number | null
	const rawCacheEnabled = agent['cacheEnabled'] as boolean | null
	const rawHideThinking = agent['hideThinking'] as boolean | null
	const rawInjectDatetime = agent['injectDatetime'] as boolean | null
	const rawMsgSeg = agent['msgSegmentation'] as boolean | null
	return {
		useGlobalGeneration: hasOverride == false,
		temperatureStr: (rawTemperature != null ? rawTemperature : global.temperature) + '',
		maxTokensStr: (rawMaxTokens != null ? rawMaxTokens : global.maxTokens) + '',
		maxIterationsStr: (rawMaxIterations != null ? rawMaxIterations : global.maxIterations) + '',
		streamEnabled: rawStreamEnabled != null ? rawStreamEnabled : global.streamEnabled,
		truncateThresholdStr: (rawThreshold != null ? rawThreshold : 40) + '',
		truncateDropCountStr: (rawDropCount != null ? rawDropCount : 20) + '',
		cacheEnabled: rawCacheEnabled != false,
		hideThinking: rawHideThinking == true,
		injectDatetime: rawInjectDatetime != false,
		msgSegmentation: rawMsgSeg != null ? rawMsgSeg : true,
		globalGenerationHint: buildAgentGenerationHint(global),
	} as AgentSettingsGenerationForm
}

export function buildAgentGenerationSaveState(useGlobalGeneration: boolean, temperatureText: string, maxTokensText: string, maxIterationsText: string, streamEnabledValue: boolean, truncateThresholdText: string, truncateDropCountText: string, global: GenerationSettings): AgentSettingsGenerationSaveState {
	let temperature: number | null = null
	let maxTokens: number | null = null
	let maxIterations: number | null = null
	let streamEnabled: boolean | null = null
	let normalizedTemperature = temperatureText
	let normalizedMaxTokens = maxTokensText
	let normalizedMaxIterations = maxIterationsText
	if (useGlobalGeneration == false) {
		const parsedTemperature = parseAgentFloatSetting(temperatureText, global.temperature, 0, 2)
		const parsedMaxTokens = parseAgentIntSetting(maxTokensText, global.maxTokens, 256, 65536)
		const parsedMaxIterations = parseAgentIntSetting(maxIterationsText, global.maxIterations, 0, 100)
		temperature = parsedTemperature
		maxTokens = parsedMaxTokens
		maxIterations = parsedMaxIterations
		streamEnabled = streamEnabledValue
		normalizedTemperature = parsedTemperature + ''
		normalizedMaxTokens = parsedMaxTokens + ''
		normalizedMaxIterations = parsedMaxIterations + ''
	}
	const threshold = parseFloat(truncateThresholdText)
	const dropScore = parseFloat(truncateDropCountText)
	return {
		temperature: temperature,
		maxTokens: maxTokens,
		maxIterations: maxIterations,
		streamEnabled: streamEnabled,
		temperatureStr: normalizedTemperature,
		maxTokensStr: normalizedMaxTokens,
		maxIterationsStr: normalizedMaxIterations,
		truncateThreshold: isNaN(threshold) ? 40 : threshold,
		truncateDropCount: isNaN(dropScore) ? 20 : dropScore,
	} as AgentSettingsGenerationSaveState
}
