export function readCreateTemplateKey(tpl: UTSJSONObject): string {
	const value = tpl['key'] as string | null
	return value != null ? value : ''
}

export function readCreateTemplateIcon(tpl: UTSJSONObject): string {
	const value = tpl['icon'] as string | null
	return value != null ? value : DEFAULT_AGENT_CREATE_ICON
}

export function readCreateTemplateName(tpl: UTSJSONObject): string {
	const value = tpl['name'] as string | null
	return value != null ? value : '模板'
}

export function readCreateTemplateDesc(tpl: UTSJSONObject): string {
	const value = tpl['desc'] as string | null
	return value != null ? value : ''
}

export function readCreateTemplatePrompt(tpl: UTSJSONObject): string {
	const value = tpl['prompt'] as string | null
	return value != null ? value : ''
}

export function readFirstRunProviderName(item: UTSJSONObject): string {
	const value = item['name'] as string | null
	return value != null ? value : ''
}

export function readFirstRunProviderDesc(item: UTSJSONObject): string {
	const value = item['desc'] as string | null
	return value != null ? value : ''
}

export function readFirstRunProviderId(item: UTSJSONObject): string {
	const value = item['id'] as string | null
	return value != null ? value : 'custom'
}

export function readFirstRunProviderDisplayName(item: UTSJSONObject): string {
	const value = item['name'] as string | null
	return value != null && value != '' ? value : '自定义'
}

export function firstRunProviderOptionAt(index: number): UTSJSONObject {
	if (index >= 0 && index < FIRST_RUN_PROVIDER_OPTIONS.length) {
		return FIRST_RUN_PROVIDER_OPTIONS[index]
	}
	return FIRST_RUN_PROVIDER_OPTIONS[0]
}

export function buildFirstRunProviderPreset(option: UTSJSONObject): UTSJSONObject {
	const apiBase = option['baseUrl'] as string | null
	const model = option['model'] as string | null
	return {
		id: readFirstRunProviderId(option),
		name: readFirstRunProviderDisplayName(option),
		apiBase: apiBase != null ? apiBase : '',
		model: model != null ? model : '',
	} as UTSJSONObject
}
