/**
 * 待办 / 笔记知识文件夹
 *
 * 逻辑目录：
 * - user/default/todo.md
 * - user/default/notes/<noteId>.md
 * - agents/<agentId>/todo.md
 * - agents/<agentId>/notes/<noteId>.md
 *
 * 底层先使用 uni.storage 做跨平台持久化，对 Agent 暴露为受限文件夹。
 */

export const KNOWLEDGE_WORKSPACE_KEY = 'knowledge_workspace_records'
export const KNOWLEDGE_MIGRATED_KEY = 'knowledge_workspace_migrated'

const OWNER_USER = 'user'
const OWNER_AGENT = 'agent'
const DEFAULT_USER_ID = 'default'
const KIND_TODO = 'todo'
const KIND_NOTE = 'note'

const MAX_NOTE_CONTENT_LENGTH = 60000
const MAX_TODOS_PER_OWNER = 300
const MAX_NOTES_PER_OWNER = 300

export type KnowledgeRenderBlock = {
	type: string
	text: string
	checked: boolean
	level: number
}

function padZero(n: number): string {
	if (n < 10) {
		return '0' + n
	}
	return '' + n
}

function nowText(): string {
	const now = new Date()
	return now.getFullYear() + '-' +
		padZero(now.getMonth() + 1) + '-' +
		padZero(now.getDate()) + ' ' +
		padZero(now.getHours()) + ':' +
		padZero(now.getMinutes())
}

function createKnowledgeId(prefix: string): string {
	return prefix + '_' + Date.now() + '_' + Math.floor(Math.random() * 100000)
}

function normalizeLineEndings(text: string): string {
	let result = text.replace(/\r\n/g, '\n')
	result = result.replace(/\r/g, '\n')
	return result
}

function truncateText(text: string, maxLength: number): string {
	if (text.length <= maxLength) {
		return text
	}
	return text.substring(0, maxLength)
}

function readString(obj: UTSJSONObject, key: string): string {
	const raw = obj[key] as string | null
	return raw != null ? raw : ''
}

function readBoolean(obj: UTSJSONObject, key: string, fallback: boolean): boolean {
	const raw = obj[key] as boolean | null
	return raw != null ? raw : fallback
}

function normalizeOwnerType(ownerType: string): string {
	if (ownerType == OWNER_AGENT) {
		return OWNER_AGENT
	}
	return OWNER_USER
}

function normalizeOwnerId(ownerType: string, ownerId: string): string {
	if (ownerType == OWNER_USER) {
		return DEFAULT_USER_ID
	}
	if (ownerId.trim() == '') {
		return 'unknown'
	}
	return ownerId.trim()
}

function normalizePriority(priority: string): string {
	if (priority == 'high' || priority == 'medium' || priority == 'low') {
		return priority
	}
	return 'medium'
}

function normalizeKind(kind: string): string {
	if (kind == KIND_NOTE) {
		return KIND_NOTE
	}
	return KIND_TODO
}

function normalizeRecord(raw: UTSJSONObject): UTSJSONObject {
	const rawKind = normalizeKind(readString(raw, 'kind'))
	const ownerType = normalizeOwnerType(readString(raw, 'ownerType'))
	const ownerId = normalizeOwnerId(ownerType, readString(raw, 'ownerId'))
	const now = nowText()
	const idPrefix = rawKind == KIND_NOTE ? 'note' : 'todo'
	const rawId = readString(raw, 'id')
	const title = readString(raw, 'title').trim()
	const content = normalizeLineEndings(readString(raw, 'content'))
	return {
		id: rawId != '' ? rawId : createKnowledgeId(idPrefix),
		ownerType: ownerType,
		ownerId: ownerId,
		kind: rawKind,
		title: title != '' ? title : (rawKind == KIND_NOTE ? '无标题' : '未命名待办'),
		content: truncateText(content, MAX_NOTE_CONTENT_LENGTH),
		priority: normalizePriority(readString(raw, 'priority')),
		completed: readBoolean(raw, 'completed', false),
		createdAt: readString(raw, 'createdAt') != '' ? readString(raw, 'createdAt') : now,
		updatedAt: readString(raw, 'updatedAt') != '' ? readString(raw, 'updatedAt') : now,
	} as UTSJSONObject
}

function readRawRecords(): UTSJSONObject[] {
	const raw = uni.getStorageSync(KNOWLEDGE_WORKSPACE_KEY) as string | null
	if (raw == null || raw == '') {
		return []
	}
	try {
		const parsed = JSON.parse(raw) as UTSJSONObject[]
		const result: UTSJSONObject[] = []
		for (let i = 0; i < parsed.length; i++) {
			result.push(normalizeRecord(parsed[i]))
		}
		return result
	} catch (_e: any) {
		return []
	}
}

function isSameOwner(record: UTSJSONObject, ownerType: string, ownerId: string): boolean {
	return readString(record, 'ownerType') == ownerType && readString(record, 'ownerId') == ownerId
}

function syncLegacyUserStorage(records: UTSJSONObject[]): void {
	const todos: UTSJSONObject[] = []
	const notes: UTSJSONObject[] = []
	for (let i = 0; i < records.length; i++) {
		const record = records[i]
		if (!isSameOwner(record, OWNER_USER, DEFAULT_USER_ID)) {
			continue
		}
		const kind = readString(record, 'kind')
		if (kind == KIND_TODO) {
			todos.push({
				id: readString(record, 'id'),
				title: readString(record, 'title'),
				priority: normalizePriority(readString(record, 'priority')),
				completed: readBoolean(record, 'completed', false),
				createdAt: readString(record, 'createdAt'),
			} as UTSJSONObject)
		} else if (kind == KIND_NOTE) {
			notes.push({
				id: readString(record, 'id'),
				title: readString(record, 'title'),
				content: readString(record, 'content'),
				updatedAt: readString(record, 'updatedAt'),
			} as UTSJSONObject)
		}
	}
	uni.setStorageSync('todo_list', JSON.stringify(todos))
	uni.setStorageSync('notes_list', JSON.stringify(notes))
}


function saveRawRecords(records: UTSJSONObject[]): void {
	uni.setStorageSync(KNOWLEDGE_WORKSPACE_KEY, JSON.stringify(records))
	syncLegacyUserStorage(records)
}

function hasOwnerKind(records: UTSJSONObject[], ownerType: string, ownerId: string, kind: string): boolean {
	for (let i = 0; i < records.length; i++) {
		if (isSameOwner(records[i], ownerType, ownerId) && readString(records[i], 'kind') == kind) {
			return true
		}
	}
	return false
}

function readLegacyArray(key: string): UTSJSONObject[] {
	const raw = uni.getStorageSync(key) as string | null
	if (raw == null || raw == '') {
		return []
	}
	try {
		return JSON.parse(raw) as UTSJSONObject[]
	} catch (_e: any) {
		return []
	}
}

function migrateLegacyTodos(records: UTSJSONObject[]): void {
	if (hasOwnerKind(records, OWNER_USER, DEFAULT_USER_ID, KIND_TODO)) {
		return
	}
	const todos = readLegacyArray('todo_list')
	for (let i = 0; i < todos.length; i++) {
		const item = todos[i]
		const now = nowText()
		records.push(normalizeRecord({
			id: readString(item, 'id') != '' ? readString(item, 'id') : createKnowledgeId('todo'),
			ownerType: OWNER_USER,
			ownerId: DEFAULT_USER_ID,
			kind: KIND_TODO,
			title: readString(item, 'title'),
			content: '',
			priority: readString(item, 'priority'),
			completed: readBoolean(item, 'completed', false),
			createdAt: readString(item, 'createdAt') != '' ? readString(item, 'createdAt') : now,
			updatedAt: readString(item, 'updatedAt') != '' ? readString(item, 'updatedAt') : now,
		} as UTSJSONObject))
	}
}

function migrateLegacyNotes(records: UTSJSONObject[]): void {
	if (hasOwnerKind(records, OWNER_USER, DEFAULT_USER_ID, KIND_NOTE)) {
		return
	}
	const notes = readLegacyArray('notes_list')
	for (let i = 0; i < notes.length; i++) {
		const item = notes[i]
		const now = nowText()
		records.push(normalizeRecord({
			id: readString(item, 'id') != '' ? readString(item, 'id') : createKnowledgeId('note'),
			ownerType: OWNER_USER,
			ownerId: DEFAULT_USER_ID,
			kind: KIND_NOTE,
			title: readString(item, 'title'),
			content: readString(item, 'content'),
			priority: 'medium',
			completed: false,
			createdAt: readString(item, 'updatedAt') != '' ? readString(item, 'updatedAt') : now,
			updatedAt: readString(item, 'updatedAt') != '' ? readString(item, 'updatedAt') : now,
		} as UTSJSONObject))
	}
}

export function migrateLegacyKnowledgeWorkspace(): void {
	const migrated = uni.getStorageSync(KNOWLEDGE_MIGRATED_KEY) as string | null
	if (migrated == 'true') {
		return
	}
	const records = readRawRecords()
	migrateLegacyTodos(records)
	migrateLegacyNotes(records)
	saveRawRecords(records)
	uni.setStorageSync(KNOWLEDGE_MIGRATED_KEY, 'true')
}

export function getKnowledgeWorkspaceRecords(): UTSJSONObject[] {
	migrateLegacyKnowledgeWorkspace()
	return readRawRecords()
}

export function saveKnowledgeWorkspaceRecords(records: UTSJSONObject[]): void {
	const result: UTSJSONObject[] = []
	for (let i = 0; i < records.length; i++) {
		result.push(normalizeRecord(records[i]))
	}
	saveRawRecords(result)
	uni.setStorageSync(KNOWLEDGE_MIGRATED_KEY, 'true')
}

function getOwnerRecords(ownerTypeValue: string, ownerIdValue: string, kind: string): UTSJSONObject[] {
	const ownerType = normalizeOwnerType(ownerTypeValue)
	const ownerId = normalizeOwnerId(ownerType, ownerIdValue)
	const records = getKnowledgeWorkspaceRecords()
	const result: UTSJSONObject[] = []
	for (let i = 0; i < records.length; i++) {
		if (isSameOwner(records[i], ownerType, ownerId) && readString(records[i], 'kind') == kind) {
			result.push(records[i])
		}
	}
	return result
}

function replaceOwnerRecords(ownerTypeValue: string, ownerIdValue: string, kind: string, items: UTSJSONObject[]): void {
	const ownerType = normalizeOwnerType(ownerTypeValue)
	const ownerId = normalizeOwnerId(ownerType, ownerIdValue)
	const records = getKnowledgeWorkspaceRecords()
	const next: UTSJSONObject[] = []
	for (let i = 0; i < records.length; i++) {
		if (!(isSameOwner(records[i], ownerType, ownerId) && readString(records[i], 'kind') == kind)) {
			next.push(records[i])
		}
	}
	const maxCount = kind == KIND_NOTE ? MAX_NOTES_PER_OWNER : MAX_TODOS_PER_OWNER
	for (let i = 0; i < items.length && i < maxCount; i++) {
		const raw = items[i]
		raw['ownerType'] = ownerType
		raw['ownerId'] = ownerId
		raw['kind'] = kind
		next.push(normalizeRecord(raw))
	}
	saveKnowledgeWorkspaceRecords(next)
}

export function getWorkspaceTodos(ownerType: string, ownerId: string): UTSJSONObject[] {
	return getOwnerRecords(ownerType, ownerId, KIND_TODO)
}

export function saveWorkspaceTodos(ownerType: string, ownerId: string, todos: UTSJSONObject[]): void {
	replaceOwnerRecords(ownerType, ownerId, KIND_TODO, todos)
}

export function getWorkspaceNotes(ownerType: string, ownerId: string): UTSJSONObject[] {
	return getOwnerRecords(ownerType, ownerId, KIND_NOTE)
}

export function saveWorkspaceNotes(ownerType: string, ownerId: string, notes: UTSJSONObject[]): void {
	replaceOwnerRecords(ownerType, ownerId, KIND_NOTE, notes)
}

function ownerPath(ownerType: string, ownerId: string): string {
	if (ownerType == OWNER_USER) {
		return 'user/default'
	}
	return 'agents/' + ownerId
}

function cleanMarkdownLine(text: string): string {
	let result = normalizeLineEndings(text)
	result = result.replace(/\n/g, ' ')
	return result.trim()
}

export function buildTodoMarkdown(ownerType: string, ownerId: string, todos: UTSJSONObject[]): string {
	const lines: string[] = []
	lines.push('---')
	lines.push('type: todo-list')
	lines.push('owner: ' + ownerPath(ownerType, ownerId))
	lines.push('updatedAt: ' + nowText())
	lines.push('---')
	lines.push('')
	lines.push('# Todo')
	lines.push('')
	for (let i = 0; i < todos.length; i++) {
		const item = todos[i]
		const completed = readBoolean(item, 'completed', false)
		const box = completed ? '[x]' : '[ ]'
		const priority = normalizePriority(readString(item, 'priority'))
		const title = cleanMarkdownLine(readString(item, 'title'))
		const id = readString(item, 'id')
		const createdAt = readString(item, 'createdAt')
		const updatedAt = readString(item, 'updatedAt')
		lines.push('- ' + box + ' (' + priority + ') ' + title + ' <!-- id:' + id + ' createdAt:' + createdAt + ' updatedAt:' + updatedAt + ' -->')
	}
	return lines.join('\n')
}

export function buildNoteMarkdown(ownerType: string, ownerId: string, note: UTSJSONObject): string {
	const title = cleanMarkdownLine(readString(note, 'title'))
	const lines: string[] = []
	lines.push('---')
	lines.push('type: note')
	lines.push('owner: ' + ownerPath(ownerType, ownerId))
	lines.push('id: ' + readString(note, 'id'))
	lines.push('title: ' + title)
	lines.push('updatedAt: ' + readString(note, 'updatedAt'))
	lines.push('---')
	lines.push('')
	lines.push('# ' + title)
	lines.push('')
	lines.push(normalizeLineEndings(readString(note, 'content')))
	return lines.join('\n')
}

function parseFrontmatterValue(line: string): string {
	const index = line.indexOf(':')
	if (index <= 0) {
		return ''
	}
	let value = line.substring(index + 1).trim()
	if (value.startsWith('"') && value.endsWith('"') && value.length >= 2) {
		value = value.substring(1, value.length - 1)
	}
	if (value.startsWith("'") && value.endsWith("'") && value.length >= 2) {
		value = value.substring(1, value.length - 1)
	}
	return value
}

function stripFrontmatter(markdown: string): UTSJSONObject {
	const normalized = normalizeLineEndings(markdown)
	const meta: UTSJSONObject = {}
	let body = normalized
	if (normalized.startsWith('---')) {
		const endIndex = normalized.indexOf('\n---', 3)
		if (endIndex > 0) {
			const metaText = normalized.substring(3, endIndex).trim()
			body = normalized.substring(endIndex + 4)
			const lines = metaText.split('\n')
			for (let i = 0; i < lines.length; i++) {
				const line = lines[i]
				const sep = line.indexOf(':')
				if (sep > 0) {
					meta[line.substring(0, sep).trim()] = parseFrontmatterValue(line)
				}
			}
		}
	}
	return {
		meta: meta,
		body: body.trim(),
	} as UTSJSONObject
}

function readCommentField(line: string, field: string): string {
	const marker = field + ':'
	const index = line.indexOf(marker)
	if (index < 0) {
		return ''
	}
	let end = line.indexOf(' ', index + marker.length)
	const commentEnd = line.indexOf('-->', index + marker.length)
	if (commentEnd >= 0 && (end < 0 || commentEnd < end)) {
		end = commentEnd
	}
	if (end < 0) {
		end = line.length
	}
	return line.substring(index + marker.length, end).trim()
}

function stripHtmlComment(line: string): string {
	const start = line.indexOf('<!--')
	if (start < 0) {
		return line
	}
	return line.substring(0, start).trim()
}

export function parseTodoMarkdown(ownerType: string, ownerId: string, markdown: string): UTSJSONObject[] {
	const parsed = stripFrontmatter(markdown)
	const body = readString(parsed, 'body')
	const lines = normalizeLineEndings(body).split('\n')
	const result: UTSJSONObject[] = []
	for (let i = 0; i < lines.length && result.length < MAX_TODOS_PER_OWNER; i++) {
		const line = lines[i].trim()
		if (!(line.startsWith('- [ ]') || line.startsWith('- [x]') || line.startsWith('- [X]'))) {
			continue
		}
		const completed = line.startsWith('- [x]') || line.startsWith('- [X]')
		let rest = stripHtmlComment(line.substring(5).trim())
		let priority = 'medium'
		if (rest.startsWith('(high)')) {
			priority = 'high'
			rest = rest.substring(6).trim()
		} else if (rest.startsWith('(medium)')) {
			priority = 'medium'
			rest = rest.substring(8).trim()
		} else if (rest.startsWith('(low)')) {
			priority = 'low'
			rest = rest.substring(5).trim()
		}
		if (rest == '') {
			continue
		}
		const id = readCommentField(line, 'id')
		const createdAt = readCommentField(line, 'createdAt')
		const updatedAt = readCommentField(line, 'updatedAt')
		const now = nowText()
		result.push(normalizeRecord({
			id: id != '' ? id : createKnowledgeId('todo'),
			ownerType: ownerType,
			ownerId: ownerId,
			kind: KIND_TODO,
			title: rest,
			content: '',
			priority: priority,
			completed: completed,
			createdAt: createdAt != '' ? createdAt : now,
			updatedAt: updatedAt != '' ? updatedAt : now,
		} as UTSJSONObject))
	}
	return result
}

function removeFirstHeading(body: string): UTSJSONObject {
	const lines = normalizeLineEndings(body).split('\n')
	const remain: string[] = []
	let title = ''
	let removed = false
	for (let i = 0; i < lines.length; i++) {
		const line = lines[i]
		if (removed == false && line.trim().startsWith('# ')) {
			title = line.trim().substring(2).trim()
			removed = true
			continue
		}
		remain.push(line)
	}
	return {
		title: title,
		content: remain.join('\n').trim(),
	} as UTSJSONObject
}

export function parseNoteMarkdown(ownerType: string, ownerId: string, noteId: string, markdown: string): UTSJSONObject {
	const parsed = stripFrontmatter(markdown)
	const meta = parsed['meta'] as UTSJSONObject | null
	const body = readString(parsed, 'body')
	const withoutHeading = removeFirstHeading(body)
	let title = meta != null ? readString(meta, 'title') : ''
	if (title == '') {
		title = readString(withoutHeading, 'title')
	}
	if (title == '') {
		title = noteId != '' ? noteId : '无标题'
	}
	let id = meta != null ? readString(meta, 'id') : ''
	if (id == '') {
		id = noteId != '' ? noteId : createKnowledgeId('note')
	}
	const updatedAt = meta != null ? readString(meta, 'updatedAt') : ''
	const now = nowText()
	return normalizeRecord({
		id: id,
		ownerType: ownerType,
		ownerId: ownerId,
		kind: KIND_NOTE,
		title: title,
		content: readString(withoutHeading, 'content'),
		priority: 'medium',
		completed: false,
		createdAt: updatedAt != '' ? updatedAt : now,
		updatedAt: now,
	} as UTSJSONObject)
}

export function renderKnowledgeMarkdown(markdown: string): KnowledgeRenderBlock[] {
	const parsed = stripFrontmatter(markdown)
	const body = readString(parsed, 'body')
	const lines = normalizeLineEndings(body).split('\n')
	const blocks: KnowledgeRenderBlock[] = []
	for (let i = 0; i < lines.length; i++) {
		const rawLine = lines[i]
		const line = rawLine.trim()
		if (line == '') {
			continue
		}
		if (line.startsWith('### ')) {
			blocks.push({ type: 'heading', text: line.substring(4).trim(), checked: false, level: 3 } as KnowledgeRenderBlock)
		} else if (line.startsWith('## ')) {
			blocks.push({ type: 'heading', text: line.substring(3).trim(), checked: false, level: 2 } as KnowledgeRenderBlock)
		} else if (line.startsWith('# ')) {
			blocks.push({ type: 'heading', text: line.substring(2).trim(), checked: false, level: 1 } as KnowledgeRenderBlock)
		} else if (line.startsWith('- [ ]') || line.startsWith('- [x]') || line.startsWith('- [X]')) {
			const checked = line.startsWith('- [x]') || line.startsWith('- [X]')
			blocks.push({ type: 'todo', text: stripHtmlComment(line.substring(5).trim()), checked: checked, level: 0 } as KnowledgeRenderBlock)
		} else if (line.startsWith('- ')) {
			blocks.push({ type: 'bullet', text: line.substring(2).trim(), checked: false, level: 0 } as KnowledgeRenderBlock)
		} else {
			blocks.push({ type: 'paragraph', text: line, checked: false, level: 0 } as KnowledgeRenderBlock)
		}
	}
	return blocks
}

export function countInlineTodos(markdown: string): number {
	const blocks = renderKnowledgeMarkdown(markdown)
	let count = 0
	for (let i = 0; i < blocks.length; i++) {
		if (blocks[i].type == 'todo') {
			count++
		}
	}
	return count
}

function normalizePath(path: string): string {
	let result = path.trim().replace(/\\/g, '/')
	while (result.startsWith('/')) {
		result = result.substring(1)
	}
	while (result.endsWith('/') && result.length > 1) {
		result = result.substring(0, result.length - 1)
	}
	while (result.indexOf('//') >= 0) {
		result = result.replace(/\/\//g, '/')
	}
	if (result == '.') {
		return ''
	}
	return result
}

function isSafeKnowledgePath(path: string): boolean {
	if (path.indexOf('\\') >= 0) {
		return false
	}
	const parts = path.split('/')
	for (let i = 0; i < parts.length; i++) {
		if (parts[i] == '..') {
			return false
		}
	}
	return true
}

function parseKnowledgePath(agentId: string, rawPath: string): UTSJSONObject {
	const path = normalizePath(rawPath)
	if (!isSafeKnowledgePath(path)) {
		return { ok: false, error: '路径不允许包含 .. 或反斜杠' } as UTSJSONObject
	}
	if (path == '') {
		return { ok: true, scope: 'root', ownerType: '', ownerId: '', rest: '', path: path } as UTSJSONObject
	}
	if (path == 'user') {
		return { ok: true, scope: 'user-root', ownerType: '', ownerId: '', rest: '', path: path } as UTSJSONObject
	}
	if (path == 'user/default') {
		return { ok: true, scope: 'owner', ownerType: OWNER_USER, ownerId: DEFAULT_USER_ID, rest: '', path: path } as UTSJSONObject
	}
	if (path.startsWith('user/default/')) {
		return { ok: true, scope: 'owner', ownerType: OWNER_USER, ownerId: DEFAULT_USER_ID, rest: path.substring(13), path: path } as UTSJSONObject
	}
	if (path == 'agents') {
		return { ok: true, scope: 'agents-root', ownerType: '', ownerId: '', rest: '', path: path } as UTSJSONObject
	}
	const ownRoot = 'agents/' + agentId
	if (path == ownRoot) {
		return { ok: true, scope: 'owner', ownerType: OWNER_AGENT, ownerId: agentId, rest: '', path: path } as UTSJSONObject
	}
	if (path.startsWith(ownRoot + '/')) {
		return { ok: true, scope: 'owner', ownerType: OWNER_AGENT, ownerId: agentId, rest: path.substring(ownRoot.length + 1), path: path } as UTSJSONObject
	}
	return { ok: false, error: '无权限访问该路径。只能访问 user/default 或 agents/' + agentId } as UTSJSONObject
}

function findNoteById(notes: UTSJSONObject[], id: string): UTSJSONObject | null {
	for (let i = 0; i < notes.length; i++) {
		if (readString(notes[i], 'id') == id) {
			return notes[i]
		}
	}
	return null
}

function fileIdFromNotePath(rest: string): string {
	let name = rest
	if (name.startsWith('notes/')) {
		name = name.substring(6)
	}
	if (name.endsWith('.md')) {
		name = name.substring(0, name.length - 3)
	}
	return name.trim()
}

function formatNoteListLine(note: UTSJSONObject): string {
	return '[FILE] ' + readString(note, 'id') + '.md | ' + readString(note, 'title') + ' | updatedAt: ' + readString(note, 'updatedAt')
}

export function buildKnowledgeWorkspaceGuide(agentId: string): string {
	return [
		'知识文件夹访问范围：',
		'- agents/' + agentId + '/notes/<id>.md：你的私有笔记（★优先使用）',
		'- agents/' + agentId + '/todo.md：你的私有待办',
		'- user/default/notes/<id>.md：用户共享笔记',
		'- user/default/todo.md：用户共享待办',
		'规则：新笔记默认写入 agents/' + agentId + '/notes/',
		'渲染规则：',
		'- #/##/### 渲染为标题',
		'- - [ ] 文本 渲染为未完成待办',
		'- - [x] 文本 渲染为已完成待办',
		'- - 文本 渲染为普通列表',
		'- 其他非空行渲染为段落',
	].join('\n')
}

export function listKnowledgeWorkspacePaths(agentId: string, rawPath: string): string {
	const parsed = parseKnowledgePath(agentId, rawPath)
	const ok = parsed['ok'] as boolean | null
	if (ok != true) {
		return readString(parsed, 'error')
	}
	const scope = readString(parsed, 'scope')
	if (scope == 'root') {
		return '[DIR] user/\n[DIR] agents/\n\n' + buildKnowledgeWorkspaceGuide(agentId)
	}
	if (scope == 'user-root') {
		return '[DIR] default/'
	}
	if (scope == 'agents-root') {
		return '[DIR] ' + agentId + '/'
	}
	const ownerType = readString(parsed, 'ownerType')
	const ownerId = readString(parsed, 'ownerId')
	const rest = readString(parsed, 'rest')
	if (rest == '') {
		return '[FILE] todo.md\n[DIR] notes/'
	}
	if (rest == 'notes') {
		const notes = getWorkspaceNotes(ownerType, ownerId)
		if (notes.length == 0) {
			return '(notes 为空)'
		}
		const lines: string[] = []
		for (let i = 0; i < notes.length; i++) {
			lines.push(formatNoteListLine(notes[i]))
		}
		return lines.join('\n')
	}
	if (rest == 'todo.md') {
		const todos = getWorkspaceTodos(ownerType, ownerId)
		return '[FILE] todo.md | todos: ' + todos.length
	}
	if (rest.startsWith('notes/')) {
		const id = fileIdFromNotePath(rest)
		const note = findNoteById(getWorkspaceNotes(ownerType, ownerId), id)
		if (note == null) {
			return '路径不存在: ' + readString(parsed, 'path')
		}
		return formatNoteListLine(note)
	}
	return '路径不存在: ' + readString(parsed, 'path')
}

export function readKnowledgeWorkspaceFile(agentId: string, rawPath: string): string | null {
	const parsed = parseKnowledgePath(agentId, rawPath)
	const ok = parsed['ok'] as boolean | null
	if (ok != true) {
		return null
	}
	const ownerType = readString(parsed, 'ownerType')
	const ownerId = readString(parsed, 'ownerId')
	const rest = readString(parsed, 'rest')
	if (rest == '') {
		return listKnowledgeWorkspacePaths(agentId, rawPath)
	}
	if (rest == 'todo.md') {
		return buildTodoMarkdown(ownerType, ownerId, getWorkspaceTodos(ownerType, ownerId))
	}
	if (rest == 'notes') {
		return listKnowledgeWorkspacePaths(agentId, rawPath)
	}
	if (rest.startsWith('notes/')) {
		const id = fileIdFromNotePath(rest)
		const note = findNoteById(getWorkspaceNotes(ownerType, ownerId), id)
		if (note == null) {
			return null
		}
		return buildNoteMarkdown(ownerType, ownerId, note)
	}
	return null
}

function upsertNote(ownerType: string, ownerId: string, note: UTSJSONObject): void {
	const notes = getWorkspaceNotes(ownerType, ownerId)
	const id = readString(note, 'id')
	let found = false
	for (let i = 0; i < notes.length; i++) {
		if (readString(notes[i], 'id') == id && id != '') {
			notes[i] = note
			found = true
			break
		}
	}
	if (found == false) {
		notes.unshift(note)
	}
	saveWorkspaceNotes(ownerType, ownerId, notes)
}

export function writeKnowledgeWorkspaceFile(agentId: string, rawPath: string, content: string): boolean {
	const parsed = parseKnowledgePath(agentId, rawPath)
	const ok = parsed['ok'] as boolean | null
	if (ok != true) {
		return false
	}
	const ownerType = readString(parsed, 'ownerType')
	const ownerId = readString(parsed, 'ownerId')
	const rest = readString(parsed, 'rest')
	if (rest == 'todo.md') {
		const todos = parseTodoMarkdown(ownerType, ownerId, content)
		saveWorkspaceTodos(ownerType, ownerId, todos)
		return true
	}
	if (rest.startsWith('notes/')) {
		const noteId = fileIdFromNotePath(rest)
		const note = parseNoteMarkdown(ownerType, ownerId, noteId, content)
		upsertNote(ownerType, ownerId, note)
		return true
	}
	return false
}
