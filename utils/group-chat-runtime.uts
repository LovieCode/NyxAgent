/**
 * 群聊运行时通用工具。
 *
 * 只放无副作用的展示、Agent 字段读取和可见性判断，避免 service/scheduler 互相依赖。
 */

import { CHAT_PART_PLAIN } from '@/utils/chat-models.uts'
import {
	DEFAULT_SCHEDULER_PROMPT_TEXT,
	DEFAULT_SHARED_PROMPT_TEXT,
	GROUP_DELIVERY_MODE_PUBLIC,
	GROUP_DELIVERY_MODE_USER_PRIVATE,
	GROUP_MESSAGE_AUDIENCE_AGENT,
	GROUP_MESSAGE_AUDIENCE_USER,
	GROUP_MESSAGE_SENDER_USER,
	GROUP_MESSAGE_VISIBILITY_PRIVATE,
	GROUP_MESSAGE_VISIBILITY_PUBLIC,
	LEGACY_DIRECTIVE_SCHEDULER_PROMPT_TEXT,
	LEGACY_ENVIRONMENT_SCHEDULER_PROMPT_TEXT,
	LEGACY_GENERIC_SHARED_PROMPT_TEXT,
	LEGACY_NATURAL_ROUTING_SCHEDULER_PROMPT_TEXT,
	LEGACY_STORY_SHARED_PROMPT_TEXT,
	PREVIOUS_DEFAULT_SCHEDULER_PROMPT_TEXT,
	PREVIOUS_DEFAULT_SHARED_PROMPT_TEXT,
	isInternalGroupSenderType,
	isInternalGroupVisibility,
	type GroupChat,
	type GroupChatSession,
} from '@/utils/group-chat-models.uts'

export function buildDefaultSchedulerPrompt(): string {
	return DEFAULT_SCHEDULER_PROMPT_TEXT
}

export function getGroupSchedulerPrompt(group: GroupChat): string {
	const text = group.schedulerPrompt.trim()
	if (text == LEGACY_DIRECTIVE_SCHEDULER_PROMPT_TEXT || text == LEGACY_ENVIRONMENT_SCHEDULER_PROMPT_TEXT || text == LEGACY_NATURAL_ROUTING_SCHEDULER_PROMPT_TEXT || text == PREVIOUS_DEFAULT_SCHEDULER_PROMPT_TEXT) {
		return buildDefaultSchedulerPrompt()
	}
	if (text != '') { return text }
	return buildDefaultSchedulerPrompt()
}

export function buildDefaultSharedPrompt(): string {
	return DEFAULT_SHARED_PROMPT_TEXT
}

export function getGroupSharedPrompt(group: GroupChat): string {
	const text = group.sharedPrompt.trim()
	if (text == LEGACY_GENERIC_SHARED_PROMPT_TEXT || text == LEGACY_STORY_SHARED_PROMPT_TEXT || text == PREVIOUS_DEFAULT_SHARED_PROMPT_TEXT) {
		return buildDefaultSharedPrompt()
	}
	if (text != '') { return text }
	return buildDefaultSharedPrompt()
}

export function displaySessionTitle(session: GroupChatSession | null): string {
	if (session == null) { return '未命名会话' }
	const title = session.title.trim()
	if (title != '') { return title }
	return '未命名会话'
}

export function readActionText(action: UTSJSONObject, key: string): string {
	const raw = action[key] as string | null
	return raw != null ? raw : ''
}

export function resolveGroupDeliveryMode(action: UTSJSONObject): string {
	const deliveryMode = readActionText(action, 'deliveryMode')
	const targetType = readActionText(action, 'targetType')
	if (deliveryMode == GROUP_DELIVERY_MODE_USER_PRIVATE && targetType == 'user') {
		return GROUP_DELIVERY_MODE_USER_PRIVATE
	}
	return GROUP_DELIVERY_MODE_PUBLIC
}

export function readAgentName(agent: UTSJSONObject | null): string {
	if (agent == null) { return 'Agent' }
	const raw = agent['name'] as string | null
	return raw != null && raw != '' ? raw : 'Agent'
}

export function readAgentAvatar(agent: UTSJSONObject | null): string {
	if (agent == null) { return '' }
	const raw = agent['avatar'] as string | null
	return raw != null ? raw : ''
}

export function readAgentModel(agent: UTSJSONObject | null): string {
	if (agent == null) { return '' }
	const raw = agent['model'] as string | null
	return raw != null ? raw : ''
}

export function readAgentSystemPrompt(agent: UTSJSONObject | null): string {
	if (agent == null) { return '' }
	const raw = agent['systemPrompt'] as string | null
	return raw != null ? raw : ''
}

export function readAgentInteractionRules(agent: UTSJSONObject | null): string {
	if (agent == null) { return '' }
	const raw = agent['interactionRules'] as string | null
	return raw != null ? raw : ''
}

export function readAgentHideThinking(agent: UTSJSONObject | null): boolean {
	if (agent == null) { return false }
	const raw = agent['hideThinking'] as boolean | null
	return raw == true
}

export function readAgentInjectDatetime(agent: UTSJSONObject | null): boolean {
	if (agent == null) { return true }
	const raw = agent['injectDatetime'] as boolean | null
	return raw != null ? raw : true
}

export function readAgentMsgSegmentation(agent: UTSJSONObject | null): boolean {
	if (agent == null) { return true }
	const raw = agent['msgSegmentation'] as boolean | null
	return raw != null ? raw : true
}

function stripLeadingSpaces(text: string): string {
	let index = 0
	while (index < text.length) {
		const ch = text.charAt(index)
		if (ch == ' ' || ch == '\n' || ch == '\r' || ch == '\t') {
			index++
		} else {
			break
		}
	}
	return index > 0 ? text.substring(index) : text
}

export function stripGroupAgentSpeakerPrefix(text: string, agentName: string): string {
	const name = agentName.trim()
	if (name == '' || text == '') { return text }
	const body = stripLeadingSpaces(text)
	const cnPrefix = name + '：'
	const enPrefix = name + ':'
	let stripped = body
	if (body.startsWith(cnPrefix)) {
		stripped = body.substring(cnPrefix.length)
	} else if (body.startsWith(enPrefix)) {
		stripped = body.substring(enPrefix.length)
	} else {
		return text
	}
	return stripLeadingSpaces(stripped)
}

export function stripGroupAgentSpeakerPrefixFromParts(parts: UTSJSONObject[], agentName: string): void {
	for (let i = 0; i < parts.length; i++) {
		const part = parts[i]
		const type = part['type'] as string | null
		if (type == CHAT_PART_PLAIN) {
			const raw = part['text'] as string | null
			if (raw != null && raw != '') {
				part['text'] = stripGroupAgentSpeakerPrefix(raw, agentName)
			}
			return
		}
	}
}

export function getPublicGroupMessages(messages: UTSJSONObject[]): UTSJSONObject[] {
	const result: UTSJSONObject[] = []
	for (let i = 0; i < messages.length; i++) {
		const senderType = messages[i]['senderType'] as string | null
		if (isInternalGroupSenderType(senderType) == true) { continue }
		const visible = messages[i]['visible'] as boolean | null
		const visibility = messages[i]['visibility'] as string | null
		if (visible != false && (visibility == null || visibility == '' || visibility == GROUP_MESSAGE_VISIBILITY_PUBLIC)) {
			result.push(messages[i])
		}
	}
	return result
}

/** 兼容旧调用：未指定观察者时只允许公开消息，避免内部消费者误读私发正文。 */
export function getVisibleGroupMessages(messages: UTSJSONObject[]): UTSJSONObject[] {
	return getPublicGroupMessages(messages)
}

export function isGroupMessageVisibleToUser(msg: UTSJSONObject): boolean {
	const senderType = msg['senderType'] as string | null
	if (isInternalGroupSenderType(senderType) == true) { return false }
	const visible = msg['visible'] as boolean | null
	if (visible == false) { return false }
	const visibility = msg['visibility'] as string | null
	if (visibility == null || visibility == '' || visibility == GROUP_MESSAGE_VISIBILITY_PUBLIC) {
		return true
	}
	const audience = msg['audience'] as string | null
	if (visibility == GROUP_MESSAGE_VISIBILITY_PRIVATE && audience == GROUP_MESSAGE_AUDIENCE_USER) {
		return true
	}
	// 用户始终可以看到自己发出的群内私聊，目标 Agent 由 visibleAgentIds 单独控制。
	return visibility == GROUP_MESSAGE_VISIBILITY_PRIVATE
		&& audience == GROUP_MESSAGE_AUDIENCE_AGENT
		&& senderType == GROUP_MESSAGE_SENDER_USER
}

export function getGroupMessagesVisibleToUser(messages: UTSJSONObject[]): UTSJSONObject[] {
	const result: UTSJSONObject[] = []
	for (let i = 0; i < messages.length; i++) {
		if (isGroupMessageVisibleToUser(messages[i]) == true) { result.push(messages[i]) }
	}
	return result
}

export function getGroupMessagesVisibleToAgent(messages: UTSJSONObject[], agentId: string): UTSJSONObject[] {
	const result: UTSJSONObject[] = []
	for (let i = 0; i < messages.length; i++) {
		const msg = messages[i]
		const senderType = msg['senderType'] as string | null
		if (isInternalGroupSenderType(senderType) == true) { continue }
		const visible = msg['visible'] as boolean | null
		if (visible == false) { continue }
		const visibility = msg['visibility'] as string | null
		if (isInternalGroupVisibility(visibility) == true) { continue }
		if (visibility == null || visibility == '' || visibility == GROUP_MESSAGE_VISIBILITY_PUBLIC) {
			result.push(msg)
		} else {
			const senderAgentId = msg['senderAgentId'] as string | null
			const targetIds = msg['visibleAgentIds'] as string[] | null
			if (agentId != '' && senderAgentId == agentId) {
				result.push(msg)
			} else if (targetIds != null) {
				for (let ti = 0; ti < targetIds.length; ti++) {
					if (targetIds[ti] == agentId) {
						result.push(msg)
						break
					}
				}
			}
		}
	}
	return result
}
