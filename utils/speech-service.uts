/**
 * 语音服务层。
 *
 * 顶层只保留 STT/TTS 入口；Provider 配置、缓存写入和 TTS engine 拆到独立模块。
 */

import {
	type SpeechAudioResult,
	type SpeechTextResult,
	buildAudioApiUrl,
	buildSpeechCacheDir,
	failAudio,
	failText,
	okText,
	readTranscriptionText,
	resolveSpeechConfig,
} from '@/utils/speech-runtime.uts'
import { synthesizeSpeechWithConfig } from '@/utils/speech-tts.uts'
export * from '@/utils/speech-runtime.uts'

export function transcribeAudio(audioPath: string): Promise<SpeechTextResult> {
	return new Promise<SpeechTextResult>((resolve) => {
		if (audioPath == '') {
			resolve(failText('录音文件为空'))
			return
		}
		const config = resolveSpeechConfig('stt')
		if (config == null) {
			resolve(failText('请先在设置中配置语音识别模型'))
			return
		}
		const url = buildAudioApiUrl(config.baseUrl, '/audio/transcriptions')
		// PROVIDER_AUDIO_API: OpenAI-compatible multipart 字段，部分 provider 可能要求 language/response_format。
		uni.uploadFile({
			url: url,
			filePath: audioPath,
			name: 'file',
			formData: {
				model: config.model,
			} as UTSJSONObject,
			header: {
				Authorization: 'Bearer ' + config.apiKey,
			} as UTSJSONObject,
			success: (res) => {
				const statusCode = res.statusCode as number
				if (statusCode < 200 || statusCode >= 300) {
					resolve(failText('语音识别失败：HTTP ' + statusCode))
					return
				}
				const text = readTranscriptionText(res.data)
				if (text == '') {
					resolve(failText('语音识别结果为空'))
					return
				}
				resolve(okText(text))
			},
			fail: (err: any) => {
				resolve(failText('语音识别网络失败：' + err))
			},
		})
	})
}

export function synthesizeSpeech(text: string, agentId: string = ''): Promise<SpeechAudioResult> {
	return new Promise<SpeechAudioResult>((resolve) => {
		const content = text.trim()
		if (content == '') {
			resolve(failAudio('朗读文本为空'))
			return
		}
		const config = resolveSpeechConfig('tts', agentId)
		if (config == null) {
			resolve(failAudio('请先在设置中配置语音合成模型'))
			return
		}
		const dir = buildSpeechCacheDir()
		if (dir == '') {
			resolve(failAudio('语音缓存目录不可用'))
			return
		}
		synthesizeSpeechWithConfig(content, config, dir).then((result) => {
			resolve(result)
		})
	})
}
