/**
 * 待办/笔记页面展示辅助。
 *
 * 页面负责文件读写和交互；过滤、排序、时间格式和预览渲染放这里。
 */

import { deleteRuntimeState, getAppSetting, getRuntimeState, setRuntimeState } from '@/utils/database.uts'
import { renderKnowledgeMarkdown, countInlineTodos, type KnowledgeRenderBlock } from '@/utils/markdown.uts'

export type NoteEditorState = {
	noteId: string
	title: string
	content: string
	agentId: string
	agentName: string
}

function readCurrentUserDisplayName(): string {
	const raw = getAppSetting('profile_nickname')
	const name = raw != null ? raw.trim() : ''
	return name != '' ? name : '我'
}

function readTodoPriorityScore(priority: string): number {
	if (priority == 'high') { return 3 }
	if (priority == 'medium') { return 2 }
	return 1
}

function cloneKnowledgeItems(items: UTSJSONObject[]): UTSJSONObject[] {
	const list: UTSJSONObject[] = []
	for (let i = 0; i < items.length; i++) {
		list.push(items[i])
	}
	return list
}

export function buildFilteredTodoList(todos: UTSJSONObject[], filter: string): UTSJSONObject[] {
	const list: UTSJSONObject[] = []
	for (let i = 0; i < todos.length; i++) {
		const todo = todos[i]
		const completed = todo['completed'] as boolean | null
		if (filter == 'pending' && completed == true) { continue }
		if (filter == 'done' && completed != true) { continue }
		list.push(todo)
	}
	list.sort((a: UTSJSONObject, b: UTSJSONObject): number => {
		const aDoneRaw = a['completed'] as boolean | null
		const bDoneRaw = b['completed'] as boolean | null
		const aDone = aDoneRaw == true
		const bDone = bDoneRaw == true
		if (aDone != bDone) {
			return aDone ? 1 : -1
		}
		const aPriorityRaw = a['priority'] as string | null
		const bPriorityRaw = b['priority'] as string | null
		const aScore = readTodoPriorityScore(aPriorityRaw != null ? aPriorityRaw : '')
		const bScore = readTodoPriorityScore(bPriorityRaw != null ? bPriorityRaw : '')
		if (aScore != bScore) {
			return bScore - aScore
		}
		const aTimeRaw = a['createdAt'] as string | null
		const bTimeRaw = b['createdAt'] as string | null
		const aTime = aTimeRaw != null ? aTimeRaw : ''
		const bTime = bTimeRaw != null ? bTimeRaw : ''
		if (aTime > bTime) { return -1 }
		if (aTime < bTime) { return 1 }
		return 0
	})
	return list
}

export function buildFilteredNoteList(notes: UTSJSONObject[], searchQuery: string): UTSJSONObject[] {
	const query = searchQuery.trim().toLowerCase()
	if (query == '') { return cloneKnowledgeItems(notes) }
	const result: UTSJSONObject[] = []
	for (let i = 0; i < notes.length; i++) {
		const note = notes[i]
		const titleRaw = note['title'] as string | null
		const contentRaw = note['content'] as string | null
		const title = titleRaw != null ? titleRaw.toLowerCase() : ''
		const content = contentRaw != null ? contentRaw.toLowerCase() : ''
		if (title.indexOf(query) >= 0 || content.indexOf(query) >= 0) {
			result.push(note)
		}
	}
	return result
}

export function filterKnowledgeItemsByAgent(items: UTSJSONObject[], agentId: string): UTSJSONObject[] {
	const result: UTSJSONObject[] = []
	for (let i = 0; i < items.length; i++) {
		const itemAgentId = items[i]['agentId'] as string | null
		if (itemAgentId == agentId) {
			result.push(items[i])
		}
	}
	return result
}

function padZero(n: number): string {
	if (n < 10) { return '0' + n }
	return '' + n
}

export function formatTodoCreatedAtNow(): string {
	const now = new Date()
	return now.getFullYear() + '-' +
		padZero(now.getMonth() + 1) + '-' +
		padZero(now.getDate()) + ' ' +
		padZero(now.getHours()) + ':' +
		padZero(now.getMinutes()) + ':' +
		padZero(now.getSeconds())
}

export function formatNoteUpdatedAtNow(): string {
	const now = new Date()
	return now.getFullYear() + '-' +
		padZero(now.getMonth() + 1) + '-' +
		padZero(now.getDate()) + ' ' +
		padZero(now.getHours()) + ':' +
		padZero(now.getMinutes())
}

export function formatTodoCreatedAt(value: string): string {
	if (value.length == 16) {
		return value + ':00'
	}
	return value
}

export function buildNotePreviewBlocks(note: UTSJSONObject): KnowledgeRenderBlock[] {
	const content = note['content'] as string | null
	if (content == null || content == '') {
		return [] as KnowledgeRenderBlock[]
	}
	const blocks = renderKnowledgeMarkdown(content)
	const result: KnowledgeRenderBlock[] = []
	for (let i = 0; i < blocks.length && result.length < 4; i++) {
		const block = blocks[i] as KnowledgeRenderBlock
		result.push(block)
	}
	return result
}

export function countNoteInlineTodos(note: UTSJSONObject): number {
	const content = note['content'] as string | null
	if (content == null || content == '') {
		return 0
	}
	return countInlineTodos(content)
}

export function clearNoteEditorRuntimeState(): void {
	deleteRuntimeState('note_editor_id')
	deleteRuntimeState('note_editor_title')
	deleteRuntimeState('note_editor_content')
	deleteRuntimeState('note_editor_agent_id')
	deleteRuntimeState('note_editor_result')
}

export function prepareNoteEditorRuntimeState(noteId: string, title: string, content: string, agentId: string): void {
	clearNoteEditorRuntimeState()
	setRuntimeState('note_editor_id', noteId)
	setRuntimeState('note_editor_title', title)
	setRuntimeState('note_editor_content', content)
	setRuntimeState('note_editor_agent_id', agentId)
}

function readStringFromPayload(payload: UTSJSONObject, key: string): string {
	const value = payload[key] as string | null
	return value != null ? value : ''
}

export function consumeNoteEditorRuntimeState(): NoteEditorState | null {
	const raw = getRuntimeState('note_editor_result')
	if (raw == null || raw == '') { return null }
	deleteRuntimeState('note_editor_result')
	try {
		const payload = JSON.parse(raw) as UTSJSONObject
		const noteId = readStringFromPayload(payload, 'id')
		let title = readStringFromPayload(payload, 'title').trim()
		if (title == '') { title = '无标题' }
		const content = readStringFromPayload(payload, 'content')
		if (content.trim() == '') { return null }
		let agentId = readStringFromPayload(payload, 'agentId')
		if (agentId == '') { agentId = '__user__' }
		let agentName = readStringFromPayload(payload, 'agentName')
		if (agentName == '' || agentName == '用户' || agentName == '我') { agentName = readCurrentUserDisplayName() }
		return {
			noteId: noteId,
			title: title,
			content: content,
			agentId: agentId,
			agentName: agentName,
		} as NoteEditorState
	} catch (_e: any) {
		return null
	}
}

function buildNoteFromEditorState(noteId: string, payload: NoteEditorState, updatedAt: string): UTSJSONObject {
	return {
		id: noteId,
		title: payload.title,
		content: payload.content,
		updatedAt: updatedAt,
		agentId: payload.agentId,
		agentName: payload.agentName,
	} as UTSJSONObject
}

export function applyNoteEditorState(notes: UTSJSONObject[], payload: NoteEditorState, updatedAt: string): UTSJSONObject[] {
	const targetId = payload.noteId
	const next: UTSJSONObject[] = []
	if (targetId == '') {
		next.push(buildNoteFromEditorState('' + Date.now(), payload, updatedAt))
		for (let i = 0; i < notes.length; i++) {
			next.push(notes[i])
		}
		return next
	}
	let updated = false
	for (let i = 0; i < notes.length; i++) {
		const id = notes[i]['id'] as string | null
		if (id == targetId) {
			next.push(buildNoteFromEditorState(targetId, payload, updatedAt))
			updated = true
		} else {
			next.push(notes[i])
		}
	}
	if (updated == false) {
		next.unshift(buildNoteFromEditorState(targetId, payload, updatedAt))
	}
	return next
}

export function readNoteEditorStateFromNote(note: UTSJSONObject): NoteEditorState {
	const noteId = readStringFromPayload(note, 'id')
	const title = readStringFromPayload(note, 'title')
	const content = readStringFromPayload(note, 'content')
	let agentId = readStringFromPayload(note, 'agentId')
	if (agentId == '') { agentId = '__user__' }
	const agentName = readStringFromPayload(note, 'agentName')
	return {
		noteId: noteId,
		title: title,
		content: content,
		agentId: agentId,
		agentName: agentName,
	} as NoteEditorState
}
