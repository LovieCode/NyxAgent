function findDefaultAgent(id: string): UTSJSONObject | null {
	for (let i = 0; i < defaultAgents.length; i++) {
		const itemId = defaultAgents[i]['id'] as string
		if (itemId == id) {
			return defaultAgents[i]
		}
	}
	return null
}

function applyDefaultAgentPromptFallbackInMemory(agents: UTSJSONObject[]): UTSJSONObject[] {
	// LEGACY_COMPAT: 只做内存兜底，不写回，避免读取时复活已删除/已清理数据。
	for (let i = 0; i < agents.length; i++) {
		const agent = agents[i]
		const id = agent['id'] as string | null
		if (id == null || id == '') continue
		const nextAgent = findDefaultAgent(id)
		if (nextAgent == null) continue
		const oldPrompt = legacyDefaultPrompts[id] as string | null
		const currentPrompt = agent['systemPrompt'] as string | null
		if (oldPrompt != null && currentPrompt == oldPrompt) {
			agent['systemPrompt'] = nextAgent['systemPrompt']
			agent['desc'] = nextAgent['desc']
		}
	}
	return agents
}

function hasAgentId(agents: UTSJSONObject[], id: string): boolean {
	for (let i = 0; i < agents.length; i++) {
		const itemId = agents[i]['id'] as string | null
		if (itemId == id) {
			return true
		}
	}
	return false
}

function buildNyxAdminAgent(): UTSJSONObject {
	return {
		id: NYX_ADMIN_AGENT_ID,
		icon: 'robot',
		name: NYX_ADMIN_AGENT_NAME,
		desc: '全局管理员，能帮你管 App，也能当私人助手聊天',
		avatar: NYX_ADMIN_AGENT_AVATAR,
		systemPrompt: NYX_ADMIN_SYSTEM_PROMPT,
		model: 'deepseek-v4-flash',
		cacheEnabled: true,
		injectDatetime: true,
		enabledToolIds: [
			AGENT_TOOL_APP_GUIDE,
			AGENT_TOOL_WORKSPACE_FILE,
			AGENT_TOOL_MEMORY_SEARCH,
			AGENT_TOOL_MEMORY_BUFFER_WRITE,
			AGENT_TOOL_WEB_SEARCH,
			AGENT_TOOL_ASTRBOT_TASK,
		],
		time: '刚刚'
	} as UTSJSONObject
}

function applyAgentDefaultFlagsInMemory(agents: UTSJSONObject[]): UTSJSONObject[] {
	// LEGACY_COMPAT: 旧 agent 缺字段时默认开启，但不写回 agent_list。
	for (let i = 0; i < agents.length; i++) {
		const rawCacheEnabled = agents[i]['cacheEnabled'] as boolean | null
		if (rawCacheEnabled == null) {
			agents[i]['cacheEnabled'] = true
		}
		const rawInjectDatetime = agents[i]['injectDatetime'] as boolean | null
		if (rawInjectDatetime == null) {
			agents[i]['injectDatetime'] = true
		}
	}
	return agents
}

/** 获取所有智能体 */
export function getAgents(): UTSJSONObject[] {
	const stored = getAppSetting('agent_list')
	if (stored != null && stored != '') {
		const list = JSON.parse(stored) as UTSJSONObject[]
		if (list != null) {
			return applyDefaultAgentPromptFallbackInMemory(applyAgentDefaultFlagsInMemory(list))
		}
	}
	// 首次使用，写入默认数据并初始化文件沙箱
	saveAgents(defaultAgents)
	for (let i = 0; i < defaultAgents.length; i++) {
		const id = defaultAgents[i]['id'] as string
		if (id != null && id != '') {
			getAgentDir(id)
		}
	}
	return defaultAgents
}

/** 保存智能体列表 */
export function saveAgents(agents: UTSJSONObject[]): void {
	setAppSetting('agent_list', JSON.stringify(agents))
}

export function ensureNyxAdminAgent(): void {
	const agents = getAgents()
	if (hasAgentId(agents, NYX_ADMIN_AGENT_ID) == true) {
		return
	}
	const nextAgents: UTSJSONObject[] = []
	nextAgents.push(buildNyxAdminAgent())
	for (let i = 0; i < agents.length; i++) {
		nextAgents.push(agents[i])
	}
	saveAgents(nextAgents)
	getAgentDir(NYX_ADMIN_AGENT_ID)
}

/** 根据 id 获取单个智能体 */
export function getAgentById(id: string): UTSJSONObject | null {
	const agents = getAgents()
	for (let i = 0; i < agents.length; i++) {
		if ((agents[i]['id'] as string) == id) {
			return agents[i]
		}
	}
	return null
}

export function agentToolIdListContains(list: string[], toolId: string): boolean {
	for (let i = 0; i < list.length; i++) {
		if (list[i] == toolId) {
			return true
		}
	}
	return false
}

export function isKnownAgentToolId(toolId: string): boolean {
	return agentToolIdListContains(ALL_AGENT_TOOL_IDS, toolId)
}

function appendUniqueAgentToolId(list: string[], toolId: string): void {
	if (toolId == '') {
		return
	}
	if (isKnownAgentToolId(toolId) == false) {
		return
	}
	if (agentToolIdListContains(list, toolId) == true) {
		return
	}
	list.push(toolId)
}

function isAgentToolRuntimeAvailable(toolId: string): boolean {
	if (toolId == AGENT_TOOL_ASTRBOT_TASK) {
		return isAstrBotEnabled()
	}
	return true
}

function appendAvailableAgentToolId(list: string[], toolId: string): void {
	if (isAgentToolRuntimeAvailable(toolId) == false) {
		return
	}
	appendUniqueAgentToolId(list, toolId)
}

function readAgentToolIdArray(value: any | null): string[] {
	const result: string[] = []
	if (value == null) {
		return result
	}
	try {
		const json = JSON.stringify(value)
		if (json.startsWith('[')) {
			const arr = JSON.parse(json) as string[]
			for (let i = 0; i < arr.length; i++) {
				appendUniqueAgentToolId(result, arr[i])
			}
		} else if (json.startsWith('"')) {
			appendUniqueAgentToolId(result, JSON.parse(json) as string)
		}
	} catch (_e: any) {
		// 旧数据异常时按未配置处理
	}
	return result
}

export function getDefaultAgentToolIds(allowCoreMemoryWrite: boolean = false): string[] {
	const result: string[] = [
		AGENT_TOOL_WORKSPACE_FILE,
		AGENT_TOOL_MEMORY_SEARCH,
		AGENT_TOOL_MEMORY_BUFFER_WRITE,
		AGENT_TOOL_WEB_SEARCH,
	]
	if (allowCoreMemoryWrite == false && isAstrBotEnabled() == true) {
		result.push(AGENT_TOOL_ASTRBOT_TASK)
	}
	if (allowCoreMemoryWrite == true) {
		result.push(AGENT_TOOL_MEMORY_CORE_LIST)
		result.push(AGENT_TOOL_MEMORY_CORE_SAVE)
		result.push(AGENT_TOOL_MEMORY_CORE_FORGET)
	}
	return result
}

function getDefaultAgentToolIdsForAgent(agent: UTSJSONObject | null, allowCoreMemoryWrite: boolean): string[] {
	const result = getDefaultAgentToolIds(allowCoreMemoryWrite)
	if (agent != null) {
		const agentId = agent['id'] as string | null
		if (agentId == NYX_ADMIN_AGENT_ID && allowCoreMemoryWrite == false) {
			appendAvailableAgentToolId(result, AGENT_TOOL_APP_GUIDE)
		}
	}
	return result
}

export function filterKnownAgentToolIds(ids: string[]): string[] {
	const result: string[] = []
	for (let i = 0; i < ids.length; i++) {
		appendUniqueAgentToolId(result, ids[i])
	}
	return result
}

function filterAllowedAgentToolIdsForAgent(ids: string[], agent: UTSJSONObject | null, allowCoreMemoryWrite: boolean): string[] {
	const allowed = getDefaultAgentToolIdsForAgent(agent, allowCoreMemoryWrite)
	const result: string[] = []
	for (let i = 0; i < ids.length; i++) {
		const id = ids[i]
		if (agentToolIdListContains(allowed, id) == true && isAgentToolRuntimeAvailable(id) == true) {
			appendUniqueAgentToolId(result, id)
		}
	}
	return result
}

export function getAgentEnabledToolIds(agent: UTSJSONObject | null, allowCoreMemoryWrite: boolean = false): string[] {
	if (agent == null) {
		return getDefaultAgentToolIds(allowCoreMemoryWrite)
	}
	const agentId = agent['id'] as string | null
	const rawValue = agent['enabledToolIds']
	if (rawValue == null) {
		return getDefaultAgentToolIdsForAgent(agent, allowCoreMemoryWrite)
	}
	const result = filterAllowedAgentToolIdsForAgent(readAgentToolIdArray(rawValue), agent, allowCoreMemoryWrite)
	if (agentId == NYX_ADMIN_AGENT_ID && allowCoreMemoryWrite == false) {
		appendAvailableAgentToolId(result, AGENT_TOOL_APP_GUIDE)
	}
	if (allowCoreMemoryWrite == true) {
		appendUniqueAgentToolId(result, AGENT_TOOL_MEMORY_CORE_LIST)
		appendUniqueAgentToolId(result, AGENT_TOOL_MEMORY_CORE_SAVE)
		appendUniqueAgentToolId(result, AGENT_TOOL_MEMORY_CORE_FORGET)
	}
	return result
}

export function isAgentToolEnabled(agent: UTSJSONObject | null, toolId: string, allowCoreMemoryWrite: boolean = false): boolean {
	if (toolId == '') {
		return false
	}
	if (isKnownAgentToolId(toolId) == false) {
		return false
	}
	const enabled = getAgentEnabledToolIds(agent, allowCoreMemoryWrite)
	return agentToolIdListContains(enabled, toolId)
}

/** 更新智能体的名称、描述、头像和系统提示词 */
export function updateAgent(id: string, name: string, desc: string, avatar: string = '', systemPrompt: string = ''): void {
	const agents = getAgents()
	for (let i = 0; i < agents.length; i++) {
		if ((agents[i]['id'] as string) == id) {
			agents[i]['name'] = name
			agents[i]['desc'] = desc
			agents[i]['systemPrompt'] = systemPrompt
			agents[i]['time'] = '刚刚'
			if (avatar != '') {
				agents[i]['avatar'] = avatar
			}
			break
		}
	}
	saveAgents(agents)
}

/** 仅更新智能体系统提示词 */
export function updateAgentSystemPrompt(id: string, systemPrompt: string): void {
	const agents = getAgents()
	for (let i = 0; i < agents.length; i++) {
		if ((agents[i]['id'] as string) == id) {
			agents[i]['systemPrompt'] = systemPrompt
			break
		}
	}
	saveAgents(agents)
}

/** 更新智能体使用的模型 */
export function updateAgentModel(id: string, model: string): void {
	const agents = getAgents()
	for (let i = 0; i < agents.length; i++) {
		if ((agents[i]['id'] as string) == id) {
			agents[i]['model'] = model
			break
		}
	}
	saveAgents(agents)
}

/** 更新智能体生成参数覆盖。 */
export function updateAgentGenerationSettings(id: string, temperature: number | null, maxTokens: number | null, maxIterations: number | null, streamEnabled: boolean | null): void {
	const agents = getAgents()
	for (let i = 0; i < agents.length; i++) {
		if ((agents[i]['id'] as string) == id) {
			agents[i]['temperature'] = temperature
			agents[i]['maxTokens'] = maxTokens
			agents[i]['maxIterations'] = maxIterations
			agents[i]['streamEnabled'] = streamEnabled
			break
		}
	}
	saveAgents(agents)
}

/** 仅更新智能体头像 */
export function updateAgentAvatar(id: string, avatarPath: string): void {
	const agents = getAgents()
	for (let i = 0; i < agents.length; i++) {
		if ((agents[i]['id'] as string) == id) {
			agents[i]['avatar'] = avatarPath
			break
		}
	}
	saveAgents(agents)
}

/** 删除智能体（同时清理文件目录） */
export function deleteAgent(id: string): void {
	if (id == NYX_ADMIN_AGENT_ID) {
		return
	}
	// 清理文件沙箱
	getAgentDir(id) // 确保目录存在
	deleteItem(getAgentDir(id))
	// 移除列表
	const agents = getAgents()
	const newAgents = [] as UTSJSONObject[]
	for (let i = 0; i < agents.length; i++) {
		if ((agents[i]['id'] as string) != id) {
			newAgents.push(agents[i])
		}
	}
	saveAgents(newAgents)
}

/** 更新智能体截断设置 */
export function updateAgentTruncation(id: string, threshold: number, dropScore: number): void {
	const agents = getAgents()
	for (let i = 0; i < agents.length; i++) {
		if ((agents[i]['id'] as string) == id) {
			agents[i]['truncateThreshold'] = threshold
			agents[i]['truncateDropCount'] = dropScore
			break
		}
	}
	saveAgents(agents)
}

/** 更新智能体缓存开关 */
export function updateAgentCache(id: string, enabled: boolean): void {
	const agents = getAgents()
	for (let i = 0; i < agents.length; i++) {
		if ((agents[i]['id'] as string) == id) {
			agents[i]['cacheEnabled'] = enabled
			break
		}
	}
	saveAgents(agents)
}

export function updateAgentHideThinking(id: string, hide: boolean): void {
	const agents = getAgents()
	for (let i = 0; i < agents.length; i++) {
		if ((agents[i]['id'] as string) == id) {
			agents[i]['hideThinking'] = hide
			break
		}
	}
	saveAgents(agents)
}

/** 更新智能体消息分段开关 */
export function updateAgentMsgSegmentation(id: string, enabled: boolean): void {
	const agents = getAgents()
	for (let i = 0; i < agents.length; i++) {
		if ((agents[i]['id'] as string) == id) {
			agents[i]['msgSegmentation'] = enabled
			break
		}
	}
	saveAgents(agents)
}

/** 更新智能体日期时间注入开关 */
export function updateAgentInjectDatetime(id: string, enabled: boolean): void {
	const agents = getAgents()
	for (let i = 0; i < agents.length; i++) {
		if ((agents[i]['id'] as string) == id) {
			agents[i]['injectDatetime'] = enabled
			break
		}
	}
	saveAgents(agents)
}

/** 更新智能体 TTS 覆盖参数；空字符串表示继承默认模型页。 */
export function updateAgentTTSSettings(id: string, voice: string, volume: string, pitch: string): void {
	const agents = getAgents()
	for (let i = 0; i < agents.length; i++) {
		if ((agents[i]['id'] as string) == id) {
			agents[i]['ttsVoice'] = voice.trim()
			agents[i]['ttsVolume'] = volume.trim()
			agents[i]['ttsPitch'] = pitch.trim()
			break
		}
	}
	saveAgents(agents)
}

/** 更新智能体启用的纯文本 Skills */
export function updateAgentSkills(id: string, skillIds: string[]): void {
	const agents = getAgents()
	for (let i = 0; i < agents.length; i++) {
		if ((agents[i]['id'] as string) == id) {
			agents[i]['skillIds'] = skillIds
			break
		}
	}
	saveAgents(agents)
}

/** 更新智能体启用的工具列表；未启用的工具不会注入 LLM 上下文。 */
export function updateAgentTools(id: string, toolIds: string[]): void {
	const agents = getAgents()
	for (let i = 0; i < agents.length; i++) {
		if ((agents[i]['id'] as string) == id) {
			agents[i]['enabledToolIds'] = filterAllowedAgentToolIdsForAgent(toolIds, agents[i], false)
			break
		}
	}
	saveAgents(agents)
}
