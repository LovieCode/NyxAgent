/**
 * 历史页群聊上下文投影服务。
 *
 * 页面只负责交互；群聊上下文快照、旧记录兼容和调度记录删除统一放这里。
 */

import {
	deleteGroupAgentContextRecord,
	deleteGroupMessage,
	displaySessionTitle,
	getGroupAgentContextRecord,
	getGroupChats,
	getGroupMessages,
	getGroupSessions,
	GROUP_MESSAGE_SENDER_REVIEWER,
	GROUP_MESSAGE_SENDER_SCHEDULER,
	listGroupAgentContextRecords,
} from '@/utils/group-chat-service.uts'
import { buildLegacyHistoryContextPreview } from '@/utils/history-page-helpers.uts'

export type HistoryGroupPreviewPayload = {
	previewJson: string
	subtitle: string
}

function trimHistoryPreviewText(text: string): string {
	if (text.length > 50) { return text.substring(0, 50) + '...' }
	return text
}

function getSchedulerInternalLabel(senderType: string | null): string {
	if (senderType == GROUP_MESSAGE_SENDER_REVIEWER) {
		return '群复盘'
	}
	return '群调度'
}

function readSnapshotMessageCount(snapshot: UTSJSONObject | null): number {
	if (snapshot == null) { return 0 }
	const rawCount = snapshot['messageCount'] as number | null
	return rawCount != null ? rawCount : 0
}

function buildGroupContextRecordItem(record: UTSJSONObject, activeAgentId: string): UTSJSONObject | null {
	const recordId = record['id'] as string | null
	if (recordId == null || recordId == '') { return null }
	const groupNameRaw = record['groupName'] as string | null
	const sessionTitleRaw = record['sessionTitle'] as string | null
	const publicIntentRaw = record['publicIntent'] as string | null
	const privateInstructionRaw = record['privateInstruction'] as string | null
	const createdAtRaw = record['createdAt'] as number | null
	const groupName = groupNameRaw != null && groupNameRaw != '' ? groupNameRaw : '群聊'
	const sessionTitle = sessionTitleRaw != null && sessionTitleRaw != '' ? sessionTitleRaw : '会话'
	const publicIntent = publicIntentRaw != null ? publicIntentRaw : ''
	const privateInstruction = privateInstructionRaw != null ? privateInstructionRaw : ''
	let preview = publicIntent != '' ? publicIntent : privateInstruction
	if (preview == '') { preview = '查看该成员在群聊中实际收到的上下文' }
	preview = trimHistoryPreviewText(preview)
	const requestSnapshot = record['requestSnapshot'] as UTSJSONObject | null
	return {
		id: recordId,
		type: 'group_context',
		agent_id: activeAgentId,
		title: groupName + ' / ' + sessionTitle,
		created_at: createdAtRaw != null ? createdAtRaw : 0,
		updated_at: createdAtRaw != null ? createdAtRaw : 0,
		message_count: readSnapshotMessageCount(requestSnapshot),
		preview: preview,
		model: requestSnapshot != null ? '真实请求快照' : '旧上下文记录',
	} as UTSJSONObject
}

function appendGroupContextRecordItems(result: UTSJSONObject[], activeAgentId: string): void {
	if (activeAgentId == '') { return }
	const records = listGroupAgentContextRecords(activeAgentId)
	for (let i = 0; i < records.length; i++) {
		const item = buildGroupContextRecordItem(records[i], activeAgentId)
		if (item != null) { result.push(item) }
	}
}

function appendLegacyGroupContextItems(result: UTSJSONObject[], activeAgentId: string): void {
	if (activeAgentId == '') { return }
	const groups = getGroupChats()
	for (let gi = 0; gi < groups.length; gi++) {
		const group = groups[gi]
		const sessions = getGroupSessions(group.id)
		for (let si = 0; si < sessions.length; si++) {
			const session = sessions[si]
			const messages = getGroupMessages(group.id, session.id)
			for (let mi = 0; mi < messages.length; mi++) {
				const msg = messages[mi]
				const senderAgentId = msg['senderAgentId'] as string | null
				if (senderAgentId != activeAgentId) { continue }
				const visible = msg['visible'] as boolean | null
				if (visible == false) { continue }
				const role = msg['role'] as string | null
				if (role != 'assistant') { continue }
				const contextRecordId = msg['contextRecordId'] as string | null
				if (contextRecordId != null && contextRecordId != '') { continue }
				const messageIdRaw = msg['id'] as string | null
				const timestampRaw = msg['timestamp'] as number | null
				const contentRaw = msg['content'] as string | null
				const contextCount = buildLegacyHistoryContextPreview(messages, mi).length
				const messageId = messageIdRaw != null && messageIdRaw != '' ? messageIdRaw : 'legacy-' + mi.toString()
				let preview = contentRaw != null ? contentRaw : ''
				if (preview == '') { preview = '旧群聊发言记录：无法还原完整私密上下文' }
				preview = trimHistoryPreviewText(preview)
				result.push({
					id: 'legacy:' + group.id + ':' + session.id + ':' + messageId,
					type: 'legacy_group_message',
					agent_id: activeAgentId,
					group_id: group.id,
					group_name: group.name,
					session_id: session.id,
					session_title: session.title,
					message_index: mi,
					title: group.name + ' / ' + session.title,
					created_at: timestampRaw != null ? timestampRaw : session.updatedAt,
					updated_at: timestampRaw != null ? timestampRaw : session.updatedAt,
					message_count: contextCount,
					preview: preview,
					model: '旧群聊记录',
				} as UTSJSONObject)
			}
		}
	}
}

function appendSchedulerContextItems(result: UTSJSONObject[]): void {
	const groups = getGroupChats()
	for (let gi = 0; gi < groups.length; gi++) {
		const group = groups[gi]
		const sessions = getGroupSessions(group.id)
		for (let si = 0; si < sessions.length; si++) {
			const session = sessions[si]
			const messages = getGroupMessages(group.id, session.id)
			for (let mi = 0; mi < messages.length; mi++) {
				const msg = messages[mi]
				const senderType = msg['senderType'] as string | null
				if (senderType != GROUP_MESSAGE_SENDER_SCHEDULER && senderType != GROUP_MESSAGE_SENDER_REVIEWER) { continue }
				const internalLabel = getSchedulerInternalLabel(senderType)
				const messageIdRaw = msg['id'] as string | null
				const messageId = messageIdRaw != null && messageIdRaw != '' ? messageIdRaw : 'index-' + mi.toString()
				const timestampRaw = msg['timestamp'] as number | null
				const contentRaw = msg['content'] as string | null
				const triggerRaw = msg['triggerReason'] as string | null
				const requestSnapshot = msg['requestSnapshot'] as UTSJSONObject | null
				const runtimeMessages = msg['runtimeMessages'] as UTSJSONObject[] | null
				let messageCount = readSnapshotMessageCount(requestSnapshot)
				if (requestSnapshot == null && runtimeMessages != null) {
					messageCount = runtimeMessages.length
				}
				let preview = triggerRaw != null && triggerRaw != '' ? triggerRaw : ''
				if (preview == '') { preview = contentRaw != null ? contentRaw : '' }
				if (preview == '') { preview = '查看' + internalLabel + '隐藏上下文' }
				preview = trimHistoryPreviewText(preview)
				const senderAgentIdRaw = msg['senderAgentId'] as string | null
				result.push({
					id: 'scheduler:' + group.id + ':' + session.id + ':' + messageId,
					type: 'scheduler_context',
					agent_id: senderAgentIdRaw != null && senderAgentIdRaw != '' ? senderAgentIdRaw : '__scheduler__',
					group_id: group.id,
					group_name: group.name,
					session_id: session.id,
					session_title: displaySessionTitle(session),
					message_id: messageId,
					message_index: mi,
					title: group.name + ' / ' + displaySessionTitle(session) + ' / ' + internalLabel,
					created_at: timestampRaw != null ? timestampRaw : session.updatedAt,
					updated_at: timestampRaw != null ? timestampRaw : session.updatedAt,
					message_count: messageCount,
					preview: preview,
					model: requestSnapshot != null ? internalLabel + '真实请求' : internalLabel + '记录',
				} as UTSJSONObject)
			}
		}
	}
}

function sortHistoryByUpdatedAt(result: UTSJSONObject[]): void {
	result.sort((a: UTSJSONObject, b: UTSJSONObject): number => {
		const at = a['updated_at'] as number | null
		const bt = b['updated_at'] as number | null
		const av = at != null ? at : 0
		const bv = bt != null ? bt : 0
		if (av == bv) { return 0 }
		return av > bv ? -1 : 1
	})
}

export function buildGroupHistoryContextItems(activeAgentId: string): UTSJSONObject[] {
	const result: UTSJSONObject[] = []
	appendGroupContextRecordItems(result, activeAgentId)
	appendLegacyGroupContextItems(result, activeAgentId)
	appendSchedulerContextItems(result)
	sortHistoryByUpdatedAt(result)
	return result
}

export function findHistorySchedulerMessage(item: UTSJSONObject): UTSJSONObject | null {
	const groupId = item['group_id'] as string | null
	const sessionId = item['session_id'] as string | null
	if (groupId == null || groupId == '' || sessionId == null || sessionId == '') { return null }
	const messages = getGroupMessages(groupId, sessionId)
	const messageId = item['message_id'] as string | null
	if (messageId != null && messageId != '') {
		for (let i = 0; i < messages.length; i++) {
			const msg = messages[i]
			const senderType = msg['senderType'] as string | null
			const rawId = msg['id'] as string | null
			if ((senderType == GROUP_MESSAGE_SENDER_SCHEDULER || senderType == GROUP_MESSAGE_SENDER_REVIEWER) && rawId == messageId) {
				return msg
			}
		}
	}
	const messageIndexRaw = item['message_index'] as number | null
	if (messageIndexRaw != null && messageIndexRaw >= 0 && messageIndexRaw < messages.length) {
		const msg = messages[messageIndexRaw]
		const senderType = msg['senderType'] as string | null
		if (senderType == GROUP_MESSAGE_SENDER_SCHEDULER || senderType == GROUP_MESSAGE_SENDER_REVIEWER) { return msg }
	}
	return null
}

function buildLegacySchedulerPreviewPayload(internalLabel: string, schedulerMsg: UTSJSONObject): HistoryGroupPreviewPayload {
	const runtimeMessages = schedulerMsg['runtimeMessages'] as UTSJSONObject[] | null
	const contentRaw = schedulerMsg['content'] as string | null
	const triggerRaw = schedulerMsg['triggerReason'] as string | null
	let safeRuntimeMessages: UTSJSONObject[] = []
	if (runtimeMessages != null) {
		safeRuntimeMessages = runtimeMessages
	}
	return {
		previewJson: JSON.stringify({
			type: 'scheduler_context',
			note: '旧' + internalLabel + '记录没有保存真实 request body 快照；以下为可恢复的调度上下文和输出。',
			triggerReason: triggerRaw != null ? triggerRaw : '',
			runtimeMessages: safeRuntimeMessages,
			response: contentRaw != null ? contentRaw : '',
		} as UTSJSONObject, null, 2),
		subtitle: internalLabel + '记录：没有真实请求快照',
	} as HistoryGroupPreviewPayload
}

function buildSnapshotPreviewPayload(subtitlePrefix: string, snapshot: UTSJSONObject): HistoryGroupPreviewPayload {
	const requestBody = snapshot['requestBody'] as UTSJSONObject | null
	const previewJson = requestBody != null ? JSON.stringify(requestBody, null, 2) : JSON.stringify(snapshot, null, 2)
	const messageCount = readSnapshotMessageCount(snapshot)
	return {
		previewJson: previewJson,
		subtitle: subtitlePrefix + ' · ' + messageCount + ' 条 messages',
	} as HistoryGroupPreviewPayload
}

export function buildGroupHistoryPreviewPayload(item: UTSJSONObject): HistoryGroupPreviewPayload {
	const itemType = item['type'] as string | null
	if (itemType == 'scheduler_context') {
		const schedulerMsg = findHistorySchedulerMessage(item)
		if (schedulerMsg != null) {
			const senderType = schedulerMsg['senderType'] as string | null
			const internalLabel = getSchedulerInternalLabel(senderType)
			const requestSnapshot = schedulerMsg['requestSnapshot'] as UTSJSONObject | null
			if (requestSnapshot != null) {
				return buildSnapshotPreviewPayload(internalLabel + '真实发送瞬间的请求体', requestSnapshot)
			}
			return buildLegacySchedulerPreviewPayload(internalLabel, schedulerMsg)
		}
		return { previewJson: '[]', subtitle: '' } as HistoryGroupPreviewPayload
	}
	if (itemType == 'legacy_group_message') {
		const groupId = item['group_id'] as string | null
		const sessionId = item['session_id'] as string | null
		const messageIndexRaw = item['message_index'] as number | null
		if (groupId != null && groupId != '' && sessionId != null && sessionId != '' && messageIndexRaw != null) {
			const messages = getGroupMessages(groupId, sessionId)
			const context = buildLegacyHistoryContextPreview(messages, messageIndexRaw)
			return {
				previewJson: JSON.stringify({
					type: 'legacy_group_message',
					note: '旧数据没有保存私密调度上下文；这里只能展示该成员发言前的公开群聊上下文。',
					contextMessages: context,
				} as UTSJSONObject, null, 2),
				subtitle: '旧群聊记录：只能还原公开上下文 · ' + context.length + ' 条',
			} as HistoryGroupPreviewPayload
		}
		return { previewJson: '[]', subtitle: '' } as HistoryGroupPreviewPayload
	}
	const recordId = item['id'] as string | null
	const agentId = item['agent_id'] as string | null
	if (recordId != null && recordId != '' && agentId != null && agentId != '') {
		const record = getGroupAgentContextRecord(agentId, recordId)
		if (record != null) {
			const requestSnapshot = record['requestSnapshot'] as UTSJSONObject | null
			if (requestSnapshot != null) {
				return buildSnapshotPreviewPayload('该成员上次真实发送瞬间的请求体', requestSnapshot)
			}
			return {
				previewJson: JSON.stringify({
					type: 'legacy_group_context_record',
					note: '旧记录没有保存真实 request body 快照；请让该成员再发言一次后查看。',
				} as UTSJSONObject, null, 2),
				subtitle: '旧群聊上下文记录：没有真实请求快照',
			} as HistoryGroupPreviewPayload
		}
	}
	return { previewJson: '[]', subtitle: '' } as HistoryGroupPreviewPayload
}

function deleteSchedulerHistoryById(id: string): boolean {
	const parts = id.split(':')
	if (parts.length < 4) { return false }
	const groupId = parts[1]
	const sessionId = parts[2]
	const messageKey = parts[3]
	if (groupId == '' || sessionId == '' || messageKey == '') { return false }
	const messages = getGroupMessages(groupId, sessionId)
	for (let i = 0; i < messages.length; i++) {
		const msg = messages[i]
		const senderType = msg['senderType'] as string | null
		const rawId = msg['id'] as string | null
		const fallbackId = 'index-' + i.toString()
		if ((senderType == GROUP_MESSAGE_SENDER_SCHEDULER || senderType == GROUP_MESSAGE_SENDER_REVIEWER) && (rawId == messageKey || fallbackId == messageKey)) {
			const persistedUpdatedAtRaw = msg['persistedUpdatedAt'] as number | null
			const persistedUpdatedAt = persistedUpdatedAtRaw != null && persistedUpdatedAtRaw >= 0 ? persistedUpdatedAtRaw : 0
			return rawId != null && rawId != '' ? deleteGroupMessage(groupId, sessionId, rawId, persistedUpdatedAt) : false
		}
	}
	return false
}

function deleteLegacyHistoryById(activeAgentId: string, id: string): boolean {
	const parts = id.split(':')
	if (parts.length < 4) { return false }
	const groupId = parts[1]
	const sessionId = parts[2]
	const messageKey = parts[3]
	if (activeAgentId == '' || groupId == '' || sessionId == '' || messageKey == '') { return false }
	const messages = getGroupMessages(groupId, sessionId)
	for (let i = 0; i < messages.length; i++) {
		const msg = messages[i]
		const senderAgentId = msg['senderAgentId'] as string | null
		const role = msg['role'] as string | null
		const contextRecordId = msg['contextRecordId'] as string | null
		const rawId = msg['id'] as string | null
		const fallbackId = 'legacy-' + i.toString()
		const isLegacyCandidate = senderAgentId == activeAgentId && role == 'assistant' && (contextRecordId == null || contextRecordId == '')
		if (isLegacyCandidate == true && (rawId == messageKey || fallbackId == messageKey)) {
			const persistedUpdatedAtRaw = msg['persistedUpdatedAt'] as number | null
			const persistedUpdatedAt = persistedUpdatedAtRaw != null && persistedUpdatedAtRaw >= 0 ? persistedUpdatedAtRaw : 0
			return rawId != null && rawId != '' ? deleteGroupMessage(groupId, sessionId, rawId, persistedUpdatedAt) : false
		}
	}
	return false
}

export function deleteGroupHistoryContextById(activeAgentId: string, id: string): boolean {
	if (id == '') { return false }
	if (id.startsWith('scheduler:')) {
		return deleteSchedulerHistoryById(id)
	}
	if (id.startsWith('legacy:')) {
		return deleteLegacyHistoryById(activeAgentId, id)
	}
	if (activeAgentId == '') { return false }
	return deleteGroupAgentContextRecord(activeAgentId, id)
}
