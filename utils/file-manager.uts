/**
 * 文件管理工具层
 *
 * Android 平台使用 java.io.File 原生 API，可访问 app 私有目录（/data/data/<pkg>/），
 * 包括 files/（agents/sessions/快照）、databases/（SQLite）、cache/ 等所有子目录。
 *
 * 其他平台回退到 uni.getFileSystemManager()，仅支持外置沙盒目录。
 *
 * 默认根目录：
 * - Android：context.applicationInfo.dataDir（/data/data/<pkg>/）
 * - 其他平台：uni.env.USER_DATA_PATH
 */

import { getAppSetting, getGroupChatRows, setAppSetting } from '@/utils/database.uts'

// #ifdef APP-ANDROID
import File from 'java.io.File'
import Charset from 'java.nio.charset.Charset'
// #endif

// #ifdef APP-ANDROID
const UTF8_CHARSET = Charset.forName('UTF-8')
// #endif

/** 文件项信息 */
export type FileItem = {
	/** 文件/文件夹名 */
	name: string
	/** 完整路径 */
	path: string
	/** 是否为目录 */
	isDirectory: boolean
	/** 文件大小（字节），目录固定为 0 */
	size: number
	/** 最后修改时间戳（毫秒） */
	lastModified: number
}

/** 路径分段（面包屑导航用） */
export type PathSegment = {
	name: string
	path: string
}

/** 文件操作结果 */
export type FileOpResult = {
	/** 是否成功 */
	ok: boolean
	/** 错误信息，失败时填充 */
	error: string
}

/** 根目录选项（带中文标签） */
export type RootDirOption = {
	name: string
	path: string
}

/** 路径分隔符（跨平台统一用 /） */
const SEP = '/'
const LEGACY_USER_DIR_MIGRATED_KEY = 'legacy_user_dir_migrated'

/** 构造成功结果 */
function okResult(): FileOpResult {
	const r: FileOpResult = { ok: true, error: '' }
	return r
}

/** 构造失败结果 */
function failResult(msg: string): FileOpResult {
	const r: FileOpResult = { ok: false, error: msg }
	return r
}

/** 构造文件项 */
function makeFileItem(name: string, path: string, isDir: boolean, size: number, mtime: number): FileItem {
	const item: FileItem = {
		name: name,
		path: path,
		isDirectory: isDir,
		size: size,
		lastModified: mtime,
	}
	return item
}

// #ifdef APP-ANDROID
/**
 * 获取 Android Application Context
 */
function getAndroidContext(): android.content.Context {
	return UTSAndroid.getAppContext()!
}

/**
 * 获取 app 私有数据根目录（/data/data/<pkg>/）
 */
function getAppDataDir(): string {
	const context = getAndroidContext()
	return context.applicationInfo.dataDir
}
// #endif

/**
 * 获取内部存储 files 目录。
 * - Android：/data/data/<pkg>/files/（Agent 文件、会话、SQLite 快照等业务数据存放于此）
 * - 其他平台：uni.env.USER_DATA_PATH
 */
export function getInternalFilesDir(): string {
	// #ifdef APP-ANDROID
	const context = getAndroidContext()
	const dir = context.filesDir as File
	return dir.absolutePath
	// #endif
	// #ifndef APP-ANDROID
	const userDataPath = uni.env.USER_DATA_PATH
	if (userDataPath != null && userDataPath != '') {
		return normalizePath(userDataPath)
	}
	return ''
	// #endif
}

/**
 * 获取 Agent 沙箱根目录。
 */
export function getAgentsRoot(): string {
	const filesDir = getInternalFilesDir()
	if (filesDir == '') return ''
	return filesDir + '/agents'
}

/**
 * 获取用户文件目录（不存在则创建）。
 * 用户自己的待办、笔记和手动文件都放这里，避免混进 Agent 沙箱。
 */
export function getUserDir(): string {
	const filesDir = getInternalFilesDir()
	if (filesDir == '') return ''
	const dirPath = filesDir + '/user'
	// #ifdef APP-ANDROID
	try {
		const dir = new File(dirPath)
		if (!dir.exists()) {
			dir.mkdirs()
		}
	} catch (_e: any) {
	}
	// #endif
	// #ifndef APP-ANDROID
	try {
		const fm = uni.getFileSystemManager()
		try {
			fm.accessSync(dirPath)
		} catch (_e: any) {
			fm.mkdirSync(dirPath, true)
		}
	} catch (_e2: any) {
	}
	// #endif
	return dirPath
}

/**
 * 获取旧版用户伪 Agent 目录。只用于无损迁移，不再写入新数据。
 */
export function getLegacyUserAgentDir(): string {
	const root = getAgentsRoot()
	if (root == '') return ''
	return root + '/__user__'
}

/**
 * 获取指定 Agent 的沙箱子目录（不存在则创建）。
 * agentId 经过路径穿越校验，防止越权。
 */
export function getAgentDir(agentId: string): string {
	if (agentId == '' || agentId.indexOf('/') >= 0 || agentId.indexOf('\\') >= 0 || agentId.indexOf('..') >= 0) {
		return ''
	}
	const root = getAgentsRoot()
	if (root == '') return ''
	const dir = root + '/' + agentId
	if (!exists(dir)) {
		createDir(dir)
	}
	return dir
}

/**
 * 获取指定 Agent 的单个私聊会话工作区（不存在则创建）。
 * 目录结构：files/agents/{agentId}/{conversationId}
 */
export function getAgentConversationDir(agentId: string, conversationId: string): string {
	if (conversationId == '' || conversationId.indexOf('/') >= 0 || conversationId.indexOf('\\') >= 0 || conversationId.indexOf('..') >= 0) {
		return ''
	}
	const agentDir = getAgentDir(agentId)
	if (agentDir == '') { return '' }
	const dir = agentDir + '/' + conversationId
	if (!exists(dir)) {
		createDir(dir)
	}
	return dir
}

/**
 * 获取内部存储 cache 目录。
 * - Android：/data/data/<pkg>/cache/（临时文件、下载缓存等）
 * - 其他平台：uni.env.CACHE_PATH
 */
export function getInternalCacheDir(): string {
	// #ifdef APP-ANDROID
	const context = getAndroidContext()
	const dir = context.cacheDir as File
	return dir.absolutePath
	// #endif
	// #ifndef APP-ANDROID
	const cachePath = uni.env.CACHE_PATH
	if (cachePath != null && cachePath != '') {
		return normalizePath(cachePath)
	}
	return ''
	// #endif
}

/**
 * 获取外置沙盒 files 目录。
 * - Android：/storage/emulated/0/Android/data/<pkg>/files/
 * - 其他平台：uni.env.USER_DATA_PATH
 */
export function getExternalFilesDir(): string {
	// #ifdef APP-ANDROID
	const context = getAndroidContext()
	const dir = context.getExternalFilesDir(null)
	if (dir != null) {
		return dir.absolutePath
	}
	return ''
	// #endif
	// #ifndef APP-ANDROID
	const userDataPath = uni.env.USER_DATA_PATH
	if (userDataPath != null && userDataPath != '') {
		return normalizePath(userDataPath)
	}
	return ''
	// #endif
}

/**
 * 获取 SQLite 数据库目录。
 * - Android：/data/data/<pkg>/databases/（系统管理，仅用于读取数据库文件信息）
 * - 其他平台：返回空字符串
 */
export function getDatabaseDir(): string {
	// #ifdef APP-ANDROID
	const dataDir = getAppDataDir()
	if (dataDir == '') {
		return ''
	}
	return normalizePath(dataDir + SEP + 'databases')
	// #endif
	// #ifndef APP-ANDROID
	return ''
	// #endif
}

/**
 * 规范化路径：统一分隔符，合并多余斜杠，去除末尾斜杠。
 * 支持 unifile://、file:// 协议路径和绝对路径。
 */
export function normalizePath(path: string): string {
	let result = path.trim().replace(/\\/g, SEP)
	// 提取协议前缀
	let protocol = ''
	if (result.startsWith('unifile://')) {
		protocol = 'unifile://'
		result = result.substring(10)
	} else if (result.startsWith('file://')) {
		protocol = 'file://'
		result = result.substring(7)
	}
	// 合并多余斜杠
	while (result.indexOf(SEP + SEP) >= 0) {
		result = result.replace(/\/\/+/g, SEP)
	}
	// 去除末尾斜杠（根目录 "/" 除外）
	if (result.length > 1 && result.endsWith(SEP)) {
		result = result.substring(0, result.length - 1)
	}
	return protocol + result
}

/** 统计字符出现次数 */
function countChar(s: string, c: string): number {
	let count = 0
	for (let i = 0; i < s.length; i++) {
		if (s.charAt(i) == c) {
			count++
		}
	}
	return count
}

/**
 * 拼接路径，自动处理分隔符。
 */
export function joinPath(base: string, name: string): string {
	let n = name.trim()
	if (n == '') {
		return normalizePath(base)
	}
	let b = normalizePath(base)
	// 提取协议前缀
	let protocol = ''
	if (b.startsWith('unifile://')) {
		protocol = 'unifile://'
		b = b.substring(10)
	} else if (b.startsWith('file://')) {
		protocol = 'file://'
		b = b.substring(7)
	}
	// 去除 b 末尾斜杠
	while (b.length > 0 && b.endsWith(SEP)) {
		b = b.substring(0, b.length - 1)
	}
	// 去除 n 开头斜杠
	while (n.startsWith(SEP)) {
		n = n.substring(1)
	}
	return protocol + b + SEP + n
}

/**
 * 获取父目录路径。根目录返回空字符串。
 */
export function parentPath(path: string): string {
	let p = normalizePath(path)
	// 提取协议前缀
	let protocol = ''
	if (p.startsWith('unifile://')) {
		protocol = 'unifile://'
		p = p.substring(10)
	} else if (p.startsWith('file://')) {
		protocol = 'file://'
		p = p.substring(7)
	}
	const lastSep = p.lastIndexOf(SEP)
	if (lastSep <= 0) {
		return ''
	}
	return protocol + p.substring(0, lastSep)
}

/**
 * 获取路径末尾的文件/文件夹名。
 */
export function basename(path: string): string {
	let p = normalizePath(path)
	// 提取协议前缀
	if (p.startsWith('unifile://')) {
		p = p.substring(10)
	} else if (p.startsWith('file://')) {
		p = p.substring(7)
	}
	const lastSep = p.lastIndexOf(SEP)
	if (lastSep < 0) {
		return p
	}
	return p.substring(lastSep + 1)
}

/**
 * 获取默认根目录。
 * - Android：app 私有数据根目录 /data/data/<pkg>/（含 files/databases/cache 等子目录）
 * - 其他平台：uni.env.USER_DATA_PATH
 */
export function getDefaultRoot(): string {
	// #ifdef APP-ANDROID
	const dataDir = getAppDataDir()
	if (dataDir != null && dataDir != '') {
		return dataDir
	}
	// #endif
	const userDataPath = uni.env.USER_DATA_PATH
	if (userDataPath != null && userDataPath != '') {
		return normalizePath(userDataPath)
	}
	const cachePath = uni.env.CACHE_PATH
	if (cachePath != null && cachePath != '') {
		return normalizePath(cachePath)
	}
	return ''
}

/**
 * 获取所有可访问的根目录列表（供侧边/快速跳转使用）。
 */
export function listRootDirs(): string[] {
	const roots: string[] = []
	// #ifdef APP-ANDROID
	const dataDir = getAppDataDir()
	if (dataDir != null && dataDir != '') {
		roots.push(dataDir)
	}
	// #endif
	const userDataPath = uni.env.USER_DATA_PATH
	if (userDataPath != null && userDataPath != '') {
		roots.push(normalizePath(userDataPath))
	}
	const cachePath = uni.env.CACHE_PATH
	if (cachePath != null && cachePath != '') {
		roots.push(normalizePath(cachePath))
	}
	return roots
}

/**
 * 获取带标签的根目录选项（供 UI 切换使用）。
 * - 沙盒文件：uni.env.USER_DATA_PATH（外部沙盒，可被系统文件管理器看到）
 * - Agent 目录：/data/data/<pkg>/files/agents/（内部存储，Agent 文件沙箱）
 */
export function getRootDirOptions(): RootDirOption[] {
	const options: RootDirOption[] = []
	// 沙盒文件
	const userDataPath = uni.env.USER_DATA_PATH
	if (userDataPath != null && userDataPath != '') {
		options.push({ name: '沙盒文件', path: normalizePath(userDataPath) })
	}
	// 用户目录
	const userDir = getUserDir()
	if (userDir != '') {
		options.push({ name: '用户目录', path: userDir })
	}
	// Agent 目录
	const filesDir = getInternalFilesDir()
	if (filesDir != '') {
		options.push({ name: 'Agent 目录', path: filesDir + '/agents' })
	}
	return options
}

/**
 * 列出根目录内容：合并沙盒文件和 Agent 目录两个来源。
 *
 * 按来源分组排序：
 *   1. 用户目录
 *   2. Agent 目录 — 每个子目录加 "[Agent] " 前缀
 *   3. 群聊目录 — 每个子目录加 "[Group] " 前缀
 *   4. 其它目录（外置沙盒、内部精选目录）
 *
 * 用于文件管理页面的根视图。
 */
export function listRootContents(): FileItem[] {
	const userRootItems: FileItem[] = []
	const sandboxItems: FileItem[] = []
	const internalItems: FileItem[] = []
	const groupItems: FileItem[] = []
	const agentItems: FileItem[] = []
	const userDir = getUserDir()

	// 第 0 组：用户文件目录
	if (userDir != '') {
		const userStat = statItem(userDir)
		userRootItems.push({
			name: '[User] 用户目录',
			path: userDir,
			isDirectory: true,
			size: 0,
			lastModified: userStat.lastModified,
		})
	}

	// 第 1 组：沙盒文件
	const sandboxDir = getExternalFilesDir()
	if (sandboxDir != '') {
		const userItems = listDir(sandboxDir)
		for (let i = 0; i < userItems.length; i++) {
			const item = userItems[i]
			if (userDir != '' && normalizePath(item.path) == normalizePath(userDir)) {
				continue
			}
			sandboxItems.push(item)
		}
	}

	// 第 2 组：内部存储精选目录
	const filesDir = getInternalFilesDir()
	if (filesDir != '') {
		const knownDirs = ['sessions', 'exports', 'imports', 'laoqianjunzi-sqlite-snapshots']
		for (let k = 0; k < knownDirs.length; k++) {
			const subPath = filesDir + '/' + knownDirs[k]
			if (exists(subPath)) {
				const stat = statItem(subPath)
				internalItems.push({
					name: knownDirs[k],
					path: subPath,
					isDirectory: stat.isDirectory,
					size: stat.size,
					lastModified: stat.lastModified,
				})
			}
		}

		// 第 3 组：群聊工作区（用群聊显示名替代 ID 文件夹名）
		// 直接读 SQLite，避免和 group-chat-service.uts 形成循环引用。
		const groupDisplayNames: Map<string, string> = new Map<string, string>()
		const groupRows = getGroupChatRows()
		for (let j = 0; j < groupRows.length; j++) {
			const item = groupRows[j]
			const gid = item['id'] as string
			const gname = item['name'] as string
			if (gid != null && gid != '' && gname != null && gname != '') {
				groupDisplayNames.set(gid, gname)
			}
		}
		const groupWorkspaceRoot = filesDir + '/group-workspaces'
		const groupList = listDir(groupWorkspaceRoot)
		for (let i = 0; i < groupList.length; i++) {
			const group = groupList[i]
			if (group.isDirectory) {
				const groupId = group.name
				const displayName = groupDisplayNames.get(groupId)
				const label = displayName != null ? displayName : groupId
				groupItems.push({
					name: '[Group] ' + label,
					path: group.path,
					isDirectory: true,
					size: 0,
					lastModified: group.lastModified,
				})
			}
		}

		// 第 4 组：Agent 子目录（用智能体显示名替代 ID 文件夹名）
		// 直接读 app_settings，避免循环引用 agent.uts。
		const agentDisplayNames: Map<string, string> = new Map<string, string>()
		const agentListJson = getAppSetting('agent_list')
		if (agentListJson != null && agentListJson != '') {
			try {
				const agentList = JSON.parse(agentListJson) as UTSJSONObject[]
				for (let j = 0; j < (agentList as any[]).length; j++) {
					const item = agentList[j] as UTSJSONObject
					const aid = item['id'] as string
					const aname = item['name'] as string
					if (aid != null && aid != '' && aname != null && aname != '') {
						agentDisplayNames.set(aid, aname)
					}
				}
			} catch (_e: any) { /* 解析失败则用文件夹名 */ }
		}
		const agentList = listDir(filesDir + '/agents')
		for (let i = 0; i < agentList.length; i++) {
			const agent = agentList[i]
			if (agent.isDirectory) {
				// agent.name 是文件夹名 = 智能体 ID，查显示名
				const agentId = agent.name
				if (agentId == '__user__') {
					continue
				}
				const displayName = agentDisplayNames.get(agentId)
				const label = displayName != null ? displayName : agentId
				agentItems.push({
					name: '[Agent] ' + label,
					path: agent.path,
					isDirectory: true,
					size: 0,
					lastModified: agent.lastModified,
				})
			}
		}
	}

	// 各组内部排序：目录在前，文件在后，同类按名称升序
	const sortGroup = (arr: FileItem[]): void => {
		arr.sort((a: FileItem, b: FileItem): number => {
			if (a.isDirectory != b.isDirectory) {
				return a.isDirectory ? -1 : 1
			}
			if (a.name < b.name) {
				return -1
			}
			if (a.name > b.name) {
				return 1
			}
			return 0
		})
	}
	sortGroup(userRootItems)
	sortGroup(sandboxItems)
	sortGroup(internalItems)
	sortGroup(groupItems)
	sortGroup(agentItems)

	// 按顺序拼接：用户目录 → Agent → 群聊 → 其它目录
	const result: FileItem[] = []
	for (let i = 0; i < userRootItems.length; i++) {
		result.push(userRootItems[i])
	}
	for (let i = 0; i < agentItems.length; i++) {
		result.push(agentItems[i])
	}
	for (let i = 0; i < groupItems.length; i++) {
		result.push(groupItems[i])
	}
	for (let i = 0; i < sandboxItems.length; i++) {
		result.push(sandboxItems[i])
	}
	for (let i = 0; i < internalItems.length; i++) {
		result.push(internalItems[i])
	}
	return result
}

/**
 * 判断路径是否存在。
 */
export function exists(path: string): boolean {
	const normalized = normalizePath(path)
	if (normalized == '') {
		return false
	}
	// #ifdef APP-ANDROID
	const absPath = toAndroidAbsPath(normalized)
	if (absPath == '') {
		return false
	}
	try {
		const file = new File(absPath)
		return file.exists()
	} catch (_e: any) {
		return false
	}
	// #endif
	// #ifndef APP-ANDROID
	const fm = uni.getFileSystemManager()
	try {
		fm.accessSync(normalized)
		return true
	} catch (_e: any) {
		return false
	}
	// #endif
}

// #ifdef APP-ANDROID
/**
 * 将路径转换为 Android 绝对路径。
 * unifile:// 路径通过 UTSAndroid.convert2AbsFullPath 转换，
 * file:// 路径去掉协议前缀，其他路径原样返回。
 */
function toAndroidAbsPath(path: string): string {
	if (path == '') {
		return ''
	}
	if (path.startsWith('unifile://')) {
		try {
			return UTSAndroid.convert2AbsFullPath(path)
		} catch (_e: any) {
			return ''
		}
	}
	if (path.startsWith('file://')) {
		return path.substring(7)
	}
	return path
}
// #endif

/**
 * 列出指定目录下的文件和文件夹。
 *
 * @param dirPath 目录路径
 * @returns 文件项数组，目录不存在或为空返回空数组。文件夹排前，文件排后，各自按名称排序。
 */
export function listDir(dirPath: string): FileItem[] {
	const normalized = normalizePath(dirPath)
	if (normalized == '') {
		return []
	}
	const items: FileItem[] = []
	// #ifdef APP-ANDROID
	const absPath = toAndroidAbsPath(normalized)
	if (absPath == '') {
		return []
	}
	try {
		const dir = new File(absPath)
		if (!dir.exists() || !dir.isDirectory()) {
			return []
		}
		const names = dir.list()
		if (names == null) {
			return []
		}
		let idx = 0 as Int
		while (idx < names.size) {
			const name = names[idx]
			if (name != '.' && name != '..') {
				const childPath = joinPath(normalized, name)
				const childAbsPath = absPath + SEP + name
				const stat = statItemByAbsPath(childAbsPath, childPath)
				items.push(stat)
			}
			idx++
		}
	} catch (_e: any) {
		return []
	}
	// #endif
	// #ifndef APP-ANDROID
	const fm = uni.getFileSystemManager()
	let names: string[]
	try {
		names = fm.readdirSync(normalized) as string[]
	} catch (_e: any) {
		return []
	}
	for (let i = 0; i < names.length; i++) {
		const name = names[i]
		if (name == '.' || name == '..') {
			continue
		}
		const fullPath = joinPath(normalized, name)
		const stat = statItem(fullPath)
		items.push(stat)
	}
	// #endif
	// 排序：目录在前，文件在后；同类按名称升序
	items.sort((a: FileItem, b: FileItem): number => {
		if (a.isDirectory != b.isDirectory) {
			return a.isDirectory ? -1 : 1
		}
		if (a.name < b.name) {
			return -1
		}
		if (a.name > b.name) {
			return 1
		}
		return 0
	})
	return items
}

// #ifdef APP-ANDROID
/**
 * 通过 Android 绝对路径获取文件信息（内部使用）。
 * @param absPath Android 文件系统绝对路径
 * @param displayPath 显示用路径（可能是 unifile:// 或绝对路径）
 */
function statItemByAbsPath(absPath: string, displayPath: string): FileItem {
	try {
		const file = new File(absPath)
		if (!file.exists()) {
			return makeFileItem(basename(displayPath), displayPath, false, 0, 0)
		}
		const isDir = file.isDirectory()
		const size = isDir ? 0 : file.length()
		const mtime = file.lastModified()
		return makeFileItem(file.name, displayPath, isDir, size, mtime)
	} catch (_e: any) {
		return makeFileItem(basename(displayPath), displayPath, false, 0, 0)
	}
}
// #endif

/**
 * 获取单个文件/目录的统计信息。
 * 失败返回默认值（isDirectory=false, size=0）。
 */
export function statItem(path: string): FileItem {
	const normalized = normalizePath(path)
	if (normalized == '') {
		return makeFileItem('', normalized, false, 0, 0)
	}
	// #ifdef APP-ANDROID
	const absPath = toAndroidAbsPath(normalized)
	if (absPath == '') {
		return makeFileItem(basename(normalized), normalized, false, 0, 0)
	}
	return statItemByAbsPath(absPath, normalized)
	// #endif
	// #ifndef APP-ANDROID
	const fm = uni.getFileSystemManager()
	try {
		const statsArray = fm.statSync(normalized, false)
		if (statsArray == null || statsArray.length == 0) {
			return makeFileItem(basename(normalized), normalized, false, 0, 0)
		}
		const fileStat = statsArray[0]
		const stat = fileStat.stats
		let isDir = false
		let size = 0
		let mtime = 0
		if (stat != null) {
			try {
				isDir = stat.isDirectory()
			} catch (_e: any) {
				isDir = false
			}
			size = stat.size
			mtime = stat.lastModifiedTime
		}
		return makeFileItem(basename(normalized), normalized, isDir, size, mtime)
	} catch (_e: any) {
		return makeFileItem(basename(normalized), normalized, false, 0, 0)
	}
	// #endif
}

/**
 * 创建目录。
 *
 * @param dirPath 目录路径
 * @param recursive 是否递归创建父目录
 */
export function createDir(dirPath: string, recursive: boolean = true): FileOpResult {
	const normalized = normalizePath(dirPath)
	if (normalized == '') {
		return failResult('路径不能为空')
	}
	if (exists(normalized)) {
		return failResult('目录已存在')
	}
	// #ifdef APP-ANDROID
	const absPath = toAndroidAbsPath(normalized)
	if (absPath == '') {
		return failResult('路径转换失败')
	}
	try {
		const dir = new File(absPath)
		const ok = recursive ? dir.mkdirs() : dir.mkdir()
		if (ok) {
			return okResult()
		}
		return failResult('创建目录失败')
	} catch (e: any) {
		const msg = e != null ? ('' + e) : '创建目录失败'
		return failResult(msg)
	}
	// #endif
	// #ifndef APP-ANDROID
	const fm = uni.getFileSystemManager()
	try {
		fm.mkdirSync(normalized, recursive)
		return okResult()
	} catch (e: any) {
		const msg = e != null ? ('' + e) : '创建目录失败'
		return failResult(msg)
	}
	// #endif
}

/**
 * 创建文件（空内容）。
 */
export function createFile(filePath: string): FileOpResult {
	const normalized = normalizePath(filePath)
	if (normalized == '') {
		return failResult('路径不能为空')
	}
	if (exists(normalized)) {
		return failResult('文件已存在')
	}
	// #ifdef APP-ANDROID
	const absPath = toAndroidAbsPath(normalized)
	if (absPath == '') {
		return failResult('路径转换失败')
	}
	try {
		const file = new File(absPath)
		const parent = file.parentFile
		if (parent != null && !parent!.exists()) {
			parent!.mkdirs()
		}
		file.writeText('', UTF8_CHARSET)
		return okResult()
	} catch (e: any) {
		const msg = e != null ? ('' + e) : '创建文件失败'
		return failResult(msg)
	}
	// #endif
	// #ifndef APP-ANDROID
	const fm = uni.getFileSystemManager()
	try {
		fm.writeFileSync(normalized, '', 'utf-8')
		return okResult()
	} catch (e: any) {
		const msg = e != null ? ('' + e) : '创建文件失败'
		return failResult(msg)
	}
	// #endif
}

/**
 * 写入文件内容（覆盖写入）。
 */
export function writeContent(filePath: string, content: string): FileOpResult {
	const normalized = normalizePath(filePath)
	if (normalized == '') {
		return failResult('路径不能为空')
	}
	// #ifdef APP-ANDROID
	const absPath = toAndroidAbsPath(normalized)
	if (absPath == '') {
		return failResult('路径转换失败')
	}
	try {
		const file = new File(absPath)
		const parent = file.parentFile
		if (parent != null && !parent!.exists()) {
			parent!.mkdirs()
		}
		file.writeText(content, UTF8_CHARSET)
		return okResult()
	} catch (e: any) {
		const msg = e != null ? ('' + e) : '写入文件失败'
		return failResult(msg)
	}
	// #endif
	// #ifndef APP-ANDROID
	const fm = uni.getFileSystemManager()
	try {
		fm.writeFileSync(normalized, content, 'utf-8')
		return okResult()
	} catch (e: any) {
		const msg = e != null ? ('' + e) : '写入文件失败'
		return failResult(msg)
	}
	// #endif
}

/**
 * 读取文件内容（文本）。
 *
 * @param filePath 文件路径
 * @returns 成功返回文件内容字符串，失败返回 null
 */
export function readContent(filePath: string): string | null {
	const normalized = normalizePath(filePath)
	if (normalized == '') {
		return null
	}
	// #ifdef APP-ANDROID
	const absPath = toAndroidAbsPath(normalized)
	if (absPath == '') {
		return null
	}
	try {
		const file = new File(absPath)
		if (!file.exists() || file.isDirectory()) {
			return null
		}
		return file.readText(UTF8_CHARSET)
	} catch (_e: any) {
		return null
	}
	// #endif
	// #ifndef APP-ANDROID
	const fm = uni.getFileSystemManager()
	try {
		const data = fm.readFileSync(normalized, 'utf-8')
		if (data == null) {
			return null
		}
		return '' + data
	} catch (_e: any) {
		return null
	}
	// #endif
}

/**
 * 删除文件或目录。
 *
 * @param path 路径
 * @param recursive 目录是否递归删除
 */
export function deleteItem(path: string, recursive: boolean = true): FileOpResult {
	const normalized = normalizePath(path)
	if (normalized == '') {
		return failResult('路径不能为空')
	}
	if (!exists(normalized)) {
		return failResult('路径不存在')
	}
	// #ifdef APP-ANDROID
	const absPath = toAndroidAbsPath(normalized)
	if (absPath == '') {
		return failResult('路径转换失败')
	}
	try {
		const file = new File(absPath)
		if (file.isDirectory() && recursive) {
			const ok = deleteRecursiveAndroid(file)
			if (ok) {
				return okResult()
			}
			return failResult('递归删除目录失败')
		}
		const ok = file.delete()
		if (ok) {
			return okResult()
		}
		return failResult('删除失败')
	} catch (e: any) {
		const msg = e != null ? ('' + e) : '删除失败'
		return failResult(msg)
	}
	// #endif
	// #ifndef APP-ANDROID
	const fm = uni.getFileSystemManager()
	const stat = statItem(normalized)
	if (stat.isDirectory) {
		try {
			fm.rmdirSync(normalized, recursive)
			return okResult()
		} catch (e: any) {
			const msg = e != null ? ('' + e) : '删除目录失败'
			return failResult(msg)
		}
	} else {
		try {
			fm.unlinkSync(normalized)
			return okResult()
		} catch (e: any) {
			const msg = e != null ? ('' + e) : '删除文件失败'
			return failResult(msg)
		}
	}
	// #endif
}

// #ifdef APP-ANDROID
/**
 * 递归删除目录（Android 原生）。
 */
function deleteRecursiveAndroid(file: File): boolean {
	if (file.isDirectory()) {
		const children = file.listFiles()
		if (children != null) {
			let idx = 0 as Int
			while (idx < children.size) {
				deleteRecursiveAndroid(children[idx])
				idx++
			}
		}
	}
	return file.delete()
}
// #endif

/**
 * 重命名或移动文件/目录。
 *
 * @param oldPath 原路径
 * @param newPath 新路径（含文件名）
 */
export function renameItem(oldPath: string, newPath: string): FileOpResult {
	const normalizedOld = normalizePath(oldPath)
	const normalizedNew = normalizePath(newPath)
	if (normalizedOld == '' || normalizedNew == '') {
		return failResult('路径不能为空')
	}
	if (!exists(normalizedOld)) {
		return failResult('原路径不存在')
	}
	if (exists(normalizedNew)) {
		return failResult('目标路径已存在')
	}
	// #ifdef APP-ANDROID
	const absOld = toAndroidAbsPath(normalizedOld)
	const absNew = toAndroidAbsPath(normalizedNew)
	if (absOld == '' || absNew == '') {
		return failResult('路径转换失败')
	}
	try {
		const oldFile = new File(absOld)
		const newFile = new File(absNew)
		const parent = newFile.parentFile
		if (parent != null && !parent!.exists()) {
			parent!.mkdirs()
		}
		const ok = oldFile.renameTo(newFile)
		if (ok) {
			return okResult()
		}
		return failResult('重命名失败')
	} catch (e: any) {
		const msg = e != null ? ('' + e) : '重命名失败'
		return failResult(msg)
	}
	// #endif
	// #ifndef APP-ANDROID
	const fm = uni.getFileSystemManager()
	try {
		fm.renameSync(normalizedOld, normalizedNew)
		return okResult()
	} catch (e: any) {
		const msg = e != null ? ('' + e) : '重命名失败'
		return failResult(msg)
	}
	// #endif
}

/**
 * 复制文件。
 *
 * @param srcPath 源文件路径
 * @param destPath 目标路径
 */
export function copyItem(srcPath: string, destPath: string): FileOpResult {
	const normalizedSrc = normalizePath(srcPath)
	const normalizedDest = normalizePath(destPath)
	if (normalizedSrc == '' || normalizedDest == '') {
		return failResult('路径不能为空')
	}
	if (!exists(normalizedSrc)) {
		return failResult('源路径不存在')
	}
	if (exists(normalizedDest)) {
		return failResult('目标路径已存在')
	}
	const stat = statItem(normalizedSrc)
	if (stat.isDirectory) {
		return copyDirRecursive(normalizedSrc, normalizedDest)
	}
	// #ifdef APP-ANDROID
	const absSrc = toAndroidAbsPath(normalizedSrc)
	const absDest = toAndroidAbsPath(normalizedDest)
	if (absSrc == '' || absDest == '') {
		return failResult('路径转换失败')
	}
	try {
		const srcFile = new File(absSrc)
		const destFile = new File(absDest)
		const parent = destFile.parentFile
		if (parent != null && !parent!.exists()) {
			parent!.mkdirs()
		}
		srcFile.copyTo(destFile)
		return okResult()
	} catch (e: any) {
		const msg = e != null ? ('' + e) : '复制文件失败'
		return failResult(msg)
	}
	// #endif
	// #ifndef APP-ANDROID
	const fm = uni.getFileSystemManager()
	try {
		fm.copyFileSync(normalizedSrc, normalizedDest)
		return okResult()
	} catch (e: any) {
		const msg = e != null ? ('' + e) : '复制文件失败'
		return failResult(msg)
	}
	// #endif
}

/**
 * 递归复制目录。
 */
function copyDirRecursive(srcPath: string, destPath: string): FileOpResult {
	const createResult = createDir(destPath, true)
	if (!createResult.ok) {
		return createResult
	}
	const items = listDir(srcPath)
	for (let i = 0; i < items.length; i++) {
		const item = items[i]
		const childSrc = item.path
		const childDest = joinPath(destPath, item.name)
		if (item.isDirectory) {
			const subResult = copyDirRecursive(childSrc, childDest)
			if (!subResult.ok) {
				return subResult
			}
		} else {
			const copyResult = copyItem(childSrc, childDest)
			if (!copyResult.ok) {
				return copyResult
			}
		}
	}
	return okResult()
}

/**
 * 递归合并源目录中目标目录缺失的文件，目标已有内容不覆盖。
 */
function mergeMissingItems(srcDir: string, destDir: string, depth: number): void {
	if (depth > 8) {
		return
	}
	const items = listDir(srcDir)
	for (let i = 0; i < items.length; i++) {
		const item = items[i]
		const targetPath = joinPath(destDir, item.name)
		if (exists(targetPath)) {
			if (item.isDirectory) {
				const targetStat = statItem(targetPath)
				if (targetStat.isDirectory) {
					mergeMissingItems(item.path, targetPath, depth + 1)
				}
			}
			continue
		}
		copyItem(item.path, targetPath)
	}
}

/**
 * 无损迁移旧版 `agents/__user__` 目录到新的用户目录。
 * 已存在的同名文件不会覆盖，避免误伤用户手动整理过的数据。
 */
export function migrateLegacyUserDir(): void {
	const migrated = getAppSetting(LEGACY_USER_DIR_MIGRATED_KEY)
	if (migrated == '1') {
		return
	}
	const legacyDir = getLegacyUserAgentDir()
	const filesDir = getInternalFilesDir()
	if (legacyDir == '' || filesDir == '') {
		return
	}
	const userDir = filesDir + '/user'
	if (userDir == '' || legacyDir == userDir) {
		setAppSetting(LEGACY_USER_DIR_MIGRATED_KEY, '1')
		return
	}
	if (!exists(legacyDir)) {
		setAppSetting(LEGACY_USER_DIR_MIGRATED_KEY, '1')
		return
	}
	// LEGACY_COMPAT: 只在新 user 目录还没出现时做一次旧目录迁移，避免已删除文件反复复活。
	if (exists(userDir) == true) {
		setAppSetting(LEGACY_USER_DIR_MIGRATED_KEY, '1')
		return
	}
	createDir(userDir, true)
	mergeMissingItems(legacyDir, userDir, 0)
	setAppSetting(LEGACY_USER_DIR_MIGRATED_KEY, '1')
}

/**
 * 格式化文件大小为可读字符串。
 *
 * @param bytes 字节数
 * @returns 如 "1.2 KB"、"3.4 MB"
 */
export function formatFileSize(bytes: number): string {
	if (bytes <= 0) {
		return '0 B'
	}
	const units = ['B', 'KB', 'MB', 'GB', 'TB']
	let value = bytes
	let unitIndex = 0
	while (value >= 1024 && unitIndex < units.length - 1) {
		value = value / 1024
		unitIndex++
	}
	// 保留 1 位小数，整数时不显示小数
	const rounded = Math.round(value * 10) / 10
	const str = rounded % 1 == 0 ? ('' + Math.floor(rounded)) : ('' + rounded)
	return str + ' ' + units[unitIndex]
}

/**
 * 格式化时间戳为可读日期字符串。
 *
 * @param timestamp 毫秒时间戳
 * @returns 如 "2025-06-20 14:30"
 */
export function formatTime(timestamp: number): string {
	if (timestamp <= 0) {
		return '-'
	}
	const date = new Date(timestamp)
	const year = date.getFullYear()
	const month = date.getMonth() + 1
	const day = date.getDate()
	const hour = date.getHours()
	const minute = date.getMinutes()
	return year + '-' + padZero(month) + '-' + padZero(day) + ' ' + padZero(hour) + ':' + padZero(minute)
}

function padZero(n: number): string {
	if (n < 10) {
		return '0' + n
	}
	return '' + n
}

/**
 * 判断文件是否为常见文本文件（根据扩展名）。
 */
export function isTextFile(fileName: string): boolean {
	const lowerName = fileName.toLowerCase()
	const textExtensions = ['.txt', '.md', '.json', '.jsonl', '.log', '.csv', '.xml', '.yaml', '.yml', '.ini', '.conf', '.properties', '.html', '.css', '.js', '.ts', '.uts', '.uvue', '.vue', '.java', '.kt', '.swift', '.py', '.go', '.rs', '.c', '.cpp', '.h', '.sh']
	for (let i = 0; i < textExtensions.length; i++) {
		if (lowerName.endsWith(textExtensions[i])) {
			return true
		}
	}
	return false
}

/**
 * 判断文件是否为图片文件（根据扩展名）。
 */
export function isImageFile(fileName: string): boolean {
	const lowerName = fileName.toLowerCase()
	const imageExtensions = ['.png', '.jpg', '.jpeg', '.gif', '.bmp', '.webp', '.svg']
	for (let i = 0; i < imageExtensions.length; i++) {
		if (lowerName.endsWith(imageExtensions[i])) {
			return true
		}
	}
	return false
}

/**
 * 获取文件扩展名（不含点，小写）。无扩展名返回空字符串。
 */
export function getExtension(fileName: string): string {
	const lastDot = fileName.lastIndexOf('.')
	if (lastDot < 0 || lastDot == fileName.length - 1) {
		return ''
	}
	return fileName.substring(lastDot + 1).toLowerCase()
}
