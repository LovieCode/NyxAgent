/**
 * 文件管理工具层
 *
 * Android 平台使用 java.io.File 原生 API，可访问 app 私有目录（/data/data/<pkg>/），
 * 包括 files/（agents/sessions/快照）、databases/（SQLite）、cache/ 等所有子目录。
 *
 * 其他平台回退到 uni.getFileSystemManager()，仅支持外置沙盒目录。
 *
 * 默认根目录：
 * - Android：context.applicationInfo.dataDir（/data/data/<pkg>/）
 * - 其他平台：uni.env.USER_DATA_PATH
 */

import { getAppSetting, getGroupChatRows, setAppSetting } from '@/utils/database.uts'
import {
	type FileItem,
	type RootDirOption,
	SEP,
	joinPath,
	normalizePath,
} from '@/utils/file-manager-models.uts'
import { copyItem, createDir, deleteItem, exists, listDir, statItem } from '@/utils/file-manager-io.uts'
export * from '@/utils/file-manager-models.uts'
export * from '@/utils/file-manager-io.uts'

// #ifdef APP-ANDROID
import File from 'java.io.File'
// #endif

const LEGACY_USER_DIR_MIGRATED_KEY = 'legacy_user_dir_migrated'

// #ifdef APP-ANDROID
/**
 * 获取 Android Application Context
 */
function getAndroidContext(): android.content.Context {
	return UTSAndroid.getAppContext()!
}

/**
 * 获取 app 私有数据根目录（/data/data/<pkg>/）
 */
function getAppDataDir(): string {
	const context = getAndroidContext()
	return context.applicationInfo.dataDir
}
// #endif

/**
 * 获取内部存储 files 目录。
 * - Android：/data/data/<pkg>/files/（Agent 文件、会话、SQLite 快照等业务数据存放于此）
 * - 其他平台：uni.env.USER_DATA_PATH
 */
export function getInternalFilesDir(): string {
	// #ifdef APP-ANDROID
	const context = getAndroidContext()
	const dir = context.filesDir as File
	return dir.absolutePath
	// #endif
	// #ifndef APP-ANDROID
	const userDataPath = uni.env.USER_DATA_PATH
	if (userDataPath != null && userDataPath != '') {
		return normalizePath(userDataPath)
	}
	return ''
	// #endif
}

/**
 * 获取 Agent 沙箱根目录。
 */
export function getAgentsRoot(): string {
	const filesDir = getInternalFilesDir()
	if (filesDir == '') return ''
	return filesDir + '/agents'
}

/**
 * 获取用户文件目录（不存在则创建）。
 * 用户自己的待办、笔记和手动文件都放这里，避免混进 Agent 沙箱。
 */
export function getUserDir(): string {
	const filesDir = getInternalFilesDir()
	if (filesDir == '') return ''
	const dirPath = filesDir + '/user'
	if (exists(dirPath) == false) {
		createDir(dirPath)
	}
	return dirPath
}

/**
 * 获取旧版用户伪 Agent 目录。只用于无损迁移，不再写入新数据。
 */
export function getLegacyUserAgentDir(): string {
	const root = getAgentsRoot()
	if (root == '') return ''
	return root + '/__user__'
}

/**
 * 获取指定 Agent 的沙箱子目录（不存在则创建）。
 * agentId 经过路径穿越校验，防止越权。
 */
export function getAgentDir(agentId: string): string {
	if (agentId == '' || agentId.indexOf('/') >= 0 || agentId.indexOf('\\') >= 0 || agentId.indexOf('..') >= 0) {
		return ''
	}
	const root = getAgentsRoot()
	if (root == '') return ''
	const dir = root + '/' + agentId
	if (!exists(dir)) {
		createDir(dir)
	}
	return dir
}

/**
 * 获取指定 Agent 的单个私聊会话工作区（不存在则创建）。
 * 目录结构：files/agents/{agentId}/{conversationId}
 */
export function getAgentConversationDir(agentId: string, conversationId: string): string {
	if (conversationId == '' || conversationId.indexOf('/') >= 0 || conversationId.indexOf('\\') >= 0 || conversationId.indexOf('..') >= 0) {
		return ''
	}
	const agentDir = getAgentDir(agentId)
	if (agentDir == '') { return '' }
	const dir = agentDir + '/' + conversationId
	if (!exists(dir)) {
		createDir(dir)
	}
	return dir
}

/**
 * 获取内部存储 cache 目录。
 * - Android：/data/data/<pkg>/cache/（临时文件、下载缓存等）
 * - 其他平台：uni.env.CACHE_PATH
 */
export function getInternalCacheDir(): string {
	// #ifdef APP-ANDROID
	const context = getAndroidContext()
	const dir = context.cacheDir as File
	return dir.absolutePath
	// #endif
	// #ifndef APP-ANDROID
	const cachePath = uni.env.CACHE_PATH
	if (cachePath != null && cachePath != '') {
		return normalizePath(cachePath)
	}
	return ''
	// #endif
}

/**
 * 获取外置沙盒 files 目录。
 * - Android：/storage/emulated/0/Android/data/<pkg>/files/
 * - 其他平台：uni.env.USER_DATA_PATH
 */
export function getExternalFilesDir(): string {
	// #ifdef APP-ANDROID
	const context = getAndroidContext()
	const dir = context.getExternalFilesDir(null)
	if (dir != null) {
		return dir.absolutePath
	}
	return ''
	// #endif
	// #ifndef APP-ANDROID
	const userDataPath = uni.env.USER_DATA_PATH
	if (userDataPath != null && userDataPath != '') {
		return normalizePath(userDataPath)
	}
	return ''
	// #endif
}

/**
 * 获取 SQLite 数据库目录。
 * - Android：/data/data/<pkg>/databases/（系统管理，仅用于读取数据库文件信息）
 * - 其他平台：返回空字符串
 */
export function getDatabaseDir(): string {
	// #ifdef APP-ANDROID
	const dataDir = getAppDataDir()
	if (dataDir == '') {
		return ''
	}
	return normalizePath(dataDir + SEP + 'databases')
	// #endif
	// #ifndef APP-ANDROID
	return ''
	// #endif
}

/**
 * 获取默认根目录。
 * - Android：app 私有数据根目录 /data/data/<pkg>/（含 files/databases/cache 等子目录）
 * - 其他平台：uni.env.USER_DATA_PATH
 */
export function getDefaultRoot(): string {
	// #ifdef APP-ANDROID
	const dataDir = getAppDataDir()
	if (dataDir != null && dataDir != '') {
		return dataDir
	}
	// #endif
	const userDataPath = uni.env.USER_DATA_PATH
	if (userDataPath != null && userDataPath != '') {
		return normalizePath(userDataPath)
	}
	const cachePath = uni.env.CACHE_PATH
	if (cachePath != null && cachePath != '') {
		return normalizePath(cachePath)
	}
	return ''
}

/**
 * 获取所有可访问的根目录列表（供侧边/快速跳转使用）。
 */
export function listRootDirs(): string[] {
	const roots: string[] = []
	// #ifdef APP-ANDROID
	const dataDir = getAppDataDir()
	if (dataDir != null && dataDir != '') {
		roots.push(dataDir)
	}
	// #endif
	const userDataPath = uni.env.USER_DATA_PATH
	if (userDataPath != null && userDataPath != '') {
		roots.push(normalizePath(userDataPath))
	}
	const cachePath = uni.env.CACHE_PATH
	if (cachePath != null && cachePath != '') {
		roots.push(normalizePath(cachePath))
	}
	return roots
}

/**
 * 获取带标签的根目录选项（供 UI 切换使用）。
 * - 沙盒文件：uni.env.USER_DATA_PATH（外部沙盒，可被系统文件管理器看到）
 * - Agent 目录：/data/data/<pkg>/files/agents/（内部存储，Agent 文件沙箱）
 */
export function getRootDirOptions(): RootDirOption[] {
	const options: RootDirOption[] = []
	// 沙盒文件
	const userDataPath = uni.env.USER_DATA_PATH
	if (userDataPath != null && userDataPath != '') {
		options.push({ name: '沙盒文件', path: normalizePath(userDataPath) })
	}
	// 用户目录
	const userDir = getUserDir()
	if (userDir != '') {
		options.push({ name: '用户目录', path: userDir })
	}
	// Agent 目录
	const filesDir = getInternalFilesDir()
	if (filesDir != '') {
		options.push({ name: 'Agent 目录', path: filesDir + '/agents' })
	}
	return options
}

/**
 * 列出根目录内容：合并沙盒文件和 Agent 目录两个来源。
 *
 * 按来源分组排序：
 *   1. 用户目录
 *   2. Agent 目录 — 每个子目录加 "[Agent] " 前缀
 *   3. 群聊目录 — 每个子目录加 "[Group] " 前缀
 *   4. 其它目录（外置沙盒、内部精选目录）
 *
 * 用于文件管理页面的根视图。
 */
export function listRootContents(): FileItem[] {
	const userRootItems: FileItem[] = []
	const sandboxItems: FileItem[] = []
	const internalItems: FileItem[] = []
	const groupItems: FileItem[] = []
	const agentItems: FileItem[] = []
	const userDir = getUserDir()

	// 第 0 组：用户文件目录
	if (userDir != '') {
		const userStat = statItem(userDir)
		userRootItems.push({
			name: '[User] 用户目录',
			path: userDir,
			isDirectory: true,
			size: 0,
			lastModified: userStat.lastModified,
		})
	}

	// 第 1 组：沙盒文件
	const sandboxDir = getExternalFilesDir()
	if (sandboxDir != '') {
		const userItems = listDir(sandboxDir)
		for (let i = 0; i < userItems.length; i++) {
			const item = userItems[i]
			if (userDir != '' && normalizePath(item.path) == normalizePath(userDir)) {
				continue
			}
			sandboxItems.push(item)
		}
	}

	// 第 2 组：内部存储精选目录
	const filesDir = getInternalFilesDir()
	if (filesDir != '') {
		const knownDirs = ['sessions', 'exports', 'imports', 'laoqianjunzi-sqlite-snapshots']
		for (let k = 0; k < knownDirs.length; k++) {
			const subPath = filesDir + '/' + knownDirs[k]
			if (exists(subPath)) {
				const stat = statItem(subPath)
				internalItems.push({
					name: knownDirs[k],
					path: subPath,
					isDirectory: stat.isDirectory,
					size: stat.size,
					lastModified: stat.lastModified,
				})
			}
		}

		// 第 3 组：群聊工作区（用群聊显示名替代 ID 文件夹名）
		// 直接读 SQLite，避免和 group-chat-service.uts 形成循环引用。
		const groupDisplayNames: Map<string, string> = new Map<string, string>()
		const groupRows = getGroupChatRows()
		for (let j = 0; j < groupRows.length; j++) {
			const item = groupRows[j]
			const gid = item['id'] as string
			const gname = item['name'] as string
			if (gid != null && gid != '' && gname != null && gname != '') {
				groupDisplayNames.set(gid, gname)
			}
		}
		const groupWorkspaceRoot = filesDir + '/group-workspaces'
		const groupList = listDir(groupWorkspaceRoot)
		for (let i = 0; i < groupList.length; i++) {
			const group = groupList[i]
			if (group.isDirectory) {
				const groupId = group.name
				const displayName = groupDisplayNames.get(groupId)
				const label = displayName != null ? displayName : groupId
				groupItems.push({
					name: '[Group] ' + label,
					path: group.path,
					isDirectory: true,
					size: 0,
					lastModified: group.lastModified,
				})
			}
		}

		// 第 4 组：Agent 子目录（用智能体显示名替代 ID 文件夹名）
		// 直接读 app_settings，避免循环引用 agent.uts。
		const agentDisplayNames: Map<string, string> = new Map<string, string>()
		const agentListJson = getAppSetting('agent_list')
		if (agentListJson != null && agentListJson != '') {
			try {
				const agentList = JSON.parse(agentListJson) as UTSJSONObject[]
				for (let j = 0; j < (agentList as any[]).length; j++) {
					const item = agentList[j] as UTSJSONObject
					const aid = item['id'] as string
					const aname = item['name'] as string
					if (aid != null && aid != '' && aname != null && aname != '') {
						agentDisplayNames.set(aid, aname)
					}
				}
			} catch (_e: any) { /* 解析失败则用文件夹名 */ }
		}
		const agentList = listDir(filesDir + '/agents')
		for (let i = 0; i < agentList.length; i++) {
			const agent = agentList[i]
			if (agent.isDirectory) {
				// agent.name 是文件夹名 = 智能体 ID，查显示名
				const agentId = agent.name
				if (agentId == '__user__') {
					continue
				}
				const displayName = agentDisplayNames.get(agentId)
				const label = displayName != null ? displayName : agentId
				agentItems.push({
					name: '[Agent] ' + label,
					path: agent.path,
					isDirectory: true,
					size: 0,
					lastModified: agent.lastModified,
				})
			}
		}
	}

	// 各组内部排序：目录在前，文件在后，同类按名称升序
	const sortGroup = (arr: FileItem[]): void => {
		arr.sort((a: FileItem, b: FileItem): number => {
			if (a.isDirectory != b.isDirectory) {
				return a.isDirectory ? -1 : 1
			}
			if (a.name < b.name) {
				return -1
			}
			if (a.name > b.name) {
				return 1
			}
			return 0
		})
	}
	sortGroup(userRootItems)
	sortGroup(sandboxItems)
	sortGroup(internalItems)
	sortGroup(groupItems)
	sortGroup(agentItems)

	// 按顺序拼接：用户目录 → Agent → 群聊 → 其它目录
	const result: FileItem[] = []
	for (let i = 0; i < userRootItems.length; i++) {
		result.push(userRootItems[i])
	}
	for (let i = 0; i < agentItems.length; i++) {
		result.push(agentItems[i])
	}
	for (let i = 0; i < groupItems.length; i++) {
		result.push(groupItems[i])
	}
	for (let i = 0; i < sandboxItems.length; i++) {
		result.push(sandboxItems[i])
	}
	for (let i = 0; i < internalItems.length; i++) {
		result.push(internalItems[i])
	}
	return result
}

/**
 * 递归合并源目录中目标目录缺失的文件，目标已有内容不覆盖。
 */
function mergeMissingItems(srcDir: string, destDir: string, depth: number): void {
	if (depth > 8) {
		return
	}
	const items = listDir(srcDir)
	for (let i = 0; i < items.length; i++) {
		const item = items[i]
		const targetPath = joinPath(destDir, item.name)
		if (exists(targetPath)) {
			if (item.isDirectory) {
				const targetStat = statItem(targetPath)
				if (targetStat.isDirectory) {
					mergeMissingItems(item.path, targetPath, depth + 1)
				}
			}
			continue
		}
		copyItem(item.path, targetPath)
	}
}

/**
 * 无损迁移旧版 `agents/__user__` 目录到新的用户目录。
 * 已存在的同名文件不会覆盖，避免误伤用户手动整理过的数据。
 */
export function migrateLegacyUserDir(): void {
	const migrated = getAppSetting(LEGACY_USER_DIR_MIGRATED_KEY)
	if (migrated == '1') {
		return
	}
	const legacyDir = getLegacyUserAgentDir()
	const filesDir = getInternalFilesDir()
	if (legacyDir == '' || filesDir == '') {
		return
	}
	const userDir = filesDir + '/user'
	if (userDir == '' || legacyDir == userDir) {
		setAppSetting(LEGACY_USER_DIR_MIGRATED_KEY, '1')
		return
	}
	if (!exists(legacyDir)) {
		setAppSetting(LEGACY_USER_DIR_MIGRATED_KEY, '1')
		return
	}
	// LEGACY_COMPAT: 只在新 user 目录还没出现时做一次旧目录迁移，避免已删除文件反复复活。
	if (exists(userDir) == true) {
		setAppSetting(LEGACY_USER_DIR_MIGRATED_KEY, '1')
		return
	}
	createDir(userDir, true)
	mergeMissingItems(legacyDir, userDir, 0)
	setAppSetting(LEGACY_USER_DIR_MIGRATED_KEY, '1')
}
