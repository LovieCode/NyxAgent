/**
 * 首页私聊 / 群聊列表投影工具。
 *
 * 把 Agent、GroupChat、最近会话记录转成页面可直接渲染的 UTSJSONObject，避免页面塞业务映射逻辑。
 */

import { getConversationsByAgent } from '@/utils/database.uts'
import {
	type GroupChat,
	displaySessionTitle,
	ensureGroupActiveSession,
	getActiveGroupMembers,
} from '@/utils/group-chat-service.uts'

function readStringField(obj: UTSJSONObject, key: string): string {
	const value = obj[key] as string | null
	return value != null ? value : ''
}

function readNumberField(obj: UTSJSONObject, key: string): number {
	const value = obj[key] as number | null
	return value != null ? value : 0
}

function readBooleanishField(obj: UTSJSONObject, boolKey: string, numberKey: string): boolean {
	const boolValue = obj[boolKey] as boolean | null
	if (boolValue == true) { return true }
	const numberValue = obj[numberKey] as number | null
	if (numberValue != null && numberValue > 0) { return true }
	const textValue = obj[boolKey] as string | null
	if (textValue == 'true' || textValue == '1') { return true }
	return false
}

/** 安全获取私聊头像路径 */
export function readAgentListAvatar(agent: UTSJSONObject): string {
	return readStringField(agent, 'avatar')
}

/** 获取私聊状态描述（优先显示最新对话预览） */
export function readAgentListStatus(agent: UTSJSONObject): string {
	const id = readStringField(agent, 'id')
	if (id == '') { return readStringField(agent, 'desc') }
	try {
		const convs = getConversationsByAgent(id)
		if (convs.length > 0) {
			const latest = convs[0]
			const preview = readStringField(latest, 'preview')
			if (preview != '') {
				return preview
			}
		}
	} catch (_e: any) {
		// 忽略错误，回退到静态描述
	}
	return readStringField(agent, 'desc')
}

export function readAgentListUpdatedAt(agentId: string): number {
	try {
		const convs = getConversationsByAgent(agentId)
		if (convs.length > 0) {
			const latest = convs[0]
			const rawTime = readNumberField(latest, 'updated_at')
			if (rawTime > 0) {
				return rawTime
			}
		}
	} catch (_e: any) {
	}
	return 0
}

export function readGroupListSummary(group: GroupChat): string {
	const members = getActiveGroupMembers(group.id)
	const session = ensureGroupActiveSession(group)
	return members.length.toString() + ' 个成员 · 当前会话：' + displaySessionTitle(session)
}

function pushAgentChatItems(result: UTSJSONObject[], agents: UTSJSONObject[]): void {
	for (let i = 0; i < agents.length; i++) {
		const agent = agents[i]
		const id = readStringField(agent, 'id')
		if (id == '') { continue }
		result.push({
			type: 'agent',
			id: id,
			name: readStringField(agent, 'name'),
			desc: readAgentListStatus(agent),
			icon: readStringField(agent, 'icon'),
			avatar: readAgentListAvatar(agent),
			updatedAt: readAgentListUpdatedAt(id),
			favorite: readBooleanishField(agent, 'favorite', 'pinned') || readBooleanishField(agent, 'starred', 'pinned'),
		} as UTSJSONObject)
	}
}

function pushGroupChatItems(result: UTSJSONObject[], groups: GroupChat[]): void {
	for (let i = 0; i < groups.length; i++) {
		const group = groups[i]
		result.push({
			type: 'group',
			id: group.id,
			name: group.name,
			desc: readGroupListSummary(group),
			icon: 'robot',
			avatar: group.avatar,
			updatedAt: group.updatedAt,
			favorite: false,
		} as UTSJSONObject)
	}
}

export function buildAgentChatList(agents: UTSJSONObject[], groups: GroupChat[]): UTSJSONObject[] {
	const result: UTSJSONObject[] = []
	pushAgentChatItems(result, agents)
	pushGroupChatItems(result, groups)
	result.sort((a: UTSJSONObject, b: UTSJSONObject): number => {
		const av = readNumberField(a, 'updatedAt')
		const bv = readNumberField(b, 'updatedAt')
		if (av == bv) { return 0 }
		return av > bv ? -1 : 1
	})
	return result
}

export function readAgentChatKey(item: UTSJSONObject): string {
	const type = readStringField(item, 'type')
	const id = readStringField(item, 'id')
	return (type != '' ? type : 'chat') + '-' + id
}

export function readAgentChatId(item: UTSJSONObject): string {
	return readStringField(item, 'id')
}

export function isAgentGroupChatItem(item: UTSJSONObject): boolean {
	return readStringField(item, 'type') == 'group'
}

export function findAgentSourceByChatId(agents: UTSJSONObject[], agentId: string): UTSJSONObject | null {
	if (agentId == '') { return null }
	for (let i = 0; i < agents.length; i++) {
		if (readStringField(agents[i], 'id') == agentId) {
			return agents[i]
		}
	}
	return null
}

export function findGroupSourceByChatId(groups: GroupChat[], groupId: string): GroupChat | null {
	if (groupId == '') { return null }
	for (let i = 0; i < groups.length; i++) {
		if (groups[i].id == groupId) {
			return groups[i]
		}
	}
	return null
}

export function readAgentChatName(item: UTSJSONObject): string {
	const name = readStringField(item, 'name')
	return name != '' ? name : '未命名会话'
}

export function readAgentChatDesc(item: UTSJSONObject): string {
	const desc = readStringField(item, 'desc')
	return desc != '' ? desc : '点进去开始聊天'
}

export function readAgentChatAvatar(item: UTSJSONObject): string {
	return readStringField(item, 'avatar')
}

export function readAgentChatIcon(item: UTSJSONObject): string {
	if (isAgentGroupChatItem(item)) { return 'robot' }
	const icon = readStringField(item, 'icon')
	return icon != '' ? icon : 'robot'
}

export function formatAgentChatTime(item: UTSJSONObject): string {
	const timestamp = readNumberField(item, 'updatedAt')
	if (timestamp <= 0) { return '' }
	const d = new Date(timestamp)
	const month = (d.getMonth() + 1).toString()
	const day = d.getDate().toString()
	const hour = d.getHours() < 10 ? '0' + d.getHours().toString() : d.getHours().toString()
	const minute = d.getMinutes() < 10 ? '0' + d.getMinutes().toString() : d.getMinutes().toString()
	return month + '/' + day + ' ' + hour + ':' + minute
}
