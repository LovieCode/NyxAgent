/**
 * Agent 文件系统沙箱
 *
 * 每个 Agent 拥有独立子目录 /data/data/<pkg>/files/agents/<agentId>/，
 * 文件操作不能越界。底层委托统一的 file-manager.uts 执行实际 IO。
 *
 * 平台兼容：
 * - Android：file-manager.uts 调用 java.io.File 原生 API
 * - 其他平台：file-manager.uts 调用 FileSystemManager（仅支持外部沙盒）
 */

import {
	exists,
	listDir,
	statItem,
	createDir,
	deleteItem,
	readContent,
	writeContent,
	getInternalFilesDir,
	FileItem,
} from '@/utils/file-manager.uts'

/** 文件信息 */
export type AgentFileInfo = {
	name: string
	isDirectory: boolean
	size: number
	lastModified: number
}

/**
 * 校验 agentId，避免拼进路径时越权。
 */
function validateAgentId(agentId: string): boolean {
	if (agentId == '') return false
	if (agentId.indexOf('/') >= 0) return false
	if (agentId.indexOf('\\') >= 0) return false
	if (agentId.indexOf('..') >= 0) return false
	return true
}

/**
 * 校验相对路径安全性
 */
function validatePath(relativePath: string): string | null {
	if (relativePath == '' || relativePath == '.') return null
	if (relativePath.startsWith('/')) return '不允许使用绝对路径'
	if (relativePath.indexOf('\\') >= 0) return '路径不允许包含反斜杠'
	const segments = relativePath.split('/')
	for (let i = 0; i < segments.length; i++) {
		if (segments[i] == '..') return '路径不允许包含 ".."'
	}
	return null
}

/**
 * 获取所有 Agent 存储的根目录
 */
function getAgentsRoot(): string {
	const filesDir = getInternalFilesDir()
	if (filesDir == '') {
		return ''
	}
	return filesDir + '/agents'
}

/**
 * 获取 agent 存储目录路径
 */
export function getAgentStoragePath(agentId: string): string {
	if (!validateAgentId(agentId)) return ''
	const root = getAgentsRoot()
	if (root == '') return ''
	return root + '/' + agentId
}

/**
 * 解析安全的完整路径
 */
function resolvePath(agentId: string, relativePath: string): string {
	if (!validateAgentId(agentId)) return ''
	const err = validatePath(relativePath)
	if (err != null) return ''
	const base = getAgentStoragePath(agentId)
	if (base == '') return ''
	if (relativePath == '' || relativePath == '.') return base
	return base + '/' + relativePath
}

/** FileItem → AgentFileInfo 转换 */
function toAgentFileInfo(item: FileItem): AgentFileInfo {
	return {
		name: item.name,
		isDirectory: item.isDirectory,
		size: item.size,
		lastModified: item.lastModified,
	} as AgentFileInfo
}

/** 初始化 agent 存储目录 */
export function initAgentStorage(agentId: string): boolean {
	const dirPath = getAgentStoragePath(agentId)
	if (dirPath == '') return false
	if (exists(dirPath)) return true
	const result = createDir(dirPath, true)
	return result.ok
}

/** 删除 agent 整个存储目录 */
export function removeAgentStorage(agentId: string): boolean {
	const dirPath = getAgentStoragePath(agentId)
	if (dirPath == '') return false
	if (!exists(dirPath)) return true
	const result = deleteItem(dirPath, true)
	return result.ok
}

/** 读取 agent 文件内容 */
export function readAgentFile(agentId: string, filePath: string): string | null {
	const fullPath = resolvePath(agentId, filePath)
	if (fullPath == '') return null
	return readContent(fullPath)
}

/** 写入 agent 文件 */
export function writeAgentFile(agentId: string, filePath: string, content: string): boolean {
	const fullPath = resolvePath(agentId, filePath)
	if (fullPath == '') return false
	const result = writeContent(fullPath, content)
	return result.ok
}

/** 删除 agent 文件 */
export function deleteAgentFile(agentId: string, filePath: string): boolean {
	const fullPath = resolvePath(agentId, filePath)
	if (fullPath == '') return false
	if (!exists(fullPath)) return true
	const result = deleteItem(fullPath, false)
	return result.ok
}

/** 列出 agent 目录内容 */
export function listAgentFiles(agentId: string, dirPath: string = ''): AgentFileInfo[] {
	const fullPath = resolvePath(agentId, dirPath)
	if (fullPath == '') return []
	const items = listDir(fullPath)
	const result: AgentFileInfo[] = []
	for (let i = 0; i < items.length; i++) {
		result.push(toAgentFileInfo(items[i]))
	}
	return result
}

/** 检查文件/目录是否存在 */
export function agentFileExists(agentId: string, path: string): boolean {
	const fullPath = resolvePath(agentId, path)
	if (fullPath == '') return false
	return exists(fullPath)
}

/** 获取文件信息 */
export function getAgentFileInfo(agentId: string, path: string): AgentFileInfo | null {
	const fullPath = resolvePath(agentId, path)
	if (fullPath == '') return null
	if (!exists(fullPath)) return null
	const item = statItem(fullPath)
	return toAgentFileInfo(item)
}

/** 创建子目录 */
export function createAgentDirectory(agentId: string, dirPath: string): boolean {
	const fullPath = resolvePath(agentId, dirPath)
	if (fullPath == '') return false
	const result = createDir(fullPath, true)
	return result.ok
}

/**
 * 获取 agent 目录总大小（递归计算字节数）。
 */
export function getAgentStorageSize(agentId: string): number {
	const dirPath = getAgentStoragePath(agentId)
	if (dirPath == '') return 0
	if (!exists(dirPath)) return 0
	return calculateDirSize(dirPath)
}

/** 递归计算目录总大小 */
function calculateDirSize(dirPath: string): number {
	let total: number = 0
	const items = listDir(dirPath)
	for (let i = 0; i < items.length; i++) {
		const child = items[i]
		if (child.isDirectory) {
			total = total + calculateDirSize(child.path)
		} else {
			total = total + child.size
		}
	}
	return total
}
