/**
 * Agent 文件系统沙箱
 * 桥接到 utssdk/agent-files 原生插件
 * 每个 Agent 拥有独立子目录，文件操作不能越界
 */

// #ifdef APP-ANDROID
import {
	initAgentStorage as nativeInit,
	removeAgentStorage as nativeRemove,
	readAgentFile as nativeRead,
	writeAgentFile as nativeWrite,
	deleteAgentFile as nativeDelete,
	listAgentFiles as nativeList,
	agentFileExists as nativeExists,
	getAgentFileInfo as nativeInfo,
	createAgentDirectory as nativeMkdir,
	getAgentStoragePath as nativeGetPath,
	getAgentStorageSize as nativeGetSize,
} from '@/utssdk/agent-files/index.uts'
// #endif

/** 文件信息 */
export type AgentFileInfo = {
	name: string
	isDirectory: boolean
	size: number
	lastModified: number
}

/** 获取 agent 存储目录路径 */
export function getAgentStoragePath(agentId: string): string {
	// #ifdef APP-ANDROID
	return nativeGetPath(agentId)
	// #endif
	return ''
}

/** 初始化 agent 存储目录 */
export function initAgentStorage(agentId: string): boolean {
	// #ifdef APP-ANDROID
	return nativeInit(agentId)
	// #endif
	return false
}

/** 删除 agent 整个存储目录 */
export function removeAgentStorage(agentId: string): boolean {
	// #ifdef APP-ANDROID
	return nativeRemove(agentId)
	// #endif
	return false
}

/** 读取 agent 文件 */
export function readAgentFile(agentId: string, filePath: string): string | null {
	// #ifdef APP-ANDROID
	return nativeRead(agentId, filePath)
	// #endif
	return null
}

/** 写入 agent 文件 */
export function writeAgentFile(agentId: string, filePath: string, content: string): boolean {
	// #ifdef APP-ANDROID
	return nativeWrite(agentId, filePath, content)
	// #endif
	return false
}

/** 删除 agent 文件 */
export function deleteAgentFile(agentId: string, filePath: string): boolean {
	// #ifdef APP-ANDROID
	return nativeDelete(agentId, filePath)
	// #endif
	return false
}

/** 列出 agent 目录内容 */
export function listAgentFiles(agentId: string, dirPath: string = ''): AgentFileInfo[] {
	// #ifdef APP-ANDROID
	const json = nativeList(agentId, dirPath)
	if (json == '[]') return []
	try {
		const arr = JSON.parse(json) as UTSJSONObject[]
		if (arr == null) return []
		const result: AgentFileInfo[] = []
		for (let i = 0; i < arr.length; i++) {
			const rawName = arr[i]['name'] as string | null
			const rawIsDirectory = arr[i]['isDirectory'] as boolean | null
			const rawSize = arr[i]['size'] as number | null
			const rawLastModified = arr[i]['lastModified'] as number | null
			result.push({
				name: rawName != null ? rawName : '',
				isDirectory: rawIsDirectory != null ? rawIsDirectory : false,
				size: rawSize != null ? rawSize : 0,
				lastModified: rawLastModified != null ? rawLastModified : 0,
			} as AgentFileInfo)
		}
		return result
	} catch (_) {
		return []
	}
	// #endif
	return []
}

/** 检查文件/目录是否存在 */
export function agentFileExists(agentId: string, path: string): boolean {
	// #ifdef APP-ANDROID
	return nativeExists(agentId, path)
	// #endif
	return false
}

/** 获取文件信息 */
export function getAgentFileInfo(agentId: string, path: string): AgentFileInfo | null {
	// #ifdef APP-ANDROID
	const json = nativeInfo(agentId, path)
	if (json == null) return null
	try {
		const jsonText = json as string
		const obj = JSON.parse(jsonText) as UTSJSONObject
		if (obj == null) return null
		const rawName = obj['name'] as string | null
		const rawIsDirectory = obj['isDirectory'] as boolean | null
		const rawSize = obj['size'] as number | null
		const rawLastModified = obj['lastModified'] as number | null
		return {
			name: rawName != null ? rawName : '',
			isDirectory: rawIsDirectory != null ? rawIsDirectory : false,
			size: rawSize != null ? rawSize : 0,
			lastModified: rawLastModified != null ? rawLastModified : 0,
		} as AgentFileInfo
	} catch (_) {
		return null
	}
	// #endif
	return null
}

/** 创建子目录 */
export function createAgentDirectory(agentId: string, dirPath: string): boolean {
	// #ifdef APP-ANDROID
	return nativeMkdir(agentId, dirPath)
	// #endif
	return false
}

/** 获取 agent 目录总大小 */
export function getAgentStorageSize(agentId: string): number {
	// #ifdef APP-ANDROID
	return nativeGetSize(agentId)
	// #endif
	return 0
}
