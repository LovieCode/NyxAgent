/**
 * 语音运行时工具。
 *
 * 负责 Provider 配置解析、缓存文件写入、错误预览和 TTS 参数归一化；不直接发起 TTS 请求。
 */

import { getDefaultTaskModel, getProviderById, getProviderModels, normalizeBaseUrl, TTS_ADAPTER_OPENAI_COMPAT } from '@/uni_modules/agent-core/utssdk/provider.uts'
import { getInternalCacheDir, createDir, exists, deleteItem } from '@/utils/file-manager.uts'
import { getAgentById } from '@/utils/agent.uts'

// #ifdef APP-ANDROID
import File from 'java.io.File'
import Base64 from 'android.util.Base64'
// #endif

export type SpeechTextResult = {
	ok: boolean
	text: string
	error: string
}

export type SpeechAudioResult = {
	ok: boolean
	path: string
	error: string
}

export type SpeechConfig = {
	providerId: string
	apiKey: string
	baseUrl: string
	model: string
	ttsAdapter: string
	ttsVoice: string
	ttsResponseFormat: string
	ttsSpeed: string
	ttsVolume: string
	ttsPitch: string
	ttsExtraParams: string
}

let lastSpeechWriteError = ''

export function failText(error: string): SpeechTextResult {
	return {
		ok: false,
		text: '',
		error: error,
	} as SpeechTextResult
}

export function okText(text: string): SpeechTextResult {
	return {
		ok: true,
		text: text,
		error: '',
	} as SpeechTextResult
}

export function failAudio(error: string): SpeechAudioResult {
	return {
		ok: false,
		path: '',
		error: error,
	} as SpeechAudioResult
}

export function okAudio(path: string): SpeechAudioResult {
	return {
		ok: true,
		path: path,
		error: '',
	} as SpeechAudioResult
}

function clearSpeechWriteError(): void {
	lastSpeechWriteError = ''
}

function setSpeechWriteError(prefix: string, error: any | null): void {
	const raw = error != null ? ('' + error) : ''
	lastSpeechWriteError = raw != '' ? prefix + '：' + raw : prefix
	console.log('[Speech] ' + lastSpeechWriteError)
}

export function buildSpeechWriteErrorMessage(): string {
	if (lastSpeechWriteError != '') {
		return '语音文件写入失败：' + lastSpeechWriteError
	}
	return '语音文件写入失败'
}

export function buildAudioApiUrl(baseUrl: string, path: string): string {
	const normalized = normalizeBaseUrl(baseUrl)
	const hasApiVersion = normalized.indexOf('/v1') >= 0 || normalized.indexOf('/api/v') >= 0
	if (hasApiVersion == true) {
		return normalized + path
	}
	return normalized + '/v1' + path
}

function readProviderString(provider: UTSJSONObject, key: string): string {
	const raw = provider[key] as string | null
	return raw != null ? raw : ''
}

function readTaskString(task: UTSJSONObject, key: string): string {
	const raw = task[key] as string | null
	return raw != null ? raw : ''
}

function getDefaultAudioBaseUrl(providerId: string): string {
	if (providerId == 'openai') { return 'https://api.openai.com' }
	return ''
}

export function resolveSpeechConfig(type: string, agentId: string = ''): SpeechConfig | null {
	const task = getDefaultTaskModel(type)
	if (task == null) { return null }
	const providerIdRaw = task['providerId'] as string | null
	const modelRaw = task['model'] as string | null
	const providerId = providerIdRaw != null ? providerIdRaw : ''
	const model = modelRaw != null ? modelRaw : ''
	if (providerId == '' || model == '') { return null }
	const provider = getProviderById(providerId)
	if (provider == null) { return null }
	const apiKey = readProviderString(provider, 'api_key')
	let baseUrl = readProviderString(provider, 'api_base')
	if (baseUrl == '') {
		baseUrl = getDefaultAudioBaseUrl(providerId)
	}
	if (apiKey == '' || baseUrl == '') { return null }
	let ttsAdapter = ''
	let ttsVoice = ''
	let ttsResponseFormat = ''
	let ttsSpeed = ''
	let ttsVolume = ''
	let ttsPitch = ''
	let ttsExtraParams = ''
	if (type == 'tts') {
		ttsAdapter = readTaskString(task, 'ttsAdapter')
		if (ttsAdapter == '') { ttsAdapter = TTS_ADAPTER_OPENAI_COMPAT }
		ttsVoice = readTaskString(task, 'ttsVoice')
		ttsResponseFormat = readTaskString(task, 'ttsResponseFormat')
		ttsSpeed = readTaskString(task, 'ttsSpeed')
		ttsVolume = readTaskString(task, 'ttsVolume')
		ttsPitch = readTaskString(task, 'ttsPitch')
		ttsExtraParams = readTaskString(task, 'ttsExtraParams')
		if (agentId != '') {
			const agent = getAgentById(agentId)
			if (agent != null) {
				const agentVoice = readTaskString(agent, 'ttsVoice')
				const agentVolume = readTaskString(agent, 'ttsVolume')
				const agentPitch = readTaskString(agent, 'ttsPitch')
				if (agentVoice != '') { ttsVoice = agentVoice }
				if (agentVolume != '') { ttsVolume = agentVolume }
				if (agentPitch != '') { ttsPitch = agentPitch }
			}
		}
	}
	return {
		providerId: providerId,
		apiKey: apiKey,
		baseUrl: baseUrl,
		model: model,
		ttsAdapter: ttsAdapter,
		ttsVoice: ttsVoice,
		ttsResponseFormat: ttsResponseFormat,
		ttsSpeed: ttsSpeed,
		ttsVolume: ttsVolume,
		ttsPitch: ttsPitch,
		ttsExtraParams: ttsExtraParams,
	} as SpeechConfig
}

export function readTranscriptionText(data: any | null): string {
	if (data == null) { return '' }
	if (typeof data == 'string') {
		try {
			const obj = JSON.parse(data as string) as UTSJSONObject
			const parsedText = obj['text'] as string | null
			return parsedText != null ? parsedText.trim() : ''
		} catch (_e: any) {
			return ''
		}
	}
	const obj = data as UTSJSONObject
	const text = obj['text'] as string | null
	return text != null ? text.trim() : ''
}

function getSpeechCacheDirPath(): string {
	const root = getInternalCacheDir()
	if (root == '') { return '' }
	return root + '/speech'
}

export function getSpeechTempDir(): string {
	return getSpeechCacheDirPath()
}

export function buildSpeechCacheDir(): string {
	const dir = getSpeechCacheDirPath()
	if (dir == '') { return '' }
	if (exists(dir) == false) {
		createDir(dir)
	}
	return dir
}

export function clearSpeechTempFiles(): boolean {
	const dir = getSpeechCacheDirPath()
	if (dir == '') { return false }
	if (exists(dir) == false) { return true }
	const result = deleteItem(dir, true)
	if (result.ok == false) {
		console.log('[Speech] 清理语音缓存失败: ' + result.error)
		return false
	}
	return true
}

export function writeArrayBufferToFile(path: string, data: ArrayBuffer): boolean {
	if (path == '') { return false }
	clearSpeechWriteError()
	try {
		const fm = uni.getFileSystemManager()
		// UTS 签名要求 encoding 必填；ArrayBuffer 会按二进制写入，不能传非法 binary。
		fm.writeFileSync(path, data, 'utf-8')
		return true
	} catch (e: any) {
		setSpeechWriteError('写入音频失败', e)
		return false
	}
}

function normalizeBase64Audio(data: string): string {
	let text = data.trim()
	const commaIndex = text.indexOf(',')
	if (text.indexOf('base64,') >= 0 && commaIndex >= 0) {
		text = text.substring(commaIndex + 1)
	}
	while (text.indexOf('\n') >= 0) {
		text = text.replace('\n', '')
	}
	while (text.indexOf('\r') >= 0) {
		text = text.replace('\r', '')
	}
	return text
}

export function writeBase64ToFile(path: string, data: string): boolean {
	if (path == '' || data == '') { return false }
	clearSpeechWriteError()
	const base64 = normalizeBase64Audio(data)
	// #ifdef APP-ANDROID
	try {
		const file = new File(path)
		const parent = file.parentFile
		if (parent != null && parent.exists() == false) {
			parent.mkdirs()
		}
		file.writeBytes(Base64.decode(base64, Base64.DEFAULT))
		return true
	} catch (e: any) {
		setSpeechWriteError('Android 写入 base64 音频失败', e)
		return false
	}
	// #endif
	// #ifndef APP-ANDROID
	try {
		const fm = uni.getFileSystemManager()
		fm.writeFileSync(path, base64, 'base64')
		return true
	} catch (e: any) {
		setSpeechWriteError('写入 base64 音频失败', e)
		return false
	}
	// #endif
}

function decodeArrayBuffer(buffer: ArrayBuffer): string {
	const bytes = new Uint8Array(buffer)
	let result = ''
	let i = 0
	while (i < bytes.length) {
		const b1 = bytes[i]
		if (b1 < 0x80) {
			result += String.fromCharCode(b1)
			i += 1
		} else if (b1 >= 0xC0 && b1 < 0xE0) {
			const b2 = bytes[i + 1]
			result += String.fromCharCode(((b1 & 0x1F) << 6) | (b2 & 0x3F))
			i += 2
		} else if (b1 >= 0xE0 && b1 < 0xF0) {
			const b2 = bytes[i + 1]
			const b3 = bytes[i + 2]
			result += String.fromCharCode(((b1 & 0x0F) << 12) | ((b2 & 0x3F) << 6) | (b3 & 0x3F))
			i += 3
		} else if (b1 >= 0xF0) {
			const b2 = bytes[i + 1]
			const b3 = bytes[i + 2]
			const b4 = bytes[i + 3]
			const code = ((b1 & 0x07) << 18) | ((b2 & 0x3F) << 12) | ((b3 & 0x3F) << 6) | (b4 & 0x3F)
			const sc = code - 0x10000
			result += String.fromCharCode(0xD800 + (sc >> 10))
			result += String.fromCharCode(0xDC00 + (sc & 0x3FF))
			i += 4
		} else {
			i += 1
		}
	}
	return result
}

export function parseJSONObject(text: string): UTSJSONObject | null {
	if (text.trim() == '') { return null }
	try {
		const parsed = JSON.parse(text)
		if (parsed == null || typeof parsed != 'object') { return null }
		return parsed as UTSJSONObject
	} catch (_e: any) {
		return null
	}
}

export function resolveModelParams(providerId: string, model: string): UTSJSONObject | null {
	const models = getProviderModels(providerId)
	for (let i = 0; i < models.length; i++) {
		if (models[i].id == model) {
			const rawParams = models[i].params
			const params = rawParams != null ? rawParams : ''
			return parseJSONObject(params)
		}
	}
	return null
}

function readParamAsString(params: UTSJSONObject | null, key: string): string {
	if (params == null) { return '' }
	const raw = params[key]
	if (raw == null) { return '' }
	if (typeof raw == 'string') { return (raw as string).trim() }
	if (typeof raw == 'number') { return (raw as number) + '' }
	if (typeof raw == 'boolean') { return (raw as boolean) == true ? 'true' : 'false' }
	return ''
}

export function readFirstParam(params: UTSJSONObject | null, keys: string[]): string {
	for (let i = 0; i < keys.length; i++) {
		const value = readParamAsString(params, keys[i])
		if (value != '') { return value }
	}
	return ''
}

function clampNumber(value: number, min: number, max: number): number {
	if (value < min) { return min }
	if (value > max) { return max }
	return value
}

export function parseNumberSetting(value: string, fallback: number, min: number, max: number): number {
	if (value.trim() == '') { return fallback }
	const parsed = parseFloat(value)
	if (isNaN(parsed)) { return fallback }
	return clampNumber(parsed, min, max)
}

export function getTTSOutputExtension(format: string): string {
	const f = format.trim().toLowerCase()
	if (f.indexOf('mp3') == 0) { return 'mp3' }
	if (f.indexOf('opus') == 0) { return 'opus' }
	if (f.indexOf('aac') == 0) { return 'aac' }
	if (f.indexOf('flac') == 0) { return 'flac' }
	if (f.indexOf('pcm') == 0) { return 'pcm' }
	return 'wav'
}

function buildArrayBufferErrorPreview(data: any | null): string {
	if (data == null) { return '' }
	try {
		const text = decodeArrayBuffer(data as ArrayBuffer)
		const trimmed = text.trim()
		if (trimmed == '') { return '' }
		return trimmed.substring(0, trimmed.length < 180 ? trimmed.length : 180)
	} catch (_e: any) {
		return ''
	}
}

function readErrorMessageFromObject(obj: UTSJSONObject | null): string {
	if (obj == null) { return '' }
	const message = obj['message'] as string | null
	if (message != null && message != '') { return message }
	const errorMessage = obj['error_message'] as string | null
	if (errorMessage != null && errorMessage != '') { return errorMessage }
	const errorMsg = obj['error_msg'] as string | null
	if (errorMsg != null && errorMsg != '') { return errorMsg }
	const error = obj['error']
	if (error == null) { return '' }
	if (typeof error == 'string') { return (error as string) }
	if (typeof error == 'object') {
		const errorObj = error as UTSJSONObject
		const nestedMessage = errorObj['message'] as string | null
		if (nestedMessage != null && nestedMessage != '') { return nestedMessage }
		const nestedCode = errorObj['code'] as string | null
		if (nestedCode != null && nestedCode != '') { return nestedCode }
	}
	return ''
}

function buildTextErrorPreview(text: string): string {
	const trimmed = text.trim()
	if (trimmed == '') { return '' }
	const parsed = parseJSONObject(trimmed)
	const message = readErrorMessageFromObject(parsed)
	if (message != '') { return message }
	return trimmed.substring(0, trimmed.length < 180 ? trimmed.length : 180)
}

export function buildJsonErrorPreview(data: any | null): string {
	if (data == null) { return '' }
	try {
		if (typeof data == 'string') { return buildTextErrorPreview(data as string) }
		const message = readErrorMessageFromObject(data as UTSJSONObject)
		if (message != '') { return message }
		return buildTextErrorPreview(JSON.stringify(data))
	} catch (_e: any) {
		return ''
	}
}

export function buildSpeechErrorPreview(data: any | null): string {
	const jsonPreview = buildJsonErrorPreview(data)
	if (jsonPreview != '') { return jsonPreview }
	return buildArrayBufferErrorPreview(data)
}

function isOpenAIProvider(config: SpeechConfig): boolean {
	const normalized = normalizeBaseUrl(config.baseUrl).toLowerCase()
	return config.providerId == 'openai' || normalized.indexOf('api.openai.com') >= 0
}

function resolveOpenAITTSVoice(config: SpeechConfig, modelParams: UTSJSONObject | null, extraParams: UTSJSONObject | null): string {
	let voice = config.ttsVoice.trim()
	if (voice != '') { return voice }
	voice = readFirstParam(extraParams, ['voice', 'openai-tts-voice', 'dashscope_tts_voice', 'mimo-tts-voice', 'edge-tts-voice'])
	if (voice != '') { return voice }
	voice = readFirstParam(modelParams, ['voice', 'openai-tts-voice', 'dashscope_tts_voice', 'mimo-tts-voice', 'edge-tts-voice'])
	if (voice != '') { return voice }
	if (isOpenAIProvider(config) == true) { return 'alloy' }
	return ''
}

function resolveOpenAITTSFormat(config: SpeechConfig, modelParams: UTSJSONObject | null, extraParams: UTSJSONObject | null): string {
	let format = config.ttsResponseFormat.trim()
	if (format != '') { return format }
	format = readFirstParam(extraParams, ['response_format', 'format', 'openai-tts-format'])
	if (format != '') { return format }
	format = readFirstParam(modelParams, ['response_format', 'format', 'openai-tts-format'])
	if (format != '') { return format }
	return ''
}

function resolveOpenAITTSSpeed(config: SpeechConfig, modelParams: UTSJSONObject | null, extraParams: UTSJSONObject | null): string {
	let speed = config.ttsSpeed.trim()
	if (speed != '') { return speed }
	speed = readFirstParam(extraParams, ['speed', 'openai-tts-speed'])
	if (speed != '') { return speed }
	return readFirstParam(modelParams, ['speed', 'openai-tts-speed'])
}

export function buildOpenAITTSBody(content: string, config: SpeechConfig): UTSJSONObject {
	const modelParams = resolveModelParams(config.providerId, config.model)
	const extraParams = parseJSONObject(config.ttsExtraParams)
	const voice = resolveOpenAITTSVoice(config, modelParams, extraParams)
	const responseFormat = resolveOpenAITTSFormat(config, modelParams, extraParams)
	const speedText = resolveOpenAITTSSpeed(config, modelParams, extraParams)
	const body: UTSJSONObject = {
		model: config.model,
		input: content,
	} as UTSJSONObject
	if (voice != '') {
		body['voice'] = voice
	}
	if (responseFormat != '') {
		body['response_format'] = responseFormat
	}
	if (speedText != '') {
		body['speed'] = parseNumberSetting(speedText, 1.0, 0.25, 4.0)
	}
	const instructions = readFirstParam(extraParams, ['instructions', 'tts_instructions'])
	if (instructions != '') {
		body['instructions'] = instructions
	}
	return body
}

export function resolveVolcengineTTSUrl(baseUrl: string): string {
	const normalized = normalizeBaseUrl(baseUrl)
	if (normalized.indexOf('openspeech.bytedance.com') >= 0) {
		if (normalized.endsWith('/tts')) { return normalized }
		if (normalized.endsWith('/api')) { return normalized + '/v1/tts' }
		return normalized + '/api/v1/tts'
	}
	return 'https://openspeech.bytedance.com/api/v1/tts'
}

export function resolveVolcengineVoice(config: SpeechConfig, modelParams: UTSJSONObject | null, extraParams: UTSJSONObject | null): string {
	let voice = config.ttsVoice.trim()
	if (voice != '') { return voice }
	voice = readFirstParam(extraParams, ['volcengine_voice_type', 'voice_type', 'voice'])
	if (voice != '') { return voice }
	return readFirstParam(modelParams, ['volcengine_voice_type', 'voice_type', 'voice'])
}

export function resolveVolcengineVolume(config: SpeechConfig, modelParams: UTSJSONObject | null, extraParams: UTSJSONObject | null): string {
	let volume = config.ttsVolume.trim()
	if (volume != '') { return volume }
	volume = readFirstParam(extraParams, ['volcengine_volume_ratio', 'volume_ratio', 'volume'])
	if (volume != '') { return volume }
	return readFirstParam(modelParams, ['volcengine_volume_ratio', 'volume_ratio', 'volume'])
}

export function resolveVolcenginePitch(config: SpeechConfig, modelParams: UTSJSONObject | null, extraParams: UTSJSONObject | null): string {
	let pitch = config.ttsPitch.trim()
	if (pitch != '') { return pitch }
	pitch = readFirstParam(extraParams, ['volcengine_pitch_ratio', 'pitch_ratio', 'pitch'])
	if (pitch != '') { return pitch }
	return readFirstParam(modelParams, ['volcengine_pitch_ratio', 'pitch_ratio', 'pitch'])
}
