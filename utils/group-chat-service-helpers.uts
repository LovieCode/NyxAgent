import { createPlainPart } from '@/utils/chat-models.uts'
import {
	GROUP_MESSAGE_AUDIENCE_GROUP,
	GROUP_MESSAGE_SENDER_REVIEWER,
	GROUP_MESSAGE_SENDER_SCHEDULER,
	GROUP_MESSAGE_VISIBILITY_PUBLIC,
	createId,
	markGroupMessageDirty,
	resolveGroupReviewerAgentId,
	resolveGroupReviewerDisplayName,
	resolveGroupSchedulerAgentId,
	resolveGroupSchedulerDisplayName,
	type GroupChat,
	type GroupChatSession,
} from '@/utils/group-chat-models.uts'
import { displaySessionTitle, readActionText } from '@/utils/group-chat-runtime.uts'
import { getAppSetting } from '@/utils/database.uts'

function readCurrentUserDisplayName(): string {
	const raw = getAppSetting('profile_nickname')
	const name = raw != null ? raw.trim() : ''
	return name != '' ? name : '我'
}

export function createGroupAgentContextRecordPayload(group: GroupChat, session: GroupChatSession, agentId: string, agentName: string, action: UTSJSONObject, runtimeMessages: UTSJSONObject[], systemPrompt: string): UTSJSONObject {
	const privateInstruction = readActionText(action, 'privateInstruction')
	const publicIntent = readActionText(action, 'publicIntent')
	const targetType = readActionText(action, 'targetType')
	const targetAgentId = readActionText(action, 'targetAgentId')
	const replyLength = readActionText(action, 'replyLength')
	const replyGuidance = readActionText(action, 'replyGuidance')
	const searchAdvice = readActionText(action, 'searchAdvice')
	const searchInstruction = readActionText(action, 'searchInstruction')
	const routeReason = readActionText(action, 'routeReason')
	const environmentFeedback = readActionText(action, 'environmentFeedback')
	const deliveryMode = readActionText(action, 'deliveryMode')
	const now = Date.now()
	return {
		id: createId('gctx'),
		agentId: agentId,
		agentName: agentName,
		groupId: group.id,
		groupName: group.name,
		sessionId: session.id,
		sessionTitle: displaySessionTitle(session),
		privateInstruction: privateInstruction,
		publicIntent: publicIntent,
		targetType: targetType,
		targetAgentId: targetAgentId,
		replyLength: replyLength,
		replyGuidance: replyGuidance,
		searchAdvice: searchAdvice,
		searchInstruction: searchInstruction,
		routeReason: routeReason,
		environmentFeedback: environmentFeedback,
		deliveryMode: deliveryMode,
		systemPrompt: systemPrompt,
		runtimeMessages: JSON.parse(JSON.stringify(runtimeMessages)) as UTSJSONObject[],
		createdAt: now,
	} as UTSJSONObject
}

export function decorateGroupMessage(base: UTSJSONObject, groupId: string, sessionId: string, senderType: string, agentId: string, agentName: string, agentAvatar: string, visible: boolean, visibility: string = GROUP_MESSAGE_VISIBILITY_PUBLIC, visibleAgentIds: string[] | null = null, audience: string = GROUP_MESSAGE_AUDIENCE_GROUP): UTSJSONObject {
	base['id'] = createId('gmsg')
	base['groupId'] = groupId
	base['sessionId'] = sessionId
	base['senderType'] = senderType
	base['senderAgentId'] = agentId
	base['senderName'] = agentName
	base['senderAvatar'] = agentAvatar
	base['visibility'] = visibility
	base['audience'] = audience
	base['visibleAgentIds'] = visibleAgentIds != null ? visibleAgentIds : ([] as string[])
	base['visible'] = visible
	base['revoked'] = false
	base['timestamp'] = Date.now()
	return base
}

export function normalizeGroupUserDisplayName(userName: string): string {
	const name = userName.trim()
	if (name != '' && name != '用户' && name != '我') { return name }
	return readCurrentUserDisplayName()
}

export function resolveGroupHiddenSenderName(group: GroupChat | null, senderType: string): string {
	if (senderType == GROUP_MESSAGE_SENDER_SCHEDULER) {
		return resolveGroupSchedulerDisplayName(group)
	}
	if (senderType == GROUP_MESSAGE_SENDER_REVIEWER) {
		return resolveGroupReviewerDisplayName(group)
	}
	return senderType
}

export function resolveGroupHiddenSenderAgentId(group: GroupChat | null, senderType: string): string {
	if (senderType == GROUP_MESSAGE_SENDER_SCHEDULER) {
		return resolveGroupSchedulerAgentId(group)
	}
	if (senderType == GROUP_MESSAGE_SENDER_REVIEWER) {
		return resolveGroupReviewerAgentId(group)
	}
	return ''
}

export function markGroupMessageRevokedFields(message: UTSJSONObject): void {
	markGroupMessageDirty(message)
	const senderName = message['senderName'] as string | null
	const name = senderName != null && senderName.trim() != '' ? senderName.trim() : '成员'
	const text = name + '撤回了一条消息'
	message['revoked'] = true
	message['content'] = text
	message['message'] = [createPlainPart(text)]
	message['isStreaming'] = false
	if ((message['deliveryStatus'] as string | null) != null) {
		message['deliveryStatus'] = 'revoked'
	}
}

export function cloneGroupMessagesForFork(oldMessages: UTSJSONObject[], forkId: string): UTSJSONObject[] {
	const copiedMessages: UTSJSONObject[] = []
	for (let i = 0; i < oldMessages.length; i++) {
		const copied = JSON.parse(JSON.stringify(oldMessages[i])) as UTSJSONObject
		copied['id'] = createId('gmsg')
		copied['sessionId'] = forkId
		if ((copied['sourceUserMessageId'] as string | null) != null) {
			// fork 后消息 ID 全部变化，改用会话内时序回执，避免引用旧会话 ID。
			copied['sourceUserMessageId'] = ''
		}
		copied['isStreaming'] = false
		copiedMessages.push(copied)
	}
	return copiedMessages
}
