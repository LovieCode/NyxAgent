/**
 * 文件管理底层 IO。
 *
 * 只放跨平台文件读写/复制/删除/统计，业务根目录、Agent 工作区和迁移逻辑留在 file-manager.uts。
 */

import {
	type FileItem,
	type FileOpResult,
	SEP,
	basename,
	failResult,
	joinPath,
	makeFileItem,
	normalizePath,
	okResult,
} from '@/utils/file-manager-models.uts'

// #ifdef APP-ANDROID
import File from 'java.io.File'
import Charset from 'java.nio.charset.Charset'
// #endif

// #ifdef APP-ANDROID
const UTF8_CHARSET = Charset.forName('UTF-8')
// #endif

/**
 * 判断路径是否存在。
 */
export function exists(path: string): boolean {
	const normalized = normalizePath(path)
	if (normalized == '') {
		return false
	}
	// #ifdef APP-ANDROID
	const absPath = toAndroidAbsPath(normalized)
	if (absPath == '') {
		return false
	}
	try {
		const file = new File(absPath)
		return file.exists()
	} catch (_e: any) {
		return false
	}
	// #endif
	// #ifndef APP-ANDROID
	const fm = uni.getFileSystemManager()
	try {
		fm.accessSync(normalized)
		return true
	} catch (_e: any) {
		return false
	}
	// #endif
}

// #ifdef APP-ANDROID
/**
 * 将路径转换为 Android 绝对路径。
 * unifile:// 路径通过 UTSAndroid.convert2AbsFullPath 转换，
 * file:// 路径去掉协议前缀，其他路径原样返回。
 */
function toAndroidAbsPath(path: string): string {
	if (path == '') {
		return ''
	}
	if (path.startsWith('unifile://')) {
		try {
			return UTSAndroid.convert2AbsFullPath(path)
		} catch (_e: any) {
			return ''
		}
	}
	if (path.startsWith('file://')) {
		return path.substring(7)
	}
	return path
}
// #endif

/**
 * 列出指定目录下的文件和文件夹。
 *
 * @param dirPath 目录路径
 * @returns 文件项数组，目录不存在或为空返回空数组。文件夹排前，文件排后，各自按名称排序。
 */
export function listDir(dirPath: string): FileItem[] {
	const normalized = normalizePath(dirPath)
	if (normalized == '') {
		return []
	}
	const items: FileItem[] = []
	// #ifdef APP-ANDROID
	const absPath = toAndroidAbsPath(normalized)
	if (absPath == '') {
		return []
	}
	try {
		const dir = new File(absPath)
		if (!dir.exists() || !dir.isDirectory()) {
			return []
		}
		const names = dir.list()
		if (names == null) {
			return []
		}
		let idx = 0 as Int
		while (idx < names.size) {
			const name = names[idx]
			if (name != '.' && name != '..') {
				const childPath = joinPath(normalized, name)
				const childAbsPath = absPath + SEP + name
				const stat = statItemByAbsPath(childAbsPath, childPath)
				items.push(stat)
			}
			idx++
		}
	} catch (_e: any) {
		return []
	}
	// #endif
	// #ifndef APP-ANDROID
	const fm = uni.getFileSystemManager()
	let names: string[]
	try {
		names = fm.readdirSync(normalized) as string[]
	} catch (_e: any) {
		return []
	}
	for (let i = 0; i < names.length; i++) {
		const name = names[i]
		if (name == '.' || name == '..') {
			continue
		}
		const fullPath = joinPath(normalized, name)
		const stat = statItem(fullPath)
		items.push(stat)
	}
	// #endif
	// 排序：目录在前，文件在后；同类按名称升序
	items.sort((a: FileItem, b: FileItem): number => {
		if (a.isDirectory != b.isDirectory) {
			return a.isDirectory ? -1 : 1
		}
		if (a.name < b.name) {
			return -1
		}
		if (a.name > b.name) {
			return 1
		}
		return 0
	})
	return items
}

// #ifdef APP-ANDROID
/**
 * 通过 Android 绝对路径获取文件信息（内部使用）。
 * @param absPath Android 文件系统绝对路径
 * @param displayPath 显示用路径（可能是 unifile:// 或绝对路径）
 */
function statItemByAbsPath(absPath: string, displayPath: string): FileItem {
	try {
		const file = new File(absPath)
		if (!file.exists()) {
			return makeFileItem(basename(displayPath), displayPath, false, 0, 0)
		}
		const isDir = file.isDirectory()
		const size = isDir ? 0 : file.length()
		const mtime = file.lastModified()
		return makeFileItem(file.name, displayPath, isDir, size, mtime)
	} catch (_e: any) {
		return makeFileItem(basename(displayPath), displayPath, false, 0, 0)
	}
}
// #endif

/**
 * 获取单个文件/目录的统计信息。
 * 失败返回默认值（isDirectory=false, size=0）。
 */
export function statItem(path: string): FileItem {
	const normalized = normalizePath(path)
	if (normalized == '') {
		return makeFileItem('', normalized, false, 0, 0)
	}
	// #ifdef APP-ANDROID
	const absPath = toAndroidAbsPath(normalized)
	if (absPath == '') {
		return makeFileItem(basename(normalized), normalized, false, 0, 0)
	}
	return statItemByAbsPath(absPath, normalized)
	// #endif
	// #ifndef APP-ANDROID
	const fm = uni.getFileSystemManager()
	try {
		const statsArray = fm.statSync(normalized, false)
		if (statsArray == null || statsArray.length == 0) {
			return makeFileItem(basename(normalized), normalized, false, 0, 0)
		}
		const fileStat = statsArray[0]
		const stat = fileStat.stats
		let isDir = false
		let size = 0
		let mtime = 0
		if (stat != null) {
			try {
				isDir = stat.isDirectory()
			} catch (_e: any) {
				isDir = false
			}
			size = stat.size
			mtime = stat.lastModifiedTime
		}
		return makeFileItem(basename(normalized), normalized, isDir, size, mtime)
	} catch (_e: any) {
		return makeFileItem(basename(normalized), normalized, false, 0, 0)
	}
	// #endif
}

/**
 * 创建目录。
 *
 * @param dirPath 目录路径
 * @param recursive 是否递归创建父目录
 */
export function createDir(dirPath: string, recursive: boolean = true): FileOpResult {
	const normalized = normalizePath(dirPath)
	if (normalized == '') {
		return failResult('路径不能为空')
	}
	if (exists(normalized)) {
		return failResult('目录已存在')
	}
	// #ifdef APP-ANDROID
	const absPath = toAndroidAbsPath(normalized)
	if (absPath == '') {
		return failResult('路径转换失败')
	}
	try {
		const dir = new File(absPath)
		const ok = recursive ? dir.mkdirs() : dir.mkdir()
		if (ok) {
			return okResult()
		}
		return failResult('创建目录失败')
	} catch (e: any) {
		const msg = e != null ? ('' + e) : '创建目录失败'
		return failResult(msg)
	}
	// #endif
	// #ifndef APP-ANDROID
	const fm = uni.getFileSystemManager()
	try {
		fm.mkdirSync(normalized, recursive)
		return okResult()
	} catch (e: any) {
		const msg = e != null ? ('' + e) : '创建目录失败'
		return failResult(msg)
	}
	// #endif
}

/**
 * 创建文件（空内容）。
 */
export function createFile(filePath: string): FileOpResult {
	const normalized = normalizePath(filePath)
	if (normalized == '') {
		return failResult('路径不能为空')
	}
	if (exists(normalized)) {
		return failResult('文件已存在')
	}
	// #ifdef APP-ANDROID
	const absPath = toAndroidAbsPath(normalized)
	if (absPath == '') {
		return failResult('路径转换失败')
	}
	try {
		const file = new File(absPath)
		const parent = file.parentFile
		if (parent != null && parent.exists() == false) {
			parent.mkdirs()
		}
		file.writeText('', UTF8_CHARSET)
		return okResult()
	} catch (e: any) {
		const msg = e != null ? ('' + e) : '创建文件失败'
		return failResult(msg)
	}
	// #endif
	// #ifndef APP-ANDROID
	const fm = uni.getFileSystemManager()
	try {
		fm.writeFileSync(normalized, '', 'utf-8')
		return okResult()
	} catch (e: any) {
		const msg = e != null ? ('' + e) : '创建文件失败'
		return failResult(msg)
	}
	// #endif
}

/**
 * 写入文件内容（覆盖写入）。
 */
export function writeContent(filePath: string, content: string): FileOpResult {
	const normalized = normalizePath(filePath)
	if (normalized == '') {
		return failResult('路径不能为空')
	}
	// #ifdef APP-ANDROID
	const absPath = toAndroidAbsPath(normalized)
	if (absPath == '') {
		return failResult('路径转换失败')
	}
	try {
		const file = new File(absPath)
		const parent = file.parentFile
		if (parent != null && parent.exists() == false) {
			parent.mkdirs()
		}
		file.writeText(content, UTF8_CHARSET)
		return okResult()
	} catch (e: any) {
		const msg = e != null ? ('' + e) : '写入文件失败'
		return failResult(msg)
	}
	// #endif
	// #ifndef APP-ANDROID
	const fm = uni.getFileSystemManager()
	try {
		fm.writeFileSync(normalized, content, 'utf-8')
		return okResult()
	} catch (e: any) {
		const msg = e != null ? ('' + e) : '写入文件失败'
		return failResult(msg)
	}
	// #endif
}

/**
 * 读取文件内容（文本）。
 *
 * @param filePath 文件路径
 * @returns 成功返回文件内容字符串，失败返回 null
 */
export function readContent(filePath: string): string | null {
	const normalized = normalizePath(filePath)
	if (normalized == '') {
		return null
	}
	// #ifdef APP-ANDROID
	const absPath = toAndroidAbsPath(normalized)
	if (absPath == '') {
		return null
	}
	try {
		const file = new File(absPath)
		if (!file.exists() || file.isDirectory()) {
			return null
		}
		return file.readText(UTF8_CHARSET)
	} catch (_e: any) {
		return null
	}
	// #endif
	// #ifndef APP-ANDROID
	const fm = uni.getFileSystemManager()
	try {
		const data = fm.readFileSync(normalized, 'utf-8')
		if (data == null) {
			return null
		}
		return '' + data
	} catch (_e: any) {
		return null
	}
	// #endif
}

/**
 * 删除文件或目录。
 *
 * @param path 路径
 * @param recursive 目录是否递归删除
 */
export function deleteItem(path: string, recursive: boolean = true): FileOpResult {
	const normalized = normalizePath(path)
	if (normalized == '') {
		return failResult('路径不能为空')
	}
	if (!exists(normalized)) {
		return failResult('路径不存在')
	}
	// #ifdef APP-ANDROID
	const absPath = toAndroidAbsPath(normalized)
	if (absPath == '') {
		return failResult('路径转换失败')
	}
	try {
		const file = new File(absPath)
		if (file.isDirectory() && recursive) {
			const ok = deleteRecursiveAndroid(file)
			if (ok) {
				return okResult()
			}
			return failResult('递归删除目录失败')
		}
		const ok = file.delete()
		if (ok) {
			return okResult()
		}
		return failResult('删除失败')
	} catch (e: any) {
		const msg = e != null ? ('' + e) : '删除失败'
		return failResult(msg)
	}
	// #endif
	// #ifndef APP-ANDROID
	const fm = uni.getFileSystemManager()
	const stat = statItem(normalized)
	if (stat.isDirectory) {
		try {
			fm.rmdirSync(normalized, recursive)
			return okResult()
		} catch (e: any) {
			const msg = e != null ? ('' + e) : '删除目录失败'
			return failResult(msg)
		}
	} else {
		try {
			fm.unlinkSync(normalized)
			return okResult()
		} catch (e: any) {
			const msg = e != null ? ('' + e) : '删除文件失败'
			return failResult(msg)
		}
	}
	// #endif
}

// #ifdef APP-ANDROID
/**
 * 递归删除目录（Android 原生）。
 */
function deleteRecursiveAndroid(file: File): boolean {
	if (file.isDirectory()) {
		const children = file.listFiles()
		if (children != null) {
			let idx = 0 as Int
			while (idx < children.size) {
				deleteRecursiveAndroid(children[idx])
				idx++
			}
		}
	}
	return file.delete()
}
// #endif

/**
 * 重命名或移动文件/目录。
 *
 * @param oldPath 原路径
 * @param newPath 新路径（含文件名）
 */
export function renameItem(oldPath: string, newPath: string): FileOpResult {
	const normalizedOld = normalizePath(oldPath)
	const normalizedNew = normalizePath(newPath)
	if (normalizedOld == '' || normalizedNew == '') {
		return failResult('路径不能为空')
	}
	if (!exists(normalizedOld)) {
		return failResult('原路径不存在')
	}
	if (exists(normalizedNew)) {
		return failResult('目标路径已存在')
	}
	// #ifdef APP-ANDROID
	const absOld = toAndroidAbsPath(normalizedOld)
	const absNew = toAndroidAbsPath(normalizedNew)
	if (absOld == '' || absNew == '') {
		return failResult('路径转换失败')
	}
	try {
		const oldFile = new File(absOld)
		const newFile = new File(absNew)
		const parent = newFile.parentFile
		if (parent != null && parent.exists() == false) {
			parent.mkdirs()
		}
		const ok = oldFile.renameTo(newFile)
		if (ok) {
			return okResult()
		}
		return failResult('重命名失败')
	} catch (e: any) {
		const msg = e != null ? ('' + e) : '重命名失败'
		return failResult(msg)
	}
	// #endif
	// #ifndef APP-ANDROID
	const fm = uni.getFileSystemManager()
	try {
		fm.renameSync(normalizedOld, normalizedNew)
		return okResult()
	} catch (e: any) {
		const msg = e != null ? ('' + e) : '重命名失败'
		return failResult(msg)
	}
	// #endif
}

/**
 * 复制文件。
 *
 * @param srcPath 源文件路径
 * @param destPath 目标路径
 */
export function copyItem(srcPath: string, destPath: string): FileOpResult {
	const normalizedSrc = normalizePath(srcPath)
	const normalizedDest = normalizePath(destPath)
	if (normalizedSrc == '' || normalizedDest == '') {
		return failResult('路径不能为空')
	}
	if (!exists(normalizedSrc)) {
		return failResult('源路径不存在')
	}
	if (exists(normalizedDest)) {
		return failResult('目标路径已存在')
	}
	const stat = statItem(normalizedSrc)
	if (stat.isDirectory) {
		return copyDirRecursive(normalizedSrc, normalizedDest)
	}
	// #ifdef APP-ANDROID
	const absSrc = toAndroidAbsPath(normalizedSrc)
	const absDest = toAndroidAbsPath(normalizedDest)
	if (absSrc == '' || absDest == '') {
		return failResult('路径转换失败')
	}
	try {
		const srcFile = new File(absSrc)
		const destFile = new File(absDest)
		const parent = destFile.parentFile
		if (parent != null && parent.exists() == false) {
			parent.mkdirs()
		}
		srcFile.copyTo(destFile)
		return okResult()
	} catch (e: any) {
		const msg = e != null ? ('' + e) : '复制文件失败'
		return failResult(msg)
	}
	// #endif
	// #ifndef APP-ANDROID
	const fm = uni.getFileSystemManager()
	try {
		fm.copyFileSync(normalizedSrc, normalizedDest)
		return okResult()
	} catch (e: any) {
		const msg = e != null ? ('' + e) : '复制文件失败'
		return failResult(msg)
	}
	// #endif
}

/**
 * 递归复制目录。
 */
function copyDirRecursive(srcPath: string, destPath: string): FileOpResult {
	const createResult = createDir(destPath, true)
	if (!createResult.ok) {
		return createResult
	}
	const items = listDir(srcPath)
	for (let i = 0; i < items.length; i++) {
		const item = items[i]
		const childSrc = item.path
		const childDest = joinPath(destPath, item.name)
		if (item.isDirectory) {
			const subResult = copyDirRecursive(childSrc, childDest)
			if (!subResult.ok) {
				return subResult
			}
		} else {
			const copyResult = copyItem(childSrc, childDest)
			if (!copyResult.ok) {
				return copyResult
			}
		}
	}
	return okResult()
}
