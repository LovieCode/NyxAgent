/**
 * 头像图片选择入口。
 *
 * 相册能力与聊天附件保持一致：系统图片选择失败时依次回退到媒体选择和文件选择。
 */

import { isChooseCancelError, readPickedImageSelection } from '@/utils/attachment-reader.uts'
import {
	APP_ERROR_CATEGORY_DATABASE,
	APP_ERROR_CATEGORY_RUNTIME,
	APP_ERROR_CATEGORY_STORAGE,
	formatAppErrorForUser,
	reportAppErrorFromCause,
} from '@/utils/app-error.uts'
import { deleteRuntimeState, getRuntimeState, setRuntimeStatePair } from '@/utils/database.uts'
import { copyItem, createDir, deleteItem, exists, getInternalFilesDir, joinPath } from '@/utils/file-manager.uts'
import { handleCameraPickerFailure } from '@/utils/media-permission.uts'

const AVATAR_CROP_RESULT_KEY = 'crop_result'
const AVATAR_CROP_TARGET_KEY = 'crop_target'
const AVATAR_CROP_IMAGE_PATH_KEY = 'crop_image_path'

function reportAvatarPickerFailure(
	code: string,
	category: string,
	operation: string,
	userMessage: string,
	cause: any | null,
	notifyUser: boolean,
): void {
	const error = reportAppErrorFromCause(
		code,
		category,
		operation,
		userMessage,
		cause,
		true,
	)
	if (notifyUser == true) {
		uni.showToast({ position: 'bottom', title: formatAppErrorForUser(error), icon: 'none' })
	}
}

function showAvatarPickerFailure(code: string, operation: string, userMessage: string, cause: any | null): void {
	reportAvatarPickerFailure(code, APP_ERROR_CATEGORY_RUNTIME, operation, userMessage, cause, true)
}

function showAvatarStorageFailure(code: string, operation: string, userMessage: string, cause: any | null): void {
	reportAvatarPickerFailure(code, APP_ERROR_CATEGORY_STORAGE, operation, userMessage, cause, true)
}

function deliverPickedAvatar(res: any, onPicked: (path: string) => void): void {
	const picked = readPickedImageSelection(res)
	if (picked.ok == false) {
		const emptyResult = picked.error == '未选择图片'
		showAvatarPickerFailure(
			emptyResult == true ? 'AVATAR_PICKER_EMPTY_RESULT' : 'AVATAR_PICKER_INVALID_RESULT',
			'avatar_picker_result',
			emptyResult == true ? '没有读取到所选图片' : '所选图片读取失败',
			picked.error,
		)
		return
	}
	onPicked(picked.path)
}

function clearAvatarCropState(operation: string, notifyFailure: boolean): boolean {
	let pairCleared = false
	let resultCleared = false
	let failureCause: any | null = null
	try {
		pairCleared = setRuntimeStatePair(AVATAR_CROP_TARGET_KEY, '', AVATAR_CROP_IMAGE_PATH_KEY, '')
	} catch (e: any) {
		failureCause = e
	}
	try {
		resultCleared = deleteRuntimeState(AVATAR_CROP_RESULT_KEY)
	} catch (e: any) {
		if (failureCause == null) { failureCause = e }
	}
	if (pairCleared == true && resultCleared == true) { return true }
	if (failureCause == null) {
		failureCause = 'target/path cleared=' + pairCleared + ', result cleared=' + resultCleared
	}
	reportAvatarPickerFailure(
		'AVATAR_CROP_STATE_CLEAR_FAILED',
		APP_ERROR_CATEGORY_DATABASE,
		operation,
		'头像裁剪临时状态清理失败，请重试',
		failureCause,
		notifyFailure,
	)
	return false
}

function readAvatarCropState(key: string, operation: string, notifyFailure: boolean): string | null {
	try {
		return getRuntimeState(key)
	} catch (e: any) {
		reportAvatarPickerFailure(
			'AVATAR_CROP_STATE_READ_FAILED',
			APP_ERROR_CATEGORY_DATABASE,
			operation,
			'头像裁剪临时状态读取失败，请重试',
			e,
			notifyFailure,
		)
		return null
	}
}

/**
 * 取消当前裁剪请求。target 为空时用于清理无法识别的损坏状态。
 */
export function cancelAvatarCropRequest(target: string): void {
	if (target != '') {
		const currentTarget = readAvatarCropState(AVATAR_CROP_TARGET_KEY, 'avatar_crop_cancel_read', true)
		if (currentTarget == null || currentTarget != target) { return }
	}
	clearAvatarCropState('avatar_crop_cancel_clear', true)
}

function buildPersistedAvatarPath(target: string): string {
	const filesDir = getInternalFilesDir()
	if (filesDir == '') {
		showAvatarStorageFailure('AVATAR_STORAGE_PATH_MISSING', 'avatar_crop_storage_path', '头像文件保存失败', '内部文件目录为空')
		return ''
	}
	const avatarDir = joinPath(filesDir, 'avatars')
	if (exists(avatarDir) == false) {
		const created = createDir(avatarDir, true)
		if (created.ok == false) {
			showAvatarStorageFailure('AVATAR_STORAGE_DIR_FAILED', 'avatar_crop_create_directory', '头像文件保存失败', created.error)
			return ''
		}
	}
	let prefix = 'avatar'
	if (target == 'profile_avatar') {
		prefix = 'profile'
	} else if (target == 'agent_avatar') {
		prefix = 'agent'
	} else if (target == 'create_agent_avatar') {
		prefix = 'agent-create'
	}
	return joinPath(avatarDir, prefix + '-' + Date.now() + '-' + Math.floor(Math.random() * 100000) + '.png')
}

function persistAvatarCropResult(path: string, target: string): string {
	if (path == '') { return '' }
	const filesDir = getInternalFilesDir()
	if (filesDir != '' && path.startsWith(joinPath(filesDir, 'avatars') + '/')) {
		return path
	}
	const persistedPath = buildPersistedAvatarPath(target)
	if (persistedPath == '') { return '' }
	const copied = copyItem(path, persistedPath)
	if (copied.ok == false) {
		showAvatarStorageFailure('AVATAR_CROP_COPY_FAILED', 'avatar_crop_persist', '头像文件保存失败', copied.error)
		return ''
	}
	return persistedPath
}

export function discardManagedAvatarFile(path: string): boolean {
	if (path == '') { return true }
	const filesDir = getInternalFilesDir()
	if (filesDir == '') {
		showAvatarStorageFailure('AVATAR_DELETE_PATH_MISSING', 'avatar_managed_file_delete', '旧头像文件清理失败', '内部文件目录为空')
		return false
	}
	const avatarPrefix = joinPath(filesDir, 'avatars') + '/'
	if (path.startsWith(avatarPrefix) == false) { return true }
	if (exists(path) == true) {
		const deleted = deleteItem(path, false)
		if (deleted.ok == false) {
			showAvatarStorageFailure('AVATAR_MANAGED_FILE_DELETE_FAILED', 'avatar_managed_file_delete', '旧头像文件清理失败', deleted.error)
			return false
		}
	}
	return true
}

/**
 * 写入裁剪页协议并打开页面。导航失败时只清理本次请求，避免留下脏状态。
 */
export function openAvatarCrop(path: string, target: string): void {
	if (path == '' || target == '') {
		showAvatarPickerFailure('AVATAR_CROP_INVALID_REQUEST', 'avatar_crop_open', '无法打开头像裁剪', '图片路径或裁剪目标为空')
		return
	}
	if (clearAvatarCropState('avatar_crop_prepare_clear', true) == false) { return }
	let stateSaved = false
	let saveFailure: any | null = null
	try {
		stateSaved = setRuntimeStatePair(AVATAR_CROP_TARGET_KEY, target, AVATAR_CROP_IMAGE_PATH_KEY, path)
	} catch (e: any) {
		saveFailure = e
	}
	if (stateSaved == false) {
		clearAvatarCropState('avatar_crop_prepare_rollback', false)
		showAvatarPickerFailure(
			'AVATAR_CROP_STATE_FAILED',
			'avatar_crop_prepare',
			'无法准备头像裁剪',
			saveFailure != null ? saveFailure : '裁剪页临时状态原子保存失败',
		)
		return
	}
	uni.navigateTo({
		url: '/pages/common/crop/crop',
		fail: (err: any) => {
			const currentTarget = readAvatarCropState(AVATAR_CROP_TARGET_KEY, 'avatar_crop_navigate_read', false)
			let cleanupOk = currentTarget != null
			if (currentTarget != null && currentTarget == target) {
				cleanupOk = clearAvatarCropState('avatar_crop_navigate_rollback', false)
			}
			showAvatarPickerFailure(
				'AVATAR_CROP_ROUTE_FAILED',
				'avatar_crop_navigate',
				cleanupOk == true ? '无法打开头像裁剪页' : '无法打开头像裁剪页，临时状态清理失败',
				err,
			)
		}
	})
}

export function hasAvatarCropRequest(target: string): boolean {
	if (target == '') { return false }
	const currentTarget = readAvatarCropState(AVATAR_CROP_TARGET_KEY, 'avatar_crop_request_read', true)
	return currentTarget != null && currentTarget == target
}

/** 消费指定页面已经生成的裁剪结果。空结果仍是进行中的请求，不做清理。 */
export function consumeAvatarCropResult(target: string): string {
	if (target == '') { return '' }
	const currentTarget = readAvatarCropState(AVATAR_CROP_TARGET_KEY, 'avatar_crop_result_target_read', true)
	if (currentTarget == null || currentTarget != target) { return '' }
	const result = readAvatarCropState(AVATAR_CROP_RESULT_KEY, 'avatar_crop_result_read', true)
	if (result == null) { return '' }
	if (result == '') { return '' }
	const persisted = persistAvatarCropResult(result, target)
	if (clearAvatarCropState('avatar_crop_result_consume', true) == false) {
		if (persisted != '' && persisted != result) {
			discardManagedAvatarFile(persisted)
		}
		return ''
	}
	return persisted
}

function chooseAvatarFromFile(onPicked: (path: string) => void): void {
	uni.chooseFile({
		count: 1,
		success: (res: any) => {
			const picked = readPickedImageSelection(res)
			if (picked.ok == false) {
				const emptyResult = picked.error == '未选择图片'
				showAvatarPickerFailure(
					emptyResult == true ? 'AVATAR_FILE_EMPTY_RESULT' : 'AVATAR_FILE_INVALID_RESULT',
					'avatar_picker_file_result',
					emptyResult == true ? '没有读取到所选图片' : '所选文件不是可用图片',
					picked.error,
				)
				return
			}
			onPicked(picked.path)
		},
		fail: (err: any) => {
			if (isChooseCancelError(err) == true) { return }
			showAvatarPickerFailure('AVATAR_FILE_PICK_FAILED', 'avatar_picker_choose_file', '选择图片失败', err)
		}
	})
}

function chooseAvatarFromMedia(onPicked: (path: string) => void): void {
	uni.chooseMedia({
		count: 1,
		sourceType: ['album'],
		success: (res: any) => {
			const picked = readPickedImageSelection(res)
			if (picked.ok == false) {
				const emptyResult = picked.error == '未选择图片'
				showAvatarPickerFailure(
					emptyResult == true ? 'AVATAR_MEDIA_EMPTY_RESULT' : 'AVATAR_MEDIA_INVALID_RESULT',
					'avatar_picker_media_result',
					emptyResult == true ? '没有读取到所选图片' : '所选媒体不是可用图片',
					picked.error,
				)
				return
			}
			onPicked(picked.path)
		},
		fail: (err: any) => {
			if (isChooseCancelError(err) == true) { return }
			reportAppErrorFromCause(
				'AVATAR_MEDIA_PICK_FAILED',
				APP_ERROR_CATEGORY_RUNTIME,
				'avatar_picker_choose_media',
				'相册媒体选择失败，已改用文件选择',
				err,
				true,
			)
			uni.showToast({ position: 'bottom', title: '相册打开失败，请从文件选择图片', icon: 'none' })
			chooseAvatarFromFile(onPicked)
		}
	})
}

function chooseAvatarFromAlbum(onPicked: (path: string) => void): void {
	uni.chooseImage({
		count: 1,
		sourceType: ['album'],
		sizeType: ['compressed'],
		success: (res: any) => {
			deliverPickedAvatar(res, onPicked)
		},
		fail: (err: any) => {
			if (isChooseCancelError(err) == true) { return }
			reportAppErrorFromCause(
				'AVATAR_ALBUM_PICK_FAILED',
				APP_ERROR_CATEGORY_RUNTIME,
				'avatar_picker_choose_image',
				'相册选择失败，正在尝试兼容通道',
				err,
				true,
			)
			chooseAvatarFromMedia(onPicked)
		}
	})
}

function chooseAvatarFromCamera(onPicked: (path: string) => void): void {
	uni.chooseImage({
		count: 1,
		sourceType: ['camera'],
		sizeType: ['compressed'],
		success: (res: any) => {
			deliverPickedAvatar(res, onPicked)
		},
		fail: (err: any) => {
			if (isChooseCancelError(err) == true) { return }
			handleCameraPickerFailure(err, 'avatar_picker_camera')
		}
	})
}

export function chooseAvatarImage(onPicked: (path: string) => void): void {
	uni.showActionSheet({
		itemList: ['从相册选择', '拍照'],
		success: (res) => {
			if (res.tapIndex == 0) {
				chooseAvatarFromAlbum(onPicked)
			} else if (res.tapIndex == 1) {
				chooseAvatarFromCamera(onPicked)
			}
		},
		fail: (err: any) => {
			if (isChooseCancelError(err) == true) { return }
			showAvatarPickerFailure('AVATAR_SOURCE_MENU_FAILED', 'avatar_picker_source_menu', '无法打开图片来源菜单', err)
		}
	})
}
