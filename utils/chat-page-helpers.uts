/**
 * Chat 页面展示/交互纯辅助。
 *
 * 参考 AstrBot message 分层：页面负责生命周期和平台 API，消息读取、定位和动作菜单决策放这里。
 */

import {
	CHAT_ROLE_ASSISTANT,
	CHAT_ROLE_USER,
	getMessageContent,
	createFileMessage,
	createImageMessage,
	createLocationMessage,
	createTextMessage,
	createVoiceMessage,
	getMessageParts,
	setImageMessageCaption,
} from '@/utils/chat-models.uts'

export const CHAT_MESSAGE_ACTION_DELETE = '删除'
export const CHAT_MESSAGE_ACTION_EDIT = '编辑'
export const CHAT_MESSAGE_ACTION_PLAY_SPEECH = '播放语音'
export const CHAT_MESSAGE_ACTION_REGENERATE = '重新回答'

export type ChatMessageActionContext = {
	ok: boolean
	actions: string[]
}

function emptyChatMessageActionContext(): ChatMessageActionContext {
	return {
		ok: false,
		actions: [] as string[],
	} as ChatMessageActionContext
}

export function getChatMessagePartsForView(msg: UTSJSONObject): UTSJSONObject[] {
	return getMessageParts(msg)
}

export function readChatMessageRole(msg: UTSJSONObject): string {
	const raw = msg['role'] as string | null
	return raw != null ? raw : ''
}

export function isChatAssistantRole(role: string): boolean {
	return role == CHAT_ROLE_ASSISTANT
}

export function findLastChatAssistantMessage(messages: UTSJSONObject[]): UTSJSONObject | null {
	for (let i = messages.length - 1; i >= 0; i--) {
		if (readChatMessageRole(messages[i]) == CHAT_ROLE_ASSISTANT) {
			return messages[i]
		}
	}
	return null
}

export function hasChatMessageRef(messages: UTSJSONObject[], target: UTSJSONObject): boolean {
	for (let i = 0; i < messages.length; i++) {
		if (messages[i] == target) {
			return true
		}
	}
	return false
}

function buildChatMessageActionItems(role: string, assistantContent: string, ttsEnabled: boolean): string[] {
	const actions: string[] = []
	if (role == CHAT_ROLE_USER || role == CHAT_ROLE_ASSISTANT) {
		actions.push(CHAT_MESSAGE_ACTION_DELETE)
		actions.push(CHAT_MESSAGE_ACTION_EDIT)
		if (role == CHAT_ROLE_ASSISTANT) {
			if (ttsEnabled == true && assistantContent != '') {
				actions.push(CHAT_MESSAGE_ACTION_PLAY_SPEECH)
			}
			actions.push(CHAT_MESSAGE_ACTION_REGENERATE)
		}
		return actions
	}
	actions.push(CHAT_MESSAGE_ACTION_DELETE)
	return actions
}

export function buildChatMessageActionContext(msg: UTSJSONObject | null, ttsEnabled: boolean): ChatMessageActionContext {
	if (msg == null) { return emptyChatMessageActionContext() }
	const role = readChatMessageRole(msg)
	if (role == '') { return emptyChatMessageActionContext() }
	const assistantContent = isChatAssistantRole(role) == true ? getMessageContent(msg).trim() : ''
	return {
		ok: true,
		actions: buildChatMessageActionItems(role, assistantContent, ttsEnabled),
	} as ChatMessageActionContext
}

export function readChatMessageActionAt(actions: string[], tapIndex: number): string {
	if (tapIndex < 0 || tapIndex >= actions.length) { return '' }
	return actions[tapIndex]
}

export function buildChatLocationContent(location: UTSJSONObject): string {
	const rawName = location['name'] as string | null
	const rawAddr = location['address'] as string | null
	const rawLat = location['latitude'] as number | null
	const rawLng = location['longitude'] as number | null
	const name = rawName != null ? rawName : '未知位置'
	const addr = rawAddr != null ? rawAddr : ''
	const lat = rawLat != null ? rawLat : 0
	const lng = rawLng != null ? rawLng : 0
	return '📍 ' + name + (addr != '' ? ' - ' + addr : '') + ' (' + lat + ', ' + lng + ')'
}

export function appendChatTextMessage(messages: UTSJSONObject[], role: string, content: string): void {
	if (role == CHAT_ROLE_USER) {
		messages.push(createTextMessage(CHAT_ROLE_USER, content))
	} else {
		messages.push(createTextMessage(role, content))
	}
}

export function appendChatImageMessage(messages: UTSJSONObject[], imagePath: string): number {
	if (imagePath == '') { return -1 }
	messages.push(createImageMessage(imagePath))
	return messages.length - 1
}

export function applyChatImageCaption(messages: UTSJSONObject[], index: number, caption: string | null): boolean {
	if (index < 0 || index >= messages.length) { return false }
	if (caption == null || caption == '') { return false }
	setImageMessageCaption(messages[index], caption)
	messages.splice(index, 1, messages[index])
	return true
}

export function appendChatFileMessage(messages: UTSJSONObject[], fileName: string, filePath: string, fileText: string): void {
	messages.push(createFileMessage(fileName, filePath, fileText))
}

export function appendChatLocationMessage(messages: UTSJSONObject[], content: string): void {
	messages.push(createLocationMessage(content))
}

export function appendChatVoiceMessage(messages: UTSJSONObject[], tempPath: string): boolean {
	if (tempPath == '') { return false }
	messages.push(createVoiceMessage(tempPath))
	return true
}

export function hasConfiguredChatDefaultTaskModel(config: UTSJSONObject | null): boolean {
	if (config == null) { return false }
	const providerIdRaw = config['providerId'] as string | null
	const modelRaw = config['model'] as string | null
	const providerId = providerIdRaw != null ? providerIdRaw : ''
	const model = modelRaw != null ? modelRaw : ''
	return providerId != '' && model != ''
}

export function calcChatInputHeight(lineCount: number): number {
	if (lineCount <= 1) {
		return 36
	}
	return Math.min(lineCount * 22 + 12, 200)
}

export function readChatMessageContentForEdit(msg: UTSJSONObject): string {
	const rawContent = msg['content'] as string | null
	return rawContent != null ? rawContent : ''
}

export function isChatAssistantMessage(msg: UTSJSONObject): boolean {
	return readChatMessageRole(msg) == CHAT_ROLE_ASSISTANT
}

export function stringifyChatContextPreview(preview: UTSJSONObject): string {
	try {
		return JSON.stringify(preview, null, 2)
	} catch (_e: any) {
		return JSON.stringify(preview)
	}
}
