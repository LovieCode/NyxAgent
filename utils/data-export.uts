/**
 * 全量数据导出工具
 * 聚合 SQLite、app_settings 和本地资源，生成可备份 ZIP 清单。
 */

import { getAllProviders, getAllConversationsForExport, getAllMessagesForExport, getAllAppSettings, getDatabaseFilePathForExport, getAllMemoryBuffersForExport, getAllMemoryCoreForExport, getAllConversationTokenUsageStatsForExport, getAllMemoryCompactionStatesForExport, getAllGroupChatDataForExport } from '@/utils/database.uts'
import { getAllDefaultTaskModels } from '@/uni_modules/agent-core/utssdk/provider.uts'
import { getAgents } from '@/utils/agent.uts'
import { getSkills } from '@/utils/skills.uts'
import { getAgentDir, getAgentsRoot, getInternalFilesDir, getUserDir, listDir, joinPath, exists, readContent, formatFileSize, formatTime } from '@/utils/file-manager.uts'
import { buildTodoMarkdown, buildNoteMarkdown } from '@/utils/markdown.uts'
import { writeExportZipFile, shareExportFile, getLastShareExportError } from '@/utssdk/app-data-export/index.uts'
import { appendDirectorySpec, appendFileSpec, appendTextSpec, cloneExportObject, inferExtension, sanitizeFilePart, sanitizeRelativeZipPath, sanitizeZipSegment, stripFileSpecContent } from '@/utils/data-export-helpers.uts'

const EXPORT_SCHEMA_VERSION = 1
const MAX_EXPORT_FILE_BYTES: number = 50 * 1024 * 1024

export type DataExportOptions = {
	includeApiKeys: boolean
}

export function buildDataExportOptions(includeApiKeys: boolean): DataExportOptions {
	return {
		includeApiKeys: includeApiKeys,
	} as DataExportOptions
}

function findAppSettingValue(appSettings: UTSJSONObject[], key: string): string | null {
	for (let i = 0; i < appSettings.length; i++) {
		const row = appSettings[i]
		const rowKey = row['key'] as string | null
		if (rowKey == key) {
			return row['value'] as string | null
		}
	}
	return null
}

function addStorageValue(target: UTSJSONObject, key: string, appSettings: UTSJSONObject[]): void {
	let value: any | null = findAppSettingValue(appSettings, key)
	if (value == null && key.startsWith('app_setting_')) {
		value = findAppSettingValue(appSettings, key.substring(12))
	}
	if (value != null) {
		target[key] = value
	}
}

function appendUniqueKey(keys: string[], key: string): void {
	if (key == '') {
		return
	}
	for (let i = 0; i < keys.length; i++) {
		if (keys[i] == key) {
			return
		}
	}
	keys.push(key)
}

function buildKnownStorageKeys(): string[] {
	return [
		'agent_list',
		'active_agent_id',
		'active_conversation_id',
		'settings_provider_id',
		'settings_api_key',
		'settings_base_url',
		'settings_model',
		'settings_gh_proxy_enabled',
		'settings_gh_proxy_domain',
		'settings_web_search_enabled',
		'settings_web_search_provider',
		'settings_web_search_provider_id',
		'settings_web_search_model',
		'settings_web_search_instance',
		'settings_astrbot_enabled',
		'settings_astrbot_base_url',
		'settings_astrbot_api_key',
		'settings_astrbot_username',
		'settings_astrbot_session_id',
		'settings_astrbot_config_id',
		'settings_generation_temperature',
		'settings_generation_max_tokens',
		'settings_generation_max_iterations',
		'settings_generation_stream_enabled',
		'skills_list',
		'settings_memory_enabled',
		'memory_agent_id',
		'memory_conversation_id',
		'app_setting_default_task_chat',
		'app_setting_default_task_vision',
		'app_setting_image_caption_prompt',
		'app_setting_default_task_stt',
		'app_setting_default_task_tts',
		'profile_nickname',
		'profile_bio',
		'profile_email',
		'profile_description',
		'profile_avatar',
		'notes_list',
		'todo_list',
		'provider_edit_data',
		'pending_agent_model_id',
		'editor_title',
		'editor_content',
		'editor_draft',
		'editor_target',
		'editor_result',
		'editor_mode',
		'editor_file_path',
		'editor_saved',
		'editor_saved_path',
		'editor_result_ready',
		'editor_readonly',
		'editor_placeholder',
		'crop_image_path',
		'crop_result',
	]
}

function collectStorageKeys(appSettings: UTSJSONObject[]): string[] {
	const keys = buildKnownStorageKeys()
	for (let i = 0; i < appSettings.length; i++) {
		const rowKey = appSettings[i]['key'] as string | null
		if (rowKey != null) {
			appendUniqueKey(keys, rowKey)
		}
	}
	return keys
}

function collectKnownStorageByKeys(keys: string[], appSettings: UTSJSONObject[]): UTSJSONObject {
	const storage: UTSJSONObject = {}
	for (let i = 0; i < keys.length; i++) {
		addStorageValue(storage, keys[i], appSettings)
	}
	return storage
}

function parseStorageArray(storage: UTSJSONObject, key: string): UTSJSONObject[] {
	const value = storage[key] as string | null
	if (value == null || value == '') {
		return []
	}
	try {
		return JSON.parse(value) as UTSJSONObject[]
	} catch (_e: any) {
		return []
	}
}

function appendAsset(assets: UTSJSONObject[], specs: UTSJSONObject[], kind: string, sourcePath: string, zipPath: string, ref: string): void {
	if (!isLocalExportPath(sourcePath)) {
		return
	}
	appendFileSpec(specs, sourcePath, zipPath)
	assets.push({
		kind: kind,
		sourcePath: sourcePath,
		zipPath: zipPath,
		ref: ref,
	} as UTSJSONObject)
}

function appendStorageAsset(storage: UTSJSONObject, assets: UTSJSONObject[], specs: UTSJSONObject[], storageKey: string, kind: string, fileName: string): void {
	const value = storage[storageKey] as string | null
	if (value == null || value == '') {
		return
	}
	const ext = inferExtension(value, 'bin')
	appendAsset(assets, specs, kind, value, 'assets/storage/' + fileName + '.' + ext, 'storage.' + storageKey)
}

function appendAgentAvatarAssets(agents: UTSJSONObject[], assets: UTSJSONObject[], specs: UTSJSONObject[]): void {
	for (let i = 0; i < agents.length; i++) {
		const rawId = agents[i]['id'] as string | null
		const rawAvatar = agents[i]['avatar'] as string | null
		if (rawId != null && rawId != '' && rawAvatar != null && rawAvatar != '') {
			const ext = inferExtension(rawAvatar, 'bin')
			const zipPath = 'assets/agents/' + sanitizeZipSegment(rawId) + '/avatar.' + ext
			appendAsset(assets, specs, 'agentAvatar', rawAvatar, zipPath, 'agents.' + rawId + '.avatar')
		}
	}
}


function readPartAssetPath(part: UTSJSONObject): string {
	const url = part['url'] as string | null
	if (url != null && url != '') {
		return url
	}
	const path = part['path'] as string | null
	if (path != null && path != '') {
		return path
	}
	return ''
}

function readPartAssetName(part: UTSJSONObject, fallback: string): string {
	const filename = part['filename'] as string | null
	if (filename != null && filename != '') {
		return sanitizeZipSegment(filename)
	}
	const name = part['name'] as string | null
	if (name != null && name != '') {
		return sanitizeZipSegment(name)
	}
	return fallback
}

function appendMessagePartAsset(messagesIdText: string, partIndex: number, part: UTSJSONObject, assets: UTSJSONObject[], specs: UTSJSONObject[]): void {
	const type = part['type'] as string | null
	if (type == null) {
		return
	}
	const sourcePath = readPartAssetPath(part)
	if (sourcePath == '') {
		return
	}
	let kind = ''
	let baseName = ''
	if (type == 'image') {
		kind = 'messageImage'
		baseName = 'image'
	} else if (type == 'file') {
		kind = 'messageFile'
		baseName = readPartAssetName(part, 'file')
	} else if (type == 'record' || type == 'voice') {
		kind = 'messageRecord'
		baseName = 'record'
	} else if (type == 'audio') {
		kind = 'messageAudio'
		baseName = 'audio'
	} else if (type == 'video') {
		kind = 'messageVideo'
		baseName = 'video'
	} else {
		return
	}
	const ext = inferExtension(sourcePath, 'bin')
	const zipPath = 'assets/messages/' + sanitizeZipSegment(messagesIdText) + '/part-' + partIndex + '-' + sanitizeZipSegment(baseName) + '.' + ext
	appendAsset(assets, specs, kind, sourcePath, zipPath, 'messages.' + messagesIdText + '.message.' + partIndex + '.path')
}

function appendMessagePartAssets(messages: UTSJSONObject[], assets: UTSJSONObject[], specs: UTSJSONObject[]): void {
	for (let i = 0; i < messages.length; i++) {
		const msg = messages[i]
		const rawId = msg['id'] as number | null
		const idText = rawId != null ? (rawId + '') : (i + '')
		const extraText = msg['extra'] as string | null
		if (extraText != null && extraText != '' && extraText != '{}') {
			try {
				const extra = JSON.parse(extraText) as UTSJSONObject
				const parts = extra['message'] as UTSJSONObject[] | null
				if (parts != null) {
					for (let pi = 0; pi < parts.length; pi++) {
						appendMessagePartAsset(idText, pi, parts[pi], assets, specs)
					}
				}
				const imageUrl = extra['imageUrl'] as string | null
				if (imageUrl != null && imageUrl != '') {
					const ext = inferExtension(imageUrl, 'bin')
					const zipPath = 'assets/messages/' + sanitizeZipSegment(idText) + '/legacy-image.' + ext
					appendAsset(assets, specs, 'messageImage', imageUrl, zipPath, 'messages.' + idText + '.imageUrl')
				}
			} catch (_e: any) {
			}
		}
	}
}

function collectAssets(storage: UTSJSONObject, agents: UTSJSONObject[], messages: UTSJSONObject[], specs: UTSJSONObject[]): UTSJSONObject[] {
	const assets: UTSJSONObject[] = []
	appendStorageAsset(storage, assets, specs, 'profile_avatar', 'profileAvatar', 'profile-avatar')
	appendStorageAsset(storage, assets, specs, 'crop_image_path', 'cropSource', 'crop-source')
	appendStorageAsset(storage, assets, specs, 'crop_result', 'cropResult', 'crop-result')
	appendAgentAvatarAssets(agents, assets, specs)
	appendMessagePartAssets(messages, assets, specs)
	return assets
}

function appendDatabaseFile(specs: UTSJSONObject[]): UTSJSONObject | null {
	const dbPath = getDatabaseFilePathForExport()
	if (dbPath == '') {
		return null
	}
	const zipPath = 'database/agent_chat.db'
	appendFileSpec(specs, dbPath, zipPath)
	return {
		kind: 'file',
		sourcePath: dbPath,
		zipPath: zipPath,
	} as UTSJSONObject
}

function appendAgentFileEntries(agentId: string, dirPath: string, result: UTSJSONObject[], specs: UTSJSONObject[], depth: number): void {
	if (depth > 8) {
		return
	}
	const agentDir = getAgentDir(agentId)
	if (agentDir == '') {
		return
	}
	const fullDirPath = dirPath == '' ? agentDir : joinPath(agentDir, dirPath)
	const files = listDir(fullDirPath)
	for (let i = 0; i < files.length; i++) {
		const item = files[i]
		const name = item.name
		if (name == '') {
			continue
		}
		const relPath = dirPath == '' ? name : dirPath + '/' + name
		const safeRelPath = sanitizeRelativeZipPath(relPath)
		if (item.isDirectory == true) {
			const directoryZipPath = 'agent-workspaces/' + sanitizeZipSegment(agentId) + '/' + safeRelPath + '/'
			appendDirectorySpec(specs, directoryZipPath)
			result.push({
				agentId: agentId,
				path: relPath,
				zipPath: directoryZipPath,
				isDirectory: true,
				size: item.size,
				lastModified: item.lastModified,
			} as UTSJSONObject)
			appendAgentFileEntries(agentId, relPath, result, specs, depth + 1)
		} else {
			const sourceRoot = agentDir
			const zipPath = 'agent-workspaces/' + sanitizeZipSegment(agentId) + '/' + safeRelPath
			const entry: UTSJSONObject = {
				agentId: agentId,
				path: relPath,
				zipPath: zipPath,
				isDirectory: false,
				size: item.size,
				lastModified: item.lastModified,
			} as UTSJSONObject
			if (sourceRoot != '') {
				appendFileSpec(specs, sourceRoot + '/' + relPath, zipPath)
				entry['includedInZip'] = true
			} else {
				entry['skipped'] = true
				entry['reason'] = 'agent storage path unavailable on this platform'
			}
			result.push(entry)
		}
	}
}

function collectAgentFiles(agents: UTSJSONObject[], specs: UTSJSONObject[]): UTSJSONObject[] {
	const result: UTSJSONObject[] = []
	for (let i = 0; i < agents.length; i++) {
		const rawId = agents[i]['id'] as string | null
		if (rawId != null && rawId != '') {
			appendAgentFileEntries(rawId, '', result, specs, 0)
		}
	}
	return result
}

function appendGroupWorkspaceEntries(dirPath: string, result: UTSJSONObject[], specs: UTSJSONObject[], depth: number): void {
	if (depth > 10) {
		return
	}
	const filesDir = getInternalFilesDir()
	if (filesDir == '') {
		return
	}
	const root = joinPath(filesDir, 'group-workspaces')
	if (exists(root) == false) {
		return
	}
	const fullDirPath = dirPath == '' ? root : joinPath(root, dirPath)
	const files = listDir(fullDirPath)
	for (let i = 0; i < files.length; i++) {
		const item = files[i]
		const name = item.name
		if (name == '') {
			continue
		}
		const relPath = dirPath == '' ? name : dirPath + '/' + name
		const safeRelPath = sanitizeRelativeZipPath(relPath)
		if (item.isDirectory == true) {
			const zipPath = 'group-workspaces/' + safeRelPath + '/'
			appendDirectorySpec(specs, zipPath)
			result.push({
				path: relPath,
				zipPath: zipPath,
				isDirectory: true,
				size: item.size,
				lastModified: item.lastModified,
			} as UTSJSONObject)
			appendGroupWorkspaceEntries(relPath, result, specs, depth + 1)
		} else {
			const zipPath = 'group-workspaces/' + safeRelPath
			appendFileSpec(specs, joinPath(root, relPath), zipPath)
			result.push({
				path: relPath,
				zipPath: zipPath,
				isDirectory: false,
				size: item.size,
				lastModified: item.lastModified,
				includedInZip: true,
			} as UTSJSONObject)
		}
	}
}

function collectGroupWorkspaceFiles(specs: UTSJSONObject[]): UTSJSONObject[] {
	const result: UTSJSONObject[] = []
	appendDirectorySpec(specs, 'group-workspaces/')
	appendGroupWorkspaceEntries('', result, specs, 0)
	return result
}

function appendUserFileEntries(dirPath: string, result: UTSJSONObject[], specs: UTSJSONObject[], depth: number): void {
	if (depth > 8) {
		return
	}
	const userDir = getUserDir()
	if (userDir == '') {
		return
	}
	const fullDirPath = dirPath == '' ? userDir : joinPath(userDir, dirPath)
	const files = listDir(fullDirPath)
	for (let i = 0; i < files.length; i++) {
		const item = files[i]
		const name = item.name
		if (name == '') {
			continue
		}
		const relPath = dirPath == '' ? name : dirPath + '/' + name
		const safeRelPath = sanitizeRelativeZipPath(relPath)
		if (item.isDirectory == true) {
			const directoryZipPath = 'user-files/' + safeRelPath + '/'
			appendDirectorySpec(specs, directoryZipPath)
			result.push({
				path: relPath,
				zipPath: directoryZipPath,
				isDirectory: true,
				size: item.size,
				lastModified: item.lastModified,
			} as UTSJSONObject)
			appendUserFileEntries(relPath, result, specs, depth + 1)
		} else {
			const zipPath = 'user-files/' + safeRelPath
			const entry: UTSJSONObject = {
				path: relPath,
				zipPath: zipPath,
				isDirectory: false,
				size: item.size,
				lastModified: item.lastModified,
			} as UTSJSONObject
			appendFileSpec(specs, userDir + '/' + relPath, zipPath)
			entry['includedInZip'] = true
			result.push(entry)
		}
	}
}

function collectUserFiles(specs: UTSJSONObject[]): UTSJSONObject[] {
	const result: UTSJSONObject[] = []
	appendDirectorySpec(specs, 'user-files/')
	appendUserFileEntries('', result, specs, 0)
	return result
}

function appendKnowledgeOwnerFiles(specs: UTSJSONObject[], ownerType: string, ownerId: string, rootZipPath: string): void {
	// 仅处理 agent 知识文件 — user/default 的 notes/todos 由 storage keys 覆盖
	if (ownerType != 'agent') {
		return
	}
	const agentDir = getAgentDir(ownerId)
	if (agentDir == '') {
		return
	}
	appendDirectorySpec(specs, rootZipPath + '/')

	// todo.md
	const todoPath = joinPath(agentDir, 'todo.md')
	if (exists(todoPath)) {
		appendFileSpec(specs, todoPath, rootZipPath + '/todo.md')
	}

	// notes/*.md
	const notesDir = joinPath(agentDir, 'notes')
	if (exists(notesDir)) {
		appendDirectorySpec(specs, rootZipPath + '/notes/')
		const noteFiles = listDir(notesDir)
		for (let i = 0; i < noteFiles.length; i++) {
			const nf = noteFiles[i]
			if (!nf.isDirectory && nf.name.endsWith('.md')) {
				appendFileSpec(specs, nf.path, rootZipPath + '/notes/' + nf.name)
			}
		}
	}
}

function appendKnowledgeWorkspaceFiles(agents: UTSJSONObject[], specs: UTSJSONObject[]): void {
	appendDirectorySpec(specs, 'knowledge-workspace/')
	for (let i = 0; i < agents.length; i++) {
		const rawId = agents[i]['id'] as string | null
		if (rawId != null && rawId != '') {
			appendKnowledgeOwnerFiles(specs, 'agent', rawId, 'knowledge-workspace/agents/' + sanitizeZipSegment(rawId))
		}
	}
}

function sanitizeProvidersForExport(providers: UTSJSONObject[], options: DataExportOptions): UTSJSONObject[] {
	const result: UTSJSONObject[] = []
	for (let i = 0; i < providers.length; i++) {
		const clean = cloneExportObject(providers[i])
		if (options.includeApiKeys == false) {
			clean['api_key'] = ''
		}
		result.push(clean)
	}
	return result
}

function sanitizeAppSettingsForExport(appSettings: UTSJSONObject[], options: DataExportOptions): UTSJSONObject[] {
	const result: UTSJSONObject[] = []
	for (let i = 0; i < appSettings.length; i++) {
		const clean = cloneExportObject(appSettings[i])
		const key = clean['key'] as string | null
		if (options.includeApiKeys == false && (key == 'settings_api_key' || key == 'settings_astrbot_api_key')) {
			clean['value'] = ''
		}
		result.push(clean)
	}
	return result
}

function sanitizeStorageForExport(storage: UTSJSONObject, options: DataExportOptions): UTSJSONObject {
	const clean = cloneExportObject(storage)
	if (options.includeApiKeys == false) {
		clean['settings_api_key'] = ''
		clean['settings_astrbot_api_key'] = ''
		// 临时编辑缓存可能携带 API Key，安全备份里直接丢弃。
		clean['provider_edit_data'] = ''
	}
	return clean
}

function buildFileName(exportedAt: string, includeApiKeys: boolean): string {
	const prefix = includeApiKeys == true ? 'agent-full-export-' : 'agent-safe-export-'
	return prefix + sanitizeFilePart(exportedAt) + '.zip'
}

/**
 * 构建全量导出对象。
 * 注意：providers 和 app_settings 中可能包含 API Key。
 */
export function buildAllDataExportWithOptions(options: DataExportOptions): UTSJSONObject {
	const exportedAt = new Date().toISOString()
	const conversations = getAllConversationsForExport()
	const messages = getAllMessagesForExport()
	const memoryBuffers = getAllMemoryBuffersForExport()
	const memoryCore = getAllMemoryCoreForExport()
	const conversationTokenUsageStats = getAllConversationTokenUsageStatsForExport()
	const memoryCompactionStates = getAllMemoryCompactionStatesForExport()
	const groupChatData = getAllGroupChatDataForExport()
	const rawAppSettings = getAllAppSettings()
	const appSettings = sanitizeAppSettingsForExport(rawAppSettings, options)
	const storageKeys = collectStorageKeys(rawAppSettings)
	const storage = sanitizeStorageForExport(collectKnownStorageByKeys(storageKeys, rawAppSettings), options)
	const agents = getAgents()
	const skills = getSkills()
	const fileSpecs: UTSJSONObject[] = []
	let databaseFile: UTSJSONObject | null = null
	if (options.includeApiKeys == true) {
		databaseFile = appendDatabaseFile(fileSpecs)
	}
	const userFiles = collectUserFiles(fileSpecs)
	const agentFiles = collectAgentFiles(agents, fileSpecs)
	const groupWorkspaceFiles = collectGroupWorkspaceFiles(fileSpecs)
	appendKnowledgeWorkspaceFiles(agents, fileSpecs)
	const notes = parseStorageArray(storage, 'notes_list')
	const todos = parseStorageArray(storage, 'todo_list')
	const assets = collectAssets(storage, agents, messages, fileSpecs)
	const providers = sanitizeProvidersForExport(getAllProviders(), options)
	return {
		schemaVersion: EXPORT_SCHEMA_VERSION,
		exportedAt: exportedAt,
		app: 'agent',
		format: 'zip',
		backupMode: options.includeApiKeys == true ? 'full' : 'safe',
		containsApiKeys: options.includeApiKeys,
		manifestFile: 'export.json',
		maxFileBytes: MAX_EXPORT_FILE_BYTES,
		warning: options.includeApiKeys == true ? 'This export may contain API keys, conversation history, prompts and personal data.' : 'This safe export removes known API keys but still contains conversation history, prompts, files and personal data.',
		files: fileSpecs,
		data: {
			databaseFile: databaseFile,
			storageKeys: storageKeys,
			providers: providers,
			appSettings: appSettings,
			defaultTaskModels: getAllDefaultTaskModels(),
			agents: agents,
			skills: skills,
			userFiles: userFiles,
			agentFiles: agentFiles,
			groupWorkspaceFiles: groupWorkspaceFiles,
			assets: assets,
			conversations: conversations,
			messages: messages,
			memoryBuffers: memoryBuffers,
			memoryCore: memoryCore,
			conversationTokenUsageStats: conversationTokenUsageStats,
			memoryCompactionStates: memoryCompactionStates,
			groupChatData: groupChatData,
			notes: notes,
			todos: todos,
			storage: storage,
		} as UTSJSONObject,
	} as UTSJSONObject
}

export function buildAllDataExport(): UTSJSONObject {
	return buildAllDataExportWithOptions(buildDataExportOptions(true))
}

/**
 * 导出到本地文件。APP-ANDROID 返回文件路径；其他平台返回空字符串。
 */
export function exportAllDataToFileWithOptions(options: DataExportOptions): string {
	const exportedAt = new Date().toISOString()
	const payload = buildAllDataExportWithOptions(options)
	payload['exportedAt'] = exportedAt
	const files = payload['files'] as UTSJSONObject[] | null
	const filesJson = files != null ? JSON.stringify(files) : '[]'
	if (files != null) {
		payload['files'] = stripFileSpecContent(files)
	}
	const json = JSON.stringify(payload)
	const fileName = buildFileName(exportedAt, options.includeApiKeys)
	return writeExportZipFile(fileName, json, filesJson)
}

export function exportAllDataToFile(): string {
	return exportAllDataToFileWithOptions(buildDataExportOptions(true))
}

/**
 * 剪贴板兜底：文件系统不可用时使用。
 */
export function exportAllDataToJsonWithOptions(options: DataExportOptions): string {
	const payload = buildAllDataExportWithOptions(options)
	const files = payload['files'] as UTSJSONObject[] | null
	if (files != null) {
		payload['files'] = stripFileSpecContent(files)
	}
	return JSON.stringify(payload)
}

export function exportAllDataToJson(): string {
	return exportAllDataToJsonWithOptions(buildDataExportOptions(true))
}

/** 分享已导出的 ZIP 文件。 */
export function shareExportedDataFile(filePath: string): boolean {
	return shareExportFile(filePath)
}

/** 获取最近一次分享失败原因。 */
export function getLastShareExportErrorMessage(): string {
	return getLastShareExportError()
}
