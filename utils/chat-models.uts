/**
 * 对话系统数据模型
 *
 * 参考 AstrBot webui 的 ChatRecord / MessagePart：
 * - 顶层消息只负责角色、时间、流式状态。
 * - message: ChatPart[] 是唯一内容真相。
 * - UI blocks、正文、思考过程、工具状态全部从 parts 派生。
 */

export const CHAT_ROLE_USER = 'user'
export const CHAT_ROLE_ASSISTANT = 'assistant'
export const CHAT_ROLE_TOOL_RESULT = 'toolResult'

export const CHAT_MESSAGE_TYPE_TEXT = 'text'
export const CHAT_MESSAGE_TYPE_IMAGE = 'image'
export const CHAT_MESSAGE_TYPE_FILE = 'file'
export const CHAT_MESSAGE_TYPE_LOCATION = 'location'
export const CHAT_MESSAGE_TYPE_VOICE = 'voice'

export const CHAT_PART_PLAIN = 'plain'
export const CHAT_PART_THINK = 'think'
export const CHAT_PART_TOOL_CALL = 'tool_call'
export const CHAT_PART_IMAGE = 'image'
export const CHAT_PART_FILE = 'file'
export const CHAT_PART_LOCATION = 'location'
export const CHAT_PART_RECORD = 'record'

export const CHAT_BLOCK_TEXT = 'text'
export const CHAT_BLOCK_THINKING = 'thinking'
export const CHAT_BLOCK_TOOL_CALL = 'toolCall'

export const TOOL_STATUS_PENDING = 'pending'
export const TOOL_STATUS_RUNNING = 'running'
export const TOOL_STATUS_COMPLETED = 'completed'
export const TOOL_STATUS_ERROR = 'error'

export type ChatUserProfile = {
	nickname: string
	avatar: string
}

export type ChatAgentSnapshot = {
	id: string
	name: string
	avatar: string
	systemPrompt: string
	interactionRules: string
	model: string
	hideThinking: boolean
	injectDatetime: boolean
	msgSegmentation: boolean
}

export type ChatConversationLoadResult = {
	conversationId: string
	messages: UTSJSONObject[]
	saved: boolean
}

export type ChatRuntimeContextOptions = {
	injectDatetime: boolean
	datetimePrefix: string
	interactionRules: string
}

export function createEmptyAgentSnapshot(): ChatAgentSnapshot {
	return {
		id: '',
		name: '',
		avatar: '',
		systemPrompt: '',
		interactionRules: '',
		model: '',
		hideThinking: false,
		injectDatetime: true,
		msgSegmentation: true,
	} as ChatAgentSnapshot
}

export function createPlainPart(text: string): UTSJSONObject {
	return {
		type: CHAT_PART_PLAIN,
		text: text,
	} as UTSJSONObject
}

export function createThinkPart(text: string): UTSJSONObject {
	return {
		type: CHAT_PART_THINK,
		think: text,
	} as UTSJSONObject
}

export function createToolCallItem(id: string, name: string, args: string, timestamp: number, status: string): UTSJSONObject {
	return {
		id: id,
		name: name,
		arguments: args,
		args: args,
		ts: timestamp,
		status: status,
		result: '',
		isError: false,
	} as UTSJSONObject
}

export function createToolCallPart(toolCalls: UTSJSONObject[]): UTSJSONObject {
	return {
		type: CHAT_PART_TOOL_CALL,
		tool_calls: toolCalls,
	} as UTSJSONObject
}

export function createImagePart(imagePath: string): UTSJSONObject {
	return {
		type: CHAT_PART_IMAGE,
		url: imagePath,
		path: imagePath,
		caption: '',
	} as UTSJSONObject
}

export function getMessageParts(message: UTSJSONObject): UTSJSONObject[] {
	const parts = message['message'] as UTSJSONObject[] | null
	if (parts != null) {
		return parts
	}
	return [] as UTSJSONObject[]
}

export function setImageMessageCaption(message: UTSJSONObject, caption: string): void {
	const parts = getMessageParts(message)
	for (let i = 0; i < parts.length; i++) {
		const part = parts[i]
		const type = part['type'] as string | null
		if (type == CHAT_PART_IMAGE) {
			part['caption'] = caption
		}
	}
	if (caption != '') {
		message['content'] = '[图片转述] ' + caption
	} else {
		message['content'] = '[图片]'
	}
}

export function createFilePart(fileName: string, filePath: string, fileText: string = ''): UTSJSONObject {
	const part = {
		type: CHAT_PART_FILE,
		filename: fileName,
		path: filePath,
	} as UTSJSONObject
	if (fileText != '') {
		part['text'] = fileText
	}
	return part
}

export function createLocationPart(locationText: string): UTSJSONObject {
	return {
		type: CHAT_PART_LOCATION,
		text: locationText,
	} as UTSJSONObject
}

export function createRecordPart(tempPath: string): UTSJSONObject {
	return {
		type: CHAT_PART_RECORD,
		url: tempPath,
		path: tempPath,
	} as UTSJSONObject
}

export function extractPlainText(parts: UTSJSONObject[]): string {
	let text = ''
	for (let i = 0; i < parts.length; i++) {
		const part = parts[i]
		const type = part['type'] as string | null
		if (type == CHAT_PART_PLAIN) {
			const rawText = part['text'] as string | null
			if (rawText != null) {
				text += rawText
			}
		} else if (type == CHAT_PART_LOCATION) {
			const rawLocation = part['text'] as string | null
			if (rawLocation != null) {
				if (text != '') { text += '\n' }
				text += rawLocation
			}
		}
	}
	return text
}

export function createChatMessage(role: string, parts: UTSJSONObject[], timestamp: number): UTSJSONObject {
	return {
		role: role,
		content: extractPlainText(parts),
		message: parts,
		msgType: CHAT_MESSAGE_TYPE_TEXT,
		timestamp: timestamp,
	} as UTSJSONObject
}

export function createTextMessage(role: string, content: string): UTSJSONObject {
	return createChatMessage(role, [createPlainPart(content)], Date.now())
}

export function createImageMessage(imagePath: string): UTSJSONObject {
	const msg = createChatMessage(CHAT_ROLE_USER, [createImagePart(imagePath)], Date.now())
	msg['content'] = '[图片]'
	msg['msgType'] = CHAT_MESSAGE_TYPE_IMAGE
	msg['imageUrl'] = imagePath
	return msg
}

export function createFileMessage(fileName: string, filePath: string, fileText: string = ''): UTSJSONObject {
	const msg = createChatMessage(CHAT_ROLE_USER, [createFilePart(fileName, filePath, fileText)], Date.now())
	msg['content'] = '[文件] ' + fileName
	msg['msgType'] = CHAT_MESSAGE_TYPE_FILE
	if (filePath != '') {
		msg['imageUrl'] = filePath
	}
	return msg
}

export function createLocationMessage(locationText: string): UTSJSONObject {
	const msg = createChatMessage(CHAT_ROLE_USER, [createLocationPart(locationText)], Date.now())
	msg['content'] = locationText
	msg['msgType'] = CHAT_MESSAGE_TYPE_LOCATION
	return msg
}

export function createVoiceMessage(tempPath: string): UTSJSONObject {
	const msg = createChatMessage(CHAT_ROLE_USER, [createRecordPart(tempPath)], Date.now())
	msg['content'] = '[语音消息]'
	msg['msgType'] = CHAT_MESSAGE_TYPE_VOICE
	msg['imageUrl'] = tempPath
	return msg
}

export function createAssistantStreamingMessage(parts: UTSJSONObject[], timestamp: number): UTSJSONObject {
	const msg = createChatMessage(CHAT_ROLE_ASSISTANT, parts, timestamp)
	msg['isStreaming'] = true
	return msg
}

export function createAssistantFinalMessage(parts: UTSJSONObject[], timestamp: number): UTSJSONObject {
	const msg = createChatMessage(CHAT_ROLE_ASSISTANT, parts, timestamp)
	msg['isStreaming'] = false
	return msg
}

export function createTextBlock(text: string): UTSJSONObject {
	return {
		type: CHAT_BLOCK_TEXT,
		text: text,
	} as UTSJSONObject
}

export function createThinkingBlock(text: string): UTSJSONObject {
	return {
		type: CHAT_BLOCK_THINKING,
		thinking: text,
	} as UTSJSONObject
}

export function createToolCallBlock(name: string, args: string, timestamp: number, status: string): UTSJSONObject {
	return {
		type: CHAT_BLOCK_TOOL_CALL,
		name: name,
		arguments: args,
		ts: timestamp,
		status: status,
		result: '',
	} as UTSJSONObject
}

export function getMessageRole(message: UTSJSONObject): string {
	const raw = message['role'] as string | null
	return raw != null ? raw : ''
}

export function getMessageContent(message: UTSJSONObject): string {
	const raw = message['content'] as string | null
	if (raw != null && raw != '') {
		return raw
	}
	return extractPlainText(getMessageParts(message))
}

export function getMessageThinking(message: UTSJSONObject): string {
	let thinking = ''
	const parts = getMessageParts(message)
	for (let i = 0; i < parts.length; i++) {
		const part = parts[i]
		const type = part['type'] as string | null
		if (type == CHAT_PART_THINK) {
			const raw = part['think'] as string | null
			if (raw != null && raw != '') {
				thinking += raw
			}
		}
	}
	return thinking
}

export function getMessageTimestamp(message: UTSJSONObject): number {
	const raw = message['timestamp'] as number | null
	return raw != null ? raw : Date.now()
}

export function isStreamingAssistant(message: UTSJSONObject): boolean {
	return getMessageRole(message) == CHAT_ROLE_ASSISTANT && (message['isStreaming'] as boolean | null) == true
}

export function cloneParts(parts: UTSJSONObject[] | null): UTSJSONObject[] {
	const copied: UTSJSONObject[] = []
	if (parts == null) {
		return copied
	}
	for (let i = 0; i < parts.length; i++) {
		copied.push(JSON.parse(JSON.stringify(parts[i])) as UTSJSONObject)
	}
	return copied
}

export function cloneBlocks(blocks: UTSJSONObject[] | null): UTSJSONObject[] {
	return cloneParts(blocks)
}

export function cloneMessage(message: UTSJSONObject): UTSJSONObject {
	const raw = JSON.stringify(message)
	return JSON.parse(raw) as UTSJSONObject
}
