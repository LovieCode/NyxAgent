/**
 * 群聊与运行态数据库访问。
 *
 * 从 database.uts 拆出，避免主数据库入口继续膨胀成万物 DAO。
 */

import {
	assertSqlSuccess,
	ensureAppRuntimeStateTable,
	ensureGroupChatTables,
	getDb,
	readNumberField,
	readStringField,
	rowsToObjects,
	runSqlOrThrow,
	safeJsonArrayForDb,
	safeJsonForDb,
} from '@/utils/database-core.uts'
import {
	ACTIVE_GROUP_CHAT_ID_KEY,
	ACTIVE_GROUP_SESSION_ID_KEY,
} from '@/utils/group-chat-models.uts'
import { xSqlite } from '@/uni_modules/laoqianjunzi-sqlite'

export type RuntimeStateMutation = {
	key: string
	value: string
}

export function setRuntimeState(key: string, value: string): boolean {
	if (key == '') { return false }
	const db = getDb()
	ensureAppRuntimeStateTable(db)
	const result = db.run('INSERT OR REPLACE INTO app_runtime_state (key, value, updated_at) VALUES (?, ?, ?)', [key, value, Date.now()])
	db.close()
	try {
		assertSqlSuccess(result, '保存页面运行状态失败')
	} catch (_e: any) {
		return false
	}
	return true
}

export function getRuntimeState(key: string): string {
	if (key == '') { return '' }
	const db = getDb()
	ensureAppRuntimeStateTable(db)
	const result = db.query('SELECT value FROM app_runtime_state WHERE key = ? AND ? = ? LIMIT 1', [key, 1, 1])
	db.close()
	assertSqlSuccess(result, '读取页面运行状态失败')
	const rows = rowsToObjects(result)
	if (rows.length > 0) {
		return readStringField(rows[0], 'value')
	}
	return ''
}

export function consumeRuntimeState(key: string): string {
	if (key == '') { return '' }
	const db = getDb()
	ensureAppRuntimeStateTable(db)
	const result = db.query('SELECT value FROM app_runtime_state WHERE key = ? AND ? = ? LIMIT 1', [key, 1, 1])
	try {
		assertSqlSuccess(result, '读取页面运行状态失败')
		assertSqlSuccess(db.run('DELETE FROM app_runtime_state WHERE key = ?', [key]), '清理页面运行状态失败')
	} catch (e: any) {
		db.close()
		throw e
	}
	db.close()
	const rows = rowsToObjects(result)
	if (rows.length > 0) {
		return readStringField(rows[0], 'value')
	}
	return ''
}

export function deleteRuntimeState(key: string): boolean {
	if (key == '') { return false }
	const db = getDb()
	ensureAppRuntimeStateTable(db)
	const result = db.run('DELETE FROM app_runtime_state WHERE key = ?', [key])
	db.close()
	try {
		assertSqlSuccess(result, '删除页面运行状态失败')
	} catch (_e: any) {
		return false
	}
	return true
}

function validateRuntimeStateMutations(items: RuntimeStateMutation[]): boolean {
	if (items.length == 0) { return false }
	for (let i = 0; i < items.length; i++) {
		if (items[i].key == '') { return false }
		for (let j = 0; j < i; j++) {
			if (items[j].key == items[i].key) { return false }
		}
	}
	return true
}

function validateRuntimeStateKeys(keys: string[]): boolean {
	if (keys.length == 0) { return false }
	for (let i = 0; i < keys.length; i++) {
		if (keys[i] == '') { return false }
		for (let j = 0; j < i; j++) {
			if (keys[j] == keys[i]) { return false }
		}
	}
	return true
}

function readRuntimeStateValueFromDb(db: xSqlite, key: string): string {
	const result = db.query('SELECT value FROM app_runtime_state WHERE key = ? AND ? = ? LIMIT 1', [key, 1, 1])
	assertSqlSuccess(result, '读取页面组合运行状态失败')
	const rows = rowsToObjects(result)
	if (rows.length == 0) { return '' }
	return readStringField(rows[0], 'value')
}

function runtimeStateGuardsMatch(db: xSqlite, guards: RuntimeStateMutation[]): boolean {
	for (let i = 0; i < guards.length; i++) {
		if (readRuntimeStateValueFromDb(db, guards[i].key) != guards[i].value) {
			return false
		}
	}
	return true
}

function applyRuntimeStateMutations(db: xSqlite, items: RuntimeStateMutation[], updatedAt: number): void {
	for (let i = 0; i < items.length; i++) {
		const item = items[i]
		if (item.value == '') {
			runSqlOrThrow(db, 'DELETE FROM app_runtime_state WHERE key = ?', [item.key])
		} else {
			runSqlOrThrow(
				db,
				'INSERT OR REPLACE INTO app_runtime_state (key, value, updated_at) VALUES (?, ?, ?)',
				[item.key, item.value, updatedAt],
			)
		}
	}
}

/** 原子写入或删除多项跨页状态；空值表示删除。 */
export function setRuntimeStates(items: RuntimeStateMutation[]): boolean {
	if (validateRuntimeStateMutations(items) == false) { return false }
	const db = getDb()
	ensureAppRuntimeStateTable(db)
	try {
		assertSqlSuccess(db.beginTransaction(), '开始保存页面批量运行状态')
		applyRuntimeStateMutations(db, items, Date.now())
		assertSqlSuccess(db.commit(), '提交页面组合运行状态')
	} catch (_e: any) {
		db.rollback()
		db.close()
		return false
	}
	db.close()
	return true
}

/** 仅当 guard 仍匹配时原子写入，防止旧页面覆盖新页面的跨页状态。 */
export function setRuntimeStatesIf(guards: RuntimeStateMutation[], items: RuntimeStateMutation[]): boolean {
	if (validateRuntimeStateMutations(guards) == false || validateRuntimeStateMutations(items) == false) { return false }
	const db = getDb()
	ensureAppRuntimeStateTable(db)
	try {
		assertSqlSuccess(db.beginTransaction(), '开始条件保存页面运行状态')
		if (runtimeStateGuardsMatch(db, guards) == false) {
			assertSqlSuccess(db.commit(), '结束页面运行状态条件检查')
			db.close()
			return false
		}
		applyRuntimeStateMutations(db, items, Date.now())
		assertSqlSuccess(db.commit(), '提交条件页面运行状态')
	} catch (_e: any) {
		db.rollback()
		db.close()
		return false
	}
	db.close()
	return true
}

/** 在同一读事务中获取整组状态；返回值顺序与 keys 一致。 */
export function getRuntimeStates(keys: string[]): string[] {
	if (validateRuntimeStateKeys(keys) == false) {
		throw new Error('页面运行状态批量读取参数无效')
	}
	const db = getDb()
	ensureAppRuntimeStateTable(db)
	const values: string[] = []
	try {
		assertSqlSuccess(db.beginTransaction(), '开始读取页面批量运行状态')
		for (let i = 0; i < keys.length; i++) {
			values.push(readRuntimeStateValueFromDb(db, keys[i]))
		}
		assertSqlSuccess(db.commit(), '提交页面批量运行状态读取')
	} catch (e: any) {
		db.rollback()
		db.close()
		throw e
	}
	db.close()
	return values
}

/** guard 匹配时，在同一事务中读取并删除整组状态；返回值顺序与 keys 一致。 */
export function consumeRuntimeStatesIf(guards: RuntimeStateMutation[], keys: string[]): string[] | null {
	if (validateRuntimeStateMutations(guards) == false || validateRuntimeStateKeys(keys) == false) {
		throw new Error('页面运行状态批量消费参数无效')
	}
	const db = getDb()
	ensureAppRuntimeStateTable(db)
	const values: string[] = []
	try {
		assertSqlSuccess(db.beginTransaction(), '开始消费页面批量运行状态')
		if (runtimeStateGuardsMatch(db, guards) == false) {
			assertSqlSuccess(db.commit(), '结束页面运行状态消费检查')
			db.close()
			return null
		}
		for (let i = 0; i < keys.length; i++) {
			values.push(readRuntimeStateValueFromDb(db, keys[i]))
		}
		for (let i = 0; i < keys.length; i++) {
			runSqlOrThrow(db, 'DELETE FROM app_runtime_state WHERE key = ?', [keys[i]])
		}
		assertSqlSuccess(db.commit(), '提交页面批量运行状态消费')
	} catch (e: any) {
		db.rollback()
		db.close()
		throw e
	}
	db.close()
	return values
}

/** 原子写入两个跨页状态键；空值表示删除，避免路由准备只提交一半。 */
export function setRuntimeStatePair(firstKey: string, firstValue: string, secondKey: string, secondValue: string): boolean {
	if (firstKey == '' || secondKey == '' || firstKey == secondKey) { return false }
	const items: RuntimeStateMutation[] = [
		{ key: firstKey, value: firstValue } as RuntimeStateMutation,
		{ key: secondKey, value: secondValue } as RuntimeStateMutation,
	]
	return setRuntimeStates(items)
}

/** 导出全部页面运行态，供全量备份与导入回滚使用。 */
export function getAllRuntimeStatesForExport(): UTSJSONObject[] {
	const db = getDb()
	ensureAppRuntimeStateTable(db)
	const result = db.query('SELECT key, value, updated_at FROM app_runtime_state ORDER BY key ASC')
	db.close()
	assertSqlSuccess(result, '导出页面运行状态失败')
	return rowsToObjects(result)
}

/** 覆盖全部页面运行态，避免导入后保留指向旧实体的草稿和活动 ID。 */
export function replaceAllRuntimeStates(rows: UTSJSONObject[]): boolean {
	const db = getDb()
	ensureAppRuntimeStateTable(db)
	try {
		assertSqlSuccess(db.beginTransaction(), '开始恢复页面运行状态')
		runSqlOrThrow(db, 'DELETE FROM app_runtime_state')
		for (let i = 0; i < rows.length; i++) {
			const key = readStringField(rows[i], 'key')
			if (key == '') { throw new Error('页面运行状态缺少 key') }
			const updatedAt = readNumberField(rows[i], 'updated_at')
			runSqlOrThrow(
				db,
				'INSERT INTO app_runtime_state (key, value, updated_at) VALUES (?, ?, ?)',
				[key, readStringField(rows[i], 'value'), updatedAt > 0 ? updatedAt : Date.now()],
			)
		}
		assertSqlSuccess(db.commit(), '提交页面运行状态恢复')
	} catch (_e: any) {
		db.rollback()
		db.close()
		return false
	}
	db.close()
	return true
}

export function getGroupChatRows(): UTSJSONObject[] {
	const db = getDb()
	ensureGroupChatTables(db)
	const result = db.query('SELECT * FROM group_chats ORDER BY updated_at DESC')
	db.close()
	assertSqlSuccess(result, '读取群聊列表失败')
	return rowsToObjects(result)
}

export function getGroupChatRowById(groupId: string): UTSJSONObject | null {
	if (groupId == '') { return null }
	const db = getDb()
	ensureGroupChatTables(db)
	const result = db.query('SELECT * FROM group_chats WHERE id = ? AND ? = ? LIMIT 1', [groupId, 1, 1])
	db.close()
	assertSqlSuccess(result, '读取群聊设置失败')
	const rows = rowsToObjects(result)
	if (rows.length > 0) { return rows[0] }
	return null
}

export function saveGroupChatRow(row: UTSJSONObject): boolean {
	const now = Date.now()
	let createdAt = readNumberField(row, 'created_at')
	if (createdAt <= 0) { createdAt = readNumberField(row, 'createdAt') }
	if (createdAt <= 0) { createdAt = now }
	let updatedAt = readNumberField(row, 'updated_at')
	if (updatedAt <= 0) { updatedAt = readNumberField(row, 'updatedAt') }
	if (updatedAt <= 0) { updatedAt = now }
	const db = getDb()
	ensureGroupChatTables(db)
	const result = db.run(
		'INSERT OR REPLACE INTO group_chats (id, name, avatar, scheduler_agent_id, scheduler_prompt, shared_prompt, active_session_id, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)',
		[
			readStringField(row, 'id'),
			readStringField(row, 'name'),
			readStringField(row, 'avatar'),
			readStringField(row, 'scheduler_agent_id') != '' ? readStringField(row, 'scheduler_agent_id') : readStringField(row, 'schedulerAgentId'),
			readStringField(row, 'scheduler_prompt') != '' ? readStringField(row, 'scheduler_prompt') : readStringField(row, 'schedulerPrompt'),
			readStringField(row, 'shared_prompt') != '' ? readStringField(row, 'shared_prompt') : readStringField(row, 'sharedPrompt'),
			readStringField(row, 'active_session_id') != '' ? readStringField(row, 'active_session_id') : readStringField(row, 'activeSessionId'),
			createdAt,
			updatedAt,
		]
	)
	db.close()
	try {
		assertSqlSuccess(result, '保存群聊设置失败')
	} catch (_e: any) {
		return false
	}
	return true
}

export function getGroupMemberRows(groupId: string): UTSJSONObject[] {
	const db = getDb()
	ensureGroupChatTables(db)
	const result = db.query('SELECT * FROM group_chat_members WHERE group_id = ? AND ? = ? ORDER BY order_index ASC, joined_at ASC', [groupId, 1, 1])
	db.close()
	assertSqlSuccess(result, '读取群聊成员失败')
	return rowsToObjects(result)
}

export function saveGroupMemberRows(groupId: string, rows: UTSJSONObject[]): boolean {
	const db = getDb()
	ensureGroupChatTables(db)
	try {
		assertSqlSuccess(db.beginTransaction(), '无法开始群成员保存事务')
		runSqlOrThrow(db, 'DELETE FROM group_chat_members WHERE group_id = ? AND ? = ?', [groupId, 1, 1])
		for (let i = 0; i < rows.length; i++) {
			const row = rows[i]
			runSqlOrThrow(db,
				'INSERT OR REPLACE INTO group_chat_members (id, group_id, agent_id, active, joined_at, left_at, order_index) VALUES (?, ?, ?, ?, ?, ?, ?)',
				[
					readStringField(row, 'id'),
					groupId,
					readStringField(row, 'agent_id') != '' ? readStringField(row, 'agent_id') : readStringField(row, 'agentId'),
					readNumberField(row, 'active'),
					readNumberField(row, 'joined_at') > 0 ? readNumberField(row, 'joined_at') : readNumberField(row, 'joinedAt'),
					readNumberField(row, 'left_at') > 0 ? readNumberField(row, 'left_at') : readNumberField(row, 'leftAt'),
					readNumberField(row, 'order_index') > 0 ? readNumberField(row, 'order_index') : readNumberField(row, 'order'),
				]
			)
		}
		assertSqlSuccess(db.commit(), '无法提交群成员保存事务')
	} catch (_e: any) {
		db.rollback()
		db.close()
		return false
	}
	db.close()
	return true
}

