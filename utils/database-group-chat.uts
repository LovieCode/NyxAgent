/** 原子恢复两个群聊路由键；空值表示删除，不修改任何群聊自身的当前会话。 */
export function setGroupChatRouteState(groupId: string, sessionId: string): boolean {
	const db = getDb()
	ensureGroupChatTables(db)
	try {
		assertSqlSuccess(db.beginTransaction(), '开始恢复群聊路由状态')
		if (groupId == '') {
			runSqlOrThrow(db, 'DELETE FROM group_chat_state WHERE key = ?', [ACTIVE_GROUP_CHAT_ID_KEY])
		} else {
			runSqlOrThrow(db, 'INSERT OR REPLACE INTO group_chat_state (key, value, updated_at) VALUES (?, ?, ?)', [ACTIVE_GROUP_CHAT_ID_KEY, groupId, Date.now()])
		}
		if (sessionId == '') {
			runSqlOrThrow(db, 'DELETE FROM group_chat_state WHERE key = ?', [ACTIVE_GROUP_SESSION_ID_KEY])
		} else {
			runSqlOrThrow(db, 'INSERT OR REPLACE INTO group_chat_state (key, value, updated_at) VALUES (?, ?, ?)', [ACTIVE_GROUP_SESSION_ID_KEY, sessionId, Date.now()])
		}
		assertSqlSuccess(db.commit(), '提交群聊路由状态恢复')
	} catch (_e: any) {
		db.rollback()
		db.close()
		return false
	}
	db.close()
	return true
}

/** 原子切换当前群聊会话，避免群聊记录和两个活动状态键部分提交。 */
export function setActiveGroupSessionState(groupId: string, sessionId: string, updatedAt: number): boolean {
	if (groupId == '' || sessionId == '') { return false }
	const db = getDb()
	ensureGroupChatTables(db)
	const writeAt = updatedAt > 0 ? updatedAt : Date.now()
	try {
		assertSqlSuccess(db.beginTransaction(), '开始切换当前群聊会话')
		const targetResult = db.query(
			'SELECT group_chats.id FROM group_chats INNER JOIN group_chat_sessions ON group_chat_sessions.group_id = group_chats.id WHERE group_chats.id = ? AND group_chat_sessions.id = ? LIMIT 1',
			[groupId, sessionId]
		)
		assertSqlSuccess(targetResult, '校验群聊当前会话')
		if (rowsToObjects(targetResult).length == 0) { throw new Error('群聊或群会话不存在') }
		assertSqlSuccess(
			db.run(
				'UPDATE group_chats SET active_session_id = ?, updated_at = ? WHERE id = ?',
				[sessionId, writeAt, groupId]
			),
			'更新群聊当前会话'
		)
		assertSqlSuccess(
			db.run(
				'INSERT OR REPLACE INTO group_chat_state (key, value, updated_at) VALUES (?, ?, ?)',
				[ACTIVE_GROUP_CHAT_ID_KEY, groupId, writeAt]
			),
			'保存当前群聊状态'
		)
		assertSqlSuccess(
			db.run(
				'INSERT OR REPLACE INTO group_chat_state (key, value, updated_at) VALUES (?, ?, ?)',
				[ACTIVE_GROUP_SESSION_ID_KEY, sessionId, writeAt]
			),
			'保存当前群会话状态'
		)
		assertSqlSuccess(db.commit(), '提交当前群聊会话切换')
	} catch (_e: any) {
		db.rollback()
		db.close()
		return false
	}
	db.close()
	return true
}

export function getGroupChatState(key: string): string {
	const db = getDb()
	ensureGroupChatTables(db)
	const result = db.query('SELECT value FROM group_chat_state WHERE key = ? AND ? = ? LIMIT 1', [key, 1, 1])
	db.close()
	assertSqlSuccess(result, '读取群聊运行状态失败')
	const rows = rowsToObjects(result)
	if (rows.length > 0) {
		return readStringField(rows[0], 'value')
	}
	return ''
}

export function deleteGroupSessionDbRows(groupId: string, sessionId: string): void {
	const db = getDb()
	ensureGroupChatTables(db)
	try {
		assertSqlSuccess(db.beginTransaction(), '无法开始群会话删除事务')
		runSqlOrThrow(db, 'DELETE FROM group_chat_messages WHERE group_id = ? AND session_id = ?', [groupId, sessionId])
		runSqlOrThrow(db, 'DELETE FROM group_agent_context_records WHERE group_id = ? AND session_id = ?', [groupId, sessionId])
		runSqlOrThrow(db, 'DELETE FROM group_chat_reviews WHERE group_id = ? AND session_id = ?', [groupId, sessionId])
		runSqlOrThrow(db, 'DELETE FROM group_chat_tasks WHERE group_id = ? AND session_id = ?', [groupId, sessionId])
		runSqlOrThrow(db, 'DELETE FROM group_agent_memories WHERE group_id = ? AND session_id = ?', [groupId, sessionId])
		runSqlOrThrow(db, 'DELETE FROM group_agent_metrics WHERE group_id = ? AND session_id = ?', [groupId, sessionId])
		runSqlOrThrow(db, 'DELETE FROM group_chat_sessions WHERE group_id = ? AND id = ?', [groupId, sessionId])
		assertSqlSuccess(db.commit(), '无法提交群会话删除事务')
	} catch (e: any) {
		db.rollback()
		db.close()
		throw e
	}
	db.close()
}

/** 回滚尚未完成创建的群聊，避免多步保存失败后留下半成品记录。 */
export function deleteGroupChatCreationRows(groupId: string): void {
	if (groupId == '') { return }
	const db = getDb()
	ensureGroupChatTables(db)
	try {
		assertSqlSuccess(db.beginTransaction(), '无法开始群聊创建回滚事务')
		runSqlOrThrow(db, 'DELETE FROM group_chat_messages WHERE group_id = ?', [groupId])
		runSqlOrThrow(db, 'DELETE FROM group_agent_context_records WHERE group_id = ?', [groupId])
		runSqlOrThrow(db, 'DELETE FROM group_chat_reviews WHERE group_id = ?', [groupId])
		runSqlOrThrow(db, 'DELETE FROM group_chat_tasks WHERE group_id = ?', [groupId])
		runSqlOrThrow(db, 'DELETE FROM group_agent_memories WHERE group_id = ?', [groupId])
		runSqlOrThrow(db, 'DELETE FROM group_agent_metrics WHERE group_id = ?', [groupId])
		runSqlOrThrow(db, 'DELETE FROM group_chat_sessions WHERE group_id = ?', [groupId])
		runSqlOrThrow(db, 'DELETE FROM group_chat_members WHERE group_id = ?', [groupId])
		runSqlOrThrow(db, 'DELETE FROM group_chats WHERE id = ?', [groupId])
		assertSqlSuccess(db.commit(), '无法提交群聊创建回滚事务')
	} catch (e: any) {
		db.rollback()
		db.close()
		throw e
	}
	db.close()
}
