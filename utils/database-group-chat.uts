export function saveGroupSessionRows(groupId: string, rows: UTSJSONObject[]): boolean {
	const db = getDb()
	ensureGroupChatTables(db)
	try {
		assertSqlSuccess(db.beginTransaction(), '无法开始群会话保存事务')
		runSqlOrThrow(db, 'DELETE FROM group_chat_sessions WHERE group_id = ? AND ? = ?', [groupId, 1, 1])
		for (let i = 0; i < rows.length; i++) {
			const row = rows[i]
			runSqlOrThrow(db,
				'INSERT OR REPLACE INTO group_chat_sessions (id, group_id, title, workspace_path, forked_from_session_id, title_locked, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?)',
				[
					readStringField(row, 'id'),
					groupId,
					readStringField(row, 'title'),
					readStringField(row, 'workspace_path') != '' ? readStringField(row, 'workspace_path') : readStringField(row, 'workspacePath'),
					readStringField(row, 'forked_from_session_id') != '' ? readStringField(row, 'forked_from_session_id') : readStringField(row, 'forkedFromSessionId'),
					readNumberField(row, 'title_locked') > 0 ? readNumberField(row, 'title_locked') : readNumberField(row, 'titleLocked'),
					readNumberField(row, 'created_at') > 0 ? readNumberField(row, 'created_at') : readNumberField(row, 'createdAt'),
					readNumberField(row, 'updated_at') > 0 ? readNumberField(row, 'updated_at') : readNumberField(row, 'updatedAt'),
				]
			)
		}
		assertSqlSuccess(db.commit(), '无法提交群会话保存事务')
	} catch (_e: any) {
		db.rollback()
		db.close()
		return false
	}
	db.close()
	return true
}

export function getGroupMessageRows(groupId: string, sessionId: string): UTSJSONObject[] {
	const db = getDb()
	ensureGroupChatTables(db)
	const result = db.query('SELECT * FROM group_chat_messages WHERE group_id = ? AND session_id = ? ORDER BY timestamp ASC, updated_at ASC, id ASC', [groupId, sessionId])
	db.close()
	assertSqlSuccess(result, '读取群聊消息失败')
	return rowsToObjects(result)
}

const GROUP_MESSAGE_PAGE_SIZE_MAX = 200

function assertValidGroupMessagePageSize(batchSize: number): void {
	if (batchSize <= 0 || batchSize > GROUP_MESSAGE_PAGE_SIZE_MAX || Math.floor(batchSize) != batchSize) {
		throw new Error('群聊消息批大小必须是 1 到 ' + GROUP_MESSAGE_PAGE_SIZE_MAX + ' 的整数')
	}
}

function reverseGroupMessageRows(rows: UTSJSONObject[]): UTSJSONObject[] {
	const result: UTSJSONObject[] = []
	for (let i = rows.length - 1; i >= 0; i--) {
		result.push(rows[i])
	}
	return result
}

export function getGroupMessageRowCount(groupId: string, sessionId: string): number {
	if (groupId == '' || sessionId == '') { return 0 }
	const db = getDb()
	ensureGroupChatTables(db)
	const result = db.query(
		'SELECT COUNT(*) AS total_count FROM group_chat_messages WHERE group_id = ? AND session_id = ?',
		[groupId, sessionId]
	)
	db.close()
	assertSqlSuccess(result, '读取群聊消息总数失败')
	const rows = rowsToObjects(result)
	return rows.length > 0 ? readNumberField(rows[0], 'total_count') : 0
}

export function getRecentGroupMessageRows(groupId: string, sessionId: string, batchSize: number): UTSJSONObject[] {
	assertValidGroupMessagePageSize(batchSize)
	if (groupId == '' || sessionId == '') { return [] as UTSJSONObject[] }
	const db = getDb()
	ensureGroupChatTables(db)
	const result = db.query(
		'SELECT * FROM group_chat_messages WHERE group_id = ? AND session_id = ? ORDER BY timestamp DESC, updated_at DESC, id DESC LIMIT ?',
		[groupId, sessionId, batchSize]
	)
	db.close()
	assertSqlSuccess(result, '读取最近群聊消息失败')
	return reverseGroupMessageRows(rowsToObjects(result))
}

export function getGroupMessageRowsBefore(
	groupId: string,
	sessionId: string,
	beforeTimestamp: number,
	beforeUpdatedAt: number,
	beforeId: string,
	batchSize: number
): UTSJSONObject[] {
	assertValidGroupMessagePageSize(batchSize)
	if (groupId == '' || sessionId == '' || beforeTimestamp < 0 || beforeUpdatedAt < 0 || beforeId == '') {
		throw new Error('群聊消息分页游标无效')
	}
	const db = getDb()
	ensureGroupChatTables(db)
	const result = db.query(
		'SELECT * FROM group_chat_messages WHERE group_id = ? AND session_id = ? AND (' +
		'timestamp < ? OR (timestamp = ? AND updated_at < ?) OR (timestamp = ? AND updated_at = ? AND id < ?)' +
		') ORDER BY timestamp DESC, updated_at DESC, id DESC LIMIT ?',
		[
			groupId,
			sessionId,
			beforeTimestamp,
			beforeTimestamp,
			beforeUpdatedAt,
			beforeTimestamp,
			beforeUpdatedAt,
			beforeId,
			batchSize,
		]
	)
	db.close()
	assertSqlSuccess(result, '向前读取群聊消息失败')
	return reverseGroupMessageRows(rowsToObjects(result))
}

const GROUP_MESSAGE_PERSISTED_UPDATED_AT_FIELD = 'persistedUpdatedAt'
const GROUP_MESSAGE_PERSISTED_PAYLOAD_FIELD = 'persistedPayloadJson'
const GROUP_MESSAGE_QUERY_BATCH_SIZE = 400

export type GroupMessageSaveResult = {
	ok: boolean
	conflicted: boolean
	conflictMessageIds: string[]
}

function buildGroupMessageSaveResult(ok: boolean, conflictMessageIds: string[]): GroupMessageSaveResult {
	return {
		ok: ok,
		conflicted: conflictMessageIds.length > 0,
		conflictMessageIds: conflictMessageIds,
	} as GroupMessageSaveResult
}

function buildGroupMessagePayloadJson(message: UTSJSONObject): string {
	const rawJson = safeJsonForDb(message)
	const payload = JSON.parse(rawJson) as UTSJSONObject
	// 数据库 updated_at 才是版本源；两个本地缓存字段都不能参与内容比较。
	payload[GROUP_MESSAGE_PERSISTED_UPDATED_AT_FIELD] = 0
	payload[GROUP_MESSAGE_PERSISTED_PAYLOAD_FIELD] = ''
	return safeJsonForDb(payload)
}

function normalizeStoredGroupMessagePayloadJson(payloadJson: string): string {
	if (payloadJson == '') { return '' }
	try {
		const payload = JSON.parse(payloadJson) as UTSJSONObject
		payload[GROUP_MESSAGE_PERSISTED_UPDATED_AT_FIELD] = 0
		payload[GROUP_MESSAGE_PERSISTED_PAYLOAD_FIELD] = ''
		return safeJsonForDb(payload)
	} catch (_e: any) {
		return payloadJson
	}
}

export function saveGroupMessageRowsDetailed(groupId: string, sessionId: string, messages: UTSJSONObject[]): GroupMessageSaveResult {
	const now = Date.now()
	const candidateMessages: UTSJSONObject[] = []
	const candidatePayloads: string[] = []
	const candidateIds: string[] = []
	const seenIds: Map<string, boolean> = new Map<string, boolean>()
	try {
		for (let i = 0; i < messages.length; i++) {
			const msg = messages[i]
			const messageId = readStringField(msg, 'id')
			if (messageId == '' || seenIds.has(messageId) == true) {
				return buildGroupMessageSaveResult(false, [] as string[])
			}
			const expectedVersionRaw = msg[GROUP_MESSAGE_PERSISTED_UPDATED_AT_FIELD] as number | null
			const cachedPayloadRaw = msg[GROUP_MESSAGE_PERSISTED_PAYLOAD_FIELD] as string | null
			seenIds.set(messageId, true)
			if (expectedVersionRaw != null && expectedVersionRaw >= 0 && cachedPayloadRaw != null && cachedPayloadRaw != '') {
				continue
			}
			const payloadJson = buildGroupMessagePayloadJson(msg)
			candidateMessages.push(msg)
			candidatePayloads.push(payloadJson)
			candidateIds.push(messageId)
		}
	} catch (_e: any) {
		return buildGroupMessageSaveResult(false, [] as string[])
	}
	if (candidateMessages.length == 0) {
		return buildGroupMessageSaveResult(true, [] as string[])
	}
	const db = getDb()
	ensureGroupChatTables(db)
	const persistedMessages: UTSJSONObject[] = []
	const persistedVersions: number[] = []
	const persistedPayloads: string[] = []
	const conflictMessageIds: string[] = []
	try {
		assertSqlSuccess(db.beginTransaction(), '无法开始群消息保存事务')
		const existingRowById: Map<string, UTSJSONObject> = new Map<string, UTSJSONObject>()
		for (let batchStart = 0; batchStart < candidateIds.length; batchStart += GROUP_MESSAGE_QUERY_BATCH_SIZE) {
			let batchEnd = batchStart + GROUP_MESSAGE_QUERY_BATCH_SIZE
			if (batchEnd > candidateIds.length) { batchEnd = candidateIds.length }
			const placeholders: string[] = []
			const queryParams: any[] = [groupId, sessionId]
			for (let i = batchStart; i < batchEnd; i++) {
				placeholders.push('?')
				queryParams.push(candidateIds[i])
			}
			const existingResult = db.query(
				'SELECT id, payload_json, updated_at FROM group_chat_messages WHERE group_id = ? AND session_id = ? AND id IN (' + placeholders.join(',') + ')',
				queryParams
			)
			assertSqlSuccess(existingResult, '无法读取群消息保存快照')
			const existingRows = rowsToObjects(existingResult)
			for (let i = 0; i < existingRows.length; i++) {
				const existingId = readStringField(existingRows[i], 'id')
				if (existingId != '') {
					existingRowById.set(existingId, existingRows[i])
				}
			}
		}
		// 整批先做 CAS 预检；任一冲突都不能让同批其他消息先提交。
		for (let i = 0; i < candidateMessages.length; i++) {
			const msg = candidateMessages[i]
			const messageId = candidateIds[i]
			const payloadJson = candidatePayloads[i]
			const expectedVersionRaw = msg[GROUP_MESSAGE_PERSISTED_UPDATED_AT_FIELD] as number | null
			const hasExpectedVersion = expectedVersionRaw != null && expectedVersionRaw >= 0
			const existingRow = existingRowById.get(messageId)
			if (existingRow != null) {
				const existingPayloadJson = normalizeStoredGroupMessagePayloadJson(readStringField(existingRow, 'payload_json'))
				if (existingPayloadJson == payloadJson) { continue }
				const existingVersion = readNumberField(existingRow, 'updated_at')
				if (hasExpectedVersion == false || expectedVersionRaw == null || expectedVersionRaw != existingVersion) {
					conflictMessageIds.push(messageId)
				}
			} else if (hasExpectedVersion == true) {
				conflictMessageIds.push(messageId)
			}
		}
		if (conflictMessageIds.length > 0) {
			db.rollback()
			db.close()
			return buildGroupMessageSaveResult(true, conflictMessageIds)
		}
		let changed = false
		let metadataUpdatedAt = now
		for (let i = 0; i < candidateMessages.length; i++) {
			const msg = candidateMessages[i]
			const messageId = candidateIds[i]
			const payloadJson = candidatePayloads[i]
			const expectedVersionRaw = msg[GROUP_MESSAGE_PERSISTED_UPDATED_AT_FIELD] as number | null
			const hasExpectedVersion = expectedVersionRaw != null && expectedVersionRaw >= 0
			const expectedVersion = hasExpectedVersion == true && expectedVersionRaw != null ? expectedVersionRaw : 0
			const existingRow = existingRowById.get(messageId)
			if (existingRow != null) {
				const existingVersion = readNumberField(existingRow, 'updated_at')
				const existingPayloadJson = normalizeStoredGroupMessagePayloadJson(readStringField(existingRow, 'payload_json'))
				if (existingPayloadJson == payloadJson) {
					persistedMessages.push(msg)
					persistedVersions.push(existingVersion)
					persistedPayloads.push(payloadJson)
					continue
				}
				if (hasExpectedVersion == false || expectedVersion != existingVersion) {
					conflictMessageIds.push(messageId)
					continue
				}
			} else if (hasExpectedVersion == true) {
				conflictMessageIds.push(messageId)
				continue
			}
			const visibleRaw = msg['visible'] as boolean | null
			const visible = visibleRaw == false ? 0 : 1
			const visibilityRaw = msg['visibility'] as string | null
			const visibility = visibilityRaw != null && visibilityRaw != '' ? visibilityRaw : (visible == 1 ? 'public' : 'internal')
			const timestampRaw = msg['timestamp'] as number | null
			const timestamp = timestampRaw != null && timestampRaw > 0 ? timestampRaw : now
			const visibleAgentIdsRaw = msg['visibleAgentIds'] as string[] | null
			const visibleAgentIds = visibleAgentIdsRaw != null ? visibleAgentIdsRaw : ([] as string[])
			let writeVersion = now
			if (existingRow != null) {
				const existingVersion = readNumberField(existingRow, 'updated_at')
				if (writeVersion <= existingVersion) { writeVersion = existingVersion + 1 }
				const updateResult = db.run(
					'UPDATE group_chat_messages SET role = ?, sender_type = ?, sender_agent_id = ?, visibility = ?, visible_agent_ids_json = ?, visible = ?, timestamp = ?, payload_json = ?, updated_at = ? WHERE id = ? AND group_id = ? AND session_id = ? AND updated_at = ?',
					[
						readStringField(msg, 'role'),
						readStringField(msg, 'senderType'),
						readStringField(msg, 'senderAgentId'),
						visibility,
						safeJsonArrayForDb(visibleAgentIds),
						visible,
						timestamp,
						payloadJson,
						writeVersion,
						messageId,
						groupId,
						sessionId,
						existingVersion,
					]
				)
				assertSqlSuccess(updateResult, '更新群聊消息失败')
				const updateChanges = updateResult.changes
				if (updateChanges == null || updateChanges <= 0) {
					const currentResult = db.query(
						'SELECT payload_json, updated_at FROM group_chat_messages WHERE id = ? AND group_id = ? AND session_id = ? LIMIT 1',
						[messageId, groupId, sessionId]
					)
					assertSqlSuccess(currentResult, '读取群消息并发更新结果失败')
					const currentRows = rowsToObjects(currentResult)
					if (currentRows.length > 0 && normalizeStoredGroupMessagePayloadJson(readStringField(currentRows[0], 'payload_json')) == payloadJson) {
						persistedMessages.push(msg)
						persistedVersions.push(readNumberField(currentRows[0], 'updated_at'))
						persistedPayloads.push(payloadJson)
					} else {
						conflictMessageIds.push(messageId)
						throw new Error('群消息并发更新冲突：' + messageId)
					}
					continue
				}
			} else {
				const insertResult = db.run(
					'INSERT OR IGNORE INTO group_chat_messages (id, group_id, session_id, role, sender_type, sender_agent_id, visibility, visible_agent_ids_json, visible, timestamp, payload_json, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)',
					[
						messageId,
						groupId,
						sessionId,
						readStringField(msg, 'role'),
						readStringField(msg, 'senderType'),
						readStringField(msg, 'senderAgentId'),
						visibility,
						safeJsonArrayForDb(visibleAgentIds),
						visible,
						timestamp,
						payloadJson,
						writeVersion,
					]
				)
				assertSqlSuccess(insertResult, '新增群聊消息失败')
				const insertChanges = insertResult.changes
				if (insertChanges == null || insertChanges <= 0) {
					const currentResult = db.query(
						'SELECT payload_json, updated_at FROM group_chat_messages WHERE id = ? AND group_id = ? AND session_id = ? LIMIT 1',
						[messageId, groupId, sessionId]
					)
					assertSqlSuccess(currentResult, '读取群消息并发新增结果失败')
					const currentRows = rowsToObjects(currentResult)
					if (currentRows.length > 0 && normalizeStoredGroupMessagePayloadJson(readStringField(currentRows[0], 'payload_json')) == payloadJson) {
						persistedMessages.push(msg)
						persistedVersions.push(readNumberField(currentRows[0], 'updated_at'))
						persistedPayloads.push(payloadJson)
					} else {
						conflictMessageIds.push(messageId)
						throw new Error('群消息并发新增冲突：' + messageId)
					}
					continue
				}
			}
			changed = true
			if (writeVersion > metadataUpdatedAt) { metadataUpdatedAt = writeVersion }
			persistedMessages.push(msg)
			persistedVersions.push(writeVersion)
			persistedPayloads.push(payloadJson)
		}
		if (changed == true) {
			runSqlOrThrow(db, 'UPDATE group_chat_sessions SET updated_at = CASE WHEN updated_at < ? THEN ? ELSE updated_at END WHERE group_id = ? AND id = ?', [metadataUpdatedAt, metadataUpdatedAt, groupId, sessionId])
			runSqlOrThrow(db, 'UPDATE group_chats SET updated_at = CASE WHEN updated_at < ? THEN ? ELSE updated_at END WHERE id = ?', [metadataUpdatedAt, metadataUpdatedAt, groupId])
		}
		assertSqlSuccess(db.commit(), '无法提交群消息保存事务')
	} catch (_e: any) {
		db.rollback()
		db.close()
		return buildGroupMessageSaveResult(false, conflictMessageIds)
	}
	db.close()
	for (let i = 0; i < persistedMessages.length; i++) {
		persistedMessages[i][GROUP_MESSAGE_PERSISTED_UPDATED_AT_FIELD] = persistedVersions[i]
		persistedMessages[i][GROUP_MESSAGE_PERSISTED_PAYLOAD_FIELD] = persistedPayloads[i]
	}
	return buildGroupMessageSaveResult(true, conflictMessageIds)
}

export function saveGroupMessageRows(groupId: string, sessionId: string, messages: UTSJSONObject[]): boolean {
	const result = saveGroupMessageRowsDetailed(groupId, sessionId, messages)
	return result.ok == true && result.conflicted == false
}

export function deleteGroupMessageRow(groupId: string, sessionId: string, messageId: string, expectedUpdatedAt: number): boolean {
	if (groupId == '' || sessionId == '' || messageId == '' || expectedUpdatedAt < 0) { return false }
	const db = getDb()
	ensureGroupChatTables(db)
	try {
		assertSqlSuccess(db.beginTransaction(), '无法开始群消息删除事务')
		const deleteResult = db.run(
			'DELETE FROM group_chat_messages WHERE group_id = ? AND session_id = ? AND id = ? AND updated_at = ?',
			[groupId, sessionId, messageId, expectedUpdatedAt]
		)
		assertSqlSuccess(deleteResult, '删除群聊消息失败')
		const deleteChanges = deleteResult.changes
		if (deleteChanges == null || deleteChanges <= 0) {
			throw new Error('群消息删除冲突：' + messageId)
		}
		let metadataUpdatedAt = Date.now()
		if (metadataUpdatedAt <= expectedUpdatedAt) { metadataUpdatedAt = expectedUpdatedAt + 1 }
		runSqlOrThrow(db, 'UPDATE group_chat_sessions SET updated_at = CASE WHEN updated_at < ? THEN ? ELSE updated_at END WHERE group_id = ? AND id = ?', [metadataUpdatedAt, metadataUpdatedAt, groupId, sessionId])
		runSqlOrThrow(db, 'UPDATE group_chats SET updated_at = CASE WHEN updated_at < ? THEN ? ELSE updated_at END WHERE id = ?', [metadataUpdatedAt, metadataUpdatedAt, groupId])
		assertSqlSuccess(db.commit(), '无法提交群消息删除事务')
	} catch (_e: any) {
		db.rollback()
		db.close()
		return false
	}
	db.close()
	return true
}

