/**
 * 发言申请热路径只需要活动申请和取消保护记录。
 * 已完成的普通任务与历史申请不参与路由，避免长会话每轮全表 JSON 解析。
 */
export function getGroupSpeakIntentTaskRows(groupId: string, sessionId: string): UTSJSONObject[] {
	const db = getDb()
	ensureGroupChatTables(db)
	const result = db.query(
		'SELECT * FROM group_chat_tasks WHERE group_id = ? AND session_id = ? AND (' +
		'((status = ? OR status = ?) AND id LIKE ?) OR id LIKE ? OR id IN (' +
		'SELECT ? || id FROM group_chat_tasks WHERE group_id = ? AND session_id = ? AND (status = ? OR status = ?) AND id LIKE ?' +
		')) ORDER BY updated_at DESC',
		[groupId, sessionId, 'open', 'claimed', 'gspeak-%', 'gspeak-session-tombstone-%', 'gspeak-tombstone-', groupId, sessionId, 'open', 'claimed', 'gspeak-%']
	)
	db.close()
	assertSqlSuccess(result, '读取群聊活动发言申请失败')
	return rowsToObjects(result)
}

