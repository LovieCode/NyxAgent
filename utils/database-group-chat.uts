		'INSERT OR REPLACE INTO group_agent_context_records (id, agent_id, group_id, session_id, created_at, payload_json) VALUES (?, ?, ?, ?, ?, ?)',
		[
			readStringField(record, 'id'),
			readStringField(record, 'agentId') != '' ? readStringField(record, 'agentId') : readStringField(record, 'agent_id'),
			readStringField(record, 'groupId') != '' ? readStringField(record, 'groupId') : readStringField(record, 'group_id'),
			readStringField(record, 'sessionId') != '' ? readStringField(record, 'sessionId') : readStringField(record, 'session_id'),
			readNumberField(record, 'createdAt') > 0 ? readNumberField(record, 'createdAt') : readNumberField(record, 'created_at'),
			payloadJson,
		]
	)
	db.close()
	try {
		assertSqlSuccess(result, '保存群聊成员上下文失败')
	} catch (_e: any) {
		return false
	}
	return true
}

