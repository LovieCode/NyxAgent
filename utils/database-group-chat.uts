export function setGroupChatState(key: string, value: string): void {
	const db = getDb()
	ensureGroupChatTables(db)
	db.run('INSERT OR REPLACE INTO group_chat_state (key, value, updated_at) VALUES (?, ?, ?)', [key, value, Date.now()])
	db.close()
}

export function getGroupChatState(key: string): string {
	const db = getDb()
	ensureGroupChatTables(db)
	const result = db.query('SELECT value FROM group_chat_state WHERE key = ? AND ? = ? LIMIT 1', [key, 1, 1])
	db.close()
	const rows = rowsToObjects(result)
	if (rows.length > 0) {
		return readStringField(rows[0], 'value')
	}
	return ''
}

export function deleteGroupSessionDbRows(groupId: string, sessionId: string): void {
	const db = getDb()
	ensureGroupChatTables(db)
	db.run('DELETE FROM group_chat_messages WHERE group_id = ? AND session_id = ?', [groupId, sessionId])
	db.run('DELETE FROM group_agent_context_records WHERE group_id = ? AND session_id = ?', [groupId, sessionId])
	db.run('DELETE FROM group_chat_reviews WHERE group_id = ? AND session_id = ?', [groupId, sessionId])
	db.run('DELETE FROM group_chat_tasks WHERE group_id = ? AND session_id = ?', [groupId, sessionId])
	db.run('DELETE FROM group_agent_memories WHERE group_id = ? AND session_id = ?', [groupId, sessionId])
	db.run('DELETE FROM group_agent_metrics WHERE group_id = ? AND session_id = ?', [groupId, sessionId])
	db.close()
}
