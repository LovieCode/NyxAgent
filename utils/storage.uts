import { getAppSetting, removeAppSetting, setAppSetting } from '@/utils/database.uts'

/**
 * storage 工具模块 - 兼容旧本地存储调用
 * 新写入统一落 SQLite app_settings，不再使用旧同步 storage 写入。
 */

/**
 * 存储数据到本地
 * @param key 存储键名
 * @param value 存储值
 */
export function setStorage(key : string, value : string) : void {
	setAppSetting(key, value)
}

/**
 * 从本地读取数据
 * @param key 存储键名
 * @returns 存储的值，不存在则返回空字符串
 */
export function getStorage(key : string) : string {
	const value = getAppSetting(key)
	if (value != null) { return value }
	// COMPAT_LEGACY_STORAGE_READ: 兼容旧版本 uni.storage，未来清理 storage 迁移时删除。
	const legacy = uni.getStorageSync(key) as string | null
	return legacy != null ? legacy : ''
}

/**
 * 从本地删除数据
 * @param key 存储键名
 */
export function removeStorage(key : string) : void {
	removeAppSetting(key)
	// COMPAT_LEGACY_STORAGE_REMOVE: 清掉旧版本残留 key，未来清理 storage 迁移时删除。
	uni.removeStorageSync(key)
}

/**
 * 清空本地存储数据
 */
export function clearStorage() : void {
	// COMPAT_LEGACY_STORAGE_CLEAR: 仅保留给旧调用方清理历史 uni.storage，未来清空。
	uni.clearStorageSync()
}
