/**
 * LLM 调用工具层
 * 直接使用 uni.request 调用 OpenAI 兼容 API
 *
 * 配置来源优先级（从高到低）：
 * 1. 显式传入的 providerId + model
 * 2. DB 中 chat 任务的默认配置
 * 3. 旧版 storage key（向后兼容）
 */

import { getDefaultTaskModel, getProviderById } from '@/utils/provider.uts'

/**
 * 规范化 baseUrl：去掉末尾的 /v1 或 /v1/
 */
function normalizeBaseUrl(url: string): string {
	let result = url
	if (result.endsWith('/v1')) {
		result = result.substring(0, result.length - 3)
	} else if (result.endsWith('/v1/')) {
		result = result.substring(0, result.length - 4)
	}
	if (result.endsWith('/')) {
		result = result.substring(0, result.length - 1)
	}
	return result
}

/**
 * 获取默认 URL（兜底）
 */
function getDefaultUrl(providerId: string): string {
	if (providerId == 'anthropic') return 'https://api.anthropic.com'
	if (providerId == 'openai') return 'https://api.openai.com'
	if (providerId == 'deepseek') return 'https://api.deepseek.com'
	if (providerId == 'zai') return 'https://api.z.ai/api/coding/paas/v4'
	if (providerId == 'kimi-coding') return 'https://api.kimi.com/coding'
	if (providerId == 'minimax-cn') return 'https://api.minimaxi.com/anthropic'
	if (providerId == 'xiaomi') return 'https://api.xiaomimimo.com/v1'
	if (providerId == 'ant-ling') return 'https://api.ant-ling.com/v1'
	if (providerId == 'siliconflow') return 'https://api.siliconflow.cn/v1'
	return ''
}

/**
 * 读取 LLM 配置（按优先级）
 * @returns { providerId, apiKey, baseUrl, model } 或 null
 */
function readLlmConfig(providerId: string, model: string): UTSJSONObject | null {
	let pid = providerId
	let mdl = model

	// 0. 解析 "providerId||modelId" 复合格式
	if (mdl != '') {
		const sep = '||'
		const idx = mdl.indexOf(sep)
		if (idx >= 0) {
			const extractedPid = mdl.substring(0, idx)
			const extractedMid = mdl.substring(idx + sep.length)
			if (pid == '') {
				pid = extractedPid
			}
			mdl = extractedMid
		}
	}

	// 1. 没有显式传 → 从 DB 读取 chat 默认配置
	if (pid == '') {
		const defaultConfig = getDefaultTaskModel('chat')
		if (defaultConfig != null) {
			pid = defaultConfig['providerId'] as string
			if (mdl == '') {
				mdl = defaultConfig['model'] as string
			}
		}
	}

	// 2. 回退到旧版 storage
	if (pid == '') {
		pid = uni.getStorageSync('settings_provider_id') as string
	}
	if (mdl == '') {
		mdl = uni.getStorageSync('settings_model') as string
	}

	if (pid == '' || mdl == '') {
		return null
	}

	// 3. 从 DB 读取提供商 API 配置
	const provider = getProviderById(pid)
	if (provider != null) {
		const apiKey = provider['api_key'] as string
		let baseUrl = provider['api_base'] as string
		if (baseUrl == '') {
			baseUrl = getDefaultUrl(pid)
		}
		if (apiKey == '') {
			return null
		}
		return {
			providerId: pid,
			apiKey: apiKey,
			baseUrl: baseUrl,
			model: mdl,
		} as UTSJSONObject
	}

	// 4. 兜底：旧版 storage
	const apiKey = uni.getStorageSync('settings_api_key') as string
	if (apiKey == null || apiKey == '') {
		return null
	}
	let baseUrl = uni.getStorageSync('settings_base_url') as string
	if (baseUrl == '') {
		baseUrl = getDefaultUrl(pid)
		if (baseUrl == '') {
			return null
		}
	}
	return {
		providerId: pid,
		apiKey: apiKey,
		baseUrl: baseUrl,
		model: mdl,
	} as UTSJSONObject
}

/**
 * 发送消息给 LLM 并获取回复文本
 * @param messages 消息列表
 * @param systemPrompt 可选的系统提示词
 * @param providerId 提供商 ID（传空字符串则使用默认配置）
 * @param model 模型名（传空字符串则使用默认配置）
 */
export function chatWithLLM(
	messages: UTSJSONObject[],
	systemPrompt: string = '',
	providerId: string = '',
	model: string = ''
): Promise<string | null> {
	return new Promise<string | null>((resolve) => {
		const config = readLlmConfig(providerId, model)
		if (config == null) {
			resolve(null)
			return
		}

		const apiKey = config['apiKey'] as string
		let baseUrl = config['baseUrl'] as string
		const mdl = config['model'] as string

		baseUrl = normalizeBaseUrl(baseUrl)

		// 构建消息列表
		const apiMessages: UTSJSONObject[] = []
		// 非空 systemPrompt 作为首条 system 消息
		if (systemPrompt != '') {
			apiMessages.push({
				role: 'system',
				content: systemPrompt,
			} as UTSJSONObject)
		}
		for (let i = 0; i < messages.length; i++) {
			const msg = messages[i]
			const role = msg['role'] as string | null
			const content = msg['content'] as string | null
			if (role == null || content == null) {
				continue
			}
			if (role == 'assistant' && content == '' && msg['isStreaming'] == true) {
				continue
			}
			apiMessages.push({
				role: role,
				content: content,
			} as UTSJSONObject)
		}

		// 构建请求
		const url = baseUrl + '/v1/chat/completions'
		const headers: UTSJSONObject = {
			'Content-Type': 'application/json',
			'Authorization': 'Bearer ' + apiKey,
		}
		const body: UTSJSONObject = {
			model: mdl,
			messages: apiMessages,
			max_tokens: 4096,
			temperature: 0.7,
			stream: false,
		}

		uni.request({
			url: url,
			method: 'POST',
			header: headers,
			data: body,
			success: (res) => {
				const statusCode = res.statusCode as number
				if (statusCode == 200) {
					try {
						const responseData = res.data as UTSJSONObject
						if (responseData == null) {
							resolve(null)
							return
						}
						const choices = responseData['choices'] as UTSJSONObject[] | null
						if (choices != null && choices.length > 0) {
							const choice = choices[0]
							const message = choice['message'] as UTSJSONObject | null
							if (message != null) {
								const text = message['content'] as string | null
								resolve(text ?? '')
								return
							}
						}
						resolve('')
					} catch (_e: any) {
						resolve(null)
					}
				} else {
					resolve(null)
				}
			},
			fail: (_err: any) => {
				resolve(null)
			}
		})
	})
}
