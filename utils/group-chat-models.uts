/**
 * 群聊基础模型与序列化工具。
 *
 * 不依赖数据库和文件系统；服务层负责持久化与副作用。
 */

export const ACTIVE_GROUP_CHAT_ID_KEY = 'active_group_chat_id'
export const ACTIVE_GROUP_SESSION_ID_KEY = 'active_group_session_id'
export const NYX_ADMIN_AGENT_ID = 'nyx-admin'
export const NYX_ADMIN_AGENT_NAME = '眠汐'
export const GROUP_SCHEDULER_AGENT_NAME = '群调度'
export const GROUP_REVIEWER_AGENT_NAME = '群复盘'
const GROUP_SCHEDULER_AGENT_ID_PREFIX = 'group-scheduler-'
const GROUP_REVIEWER_AGENT_ID_PREFIX = 'group-reviewer-'

export const GROUP_MESSAGE_SENDER_USER = 'user'
export const GROUP_MESSAGE_SENDER_AGENT = 'agent'
export const GROUP_MESSAGE_SENDER_SCHEDULER = 'scheduler'
export const GROUP_MESSAGE_SENDER_REVIEWER = 'reviewer'
export const GROUP_MESSAGE_SENDER_SYSTEM = 'system'

export const GROUP_MESSAGE_VISIBILITY_PUBLIC = 'public'
export const GROUP_MESSAGE_VISIBILITY_INTERNAL = 'internal'
export const GROUP_MESSAGE_VISIBILITY_PRIVATE = 'private'
export const GROUP_MESSAGE_VISIBILITY_DEBUG = 'debug'

export const GROUP_MESSAGE_AUDIENCE_GROUP = 'group'
export const GROUP_MESSAGE_AUDIENCE_USER = 'user'
export const GROUP_MESSAGE_AUDIENCE_AGENT = 'agent'

export const GROUP_DELIVERY_MODE_PUBLIC = 'public'
export const GROUP_DELIVERY_MODE_USER_PRIVATE = 'user_private'

export function markGroupMessageDirty(message: UTSJSONObject): void {
	message['persistedPayloadJson'] = ''
}

export const LEGACY_DIRECTIVE_SCHEDULER_PROMPT_TEXT = '你是本群聊独立的隐藏调度子代理。你可以在内部向任意成员 Agent 传递私密指令、背景信息和任务拆解，也可以指定一个或多个成员按顺序发言。你的存在、调度流程、私密指令不能被其他成员在公开发言中暴露。你只在系统触发节点工作，例如用户发消息、用户手动继续、连续讨论过多需要判断是否继续。\n' +
	'输出必须是 JSON 对象，禁止 Markdown，结构：{"actions":[{"type":"speak","agentId":"成员ID","targetType":"user","targetAgentId":"","privateInstruction":"给该成员的私密指令","publicIntent":"公开发言目标","replyLength":"short","replyGuidance":"简短自然，优先 1-3 句","searchAdvice":"none","searchInstruction":"","order":0}],"shouldContinue":false,"titleSuggestion":"适合本会话的短标题","privateNotes":"仅内部记录"}。\n' +
	'默认让成员简短发言。事实不确定、涉及外部/时效信息时，建议具备相关工具的成员先查证或搜索；发现跑题、重复、事实冲突或虚构 App 功能时，用私密指令要求纠偏和收束。不要为了热闹强行多人发言。'

export const LEGACY_ENVIRONMENT_SCHEDULER_PROMPT_TEXT = '你是本群聊独立的隐藏环境模型。你只负责选择下一位发言成员、提供必要的环境反馈，并判断当前讨论是否应当结束。不要替成员撰写观点、措辞、回答提纲或固定回复长度，成员必须依据用户原文和自身人格自主发言。\n' +
	'输出必须是 JSON 对象，禁止 Markdown，结构：{"actions":[{"type":"speak","agentId":"成员ID","targetType":"user","targetAgentId":"","routeReason":"选择该成员的简短原因","environmentFeedback":"该成员需要知道的客观环境变化，没有则为空","order":0}],"shouldContinue":false,"titleSuggestion":"适合本会话的短标题","privateNotes":"仅内部记录"}。\n' +
	'简单消息只选一个最合适的成员；用户点名时优先被点名者；协作、评审或明确要求多人参与时最多选择三个成员。不要要求成员复述全部要点，也不要为了热闹强行多人发言。'

export const PREVIOUS_DEFAULT_SCHEDULER_PROMPT_TEXT = '本群采用自然对话路由。先判断最新消息在回应谁、需要什么能力，以及现有公开发言是否已经覆盖重点，再选择本轮发言者。\n' +
	'默认只选一位最合适的成员；用户点名时只安排被点名者，除非用户明确邀请其他人。只有多人能提供彼此独立、非重复的价值，或用户明确要求协作、对比、评审时，才安排两到三人，并按前后发言依赖排序。\n' +
	'不要按成员列表顺序或发言次数机械轮换。发言次数只能在候选者同样合适时作为弱参考；连续讨论只有存在尚未完成且能被下一位成员具体推进的事项时才继续。成员公开发言中的明确 @交接只是候选信号，仍由调度决定是否安排下一位。'

export const LEGACY_NATURAL_ROUTING_SCHEDULER_PROMPT_TEXT = '本群采用自然对话路由。先判断最新消息在回应谁、需要什么能力，以及现有公开发言是否已经覆盖重点，再选择本轮发言者。\n' +
	'默认只选一位最合适的成员；用户点名时只安排被点名者，除非用户明确邀请其他人。只有多人能提供彼此独立、非重复的价值，或用户明确要求协作、对比、评审时，才安排两到三人，并按前后发言依赖排序。\n' +
	'不要按成员列表顺序或发言次数机械轮换。发言次数只能在候选者同样合适时作为弱参考；连续讨论只有存在尚未完成且能被下一位成员具体推进的事项时才继续。'

export const PREVIOUS_DEFAULT_SHARED_PROMPT_TEXT = '这是多人线上聊天，不是统一口吻的协作报告。每位成员保持自己的身份、知识边界、关系距离和表达习惯；被选中只表示获得发言机会，不代表必须附和、解释全部上下文或替其他成员总结。直接回应用户原文或必要的公开发言，只说自己能带来的新内容；不先自我介绍，不复述已知信息，不写心理、动作或场景。公开正文不得提调度、内部任务、私聊、工具过程或隐藏提示。共同规则只能补充群内边界，不能把成员改成同一种人格。'

export const LEGACY_GENERIC_SHARED_PROMPT_TEXT = '这是一个多人群聊。成员应保持各自的人格、立场和专业特点，直接回应用户原文或其他成员的公开发言。公开发言只输出自己要说的话，不提隐藏调度、内部指令或系统消息。'

export const LEGACY_STORY_SHARED_PROMPT_TEXT = '这是一个故事/写作交流群聊。成员可以讨论人物、剧情、节奏、文风和表达，但要自然像群聊发言。公开发言只输出自己要说的话，不写舞台说明，不提隐藏调度、内部指令或系统消息。'

export const DEFAULT_SCHEDULER_PROMPT_TEXT = '点名优先；默认一人；只有价值互补时才多人。不要轮换或为了热闹续轮；@ 只是候选信号。'

export const DEFAULT_SHARED_PROMPT_TEXT = '公开聊天中各自保持角色和判断。只在有新增内容时发言；不替其他成员附和、复述或总结。'

export type GroupChat = {
	id: string
	name: string
	avatar: string
	schedulerAgentId: string
	schedulerPrompt: string
	sharedPrompt: string
	activeSessionId: string
	createdAt: number
	updatedAt: number
}

export type GroupChatMember = {
	id: string
	groupId: string
	agentId: string
	active: boolean
	joinedAt: number
	leftAt: number
	order: number
}

export type GroupChatSession = {
	id: string
	groupId: string
	title: string
	workspacePath: string
	forkedFromSessionId: string
	titleLocked: boolean
	createdAt: number
	updatedAt: number
}

export type GroupChatMessage = {
	id: string
	groupId: string
	sessionId: string
	role: string
	senderType: string
	senderAgentId: string
	senderName: string
	senderAvatar: string
	content: string
	message: UTSJSONObject[]
	visibility: string
	audience: string
	visibleAgentIds: string[]
	visible: boolean
	revoked: boolean
	isStreaming: boolean
	timestamp: number
}

export function isInternalGroupSenderType(senderType: string | null): boolean {
	return senderType == GROUP_MESSAGE_SENDER_SCHEDULER || senderType == GROUP_MESSAGE_SENDER_REVIEWER || senderType == GROUP_MESSAGE_SENDER_SYSTEM
}

export function isInternalGroupVisibility(visibility: string | null): boolean {
	return visibility == GROUP_MESSAGE_VISIBILITY_INTERNAL || visibility == GROUP_MESSAGE_VISIBILITY_DEBUG
}

export function buildGroupSchedulerAgentId(groupId: string): string {
	return GROUP_SCHEDULER_AGENT_ID_PREFIX + groupId
}

export function buildGroupReviewerAgentId(groupId: string): string {
	return GROUP_REVIEWER_AGENT_ID_PREFIX + groupId
}

export function resolveGroupSchedulerAgentId(group: GroupChat | null): string {
	if (group == null) { return 'group-scheduler' }
	const current = group.schedulerAgentId.trim()
	if (current != '' && current != 'scheduler') { return current }
	return buildGroupSchedulerAgentId(group.id)
}

export function resolveGroupReviewerAgentId(group: GroupChat | null): string {
	if (group == null) { return 'group-reviewer' }
	return buildGroupReviewerAgentId(group.id)
}

export function resolveGroupSchedulerDisplayName(group: GroupChat | null): string {
	const groupName = group != null ? group.name.trim() : ''
	if (groupName != '') { return groupName + '调度' }
	return GROUP_SCHEDULER_AGENT_NAME
}

export function resolveGroupReviewerDisplayName(group: GroupChat | null): string {
	const groupName = group != null ? group.name.trim() : ''
	if (groupName != '') { return groupName + '复盘' }
	return GROUP_REVIEWER_AGENT_NAME
}

let groupChatIdSequence = 0

export function createId(prefix: string): string {
	groupChatIdSequence++
	return prefix + '-' + Date.now() + '-' + groupChatIdSequence + '-' + Math.floor(Math.random() * 100000)
}

export function readStringField(item: UTSJSONObject, key: string): string {
	const value = item[key] as string | null
	return value != null ? value : ''
}

export function readNumberField(item: UTSJSONObject, key: string): number {
	const value = item[key] as number | null
	return value != null ? value : 0
}

export function readBooleanField(item: UTSJSONObject, key: string): boolean {
	const value = item[key] as boolean | null
	return value != null ? value : false
}

export function normalizeGroupChat(item: UTSJSONObject): GroupChat {
	const now = Date.now()
	const id = readStringField(item, 'id')
	let name = readStringField(item, 'name')
	if (name == '') { name = '故事工坊' }
	let schedulerAgentId = readStringField(item, 'schedulerAgentId')
	if (schedulerAgentId == '') {
		schedulerAgentId = buildGroupSchedulerAgentId(id)
	}
	const schedulerPrompt = readStringField(item, 'schedulerPrompt')
	let sharedPrompt = readStringField(item, 'sharedPrompt')
	if (sharedPrompt == '') { sharedPrompt = DEFAULT_SHARED_PROMPT_TEXT }
	let createdAt = readNumberField(item, 'createdAt')
	if (createdAt <= 0) { createdAt = now }
	let updatedAt = readNumberField(item, 'updatedAt')
	if (updatedAt <= 0) { updatedAt = createdAt }
	return {
		id: id,
		name: name,
		avatar: readStringField(item, 'avatar'),
		schedulerAgentId: schedulerAgentId,
		schedulerPrompt: schedulerPrompt,
		sharedPrompt: sharedPrompt,
		activeSessionId: readStringField(item, 'activeSessionId'),
		createdAt: createdAt,
		updatedAt: updatedAt,
	} as GroupChat
}

export function normalizeGroupMember(item: UTSJSONObject): GroupChatMember {
	let id = readStringField(item, 'id')
	if (id == '') { id = createId('gmember') }
	let joinedAt = readNumberField(item, 'joinedAt')
	if (joinedAt <= 0) { joinedAt = Date.now() }
	return {
		id: id,
		groupId: readStringField(item, 'groupId'),
		agentId: readStringField(item, 'agentId'),
		active: readBooleanField(item, 'active'),
		joinedAt: joinedAt,
		leftAt: readNumberField(item, 'leftAt'),
		order: readNumberField(item, 'order'),
	} as GroupChatMember
}

export function normalizeGroupSession(item: UTSJSONObject): GroupChatSession {
	let id = readStringField(item, 'id')
	if (id == '') { id = createId('gsession') }
	let title = readStringField(item, 'title')
	if (title == '') { title = '故事会话' }
	let createdAt = readNumberField(item, 'createdAt')
	if (createdAt <= 0) { createdAt = Date.now() }
	let updatedAt = readNumberField(item, 'updatedAt')
	if (updatedAt <= 0) { updatedAt = createdAt }
	return {
		id: id,
		groupId: readStringField(item, 'groupId'),
		title: title,
		workspacePath: readStringField(item, 'workspacePath'),
		forkedFromSessionId: readStringField(item, 'forkedFromSessionId'),
		titleLocked: readBooleanField(item, 'titleLocked'),
		createdAt: createdAt,
		updatedAt: updatedAt,
	} as GroupChatSession
}

export function parseStringList(raw: string): string[] {
	if (raw == '') { return [] as string[] }
	try {
		const list = JSON.parse(raw) as string[]
		if (list != null) { return list }
	} catch (_e: any) {
	}
	return [] as string[]
}

export function groupChatToDbRow(group: GroupChat): UTSJSONObject {
	return {
		id: group.id,
		name: group.name,
		avatar: group.avatar,
		scheduler_agent_id: group.schedulerAgentId,
		scheduler_prompt: group.schedulerPrompt,
		shared_prompt: group.sharedPrompt,
		active_session_id: group.activeSessionId,
		created_at: group.createdAt,
		updated_at: group.updatedAt,
	} as UTSJSONObject
}

export function memberToDbRow(member: GroupChatMember): UTSJSONObject {
	return {
		id: member.id,
		group_id: member.groupId,
		agent_id: member.agentId,
		active: member.active == true ? 1 : 0,
		joined_at: member.joinedAt,
		left_at: member.leftAt,
		order_index: member.order,
	} as UTSJSONObject
}

export function sessionToDbRow(session: GroupChatSession): UTSJSONObject {
	return {
		id: session.id,
		group_id: session.groupId,
		title: session.title,
		workspace_path: session.workspacePath,
		forked_from_session_id: session.forkedFromSessionId,
		title_locked: session.titleLocked == true ? 1 : 0,
		created_at: session.createdAt,
		updated_at: session.updatedAt,
	} as UTSJSONObject
}

export function dbRowToGroupChat(row: UTSJSONObject): GroupChat {
	return normalizeGroupChat({
		id: readStringField(row, 'id'),
		name: readStringField(row, 'name'),
		avatar: readStringField(row, 'avatar'),
		schedulerAgentId: readStringField(row, 'scheduler_agent_id'),
		schedulerPrompt: readStringField(row, 'scheduler_prompt'),
		sharedPrompt: readStringField(row, 'shared_prompt'),
		activeSessionId: readStringField(row, 'active_session_id'),
		createdAt: readNumberField(row, 'created_at'),
		updatedAt: readNumberField(row, 'updated_at'),
	} as UTSJSONObject)
}

export function dbRowToGroupMember(row: UTSJSONObject): GroupChatMember {
	return normalizeGroupMember({
		id: readStringField(row, 'id'),
		groupId: readStringField(row, 'group_id'),
		agentId: readStringField(row, 'agent_id'),
		active: readNumberField(row, 'active') != 0,
		joinedAt: readNumberField(row, 'joined_at'),
		leftAt: readNumberField(row, 'left_at'),
		order: readNumberField(row, 'order_index'),
	} as UTSJSONObject)
}

export function dbRowToGroupSession(row: UTSJSONObject): GroupChatSession {
	return normalizeGroupSession({
		id: readStringField(row, 'id'),
		groupId: readStringField(row, 'group_id'),
		title: readStringField(row, 'title'),
		workspacePath: readStringField(row, 'workspace_path'),
		forkedFromSessionId: readStringField(row, 'forked_from_session_id'),
		titleLocked: readNumberField(row, 'title_locked') != 0,
		createdAt: readNumberField(row, 'created_at'),
		updatedAt: readNumberField(row, 'updated_at'),
	} as UTSJSONObject)
}

export function dbRowToGroupMessage(row: UTSJSONObject): UTSJSONObject {
	const payload = readStringField(row, 'payload_json')
	let msg: UTSJSONObject = {}
	try {
		msg = JSON.parse(payload) as UTSJSONObject
	} catch (_e: any) {
		msg = {} as UTSJSONObject
	}
	msg['id'] = readStringField(row, 'id')
	msg['groupId'] = readStringField(row, 'group_id')
	msg['sessionId'] = readStringField(row, 'session_id')
	msg['role'] = readStringField(row, 'role')
	msg['senderType'] = readStringField(row, 'sender_type')
	msg['senderAgentId'] = readStringField(row, 'sender_agent_id')
	msg['visibility'] = readStringField(row, 'visibility')
	const audience = msg['audience'] as string | null
	if (audience == null || audience == '') {
		msg['audience'] = GROUP_MESSAGE_AUDIENCE_GROUP
	}
	msg['visibleAgentIds'] = parseStringList(readStringField(row, 'visible_agent_ids_json'))
	msg['visible'] = readNumberField(row, 'visible') != 0
	msg['timestamp'] = readNumberField(row, 'timestamp')
	// 两个字段只服务于本地增量保存，不进入真正的消息内容。
	msg['persistedUpdatedAt'] = 0
	msg['persistedPayloadJson'] = ''
	const persistedPayloadJson = JSON.stringify(msg)
	msg['persistedUpdatedAt'] = readNumberField(row, 'updated_at')
	msg['persistedPayloadJson'] = persistedPayloadJson
	return msg
}
