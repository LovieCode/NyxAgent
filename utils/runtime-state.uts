/**
 * 运行期跨页状态。
 *
 * 新路由参数统一写 SQLite，避免继续把临时状态散落到 uni.storage。
 */
import { consumeRuntimeState, deleteRuntimeState, getRuntimeState, setRuntimeState, setRuntimeStatePair } from '@/utils/database.uts'

export const RUNTIME_ACTIVE_AGENT_ID_KEY = 'active_agent_id'
export const RUNTIME_ACTIVE_CONVERSATION_ID_KEY = 'active_conversation_id'
export const RUNTIME_CONTEXT_PREVIEW_PAYLOAD_KEY = 'context_preview_payload'
export const RUNTIME_FILES_INITIAL_PATH_KEY = 'files_initial_path'
export const RUNTIME_MEMORY_AGENT_ID_KEY = 'memory_agent_id'
export const RUNTIME_MEMORY_CONVERSATION_ID_KEY = 'memory_conversation_id'
export const RUNTIME_NYX_FLOAT_VOICE_TEXT_KEY = 'nyx_float_voice_text'
export const RUNTIME_NYX_FLOAT_VOICE_CONTEXT_KEY = 'nyx_float_voice_context'
export const RUNTIME_NYX_FLOAT_POSITION_KEY = 'nyx_float_position'

function saveRuntimeStateValue(key: string, value: string): boolean {
	try {
		return setRuntimeState(key, value)
	} catch (_e: any) {
		return false
	}
}

function removeRuntimeStateValue(key: string): boolean {
	try {
		return deleteRuntimeState(key)
	} catch (_e: any) {
		return false
	}
}

export function setContextPreviewPayload(value: string): boolean {
	return saveRuntimeStateValue(RUNTIME_CONTEXT_PREVIEW_PAYLOAD_KEY, value)
}

export function consumeContextPreviewPayload(): string {
	const value = consumeRuntimeState(RUNTIME_CONTEXT_PREVIEW_PAYLOAD_KEY)
	return value
}

export function setFilesInitialPath(value: string): boolean {
	return saveRuntimeStateValue(RUNTIME_FILES_INITIAL_PATH_KEY, value)
}

export function consumeFilesInitialPath(): string {
	const value = consumeRuntimeState(RUNTIME_FILES_INITIAL_PATH_KEY)
	return value
}

export function setMemoryRouteState(agentId: string, conversationId: string): boolean {
	try {
		return setRuntimeStatePair(RUNTIME_MEMORY_AGENT_ID_KEY, agentId, RUNTIME_MEMORY_CONVERSATION_ID_KEY, conversationId)
	} catch (_e: any) {
		return false
	}
}

export function consumeMemoryRouteAgentId(): string {
	const value = consumeRuntimeState(RUNTIME_MEMORY_AGENT_ID_KEY)
	return value
}

export function consumeMemoryRouteConversationId(): string {
	const value = consumeRuntimeState(RUNTIME_MEMORY_CONVERSATION_ID_KEY)
	return value
}

export function setActiveConversationRuntimeId(value: string): boolean {
	return saveRuntimeStateValue(RUNTIME_ACTIVE_CONVERSATION_ID_KEY, value)
}

export function clearActiveConversationRuntimeId(): boolean {
	return removeRuntimeStateValue(RUNTIME_ACTIVE_CONVERSATION_ID_KEY)
}

export function consumeActiveConversationRuntimeId(): string {
	const value = consumeRuntimeState(RUNTIME_ACTIVE_CONVERSATION_ID_KEY)
	return value
}

export function getActiveAgentRuntimeId(): string {
	const value = getRuntimeState(RUNTIME_ACTIVE_AGENT_ID_KEY)
	return value
}

export function setActiveAgentRuntimeId(value: string): boolean {
	return saveRuntimeStateValue(RUNTIME_ACTIVE_AGENT_ID_KEY, value)
}

export function clearActiveAgentRuntimeId(): boolean {
	return removeRuntimeStateValue(RUNTIME_ACTIVE_AGENT_ID_KEY)
}

export function getActiveConversationRuntimeId(): string {
	const value = getRuntimeState(RUNTIME_ACTIVE_CONVERSATION_ID_KEY)
	return value
}

export function setActiveChatRouteState(agentId: string, conversationId: string): boolean {
	try {
		return setRuntimeStatePair(RUNTIME_ACTIVE_AGENT_ID_KEY, agentId, RUNTIME_ACTIVE_CONVERSATION_ID_KEY, conversationId)
	} catch (_e: any) {
		return false
	}
}

export function setNyxFloatVoiceText(value: string): boolean {
	return saveRuntimeStateValue(RUNTIME_NYX_FLOAT_VOICE_TEXT_KEY, value)
}

export function consumeNyxFloatVoiceText(): string {
	return consumeRuntimeState(RUNTIME_NYX_FLOAT_VOICE_TEXT_KEY)
}

export function setNyxFloatVoiceContext(value: string): boolean {
	return saveRuntimeStateValue(RUNTIME_NYX_FLOAT_VOICE_CONTEXT_KEY, value)
}

export function getNyxFloatVoiceContext(): string {
	return getRuntimeState(RUNTIME_NYX_FLOAT_VOICE_CONTEXT_KEY)
}

export function clearNyxFloatVoiceContext(value: string): boolean {
	let current = ''
	try {
		current = getRuntimeState(RUNTIME_NYX_FLOAT_VOICE_CONTEXT_KEY)
	} catch (_e: any) {
		return false
	}
	if (current == value) {
		return removeRuntimeStateValue(RUNTIME_NYX_FLOAT_VOICE_CONTEXT_KEY)
	}
	return true
}

export function setNyxFloatPosition(value: string): boolean {
	return saveRuntimeStateValue(RUNTIME_NYX_FLOAT_POSITION_KEY, value)
}

export function getNyxFloatPosition(): string {
	return getRuntimeState(RUNTIME_NYX_FLOAT_POSITION_KEY)
}
