/**
 * 事件系统 - Agent 循环事件流
 *
 * 类型定义已迁入 SDK（uni_modules/agent-core/utssdk/types.uts），
 * 本文件仅保留 AgentEventStream 运行时实现，并重导出 SDK 类型以保持向后兼容。
 */

import {
	AgentEvent,
	AgentEventType,
	AgentEventConsumer,
	ToolCallInfo,
	ToolResultInfo,
} from '@/uni_modules/agent-core/utssdk/types.uts'
import { APP_ERROR_CATEGORY_RUNTIME, reportAppError } from '@/utils/app-error.uts'

// 重导出 SDK 类型，业务代码无需改 import 路径
export {
	AgentEvent,
	AgentEventType,
	AgentEventConsumer,
	ToolCallInfo,
	ToolResultInfo,
}

/**
 * Agent 事件流
 * 生产者（llm.uts）push 事件，消费者（UI）消费事件
 */
export class AgentEventStream {
	private queue: AgentEvent[] = []
	private consumers: AgentEventConsumer[] = []
	private _ended: boolean = false
	private _aborted: boolean = false
	private _error: string | null = null
	private abortHandler: (() => void) | null = null

	/** 推送事件 */
	push(event: AgentEvent): void {
		if (this._ended == true) return
		this.queue.push(event)
		this.notifyConsumers()
	}

	/** 结束流 */
	end(): void {
		if (this._ended == true) return
		this.abortHandler = null
		this.push({ type: 'agent_end' })
		this._ended = true
	}

	/** 注册底层任务中断函数 */
	setAbortHandler(handler: (() => void) | null): void {
		this.abortHandler = handler
	}

	/** 中止流：通知消费者结束，然后丢弃后续事件 */
	abort(): void {
		if (this._ended == true) return
		this._aborted = true
		const handler = this.abortHandler
		this.abortHandler = null
		if (handler != null) {
			handler.invoke()
		}
		this.queue.push({ type: 'agent_end' })
		this.notifyConsumers()
		this._ended = true
		this.queue = []
		this.offAll()
	}

	/** 以错误结束 */
	error(message: string): void {
		if (this._ended == true) return
		this.abortHandler = null
		this._error = message
		reportAppError(
			'AGENT_STREAM_FAILED',
			APP_ERROR_CATEGORY_RUNTIME,
			'agent_event_stream',
			'生成失败，请重试',
			message,
			true,
		)
		this.push({ type: 'error', error: message })
		this.push({ type: 'agent_end' })
		this._ended = true
	}

	/** 是否已结束 */
	get ended(): boolean {
		return this._ended
	}

	/** 是否被用户中止 */
	get aborted(): boolean {
		return this._aborted
	}

	/** 错误信息 */
	get errorMessage(): string | null {
		return this._error
	}

	/** 订阅事件 */
	on(consumer: AgentEventConsumer): void {
		this.consumers.push(consumer)
		// 立即投递已排队的事件
		this.notifyConsumers()
	}

	/** 通知所有消费者 */
	private notifyConsumers(): void {
		if (this.consumers.length == 0) return
		while (this.queue.length > 0) {
			const event = this.queue.shift()
			if (event == null) continue
			for (let i = 0; i < this.consumers.length; i++) {
				this.consumers[i](event)
			}
		}
	}

	/** 清空消费者 */
	offAll(): void {
		this.consumers = []
	}
}
