/**
 * 事件系统 - Agent 循环事件流
 * 参考 Pi 的 EventStream 设计，适配 UTS/UniApp-X
 */

// ====== Agent 事件类型定义 ======

/** 工具调用信息 */
export type ToolCallInfo = {
	id: string
	name: string
	arguments: string
}

/** 工具执行结果 */
export type ToolResultInfo = {
	toolCallId: string
	toolName: string
	content: string
	isError: boolean
}

/** Agent 事件类型 */
export type AgentEventType =
	| 'agent_start'
	| 'agent_end'
	| 'turn_start'
	| 'turn_end'
	| 'text_delta'
	| 'text_end'
	| 'tool_call'
	| 'tool_execution_start'
	| 'tool_execution_end'
	| 'error'

/** Agent 事件 */
export type AgentEvent = {
	type: AgentEventType
	/** 文本增量（text_delta 时） */
	text?: string
	/** 完整文本（text_end 时） */
	fullText?: string
	/** assistant 工具调用消息（tool_call 时，用于持久化上下文） */
	toolCalls?: UTSJSONObject[]
	/** 工具调用 ID */
	toolCallId?: string
	/** 工具名称 */
	toolName?: string
	/** 工具参数 */
	toolArgs?: string
	/** 工具结果 */
	toolResult?: string
	/** 工具是否出错 */
	isError?: boolean
	/** 错误信息 */
	error?: string
}

/** 事件消费者回调 */
export type AgentEventConsumer = (event: AgentEvent) => void

/**
 * Agent 事件流
 * 生产者（llm.uts）push 事件，消费者（UI）消费事件
 */
export class AgentEventStream {
	private queue: AgentEvent[] = []
	private consumers: AgentEventConsumer[] = []
	private _ended: boolean = false
	private _aborted: boolean = false
	private _error: string | null = null
	private abortHandler: (() => void) | null = null

	/** 推送事件 */
	push(event: AgentEvent): void {
		if (this._ended) return
		this.queue.push(event)
		this.notifyConsumers()
	}

	/** 结束流 */
	end(): void {
		if (this._ended) return
		this.abortHandler = null
		this.push({ type: 'agent_end' })
		this._ended = true
	}

	/** 注册底层任务中断函数 */
	setAbortHandler(handler: (() => void) | null): void {
		this.abortHandler = handler
	}

	/** 中止流：通知消费者结束，然后丢弃后续事件 */
	abort(): void {
		if (this._ended) return
		this._aborted = true
		const handler = this.abortHandler
		this.abortHandler = null
		if (handler != null) {
			handler.invoke()
		}
		this.queue.push({ type: 'agent_end' })
		this.notifyConsumers()
		this._ended = true
		this.queue = []
		this.offAll()
	}

	/** 以错误结束 */
	error(message: string): void {
		if (this._ended) return
		this.abortHandler = null
		this._error = message
		this.push({ type: 'error', error: message })
		this.push({ type: 'agent_end' })
		this._ended = true
	}

	/** 是否已结束 */
	get ended(): boolean {
		return this._ended
	}

	/** 是否被用户中止 */
	get aborted(): boolean {
		return this._aborted
	}

	/** 错误信息 */
	get errorMessage(): string | null {
		return this._error
	}

	/** 订阅事件 */
	on(consumer: AgentEventConsumer): void {
		this.consumers.push(consumer)
		// 立即投递已排队的事件
		this.notifyConsumers()
	}

	/** 通知所有消费者 */
	private notifyConsumers(): void {
		if (this.consumers.length == 0) return
		while (this.queue.length > 0) {
			const event = this.queue.shift()
			if (event == null) continue
			for (let i = 0; i < this.consumers.length; i++) {
				this.consumers[i](event)
			}
		}
	}

	/** 清空消费者 */
	offAll(): void {
		this.consumers = []
	}
}
