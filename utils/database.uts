/**
 * 数据库工具层 - 基于 laoqianjunzi-sqlite 的本地持久化
 *
 * 管理 providers（提供商）、conversations（对话列表）和 messages（消息）三张表
 */
import {
	ensureAppRuntimeStateTable,
	ensureAppSettingsTable,
	ensureConversationTokenUsageStatsTable,
	ensureGroupChatTables,
	ensureMemoryCompactionStateTable,
	getDb,
	readNumberField,
	readObjectArrayField,
	readStringField,
	rowsToObjects,
} from '@/utils/database-core.uts'
export * from '@/utils/database-group-chat.uts'
export * from '@/utils/database-conversation.uts'

/** 获取当前 SQLite 数据库文件路径，用于 Android 全量 ZIP 备份。 */
export function getDatabaseFilePathForExport(): string {
	// #ifdef APP-ANDROID
	const db = getDb()
	const path = db.getDatabasePath()
	db.close()
	if (path == null) {
		return ''
	}
	return path
	// #endif
	return ''
}

/**
 * 初始化数据库（建表）
 * 在 App 启动时调用
 */
export function initDatabase(): void {
	const db = getDb()

	db.run(
		'CREATE TABLE IF NOT EXISTS conversations (' +
		'id TEXT PRIMARY KEY,' +
		'title TEXT NOT NULL DEFAULT \'\',' +
		'model TEXT NOT NULL DEFAULT \'\',' +
		'agent_id TEXT NOT NULL DEFAULT \'\',' +
		'created_at INTEGER NOT NULL DEFAULT (CAST(strftime(\'%s\',\'now\') AS INTEGER) * 1000),' +
		'updated_at INTEGER NOT NULL DEFAULT (CAST(strftime(\'%s\',\'now\') AS INTEGER) * 1000),' +
		'message_count INTEGER NOT NULL DEFAULT 0,' +
		'preview TEXT NOT NULL DEFAULT \'\')'
	)

	// 兼容旧表：尝试添加 agent_id 列（表已存在时忽略）
	try {
		db.run('ALTER TABLE conversations ADD COLUMN agent_id TEXT NOT NULL DEFAULT \'\'')
	} catch (_e: any) {
		// 列已存在，忽略
	}

	// 兼容旧表：尝试添加 updated_at 列
	try {
		db.run('ALTER TABLE conversations ADD COLUMN updated_at INTEGER NOT NULL DEFAULT 0')
	} catch (_e: any) {
		// 列已存在，忽略
	}

	// 兼容旧表：尝试添加 system_prompt 列
	try {
		db.run('ALTER TABLE conversations ADD COLUMN system_prompt TEXT NOT NULL DEFAULT \'\'')
	} catch (_e: any) {
		// 列已存在，忽略
	}

	db.run(
		'CREATE TABLE IF NOT EXISTS providers (' +
		'id TEXT PRIMARY KEY,' +
		'name TEXT NOT NULL DEFAULT \'\',' +
		'api_base TEXT NOT NULL DEFAULT \'\',' +
		'api_key TEXT NOT NULL DEFAULT \'\',' +
		'models TEXT NOT NULL DEFAULT \'[]\',' +
		'enabled INTEGER NOT NULL DEFAULT 1,' +
		'created_at INTEGER NOT NULL DEFAULT 0,' +
		'updated_at INTEGER NOT NULL DEFAULT 0)'
	)

	db.run(
		'CREATE TABLE IF NOT EXISTS app_settings (' +
		'key TEXT PRIMARY KEY,' +
		'value TEXT NOT NULL DEFAULT \'\')'
	)

	db.run(
		'CREATE TABLE IF NOT EXISTS messages (' +
		'id INTEGER PRIMARY KEY AUTOINCREMENT,' +
		'conversation_id TEXT NOT NULL,' +
		'role TEXT NOT NULL,' +
		'content TEXT NOT NULL DEFAULT \'\',' +
		'timestamp INTEGER NOT NULL,' +
		'extra TEXT NOT NULL DEFAULT \'{}\')'
	)

	ensureConversationTokenUsageStatsTable(db)
	ensureMemoryCompactionStateTable(db)
	ensureAppRuntimeStateTable(db)
	ensureGroupChatTables(db)

	db.run(
		'CREATE TABLE IF NOT EXISTS memory_buffer (' +
		'id TEXT PRIMARY KEY,' +
		'agent_id TEXT NOT NULL DEFAULT \'\',' +
		'person_id TEXT NOT NULL DEFAULT \'\',' +
		'conversation_id TEXT NOT NULL DEFAULT \'\',' +
		'content TEXT NOT NULL DEFAULT \'\',' +
		'updated_at INTEGER NOT NULL DEFAULT 0)'
	)

	db.run(
		'CREATE TABLE IF NOT EXISTS agent_memory_core (' +
		'id TEXT PRIMARY KEY,' +
		'agent_id TEXT NOT NULL DEFAULT \'\',' +
		'person_id TEXT NOT NULL DEFAULT \'\',' +
		'conversation_id TEXT NOT NULL DEFAULT \'\',' +
		'category TEXT NOT NULL DEFAULT \'important\',' +
		'scope TEXT NOT NULL DEFAULT \'manual_only\',' +
		'content TEXT NOT NULL DEFAULT \'\',' +
		'priority INTEGER NOT NULL DEFAULT 3,' +
		'confidence INTEGER NOT NULL DEFAULT 80,' +
		'pinned INTEGER NOT NULL DEFAULT 0,' +
		'archived INTEGER NOT NULL DEFAULT 0,' +
		'created_at INTEGER NOT NULL DEFAULT 0,' +
		'updated_at INTEGER NOT NULL DEFAULT 0,' +
		'last_used_at INTEGER NOT NULL DEFAULT 0,' +
		'use_count INTEGER NOT NULL DEFAULT 0)'
	)

	db.close()
}

/** 覆盖导入数据库核心表。 */
export function importDatabaseTables(
	providers: UTSJSONObject[],
	conversations: UTSJSONObject[],
	messages: UTSJSONObject[],
	appSettings: UTSJSONObject[],
	memoryBuffers: UTSJSONObject[],
	memoryCore: UTSJSONObject[],
	conversationTokenUsageStats: UTSJSONObject[],
	memoryCompactionStates: UTSJSONObject[],
	groupChatData: UTSJSONObject
): void {
	initDatabase()
	const db = getDb()
	ensureGroupChatTables(db)
	db.run('DELETE FROM messages')
	db.run('DELETE FROM conversations')
	db.run('DELETE FROM providers')
	db.run('DELETE FROM app_settings')
	db.run('DELETE FROM memory_buffer')
	db.run('DELETE FROM agent_memory_core')
	db.run('DELETE FROM conversation_token_usage_stats')
	db.run('DELETE FROM agent_memory_compaction_state')
	db.run('DELETE FROM group_chats')
	db.run('DELETE FROM group_chat_members')
	db.run('DELETE FROM group_chat_sessions')
	db.run('DELETE FROM group_chat_messages')
	db.run('DELETE FROM group_agent_context_records')
	db.run('DELETE FROM group_chat_reviews')
	db.run('DELETE FROM group_chat_tasks')
	db.run('DELETE FROM group_agent_memories')
	db.run('DELETE FROM group_agent_metrics')
	db.run('DELETE FROM group_chat_state')

	for (let i = 0; i < providers.length; i++) {
		const item = providers[i]
		db.run(
			'INSERT OR REPLACE INTO providers (id, name, api_base, api_key, models, enabled, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?)',
			[
				readStringField(item, 'id'),
				readStringField(item, 'name'),
				readStringField(item, 'api_base'),
				readStringField(item, 'api_key'),
				readStringField(item, 'models'),
				readNumberField(item, 'enabled'),
				readNumberField(item, 'created_at'),
				readNumberField(item, 'updated_at'),
			]
		)
	}

	for (let i = 0; i < conversations.length; i++) {
		const item = conversations[i]
		db.run(
			'INSERT OR REPLACE INTO conversations (id, title, model, agent_id, system_prompt, created_at, updated_at, message_count, preview) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)',
			[
				readStringField(item, 'id'),
				readStringField(item, 'title'),
				readStringField(item, 'model'),
				readStringField(item, 'agent_id'),
				readStringField(item, 'system_prompt'),
				readNumberField(item, 'created_at'),
				readNumberField(item, 'updated_at'),
				readNumberField(item, 'message_count'),
				readStringField(item, 'preview'),
			]
		)
	}

	for (let i = 0; i < messages.length; i++) {
		const item = messages[i]
		db.run(
			'INSERT INTO messages (conversation_id, role, content, timestamp, extra) VALUES (?, ?, ?, ?, ?)',
			[
				readStringField(item, 'conversation_id'),
				readStringField(item, 'role'),
				readStringField(item, 'content'),
				readNumberField(item, 'timestamp'),
				readStringField(item, 'extra'),
			]
		)
	}

	for (let i = 0; i < appSettings.length; i++) {
		const item = appSettings[i]
		db.run(
			'INSERT OR REPLACE INTO app_settings (key, value) VALUES (?, ?)',
			[readStringField(item, 'key'), readStringField(item, 'value')]
		)
	}

	for (let i = 0; i < memoryBuffers.length; i++) {
		const item = memoryBuffers[i]
		db.run(
			'INSERT OR REPLACE INTO memory_buffer (id, agent_id, person_id, conversation_id, content, updated_at) VALUES (?, ?, ?, ?, ?, ?)',
			[
				readStringField(item, 'id'),
				readStringField(item, 'agent_id'),
				readStringField(item, 'person_id'),
				readStringField(item, 'conversation_id'),
				readStringField(item, 'content'),
				readNumberField(item, 'updated_at'),
			]
		)
	}

	for (let i = 0; i < memoryCore.length; i++) {
		const item = memoryCore[i]
		db.run(
			'INSERT OR REPLACE INTO agent_memory_core (id, agent_id, person_id, conversation_id, category, scope, content, priority, confidence, pinned, archived, created_at, updated_at, last_used_at, use_count) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)',
			[
				readStringField(item, 'id'),
				readStringField(item, 'agent_id'),
				readStringField(item, 'person_id'),
				readStringField(item, 'conversation_id'),
				readStringField(item, 'category'),
				readStringField(item, 'scope'),
				readStringField(item, 'content'),
				readNumberField(item, 'priority'),
				readNumberField(item, 'confidence'),
				readNumberField(item, 'pinned'),
				readNumberField(item, 'archived'),
				readNumberField(item, 'created_at'),
				readNumberField(item, 'updated_at'),
				readNumberField(item, 'last_used_at'),
				readNumberField(item, 'use_count'),
			]
		)
	}
	for (let i = 0; i < conversationTokenUsageStats.length; i++) {
		const item = conversationTokenUsageStats[i]
		db.run(
			'INSERT OR REPLACE INTO conversation_token_usage_stats (conversation_id, prompt_tokens, prompt_cache_hit_tokens, call_count, updated_at) VALUES (?, ?, ?, ?, ?)',
			[
				readStringField(item, 'conversation_id'),
				readNumberField(item, 'prompt_tokens'),
				readNumberField(item, 'prompt_cache_hit_tokens'),
				readNumberField(item, 'call_count'),
				readNumberField(item, 'updated_at'),
			]
		)
	}
	for (let i = 0; i < memoryCompactionStates.length; i++) {
		const item = memoryCompactionStates[i]
		db.run(
			'INSERT OR REPLACE INTO agent_memory_compaction_state (id, agent_id, conversation_id, last_message_key, last_message_timestamp, updated_at) VALUES (?, ?, ?, ?, ?, ?)',
			[
				readStringField(item, 'id'),
				readStringField(item, 'agent_id'),
				readStringField(item, 'conversation_id'),
				readStringField(item, 'last_message_key'),
				readNumberField(item, 'last_message_timestamp'),
				readNumberField(item, 'updated_at'),
			]
		)
	}

	const groupChats = readObjectArrayField(groupChatData, 'groupChats')
	for (let i = 0; i < groupChats.length; i++) {
		const item = groupChats[i]
		db.run(
			'INSERT OR REPLACE INTO group_chats (id, name, avatar, scheduler_agent_id, scheduler_prompt, shared_prompt, active_session_id, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)',
			[
				readStringField(item, 'id'),
				readStringField(item, 'name'),
				readStringField(item, 'avatar'),
				readStringField(item, 'scheduler_agent_id'),
				readStringField(item, 'scheduler_prompt'),
				readStringField(item, 'shared_prompt'),
				readStringField(item, 'active_session_id'),
				readNumberField(item, 'created_at'),
				readNumberField(item, 'updated_at'),
			]
		)
	}
	const groupMembers = readObjectArrayField(groupChatData, 'groupMembers')
	for (let i = 0; i < groupMembers.length; i++) {
		const item = groupMembers[i]
		db.run(
			'INSERT OR REPLACE INTO group_chat_members (id, group_id, agent_id, active, joined_at, left_at, order_index) VALUES (?, ?, ?, ?, ?, ?, ?)',
			[
				readStringField(item, 'id'),
				readStringField(item, 'group_id'),
				readStringField(item, 'agent_id'),
				readNumberField(item, 'active'),
				readNumberField(item, 'joined_at'),
				readNumberField(item, 'left_at'),
				readNumberField(item, 'order_index'),
			]
		)
	}
	const groupSessions = readObjectArrayField(groupChatData, 'groupSessions')
	for (let i = 0; i < groupSessions.length; i++) {
		const item = groupSessions[i]
		db.run(
			'INSERT OR REPLACE INTO group_chat_sessions (id, group_id, title, workspace_path, forked_from_session_id, title_locked, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?)',
			[
				readStringField(item, 'id'),
				readStringField(item, 'group_id'),
				readStringField(item, 'title'),
				readStringField(item, 'workspace_path'),
				readStringField(item, 'forked_from_session_id'),
				readNumberField(item, 'title_locked'),
				readNumberField(item, 'created_at'),
				readNumberField(item, 'updated_at'),
			]
		)
	}
	const groupMessages = readObjectArrayField(groupChatData, 'groupMessages')
	for (let i = 0; i < groupMessages.length; i++) {
		const item = groupMessages[i]
		db.run(
			'INSERT OR REPLACE INTO group_chat_messages (id, group_id, session_id, role, sender_type, sender_agent_id, visibility, visible_agent_ids_json, visible, timestamp, payload_json, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)',
			[
				readStringField(item, 'id'),
				readStringField(item, 'group_id'),
				readStringField(item, 'session_id'),
				readStringField(item, 'role'),
				readStringField(item, 'sender_type'),
				readStringField(item, 'sender_agent_id'),
				readStringField(item, 'visibility'),
				readStringField(item, 'visible_agent_ids_json'),
				readNumberField(item, 'visible'),
				readNumberField(item, 'timestamp'),
				readStringField(item, 'payload_json'),
				readNumberField(item, 'updated_at'),
			]
		)
	}
	const groupContextRecords = readObjectArrayField(groupChatData, 'groupContextRecords')
	for (let i = 0; i < groupContextRecords.length; i++) {
		const item = groupContextRecords[i]
		db.run(
			'INSERT OR REPLACE INTO group_agent_context_records (id, agent_id, group_id, session_id, created_at, payload_json) VALUES (?, ?, ?, ?, ?, ?)',
			[
				readStringField(item, 'id'),
				readStringField(item, 'agent_id'),
				readStringField(item, 'group_id'),
				readStringField(item, 'session_id'),
				readNumberField(item, 'created_at'),
				readStringField(item, 'payload_json'),
			]
		)
	}
	const groupReviews = readObjectArrayField(groupChatData, 'groupReviews')
	for (let i = 0; i < groupReviews.length; i++) {
		const item = groupReviews[i]
		db.run(
			'INSERT OR REPLACE INTO group_chat_reviews (id, group_id, session_id, message_id, summary, continue_advice, payload_json, created_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?)',
			[
				readStringField(item, 'id'),
				readStringField(item, 'group_id'),
				readStringField(item, 'session_id'),
				readStringField(item, 'message_id'),
				readStringField(item, 'summary'),
				readStringField(item, 'continue_advice'),
				readStringField(item, 'payload_json'),
				readNumberField(item, 'created_at'),
			]
		)
	}
	const groupTasks = readObjectArrayField(groupChatData, 'groupTasks')
	for (let i = 0; i < groupTasks.length; i++) {
		const item = groupTasks[i]
		db.run(
			'INSERT OR REPLACE INTO group_chat_tasks (id, group_id, session_id, title, owner_agent_id, participants_json, status, source_review_id, payload_json, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)',
			[
				readStringField(item, 'id'),
				readStringField(item, 'group_id'),
				readStringField(item, 'session_id'),
				readStringField(item, 'title'),
				readStringField(item, 'owner_agent_id'),
				readStringField(item, 'participants_json'),
				readStringField(item, 'status'),
				readStringField(item, 'source_review_id'),
				readStringField(item, 'payload_json'),
				readNumberField(item, 'created_at'),
				readNumberField(item, 'updated_at'),
			]
		)
	}
	const groupMemories = readObjectArrayField(groupChatData, 'groupMemories')
	for (let i = 0; i < groupMemories.length; i++) {
		const item = groupMemories[i]
		db.run(
			'INSERT OR REPLACE INTO group_agent_memories (id, group_id, session_id, agent_id, category, visibility, content, source_review_id, payload_json, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)',
			[
				readStringField(item, 'id'),
				readStringField(item, 'group_id'),
				readStringField(item, 'session_id'),
				readStringField(item, 'agent_id'),
				readStringField(item, 'category'),
				readStringField(item, 'visibility'),
				readStringField(item, 'content'),
				readStringField(item, 'source_review_id'),
				readStringField(item, 'payload_json'),
				readNumberField(item, 'created_at'),
				readNumberField(item, 'updated_at'),
			]
		)
	}
	const groupMetrics = readObjectArrayField(groupChatData, 'groupMetrics')
	for (let i = 0; i < groupMetrics.length; i++) {
		const item = groupMetrics[i]
		db.run(
			'INSERT OR REPLACE INTO group_agent_metrics (id, group_id, session_id, agent_id, speak_count, useful_count, issue_count, memory_count, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)',
			[
				readStringField(item, 'id'),
				readStringField(item, 'group_id'),
				readStringField(item, 'session_id'),
				readStringField(item, 'agent_id'),
				readNumberField(item, 'speak_count'),
				readNumberField(item, 'useful_count'),
				readNumberField(item, 'issue_count'),
				readNumberField(item, 'memory_count'),
				readNumberField(item, 'updated_at'),
			]
		)
	}
	const groupState = readObjectArrayField(groupChatData, 'groupState')
	for (let i = 0; i < groupState.length; i++) {
		const item = groupState[i]
		db.run(
			'INSERT OR REPLACE INTO group_chat_state (key, value, updated_at) VALUES (?, ?, ?)',
			[
				readStringField(item, 'key'),
				readStringField(item, 'value'),
				readNumberField(item, 'updated_at'),
			]
		)
	}
	db.close()
}

function findProviderApiKeyInRows(rows: UTSJSONObject[], id: string): string {
	if (id == '') {
		return ''
	}
	for (let i = 0; i < rows.length; i++) {
		const rowId = rows[i]['id'] as string | null
		if (rowId == id) {
			const apiKey = rows[i]['api_key'] as string | null
			if (apiKey != null) {
				return apiKey
			}
		}
	}
	return ''
}

function findSettingValueInRows(rows: UTSJSONObject[], key: string): string {
	if (key == '') {
		return ''
	}
	for (let i = 0; i < rows.length; i++) {
		const rowKey = rows[i]['key'] as string | null
		if (rowKey == key) {
			const value = rows[i]['value'] as string | null
			if (value != null) {
				return value
			}
		}
	}
	return ''
}

/** 仅覆盖导入配置类表，不触碰对话、消息、记忆和群聊数据。 */
export function importSettingsTables(providers: UTSJSONObject[], appSettings: UTSJSONObject[], preserveEmptyApiKeys: boolean): void {
	initDatabase()
	const db = getDb()
	let oldProviderKeys: UTSJSONObject[] = []
	let oldApiSettings: UTSJSONObject[] = []
	if (preserveEmptyApiKeys == true) {
		oldProviderKeys = rowsToObjects(db.query('SELECT id, api_key FROM providers'))
		oldApiSettings = rowsToObjects(db.query('SELECT key, value FROM app_settings WHERE key = ?', ['settings_api_key']))
	}
	db.run('DELETE FROM providers')
	db.run('DELETE FROM app_settings')

	for (let i = 0; i < providers.length; i++) {
		const item = providers[i]
		const providerId = readStringField(item, 'id')
		let apiKey = readStringField(item, 'api_key')
		if (preserveEmptyApiKeys == true && apiKey == '') {
			apiKey = findProviderApiKeyInRows(oldProviderKeys, providerId)
		}
		db.run(
			'INSERT OR REPLACE INTO providers (id, name, api_base, api_key, models, enabled, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?)',
			[
				providerId,
				readStringField(item, 'name'),
				readStringField(item, 'api_base'),
				apiKey,
				readStringField(item, 'models'),
				readNumberField(item, 'enabled'),
				readNumberField(item, 'created_at'),
				readNumberField(item, 'updated_at'),
			]
		)
	}

	for (let i = 0; i < appSettings.length; i++) {
		const item = appSettings[i]
		const key = readStringField(item, 'key')
		let value = readStringField(item, 'value')
		if (preserveEmptyApiKeys == true && key == 'settings_api_key' && value == '') {
			value = findSettingValueInRows(oldApiSettings, key)
		}
		db.run(
			'INSERT OR REPLACE INTO app_settings (key, value) VALUES (?, ?)',
			[key, value]
		)
	}

	db.close()
}

/** 导出短记忆缓存。 */
export function getAllMemoryBuffersForExport(): UTSJSONObject[] {
	const db = getDb()
	const result = db.query('SELECT * FROM memory_buffer ORDER BY updated_at DESC')
	db.close()
	return rowsToObjects(result)
}

/** 导出 Agent 重要信息库。 */
export function getAllMemoryCoreForExport(): UTSJSONObject[] {
	const db = getDb()
	const result = db.query('SELECT * FROM agent_memory_core ORDER BY updated_at DESC')
	db.close()
	return rowsToObjects(result)
}

/** 导出会话 Token/缓存命中累计统计。 */
export function getAllConversationTokenUsageStatsForExport(): UTSJSONObject[] {
	const db = getDb()
	ensureConversationTokenUsageStatsTable(db)
	const result = db.query('SELECT * FROM conversation_token_usage_stats ORDER BY updated_at DESC')
	db.close()
	return rowsToObjects(result)
}

/** 导出记忆整理游标状态。 */
export function getAllMemoryCompactionStatesForExport(): UTSJSONObject[] {
	const db = getDb()
	ensureMemoryCompactionStateTable(db)
	const result = db.query('SELECT * FROM agent_memory_compaction_state ORDER BY updated_at DESC')
	db.close()
	return rowsToObjects(result)
}

export function getAllGroupChatDataForExport(): UTSJSONObject {
	const db = getDb()
	ensureGroupChatTables(db)
	const groupChats = rowsToObjects(db.query('SELECT * FROM group_chats ORDER BY updated_at DESC'))
	const groupMembers = rowsToObjects(db.query('SELECT * FROM group_chat_members ORDER BY group_id ASC, order_index ASC'))
	const groupSessions = rowsToObjects(db.query('SELECT * FROM group_chat_sessions ORDER BY updated_at DESC'))
	const groupMessages = rowsToObjects(db.query('SELECT * FROM group_chat_messages ORDER BY group_id ASC, session_id ASC, timestamp ASC, updated_at ASC'))
	const groupContextRecords = rowsToObjects(db.query('SELECT * FROM group_agent_context_records ORDER BY created_at DESC'))
	const groupReviews = rowsToObjects(db.query('SELECT * FROM group_chat_reviews ORDER BY created_at DESC'))
	const groupTasks = rowsToObjects(db.query('SELECT * FROM group_chat_tasks ORDER BY updated_at DESC'))
	const groupMemories = rowsToObjects(db.query('SELECT * FROM group_agent_memories ORDER BY updated_at DESC'))
	const groupMetrics = rowsToObjects(db.query('SELECT * FROM group_agent_metrics ORDER BY updated_at DESC'))
	const groupState = rowsToObjects(db.query('SELECT * FROM group_chat_state ORDER BY updated_at DESC'))
	db.close()
	return {
		groupChats: groupChats,
		groupMembers: groupMembers,
		groupSessions: groupSessions,
		groupMessages: groupMessages,
		groupContextRecords: groupContextRecords,
		groupReviews: groupReviews,
		groupTasks: groupTasks,
		groupMemories: groupMemories,
		groupMetrics: groupMetrics,
		groupState: groupState,
	} as UTSJSONObject
}

/**
 * 清空所有数据
 */
export function clearAll(): void {
	const db = getDb()
	ensureConversationTokenUsageStatsTable(db)
	ensureMemoryCompactionStateTable(db)
	db.run('DELETE FROM messages')
	db.run('DELETE FROM conversations')
	db.run('DELETE FROM providers')
	db.run('DELETE FROM memory_buffer')
	db.run('DELETE FROM agent_memory_core')
	db.run('DELETE FROM conversation_token_usage_stats')
	db.run('DELETE FROM agent_memory_compaction_state')
	db.close()
}

/**
 * 获取所有提供商
 */
export function getAllProviders(): UTSJSONObject[] {
	const db = getDb()
	const result = db.query('SELECT * FROM providers ORDER BY enabled DESC, created_at ASC, id ASC')
	db.close()
	return rowsToObjects(result)
}

/**
 * 根据 id 获取单个提供商
 * 用 getAllProviders 替代直接 SQL 查询，避免 Android SingletonList 问题
 */
export function getProviderById(id: string): UTSJSONObject | null {
	const all = getAllProviders()
	for (let i = 0; i < all.length; i++) {
		if ((all[i]['id'] as string) == id) {
			return all[i]
		}
	}
	return null
}

/**
 * 初始化默认提供商（首次使用时填充）
 */
export function initDefaultProviders(): void {
	// 用 getAllProviders 检查，避免 SingletonList 问题
	const existing = getAllProviders()
	if (existing.length > 0) {
		return
	}

	const defaults: UTSJSONObject[] = [
		{ id: 'deepseek', name: 'DeepSeek', api_base: 'https://api.deepseek.com', api_key: '', models: '["deepseek-v4-flash","deepseek-v4-pro"]', enabled: 1 },
		{ id: 'openai', name: 'OpenAI', api_base: 'https://api.openai.com', api_key: '', models: '["gpt-4o","gpt-4o-mini","gpt-4.1","gpt-4.1-mini","gpt-4.1-nano"]', enabled: 0 },
		{ id: 'anthropic', name: 'Anthropic', api_base: 'https://api.anthropic.com', api_key: '', models: '["claude-sonnet-4-20250514","claude-3-5-sonnet-20241022","claude-3-5-haiku-20241022"]', enabled: 0 },
		{ id: 'volcengine', name: '豆包(火山引擎)', api_base: 'https://ark.cn-beijing.volces.com/api/v3', api_key: '', models: '["doubao-seed-1-6-250615","doubao-seed-1-6-flash-250615","doubao-seed-1-6-thinking-250615"]', enabled: 0 },
		{ id: 'xai', name: 'xAI(Grok)', api_base: 'https://api.x.ai', api_key: '', models: '["grok-2","grok-3","grok-3-api"]', enabled: 0 },
		{ id: 'zai', name: '零一万物', api_base: 'https://api.z.ai/api/coding/paas/v4', api_key: '', models: '["glm-5.2","glm-5.1","glm-5-turbo","glm-4.7","glm-4.5-air"]', enabled: 0 },
		{ id: 'kimi-coding', name: 'Kimi', api_base: 'https://api.kimi.com/coding', api_key: '', models: '["k2p7","kimi-for-coding","kimi-k2-thinking"]', enabled: 0 },
		{ id: 'minimax-cn', name: 'MiniMax', api_base: 'https://api.minimaxi.com/anthropic', api_key: '', models: '["MiniMax-M3","MiniMax-M2.7","MiniMax-M2.7-highspeed"]', enabled: 0 },
		{ id: 'xiaomi', name: '小米', api_base: 'https://api.xiaomimimo.com/v1', api_key: '', models: '["mimo-v2.5-pro-ultraspeed","mimo-v2.5-pro","mimo-v2-pro","mimo-v2-omni","mimo-v2-flash"]', enabled: 0 },
		{ id: 'ant-ling', name: '通义千问', api_base: 'https://api.ant-ling.com/v1', api_key: '', models: '["Ring-2.6-1T","Ling-2.6-1T","Ling-2.6-flash"]', enabled: 0 },
		{ id: 'siliconflow', name: '硅基流动', api_base: 'https://api.siliconflow.cn/v1', api_key: '', models: '[]', enabled: 0 },
	]

	const db = getDb()
	const now = Date.now()
	for (let i = 0; i < defaults.length; i++) {
		const p = defaults[i]
		const id: string = p['id'] as string
		const name: string = p['name'] as string
		const apiBase: string = p['api_base'] as string
		const apiKey: string = p['api_key'] as string
		const models: string = p['models'] as string
		const enabled: number = p['enabled'] as number
		db.run(
			'INSERT INTO providers (id, name, api_base, api_key, models, enabled, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?)',
			[id, name, apiBase, apiKey, models, enabled, now, now]
		)
	}
	db.close()
}

/**
 * 保存提供商（插入或替换）
 */
export function saveProvider(
	id: string,
	name: string,
	apiBase: string,
	apiKey: string,
	models: string,
	enabled: boolean
): void {
	const db = getDb()
	const now = Date.now()
	// 用 tableExists 替代 SELECT 查询，避免 Android 单行结果问题
	const tableExists = db.tableExists('providers')
	if (!tableExists) {
		// 表不存在时直接 INSERT
		db.run(
			'INSERT INTO providers (id, name, api_base, api_key, models, enabled, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?)',
			[id, name, apiBase, apiKey, models, enabled ? 1 : 0, now, now]
		)
	} else {
		// 直接用 INSERT OR REPLACE 简化逻辑
		db.run(
			'INSERT OR REPLACE INTO providers (id, name, api_base, api_key, models, enabled, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?)',
			[id, name, apiBase, apiKey, models, enabled ? 1 : 0, now, now]
		)
	}
	db.close()
}

/**
 * 删除提供商
 */
export function deleteProvider(id: string): void {
	const db = getDb()
	db.run('DELETE FROM providers WHERE id = ? AND ? = ?', [id, 1, 1])
	db.close()
}

/**
 * 切换提供商启用状态
 */
export function toggleProvider(id: string, enabled: boolean): void {
	const db = getDb()
	db.run('UPDATE providers SET enabled=?, updated_at=? WHERE id=?', [enabled ? 1 : 0, Date.now(), id])
	db.close()
}

// ==================== 应用设置（SQLite app_settings） ====================

/**
 * 获取应用设置值
 */
export function getAppSetting(key: string): string | null {
	if (key == '') { return null }
	const db = getDb()
	ensureAppSettingsTable(db)
	const result = db.query('SELECT value FROM app_settings WHERE key = ? AND ? = ? LIMIT 1', [key, 1, 1])
	db.close()
	const rows = rowsToObjects(result)
	if (rows.length > 0) {
		const value = rows[0]['value'] as string | null
		if (value != null && value != '') {
			return value
		}
		return null
	}
	return null
}

/**
 * 保存应用设置
 */
export function setAppSetting(key: string, value: string): void {
	if (key == '') { return }
	const db = getDb()
	ensureAppSettingsTable(db)
	if (value == '') {
		db.run('INSERT OR REPLACE INTO app_settings (key, value) VALUES (?, ?)', [key, ''])
	} else {
		db.run('INSERT OR REPLACE INTO app_settings (key, value) VALUES (?, ?)', [key, value])
	}
	db.close()
}

export function removeAppSetting(key: string): void {
	if (key == '') { return }
	const db = getDb()
	ensureAppSettingsTable(db)
	db.run('DELETE FROM app_settings WHERE key = ?', [key])
	db.close()
}

/**
 * 导出 SQLite app_settings 表中的原始设置。
 */
export function getAllAppSettings(): UTSJSONObject[] {
	const db = getDb()
	ensureAppSettingsTable(db)
	const result = db.query('SELECT key, value FROM app_settings ORDER BY key ASC')
	db.close()
	return rowsToObjects(result)
}
