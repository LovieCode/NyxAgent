export function getAllMemoryBuffersForExport(): UTSJSONObject[] {
	const db = getDb()
	const result = db.query('SELECT * FROM memory_buffer ORDER BY updated_at DESC')
	db.close()
	return rowsToObjects(result)
}

/** 导出 Agent 重要信息库。 */
export function getAllMemoryCoreForExport(): UTSJSONObject[] {
	const db = getDb()
	const result = db.query('SELECT * FROM agent_memory_core ORDER BY updated_at DESC')
	db.close()
	return rowsToObjects(result)
