export function saveGroupTaskRow(record: UTSJSONObject): void {
	const now = Date.now()
	const participants = record['participants'] as string[] | null
	const db = getDb()
	ensureGroupChatTables(db)
	db.run(
		'INSERT OR REPLACE INTO group_chat_tasks (id, group_id, session_id, title, owner_agent_id, participants_json, status, source_review_id, payload_json, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)',
		[
			readStringField(record, 'id'),
			readStringField(record, 'groupId'),
			readStringField(record, 'sessionId'),
			readStringField(record, 'title'),
			readStringField(record, 'ownerAgentId'),
			participants != null ? safeJsonArrayForDb(participants) : '[]',
			readStringField(record, 'status') != '' ? readStringField(record, 'status') : 'open',
			readStringField(record, 'sourceReviewId'),
			safeJsonForDb(record),
			readNumberField(record, 'createdAt') > 0 ? readNumberField(record, 'createdAt') : now,
			now,
		]
	)
	db.close()
}

