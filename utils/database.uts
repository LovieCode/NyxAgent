		groupState: groupState,
	} as UTSJSONObject
}

/**
 * 删除某条对话及其消息
 */
export function deleteConversation(id: string): void {
	const db = getDb()
	ensureConversationTokenUsageStatsTable(db)
	ensureMemoryCompactionStateTable(db)
	db.run('DELETE FROM messages WHERE conversation_id = ? AND ? = ?', [id, 1, 1])
	db.run('DELETE FROM conversations WHERE id = ? AND ? = ?', [id, 1, 1])
	db.run('DELETE FROM memory_buffer WHERE conversation_id = ? AND ? = ?', [id, 1, 1])
	db.run('DELETE FROM conversation_token_usage_stats WHERE conversation_id = ? AND ? = ?', [id, 1, 1])
	db.run('DELETE FROM agent_memory_compaction_state WHERE conversation_id = ? AND ? = ?', [id, 1, 1])
	db.run('UPDATE agent_memory_core SET archived = 1, updated_at = ? WHERE conversation_id = ?', [Date.now(), id])
	db.close()
}

/**
 * 清空所有数据
 */
export function clearAll(): void {
	const db = getDb()
	ensureConversationTokenUsageStatsTable(db)
	ensureMemoryCompactionStateTable(db)
	db.run('DELETE FROM messages')
	db.run('DELETE FROM conversations')
	db.run('DELETE FROM providers')
	db.run('DELETE FROM memory_buffer')
	db.run('DELETE FROM agent_memory_core')
	db.run('DELETE FROM conversation_token_usage_stats')
	db.run('DELETE FROM agent_memory_compaction_state')
	db.close()
}

