/**
 * 数据库工具层 - 基于 laoqianjunzi-sqlite 的本地持久化
 *
 * 管理 providers（提供商）、conversations（对话列表）和 messages（消息）三张表
 */
import { xSqlite, SQLiteResult } from '@/uni_modules/laoqianjunzi-sqlite'

/** 数据库文件名 */
const DB_NAME = 'agent_chat.db'

/**
 * 获取数据库实例（自动打开/创建）
 */
function getDb(): xSqlite {
	const db = new xSqlite()
	db.createDb(DB_NAME)
	return db
}

/**
 * 将 SQLite 查询结果的 columns+rows 转换为 UTSJSONObject[]
 * 仅用于多行结果查询（getAllProviders、getConversations、getMessages），
 * 单行结果分别用其他方式处理。
 */
function rowsToObjects(result: SQLiteResult): UTSJSONObject[] {
	const rows = result.rows
	const columns = result.columns
	if (rows == null || columns == null || rows.length == 0) {
		return []
	}
	const list: UTSJSONObject[] = []
	for (let r = 0; r < rows.length; r++) {
		const row = rows[r]
		const obj: UTSJSONObject = {}
		for (let c = 0; c < columns.length; c++) {
			const colName = columns[c]
			const value = row[c]
			if (value != null) {
				obj[colName] = value
			}
		}
		list.push(obj)
	}
	return list
}

/**
 * 初始化数据库（建表）
 * 在 App 启动时调用
 */
export function initDatabase(): void {
	const db = getDb()

	db.run(
		'CREATE TABLE IF NOT EXISTS conversations (' +
		'id TEXT PRIMARY KEY,' +
		'title TEXT NOT NULL DEFAULT \'\',' +
		'model TEXT NOT NULL DEFAULT \'\',' +
		'agent_id TEXT NOT NULL DEFAULT \'\',' +
		'created_at INTEGER NOT NULL DEFAULT (CAST(strftime(\'%s\',\'now\') AS INTEGER) * 1000),' +
		'updated_at INTEGER NOT NULL DEFAULT (CAST(strftime(\'%s\',\'now\') AS INTEGER) * 1000),' +
		'message_count INTEGER NOT NULL DEFAULT 0,' +
		'preview TEXT NOT NULL DEFAULT \'\')'
	)

	// 兼容旧表：尝试添加 agent_id 列（表已存在时忽略）
	try {
		db.run('ALTER TABLE conversations ADD COLUMN agent_id TEXT NOT NULL DEFAULT \'\'')
	} catch (_e: any) {
		// 列已存在，忽略
	}

	// 兼容旧表：尝试添加 updated_at 列
	try {
		db.run('ALTER TABLE conversations ADD COLUMN updated_at INTEGER NOT NULL DEFAULT 0')
	} catch (_e: any) {
		// 列已存在，忽略
	}

	// 兼容旧表：尝试添加 system_prompt 列
	try {
		db.run('ALTER TABLE conversations ADD COLUMN system_prompt TEXT NOT NULL DEFAULT \'\'')
	} catch (_e: any) {
		// 列已存在，忽略
	}

	db.run(
		'CREATE TABLE IF NOT EXISTS providers (' +
		'id TEXT PRIMARY KEY,' +
		'name TEXT NOT NULL DEFAULT \'\',' +
		'api_base TEXT NOT NULL DEFAULT \'\',' +
		'api_key TEXT NOT NULL DEFAULT \'\',' +
		'models TEXT NOT NULL DEFAULT \'[]\',' +
		'enabled INTEGER NOT NULL DEFAULT 1,' +
		'created_at INTEGER NOT NULL DEFAULT 0,' +
		'updated_at INTEGER NOT NULL DEFAULT 0)'
	)

	db.run(
		'CREATE TABLE IF NOT EXISTS app_settings (' +
		'key TEXT PRIMARY KEY,' +
		'value TEXT NOT NULL DEFAULT \'\')'
	)

	db.run(
		'CREATE TABLE IF NOT EXISTS messages (' +
		'id INTEGER PRIMARY KEY AUTOINCREMENT,' +
		'conversation_id TEXT NOT NULL,' +
		'role TEXT NOT NULL,' +
		'content TEXT NOT NULL DEFAULT \'\',' +
		'timestamp INTEGER NOT NULL,' +
		'extra TEXT NOT NULL DEFAULT \'{}\')'
	)

	db.close()
}

/**
 * 保存整条对话（含消息）
 * 先删旧数据，再写新数据，实现覆盖更新
 */
export function saveConversation(
	id: string,
	title: string,
	model: string,
	agentId: string,
	systemPrompt: string,
	messages: UTSJSONObject[]
): void {
	const db = getDb()

	// 取最后一条消息的内容作为预览
	let preview = ''
	if (messages.length > 0) {
		const last = messages[messages.length - 1]
		const c = last['content'] as string | null
		if (c != null) {
			preview = c.length > 50 ? c.substring(0, 50) + '...' : c
		}
	}

	// UPSERT 对话
	const now = Date.now()
	db.run(
		'INSERT OR REPLACE INTO conversations (id, title, model, agent_id, system_prompt, created_at, updated_at, message_count, preview) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)',
		[id, title, model, agentId, systemPrompt, now, now, messages.length, preview]
	)

	// 先删该对话的旧消息
	db.run('DELETE FROM messages WHERE conversation_id = ?', [id])

	// 逐条插入消息
	for (let i = 0; i < messages.length; i++) {
		const msg = messages[i]
		const rawRole = msg['role'] as string | null
		const rawContent = msg['content'] as string | null
		const rawTimestamp = msg['timestamp'] as number | null
		const role = rawRole != null ? rawRole : ''
		const content = rawContent != null ? rawContent : ''
		const timestamp = rawTimestamp != null ? rawTimestamp : now

		// 收集可选字段到 extra
		const extra: UTSJSONObject = {}
		const isStreaming = msg['isStreaming']
		if (isStreaming != null) {
			extra['isStreaming'] = isStreaming
		}
		const isError = msg['isError']
		if (isError != null) {
			extra['isError'] = isError
		}
		const toolName = msg['toolName']
		if (toolName != null) {
			extra['toolName'] = toolName
		}
		const toolStatus = msg['toolStatus']
		if (toolStatus != null) {
			extra['toolStatus'] = toolStatus
		}
		const msgType = msg['msgType']
		if (msgType != null) {
			extra['msgType'] = msgType
		}
		const imageUrl = msg['imageUrl']
		if (imageUrl != null) {
			extra['imageUrl'] = imageUrl
		}
		const toolCallId = msg['tool_call_id']
		if (toolCallId != null) {
			extra['tool_call_id'] = toolCallId
		}
		const camelToolCallId = msg['toolCallId']
		if (camelToolCallId != null) {
			extra['toolCallId'] = camelToolCallId
		}
		const toolCalls = msg['tool_calls']
		if (toolCalls != null) {
			extra['tool_calls'] = toolCalls
		}
		const args = msg['args']
		if (args != null) {
			extra['args'] = args
		}
		const extraStr = JSON.stringify(extra)

		db.run(
			'INSERT INTO messages (conversation_id, role, content, timestamp, extra) VALUES (?, ?, ?, ?, ?)',
			[id, role, content, timestamp, extraStr]
		)
	}

	db.close()
}

/**
 * 获取所有对话列表（按创建时间倒序）
 * 返回 UTSJSONObject[]
 */
export function getConversations(): UTSJSONObject[] {
	const db = getDb()
	const result = db.query(
		'SELECT id, title, model, agent_id, created_at, updated_at, message_count, preview FROM conversations ORDER BY updated_at DESC'
	)
	db.close()
	return rowsToObjects(result)
}

/**
 * 导出所有对话原始字段。
 */
export function getAllConversationsForExport(): UTSJSONObject[] {
	const db = getDb()
	const result = db.query('SELECT * FROM conversations ORDER BY updated_at DESC')
	db.close()
	return rowsToObjects(result)
}

/**
 * 获取某个智能体的对话列表（按创建时间倒序）
 */
export function getConversationsByAgent(agentId: string): UTSJSONObject[] {
	const db = getDb()
	const result = db.query(
		'SELECT id, title, model, agent_id, created_at, updated_at, message_count, preview FROM conversations WHERE agent_id = ? ORDER BY updated_at DESC',
		[agentId]
	)
	db.close()
	return rowsToObjects(result)
}

/**
 * 获取某条对话的所有消息（按时间升序）
 */
export function getMessages(conversationId: string): UTSJSONObject[] {
	const db = getDb()
	const result = db.query(
		'SELECT id, conversation_id, role, content, timestamp, extra FROM messages WHERE conversation_id = ? ORDER BY timestamp ASC',
		[conversationId]
	)
	db.close()

	const rows = rowsToObjects(result)

	// 将 extra JSON 字段合并到返回对象中
	for (let i = 0; i < rows.length; i++) {
		const row = rows[i]
		const extraStr = row['extra'] as string | null
		if (extraStr != null && extraStr != '' && extraStr != '{}') {
			try {
				const extra = JSON.parse(extraStr) as UTSJSONObject
				// 手动合并已知的 extra 字段（UTS 不支持 Object.keys）
				if (extra['isStreaming'] != null) {
					row['isStreaming'] = extra['isStreaming']
				}
				if (extra['isError'] != null) {
					row['isError'] = extra['isError']
				}
				if (extra['toolName'] != null) {
					row['toolName'] = extra['toolName']
				}
				if (extra['toolStatus'] != null) {
					row['toolStatus'] = extra['toolStatus']
				}
				if (extra['msgType'] != null) {
					row['msgType'] = extra['msgType']
				}
				if (extra['imageUrl'] != null) {
					row['imageUrl'] = extra['imageUrl']
				}
				if (extra['tool_call_id'] != null) {
					row['tool_call_id'] = extra['tool_call_id']
				}
				if (extra['toolCallId'] != null) {
					row['toolCallId'] = extra['toolCallId']
				}
				if (extra['tool_calls'] != null) {
					row['tool_calls'] = extra['tool_calls']
				}
				if (extra['args'] != null) {
					row['args'] = extra['args']
				}
			} catch (_e: any) {
				// ignore parse error
			}
		}
	}
	return rows
}

/**
 * 导出所有消息原始字段，包含 extra JSON 字段。
 */
export function getAllMessagesForExport(): UTSJSONObject[] {
	const db = getDb()
	const result = db.query('SELECT * FROM messages ORDER BY conversation_id ASC, timestamp ASC, id ASC')
	db.close()
	return rowsToObjects(result)
}

/**
 * 删除某条对话及其消息
 */
export function deleteConversation(id: string): void {
	const db = getDb()
	db.run('DELETE FROM messages WHERE conversation_id = ?', [id])
	db.run('DELETE FROM conversations WHERE id = ?', [id])
	db.close()
}

/**
 * 清空所有数据
 */
export function clearAll(): void {
	const db = getDb()
	db.run('DELETE FROM messages')
	db.run('DELETE FROM conversations')
	db.run('DELETE FROM providers')
	db.close()
}

/**
 * 更新某个智能体所有历史对话的 system_prompt
 * 当用户在智能体设置中修改了系统提示词后调用
 */
export function updateSystemPromptForAgent(agentId: string, systemPrompt: string): void {
	const db = getDb()
	db.run('UPDATE conversations SET system_prompt = ? WHERE agent_id = ?', [systemPrompt, agentId])
	db.close()
}

/**
 * 获取所有提供商
 */
export function getAllProviders(): UTSJSONObject[] {
	const db = getDb()
	const result = db.query('SELECT * FROM providers ORDER BY enabled DESC, created_at ASC, id ASC')
	db.close()
	return rowsToObjects(result)
}

/**
 * 根据 id 获取单个提供商
 * 用 getAllProviders 替代直接 SQL 查询，避免 Android SingletonList 问题
 */
export function getProviderById(id: string): UTSJSONObject | null {
	const all = getAllProviders()
	for (let i = 0; i < all.length; i++) {
		if ((all[i]['id'] as string) == id) {
			return all[i]
		}
	}
	return null
}

/**
 * 初始化默认提供商（首次使用时填充）
 */
export function initDefaultProviders(): void {
	// 用 getAllProviders 检查，避免 SingletonList 问题
	const existing = getAllProviders()
	if (existing.length > 0) {
		return
	}

	const defaults: UTSJSONObject[] = [
		{ id: 'deepseek', name: 'DeepSeek', api_base: 'https://api.deepseek.com', api_key: '', models: '["deepseek-v4-flash","deepseek-v4-pro"]', enabled: 1 },
		{ id: 'openai', name: 'OpenAI', api_base: 'https://api.openai.com', api_key: '', models: '["gpt-4o","gpt-4o-mini","gpt-4.1","gpt-4.1-mini","gpt-4.1-nano"]', enabled: 0 },
		{ id: 'anthropic', name: 'Anthropic', api_base: 'https://api.anthropic.com', api_key: '', models: '["claude-sonnet-4-20250514","claude-3-5-sonnet-20241022","claude-3-5-haiku-20241022"]', enabled: 0 },
		{ id: 'zai', name: '零一万物', api_base: 'https://api.z.ai/api/coding/paas/v4', api_key: '', models: '["glm-5.2","glm-5.1","glm-5-turbo","glm-4.7","glm-4.5-air"]', enabled: 0 },
		{ id: 'kimi-coding', name: 'Kimi', api_base: 'https://api.kimi.com/coding', api_key: '', models: '["k2p7","kimi-for-coding","kimi-k2-thinking"]', enabled: 0 },
		{ id: 'minimax-cn', name: 'MiniMax', api_base: 'https://api.minimaxi.com/anthropic', api_key: '', models: '["MiniMax-M3","MiniMax-M2.7","MiniMax-M2.7-highspeed"]', enabled: 0 },
		{ id: 'xiaomi', name: '小米', api_base: 'https://api.xiaomimimo.com/v1', api_key: '', models: '["mimo-v2.5-pro-ultraspeed","mimo-v2.5-pro","mimo-v2-pro","mimo-v2-omni","mimo-v2-flash"]', enabled: 0 },
		{ id: 'ant-ling', name: '通义千问', api_base: 'https://api.ant-ling.com/v1', api_key: '', models: '["Ring-2.6-1T","Ling-2.6-1T","Ling-2.6-flash"]', enabled: 0 },
		{ id: 'siliconflow', name: '硅基流动', api_base: 'https://api.siliconflow.cn/v1', api_key: '', models: '[]', enabled: 0 },
	]

	const db = getDb()
	const now = Date.now()
	for (let i = 0; i < defaults.length; i++) {
		const p = defaults[i]
		const id: string = p['id'] as string
		const name: string = p['name'] as string
		const apiBase: string = p['api_base'] as string
		const apiKey: string = p['api_key'] as string
		const models: string = p['models'] as string
		const enabled: number = p['enabled'] as number
		db.run(
			'INSERT INTO providers (id, name, api_base, api_key, models, enabled, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?)',
			[id, name, apiBase, apiKey, models, enabled, now, now]
		)
	}
	db.close()
}

/**
 * 保存提供商（插入或替换）
 */
export function saveProvider(
	id: string,
	name: string,
	apiBase: string,
	apiKey: string,
	models: string,
	enabled: boolean
): void {
	const db = getDb()
	const now = Date.now()
	// 用 tableExists 替代 SELECT 查询，避免 Android 单行结果问题
	const tableExists = db.tableExists('providers')
	if (!tableExists) {
		// 表不存在时直接 INSERT
		db.run(
			'INSERT INTO providers (id, name, api_base, api_key, models, enabled, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?)',
			[id, name, apiBase, apiKey, models, enabled ? 1 : 0, now, now]
		)
	} else {
		// 直接用 INSERT OR REPLACE 简化逻辑
		db.run(
			'INSERT OR REPLACE INTO providers (id, name, api_base, api_key, models, enabled, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?)',
			[id, name, apiBase, apiKey, models, enabled ? 1 : 0, now, now]
		)
	}
	db.close()
}

/**
 * 删除提供商
 */
export function deleteProvider(id: string): void {
	const db = getDb()
	db.run('DELETE FROM providers WHERE id = ?', [id])
	db.close()
}

/**
 * 切换提供商启用状态
 */
export function toggleProvider(id: string, enabled: boolean): void {
	const db = getDb()
	db.run('UPDATE providers SET enabled=?, updated_at=? WHERE id=?', [enabled ? 1 : 0, Date.now(), id])
	db.close()
}

// ==================== 应用设置（基于 uni.storage，避免 SQLite 单行结果问题） ====================

const SETTINGS_PREFIX = 'app_setting_'

/**
 * 获取应用设置值
 */
export function getAppSetting(key: string): string | null {
	const val = uni.getStorageSync(SETTINGS_PREFIX + key) as string
	return (val != null && val != '') ? val : null
}

/**
 * 保存应用设置
 */
export function setAppSetting(key: string, value: string): void {
	uni.setStorageSync(SETTINGS_PREFIX + key, value)
}

/**
 * 导出 SQLite app_settings 表中的原始设置。
 * 当前运行时设置主要走 uni.storage，这里用于兼容旧数据或未来迁移数据。
 */
export function getAllAppSettings(): UTSJSONObject[] {
	const db = getDb()
	const result = db.query('SELECT key, value FROM app_settings ORDER BY key ASC')
	db.close()
	return rowsToObjects(result)
}
