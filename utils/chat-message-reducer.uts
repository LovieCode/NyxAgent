/**
 * 对话消息 reducer
 *
 * AstrBot 风格：message: ChatPart[] 是唯一内容真相。
 * UI blocks、正文、思考过程、工具状态全部由 parts 派生。
 */

import { AgentEvent } from '@/utils/event.uts'
import {
	CHAT_PART_PLAIN,
	CHAT_PART_THINK,
	CHAT_PART_TOOL_CALL,
	CHAT_ROLE_ASSISTANT,
	CHAT_ROLE_USER,
	TOOL_STATUS_PENDING,
	TOOL_STATUS_RUNNING,
	TOOL_STATUS_COMPLETED,
	TOOL_STATUS_ERROR,
	type ChatRuntimeContextOptions,
	cloneParts,
	cloneMessage,
	createAssistantFinalMessage,
	createAssistantStreamingMessage,
	createPlainPart,
	createThinkPart,
	createToolCallItem,
	createToolCallPart,
	createTextMessage,
	extractPlainText,
	getMessageContent,
	getMessageParts,
	getMessageRole,
	getMessageTimestamp,
	isStreamingAssistant,
} from '@/utils/chat-models.uts'

function replaceMessage(messages: UTSJSONObject[], index: number, message: UTSJSONObject): void {
	messages.splice(index, 1, message)
}

function findLastAssistantIndex(messages: UTSJSONObject[]): number {
	for (let i = messages.length - 1; i >= 0; i--) {
		if (getMessageRole(messages[i]) == CHAT_ROLE_ASSISTANT) {
			return i
		}
	}
	return -1
}

function findLastStreamingAssistantIndex(messages: UTSJSONObject[]): number {
	for (let i = messages.length - 1; i >= 0; i--) {
		if (isStreamingAssistant(messages[i]) == true) {
			return i
		}
	}
	return -1
}

function findLastUserText(messages: UTSJSONObject[]): string {
	for (let i = messages.length - 1; i >= 0; i--) {
		const role = getMessageRole(messages[i])
		if (role == CHAT_ROLE_USER) {
			return getMessageContent(messages[i])
		}
	}
	return ''
}

function readToolCallId(toolCall: UTSJSONObject): string {
	const rawId = toolCall['id'] as string | null
	return rawId != null ? rawId : ''
}

function readToolName(toolCall: UTSJSONObject): string {
	const fobj = toolCall['function'] as UTSJSONObject | null
	if (fobj == null) {
		const raw = toolCall['name'] as string | null
		return raw != null ? raw : ''
	}
	const raw = fobj['name'] as string | null
	return raw != null ? raw : ''
}

function readToolArgs(toolCall: UTSJSONObject): string {
	const fobj = toolCall['function'] as UTSJSONObject | null
	if (fobj == null) {
		const raw = toolCall['arguments'] as string | null
		if (raw != null) { return raw }
		const rawArgs = toolCall['args'] as string | null
		return rawArgs != null ? rawArgs : '{}'
	}
	const raw = fobj['arguments'] as string | null
	return raw != null ? raw : '{}'
}

function refreshMessagePreview(message: UTSJSONObject): void {
	const parts = getMessageParts(message)
	message['content'] = extractPlainText(parts)
}

function ensureStreamingAssistant(messages: UTSJSONObject[]): number {
	const lastIdx = messages.length - 1
	if (lastIdx >= 0 && isStreamingAssistant(messages[lastIdx]) == true) {
		return lastIdx
	}
	const now = Date.now()
	messages.push(createAssistantStreamingMessage([] as UTSJSONObject[], now))
	return messages.length - 1
}

function findLastPartIndex(parts: UTSJSONObject[], type: string): number {
	for (let i = parts.length - 1; i >= 0; i--) {
		const partType = parts[i]['type'] as string | null
		if (partType == type) {
			return i
		}
	}
	return -1
}

function hasPlainTextPart(parts: UTSJSONObject[]): boolean {
	for (let i = 0; i < parts.length; i++) {
		const part = parts[i]
		if ((part['type'] as string | null) == CHAT_PART_PLAIN) {
			const text = part['text'] as string | null
			if (text != null && text != '') {
				return true
			}
		}
	}
	return false
}

function hasThinkPart(parts: UTSJSONObject[]): boolean {
	for (let i = 0; i < parts.length; i++) {
		if ((parts[i]['type'] as string | null) == CHAT_PART_THINK) {
			return true
		}
	}
	return false
}

function hasToolCallPart(parts: UTSJSONObject[]): boolean {
	for (let i = 0; i < parts.length; i++) {
		if ((parts[i]['type'] as string | null) == CHAT_PART_TOOL_CALL) {
			return true
		}
	}
	return false
}

function appendPlainPart(parts: UTSJSONObject[], text: string): void {
	if (text == '') { return }
	const lastIdx = parts.length - 1
	if (lastIdx >= 0 && (parts[lastIdx]['type'] as string | null) == CHAT_PART_PLAIN) {
		const oldText = parts[lastIdx]['text'] as string | null
		parts[lastIdx]['text'] = (oldText != null ? oldText : '') + text
		return
	}
	parts.push(createPlainPart(text))
}

function ensurePlainPart(parts: UTSJSONObject[], text: string): void {
	if (text == '') { return }
	if (hasPlainTextPart(parts) == true) { return }
	parts.push(createPlainPart(text))
}

function appendThinkPart(parts: UTSJSONObject[], text: string): void {
	if (text == '') { return }
	const lastIdx = parts.length - 1
	if (lastIdx >= 0 && (parts[lastIdx]['type'] as string | null) == CHAT_PART_THINK) {
		const oldThinking = parts[lastIdx]['think'] as string | null
		parts[lastIdx]['think'] = (oldThinking != null ? oldThinking : '') + text
		return
	}
	parts.push(createThinkPart(text))
}

function ensureThinkPart(parts: UTSJSONObject[], text: string): void {
	if (text == '') { return }
	if (hasThinkPart(parts) == true) { return }
	parts.push(createThinkPart(text))
}

function buildOpenAIToolCall(item: UTSJSONObject): UTSJSONObject {
	const id = item['id'] as string | null
	const name = item['name'] as string | null
	const rawArgs = item['arguments'] as string | null
	return {
		id: id != null ? id : '',
		type: 'function',
		function: {
			name: name != null ? name : '',
			arguments: rawArgs != null ? rawArgs : '{}',
		} as UTSJSONObject,
	} as UTSJSONObject
}

function buildOpenAIToolCallsFromParts(parts: UTSJSONObject[]): UTSJSONObject[] {
	const list: UTSJSONObject[] = []
	for (let i = 0; i < parts.length; i++) {
		const part = parts[i]
		if ((part['type'] as string | null) != CHAT_PART_TOOL_CALL) { continue }
		const calls = part['tool_calls'] as UTSJSONObject[] | null
		if (calls == null) { continue }
		for (let j = 0; j < calls.length; j++) {
			const name = calls[j]['name'] as string | null
			if (name != null && name != '') {
				list.push(buildOpenAIToolCall(calls[j]))
			}
		}
	}
	return list
}

function makeAssistantFromExisting(existing: UTSJSONObject, parts: UTSJSONObject[], streaming: boolean): UTSJSONObject {
	const timestamp = getMessageTimestamp(existing)
	const msg = streaming == true ? createAssistantStreamingMessage(parts, timestamp) : createAssistantFinalMessage(parts, timestamp)
	if ((existing['isError'] as boolean | null) == true) {
		msg['isError'] = true
		const errorMessage = existing['errorMessage'] as string | null
		if (errorMessage != null && errorMessage != '') {
			msg['errorMessage'] = errorMessage
		}
	}
	const toolCalls = buildOpenAIToolCallsFromParts(parts)
	if (toolCalls.length > 0) {
		msg['tool_calls'] = toolCalls
	}
	return msg
}

function buildToolCallItems(toolCalls: UTSJSONObject[] | null, timestamp: number): UTSJSONObject[] {
	const items: UTSJSONObject[] = []
	if (toolCalls == null) {
		return items
	}
	for (let i = 0; i < toolCalls.length; i++) {
		const name = readToolName(toolCalls[i])
		if (name == '') {
			continue
		}
		items.push(createToolCallItem(readToolCallId(toolCalls[i]), name, readToolArgs(toolCalls[i]), timestamp, TOOL_STATUS_PENDING))
	}
	return items
}

function mergeToolCallItem(target: UTSJSONObject, incoming: UTSJSONObject, appendArgs: boolean): void {
	const id = incoming['id'] as string | null
	if (id != null && id != '') { target['id'] = id }
	const name = incoming['name'] as string | null
	if (name != null && name != '') { target['name'] = name }
	const incomingArgs = incoming['arguments'] as string | null
	if (incomingArgs != null && incomingArgs != '') {
		const oldArgs = target['arguments'] as string | null
		target['arguments'] = appendArgs == true ? ((oldArgs != null ? oldArgs : '') + incomingArgs) : incomingArgs
		target['args'] = target['arguments']
	}
	const incomingStatus = incoming['status'] as string | null
	if (incomingStatus != null && incomingStatus != '') { target['status'] = incomingStatus }
	const incomingResult = incoming['result'] as string | null
	if (incomingResult != null && incomingResult != '') { target['result'] = incomingResult }
	const incomingError = incoming['isError'] as boolean | null
	if (incomingError != null) { target['isError'] = incomingError }
}

function matchToolItem(item: UTSJSONObject, id: string, name: string): boolean {
	const itemId = item['id'] as string | null
	const itemName = item['name'] as string | null
	if (id != '' && itemId != null && itemId == id) { return true }
	if (name != '' && itemName != null && itemName == name) { return true }
	return false
}


function mergeTrailingToolDelta(parts: UTSJSONObject[], incoming: UTSJSONObject): boolean {
	const incomingName = incoming['name'] as string | null
	const name = incomingName != null ? incomingName : ''
	if (name == '') { return false }
	for (let i = parts.length - 1; i >= 0; i--) {
		const part = parts[i]
		if ((part['type'] as string | null) != CHAT_PART_TOOL_CALL) { continue }
		const calls = part['tool_calls'] as UTSJSONObject[] | null
		if (calls == null) { continue }
		for (let j = calls.length - 1; j >= 0; j--) {
			const item = calls[j]
			const itemName = item['name'] as string | null
			const itemId = item['id'] as string | null
			if (itemName != null && itemName == name && itemId != null && itemId.startsWith('tool_delta_')) {
				mergeToolCallItem(item, incoming, false)
				return true
			}
		}
	}
	return false
}

function upsertToolCallPart(parts: UTSJSONObject[], incoming: UTSJSONObject, appendArgs: boolean): void {
	const id = incoming['id'] as string | null
	const name = incoming['name'] as string | null
	const safeId = id != null ? id : ''
	const safeName = name != null ? name : ''
	if (safeId == '' && safeName == '') { return }
	for (let i = 0; i < parts.length; i++) {
		const part = parts[i]
		if ((part['type'] as string | null) != CHAT_PART_TOOL_CALL) { continue }
		const calls = part['tool_calls'] as UTSJSONObject[] | null
		if (calls == null) { continue }
		for (let j = 0; j < calls.length; j++) {
			if (matchToolItem(calls[j], safeId, safeName) == true) {
				mergeToolCallItem(calls[j], incoming, appendArgs)
				return
			}
		}
	}
	if (appendArgs == false && mergeTrailingToolDelta(parts, incoming) == true) {
		return
	}
	const lastIdx = parts.length - 1
	if (lastIdx >= 0 && (parts[lastIdx]['type'] as string | null) == CHAT_PART_TOOL_CALL) {
		const calls = parts[lastIdx]['tool_calls'] as UTSJSONObject[] | null
		if (calls != null) {
			calls.push(incoming)
			return
		}
	}
	parts.push(createToolCallPart([incoming]))
}

function updateToolCallState(parts: UTSJSONObject[], toolCallId: string, toolName: string, result: string, isError: boolean, status: string): boolean {
	for (let i = parts.length - 1; i >= 0; i--) {
		const part = parts[i]
		if ((part['type'] as string | null) != CHAT_PART_TOOL_CALL) { continue }
		const calls = part['tool_calls'] as UTSJSONObject[] | null
		if (calls == null) { continue }
		for (let j = calls.length - 1; j >= 0; j--) {
			const item = calls[j]
			if (matchToolItem(item, toolCallId, toolName) == true) {
				if (toolCallId != '') { item['id'] = toolCallId }
				if (toolName != '') { item['name'] = toolName }
				item['status'] = status
				if (status == TOOL_STATUS_RUNNING) {
					item['ts'] = Date.now()
				}
				if (status == TOOL_STATUS_COMPLETED || status == TOOL_STATUS_ERROR) {
					item['finished_ts'] = Date.now()
					item['result'] = result
					item['isError'] = isError
				}
				return true
			}
		}
	}
	return false
}

export function pushUserTextMessage(messages: UTSJSONObject[], content: string): void {
	messages.push(createTextMessage(CHAT_ROLE_USER, content))
}

export function deleteChatMessage(messages: UTSJSONObject[], index: number): void {
	if (index < 0 || index >= messages.length) {
		return
	}
	messages.splice(index, 1)
}

export function updateChatMessageContent(messages: UTSJSONObject[], index: number, content: string): void {
	if (index < 0 || index >= messages.length) {
		return
	}
	const msg = cloneMessage(messages[index])
	msg['content'] = content
	msg['message'] = [createPlainPart(content)]
	replaceMessage(messages, index, msg)
}

export function truncateAfterMessage(messages: UTSJSONObject[], index: number): void {
	if (index < 0 || index >= messages.length) {
		return
	}
	messages.splice(index + 1, messages.length - index - 1)
}

export function truncateFromMessage(messages: UTSJSONObject[], index: number): string {
	if (index < 0 || index >= messages.length) {
		return ''
	}
	messages.splice(index, messages.length - index)
	return findLastUserText(messages)
}

export function saveEditAndFindLastUserText(messages: UTSJSONObject[], index: number, content: string): string {
	updateChatMessageContent(messages, index, content)
	truncateAfterMessage(messages, index)
	return findLastUserText(messages)
}

export function buildRuntimeMessages(messages: UTSJSONObject[], options: ChatRuntimeContextOptions): UTSJSONObject[] {
	const runtimeMessages: UTSJSONObject[] = []
	let lastUserIndex = -1
	for (let i = 0; i < messages.length; i++) {
		if ((messages[i]['isError'] as boolean | null) == true && getMessageRole(messages[i]) == CHAT_ROLE_ASSISTANT) {
			continue
		}
		const copied = cloneMessage(messages[i])
		runtimeMessages.push(copied)
		if (getMessageRole(copied) == CHAT_ROLE_USER) {
			lastUserIndex = i
		}
	}
	if (lastUserIndex >= 0 && lastUserIndex < runtimeMessages.length) {
		const target = runtimeMessages[lastUserIndex]
		let changed = false
		if (options.injectDatetime == true) {
			target['agent_current_time_context'] = options.datetimePrefix
			changed = true
		}
		const interactionRules = options.interactionRules.trim()
		if (interactionRules != '') {
			target['agent_interaction_rules_context'] = interactionRules
			changed = true
		}
		if (changed == true) {
			runtimeMessages.splice(lastUserIndex, 1, target)
		}
	}
	return runtimeMessages
}

export function appendAssistantDelta(messages: UTSJSONObject[], text: string): void {
	if (text == '') {
		return
	}
	const idx = ensureStreamingAssistant(messages)
	const existing = messages[idx]
	const parts = cloneParts(getMessageParts(existing))
	appendPlainPart(parts, text)
	replaceMessage(messages, idx, makeAssistantFromExisting(existing, parts, true))
}

export function finishAssistantMessage(messages: UTSJSONObject[], response: string): void {
	let idx = findLastStreamingAssistantIndex(messages)
	if (idx < 0) {
		if (response == '') { return }
		idx = ensureStreamingAssistant(messages)
	}
	const existing = messages[idx]
	const parts = cloneParts(getMessageParts(existing))
	ensurePlainPart(parts, response)
	const next = makeAssistantFromExisting(existing, parts, true)
	refreshMessagePreview(next)
	replaceMessage(messages, idx, next)
}

export function markAssistantMessageError(messages: UTSJSONObject[], errorMessage: string): void {
	const detail = errorMessage.trim() != '' ? errorMessage.trim() : '未知错误'
	const idx = ensureStreamingAssistant(messages)
	const existing = messages[idx]
	const parts = cloneParts(getMessageParts(existing))
	parts.push(createPlainPart('请求失败：' + detail))
	const next = makeAssistantFromExisting(existing, parts, true)
	next['isError'] = true
	next['errorMessage'] = detail
	refreshMessagePreview(next)
	replaceMessage(messages, idx, next)
}

export function appendThinkingDelta(messages: UTSJSONObject[], text: string): void {
	if (text == '') {
		return
	}
	const idx = ensureStreamingAssistant(messages)
	const existing = messages[idx]
	const parts = cloneParts(getMessageParts(existing))
	appendThinkPart(parts, text)
	replaceMessage(messages, idx, makeAssistantFromExisting(existing, parts, true))
}

export function finishAssistantThinking(messages: UTSJSONObject[], text: string): void {
	if (text == '') { return }
	const idx = ensureStreamingAssistant(messages)
	const existing = messages[idx]
	const parts = cloneParts(getMessageParts(existing))
	ensureThinkPart(parts, text)
	replaceMessage(messages, idx, makeAssistantFromExisting(existing, parts, true))
}

export function appendToolCallBlockToAssistant(messages: UTSJSONObject[], name: string, args: string, toolCallId: string = ''): void {
	if (name == '' && toolCallId == '') {
		return
	}
	const idx = ensureStreamingAssistant(messages)
	const existing = messages[idx]
	const parts = cloneParts(getMessageParts(existing))
	const item = createToolCallItem(toolCallId, name, args, Date.now(), TOOL_STATUS_PENDING)
	upsertToolCallPart(parts, item, true)
	replaceMessage(messages, idx, makeAssistantFromExisting(existing, parts, true))
}

export function addToolCallMessage(messages: UTSJSONObject[], fullText: string, toolCalls: UTSJSONObject[] | null): void {
	if ((toolCalls == null || toolCalls.length == 0) && fullText == '') {
		return
	}
	const idx = ensureStreamingAssistant(messages)
	const existing = messages[idx]
	const parts = cloneParts(getMessageParts(existing))
	ensurePlainPart(parts, fullText)
	const now = Date.now()
	const items = buildToolCallItems(toolCalls, now)
	for (let i = 0; i < items.length; i++) {
		upsertToolCallPart(parts, items[i], false)
	}
	const next = makeAssistantFromExisting(existing, parts, true)
	if (toolCalls != null && toolCalls.length > 0) {
		next['tool_calls'] = toolCalls
	}
	refreshMessagePreview(next)
	replaceMessage(messages, idx, next)
}

export function addToolExecutionStart(messages: UTSJSONObject[], toolName: string, toolCallId: string = ''): void {
	if (toolName == '' && toolCallId == '') {
		return
	}
	const assistantIdx = findLastStreamingAssistantIndex(messages)
	if (assistantIdx < 0) {
		return
	}
	const assistantMsg = messages[assistantIdx]
	const parts = cloneParts(getMessageParts(assistantMsg))
	const updated = updateToolCallState(parts, toolCallId, toolName, '', false, TOOL_STATUS_RUNNING)
	if (updated == false && toolName != '') {
		const item = createToolCallItem(toolCallId, toolName, '{}', Date.now(), TOOL_STATUS_RUNNING)
		upsertToolCallPart(parts, item, false)
	}
	replaceMessage(messages, assistantIdx, makeAssistantFromExisting(assistantMsg, parts, true))
}

export function updateToolExecutionEnd(messages: UTSJSONObject[], toolName: string, result: string, isError: boolean, keepStreaming: boolean = true, toolCallId: string = ''): void {
	if (toolName == '' && toolCallId == '') {
		return
	}
	const assistantIdx = findLastStreamingAssistantIndex(messages)
	if (assistantIdx < 0) {
		return
	}
	const assistantMsg = messages[assistantIdx]
	const parts = cloneParts(getMessageParts(assistantMsg))
	const status = isError == true ? TOOL_STATUS_ERROR : TOOL_STATUS_COMPLETED
	const updated = updateToolCallState(parts, toolCallId, toolName, result, isError, status)
	if (updated == false && toolName != '') {
		const item = createToolCallItem(toolCallId, toolName, '{}', Date.now(), status)
		item['finished_ts'] = Date.now()
		item['result'] = result
		item['isError'] = isError
		upsertToolCallPart(parts, item, false)
	}
	replaceMessage(messages, assistantIdx, makeAssistantFromExisting(assistantMsg, parts, keepStreaming))
}

export function finalizeAssistantTurn(messages: UTSJSONObject[], _msgSegmentation: boolean = false): void {
	const assistantIdx = findLastAssistantIndex(messages)
	if (assistantIdx < 0) {
		return
	}
	const assistantMsg = messages[assistantIdx]
	if ((assistantMsg['isStreaming'] as boolean | null) != true) {
		return
	}
	const parts = cloneParts(getMessageParts(assistantMsg))
	replaceMessage(messages, assistantIdx, makeAssistantFromExisting(assistantMsg, parts, false))
}

export function finalizeAgentLoopTurn(messages: UTSJSONObject[]): void {
	const assistantIdx = findLastAssistantIndex(messages)
	if (assistantIdx < 0) {
		return
	}
	const assistantMsg = messages[assistantIdx]
	if ((assistantMsg['isStreaming'] as boolean | null) != true) {
		return
	}
	const parts = getMessageParts(assistantMsg)
	// 空响应 + 工具调用是 AstrBot 的合法中间态：保持在同一个 thinking timeline。
	if (hasPlainTextPart(parts) == false && hasToolCallPart(parts) == true) {
		return
	}
	finalizeAssistantTurn(messages)
}

export function reduceAgentEvent(messages: UTSJSONObject[], event: AgentEvent): boolean {
	if (event.type == 'turn_start') {
		finalizeAgentLoopTurn(messages)
		return true
	}
	if (event.type == 'text_delta') {
		appendAssistantDelta(messages, event.text != null ? (event.text as string) : '')
		return true
	}
	if (event.type == 'text_end') {
		finishAssistantMessage(messages, event.fullText != null ? (event.fullText as string) : '')
		return true
	}
	if (event.type == 'thinking_delta') {
		appendThinkingDelta(messages, event.thinkingText != null ? (event.thinkingText as string) : '')
		return true
	}
	if (event.type == 'thinking_end') {
		finishAssistantThinking(messages, event.fullThinking != null ? (event.fullThinking as string) : '')
		return true
	}
	if (event.type == 'tool_call') {
		if (event.toolName != null && event.toolCalls == null) {
			appendToolCallBlockToAssistant(
				messages,
				event.toolName as string,
				event.toolArgs != null ? (event.toolArgs as string) : '{}',
				event.toolCallId != null ? (event.toolCallId as string) : ''
			)
		} else {
			addToolCallMessage(messages, event.fullText != null ? (event.fullText as string) : '', event.toolCalls != null ? (event.toolCalls as UTSJSONObject[]) : null)
		}
		return true
	}
	if (event.type == 'tool_execution_start') {
		addToolExecutionStart(
			messages,
			event.toolName != null ? (event.toolName as string) : '',
			event.toolCallId != null ? (event.toolCallId as string) : ''
		)
		return true
	}
	if (event.type == 'tool_execution_end') {
		updateToolExecutionEnd(
			messages,
			event.toolName != null ? (event.toolName as string) : '',
			event.toolResult != null ? (event.toolResult as string) : '',
			event.isError == true,
			true,
			event.toolCallId != null ? (event.toolCallId as string) : ''
		)
		return true
	}
	if (event.type == 'turn_end') {
		finalizeAgentLoopTurn(messages)
		return true
	}
	if (event.type == 'error') {
		markAssistantMessageError(messages, event.error != null ? (event.error as string) : '未知错误')
		return true
	}
	return false
}
